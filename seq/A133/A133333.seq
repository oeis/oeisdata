%N A133333 Irregular triangle read by rows: coefficients of polynomial (x^(n-1) - (1+x+...+x^(n-2))) ^ (n+1).
%H A133333 Warren P. Johnson, <a href="https://www.jstor.org/stable/27642326">Mathematics and Social Utopias in France: Olinde Rodrigues and His times by Simon Altmann; Eduardo L. Ortiz</a>, American Math. Monthly, Oct 2007, volume 114, number 8, pages 752-758.
%e A133333 Triangle begins:
%e A133333   {1},
%e A133333   {-1, 3, -3, 1},
%e A133333   {1, 4, 2, -8, -5, 8, 2, -4, 1},
%e A133333   {-1, -5, -15, -25, -25, -1, 25, 35, 5, -15, -21, 5, 5, 5, -5, 1},
%e A133333   {1, 6, 21, 56, 114, 186, 246, 246, 171, 34, -114, -174, -149, -54, 54, 66, 51, 6, -34, -6, -6, 4, 9, -6, 1},
%e A133333   {-1, -7, -28, -84, -210, -448, -833, -1373, -2023, -2653, -3094, -3178, -2793, -1953, -883, 161, 917, 1197, 987, 567, 91, -253, -343, -203, -98, 28, 91, 63, -15, 7, -14, -14, 0, 14, -7, 1},
%e A133333   ...
%t A133333 f[q_, n_] = q^(n - 1) - Sum[q^i, {i, 0, n - 2}];
%t A133333 a = Table[CoefficientList[f[x, n]^(n+1), x], {n, 6}];
%t A133333 Flatten[a]
