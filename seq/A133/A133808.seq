%S A133808 1,2,4,6,8,16,18,30,32,36,54,64,108,128,150,162,210,216,256,324,450,
%T A133808 486,512,648,750,900,972,1024,1296,1458,1470,1944,2048,2250,2310,2916,
%U A133808 3750,3888,4096,4374,4500,5832,6750,7350,7776,8192,8748,10290,11250
%N A133808 Numbers that are primally tight, have 2 as first prime and weakly ascending powers.
%C A133808 All numbers of the form 2^k1*p_2^k2*...*p_n^k_n, where k1 <= k2 <= ... <= k_n and the p_i are the n first primes.
%C A133808 Subset of A073491, A133810.
%H A133808 Reinhard Zumkeller, <a href="/A133808/b133808.txt">Table of n, a(n) for n = 1..10000</a>
%e A133808 10 = 2*5 with missing prime factor 3 between 2 and 5 is not in the sequence.
%e A133808 12 = 2^2*3 with 2's exponent > 3's exponent is not in the sequence.
%o A133808 (PARI) isok(n) = {my(f = factor(n)); my(nbf = #f~); if (prod(i=1, nbf, prime(i)) ! = prod(i=1, nbf, f[i, 1]), return (0)); for (j=2, nbf, if (f[j,2] < f[j-1,2], return (0));); return (1);} \\ _Michel Marcus_, Jun 04 2014
%o A133808 (Haskell)
%o A133808 import Data.Set (singleton, deleteFindMin, insert)
%o A133808 a133808 n = a133808_list !! (n-1)
%o A133808 a133808_list = 1 : f (singleton (2, 2, 1)) where
%o A133808    f s = y : f (insert (y * p, p, e + 1) $ insert (y * q^e, q, e) s')
%o A133808              where q = a151800 p
%o A133808                    ((y, p, e), s') = deleteFindMin s
%o A133808 -- _Reinhard Zumkeller_, Apr 13 2015
%o A133808 (Python)
%o A133808 from functools import lru_cache
%o A133808 from itertools import count
%o A133808 from sympy import prime, integer_log, primorial
%o A133808 from oeis_sequences.OEISsequences import bisection
%o A133808 def A133808(n):
%o A133808     @lru_cache(maxsize=None)
%o A133808     def g(x, m, j): return sum(g(x//(prime(m)**i), m-1, i) for i in range(1,min(j,integer_log(x, prime(m))[0])+1)) if m-1 else min(j,x.bit_length()-1)
%o A133808     def f(x):
%o A133808         c = n-1+x
%o A133808         for k in count(1):
%o A133808             if primorial(k)>x:
%o A133808                 break
%o A133808             c -= g(x,k,integer_log(x,prime(k))[0])
%o A133808         return c
%o A133808     return bisection(f,n,n) # _Chai Wah Wu_, Mar 23 2026
%o A133808 (Python)
%o A133808 from heapq import heappop, heappush
%o A133808 from sympy import factorint, nextprime
%o A133808 def A133808_gen(): # generator of terms if the first n terms are desired
%o A133808     h, hset = [1], {1}
%o A133808     while True:
%o A133808         yield (m:=heappop(h))
%o A133808         ps = factorint(m)
%o A133808         for p in ps:
%o A133808             if p == max(ps) or ps[nextprime(p)]>ps[p]:
%o A133808                 mp = m*p
%o A133808                 if mp not in hset:
%o A133808                     heappush(h,mp)
%o A133808                     hset.add(mp)
%o A133808         mp = 2 if m==1 else m*nextprime(a:=max(ps.keys()))**ps[a]
%o A133808         if mp not in hset:
%o A133808             heappush(h,mp)
%o A133808             hset.add(mp)
%o A133808 A133808_list = list(islice(A133808_gen(),40)) # _Chai Wah Wu_, Mar 23 2026
