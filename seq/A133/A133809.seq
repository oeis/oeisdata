%I A133809 #19 Mar 25 2026 00:00:32
%S A133809 1,2,4,8,16,18,32,54,64,108,128,162,256,324,486,512,648,972,1024,1458,
%T A133809 1944,2048,2250,2916,3888,4096,4374,5832,8192,8748,11250,11664,13122,
%U A133809 16384,17496,23328,26244,32768,33750,34992,39366,52488,56250,65536
%N A133809 Numbers that are primally tight, have 2 as first prime and strictly ascending powers.
%C A133809 All numbers of the form 2^k1*p_2^k2*...*p_n^k_n, where k1 < k2 < ... < k_n and the p_i are the n first primes.
%C A133809 Subset of A073491, A133811 and A133808.
%H A133809 Reinhard Zumkeller, <a href="/A133809/b133809.txt">Table of n, a(n) for n = 1..10000</a>
%e A133809 36 = 2^2*3^2 with both exponents being equal is not in the sequence.
%o A133809 (PARI) isok(n) = {my(f = factor(n)); my(nbf = #f~); if (prod(i=1, nbf, prime(i)) ! = prod(i=1, nbf, f[i, 1]), return (0)); for (j=2, nbf, if (f[j,2] <= f[j-1,2], return (0));); return (1);} \\ _Michel Marcus_, Jun 04 2014
%o A133809 (Haskell)
%o A133809 import Data.Set (singleton, deleteFindMin, insert)
%o A133809 a133809 n = a133809_list !! (n-1)
%o A133809 a133809_list = 1 : f (singleton (2, 2, 1)) where
%o A133809    f s = y : f (insert (y*p, p, e+1) $ insert (y*q^(e+1), q, e+1) s')
%o A133809              where q = a151800 p
%o A133809                    ((y, p, e), s') = deleteFindMin s
%o A133809 -- _Reinhard Zumkeller_, Apr 14 2015
%o A133809 (Python)
%o A133809 from math import prod
%o A133809 from functools import lru_cache
%o A133809 from itertools import count
%o A133809 from sympy import prime, integer_log
%o A133809 from oeis_sequences.OEISsequences import bisection
%o A133809 def A133809(n):
%o A133809     @lru_cache(maxsize=None)
%o A133809     def A076954(n): return prod(prime(k)**k for k in range(1,n+1))
%o A133809     @lru_cache(maxsize=None)
%o A133809     def g(x, m, j): return sum(g(x//(prime(m)**i), m-1, i) for i in range(1,min(j-1,integer_log(x, prime(m))[0])+1)) if m-1 else min(j,x.bit_length())-1
%o A133809     def f(x):
%o A133809         c = n-1+x
%o A133809         for k in count(1):
%o A133809             if A076954(k)>x:
%o A133809                 break
%o A133809             c -= g(x,k,integer_log(x,prime(k))[0]+1)
%o A133809         return c
%o A133809     return bisection(f,n,n) # _Chai Wah Wu_, Mar 23 2026
%o A133809 (Python)
%o A133809 from itertools import islice
%o A133809 from heapq import heappop, heappush
%o A133809 from sympy import factorint, nextprime
%o A133809 def A133809_gen(): # generator of terms if the first n terms are desired
%o A133809     h, hset = [1], {1}
%o A133809     while True:
%o A133809         yield (m:=heappop(h))
%o A133809         ps = factorint(m)
%o A133809         for p in ps:
%o A133809             if p == max(ps) or ps[nextprime(p)]>ps[p]+1:
%o A133809                 mp = m*p
%o A133809                 if mp not in hset:
%o A133809                     heappush(h,mp)
%o A133809                     hset.add(mp)
%o A133809         mp = 2 if m==1 else m*nextprime(a:=max(ps.keys()))**(ps[a]+1)
%o A133809         if mp not in hset:
%o A133809             heappush(h,mp)
%o A133809             hset.add(mp)
%o A133809 A133809_list = list(islice(A133809_gen(),40)) # _Chai Wah Wu_, Mar 23 2026
%Y A133809 Cf. A025487, A087980, A073491, A133808-A133813.
%Y A133809 Cf. A027748, A124010, A151800, A000040, A145108 (subsequence).
