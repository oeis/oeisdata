%I A085482 #18 May 29 2026 01:10:14
%S A085482 54,13824,354294,3538944,21093750,90699264,311299254,905969664,
%T A085482 2324522934,5400000000,11575379574,23219011584,44049458934,
%U A085482 79692609024,138396093750,231928233984,376690901814,595077871104,917112404214
%N A085482 Product of three solutions of the Diophantine equation x^2 - y^2 = z^3.
%C A085482 Parametric representation of the solution is (x,y,z) = (6*n^3, 3*n^3, 3*n^2), thus getting a(n) = 54*n^8.
%H A085482 <a href="/index/Rec#order_09">Index entries for linear recurrences with constant coefficients</a>, signature (9,-36,84,-126,126,-84,36,-9,1).
%F A085482 a(n) = 54*n^8.
%F A085482 a(n) = 9*a(n-1) - 36*a(n-2) + 84*a(n-3) - 126*a(n-4) + 126*a(n-5) - 84*a(n-6) + 36*a(n-7) - 9*a(n-8) + a(n-9); a(1)=54, a(2)=13824, a(3)=354294, a(4)=3538944, a(5)=21093750, a(6)=90699264, a(7)=311299254, a(8)=905969664, a(9)=2324522934. - _Harvey P. Dale_, Jul 10 2013
%F A085482 From _Elmo R. Oliveira_, May 27 2026: (Start)
%F A085482 a(n) = 54*A001016(n).
%F A085482 G.f.: 54*x*(1 + 247*x + 4293*x^2 + 15619*x^3 + 15619*x^4 + 4293*x^5 + 247*x^6 + x^7)/(1 - x)^9.
%F A085482 E.g.f.: 54*exp(x)*x*(1 + 127*x + 966*x^2 + 1701*x^3 + 1050*x^4 + 266*x^5 + 28*x^6 + x^7). (End)
%p A085482 A085482:=n->54*n^8; seq(A085482(n), n=1..50); # _Wesley Ivan Hurt_, Nov 26 2013
%t A085482 54*Range[20]^8 (* _Harvey P. Dale_, Jul 10 2013 *)
%t A085482 (* Alternative: *)
%t A085482 LinearRecurrence[{9,-36,84,-126,126,-84,36,-9,1},{54,13824,354294,3538944,21093750,90699264,311299254,905969664,2324522934},20] (* _Harvey P. Dale_, Jul 10 2013 *)
