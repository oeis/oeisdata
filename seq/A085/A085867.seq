%I A085867 #17 Jul 16 2026 00:49:59
%S A085867 2,12,105,1008,10080,100352,1000188,10001880,100018800,1000188000,
%T A085867 10001880000,100018800000,1000188000000,10001880000000,
%U A085867 100018800000000,1000188000000000,10001473779644928,100008061430022144
%N A085867 Smallest nontrivial (not = 10^(n-1)) n-digit 7-smooth number. Or smallest n-digit number > 10^(n-1) with prime divisors < 10.
%H A085867 Sean A. Irvine, <a href="/A085867/b085867.txt">Table of n, a(n) for n = 1..100</a>
%o A085867 (Python)
%o A085867 from sympy import integer_log
%o A085867 from oeis_sequences.OEISsequences import bisection
%o A085867 def A085867(n):
%o A085867     def g(x):
%o A085867         c = 0
%o A085867         for i in range(integer_log(x,7)[0]+1):
%o A085867             for j in range(integer_log(m:=x//7**i,5)[0]+1):
%o A085867                 for k in range(integer_log(r:=m//5**j,3)[0]+1):
%o A085867                     c += (r//3**k).bit_length()
%o A085867         return c
%o A085867     m = g(10**(n-1))
%o A085867     def f(x): return m+1+x-g(x)
%o A085867     return bisection(f,m+1,10**(n-1)) # _Chai Wah Wu_, Jul 15 2026
%Y A085867 Cf. A085868, A002473.
%K A085867 base,nonn,changed
