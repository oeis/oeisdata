%S A085045 2,1,5,2,3,134,3,4,11,2,3,548,2,1,3,2,5,402,2,316,1,38,3,1236,3,1,13,
%T A085045 2,5,1986,2,16,1,1,19,1644,2,1,13,716,4,1398,3,1,15,14,11,2472,3,10,5,
%U A085045 2,2,1146,23,4,1,14,3,11028,13,4,3,2,23,1194,2,2,9,2
%N A085045 Smallest k such that tau(n + k) = tau(n*k), or 0 if no such number exists, where tau = A000005.
%H A085045 Robert Israel, <a href="/A085045/b085045.txt">Table of n, a(n) for n = 1..1000</a>
%e A085045 a(4) = 2 as tau(4+2) = tau(6) = 4 and tau(4*2) = tau(8) = 4.
%p A085045 f:= proc(n) local k; for k from 1 do if NumberTheory:-tau(n+k)=NumberTheory:-tau(n*k) then return k fi od end proc:
%p A085045 map(f, [$1..100]); # _Robert Israel_, May 26 2026
%t A085045 f[n_] := Block[{k = 1}, While[ DivisorSigma[0, n + k] != DivisorSigma[0, n*k], k++ ]; k]; Table[ f[n], {n, 1, 80}]
%Y A085045 Cf. A000005, A005237 (a(n)=1), A396005.
%K A085045 nonn
%O A085045 1,1
