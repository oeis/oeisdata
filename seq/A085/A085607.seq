%I A085607 #21 Mar 05 2026 16:01:16
%S A085607 45,54,250,495,594,1131,1311,2262,2550,2622,2750,2926,3393,3933,4154,
%T A085607 4489,4514,4545,4636,4995,5454,5808,5994,6292,6364,6550,7800,8085,
%U A085607 8749,9478,9844,12441,13980,14269,14421,15167,15180,15602,16237,18449,18977
%N A085607 Non-palindromic numbers whose digit reversal have the same sum of prime factors (with repetition).
%H A085607 Scott R. Shannon, <a href="/A085607/b085607.txt">Table of n, a(n) for n = 1..10000</a> (1..500 from Harvey P. Dale).
%e A085607 250 is a term because 250 = 2*5^3 and 52 = 2^2*13 and 2+5+5+5 = 2+2+13 = 17.
%t A085607 spf[n_]:=Total[Flatten[Table[#[[1]],#[[2]]]&/@FactorInteger[n]]];
%t A085607 spffQ[ n_]:=!PalindromeQ[n]&&spf[n]==spf[IntegerReverse[n]];
%t A085607 Select[Range[ 20000], spffQ] (* Requires Mathematica version 10 or later *) (* _Harvey P. Dale_, May 19 2017 *)
%o A085607 (Python)
%o A085607 from sympy import factorint
%o A085607 def sopfr(n): return sum(p*e for p, e in factorint(n).items())
%o A085607 def ok(n): return n != (r:=int(str(n)[::-1])) and sopfr(n) == sopfr(r)
%o A085607 print([k for k in range(20000) if ok(k)]) # _Michael S. Branicky_, Mar 05 2026
%Y A085607 Cf. A001414, A029742.
%K A085607 base,nonn
