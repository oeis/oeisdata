%I A085271 #34 Jul 12 2026 00:56:26
%S A085271 2,4,6,6,8,10,12,12,14,16,18,18,20,22,20,24,24,26,28,30,30,32,30,34,
%T A085271 36,36,38,40,42,42,44,46,42,48,48,50,52,50,54,54,56,58,60,60,62,60,64,
%U A085271 66,66,68,70,72,72,74,70,76,78,78,80,82,80,84,84,86,88,84,90,90,92,90,94
%N A085271 Difference between n-th composite number and its smallest prime divisor.
%C A085271 Equivalently, a(n) is the largest integer smaller than A002808(n) that is not coprime to A002808(n). The first term a(1) = 2 corresponds to A002808(1) = 4 and is the only noncomposite term of the sequence. - _Charles Kusniec_, Jul 03 2026
%F A085271 a(n) = A002808(n) - A020639(A002808(n)) = A002808(n) - A056608(n). - _Charles Kusniec_, Jul 03 2026
%e A085271 For composite number 91 we have 91-7 = 84.
%e A085271 From _Charles Kusniec_, Jul 03 2026: (Start)
%e A085271 A002808(2) = 6 and A020639(6) = 2, so a(2) = 6 - 2 = 4. Thus a(2) + 2 = 6, and 2 divides a(2).
%e A085271 A002808(15) = 25 and A020639(25) = 5, so a(15) = 25 - 5 = 20. Thus a(15) + 5 = 25, and 5 divides a(15). This is the prime-square case, where 20 = 5*(5 - 1) is the lower oblong adjacent to 25 = 5^2.
%e A085271 A002808(26) = 39 and A020639(39) = 3, so a(26) = 39 - 3 = 36. Thus a(26) + 3 = 39, and 3 divides a(26). (End)
%t A085271 #-FactorInteger[#][[1,1]]&/@Complement[Range[2,200],Prime[Range[PrimePi[200]]]] (* _Harvey P. Dale_, Dec 11 2010 *)
%t A085271 (* Alternative: *)
%t A085271 #-Divisors[#][[2]]&/@Select[Range[4,200],!PrimeQ[#]&] (* _Zak Seidov_, Apr 09 2011 *)
%o A085271 (PARI) cminusp(n) = { for(x=2,n, forprime(p=2,sqrtint(x), if(x%p==0,print1(x-p,", "); break); ) ) }
%o A085271 (PARI) {n=200;for(x=4,n,if(isprime(x),,print1(x-divisors(x)[2], ", ")))} \\ _Zak Seidov_, Apr 09 2011
%Y A085271 Cf. A002808, A085273.
%Y A085271 Cf. A020639, A036689, A056608, A079772 (sum of the n-th composite number and its smallest prime divisor).
%K A085271 easy,nonn,changed
%O A085271 1,1
%A A085271 _Cino Hilliard_, Aug 12 2003
%E A085271 Typo in data corrected by _Zak Seidov_, Apr 09 2011
