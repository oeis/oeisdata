%I A085868 #17 Jul 16 2026 00:49:55
%S A085868 9,98,980,9800,99225,995328,9953280,99574272,996451875,9999593856,
%T A085868 99995938560,999959385600,9999593856000,99995938560000,
%U A085868 999959385600000,9999593856000000,99995938560000000,999959385600000000
%N A085868 Largest n-digit 7-smooth number. Or largest n-digit number with prime divisors < 10.
%H A085868 Sean A. Irvine, <a href="/A085868/b085868.txt">Table of n, a(n) for n = 1..100</a>
%o A085868 (Python)
%o A085868 from sympy import integer_log
%o A085868 from oeis_sequences.OEISsequences import bisection
%o A085868 def A085868(n):
%o A085868     def g(x):
%o A085868         c = 0
%o A085868         for i in range(integer_log(x,7)[0]+1):
%o A085868             for j in range(integer_log(m:=x//7**i,5)[0]+1):
%o A085868                 for k in range(integer_log(r:=m//5**j,3)[0]+1):
%o A085868                     c += (r//3**k).bit_length()
%o A085868         return c
%o A085868     m = g(10**n-1)
%o A085868     def f(x): return m+x-g(x)
%o A085868     return bisection(f,m,10**n-1) # _Chai Wah Wu_, Jul 15 2026
%Y A085868 Cf. A085867, A002473.
%K A085868 base,nonn,changed
