%S A054355 1,3,7,14,26,48,91,178,357,728,1497,3083,6331,12937,26292,53144,
%T A054355 106846,213676,425126,841854,1660587,3266550,6416933,12607706,
%U A054355 24811601,48969428,97010347,192968489,385347506,772039743,1550372341,3117282657
%N A054355 Binomial transform of Kolakoski sequence A000002.
%C A054355 Before taking the transform, relabel A000002 so the subscripts start at 0 instead of 1.
%p A054355 # Using _R. J. Mathar_'s function A000002.
%p A054355 binomial_transform := (sq, dim) -> local n, k; seq(add(binomial(n, k) * sq(k), k = 0..n), n = 0..dim):
%p A054355 binomial_transform(n -> A000002(n + 1), 31);  # _Peter Luschny_, Jul 05 2026
%o A054355 (Python) # Using _David Eppstein_'s Kolakoski function from A000002.
%o A054355 from typing import Iterator
%o A054355 def binomial_trans(seq: Iterator, dim: int) -> list[int]:
%o A054355     c = []; t = []
%o A054355     for _ in range(dim):
%o A054355         try: r = next(seq)
%o A054355         except StopIteration: break
%o A054355         c += [r]
%o A054355         for i in range(len(c) - 1, 0, -1):
%o A054355             c[i - 1] += c[i]
%o A054355         t.append(c[0])
%o A054355     return t
%o A054355 A054355 = binomial_trans(Kolakoski(), 32); print(A054355)  # _Peter Luschny_, Jul 05 2026
%Y A054355 Cf. A000002.
%K A054355 nonn,changed
%O A054355 0,2
%A A054355 _N. J. A. Sloane_, May 07 2000
