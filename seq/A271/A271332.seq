%I A271332 #20 Jul 15 2026 01:05:06
%S A271332 6,15,51,754,803,2160,3048,8315,18549,27094,89929,251712,505768,
%T A271332 936240,1617182,2182656,2582372,5116884,27067121,77131559,487568736,
%U A271332 1138774449,1261336587,1424530096,1995592624
%N A271332 Integers k such that k-th prime divides the k-th golden rectangle number.
%C A271332 A075702 is a subsequence.
%C A271332 Integers k such that A000040(k) divides A001654(k).
%e A271332 6 is a term because A001654(6) = 104 is divisible by A000040(6) = 13.
%o A271332 (Python)
%o A271332 from itertools import count, islice
%o A271332 from sympy import nextprime
%o A271332 def A271332_gen(): # generator of terms
%o A271332     def f(n,m):
%o A271332         a, b, c, d, a2, b2, c2, d2 = 1, 1, 1, 0, 1, 0, 0, 1
%o A271332         for x in bin(n)[2:]:
%o A271332             e, f = b2*c2%m, k if (k:=a2+d2)<m else k-m
%o A271332             a2, b2, c2, d2 = (a2*a2+e)%m, b2*f%m, c2*f%m, (d2*d2+e)%m
%o A271332             if x=='1':
%o A271332                 a2, b2, c2, d2 = (a2*a+b2*c)%m, (a2*b+b2*d)%m, (c2*a+d2*c)%m, (c2*b+d2*d)%m
%o A271332         return c2*d2%m
%o A271332     p = 1
%o A271332     for k in count(1):
%o A271332         if not f(k+1,p:=nextprime(p)): yield k
%o A271332 A271332_list = list(islice(A271332_gen(),12)) # _Chai Wah Wu_, Jul 14 2026
%Y A271332 Cf. A001654, A075702.
%K A271332 nonn,more,changed
