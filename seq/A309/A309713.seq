%S A309713 0,0,0,0,1,1,2,2,3,3,7,10,17,20,27,30,42,50,67,80,102,115,144,164,200,
%T A309713 227,270,304,363,406,474,526,603,664,761,842,959,1051,1179,1282,1434,
%U A309713 1561,1737,1888,2088,2252,2480,2672,2928,3148,3432,3680,4009,4289
%N A309713 Sum of the odd parts appearing among the third largest parts of the partitions of n into 4 parts.
%H A309713 <a href="/index/Par#part">Index entries for sequences related to partitions</a>
%F A309713 a(n) = Sum_{k=1..floor(n/4)} Sum_{j=k..floor((n-k)/3)} Sum_{i=j..floor((n-j-k)/2)} j * (j mod 2).
%F A309713 From _Hoang Xuan Thanh_, May 01 2026: (Start)
%F A309713 G.f.: x^4*(1-x^7)/(2*(1-x)*(1-x^2))*(1/((1-x^3)*(1-x^4))^2 + 1/((1+x^3)*(1+x^4))^2).
%F A309713 a(n) = floor((7*n^4+28*n^3+96*n^2+392*n+6912)/13824 - (n mod 2)*(25*n^2+50*n)/2304 - ((n+2) mod 3)*n/54 + (((n+3) mod 4) +((n+2) mod 4) -((n+1) mod 4) -(n mod 4))*n/256 + (((n+4) mod 6) +((n+3) mod 6) -((n+1) mod 6) -(n mod 6))*n/108 + ((n mod 8) +((n+1) mod 8) -((n+4) mod 8) -((n+5) mod 8))*n/128). (End)
