%p A383630 f:= gfun:-rectoproc({118514880*(n + 1)*a(n) - 22393176*(13 + 7*n)*a(n + 1) + 6135118*(19 + 7*n)*a(n + 2) - 713767*(25 + 7*n)*a(n + 3) + 42460*(31 + 7*n)*a(n + 4) - 1354*(37 + 7*n)*a(n + 5) + 22*(43 + 7*n)*a(n + 6) - (n + 7)*a(n + 7), a(0) = 1, a(1) = 22, a(2) = 582, a(3) = 17116, a(4) = 540457, a(5) = 17965662, a(6) = 620869768}, a(n), remember):
