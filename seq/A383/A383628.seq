%F A383628 D-finite with recurrence: (585 + 585*n)*a(n) + (-1421 - 812*n)*a(n + 1) + (635 + 254*n)*a(n + 2) + (-91 - 28*n)*a(n + 3) + (n + 4)*a(n + 4) = 0. - _Robert Israel_, Mar 13 2026
%p A383628 f:= gfun:-rectoproc({(585 + 585*n)*a(n) + (-1421 - 812*n)*a(n + 1) + (635 + 254*n)*a(n + 2) + (-91 - 28*n)*a(n + 3) + (n + 4)*a(n + 4), a(0) = 1, a(1) = 7, a(2) = 59, a(3) = 553}, a(n), remember):
%p A383628 map(f, [$0..30]); # _Robert Israel_, Mar 13 2026
%o A383628 (PARI) my(N=30, x='x+O('x^N)); Vec(1/prod(k=0, 3, 1-(4*k+1)*x)^(1/4))
