%S A141117 1,2,8,46,330,2756,25782,263866,2909092,34181138,424730866,5549236120,
%T A141117 75895955810,1082808876274,16069706031016,247501424330182,
%U A141117 3948322598675930,65130737179097436,1109339652229852966,19484430449616724234,352494529823563125780,6561473909742778098730
%N A141117 G.f.: A(x) = G(G(x)) = G(x)*(1 + A(A(x))) where G(x) = x + x*G(G(G(x))) = g.f. of A091713.
%C A141117 Conjecture: a(n) is divisible by 4 iff n is divisible by 3, otherwise a(n) == 2 (mod 4) for n > 1 with a(1) = 1. - _Paul D. Hanna_, Apr 03 2026
%H A141117 Paul D. Hanna, <a href="/A141117/b141117.txt">Table of n, a(n) for n = 1..300</a>
%F A141117 G.f. A(x) satisfies: G( x/(1 + A(x)) ) = x where G(x) = g.f. of A091713.
%F A141117 From _Paul D. Hanna_, Apr 03 2026: (Start)
%F A141117 G.f. A(x) satisfies: A( x/(1 + A(x)) ) = Series_Reversion( x/(1 + A(x)) ).
%F A141117 G.f. A(x) satisfies: A( x/(1 + A(x)) ) = G(x), where G(x) = g.f. of A091713. (End)
%e A141117 G.f.: A(x) = x + 2*x^2 + 8*x^3 + 46*x^4 + 330*x^5 + 2756*x^6 + 25782*x^7 + ...
%e A141117 where A(x) = G(G(x)) such that G(x) = A(x)/(1 + A(A(x))) and
%e A141117 G(x) = x + x^2 + 3*x^3 + 15*x^4 + 99*x^5 + 781*x^6 + 7001*x^7 + 69253*x^8 + 742071*x^9 + ... + A091713(n)*x^n + ...
%e A141117 Also,
%e A141117 A(A(x)) = x + 4*x^2 + 24*x^3 + 180*x^4 + 1564*x^5 + 15140*x^6 + 159580*x^7 + 1804740*x^8 + 21681260*x^9 + ...
%e A141117 where A(x) = G(x)*(1 + A(A(x))).
%o A141117 (PARI) {a(n) = my(G=x+x^2); for(k=3, n, G = truncate(G); G = x + x*subst(G, x, subst(G, x, G +x*O(x^k)))); polcoef(A = subst(G, x, G), n, x)}
%o A141117 {upto(n) = a(n); Vec(A)} \\ program revised by _Paul D. Hanna_, Apr 03 2026
%o A141117 upto(30)
%Y A141117 Cf. A091713.
%K A141117 nonn
%O A141117 1,2
