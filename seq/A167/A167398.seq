%T A167398 5527939700884757,1100087778366101931,218922995834555169026,
%U A167398 43566776258854844738105,8670007398507948658051921,1725375039079340637797070384,343358302784187294870275058337,68330027629092351019822533679447
%N A167398 a(n) = Fibonacci(11*n).
%H A167398 <a href="/index/Rec#order_02">Index entries for linear recurrences with constant coefficients</a>, signature (199,1).
%F A167398 a(n) = 199*a(n-1) + a(n-2) for n > 1; a(0)=0, a(1)=89.
%F A167398 From _Elmo R. Oliveira_, Mar 29 2026: (Start)
%F A167398 G.f.: 89*x/(1 - 199*x - x^2).
%F A167398 a(n) = 89*A305413(n) = A000045(A008593(n)). (End)
%F A167398 Sum_{n>=1} (-1)^(n+1)/(a(n)*a(n+1)) = (89*sqrt(5)-199)/15842. - _Amiram Eldar_, Apr 06 2026
%t A167398 Table[Fibonacci[11k],{k,0,20}]
%t A167398 (* Alternative: *)
%t A167398 {a,b}={0,89};Do[Print[c={a,b}.{1,199}];a=b;b=c,{20}]
