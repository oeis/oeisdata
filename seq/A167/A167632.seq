%N A167632 Smallest m such that A033183(m) = n.
%C A167632 A033183(a(n)) = n and A033183(m) < n for m < a(n);
%C A167632 for n>1: a(n) = A044102(n-1).
%H A167632 Paolo Xausa, <a href="/A167632/b167632.txt">Table of n, a(n) for n = 0..10000</a>
