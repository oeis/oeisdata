%F A167854 G.f.: (t^15 + 2*t^14 + 2*t^13 + 2*t^12 + 2*t^11 + 2*t^10 + 2*t^9 + 2*t^8 + 2*t^7 + 2*t^6 + 2*t^5 + 2*t^4 + 2*t^3 + 2*t^2 + 2*t + 1)/(903*t^15 - 42*t^14 - 42*t^13 - 42*t^12 - 42*t^11 - 42*t^10 - 42*t^9 - 42*t^8 - 42*t^7 - 42*t^6 - 42*t^5 - 42*t^4 - 42*t^3 - 42*t^2 - 42*t + 1).
%t A167854 CoefficientList[Series[(t^15 + 2*t^14 + 2*t^13 + 2*t^12 + 2*t^11 + 2*t^10 + 2*t^9 + 2*t^8 + 2*t^7 + 2*t^6 + 2*t^5 + 2*t^4 + 2*t^3 + 2*t^2 + 2*t + 1)/(903*t^15 - 42*t^14 - 42*t^13 - 42*t^12 - 42*t^11 - 42*t^10 - 42*t^9 - 42*t^8 - 42*t^7 - 42*t^6 - 42*t^5 - 42*t^4 - 42*t^3 - 42*t^2 - 42*t + 1), {t, 0, 50}], t] (* _G. C. Greubel_, Jun 28 2016 *)
%t A167854 coxG[{15,903,-42}] (* The coxG program is at A169452 *) (* _Harvey P. Dale_, Oct 04 2017 *)
%o A167854 (PARI) first(n)=Vec((1+x^5+x^10)*(1+x+x^2+x^3+x^4)*(1+x)/(1-42*x-42*x^2-42*x^3-42*x^4-42*x^5-42*x^6-42*x^7-42*x^8-42*x^9-42*x^10-42*x^11-42*x^12-42*x^13-42*x^14+903*x^15)+O(x^(n+1))) \\ _Charles R Greathouse IV_, Jun 29 2026
