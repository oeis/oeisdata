%U A179585 85618781281932,439276139103524,2240770839005570,11378775867126410,57578330604264242,290551102865749530,1463013808934754634,7354328996873056805
%N A179585 Number of permutations of 1..n+10 with deficiencies #{i : p(i) < i} exceeding exceedances #{i : p(i) > i} by n or more.
%C A179585 Added a(0) = 2307264 for the number of permutations of [1..10] which have number of deficiencies >= exceedances. - _M. F. Hasler_, Jul 21 2026
%H A179585 M. F. Hasler and R. J. Mathar, <a href="/A179582/a179582_3.pdf">Hardin's exceedance excesses A179579-A179582</a>, July 2026.
%H A179585 <a href="/index/Rec#order_25">OEIS Index to entries for linear recurrences with constant coefficients</a>, order 25.
%F A179585 a(n) = A179584(n+1) + A179577(n). - _R. J. Mathar_, Jul 18 2026
%F A179585 a(n) = 5^(n + 10) + 4^(n + 8)*(n - 23)*(n + 10)/2 + 3^(n + 5)*(n + 9)*(n + 10)*(n^2 - 117*n - 136)/8 + 2^n*(n + 7)*(n + 8)*(n + 9)*(n + 10)*(n^2 - 157*n + 4062)/45 + (n + 7)*(n + 8)*(n + 9)*(n + 10)*(n^4 - 86*n^3 + 1247*n^2 + 8774*n - 39000)/40320. - _M. F. Hasler_, Jul 18 2026
%F A179585 G.f.: ( -2307264 +110947601*x -2536338114*x^2 -34202775253877784*x^14 -376576777576*x^4 +1160580445580628*x^9 -17778357272312*x^6 +36677480625*x^3 -3222688604429678*x^10 -21070319105524864*x^18 +7517630305592800*x^11 -3073970995200*x^24 +87081339202995*x^7 -349228739260440*x^8 +11216400982754816*x^19 -4677467452230144*x^20 +40099817828010128*x^15 -39250753790749216*x^16 +31803078023704768*x^17 +2920835539879*x^5 +1470742866920448*x^21 -327668605710336*x^22 -14776375157421728*x^12 +46079379947520*x^23 +24494139357208992*x^13 ) / ( (-1+5*x)*(-1+4*x)^3*(-1+3*x)^5*(2*x-1)^7*(x-1)^9 ). - _R. J. Mathar_, Jul 22 2026
%o A179585 (PARI) A179585(n)=5^(n+10)+4^(n+8)*(n-23)*(n+10)\2+3^(n+5)*(n+9)*(n+10)*(n^2-117*n-136)/8+2^n*(n+7)*(n+8)*(n+9)*(n+10)*(n^2-157*n+4062)/45+(n+7)*(n+8)*(n+9)*(n+10)*(n^4-86*n^3+1247*n^2+8774*n-39000)/40320 \\ (same as formula). - _M. F. Hasler_, Jul 18 2026
