%N A179907 Numerators in the approximation of sqrt(2) satisfying the recurrence: a(n)= [a(n-1)*a(n-2)+2]/[a(n-1)+a(n-2)] with a(1)=a(2)=1.
%H A179907 Peter Bala, <a href="/A179823/a179823.pdf">Notes on A179823 and A179907</a>.
%F A179907 From _Peter Bala_, Jul 05 2026: (Start)
%F A179907 a(n) = A001333(Fibonacci(n)) = (1/2) * ( (1 + sqrt(2))^Fibonacci(n) + (1 - sqrt(2))^Fibonacci(n) ).
%F A179907 a(n) ~ 1/2 * exp(c*phi^n), where c = 1/sqrt(5) * log(1 + sqrt(2)) and phi = (1 + sqrt(5))/2 is the golden ratio. (End)
%p A179907 with(combinat):
%p A179907 seq( simplify( (1/2) * ( (1 + sqrt(2))^fibonacci(n) + (1 - sqrt(2))^fibonacci(n) ) ), n = 1..13); # _Peter Bala_, Jul 05 2026
%Y A179907 Cf. A000045, A001333, A002203, A179823
%K A179907 frac,nonn,changed
%O A179907 1,3
