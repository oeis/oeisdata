%I A295576 #26 Apr 30 2026 00:22:19
%S A295576 0,1,1,1,17,1,98,82,273,82,979,626,2275,707,2674,3108,8772,3027,15333,
%T A295576 9044,14994,9669,39974,17668,50085,24310,60597,50470,127687,45604,
%U A295576 178312,103496,149908,103496,225302,129750,432345,187017,349830,266088,722666
%N A295576 a(n) = Sum_{1 <= j <= n/2, gcd(j,n)=1} j^4.
%C A295576 If p is an odd prime, a(p) = p*(p^2-1)*(3*p^2-7)/480. - _Robert Israel_, Dec 10 2017
%H A295576 Seiichi Manyama, <a href="/A295576/b295576.txt">Table of n, a(n) for n = 1..10000</a>
%H A295576 John D. Baum, <a href="https://www.jstor.org/stable/2690056">A Number-Theoretic Sum</a>, Mathematics Magazine 55.2 (1982): 111-113.
%F A295576 From _Chai Wah Wu_, Apr 28 2026: (Start)
%F A295576 If n==0 (mod 4):          a(n) = n*(3*n^3*A000010(n)+20*n^2*A023900(n)-8*A063453(n))/480
%F A295576 If n is odd:              a(n) = n*(3*n^3*A000010(n)-10*n^2*A023900(n)+7*A063453(n))/480
%F A295576 If n!=2 and n==2 (mod 4): a(n) = n*(21*n^3*A000010(n)-280*n^2*A023900(n)+64*A063453(n))/3360 (End)
%p A295576 f:= n -> add(t^4, t = select(t->igcd(t,n)=1, [$1..n/2])):
%p A295576 map(f, [$1..100]); # _Robert Israel_, Dec 10 2017
%t A295576 f[n_] := Plus @@ (Select[Range[n/2], GCD[#, n] == 1 &]^4); Array[f, 41] (* _Robert G. Wilson v_, Dec 10 2017 *)
%o A295576 (PARI) a(n) = sum(j=1, n\2, (gcd(j, n)==1)*j^4); \\ _Michel Marcus_, Dec 10 2017
%o A295576 (Python)
%o A295576 from math import prod
%o A295576 from sympy import primefactors
%o A295576 def A295576(n):
%o A295576     if n == 2: return 1
%o A295576     m, ps = n&3, primefactors(n)
%o A295576     s1, s3 = prod(1-p for p in ps), prod(1-p**3 for p in ps)
%o A295576     t = n*(-s1 if len(ps)&1 else s1)//prod(ps)
%o A295576     if not m:
%o A295576         return (3*n**4*t+20*n**3*s1-8*n*s3)//480
%o A295576     elif m==2:
%o A295576         return n*(21*n**3*t - 280*n**2*s1 + 64*s3)//3360
%o A295576     else:
%o A295576         return n*(3*n**3*t - 10*n**2*s1 + 7*s3)//480 # _Chai Wah Wu_, Apr 28 2026
%Y A295576 In the Baum (1982) paper, S_1, S_2, S_3, S_4 are A023896, A053818, A053819, A053820, and S'_1, S'_2, S'_3, S'_4 are A066840, A295574, A295575, A295576.
