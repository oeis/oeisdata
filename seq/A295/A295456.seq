%S A295456 1,168043980,126694219977836700,109504706026534324525391988,
%T A295456 100204869963549181630558779565943580,
%U A295456 94632263448378916462441320194245442445186480,91178760822805067678742350221792424866578707819103300,89078657321704573467701346299333700225381618490806719145843000
%N A295456 a(n) = (30*n)!*(5*n)!*(4*n)!/((15*n)!*(12*n)!*(10*n)!*(2*n)!).
%C A295456 Conjecture: for n >= 0, both a(n/2) = (15*n)!*(5*n/2)!*(2*n)! / ((15*n/2)!*(6*n)!*(5*n)!*n!) and a(n/3) = (10*n)!*(5*n/3)!*(4*n/3)! / ((5*n)!*(4*n)!*(10*n/3)!*(2*n/3)!) are integers, where fractional factorials are defined using the Gamma function; for example (5*n/2)! := Gamma(5*n/2 + 1). - _Peter Bala_, Jun 13 2026
%F A295456 G.f.: hypergeom([1/30, 7/30, 11/30, 13/30, 17/30, 19/30, 23/30, 29/30], [1/12, 1/3, 5/12, 1/2, 7/12, 2/3, 11/12], 1054687500*x).
%F A295456 a(n) = binomial(30*n,15*n)*binomial(15*n,3*n)*binomial(3*n,n)/(binomial(10*n,5*n)*binomial(5*n,n)). - _Chai Wah Wu_, Feb 15 2026
%F A295456 a(n) ~ 2^(2*n-1) * 3^(3*n-1/2) * 5^(10*n) / sqrt(Pi*n). - _Amiram Eldar_, Feb 22 2026
%t A295456 a[n_] := (30*n)!*(5*n)!*(4*n)!/((15*n)!*(12*n)!*(10*n)!*(2*n)!); Array[a, 8, 0] (* _Amiram Eldar_, Feb 22 2026 *)
%o A295456 (Python)
%o A295456 from math import comb
%o A295456 def A295456(n): return comb(30*n,15*n)*comb(15*n,3*n)*comb(3*n,n)//(comb(10*n,5*n)*comb(5*n,n)) # _Chai Wah Wu_, Feb 15 2026
