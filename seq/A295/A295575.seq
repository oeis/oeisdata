%I A295575 #27 Apr 30 2026 00:22:24
%S A295575 0,1,1,1,9,1,36,28,73,28,225,126,441,153,416,496,1296,469,2025,1100,
%T A295575 1710,1225,4356,1800,4959,2556,5581,4410,11025,3872,14400,8128,11090,
%U A295575 8128,15822,8910,29241,13041,21996,16400,44100,15426,53361,27830,33716,29161,76176,27936,77652,37828
%N A295575 a(n) = Sum_{1 <= j <= n/2, gcd(j,n)=1} j^3.
%C A295575 If p is an odd prime, a(p) = (n^2-1)^2/64. - _Robert Israel_, Dec 10 2017
%H A295575 Seiichi Manyama, <a href="/A295575/b295575.txt">Table of n, a(n) for n = 1..10000</a>
%H A295575 John D. Baum, <a href="https://www.jstor.org/stable/2690056">A Number-Theoretic Sum</a>, Mathematics Magazine 55.2 (1982): 111-113.
%F A295575 From _Chai Wah Wu_, Apr 28 2026: (Start)
%F A295575 If n==0 (mod 4):          a(n) = n^2*(n*A000010(n)+4*A023900(n))/64
%F A295575 If n is odd:              a(n) = (n^3*A000010(n)-2*n^2*A023900(n)+A063453(n))/64
%F A295575 If n!=2 and n==2 (mod 4): a(n) = (7*n^3*A000010(n)-56*n^2*A023900(n)+8*A063453(n))/448 (End)
%p A295575 f:= n -> add(t^3, t = select(t->igcd(t,n)=1, [$1..n/2])) :
%p A295575 map(f, [$1..100]); # _Robert Israel_, Dec 10 2017
%t A295575 f[n_] := Plus @@ (Select[Range[n/2], GCD[#, n] == 1 &]^3); Array[f, 50] (* _Robert G. Wilson v_, Dec 10 2017 *)
%o A295575 (PARI) a(n) = sum(j=1, n\2, (gcd(j, n)==1)*j^3); \\ _Michel Marcus_, Dec 10 2017
%o A295575 (Python)
%o A295575 from math import prod
%o A295575 from sympy import primefactors
%o A295575 def A295575(n):
%o A295575     if n == 2: return 1
%o A295575     m, ps = n&3, primefactors(n)
%o A295575     s1, s3 = prod(1-p for p in ps), prod(1-p**3 for p in ps)
%o A295575     t = n*(-s1 if len(ps)&1 else s1)//prod(ps)
%o A295575     if not m:
%o A295575         return n**2*(n*t+4*s1)>>6
%o A295575     elif m==2:
%o A295575         return (7*n**3*t-56*n**2*s1+8*s3)//7>>6
%o A295575     else:
%o A295575         return (n**3*t-n**2*s1*2+s3)>>6 # _Chai Wah Wu_, Apr 28 2026
%Y A295575 In the Baum (1982) paper, S_1, S_2, S_3, S_4 are A023896, A053818, A053819, A053820, and S'_1, S'_2, S'_3, S'_4 are A066840, A295574, A295575, A295576.
%K A295575 nonn,changed
%O A295575 1,5
