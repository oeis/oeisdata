%S A047272 61,89,109,149,269,389,401,421,521,661,701,761,769,809,821,829,1009,
%T A047272 1049,1069,1181,1249,1289,1301,1361,1381,1409,1429,1601,1721,1901,
%U A047272 1949,2081,2089,2141,2221,2269,2309,2341,2381,2441,2549,2729,2741,2749,2789
%N A047272 Primes p such that p == 1 (mod 4) and Fibonacci((p-1)/4) is divisible by p.
%C A047272 There are typos in Theorems 1 and 2 of Lehmer's paper. The condition a == 1 (mod 4) should be a == 1 (mod 2). - _Eric Rowland_, May 20 2018
%C A047272 These primes are characterized by p = x^2 + 5*y^2 (A033205) with 4|xy. The case 4|y is A107192. - _John Blythe Dobson_, Jul 03 2026
%H A047272 Chai Wah Wu, <a href="/A047272/b047272.txt">Table of n, a(n) for n = 1..10000</a>
%H A047272 E. Lehmer, <a href="https://www.fq.math.ca/Scanned/4-2/lehmer.pdf">On the quadratic character of the Fibonacci root</a>, Fib. Quart., 4 (1966), 135-138.
%H A047272 E. Lehmer, <a href="/A001583/a001583.pdf">On the quadratic character of the Fibonacci root</a> (annotated scanned copy)
%H A047272 Zhi-Hong Sun, <a href="https://doi.org/10.1216/rmjm/1181069947">Values of Lucas sequences modulo primes</a>, Rocky Mountain J. Math. 33 (3) (2003), 1123-1145.
%H A047272 Zhi-Hong Sun and Zhi-Wei Sun, <a href="https://eudml.org/doc/206445">Fibonacci numbers and Fermat's last theorem</a>, Acta Arith. 60 (1992), 371-388.
%t A047272 Select[Prime[Range[400]], Function[p, Mod[p, 4] == 1 && Divisible[Fibonacci[(p - 1)/4], p]]] (* _Eric Rowland_, May 20 2018 *)
%o A047272 (Python)
%o A047272 from itertools import count, islice
%o A047272 from sympy import isprime
%o A047272 def A047272_gen(): # generator of terms
%o A047272     def fibonacci_mod(n,m): # fibonacci(n) mod m
%o A047272         a, b, c, d, a2, b2, c2, d2 = 1, 1, 1, 0, 1, 0, 0, 1
%o A047272         for x in bin(n)[2:]:
%o A047272             e, f = b2*c2%m, a2+d2
%o A047272             a2, b2, c2, d2 = (pow(a2,2,m)+e)%m, b2*f%m, c2*f%m, (pow(d2,2,m)+e)%m
%o A047272             if x=='1':
%o A047272                 a2, b2, c2, d2 = (a2*a+b2*c)%m, (a2*b+b2*d)%m, (c2*a+d2*c)%m, (c2*b+d2*d)%m
%o A047272         return c2
%o A047272     for m in count(1,4):
%o A047272         if isprime(m) and fibonacci_mod(m-1>>2,m)==0:
%o A047272             yield m
%o A047272 A047272_list = list(islice(A047272_gen(),45)) # _Chai Wah Wu_, Jul 03 2026
%Y A047272 For nonprimes see A091982.
%Y A047272 Subsequence of A033205.
%Y A047272 Supersequence of A107192.
%K A047272 nonn,easy,changed
%O A047272 1,1
%A A047272 _N. J. A. Sloane_
%E A047272 More terms from _James Sellers_, Jan 25 2000
%E A047272 New Name from _Eric Rowland_, May 20 2018
