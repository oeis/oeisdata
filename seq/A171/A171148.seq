%N A171148 a(n) = 3 + 10^n + 3*100^n.
%H A171148 Paolo Xausa, <a href="/A171148/b171148.txt">Table of n, a(n) for n = 0..450</a>
%H A171148 <a href="/index/Rec#order_03">Index entries for linear recurrences with constant coefficients</a>, signature (111,-1110,1000).
%F A171148 From _Elmo R. Oliveira_, Mar 26 2026: (Start)
%F A171148 O.g.f.: (7 - 464*x + 3130*x^2)/((1 - 101*x + 100*x^2)*(1 - 10*x)).
%F A171148 E.g.f.: (3 + exp(9*x) + 3*exp(99*x))*exp(x).
%F A171148 a(n) = 111*a(n-1) - 1110*a(n-2) + 1000*a(n-3).
%F A171148 a(n) = 3*A098608(n) + A216179(n) for n > 0. (End)
%t A171148 A171148[n_] := 3*100^n + 10^n + 3; Array[A171148, 20, 0] (* _Paolo Xausa_, Mar 03 2026 *)
