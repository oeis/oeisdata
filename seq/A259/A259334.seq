%U A259334 268800,120960,35280,5040,4782969,8503056,9920232,8817984,6123600,3265920,1270080,322560,40320
%N A259334 Triangle read by rows: T(n, k) = k * (n - 1)! * n^(n - k - 1) / (n - k)!.
%C A259334 T(n, k)/n^(n-1) is the probability that a fair n-sided die being repeatedly rolled has k distinct faces seen before the first reoccurrence. - _Natalia L. Skirrow_, Apr 01 2026
%H A259334 Michael De Vlieger, <a href="/A259334/b259334.txt">Table of n, a(n) for n = 1..11325</a> (rows n = 1..150, flattened)
%H A259334 Enrica Duchi, Adrián Lillo, Pablo Puerto, Mercedes Rosas, and Stefan Trandafir, <a href="https://arxiv.org/abs/2601.07938">The genesis sequence, tree records and endofunctions</a>, arXiv:2601.07938 [math.CO], 2026. See pp. 7-8.
%H A259334 Philippe Flajolet, Peter J. Grabner, Peter Kirschenhofer, and Helmut Prodinger, <a href="https://doi.org/10.1016/0377-0427(93)E0258-N">On Ramanujan's Q-function</a>, Journal of Computational and Applied Mathematics, vol. 58, iss. 1 (1995-03-20), pp. 103-116.
%H A259334 F. A. Haight, <a href="https://www.jstor.org/stable/2333538">Overflow at a traffic light</a>, Biometrika, 46 (1959), 420-424.
%H A259334 F. A. Haight, <a href="/A001787/a001787_3.pdf">Overflow at a traffic light</a>, Biometrika, 46 (1959), 420-424. (Annotated scanned copy)
%H A259334 F. A. Haight, <a href="/A001787/a001787_2.pdf">Letter to N. J. A. Sloane, n.d.</a>
%H A259334 Adrián Lillo, Mercedes Rosas, and Stefan Trandafir, <a href="https://arxiv.org/abs/2510.12536">On the enumeration of records of rooted trees and rooted forests</a>, arXiv:2510.12536 [math.CO], 2025. See p. 2.
%F A259334 A000435(n) = Sum_{k=1..n} (k-1)*T(n,k). - _David desJardins_, Jan 22 2017
%F A259334 From _Natalia L. Skirrow_, Apr 01 2026: (Start)
%F A259334 E.g.f.: F(x,y) = T(x) + (1-1/y)*C(x,y), where T(x)=-W(-x) is the e.g.f. for A000169 and C(x,y) = log(1/(1-y*T(x))) is the e.g.f for A201685.
%F A259334 x * d/dx F(x,y) = y * T(x) / (1-y*T(x)) is the e.g.f. for A066324, so T(n,k) = A066324(n,k)/n.
%F A259334 Row o.g.f.: Sum_{k=1..n} T(n,k)*y^k = n^(n-1) * ((1-1/y) * hypergeom([-n,1],[],-y/n) + 1/y) = y^n * (1-1/y) * e^(n/y) * Gamma(n+1,n/y) / n + n^(n-1) / y.
%F A259334 Let P(n,k) = n!/(n-k)! be the number of ordered k-subsets of [n] and Q(n) = Sum_{k=1..n} P(n, k) / n^k ~ sqrt(Pi*n/2) be Ramanujan's Q function. The n-th row has center of mass Q(n) and variance 2*n - Q(n) - Q(n)^2 ~ (2-Pi/2)*n - sqrt(Pi*n/2)/3 + 2/9-Pi/12 + O(1/sqrt(n)).
%F A259334 Sum_{k=1..n} T(n, k)         = A000169(n) = n^(n-1) (row sums).
%F A259334 Sum_{k=1..n} T(n, k)*  k     = A001865(n) = n^(n-1)*Q(n).
%F A259334 Sum_{k=2..n} T(n, k)*C(k, 2) = A185391(n-1) = n^(n-1)*(n - Q(n)).
%F A259334 Sum_{k=m..n} T(n, k)*C(k, m) = A394852(n, m)/n. (End)
%F A259334 From _Peter Luschny_, Apr 19 2026: (Start)
%F A259334 Row recurrence: T(n, k) = T(n, k + 1) * ((n + 1)*(k + 1)) / ((n - k)*(k + 2)) starting T(n, n) = n*T(n-1, n-1) = n!, assuming the triangle (0, 0)-based.
%F A259334 T(n, k) = k! * [y^k] (y + 1)*(y + n + 1)^(n - 1).  (End)
%e A259334 Triangle begins:
%e A259334      1;
%e A259334      1,    1;
%e A259334      3,    4,    2;
%e A259334     16,   24,   18,    6;
%e A259334    125,  200,  180,   96,   24;
%e A259334   1296, 2160, 2160, 1440,  600,  120;
%e A259334   ...
%e A259334 From _Natalia L. Skirrow_, Apr 01 2026: (Start)
%e A259334 P(n, k) = n!/(n-k)! as before. A 3-sided die can roll:
%e A259334   * (AA up to relabeling (* P(3,1) = 3) ) = 3,
%e A259334   * (ABA,ABB up to relabeling (* P(3,2) = 6) ) / 3^1 = 4,
%e A259334   * (ABCA,ABCB,ABCC up to relabeling (* P(3,3) = 6) ) / 3^2 = 2,
%e A259334 hence row 3 is (3, 4, 2). (End)
%p A259334 egf := n -> (y+1)*(y+n+1)^(n-1): ser := n -> series(egf(n), y, 10): row := n -> local k; seq(k!*coeff(ser(n), y, k), k = 0..n): seq(print(row(n)), n = 0..8); # _Peter Luschny_, Apr 19 2026
%t A259334 Table[k*(n - 1)!*n^(n - k - 1)/(n - k)!, {n, 9}, {k, n}] // Flatten (* _Michael De Vlieger_, Jan 16 2026 *)
%o A259334 (PARI) tabl(nn) = {for (n=1, nn, for (k=1, n, print1(k*(n-1)!*n^(n-k-1)/(n-k)!, ", ");); print(););} \\ _Michel Marcus_, Jun 26 2015
%o A259334 (Python)
%o A259334 from math import factorial
%o A259334 def Trow(n: int) -> list[int]: # is (0, 0)-based!
%o A259334     row = [0] * (n + 1); row[n] = factorial(n)
%o A259334     for k in range(n - 1, -1, -1):
%o A259334         row[k] = (row[k + 1] * (n + 1) * (k + 1)) // ((n - k) * (k + 2))
%o A259334     return row
%o A259334 def T(n: int, k: int) -> int:  # is (1, 1)-based!
%o A259334     return Trow(n - 1)[k - 1]
%o A259334 # _Peter Luschny_, Apr 19 2026
