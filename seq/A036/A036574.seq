%I A036574 #8 Jul 08 2026 11:33:26
%S A036574 3,3,7,19,15,23,54,187,166,167,136,329,115,369,647,323,630,287,6666,
%T A036574 1583,2495,1439,2278,4223,4054,12959,10799,10143,13580,11231,23183,
%U A036574 105335,20774,20163,96306,93631,124062,48786,143290,88439,192355,80255
%N A036574 a(n) = least number not of form floor((a^2+b^2)/n).
%C A036574 a(n) = floor(A001481(k)/n) + 1 for the least k such that floor(A001481(k+1)/n) - floor(A001481(k)/n) > 1. - _Robert Israel_, Jul 07 2026
%H A036574 Robert Israel, <a href="/A036574/b036574.txt">Table of n, a(n) for n = 1..66</a>
%p A036574 N:= 50: # for a(1) .. a(N)
%p A036574 V:= Vector(N): Cands:= {$1..N}: count:= 0:
%p A036574 x:= 0:
%p A036574 for y from 1 while count < N do
%p A036574 if andmap(t -> t[2]::even or t[1] mod 4 <> 3, ifactors(n)[2]) then
%p A036574   J:= select(t -> floor(y/t) - floor(x/t) > 1, Cands);
%p A036574   for t in J do
%p A036574     V[t]:= floor(x/t)+1;
%p A036574     count:= count+1;
%p A036574   od;
%p A036574   Cands:= Cands minus J;
%p A036574   x:= y
%p A036574 fi
%p A036574 od:
%p A036574 convert(V,list); # _Robert Israel_, Jul 07 2026
%Y A036574 Cf. A001481.
%K A036574 nonn,changed
%O A036574 1,1
%A A036574 _David W. Wilson_
