%N A036505 Numerator of (n+1)^n/n!.
%C A036505 Also denominator of Sum_{k=0..n} binomial(n,k)*(k/n)^k*((n-k)/n)^(n-k) [Prodinger]. - _N. J. A. Sloane_, Jul 31 2013
%H A036505 Vincenzo Librandi, <a href="/A036505/b036505.txt">Table of n, a(n) for n = 0..200</a>
%H A036505 Helmut Prodinger, <a href="https://doi.org/10.37236/3309">An identity conjectured by Lacasse via the tree function</a>, Electronic Journal of Combinatorics, 20(3) (2013), #P7.
%F A036505 a(n) = A090878(n+1)/Sum_{k=0..n+1} (A128433(n+1)/A128434(n+1)). - _Reinhard Zumkeller_, Mar 03 2007
%F A036505 G.f.: -x*e^(-LambertW(-x))/((LambertW(-x)+1)*LambertW(-x)). - _Vladimir Kruchinin_, Feb 04 2013
%F A036505 A simpler g.f. is 1/(1 + LambertW(-x)). - _Jean-François Alcover_, Feb 04 2013
%F A036505 a(n) = denominator(hypergeom([1, -n], [], -1/(n+1))). - _Peter Luschny_, Mar 09 2026
%p A036505 a := n -> numer((n+1)^n/factorial(n)): A036505 := [seq(a(n), n=0..20)]; # _Muniru A Asiru_, Feb 12 2018
%p A036505 # Alternative:
%p A036505 Q := n -> hypergeom([1, -n], [], -1/(n+1)): seq(denom(simplify(Q(n))), n = 0..20); # _Peter Luschny_, Mar 09 2026
%t A036505 CoefficientList[Series[1/(1 + ProductLog[-x]), {x, 0, 21}], x] // Numerator // Rest (* _Jean-François Alcover_, Feb 04 2013, after _Vladimir Kruchinin_ *)
%o A036505 (Magma) [Numerator((n+1)^n/Factorial(n)): n in [0..20]]; // _Vincenzo Librandi_, Sep 10 2013
%o A036505 (GAP) List([0..20], n -> NumeratorRat((n+1)^n/Factorial(n))); # _Muniru A Asiru_, Feb 12 2018
%o A036505 (PARI) my(x='x+O('x^30)); apply(x -> numerator(x), Vec(-1+1/(1+lambertw(-x)))) \\ _G. C. Greubel_ and _Michel Marcus_, Feb 08 2019
%o A036505 (SageMath) [numerator((n+1)^n/factorial(n)) for n in (0..20)] # _G. C. Greubel_, Feb 08 2019
%o A036505 (Python)
%o A036505 from math import gcd
%o A036505 def A036505(n: int) -> int:
%o A036505     t_num, t_den = 1, 1   # term
%o A036505     s_num, s_den = 0, 1   # sum
%o A036505     for k in range(n + 1):
%o A036505         if k > 0:
%o A036505             t_num *= (n - k + 1)
%o A036505             t_den *= (n + 1)
%o A036505             g = gcd(t_num, t_den)
%o A036505             t_num //= g
%o A036505             t_den //= g
%o A036505         num = s_num * t_den + t_num * s_den
%o A036505         den = s_den * t_den
%o A036505         g = gcd(num, den)
%o A036505         s_num, s_den = num // g, den // g
%o A036505     return s_den
%o A036505 L = [A036505(n) for n in range(21)]; print(L) # _Peter Luschny_, Mar 17 2026
%o A036505 (Python)
%o A036505 from sympy import factorint
%o A036505 from sympy.ntheory.factor_ import digits
%o A036505 def A036505(n):
%o A036505     m = (n+1)**n
%o A036505     for p, e in factorint(n+1).items():
%o A036505         m //= p**min(e*n,(n-sum(digits(n,p)[1:]))//(p-1))
%o A036505     return m # _Chai Wah Wu_, May 03 2026
