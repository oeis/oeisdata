%I A213269 #21 Jun 21 2026 09:55:38
%S A213269 0,6,60,540,5040,50400,544320,6350400,79833600,1077753600,15567552000,
%T A213269 239740300800,3923023104000,67999067136000,1244905998336000,
%U A213269 24008901396480000,486580401635328000,10339833534750720000,229909239772692480000,5339003456943636480000
%N A213269 The number of edges in the directed graph of the 2-opt landscape of the symmetric TSP.
%H A213269 J. W. Barnes, B. Dimova, S. P. Dokov, and A. Solomon, <a href="https://doi.org/10.1016/S0893-9659(03)80054-X">The theory of elementary landscapes</a>, Applied Mathematics Letters, 16(3) (2003), 337-343.
%F A213269 a(n) = n!*(n-3)/4.
%F A213269 From _Amiram Eldar_, Jun 21 2026: (Start)
%F A213269 Sum_{n>=4} 1/a(n) = 2*(Ei(1) - gamma)/3 - 8*e/3 + 59/9, where e = A001113, gamma = A001620 and Ei(1) = A091725.
%F A213269 Sum_{n>=4} (-1)^n/a(n) = 2*(gamma - Ei(-1))/3 - 4/(3*e) + 1/9, where Ei(-1) = -A099285. (End)
%e A213269 For a 3 city TSP n=3 there are no edges in the landscape.
%e A213269 For a 4 city TSP there are 6 edges in the directed graph of the 2-opt landscape.
%t A213269 Table[(n!(n-3))/4,{n,3,30}] (* _Harvey P. Dale_, Oct 15 2016 *)
%o A213269 (GAP)
%o A213269 edges:=n->Factorial(n)*(n-3)/4;
%o A213269 List([3..30], edges);
%Y A213269 Cf. A001113, A001620, A091725, A099285.
%K A213269 nonn,easy
%O A213269 3,2
%A A213269 _Paul John Sutcliffe_, Jun 07 2012
