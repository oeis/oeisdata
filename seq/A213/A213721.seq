%I A213721 #20 Mar 28 2026 23:26:55
%S A213721 2,7,31,67,97,103,157,199,277,223,307,383,439,367,547,463,673,613,577,
%T A213721 751,643,733,787,727,853,983,997,967,1171,1223,1063,1087,1123,1613,
%U A213721 1237,1279,1471,1453,1669,1423,1483,1597,1627,1543,1567,1747,2039,1753,1867,1951
%N A213721 Smallest prime that is the sum of four nonzero squares in exactly n ways, or -1 if there is no such prime.
%C A213721 a(88) > 10^6 if it is not -1. - _Robert Israel_, Mar 27 2026
%H A213721 <a href="/index/Su#ssq">Index entries for sequences related to sums of squares</a>
%e A213721 a(2) = 31 because 31 = 2*1 + 4 + 25 = 4 + 3*9.
%p A213721 N:= 10000: # to consider primes <= N
%p A213721 V:= Vector(N):
%p A213721 for i from 1 while 4*i^2 <= N do
%p A213721   si:= i^2;
%p A213721   for j from i while si + 3*j^2 <= N do
%p A213721     sj:= i^2 + j^2;
%p A213721     for k from j while sj + 2*k^2 <= N do
%p A213721       sk:= sj + k^2;
%p A213721       m0:= k + 1 - (k + sk mod 2);
%p A213721       for m from m0 by 2 do
%p A213721         v:= sk + m^2; if v > N then break fi;
%p A213721         V[v]:= V[v]+1;
%p A213721 od od od od:
%p A213721 R:= 'R':
%p A213721 p:= 1:
%p A213721 do
%p A213721   p:= nextprime(p);
%p A213721   if p > N then break fi;
%p A213721   v:= V[p];
%p A213721   if not assigned(R[v]) then R[v]:= p fi;
%p A213721 od:
%p A213721 inds:= map(op,{indices(R)}):
%p A213721 u:= min({$0 .. (1+max(inds))} minus inds):
%p A213721 [seq(R[i],i=0..u-1)]; # _Robert Israel_, Mar 27 2026
%t A213721 lst = {}; Do[p = 2; While[True, If[PrimeQ[p] && Length@Select[PowersRepresentations[p, 4, 2], ! MemberQ[#, 0] &] == n, AppendTo[lst, p]; Break[]]; p++], {n, 0, 49}]; lst
%Y A213721 Cf. A025416.
%K A213721 nonn,changed
%O A213721 0,1
%A A213721 _Arkadiusz Wesolowski_, Nov 02 2012
%E A213721 Name edited by _Robert Israel_, Mar 27 2026
