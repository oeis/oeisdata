%S A177775 1,1,-4,39,-580,11480,-285116,8617217,-311138320,13245849264,
%T A177775 -657721045720,37721447340698,-2476051190767536,184449202720026868,
%U A177775 -15472664808232769104,1451318259607442040637,-151254398423642331357224,17414648221422452867182432,-2203639562315970209774977028
%N A177775 G.f. A(x) satisfies: [x^n] A^{n}(x) = [x^n] A^{n-1}(x) for n > 2 where A^{n+1}(x) = A^{n}(A(x)) denotes iteration with A^0(x)=x.
%C A177775 Conjecture: a(n) is odd iff n is a power of 2. - _Paul D. Hanna_, May 19 2026
%H A177775 Paul D. Hanna, <a href="/A177775/b177775.txt">Table of n, a(n) for n = 1..256</a>
%e A177775 G.f.: A(x) = x + x^2 - 4*x^3 + 39*x^4 - 580*x^5 + 11480*x^6 - 285116*x^7 + 8617217*x^8 - 311138320*x^9 + ...
%e A177775 Coefficients in the initial iterations of A(x) begin:
%e A177775   [1, 1, -4,  39,   -580,  11480,  -285116,   8617217, ...];
%e A177775   [1, 2,(-6), 59,   -898,  18228,  -463816,  14330618, ...];
%e A177775   [1, 3,(-6),(66), -1048,  21932,  -572180,  18055088, ...];
%e A177775   [1, 4, -4, (66),(-1100), 23750,  -634548,  20415192, ...];
%e A177775   [1, 5,  0,  65, (-1100),(24430), -666940,  21835125, ...];
%e A177775   [1, 6,  6,  69,  -1070, (24430),(-679756), 22603642, ...];
%e A177775   [1, 7, 14,  84,  -1008,  24038, (-679756),(22919008), ...];
%e A177775   [1, 8, 24, 116,   -888,  23492,  -671320, (22919008), ...]; ...
%e A177775 where the above coefficients in parenthesis illustrate the property that the coefficients of x^n in A^{n}(x) and in A^{n-1}(x) are equal.
%e A177775 The main diagonal in the above table equals A395842.
%o A177775 (PARI) \\ Routine returns the n-th iteration of a function F
%o A177775 {IT(n,F) = my(G=x); for(i=1,n, G = subst(F,x,G));G}
%o A177775 \\ Calculate and print the terms
%o A177775 {a(n) = my(V=[0,1,1],A,m); for(i=3,n, V = concat(V,0); m = #V-2; A=Ser(V);
%o A177775 V[#V] = -polcoef( IT(m+1,A) - IT(m,A), m+1) ); A=Ser(V); polcoef(GF=A,n)}
%o A177775 {upto(n) = a(n); Vec(GF)}
%o A177775 upto(20) \\ program revised by _Paul D. Hanna_, May 19 2026
