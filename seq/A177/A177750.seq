%I A177750 #12 Jul 07 2026 14:06:57
%S A177750 1,1,-4,32,-346,4472,-65292,1043753,-17921768,326358300,-6247293860,
%T A177750 124904785856,-2595750453348,55864370827852,-1241459233450784,
%U A177750 28421477429433280,-669049539675142690,16169348706143246816,-400669193608178111624,10168617943338798853142,-264065780322430320166880
%N A177750 G.f. A(x) satisfies: A(A(A(x))) = A(A(x)) + x^2 = A^3(x)=A^2(x)+x^2, where A^n(x) denotes the n-th iteration of A(x).
%H A177750 Paul D. Hanna, <a href="/A177750/b177750.txt">Table of n, a(n) for n = 1..450</a>
%F A177750 Unsigned series reversion yields A141372, the g.f. G(x) of which satisfies: G(x) = x + G(G(G(x)))^2
%F A177750 .
%F A177750 From _Paul D. Hanna_ Jul 04 2026 (Start):
%F A177750 A(x) = x + R^2(x)^2 where R(A(x)) = x and R(x) = x - R^3(x)^2 so that -R(-x) is the g.f. of A141372.
%F A177750 A^3(x) = A^2(x) + x^2.
%F A177750 A^4(x) = A^2(x) + A(x)^2 + x^2.
%F A177750 A^5(x) = A^2(x) + A^2(x)^2 + A(x)^2 + x^2.
%F A177750 A^6(x) = 2*A^2(x)^2 + (1 + 2*x^2)*A^2(x) + A(x)^2 + x^4 + x^2
%F A177750 (End)
%e A177750 G.f.: A(x) = x + x^2 - 4*x^3 + 32*x^4 - 346*x^5 + 4472*x^6 +...
%e A177750 Compare the iterations:
%e A177750 A(A(x)) = x +2*x^2 -6*x^3 +45*x^4 -472*x^5 +5990*x^6 -86368*x^7 +...
%e A177750 A(A(A(x))) = x +3*x^2 -6*x^3 +45*x^4 -472*x^5 +5990*x^6 -86368*x^7 +...
%e A177750 From _Paul D. Hanna_ Jul 04 2026 (Start):
%e A177750 Also, R(x) = sqrt( A^2(x) - A(x) ) begins
%e A177750 R(x) = x - x^2 + 6*x^3 - 57*x^4 + 684*x^5 - 9512*x^6 + 146848*x^7 - 2455208*x^8 + 43764802*x^9 + ... + (-1)^(n-1)*A141372(n)*x^n + ...
%e A177750 where A(R(x)) = x and A(x) = x + R^2(x)^2.
%e A177750 (End)
%o A177750 (PARI) {a(n)=local(A=x+sum(k=2,n-1,a(k)*x^k)+x*O(x^n),B=subst(A,x,A));polcoeff(x+x^2+B-subst(B,x,A),n)}
%Y A177750 Cf. A141372 (unsigned inverse), A138740, A177751,
%K A177750 sign
%O A177750 1,3
%A A177750 _Paul D. Hanna_, May 12 2010
