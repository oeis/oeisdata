%I A300595 #20 Apr 12 2026 08:38:12
%S A300595 1,4,243,40448,12519125,6111917748,4308276119854,4151360558858752,
%T A300595 5268077625693186225,8567999843251994553500,
%U A300595 17491034862909191177473132,44081002571786307016424642880,135294991782833277819666508563622,499980220350805674732349875409752344,2203045016526580123761644939382016407000,11476028442989415865296132639050660100915200
%N A300595 O.g.f. A(x) satisfies [x^n] exp( n^3 * A(x) ) = n^3 * [x^(n-1)] exp( n^3 * A(x) ) for n >= 1.
%C A300595 Compare to: [x^n] exp( n^3 * x ) = n^2 * [x^(n-1)] exp( n^3 * x ) for n>=1.
%C A300595 It is conjectured that this sequence consists entirely of integers.
%H A300595 Paul D. Hanna, <a href="/A300595/b300595.txt">Table of n, a(n) for n = 1..200</a>
%F A300595 O.g.f. equals the logarithm of the e.g.f. of A300594.
%F A300595 a(n) ~ c * n!^3 * n^3, where c = 0.40774346023... - _Vaclav Kotesovec_, Oct 14 2020
%F A300595 From _Seiichi Manyama_, Apr 12 2026: (Start)
%F A300595 G.f. A(x) satisfies [x^n] exp(n^3*A(x)) * (1 - n^3*x) = 0, for n >= 1.
%F A300595 a(n) = n^(3*n-4) - (1/n) * Sum_{k=1..n-1} k * c_n(k) * e_n(n-k),
%F A300595 where c_n(k) = a(k) - n^(3*k-3)/k for 1 <= k <= n-1,
%F A300595 and e_n(0) = 1, e_n(k) = (n^3/k) * Sum_{j=1..k} j * c_n(j) * e_n(k-j) for 1 <= k <= n-1. (End)
%e A300595 O.g.f.: A(x) = x + 4*x^2 + 243*x^3 + 40448*x^4 + 12519125*x^5 + 6111917748*x^6 + 4308276119854*x^7 + 4151360558858752*x^8 + 5268077625693186225*x^9 + ...
%e A300595 where
%e A300595 exp(A(x)) = 1 + x + 9*x^2/2! + 1483*x^3/3! + 976825*x^4/4! + 1507281021*x^5/5! + 4409747597401*x^6/6! + 21744850191313999*x^7/7! + ... + A300594(n)*x^n/n! + ...
%e A300595 such that: [x^n] exp( n^3 * A(x) ) = n^3 * [x^(n-1)] exp( n^3 * A(x) ).
%o A300595 (PARI) {a(n) = my(A=[1]); for(i=1, n+1, A=concat(A, 0); V=Vec(Ser(A)^((#A-1)^3)); A[#A] = ((#A-1)^3*V[#A-1] - V[#A])/(#A-1)^3 ); polcoeff( log(Ser(A)), n)}
%o A300595 for(n=1, 30, print1(a(n), ", "))
%o A300595 (Ruby)
%o A300595 def A300595(n)
%o A300595   a = [0]
%o A300595   (1..n).each{|i|
%o A300595     c = [0] + (1..i - 1).map{|k| a[k] - i ** (3 * k - 3) / k.to_r}
%o A300595     e = [1]
%o A300595     (1..i - 1).each{|k| e << i ** 3 / k.to_r * (1..k).inject(0){|s, j| s + j * c[j] * e[k - j]}}
%o A300595     a << i ** (3 * i - 4) - (1..i - 1).inject(0){|s, k| s + k * c[k] * e[i - k]}.to_i / i
%o A300595   }
%o A300595   a[1..-1]
%o A300595 end
%o A300595 p A300595(20) # _Seiichi Manyama_, Apr 12 2026
%Y A300595 Cf. A300594, A296171, A300591, A300593, A300619.
