%I A255349 #18 Jul 04 2026 09:57:07
%S A255349 20,35,77,84,98,99,104,119,132,153,174,175,186,189,195,216,224,230,
%T A255349 231,245,246,260,272,279,285,350,351,363,374,384,399,425,429,440,455,
%U A255349 459,494,527,539,551,560,575,594,608,609,615,620,644,645,650,665,696,714,730,735,759,779,780
%N A255349 Numbers k such that k*(k+1) is divisible by some m*(m+1) with none of {k, k+1} divisible by any of {m, m+1}.
%C A255349 A subsequence of A255346, see there for further information.
%H A255349 Robert Israel, <a href="/A255349/b255349.txt">Table of n, a(n) for n = 1..10000</a>
%H A255349 T. Korimort, <a href="https://www.linkedin.com/groups/Let-x-y-be-positive-4510047.S.5973962079390941188">How many (x,y) satisfy x(x+1)|y(y+1),...</a>, Number Theory group on LinkedIn.com, Feb. 2014.
%e A255349 20 is a term since 20*21=420 is divisible by 14*15=210 and none of {20, 21} is divisible by any of {14, 15}.
%e A255349 35 is a term since 35*36 = 1260 is divisible by 14*15 = 210 (and also by 20*21 = 420).
%e A255349 69 is not a term although 69*70 = 4830 is divisible by 14*15 = 210, because 14 divides 70.
%p A255349 filter:= proc(n) local w,m;
%p A255349   for w in select(t -> issqr(1+4*t), NumberTheory:-Divisors(n*(n+1)) minus {1,n*(n+1)}) do
%p A255349     m:= (sqrt(1+4*w)-1)/2;
%p A255349     if n mod m > 0 and (n+1) mod m > 0 and n mod (m+1) > 0 and (n+1) mod (m+1) > 0 then return true fi
%p A255349   od;
%p A255349   false
%p A255349 end proc:
%p A255349 select(filter, [$1..1000]); # _Robert Israel_, Jul 03 2026
%o A255349 (PARI) is(n)={omega(n)>=2&&omega(n+1)>=2&&fordiv(n*(n+1),x,x>=n&&return;n*(n+1)%(x*(x+1))&&next;n%x||next;(n+1)%x||next;n%(x+1)||next;(n+1)%(x+1)&&return(1))}
%Y A255349 Cf. A074851, A255346.
%K A255349 nonn,changed
%O A255349 1,1
%A A255349 _M. F. Hasler_, Feb 21 2015
