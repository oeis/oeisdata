%I A255204 #13 Jul 22 2026 15:34:04
%S A255204 29,37,43,59,79,97,103,109,113,137,151,181,191,197,199,223,233,241,
%T A255204 257,263,281,283,293,307,373,379,397,401,419,421,433,439,449,461,499,
%U A255204 521,523,547,557,563,577,601,617,619,641,659,661,701,727,739,743,761,769
%N A255204 Primes p for which exactly one base b with 1 < b < p exists such that p is a base b Wieferich prime.
%C A255204 p = prime(n) such that A242830(n) = 1.
%H A255204 Robert Israel, <a href="/A255204/b255204.txt">Table of n, a(n) for n = 1..2500</a>
%p A255204 filter:= proc(p)
%p A255204    if not isprime(p) then return false fi;
%p A255204    nops(select( b -> b &^ (p-1) mod (p^2) = 1, [$2..p-1]))=1;
%p A255204 end proc:
%p A255204 select(filter, [seq(i,i=3..1000,2)]); # _Robert Israel_, Jul 22 2026
%o A255204 (PARI) forprime(p=1, , b=2; i=0; while(b < p, if(Mod(b, p^2)^(p-1)==1, i++); b++); if(i==1, print1(p, ", ")))
%Y A255204 Cf. A255203, A255205, A255206, A255207, A255208, A255209, A255210.
%K A255204 nonn,changed
%O A255204 1,1
%A A255204 _Felix Fröhlich_, Feb 17 2015
