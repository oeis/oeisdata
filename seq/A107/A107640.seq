%S A107640 1,2,1,4,3,5,2,4,1,4,3,5,8,2,4,7,1,4,8,10,3,5,8,11,2,4,7,11,1,4,8,10,
%T A107640 13,3,5,8,11,13,2,4,7,11,13,1,4,8,10,13,16,3,5,8,11,13,16,2,4,7,11,13,
%U A107640 16,18,1,4,8,10,13,16,18,3,5,8,11,13,16,20
%N A107640 Irregular triangle read by rows: positions of 2's in the triangle generated by the morphism 1->2, 2->3, 3->123 starting from 2.
%e A107640 Begins:
%e A107640   row triangle    positions of 2's
%e A107640    1  2        -> 1;
%e A107640    2  3        -> none;
%e A107640    3  123      -> 2;
%e A107640    4  2312     -> 1, 4;
%e A107640    5  31232    -> 3, 5;
%e A107640    6  123231   -> 2, 4;
%e A107640    7  2312331  -> 1, 4;
%e A107640    8  31232312 -> 3, 5, 8;
%t A107640 s[1] = {2}; s[2] = {3}; s[3] = {1, 2, 3};
%t A107640 t[a_] := Flatten[s /@ a];
%t A107640 p[0] = {1}; p[1] = t[p[0]]; p[n_] := t[p[n - 1]];
%t A107640 a = Table[Flatten[Table[If[(Length[p[i]]) >= j && (p[i][[j]] == 2), j, {}], {j, 1, i}]], {i, 1, 20}];
%t A107640 MatrixForm[a] //Flatten
