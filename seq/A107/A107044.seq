%N A107044 A symmetric factorial triangle, read by rows: T(n,k) = min(k,n-k)!; n>=2, 1<=k<=n-1.
%C A107044 Take antidiagonals of A003983, replace each term with its factorial.
%H A107044 Paolo Xausa, <a href="/A107044/b107044.txt">Table of n, a(n) for n = 2..11176</a> (rows 2..150 of triangle, flattened).
%F A107044 T(n,k) = min(k,n-k)!.
%e A107044 First few rows of the triangle are:
%e A107044   1;
%e A107044   1, 1;
%e A107044   1, 2, 1;
%e A107044   1, 2, 2,  1;
%e A107044   1, 2, 6,  2, 1;
%e A107044   1, 2, 6,  6, 2, 1;
%e A107044   1, 2, 6, 24, 6, 2, 1;
%e A107044   ...
%p A107044 T:= (n, k) -> min(k, n-k)!:
%p A107044 seq(seq(T(n, k), k=1..n-1), n=2..13);  # _Alois P. Heinz_, Mar 22 2026
%t A107044 A107044[n_, k_] := Min[k, n - k]!;
%t A107044 Table[A107044[n, k], {n, 2, 13}, {k, n - 1}] (* _Paolo Xausa_, Mar 22 2026 *)
