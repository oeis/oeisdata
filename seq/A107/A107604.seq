%S A107604 2,2,2,2,5,2,5,2,5,7,2,5,7,2,5,7,2,5,7,10,2,5,7,10,2,5,7,10,2,5,7,10,
%T A107604 13,2,5,7,10,13,2,5,7,10,13,15,2,5,7,10,13,15,2,5,7,10,13,15,2,5,7,10,
%U A107604 13,15,18,2,5,7,10,13,15,18,2,5,7,10,13,15,18,20
%N A107604 Irregular triangle read by rows of the positions of 2 in the triangle generated by the morphism 1->12, 2->1.
%H A107604 Sean A. Irvine, <a href="https://github.com/archmageirvine/joeis/blob/master/src/irvine/oeis/a107/A107604.java">Java program</a> (github)
%e A107604 Begins:
%e A107604   row triangle              positions of 2's
%e A107604    2  12(1)              -> 2;
%e A107604    3  121(12)            -> 2;
%e A107604    4  1211(212)          -> 2;
%e A107604    5  12112(121)         -> 2, 5;
%e A107604    6  121121(2112)       -> 2, 5;
%e A107604    7  1211212(1121)      -> 2, 5, 7;
%e A107604    8  12112121(12112)    -> 2, 5, 7;
%e A107604    9  121121211(211212)  -> 2, 5, 7;
%e A107604   10  1211212112(112121) -> 2, 5, 7, 10;
%e A107604 at each row we expand one more symbol and report the positions of 2 that are <= row number.
%t A107604 s[1] = {1, 2}; s[2] = {1};; t[a_] := Flatten[s /@ a]; p[0] = {1}; p[1] = t[p[0]]; p[n_] := t[p[n - 1]] a = Table[Flatten[Table[If[p[i][[j]] == 2, j, {}], {j, 1, i}]], {i, 1, 20}]
%Y A107604 Cf. A000045.
%K A107604 nonn,tabf,changed
%O A107604 2,1
