%N A366327 G.f. satisfies A(x) = (1 + x) * (1 + x/A(x)^3).
%H A366327 Robert Israel, <a href="/A366327/b366327.txt">Table of n, a(n) for n = 0..920</a>
%F A366327 a(n) = (-1)^(n-1) * Sum_{k=0..n} binomial(4*k-1,k) * binomial(n+2*k-2,n-k)/(4*k-1).
%F A366327 D-finite with recurrence: 12*(n - 1)*(3*n - 1)*(3*n + 1)*a(n) + 6*(15*n - 1)*(3*n + 2)*(2*n + 1)*a(n + 1) + (2023*n^3 + 4856*n^2 + 2961*n + 480)*a(n + 2) + (2750*n^3 + 12211*n^2 + 13245*n + 1464)*a(n + 3) + (121*n^3 - 4171*n^2 - 26676*n - 36600)*a(n + 4) - 4*(428*n^3 + 5896*n^2 + 25335*n + 33222)*a(n + 5) - (391*n^3 + 5150*n^2 + 19047*n + 13812)*a(n + 6) + (310*n^3 + 6827*n^2 + 49941*n + 121380)*a(n + 7) + 3*(3*n + 22)*(n + 8)*(3*n + 23)*a(n + 8) = 0. - _Robert Israel_, Jun 07 2026
%p A366327 f:= gfun:-rectoproc({12*(n - 1)*(3*n - 1)*(3*n + 1)*a(n) + 6*(15*n - 1)*(3*n + 2)*(2*n + 1)*a(n + 1) + (2023*n^3 + 4856*n^2 + 2961*n + 480)*a(n + 2) + (2750*n^3 + 12211*n^2 + 13245*n + 1464)*a(n + 3) + (121*n^3 - 4171*n^2 - 26676*n - 36600)*a(n + 4) - 4*(428*n^3 + 5896*n^2 + 25335*n + 33222)*a(n + 5) - (391*n^3 + 5150*n^2 + 19047*n + 13812)*a(n + 6) + (310*n^3 + 6827*n^2 + 49941*n + 121380)*a(n + 7) + 3*(3*n + 22)*(n + 8)*(3*n + 23)*a(n + 8), a(0) = 1, a(1) = 2, a(2) = -5, a(3) = 33, a(4) = -260, a(5) = 2263, a(6) = -20979, a(7) = 203124}, a(n), remember):
%p A366327 map(f, [$0..30]); # _Robert Israel_, Jun 07 2026
%o A366327 (PARI) a(n) = (-1)^(n-1)*sum(k=0, n, binomial(4*k-1, k)*binomial(n+2*k-2, n-k)/(4*k-1));
