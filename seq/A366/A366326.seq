%N A366326 G.f. satisfies A(x) = (1 + x) * (1 + x/A(x)^2).
%H A366326 Winston de Greef, <a href="/A366326/b366326.txt">Table of n, a(n) for n = 0..1067</a>
%F A366326 a(n) = (-1)^(n-1) * Sum_{k=0..n} binomial(3*k-1,k) * binomial(n+k-2,n-k)/(3*k-1).
%F A366326 D-finite with recurrence: 2*(2*n - 1)*(n - 1)*a(n) + (13*n + 5)*(3*n - 1)*a(n + 1) + (35*n^2 + 58*n - 3)*a(n + 2) - (35*n^2 + 222*n + 325)*a(n + 3) - (3*n + 13)*(13*n + 47)*a(n + 4) - 2*(n + 5)*(2*n + 9)*a(n + 5) = 0. - _Robert Israel_, Jun 07 2026
%p A366326 f:= gfun:-rectoproc({ 2*(2*n - 1)*(n - 1)*a(n) + (13*n + 5)*(3*n - 1)*a(n + 1) + (35*n^2 + 58*n - 3)*a(n + 2) - (35*n^2 + 222*n + 325)*a(n + 3) - (3*n + 13)*(13*n + 47)*a(n + 4) - 2*(n + 5)*(2*n + 9)*a(n + 5), a(0) = 1, a(1) = 2, a(2) = -3, a(3) = 14, a(4) = -78, a(5) = 479}, a(n), remember):
%p A366326 map(f, [$0..30]); # _Robert Israel_, Jun 07 2026
%o A366326 (PARI) a(n) = (-1)^(n-1)*sum(k=0, n, binomial(3*k-1, k)*binomial(n+k-2, n-k)/(3*k-1));
