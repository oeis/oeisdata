%t A366719 Table[FactorInteger[12^n + 1][[1,1]], {n, 0, 69}] (* _Paul F. Marrero Romero_, Oct 25 2023 *)
%o A366719 (Python)
%o A366719 from sympy import nextprime
%o A366719 def A366719(n):
%o A366719     p = 2
%o A366719     while True:
%o A366719         if pow(12,n,p)==p-1:
%o A366719             return p
%o A366719         p = nextprime(p) # _Chai Wah Wu_, Jun 09 2026
