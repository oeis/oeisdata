%S A366723 1,5,21,50,121,236,447,736,1247,1896,2898,4151,5972,8146,11292,14797,
%T A366723 19643,25248,32564,40663,51515,63168,78119,94452,114998,136933,164849,
%U A366723 193753,229714,268334,314711,362824,422746,483950,558046,635070,726461,820420,934186,1048245
%N A366723 a(n) = Sum_{k=1..n} (-1)^(k-1) * binomial(floor(n/k)+4,5).
%F A366723 a(n) = Sum_{k=1..n} binomial(k+3,4) * (floor(n/k) mod 2).
%F A366723 G.f.: -1/(1-x) * Sum_{k>=1} (-x)^k/(1-x^k)^5 = 1/(1-x) * Sum_{k>=1} binomial(k+3,4) * x^k/(1+x^k).
%o A366723 (PARI) a(n) = sum(k=1, n, (-1)^(k-1)*binomial(n\k+4, 5));
%o A366723 (Python)
%o A366723 from math import comb
%o A366723 def A366723(n):
%o A366723     c, j = 0, 1
%o A366723     while j <= n:
%o A366723         k = n//j
%o A366723         m = n//k
%o A366723         if m-j&1^1:
%o A366723             c += (comb(k+4,5) if j&1 else -comb(k+4,5))
%o A366723         j = m+1
%o A366723     return c # _Chai Wah Wu_, May 18 2026
