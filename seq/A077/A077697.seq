%I A077697 #10 Jul 10 2026 10:26:38
%S A077697 6,11,76,719,141,1351,1329,5507,2683,10638,456,9789,8442,3764,4834,
%T A077697 13652,4587,8537,28519,40677,45956,31228,66761,92324,142832,92387,
%U A077697 42406,171292,21789,66337,10699,143976,569479,130453,183686,203523,25027,824943,1088593,510029,583643,1045241,2471149
%N A077697 a(n) = A077696(n)/A077696(n-1).
%p A077697 f:= proc(t) local S,Sd,Sr,nS, k,T,Td,i,j;
%p A077697   S:= Statistics:-Tally(convert(t,base,10));
%p A077697   Sd:= map(lhs,S);
%p A077697   Sr:= map(rhs,S);
%p A077697   nS:= nops(S);
%p A077697   for k from 2 do
%p A077697     if k*t mod 10 = 0 then next fi;
%p A077697     T:= Statistics:-Tally(convert(k*t,base,10));
%p A077697     Td:= map(lhs,T);
%p A077697     if andmap(j -> member(Sd[j],Td,'i') and Sr[j] <= rhs(T[i]), [$1..nS]) then return k*t fi
%p A077697   od
%p A077697 end proc:
%p A077697 R:= NULL: x:= 2:
%p A077697 for i from 1 to 44 do
%p A077697   xp:= f(x);
%p A077697 R:= R, xp/x;
%p A077697 x:= xp;
%p A077697 od:
%p A077697 R; # _Robert Israel_, Jul 09 2026
%Y A077697 Cf. A077696.
%K A077697 base,nonn,changed
%O A077697 1,1
