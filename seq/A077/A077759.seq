%I A077759 #13 Apr 18 2026 16:53:33
%S A077759 0,1,3,10,15,21,45,105,136,190,210,231,325,435,465,780,1081,1225,1485,
%T A077759 1596,2415,3081,4005,4465,4560,5253,6670,7021,7750,9730,14365,15576,
%U A077759 16653,17020,19306,20100,20301,23436,24310,24531,30135,30628,36585
%N A077759 Smaller of the two successive triangular numbers which differ in the use of only one digit.
%C A077759 The i-th triangular number T(i) is in the sequence if and only if its successor T(i+1) can be obtained by changing a single digit of T(i) and, if necessary, changing the order of the digits. Thus the sequence does not include 55, even though it and its successor 66 could be said to "differ in the use of only one digit" (i.e., using 5 vs. using 6). Triangular numbers such as 404550, whose successor 405450 uses the same digits in the same frequencies, would also be excluded. - _Jon E. Schoenfield_, Sep 05 2009
%H A077759 Robert Israel, <a href="/A077759/b077759.txt">Table of n, a(n) for n = 1..10000</a>
%e A077759 231 belongs to this sequence as 231 and 253 differ in the use of only one digit, i.e., 1 and 5.
%p A077759 R:= NULL: Lb:= [0]: Mb:= {[]}: db:= 0:
%p A077759 for i from 1 to 1000 do
%p A077759    La:= Lb; Ma:= Mb; da:= db;
%p A077759    b:= i*(i+1)/2; db:= ilog10(b);
%p A077759    Lb:= sort(convert(b,base,10));
%p A077759    Mb:= {seq(subsop(i=NULL,Lb),i=1..nops(Lb))};
%p A077759    if da=db and Lb <> La and Mb intersect Ma <> {} then
%p A077759      R:= R,(i-1)*i/2
%p A077759    fi
%p A077759 od:
%p A077759 R; # _Robert Israel_, Apr 16 2026
%K A077759 base,nonn,changed
%O A077759 1,3
%A A077759 _Amarnath Murthy_, Nov 21 2002
%E A077759 More terms from _Jon E. Schoenfield_, Sep 05 2009
