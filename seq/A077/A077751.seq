%I A077751 #15 Apr 16 2026 16:51:04
%S A077751 0,1,21952,343,405224,5359375,636056,79507,8,970299,0,11712548511,
%T A077751 1259712,138188413,0,0,16777216,17034106517,0,1902014919,0,
%U A077751 2117368939321,0,23076099423,242970624,2543302125,0,27,2815166528,29503629,0,315960389731,32157432
%N A077751 Smallest cube that begins and ends in n, or 0 if no such cube exists.
%H A077751 Robert Israel, <a href="/A077751/b077751.txt">Table of n, a(n) for n = 0..10000</a>
%p A077751 f:= proc(n) local m,d,x,R,Rn,n1,n2,n0;
%p A077751       m:= 1+ilog10(n);
%p A077751       R:= map(t -> rhs(op(t)), {msolve(x^3=n,10^m)});
%p A077751       if R = {} then return 0 fi;
%p A077751       for d from 0 do
%p A077751         n1:= ceil(surd(n*10^d,3));
%p A077751         n2:= ceil(surd((n+1)*10^d,3))-1;
%p A077751         Rn:= (R -~ n1) mod 10^m;
%p A077751         n0:= min(Rn) + n1;
%p A077751         if n0 <= n2 then return n0^3 fi
%p A077751       od
%p A077751 end proc:
%p A077751 f(0):= 0:
%p A077751 map(f, [$0..50]); # _Robert Israel_, Apr 16 2026
%Y A077751 Cf. A000578, A077752.
%K A077751 nonn,look,base
%O A077751 0,3
