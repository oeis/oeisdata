%S A336398 0,2,1,4,5,14,21,48,85,182,341,704,1365,2774,5461,11008,21845,43862,
%T A336398 87381,175104,349525,699734,1398101,2797568,5592405,11187542,22369621,
%U A336398 44744704,89478485,178967894,357913941,715849728,1431655765,2863355222,5726623061,11453333504
%N A336398 Number of rational knots (or two-bridge knots) with n crossings (chiral pairs counted as distinct).
%H A336398 Paolo Xausa, <a href="/A336398/b336398.txt">Table of n, a(n) for n = 2..1000</a>
%H A336398 C. Ernst and D. W. Sumners, <a href="https://doi.org/10.1017/S0305004100067323">The Growth of the Number of Prime Knots</a>, Math. Proc. Cambridge Philos. Soc., Vol. 102, Iss. 2 (1987), pp. 303-315 (see Theorem 1, formulas for TK_n^*).
%H A336398 Taizo Kanenobu and Toshio Sumi, <a href="https://doi.org/10.1090/S0025-5718-1993-1176711-4">Polynomial Invariants of 2-Bridge Knots through 22 Crossings</a>, Math. Comp., Vol. 60, No. 202 (1993), pp. 771-778, S17 (see Table 2).
%H A336398 <a href="/index/Rec#order_06">Index entries for linear recurrences with constant coefficients</a>, signature (1,3,-1,0,-2,-4).
%F A336398 (2^(n-2) - 1) / 3 if n is even,
%F A336398 (2^(n-2) + 2^((n-1)/2)) / 3 if n = 1 (mod 4),
%F A336398 (2^(n-2) + 2^((n-1)/2) + 2) / 3 if n = 3 (mod 4).
%F A336398 a(n) = a(n-1) + 3*a(n-2) - a(n-3) - 2*a(n-5) - 4*a(n-6).
%F A336398 G.f.: x^3 * (2-x-3*x^2-2*x^4) / ((1-x-2*x^2) * (1-x^2-2*x^4)). - _Elmo R. Oliveira_, Apr 12 2026
%t A336398 LinearRecurrence[{1, 3, -1, 0, -2, -4}, {0, 2, 1, 4, 5, 14}, 50] (* _Paolo Xausa_, Apr 16 2026 *)
%o A336398 (Python) [(2**(n-2) + [-1, 2**(n//2), -1, 2**(n//2)+2][n%4])//3 for n in range(2, 30)]
%Y A336398 Cf. A018240, A090597, A329908.
%K A336398 nonn,easy
