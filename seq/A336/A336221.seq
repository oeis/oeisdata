%I A336221 #22 Jul 06 2026 01:07:02
%S A336221 1547,16526,21081,43251,50752,90078,101630,114707,116967,124913,
%T A336221 189077,189242,205058,205059,217409,221474,222915,229278,229279,
%U A336221 230805,232670,287891,290937,320916,419830,435140,467550,479689,479690,498052,558747,617321,633490,633491,719374,719375,737073
%N A336221 Numbers k such that k, k+1, k+2, k+3 and k+4 are terms of A288041.
%C A336221 Subsequence of numbers k such that k, k+1, k+2, k+3, k+4 and k+5 are terms of A288041: 205058, 229278, 479689, 633490, 719374, 855732, 992975, 992976, 992977, 1271040, 1271041, 1271042.
%H A336221 Robert Israel, <a href="/A336221/b336221.txt">Table of n, a(n) for n = 1..1000</a>
%p A336221 P:= [seq(ithprime(i),i=1..5)]: s:= convert(P,`+`): R:= NULL: count:= 0: m:= 0:
%p A336221 for k from 2 while count < 50 do
%p A336221   p:= nextprime(P[5]);
%p A336221   s:= s + p - P[1];
%p A336221   P:= [P[2],P[3],P[4],P[5],p];
%p A336221   if isprime(s) then
%p A336221       m:= m+1;
%p A336221       if m >= 5 then R:= R, k-4; count:= count+1  fi
%p A336221   else m:= 0
%p A336221   fi;
%p A336221 od:
%p A336221 R; # _Robert Israel_, Jul 05 2026
%t A336221 s = {}; p = Prime @ Range[9]; Do[If[AllTrue[Total @ Partition[p, 5, 1], PrimeQ], AppendTo[s, n]]; p = Join[Rest[p], {NextPrime @ Last[p]}], {n, 10^6}]; s (* _Amiram Eldar_, Jul 22 2020 *)
%Y A336221 Cf. A288041.
%K A336221 nonn
%O A336221 1,1
%A A336221 _Zak Seidov_, Jul 17 2020
