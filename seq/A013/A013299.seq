%I A013299 #30 Mar 30 2026 17:18:28
%S A013299 1,6,135,6300,496125,58939650,9833098275,2191376187000,
%T A013299 628651043645625,225615874552818750,99022807341232149375,
%U A013299 52176017395434685252500,32501310835906189355203125,23625952876870268415897656250,19820486895631521610336998046875
%N A013299 Expansion of e.g.f. -sinh(log(x+1) - arctanh(x)) (even powers only).
%C A013299 Number of degree-2n permutations without odd cycles and with odd number of even cycles, offset 1. E.g.f.: x^2/(2*sqrt(1-x^2)). - _Vladeta Jovovic_, Aug 10 2007
%D A013299 Miklos Bona, Introduction to Enumerative and Analytic Combinatorics, CRC Press, 2025, p. 219.
%H A013299 Alois P. Heinz, <a href="/A013299/b013299.txt">Table of n, a(n) for n = 0..224</a>
%F A013299 a(n) ~ (2*n)^(2*n+2)/exp(2*n). - _Vaclav Kotesovec_, Oct 24 2013
%e A013299 E.g.f. = 1/2!*x^2 + 6/4!*x^4 + 135/6!*x^6 + 6300/8!*x^8 + ...
%p A013299 b:= proc(n, t) option remember; `if`(n=0, t, add(
%p A013299       b(n-2*j, 1-t)*binomial(n-1, 2*j-1)*(2*j-1)!, j=1..n/2))
%p A013299     end:
%p A013299 a:= n-> b(2*n+2,0):
%p A013299 seq(a(n), n=0..14);  # _Alois P. Heinz_, Mar 30 2026
%t A013299 nn = 30; Select[Range[0, nn]! CoefficientList[Series[Sinh[Log[1/(1 - x^2)^(1/2)]], {x, 0, nn}], x], # > 0 &]  (* _Geoffrey Critzer_, Jan 15 2012 *)
%t A013299 With[{nn=30},Take[-CoefficientList[Series[Sinh[Log[x+1]-ArcTanh[x]], {x,0,nn}], x] Range[0,nn]!, {3,-1,2}]] (* _Harvey P. Dale_, Oct 30 2013 *)
%Y A013299 Cf. A013302.
%K A013299 nonn
%O A013299 0,2
%A A013299 _Patrick Demichel_
