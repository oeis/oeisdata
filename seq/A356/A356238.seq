%S A356238 1,8,62,849,8541,206345,2581403,76623522,1617299079,49463993875,
%T A356238 952905453423,59000021366675,1198427462876421,54128102218676115,
%U A356238 2321105129608323165,117387839988330848902,3205342976298888473968,268263812478494295219717
%N A356238 a(n) = Sum_{k=1..n} (k * floor(n/k))^n.
%H A356238 Seiichi Manyama, <a href="/A356238/b356238.txt">Table of n, a(n) for n = 1..386</a>
%F A356238 a(n) = Sum_{k=1..n} k^n * Sum_{d|k} (1 - (1 - 1/d)^n).
%t A356238 a[n_] := Sum[(k * Floor[n/k])^n, {k, 1, n}]; Array[a, 18] (* _Amiram Eldar_, Jul 30 2022 *)
%o A356238 (PARI) a(n) = sum(k=1, n, (k*(n\k))^n);
%o A356238 (PARI) a(n) = sum(k=1, n, k^n*sumdiv(k, d, 1-(1-1/d)^n));
%o A356238 (Python)
%o A356238 from sympy import bernoulli
%o A356238 def A356238(n):
%o A356238     c, j = 0, 1
%o A356238     while j <= n:
%o A356238         k = n//j
%o A356238         m = n//k
%o A356238         c += k**n*(bernoulli(n+1,m+1)-bernoulli(n+1,j))
%o A356238         j = m+1
%o A356238     return c//(n+1) # _Chai Wah Wu_, May 14 2026
