%I A356095 #17 May 24 2026 00:38:12
%S A356095 165,286,455,969,1771,4495,9139,12341,32509,176851,437989,657359,
%T A356095 939929,3737581,9290431,21084251,26536591,39338069,44101441,61690919,
%U A356095 92568571,112805879,289442201,381588019,439918931,495593039,711215371,815946449,1008077071,1103914379
%N A356095 Tetrahedral numbers which are products of three distinct primes.
%C A356095 A squarefree subsequence of tetrahedral numbers T(n) = C(n+2,3) = n*(n+1)*(n+2)/6.
%H A356095 Chai Wah Wu, <a href="/A356095/b356095.txt">Table of n, a(n) for n = 1..10000</a>
%e A356095 165 = 9*10*11/6 = 3*5*11
%e A356095 286 = 11*12*13/6 = 2*11*13
%e A356095 455 = 13*14*15/6 = 5*7*13
%e A356095 9139 = 37*38*39/6 = 13*19*37
%t A356095 Select[Table[n*(n + 1)*(n + 2)/6, {n, 1, 2000}], FactorInteger[#][[;; , 2]] == {1, 1, 1} &] (* _Amiram Eldar_, Jul 26 2022 *)
%o A356095 (Python)
%o A356095 from math import comb
%o A356095 from itertools import count, islice
%o A356095 from collections import deque, Counter
%o A356095 from sympy import factorint
%o A356095 def A356095_gen(): # generator of terms
%o A356095     c, d = deque([Counter(factorint(i)) for i in range(1,4)]), Counter(factorint(6))
%o A356095     for k in count(1):
%o A356095         a = sum(c,start=Counter())-d
%o A356095         if len(a) == 3 == sum(a.values()):
%o A356095             yield comb(k+2,3)
%o A356095         c.popleft()
%o A356095         c.append(Counter(factorint(k+3)))
%o A356095 A356095_list = list(islice(A356095_gen(),30)) # _Chai Wah Wu_, May 23 2026
%Y A356095 Intersection of A000292 and A007304.
%Y A356095 Subsequence of A070755.
%K A356095 nonn
%O A356095 1,1
%A A356095 _Massimo Kofler_, Jul 26 2022
