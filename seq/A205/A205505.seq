%F A205505 a(n) = [x^n] 1/(1 - Lucas(n)*x + (-1)^n*x^2), where Lucas(n) = A000204(n).
%F A205505 Forms a diagonal in table A028412.
%p A205505 a:= n-> (f->f(n*(n+1))/f(n))(k->(<<0|1>, <1|1>>^k)[1, 2]):
%p A205505 seq(a(n), n=1..14);  # _Alois P. Heinz_, May 17 2026
%t A205505 Table[Fibonacci[n(n+1)]/Fibonacci[n],{n,20}] (* _Harvey P. Dale_, Mar 30 2012 *)
%o A205505 (PARI) {a(n)=fibonacci(n*(n+1))/fibonacci(n)}
%o A205505 (PARI) {Lucas(n)=fibonacci(n-1)+fibonacci(n+1)}
%o A205505 {a(n)=polcoeff(1/(1-Lucas(n)*x+(-1)^n*x^2+x*O(x^n)), n)}
