%F A209042 Empirical: a(n) = 23*a(n-1) +491*a(n-2) +570*a(n-3) -2219*a(n-4) -7882*a(n-5) -12517*a(n-6) -6376*a(n-7) -1205*a(n-8) -6747*a(n-9) +4080*a(n-10) +7811*a(n-11) -4675*a(n-12) +1790*a(n-13) +2576*a(n-14) -2905*a(n-15) +513*a(n-16) +621*a(n-17) -27*a(n-18) -81*a(n-19).
