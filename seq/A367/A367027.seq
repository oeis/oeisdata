%F A367027 a(n) = (1/(2*n+1)) * Sum_{k=0..floor(n/2)} (-1)^k * binomial(3*n-k,k) * binomial(3*n-2*k,n-2*k).
%F A367027 G.f.: ( (1/x) * Series_Reversion( x * (1-x+x^2)^2 ) )^(1/2). - _Seiichi Manyama_, Mar 08 2025
%F A367027 D-finite with recurrence: -50*(5*n + 6)*(5*n + 2)*(5*n + 3)*(5*n + 4)*a(n) + 5*(3041*n^4 + 15872*n^3 + 32443*n^2 + 31300*n + 12096)*a(n + 1) - 4*(2*n + 5)*(n + 2)*(331*n^2 + 1025*n + 1044)*a(n + 2) + 36*(2*n + 5)*(n + 3)*(n + 2)*(2*n + 7)*a(n + 3) = 0. - _Robert Israel_, Mar 08 2026
%p A367027 f:= gfun:-rectoproc({-50*(5*n + 6)*(5*n + 2)*(5*n + 3)*(5*n + 4)*a(n) + 5*(3041*n^4 + 15872*n^3 + 32443*n^2 + 31300*n + 12096)*a(n + 1) - 4*(2*n + 5)*(n + 2)*(331*n^2 + 1025*n + 1044)*a(n + 2) + 36*(2*n + 5)*(n + 3)*(n + 2)*(2*n + 7)*a(n + 3), a(0) = 1, a(1) = 1, a(2) = 2},a(n),remember):
%p A367027 map(f, [$0..30]); # _Robert Israel_, Mar 08 2026
%o A367027 (PARI) a(n) = sum(k=0, n\2, (-1)^k*binomial(3*n-k, k)*binomial(3*n-2*k, n-2*k))/(2*n+1);
