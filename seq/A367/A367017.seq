%U A367017 883103159075400,9013769253136005,92419535419392485,951446700812718515,9831013564639954705
%N A367017 G.f. satisfies A(x) = 1 + x*A(x)^5*(1 - x).
%F A367017 a(n)  = Sum_{k=0..n} (-1)^(n-k) * binomial(k,n-k) * A002294(k).
%F A367017 D-finite with recurrence 8*n*(4*n+1)*(2*n-1)*(4*n-1)*a(n) +(-5429*n^4 +18282*n^3 -25831*n^2 +17298*n -4440)*a(n-1) +2*(19849*n^4 -141024*n^3 +381209*n^2 -464754*n +216120)*a(n-2) +2*(-73689*n^4 +806134*n^3 -3333345*n^2 +6161648*n -4286688)*a(n-3) +8*(39612*n^4 -581510*n^3 +3224355*n^2 -7996990*n +7478448)*a(n-4) +(-412341*n^4 +7529906*n^3 -51862191*n^2 +159663466*n -185354880)*a(n-5) +2*(160399*n^4 -3475600*n^3 +28343735*n^2 -103123250*n +141257856)*a(n-6) +20*(-6875*n^4 +171250*n^3 -1601500*n^2 +6665375*n -10418688)*a(n-7) +40*(5*n-38) *(5*n-32)*(5*n-36)*(5*n-34)*a(n-8)=0. - _R. J. Mathar_, Mar 02 2026
%o A367017 (PARI) a(n) = sum(k=0, n, (-1)^(n-k)*binomial(k, n-k)*binomial(5*k, k)/(4*k+1));
