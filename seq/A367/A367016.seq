%N A367016 G.f. satisfies A(x) = 1 + x*A(x)^4*(1 - x).
%F A367016 a(n) = Sum_{k=0..n} (-1)^(n-k) * binomial(k,n-k) * A002293(k).
%F A367016 D-finite with recurrence 3*n*(3*n-1)*(3*n+1)*a(n) +(-418*n^3 +951*n^2 -773*n+216)*a(n-1) +(2143*n^3 -10797*n^2 +18398*n-10512)*a(n-2) +2*(-2594*n^3 +20163*n^2 -52903*n +46800)*a(n-3) +4*(1627*n^3 -16836*n^2 +58532*n -68400)*a(n-4) -128*(2*n-9)*(16*n^2-132*n+275)*a(n-5) +256*(n-5)*(2*n-9)*(2*n-11)*a(n-6)=0. - _R. J. Mathar_, Mar 02 2026
%o A367016 (PARI) a(n) = sum(k=0, n, (-1)^(n-k)*binomial(k, n-k)*binomial(4*k, k)/(3*k+1));
