%N A367876 Expansion of e.g.f. exp(x * (2 - exp(x))).
%H A367876 Alois P. Heinz, <a href="/A367876/b367876.txt">Table of n, a(n) for n = 0..556</a>
%F A367876 G.f.: Sum_{k>=0} (-x)^k / (1 - (k+2)*x)^(k+1).
%F A367876 a(n) = Sum_{k=0..n} (-1)^k * (k+2)^(n-k) * binomial(n,k).
%F A367876 a(n) = Sum_{k=0..floor(n/2)} (-1)^k * A133399(n,k). - _Alois P. Heinz_, Mar 19 2026
%p A367876 a:= n-> add((-1)^k*binomial(n, k)*k!*Stirling2(n-k+1, k+1), k=0..n/2):
%p A367876 seq(a(n), n=0..24);  # _Alois P. Heinz_, Mar 19 2026
%o A367876 (PARI) a(n) = sum(k=0, n, (-1)^k*(k+2)^(n-k)*binomial(n, k));
%Y A367876 Cf. A133399, A367874, A367877.
