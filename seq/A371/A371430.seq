%F A371430 a(n) = (1/(n+1)) * Sum_{k=0..floor(n/2)} (-1)^k * binomial(n+1,k) * binomial(4*n-4*k+4,n-2*k).
%F A371430 D-finite with recurrence: (-24960*n^3 - 149760*n^2 - 274560*n - 149760)*a(n) + (105344*n^3 + 862080*n^2 + 2308864*n + 2012160)*a(n + 1) + (-188000*n^3 - 1984800*n^2 - 6981568*n - 8157504)*a(n + 2) + (176912*n^3 + 2326176*n^2 + 10216480*n + 14972256)*a(n + 3) + (-92104*n^3 - 1455168*n^2 - 7666256*n - 13465872)*a(n + 4) + (23740*n^3 + 433140*n^2 + 2630696*n + 5318472)*a(n + 5) + (-1948*n^3 - 39780*n^2 - 270056*n - 609360)*a(n + 6) + (27*n^3 + 648*n^2 + 5181*n + 13800)*a(n + 7) = 0. - _Robert Israel_, Mar 11 2026
%p A371430 f:= gfun:-rectoproc({(-24960*n^3 - 149760*n^2 - 274560*n - 149760)*a(n) + (105344*n^3 + 862080*n^2 + 2308864*n + 2012160)*a(n + 1) + (-188000*n^3 - 1984800*n^2 - 6981568*n - 8157504)*a(n + 2) + (176912*n^3 + 2326176*n^2 + 10216480*n + 14972256)*a(n + 3) + (-92104*n^3 - 1455168*n^2 - 7666256*n - 13465872)*a(n + 4) + (23740*n^3 + 433140*n^2 + 2630696*n + 5318472)*a(n + 5) + (-1948*n^3 - 39780*n^2 - 270056*n - 609360)*a(n + 6) + (27*n^3 + 648*n^2 + 5181*n + 13800)*a(n + 7), a(0) = 1, a(1) = 4, a(2) = 21, a(3) = 128, a(4) = 851, a(5) = 5984, a(6) = 43759},a(n),remember):
%p A371430 map(f, [$0..30]); # _Robert Israel_, Mar 11 2026
%o A371430 (PARI) my(N=30, x='x+O('x^N)); Vec(serreverse(x/((1+x)^4-x^2))/x)
