%N A371120 E.g.f. satisfies A(x) = 1 + x*A(x)^3*(exp(x*A(x)) - 1).
%H A371120 Vincenzo Librandi, <a href="/A371120/b371120.txt">Table of n, a(n) for n = 0..300</a>
%F A371120 a(n) = n! * Sum_{k=0..floor(n/2)} (n+2*k)! * Stirling2(n-k,k)/( (n-k)! * (n+k+1)! ).
%t A371120 Table[ n! * Sum[(n + 2 k)!*StirlingS2[n - k, k]/((n - k)!*(n + k + 1)!), {k, 0, Floor[n/2]}], {n, 0, 21}] (* _Vincenzo Librandi_, Mar 02 2026 *)
%o A371120 (PARI) a(n) = n!*sum(k=0, n\2, (n+2*k)!*stirling(n-k, k, 2)/((n-k)!*(n+k+1)!));
%o A371120 (Magma) [Factorial(n)* &+[Factorial(n+2*k)*StirlingSecond(n-k, k) / (Factorial(n-k)* Factorial(n+k+1)): k in [0..Floor(n/2)] ] : n in [0..23] ]; // _Vincenzo Librandi_, Mar 02 2026
