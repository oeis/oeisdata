%N A371426 Expansion of (1/x) * Series_Reversion( x / ((1+x)^2 - x^3) ).
%H A371426 Robert Israel, <a href="/A371426/b371426.txt">Table of n, a(n) for n = 0..1811</a>
%H A371426 <a href="/index/Res#revert">Index entries for reversions of series</a>
%F A371426 a(n) = (1/(n+1)) * Sum_{k=0..floor(n/3)} (-1)^k * binomial(n+1,k) * binomial(2*n-2*k+2,n-3*k).
%F A371426 D-finite with recurrence: (341*n^2 + 1023*n + 682)*a(n) + (343*n^2 + 1497*n + 1622)*a(n + 1) + (-309*n^2 - 1905*n - 2892)*a(n + 2) + (69*n^2 + 555*n + 1098)*a(n + 3) + (-4*n^2 - 42*n - 110)*a(n + 4) = 0. - _Robert Israel_, Mar 11 2026
%p A371426 f:= gfun:-rectoproc({(341*n^2 + 1023*n + 682)*a(n) + (343*n^2 + 1497*n + 1622)*a(n + 1) + (-309*n^2 - 1905*n - 2892)*a(n + 2) + (69*n^2 + 555*n + 1098)*a(n + 3) + (-4*n^2 - 42*n - 110)*a(n + 4), a(0) = 1, a(1) = 2, a(2) = 5, a(3) = 13},a(n),remember):
%p A371426 map(f, [$0..30]); # _Robert Israel_, Mar 11 2026
%o A371426 (PARI) my(N=30, x='x+O('x^N)); Vec(serreverse(x/((1+x)^2-x^3))/x)
%o A371426 (PARI) a(n) = sum(k=0, n\3, (-1)^k*binomial(n+1, k)*binomial(2*n-2*k+2, n-3*k))/(n+1);
