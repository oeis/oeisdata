%N A371431 Expansion of (1/x) * Series_Reversion( x * ((1-x)^2 + x^3) ).
%H A371431 Robert Israel, <a href="/A371431/b371431.txt">Table of n, a(n) for n = 0..1289</a>
%H A371431 <a href="/index/Res#revert">Index entries for reversions of series</a>
%F A371431 a(n) = (1/(n+1)) * Sum_{k=0..floor(n/3)} (-1)^k * binomial(n+k,k) * binomial(3*n-k+1,n-3*k).
%F A371431 D-finite with recurrence: (-14592*n^3 - 51072*n^2 - 57456*n - 20520)*a(n) + (-60643*n^3 - 309615*n^2 - 524714*n - 295560)*a(n + 1) + (10444*n^3 + 42411*n^2 - 2287*n - 106572)*a(n + 2) + (1853*n^3 + 23874*n^2 + 98557*n + 130836)*a(n + 3) + (-310*n^3 - 3720*n^2 - 14570*n - 18600)*a(n + 4) = 0. - _Robert Israel_, Mar 11 2026
%p A371431 f:= gfun:-rectoproc({(-14592*n^3 - 51072*n^2 - 57456*n - 20520)*a(n) + (-60643*n^3 - 309615*n^2 - 524714*n - 295560)*a(n + 1) + (10444*n^3 + 42411*n^2 - 2287*n - 106572)*a(n + 2) + (1853*n^3 + 23874*n^2 + 98557*n + 130836)*a(n + 3) + (-310*n^3 - 3720*n^2 - 14570*n - 18600)*a(n + 4), a(0) = 1, a(1) = 2, a(2) = 7, a(3) = 29},a(n),remember):
%p A371431 map(f, [$0..30]); # _Robert Israel_, Mar 11 2026
%o A371431 (PARI) my(N=30, x='x+O('x^N)); Vec(serreverse(x*((1-x)^2+x^3))/x)
%o A371431 (PARI) a(n) = sum(k=0, n\3, (-1)^k*binomial(n+k, k)*binomial(3*n-k+1, n-3*k))/(n+1);
