%N A371433 Expansion of (1/x) * Series_Reversion( x * ((1-x)^3 + x) ).
%H A371433 Robert Israel, <a href="/A371433/b371433.txt">Table of n, a(n) for n = 0..1415</a>
%H A371433 <a href="/index/Res#revert">Index entries for reversions of series</a>
%F A371433 a(n) = (1/(n+1)) * Sum_{k=0..n} (-1)^k * binomial(n+k,k) * binomial(4*n+2*k+2,n-k).
%F A371433 D-finite with recurrence: (-768*n^3 - 2688*n^2 - 3024*n - 1080)*a(n) + (3073*n^3 + 17925*n^2 + 35318*n + 23400)*a(n + 1) + (-3374*n^3 - 28761*n^2 - 81889*n - 77916)*a(n + 2) + (925*n^3 + 9540*n^2 + 32555*n + 36780)*a(n + 3) + (-92*n^3 - 1104*n^2 - 4324*n - 5520)*a(n + 4) = 0. - _Robert Israel_, Mar 11 2026
%p A371433 f:= gfun:-rectoproc({(-768*n^3 - 2688*n^2 - 3024*n - 1080)*a(n) + (3073*n^3 + 17925*n^2 + 35318*n + 23400)*a(n + 1) + (-3374*n^3 - 28761*n^2 - 81889*n - 77916)*a(n + 2) + (925*n^3 + 9540*n^2 + 32555*n + 36780)*a(n + 3) + (-92*n^3 - 1104*n^2 - 4324*n - 5520)*a(n + 4), a(0) = 1, a(1) = 2, a(2) = 5, a(3) = 11},a(n),remember):
%p A371433 map(f, [$0..30]); # _Robert Israel_, Mar 11 2026
%o A371433 (PARI) my(N=30, x='x+O('x^N)); Vec(serreverse(x*((1-x)^3+x))/x)
%o A371433 (PARI) a(n) = sum(k=0, n, (-1)^k*binomial(n+k, k)*binomial(4*n+2*k+2, n-k))/(n+1);
