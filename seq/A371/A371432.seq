%p A371432 f:= gfun:-rectoproc({(3125000*n^4 + 15625000*n^3 + 28750000*n^2 + 23000000*n + 6720000)*a(n) + (46646875*n^4 + 492718750*n^3 + 1861345625*n^2 + 3019445750*n + 1788110040)*a(n + 1) + (-57950750*n^4 - 508983500*n^3 - 1161428650*n^2 + 500393300*n + 2893080720)*a(n + 2) + (81538116*n^4 + 522378008*n^3 - 1140689184*n^2 - 13390309148*n - 22750395312)*a(n + 3) + (209631384*n^4 + 4065612672*n^3 + 29350434864*n^2 + 93538775112*n + 111114972960)*a(n + 4) + (-100694928*n^4 - 2107886112*n^3 - 16497030912*n^2 - 57216000528*n - 74205663840)*a(n + 5) + (15042016*n^4 + 350709856*n^3 + 3048659936*n^2 + 11713855136*n + 16790249280)*a(n + 6) + (-735488*n^4 - 19122688*n^3 - 184607488*n^2 - 784030208*n - 1235619840)*a(n + 7), a(0) = 1, a(1) = 2, a(2) = 7, a(3) = 30, a(4) = 142, a(5) = 714, a(6) = 3740},a(n),remember):
