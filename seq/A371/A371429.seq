%p A371429 f:= gfun:-rectoproc({(-1150961*n^3 - 6905766*n^2 - 12660571*n - 6905766)*a(n) + (3196056*n^3 + 26165085*n^2 + 70100361*n + 61108830)*a(n + 1) + (-7631535*n^3 - 73443765*n^2 - 235949718*n - 252906714)*a(n + 2) + (6107914*n^3 + 75846747*n^2 + 313993307*n + 433465164)*a(n + 3) + (-1631073*n^3 - 24202536*n^2 - 119534547*n - 196560324)*a(n + 4) + (161184*n^3 + 2736894*n^2 + 15401514*n + 28712724)*a(n + 5) + (-2660*n^3 - 43650*n^2 - 218350*n - 302940)*a(n + 6) + (-270*n^3 - 6480*n^2 - 51810*n - 138000)*a(n + 7), a(0) = 1, a(1) = 3, a(2) = 12, a(3) = 55, a(4) = 272, a(5) = 1413, a(6) = 7599},a(n),remember):
