%S A371785 1,3,14,76,441,2652,16303,101727,641630,4080154,26112384,167978615,
%T A371785 1085182436,7035477777,45750406205,298279844724,1949096816505,
%U A371785 12761551428024,83701819019155,549850618355886,3617119500327536,23824816811652905,157106267803712709
%N A371785 a(n) = Sum_{k=0..floor(n/2)} (-1)^k * binomial(3*n-k,n-2*k).
%F A371785 a(n) = [x^n] 1/((1-x+x^2) * (1-x)^(2*n)).
%F A371785 From _Seiichi Manyama_, Nov 10 2025: (Start)
%F A371785 G.f.: g/((1-3*x*g^2) * (1+x*g^4)) where g = 1+x*g^3 is the g.f. of A001764.
%F A371785 a(n) = Sum_{k=0..n} binomial(n+2*k-1,k).
%F A371785 a(n) = Sum_{k=0..n} (-1)^k * binomial(3*n+k+1,n-k). (End)
%F A371785 From _Seiichi Manyama_, Jun 30 2026: (Start)
%F A371785 G.f.: g^2/((3-2*g) * (1-g+g^2)) where g = 1+x*g^3 is the g.f. of A001764.
%F A371785 Here and below, binomial(N,k) = 0 for k<0.
%F A371785 This is the special case l=1, m=2, c=2, r=1, s=0 of the following family. For integers l, m, c in Z, and for any constants r and s, define a_{l,m,c,r,s}(n) = Sum_{k=0..n} (r*binomial(l*n+m*k-m-1+c,k) - s*binomial(l*n+m*k-m-1+c,k-1)). A_{l,m,c,r,s}(x) = Sum_{n>=0} a_{l,m,c,r,s}(n)*x^n = t^c*(r+s-s*t)/((l+m-(l+m-1)*t)*(1-t+t^m)), where t = t(x) satisfies t = 1 + x*t^(l+m), equivalently y = x*(1+y)^(l+m) with y=t-1. (End)
%o A371785 (PARI) a(n) = sum(k=0, n\2, (-1)^k*binomial(3*n-k, n-2*k));
%Y A371785 Cf. A024718, A371786, A371787.
