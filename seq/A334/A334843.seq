%N A334843 Decimal expansion of arclength between (0,0) and (Pi/6,1/2) on y = sin x.
%F A334843 Equals sqrt(2) * E(Pi/6, 1/sqrt(2)), where E(phi, k) is the incomplete elliptic integral of the second kind. - _Amiram Eldar_, May 16 2026
%e A334843 0.72414709627192652466264478122042741544575468653096...
%t A334843 s = Integrate[Sqrt[1 + D[Sin[x], x]^2], {x, 0, Pi/6}] (* corrected by _Amiram Eldar_, May 16 2026 *)
%t A334843 r = N[s, 200]
%t A334843 RealDigits[r][[1]]
%t A334843 (* Alternative: *)
%t A334843 RealDigits[Sqrt[2] * EllipticE[Pi/6, 1/2], 10, 120][[1]] (* _Amiram Eldar_, May 16 2026 *)
%o A334843 (PARI) intnum(x = 0, Pi/6, sqrt(1 + cos(x)^2)) \\ _Amiram Eldar_, May 16 2026
