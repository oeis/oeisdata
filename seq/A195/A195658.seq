%F A195658 Recurrence: a(n) = -4*a(n-10) + 36*a(n-9) - 145*a(n-8) + 344*a(n-7) - 532*a(n-6) + 560*a(n-5) - 406*a(n-4) + 200*a(n-3) - 64*a(n-2) + 12*a(n-1).
%F A195658 G.f.: (1 + 1012*x + 38698*x^2 + 270088*x^3 + 503686*x^4 + 270112*x^5 + 37900*x^6 + 1516*x^7 + 25*x^8)/((x-1)^8*(2*x-1)^2).
%F A195658 a(n) = (21623809*n - 226349399)*2^n + 8913/40*n^7 + 124781/20*n^6 + 376359/4*n^5 + 977074*n^4 + 294753537/40*n^3 + 787733819/20*n^2 + 135269649*n + 226349400.
