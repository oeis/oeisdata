%I A269569 #11 May 02 2026 20:53:19
%S A269569 0,2,4,8,29,37,45,56,68,80,92,99,115,235,257,279,413,593,751,791,831,
%T A269569 909,955,1001,1396,1450,1504,1572,1961,2019,2087,2500,2576,3093,3634,
%U A269569 3720,4129,4223,4317,4522,4624,4726,5816,5928,6040,7110,7232,7354,7535,7665,8368,8500
%N A269569 Numbers k such that k+s+c is a square, where s is the nearest square to k and c is the nearest cube to k.
%H A269569 Robert Israel, <a href="/A269569/b269569.txt">Table of n, a(n) for n = 1..10000</a>
%e A269569 The square nearest to 8 is 9, the cube nearest to 8 is 8. Because 8+8+9 is a square, 8 is in the sequence.
%e A269569 The square nearest to 29 is 25, the cube nearest to 29 is 27. Because 29+25+27 is a square, 29 is in the sequence.
%p A269569 filter:= proc(k) local s,ss,sp,c,cc,cp;
%p A269569   s:= isqrt(k); ss:= s^2;
%p A269569   if ss < k then sp:= (s+1)^2; if k - ss > sp - k then ss:= sp fi
%p A269569   elif ss > k then sp:= (s-1)^2; if ss - k > k - sp then ss:= sp fi
%p A269569   fi;
%p A269569   c:= iroot(k,3); cc:= c^3;
%p A269569   if cc < k then cp:= (c+1)^3; if k - cc > cp - k then cc:= cp fi
%p A269569   elif cc > k then cp:= (c-1)^3; if cc - k > k - cp then cc:= cp fi
%p A269569   fi;
%p A269569   issqr(k+ss+cc)
%p A269569 end proc:
%p A269569 select(filter, [$0..10000]); # _Robert Israel_, Apr 29 2026
%o A269569 (Python)
%o A269569 from itertools import count, islice
%o A269569 from math import isqrt
%o A269569 from sympy import integer_nthroot
%o A269569 from sympy.ntheory.primetest import is_square
%o A269569 def A269569_gen(startvalue=0): # generator of terms >= startvalue
%o A269569     return filter(lambda n:is_square(n+(c if (2*n<(c:=(a:=integer_nthroot(n,3)[0])**3)+(d:=(a+1)**3)) else d)+((m:=isqrt(n))+int(n>m*(m+1)))**2), count(max(startvalue,0)))
%o A269569 A269569_list = list(islice(A269569_gen(),50)) # _Chai Wah Wu_, Apr 30 2026
%Y A269569 Cf. A000290, A000578, A053187, A201053, A238456, A238489.
%K A269569 nonn,changed
