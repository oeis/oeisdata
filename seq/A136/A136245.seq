%N A136245 a(n) = (1/n!)*Sum_{k=0..n} Stirling1(n,k)*A062208(k).
%H A136245 Vaclav Kotesovec, <a href="/A136245/b136245.txt">Table of n, a(n) for n = 0..100</a> (terms 0..30 from Alois P. Heinz)
%F A136245 a(n) = Sum_{m>=0} binomial(binomial(m,3),n)/2^(m+1).
%F A136245 a(n) ~ 3^(2*n + 1/2) * n^(2*n) / (2^(n+2) * exp(2*n) * log(2)^(3*n+1)). - _Vaclav Kotesovec_, Jul 23 2026
%t A136245 Join[{1}, Table[1/n!*Sum[StirlingS1[n, k]*Sum[Sum[(-1)^i*Binomial[j, i]*Binomial[j - i, 3]^k, {i, 0, j}], {j, 0, 3*k}], {k, 1, n}], {n, 1, 20}]] (* _Vaclav Kotesovec_, Jul 23 2026 *)
