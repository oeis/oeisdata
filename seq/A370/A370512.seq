%U A370512 12122232623222121,5221225,0,0,0,0,0,1212225222121,0,12122232623222121,6948496,0,0,123212222474222212321,0,0,1212225222121,0,12122232623222121,165551171155561,0,0,123212222474222212321,0,0,1230127210321,0,121220122262221022121,123212222232484232222212321,0,0,123212222474222212321,0,0
%N A370512 Largest palindromic square which is a concatenation of a composition of n; or 0 if no such square exists.
%F A370512 a(n) <= A079842(n).
%F A370512 If n is a palindromic square, then a(n) >= n.
%F A370512 a(n) = 0 wheneven n == 2, 3, 5, 6, or 8 (mod 9). - _Max Alekseyev_, Jul 08 2026
%e A370512 Note that a(4) = a(13) = a(22) = 121 as the digits of 121 can be partitioned into compositions 1+2+1 = 4 or 12+1 = 13 or 1+21 = 22.
%o A370512 (Python)
%o A370512 from collections import Counter
%o A370512 from operator import itemgetter
%o A370512 from sympy.ntheory.primetest import is_square
%o A370512 from sympy.utilities.iterables import partitions, multiset_permutations
%o A370512 def A370512(n):
%o A370512     smax, m = 0, 0
%o A370512     for s, p in sorted(partitions(n,size=True),key=itemgetter(0),reverse=True):
%o A370512         if s<smax:
%o A370512             break
%o A370512         q = tuple(Counter(p).elements())
%o A370512         c = sum((Counter(str(d)) for d in q), start=Counter())
%o A370512         if len(tuple(filter(lambda x:x&1,c.values()))) <= 1:
%o A370512             for a in multiset_permutations(q):
%o A370512                 if (b:=''.join(str(d) for d in a))==b[::-1] and is_square(k:=int(b)):
%o A370512                     m = max(k,m)
%o A370512             if m>0:
%o A370512                 smax=s
%o A370512     return m
%Y A370512 Subset of A002779.
%Y A370512 Cf. A002778, A079842.
%K A370512 nonn,base,changed
%O A370512 1,4
