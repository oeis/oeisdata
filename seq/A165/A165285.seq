%I A165285 #12 Apr 18 2026 09:45:12
%S A165285 17,43,59,73,79,101,109,139,163,191,197,233,239,283,317,331,379,419,
%T A165285 433,439,443,463,467,499,521,569,571,599,617,619,641,739,743,787,811,
%U A165285 863,911,919,941,967,971,1021,1039,1061,1063,1087,1097,1109,1117,1229,1289
%N A165285 Primes which can be expressed as the sum of 2*p-1 for two or more consecutive primes p.
%C A165285 The original description of this sequence expressed this in terms of pairs (p-1, p).
%C A165285 The pair (p-1,p) has sum 2*p-1 as given by A076274.
%C A165285 Thus, a prime is in this sequence if it can be represented as a sum of consecutive terms from A076274.
%H A165285 Robert Israel, <a href="/A165285/b165285.txt">Table of n, a(n) for n = 1..10000</a>
%e A165285 (1+2)+(2+3)+(4+5)=17, (4+5)+(6+7)+(10+11)=43, (6+7)+(10+11)+(12+13)=59, ...
%p A165285 N:= 10^4: # for terms <= N
%p A165285 pmax:= nextprime(nextprime(ceil((N+3)/6))):
%p A165285 T:= map(p -> 2*p-1, select(isprime,[2,seq(i,i=3..pmax,2)])):
%p A165285 S:= ListTools:-PartialSums([0,op(T)]):
%p A165285 R:= {}:
%p A165285 for m from 3 by 2 while S[m] <= N do
%p A165285   for j from 1 do
%p A165285     v:= S[m+j]-S[j];
%p A165285     if v > N then break fi;
%p A165285     if isprime(v) then R:= R union {v} fi
%p A165285 od od:
%p A165285 sort(convert(R,list)); # _Robert Israel_, Apr 17 2026
%t A165285 lst={};Do[s=2*Prime[m]-1;Do[p=Prime[n];s+=(2*p-1);If[PrimeQ[s],If[s<=6793,AppendTo[lst,s]]],{n,m+1,3*5!}],{m,1,3*5!}];lst=Take[Union@lst,200]
%Y A165285 Cf. A076274, A130097, A062090, A050150, A015919.
%K A165285 nonn
%O A165285 1,1
%A A165285 _Vladimir Joseph Stephan Orlovsky_, Sep 13 2009
%E A165285 Revised by _Sean A. Irvine_, Feb 02 2026
