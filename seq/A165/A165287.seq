%I A165287 #14 Apr 18 2026 09:45:08
%S A165287 61,73,97,107,163,179,197,233,239,257,263,271,307,331,349,359,367,397,
%T A165287 409,419,421,461,467,479,487,503,523,547,571,593,599,613,617,631,659,
%U A165287 677,691,709,727,733,743,757,761,787,809,811,821,827,839,857,859,881,883,907,929,967,997,1019,1039
%N A165287 Primes which are the sum of at least 3 consecutive odd nonprimes (A014076) >1.
%H A165287 Robert Israel, <a href="/A165287/b165287.txt">Table of n, a(n) for n = 1..10000</a>
%e A165287 15+21+25 = 61, 9+15+21+25+27 = 97.
%p A165287 N:= 1000: # for terms <= N
%p A165287 tmax:= 2*ceil(N/6)+7:
%p A165287 T:= remove(isprime,[seq(i,i=3..tmax,2)]):
%p A165287 S:= ListTools:-PartialSums([0,op(T)]):
%p A165287 R:= {}:
%p A165287 for m from 3 by 2 while S[m] <= N do
%p A165287   for j from 1 do
%p A165287     v:= S[m+j]-S[j];
%p A165287     if v > N then break fi;
%p A165287     if isprime(v) then R:= R union {v} fi
%p A165287 od od:
%p A165287 sort(convert(R,list)); # _Robert Israel_, Apr 17 2026
%t A165287 lst={};Do[If[PrimeQ[m],Continue[]];s=m;Do[If[PrimeQ[n],Continue[]];s+=n;If[PrimeQ[s],If[s<=2917,AppendTo[lst,s]]],{n,m+2,2*6!,2}],{m,1,2*6!,2}];lst=Take[Union@lst,200]
%o A165287 (PARI) N=1000;v=vector(N);L=listcreate();n=9;while(n<N,if(!isprime(n),listput(L,n));n=n+2);vv=Vec(L);forstep(k=3,#vv,2,for(offs=1,#vv-k+1,s=sum(i=offs,offs+k-1,vv[i]);if(isprime(s)&&s<=N,v[s]=1)));for(n=60,#v,if(v[n],print1(n,","))) \\ _Ralf Stephan_, Nov 26 2013
%Y A165287 Cf. A014076, A106091.
%K A165287 nonn
%O A165287 1,1
%A A165287 _Vladimir Joseph Stephan Orlovsky_, Sep 13 2009
%E A165287 Edited by _Ralf Stephan_, Nov 26 2013
%E A165287 Corrected by _Robert Israel_, Apr 17 2026
