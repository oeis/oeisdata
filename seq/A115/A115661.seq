%N A115661 Numbers k which have the same number of distinct prime divisors as the reverse of k.
%H A115661 G. C. Greubel, <a href="/A115661/b115661.txt">Table of n, a(n) for n = 1..1000</a>
%e A115661 omega(16) = omega(61) = 1.
%t A115661 Select[Range[130],PrimeNu[#]==PrimeNu[FromDigits[Reverse[ IntegerDigits[ #]]]]&] (* _Harvey P. Dale_, Jan 14 2012 *)
%o A115661 (Python)
%o A115661 from sympy import factorint
%o A115661 def ok(n): return len(factorint(n)) == len(factorint(int(str(n)[::-1])))
%o A115661 print([k for k in range(1, 129) if ok(k)]) # _Michael S. Branicky_, Mar 05 2026
