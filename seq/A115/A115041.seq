%I A115041 #18 Mar 10 2026 23:50:50
%S A115041 3,2,3,2,3,7,3,10,3,15,2,19,21,22,2,3,30,5,34,2,37,2,42,5,7,51,2,54,5,
%T A115041 57,2,66,69,70,75,2,79,82,6,87,3,91,6,97,99,7,106,2,3,115,117,3,11,3,
%U A115041 129,132,135,10,139,141,142,147,7,156,157,159,166,13,174,175,177,12,2
%N A115041 a(n) = y where A115038(x)^2 + prime(n) = y^A115039(n).
%C A115041 Conjecture: There will always be an x,y,n such that x^2 + p = y^n for all primes p.
%H A115041 Robert Israel, <a href="/A115041/b115041.txt">Table of n, a(n) for n = 1..10000</a>
%F A115041 A115038(x)^2 + prime(n) = a(n)^A115039(n). - _Robert Israel_, Mar 09 2026
%e A115041 5 is the smallest number that when we add its square to prime 2, we get a perfect power, 3^3. So 3 is the first entry. 498^2 + 997 = 499^2. So 499 is the last entry in the table.
%p A115041 h:= proc(n) local p,F,x,d;
%p A115041   p:= ithprime(n);
%p A115041   for x from 1 do
%p A115041     F:= ifactors(x^2+p)[2];
%p A115041     d:= igcd(F[..,2]);
%p A115041     if d > 1 then return surd(x^2+p,d) fi
%p A115041   od
%p A115041 end proc:
%p A115041 map(h, [$1..100]); # _Robert Israel_, Mar 09 2026
%o A115041 (PARI) sqplusp(n) = { local(p,x,y,c=0); forprime(p=2,n, for(x=1,n, y=x^2+p; if(ispower(y), print1(power(y)",");c++;break ) ) ); print(); print(c) }
%o A115041 exponent(n) = { local(x,ln,j,e=0); ln=omega(n); x=factor(n); e=x[1,2]; for(j=2,ln, if(x[j,2] < e,e=x[j,2]) ); return(e) } \\ Return the exponent if n is a perfect power
%o A115041 power(n) =  { if(ispower(n), return(round(n^(1/exponent(n)))) ) } \\ Return the largest factor for which n is a perfect power
%Y A115041 Cf. A115038, A115039.
%K A115041 easy,nonn
%O A115041 1,1
