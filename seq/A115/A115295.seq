%I A115295 #14 Jul 22 2026 01:24:47
%S A115295 1,17,66,130,194,258,322,386,450,514,578,642,706,770,834,898,962,1026,
%T A115295 1090,1154,1218,1282,1346,1410,1474,1538,1602,1666,1730,1794,1858,
%U A115295 1922,1986,2050,2114,2178,2242,2306,2370,2434,2498,2562,2626,2690,2754,2818
%N A115295 Partial sums of squares of A115291(n).
%C A115295 Central coefficients of number triangle A115292.
%H A115295 <a href="/index/Rec#order_02">Index entries for linear recurrences with constant coefficients</a>, signature (2,-1).
%F A115295 a(n) = Sum_{k=0..n, (Sum_{j=0..k, C(3,j)})^2}; a(n) = A115292(2*n,n).
%F A115295 From _Elmo R. Oliveira_, Jul 21 2026: (Start)
%F A115295 G.f.: (1 + 15*x + 33*x^2 + 15*x^3)/(1 - x)^2.
%F A115295 E.g.f.: 2*exp(x)*(32*x - 31) + 15*x + 63.
%F A115295 a(n) = 2*a(n-1) - a(n-2) for n > 3.
%F A115295 a(n) = 2*(32*n - 31) for n >= 2; a(0)=1, a(1)=17. (End)
%t A115295 Join[{1, 17}, Range[66, 7000, 64]] (* _Vladimir Joseph Stephan Orlovsky_, Jul 12 2011 *)
%t A115295 (* Alternative: *)
%t A115295 LinearRecurrence[{2,-1},{1,17,66,130},50] (* _Harvey P. Dale_, May 27 2026 *)
