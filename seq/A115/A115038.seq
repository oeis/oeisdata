%S A115038 5,1,2,1,4,6,8,9,2,14,1,18,20,21,9,26,29,8,33,21,36,7,41,6,48,50,5,53,
%T A115038 4,56,1,65,68,69,74,19,78,81,7,86,8,90,5,96,98,12,105,17,4,114,116,2,
%U A115038 120,44,128,131,134,27,138,140,141,146,6,155,156,158,165,168,173,174,176,37
%N A115038 a(n) is the smallest x such that x^2 + prime(n) is a perfect power.
%C A115038 Conjecture: There will always be an x,y,n such that x^2 + p = y^n for all primes p. In otherwords, there is a one-one mapping of the prime numbers to y^n - x^2 for some x,y,n. Therefore primes of the form y^n - x^2 are infinite in number.
%H A115038 Robert Israel, <a href="/A115038/b115038.txt">Table of n, a(n) for n = 1..10000</a>
%F A115038 a(n)^2 + prime(n) = A115041(n)^A115039(n). - _Robert Israel_, Mar 09 2026
%e A115038 5 is the smallest number that when we add its square to prime 2, we get a perfect power, 3^3. 1 is the smallest number that when we add its square to prime 3, we get a perfect power, 2^2. So 5 and 1 are the first two entries in the table.
%p A115038 ispow:= proc(n) local F;
%p A115038   F:= ifactors(n)[2];
%p A115038   igcd(F[..,2])>1
%p A115038 end proc:
%p A115038 f:= proc(n) local p,x;
%p A115038   p:= ithprime(n);
%p A115038   for x from 1 do if ispow(x^2+p) then return x fi od
%p A115038 end proc:
%p A115038 map(f, [$1..100]); # _Robert Israel_, Mar 09 2026
%o A115038 (PARI) sqplusp(n) = { local(p,x,y,c=0); forprime(p=2,n, for(x=1,n, y=x^2+p; if(ispower(y), print1(x",");c++;break ) ) ); print(); print(c) }
%Y A115038 Cf. A115039, A115041.
%K A115038 easy,nonn
%O A115038 1,1
