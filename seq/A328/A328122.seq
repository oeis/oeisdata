%p A328122       +8*(2*n-7)*(289*n^3-2805*n^2+8948*n-9378)*a(n-3)-16*(n-4)*(17*n-47)
%p A328122        *(2*n-7)*(2*n-9)*(n-3)*a(n-4))/(85*n-320))
%p A328122     end:
%p A328122 seq(a(n), n=1..19);  # _Alois P. Heinz_, Jul 22 2026
