%I A328784 #38 Jul 15 2026 01:05:09
%S A328784 2,4,5,608,1221,60264,205965,994856,69709961,3140421767
%N A328784 Integers k such that the k-th prime divides the k-th Lucas number.
%p A328784 a:= 1:
%p A328784 b:= 2:
%p A328784 p:= 2:
%p A328784 Res:= NULL:
%p A328784 for n from 2 to 10^6 do
%p A328784   c:= a+b;
%p A328784   b:= a;
%p A328784   a:= c;
%p A328784   p:= nextprime(p);
%p A328784   if a mod p = 0 then
%p A328784     Res:= Res,n;
%p A328784   fi
%p A328784 od:
%p A328784 Res; # _Robert Israel_, Oct 30 2019
%o A328784 (Magma) [n: n in [1..100000] | IsZero(Lucas(n) mod NthPrime(n))];
%o A328784 (Python)
%o A328784 from itertools import count, islice
%o A328784 from sympy import nextprime
%o A328784 from oeis_sequences.OEISsequences import lucas_mod
%o A328784 def A328784_gen(): # generator of terms
%o A328784     p = 1
%o A328784     for k in count(1):
%o A328784         if not lucas_mod(k,p:=nextprime(p)): yield k
%o A328784 A328784_list= list(islice(A328784_gen(),7)) # _Chai Wah Wu_, Jul 14 2026
%Y A328784 Cf. A000032, A000040.
%Y A328784 Cf. A075702 (analog with Fibonacci).
%K A328784 nonn,more,changed
%O A328784 1,1
%A A328784 _Juri-Stepan Gerasimov_, Oct 30 2019
%E A328784 a(8) from _Robert Israel_, Oct 30 2019
%E A328784 a(9)-a(10) from _Daniel Suteu_, Nov 07 2019
