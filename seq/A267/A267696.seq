%S A267696 81,162,324,625,648,1250,1296,2401,2500,2592,4802,5000,5184,9604,
%T A267696 10000,10368,14641,19208,20000,20736,28561,29282,38416,40000,41472,
%U A267696 57122,58564,76832,80000,82944,83521,114244,117128,130321,153664,160000,165888,167042,228488,234256,260642,279841
%N A267696 Numbers with 5 odd divisors.
%C A267696 Positive integers that have exactly five odd divisors.
%C A267696 Numbers k such that the symmetric representation of sigma(k) has 5 subparts. - _Omar E. Pol_, Dec 28 2016
%C A267696 Also numbers that can be expressed as the sum of k > 1 consecutive positive integers in exactly 4 ways; e.g., 81 = 40+41 = 26+27+28 = 11+12+13+14+15+16 = 5+6+7+8+9+10+11+12+13. - _Julie Jones_, Aug 13 2018
%C A267696 Every term a(n) in the sequence has the form 2^m * p^4, m >= 0 and p an odd prime. If p < 2^(m+1) then all divisors of a(n) belong to the single 2-dense sublist (see A237270) of all divisors of a(n) so that the symmetric representation of sigma for a(n), SRS(a(n)), consists of a single part of maximum width between 2 and 5; the latter occurs when p^4 < 2^(m+1) and makes SRS(a(n)) unimodal. If 2^(m+1) < p then 1 < 2^(m+1) < p < 2^(m+1) * p < p^2 <= A003056(a(n)) < 2^(m+1) * p^2 so that SRS(a(n)) consists of 5 parts of width 1 - these are also terms in A320066 and in A357581 (column 5). The width pattern (see A376829) of any term in this sequence has length 9. - _Hartmut F. W. Hoft_, May 25 2026
%H A267696 Amiram Eldar, <a href="/A267696/b267696.txt">Table of n, a(n) for n = 1..10000</a>
%F A267696 A001227(a(n)) = 5.
%F A267696 Sum_{n>=1} 1/a(n) = 2 * P(4) - 1/8 = 0.00289017370127..., where P(4) is the value of the prime zeta function at 4 (A085964). - _Amiram Eldar_, Sep 16 2024
%e A267696 From _Hartmut F. W. Hoft_, May 25 2026: (Start)
%e A267696 a(1) = 81 = 3^4 with parts {41, 15, 9, 15, 41} where odd divisor 9 starts the center part of SRS(a(1)), while a(2) = 162 = 2*3^4 satisfies 3 < 2^2 so that SRS(a(2)) consists of the single part {363} with width pattern 1 2 1 2 1 2 1 2 1.
%e A267696 a(17) = 11^4 = 14641 has 5 parts where odd divisor 121 starts the center part of SRS(a(17)), while a(33) = 8 * 11^4 = 117128  satisfies 11 < 2^4 so that SRS(a(33)) consists of the single part {241575}, again with width pattern 1 2 1 2 1 2 1 2 1. (End)
%p A267696 N:= 10^6: # for terms <= N
%p A267696 R:= NULL: p:= 2:
%p A267696 do
%p A267696   p:= nextprime(p);
%p A267696   if p^4 > N then break fi;
%p A267696   R:= R, seq(2^i*p^4, i=0..floor(log[2](N/p^4)));
%p A267696 od:
%p A267696 sort([R]); # _Robert Israel_, May 25 2026
%t A267696 power2[n_, k_] := Module[{n4=Prime[n]^4 , k4=Prime[k]^4 }, k4 NestWhileList[2# &, 1, # k4 <=n4  &]]
%t A267696 a267696[n_] := Sort[Flatten[Map[power2[n, #]&, Range[2, n]]]]
%t A267696 a267696[8] (* all terms k less than or equal to twice the 4-th power of the 8-th prime; 260642 *)
%t A267696 (* _Hartmut F. W. Hoft_, May 25 2026 *)
%o A267696 (PARI) isok(n) = sumdiv(n, d, (d%2)) == 5; \\ _Michel Marcus_, Apr 03 2016
%o A267696 (GAP) A:=List([1..700000],n->DivisorsInt(n));;
%o A267696 B:=List([1..Length(A)],i->Filtered(A[i],IsOddInt));;
%o A267696 a:=Filtered([1..Length(B)],i->Length(B[i])=5); # _Muniru A Asiru_, Aug 14 2018
