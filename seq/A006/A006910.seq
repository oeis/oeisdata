%S A006910 1,0,432,1632,8700,18048,51072,82880,191926,251648,517568,619104,
%T A006910 1204024,1322368,2326528,2515904,4396188,4407552,7238000,7303456,
%U A006910 11911352,11434752,17948288,17151936,27144744,25129984,37714368,35413888,54674928,48607872,72122368
%N A006910 Theta series of laminated lattice LAMBDA_11^{min}.
%C A006910 Theta series is an element of the space of modular forms on Gamma_1(32) with Kronecker character 8 in modulus 32, weight 11/2, and dimension 22 over the integers. - _Andy Huchala_, May 05 2023
%C A006910 The g.f. identity in the Formula section is proven: multiplying both sides by theta_3(q)^3, where theta_3(q) = A2^5/(A1^2*A4^2), gives modular forms of weight 7 on Gamma_0(32) with character Kronecker(-2, .). The left side is the theta series of the even lattice LAMBDA_11^{min} + sqrt(2)Z^3, of determinant 8192, by Schoeneberg's theorem; each right-side eta quotient after multiplication by theta_3(q)^3 is in the same space by Ligozat's criteria. The two sides agree to n = 519, beyond the Sturm bound 448 for Gamma_1(32). - _Steven Kotlarz_, Jun 23 2026
%C A006910 The character Kronecker(-2, .) in the preceding comment is for the integer-weight theta_3(q)^3 lift, not for the raw half-integral-weight theta series described in the existing comments. - _Steven Kotlarz_, Jun 23 2026
%D A006910 J. H. Conway and N. J. A. Sloane, "Sphere Packings, Lattices and Groups", Springer-Verlag, p. 157.
%D A006910 E. C. Pervin, personal communication.
%D A006910 N. J. A. Sloane and Simon Plouffe, The Encyclopedia of Integer Sequences, Academic Press, 1995 (includes this sequence).
%H A006910 Andy Huchala, <a href="/A006910/b006910.txt">Table of n, a(n) for n = 0..20000</a>
%H A006910 G. Nebe and N. J. A. Sloane, <a href="http://www.math.rwth-aachen.de/~Gabriele.Nebe/LATTICES/LAMBDA11_MIN.html">Home page for this lattice</a>
%H A006910 <a href="/index/La#laminated">Index entries for sequences related to laminated lattices</a>
%F A006910 G.f.: 55*A2^12*A4^8*A16/(A1^8*A32^2) + 156*q^2*A2^12*A4^8*A8^2*A32^2/(A1^8*A16^5) + 16*q*A2^12*A4^10*A16^5/(A1^8*A8^6*A32^2) - 16*q^3*A2^12*A4^10*A32^2/(A1^8*A8^4*A16) + 8*q^4*A2^12*A4^12*A16^3*A32^2/(A1^8*A8^10) + 72*A2^7*A4^8*A8^5/(A1^6*A16*A32^2) - 544*q^2*A2^7*A4^8*A8^7*A32^2/(A1^6*A16^7) - 132*A2^9*A4^3*A8^5*A16^4/(A1^6*A32^4) - 152*q*A2^9*A4^5*A16^8/(A1^6*A8*A32^4) + 16*A2^11*A8^5*A16^9/(A1^6*A4^2*A32^6) + 256*q^3*A2^11*A8*A16^7/(A1^6*A32^2) + 118*A2^2*A4^8*A8^10/(A1^4*A16^3*A32^2) + 388*q^2*A2^2*A4^8*A8^12*A32^2/(A1^4*A16^9) - 128*q^3*A2^8*A8^6*A16^10/(A1^4*A4^5*A32^4) - 512*q^5*A2^10*A8^8*A16^9/(A1^4*A4^10*A32^2) - 512*q*A4^10*A8^9/(A1^2*A2^3*A16*A32^2) + 512*q^3*A4^10*A8^11*A32^2/(A1^2*A2^3*A16^7) - 128*A4^12*A8^6*A16^7/(A2^8*A32^6) + 768*q^2*A4^12*A8^8*A16/(A2^8*A32^2), where A_k = Product_{m>=1} (1 - q^(k*m)). - _Steven Kotlarz_, Jun 23 2026
%o A006910 (Magma)
%o A006910 prec := 40;
%o A006910 S := SymmetricMatrix([4,2,4,0,-2,4,0,-2,0,4,0,0,-2,0,4,-2,-2,0,0,0,4,0,0,0,0,0,-2,4,0,0,0,0,0,0,-2,4,0,0,0,0,1,-1,0,0,4,0,0,0,0,-1,0,0,0,0,4,-1,-2,1,1,0,1,0,-1,0,1,4]);
%o A006910 L := LatticeWithGram(S);
%o A006910 T<q> := ThetaSeries(L, 45);
%o A006910 M := ThetaSeriesModularFormSpace(L);
%o A006910 B := Basis(M, prec);
%o A006910 Coefficients(&+[Coefficients(T)[2*i-1] * B[i] : i in [1..21]] + Coefficients(T)[45]*B[22]); // _Andy Huchala_, May 05 2023
%o A006910 (PARI) T=40; q='q+O('q^T); E1=eta(q); E2=eta(q^2); E4=eta(q^4); E8=eta(q^8); E16=eta(q^16); E32=eta(q^32); Vec(55*E2^12*E4^8*E16/(E1^8*E32^2) + 156*q^2*E2^12*E4^8*E8^2*E32^2/(E1^8*E16^5) + 16*q*E2^12*E4^10*E16^5/(E1^8*E8^6*E32^2) - 16*q^3*E2^12*E4^10*E32^2/(E1^8*E8^4*E16) + 8*q^4*E2^12*E4^12*E16^3*E32^2/(E1^8*E8^10) + 72*E2^7*E4^8*E8^5/(E1^6*E16*E32^2) - 544*q^2*E2^7*E4^8*E8^7*E32^2/(E1^6*E16^7) - 132*E2^9*E4^3*E8^5*E16^4/(E1^6*E32^4) - 152*q*E2^9*E4^5*E16^8/(E1^6*E8*E32^4) + 16*E2^11*E8^5*E16^9/(E1^6*E4^2*E32^6) + 256*q^3*E2^11*E8*E16^7/(E1^6*E32^2) + 118*E2^2*E4^8*E8^10/(E1^4*E16^3*E32^2) + 388*q^2*E2^2*E4^8*E8^12*E32^2/(E1^4*E16^9) - 128*q^3*E2^8*E8^6*E16^10/(E1^4*E4^5*E32^4) - 512*q^5*E2^10*E8^8*E16^9/(E1^4*E4^10*E32^2) - 512*q*E4^10*E8^9/(E1^2*E2^3*E16*E32^2) + 512*q^3*E4^10*E8^11*E32^2/(E1^2*E2^3*E16^7) - 128*E4^12*E8^6*E16^7/(E2^8*E32^6) + 768*q^2*E4^12*E8^8*E16/(E2^8*E32^2)) \\ _Steven Kotlarz_, Jun 23 2026
%o A006910 (Python)
%o A006910 def A006910_list(T):
%o A006910     def euler(d):  # Product_{n>=1} (1-q^(d*n)), pentagonal number theorem
%o A006910         e = [0]*T; e[0] = 1; k = 1
%o A006910         while k*(3*k-1)//2*d < T:
%o A006910             s = -1 if k % 2 else 1
%o A006910             for g in (k*(3*k-1)//2*d, k*(3*k+1)//2*d):
%o A006910                 if g < T: e[g] += s
%o A006910             k += 1
%o A006910         return e
%o A006910     def mul(a, b):
%o A006910         c = [0]*T
%o A006910         for i, ai in enumerate(a):
%o A006910             if ai:
%o A006910                 for j in range(T-i):
%o A006910                     if b[j]: c[i+j] += ai*b[j]
%o A006910         return c
%o A006910     def inv(a):
%o A006910         c = [0]*T; c[0] = 1
%o A006910         for n in range(1, T): c[n] = -sum(a[k]*c[n-k] for k in range(1, n+1))
%o A006910         return c
%o A006910     def pw(a, e):
%o A006910         if e < 0: a, e = inv(a), -e
%o A006910         r = [0]*T; r[0] = 1
%o A006910         while e:
%o A006910             if e & 1: r = mul(r, a)
%o A006910             a = mul(a, a); e >>= 1
%o A006910         return r
%o A006910     E = {d: euler(d) for d in (1, 2, 4, 8, 16, 32)}
%o A006910     terms = [(55, 0, {1:-8, 2:12, 4:8, 16:1, 32:-2}), (156, 2, {1:-8, 2:12, 4:8, 8:2, 16:-5, 32:2}),
%o A006910         (16, 1, {1:-8, 2:12, 4:10, 8:-6, 16:5, 32:-2}), (-16, 3, {1:-8, 2:12, 4:10, 8:-4, 16:-1, 32:2}),
%o A006910         (8, 4, {1:-8, 2:12, 4:12, 8:-10, 16:3, 32:2}), (72, 0, {1:-6, 2:7, 4:8, 8:5, 16:-1, 32:-2}),
%o A006910         (-544, 2, {1:-6, 2:7, 4:8, 8:7, 16:-7, 32:2}), (-132, 0, {1:-6, 2:9, 4:3, 8:5, 16:4, 32:-4}),
%o A006910         (-152, 1, {1:-6, 2:9, 4:5, 8:-1, 16:8, 32:-4}), (16, 0, {1:-6, 2:11, 4:-2, 8:5, 16:9, 32:-6}),
%o A006910         (256, 3, {1:-6, 2:11, 8:1, 16:7, 32:-2}), (118, 0, {1:-4, 2:2, 4:8, 8:10, 16:-3, 32:-2}),
%o A006910         (388, 2, {1:-4, 2:2, 4:8, 8:12, 16:-9, 32:2}), (-128, 3, {1:-4, 2:8, 4:-5, 8:6, 16:10, 32:-4}),
%o A006910         (-512, 5, {1:-4, 2:10, 4:-10, 8:8, 16:9, 32:-2}), (-512, 1, {1:-2, 2:-3, 4:10, 8:9, 16:-1, 32:-2}),
%o A006910         (512, 3, {1:-2, 2:-3, 4:10, 8:11, 16:-7, 32:2}), (-128, 0, {2:-8, 4:12, 8:6, 16:7, 32:-6}),
%o A006910         (768, 2, {2:-8, 4:12, 8:8, 16:1, 32:-2})]
%o A006910     total = [0]*T
%o A006910     for c, lead, rd in terms:
%o A006910         f = [0]*T; f[0] = 1
%o A006910         for d, r in rd.items(): f = mul(f, pw(E[d], r))
%o A006910         for i in range(T - lead): total[i + lead] += c*f[i]
%o A006910     return total
%o A006910 print(A006910_list(35)) # _Steven Kotlarz_, Jun 23 2026
%K A006910 nonn
%O A006910 0,3
%A A006910 _N. J. A. Sloane_
%E A006910 a(26)-a(30) from _Andy Huchala_, May 05 2023
