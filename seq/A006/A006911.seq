%U A006911 13070328,9799680,20203512,14693376,29739560,21553152,42530424,30369792,59881584,41671680,81197184
%N A006911 Theta series of laminated lattice LAMBDA_11^{max}.
%C A006911 The g.f. identity in the Formula section is proven: multiplying both sides by theta_3(q)^3, where theta_3(q) = A2^5/(A1^2*A4^2), gives modular forms of weight 7 on Gamma_0(32) with character Kronecker(-2, .). The left side is the theta series of the even lattice LAMBDA_11^{max} + sqrt(2)Z^3, of determinant 8192, by Schoeneberg's theorem; each right-side eta quotient after multiplication by theta_3(q)^3 is in the same comparison space by Ligozat's criteria. The two sides agree to n = 519, beyond the Sturm bound 448 for Gamma_1(32). - _Steven Kotlarz_, Jun 23 2026
%C A006911 The character Kronecker(-2, .) in the preceding comment is for the integer-weight theta_3(q)^3 lift, not for the raw half-integral-weight theta series. - _Steven Kotlarz_, Jun 23 2026
%D A006911 J. H. Conway and N. J. A. Sloane, Laminated lattices, Annals of Math., 116 (1982), pp. 593-620. A revised version appears as Chapter 6 of ``Sphere Packings, Lattices and Groups'' by J. H. Conway and N. J. A. Sloane, Springer-Verlag, NY, 1988.
%D A006911 J. H. Conway and N. J. A. Sloane, "Sphere Packings, Lattices and Groups", Springer-Verlag. See Chap. 6.
%D A006911 E. C. Pervin, personal communication.
%D A006911 N. J. A. Sloane and Simon Plouffe, The Encyclopedia of Integer Sequences, Academic Press, 1995 (includes this sequence).
%H A006911 Andy Huchala, <a href="/A006911/b006911.txt">Table of n, a(n) for n = 0..20000</a>
%H A006911 J. H. Conway and N. J. A. Sloane, <a href="/A005135/a005135.png">The "shower" showing containments among the laminated lattices up to dimension 48</a> (Fig 3 from the Annals paper, also Fig. 6.1 in the Sphere packing book).
%F A006911 G.f.: 169*A2^12*A4^8*A16/(A1^8*A32^2) + 130*q^2*A2^12*A4^8*A8^2*A32^2/(A1^8*A16^5) - 8*q*A2^12*A4^10*A16^5/(A1^8*A8^6*A32^2) - 16*q^3*A2^12*A4^10*A32^2/(A1^8*A8^4*A16) + 4*q^2*A2^12*A4^12*A16^9/(A1^8*A8^12*A32^2) + 8*q^4*A2^12*A4^12*A16^3*A32^2/(A1^8*A8^10) - 256*A2^7*A4^8*A8^5/(A1^6*A16*A32^2) - 512*q^2*A2^7*A4^8*A8^7*A32^2/(A1^6*A16^7) - 104*A2^9*A4^3*A8^5*A16^4/(A1^6*A32^4) - 208*q*A2^9*A4^5*A16^8/(A1^6*A8*A32^4) + 448*A2^2*A4^8*A8^10/(A1^4*A16^3*A32^2) + 384*q^2*A2^2*A4^8*A8^12*A32^2/(A1^4*A16^9) - 768*q*A4^10*A8^9/(A1^2*A2^3*A16*A32^2) + 512*q^3*A4^10*A8^11*A32^2/(A1^2*A2^3*A16^7) - 256*A4^12*A8^6*A16^7/(A2^8*A32^6) + 1536*q^2*A4^12*A8^8*A16/(A2^8*A32^2), where A_k = Product_{m>=1} (1 - q^(k*m)). - _Steven Kotlarz_, Jun 23 2026
%o A006911 (Magma)
%o A006911 L := Lattice("Lambda", 11);
%o A006911 B := Basis(ThetaSeriesModularFormSpace(L),20);
%o A006911 Coefficients(B[1] + 438*B[3] + 1536*B[4] + 9372*B[5] + 15360*B[6]); // _Andy Huchala_, Jun 16 2021
%o A006911 (PARI) T=40; q='q+O('q^T); E1=eta(q); E2=eta(q^2); E4=eta(q^4); E8=eta(q^8); E16=eta(q^16); E32=eta(q^32); Vec(169*E2^12*E4^8*E16/(E1^8*E32^2) + 130*q^2*E2^12*E4^8*E8^2*E32^2/(E1^8*E16^5) - 8*q*E2^12*E4^10*E16^5/(E1^8*E8^6*E32^2) - 16*q^3*E2^12*E4^10*E32^2/(E1^8*E8^4*E16) + 4*q^2*E2^12*E4^12*E16^9/(E1^8*E8^12*E32^2) + 8*q^4*E2^12*E4^12*E16^3*E32^2/(E1^8*E8^10) - 256*E2^7*E4^8*E8^5/(E1^6*E16*E32^2) - 512*q^2*E2^7*E4^8*E8^7*E32^2/(E1^6*E16^7) - 104*E2^9*E4^3*E8^5*E16^4/(E1^6*E32^4) - 208*q*E2^9*E4^5*E16^8/(E1^6*E8*E32^4) + 448*E2^2*E4^8*E8^10/(E1^4*E16^3*E32^2) + 384*q^2*E2^2*E4^8*E8^12*E32^2/(E1^4*E16^9) - 768*q*E4^10*E8^9/(E1^2*E2^3*E16*E32^2) + 512*q^3*E4^10*E8^11*E32^2/(E1^2*E2^3*E16^7) - 256*E4^12*E8^6*E16^7/(E2^8*E32^6) + 1536*q^2*E4^12*E8^8*E16/(E2^8*E32^2)) \\ _Steven Kotlarz_, Jun 23 2026
%o A006911 (Python)
%o A006911 def A006911_list(T):
%o A006911     def euler(d):  # Product_{n>=1} (1-q^(d*n)), pentagonal number theorem
%o A006911         e = [0]*T; e[0] = 1; k = 1
%o A006911         while k*(3*k-1)//2*d < T:
%o A006911             s = -1 if k % 2 else 1
%o A006911             for g in (k*(3*k-1)//2*d, k*(3*k+1)//2*d):
%o A006911                 if g < T: e[g] += s
%o A006911             k += 1
%o A006911         return e
%o A006911     def mul(a, b):
%o A006911         c = [0]*T
%o A006911         for i, ai in enumerate(a):
%o A006911             if ai:
%o A006911                 for j in range(T-i):
%o A006911                     if b[j]: c[i+j] += ai*b[j]
%o A006911         return c
%o A006911     def inv(a):
%o A006911         c = [0]*T; c[0] = 1
%o A006911         for n in range(1, T): c[n] = -sum(a[k]*c[n-k] for k in range(1, n+1))
%o A006911         return c
%o A006911     def pw(a, e):
%o A006911         if e < 0: a, e = inv(a), -e
%o A006911         r = [0]*T; r[0] = 1
%o A006911         while e:
%o A006911             if e & 1: r = mul(r, a)
%o A006911             a = mul(a, a); e >>= 1
%o A006911         return r
%o A006911     E = {d: euler(d) for d in (1, 2, 4, 8, 16, 32)}
%o A006911     terms = [(169, 0, {1:-8, 2:12, 4:8, 16:1, 32:-2}), (130, 2, {1:-8, 2:12, 4:8, 8:2, 16:-5, 32:2}),
%o A006911         (-8, 1, {1:-8, 2:12, 4:10, 8:-6, 16:5, 32:-2}), (-16, 3, {1:-8, 2:12, 4:10, 8:-4, 16:-1, 32:2}),
%o A006911         (4, 2, {1:-8, 2:12, 4:12, 8:-12, 16:9, 32:-2}), (8, 4, {1:-8, 2:12, 4:12, 8:-10, 16:3, 32:2}),
%o A006911         (-256, 0, {1:-6, 2:7, 4:8, 8:5, 16:-1, 32:-2}), (-512, 2, {1:-6, 2:7, 4:8, 8:7, 16:-7, 32:2}),
%o A006911         (-104, 0, {1:-6, 2:9, 4:3, 8:5, 16:4, 32:-4}), (-208, 1, {1:-6, 2:9, 4:5, 8:-1, 16:8, 32:-4}),
%o A006911         (448, 0, {1:-4, 2:2, 4:8, 8:10, 16:-3, 32:-2}), (384, 2, {1:-4, 2:2, 4:8, 8:12, 16:-9, 32:2}),
%o A006911         (-768, 1, {1:-2, 2:-3, 4:10, 8:9, 16:-1, 32:-2}), (512, 3, {1:-2, 2:-3, 4:10, 8:11, 16:-7, 32:2}),
%o A006911         (-256, 0, {2:-8, 4:12, 8:6, 16:7, 32:-6}), (1536, 2, {2:-8, 4:12, 8:8, 16:1, 32:-2})]
%o A006911     total = [0]*T
%o A006911     for c, lead, rd in terms:
%o A006911         f = [0]*T; f[0] = 1
%o A006911         for d, r in rd.items(): f = mul(f, pw(E[d], r))
%o A006911         for i in range(T - lead): total[i + lead] += c*f[i]
%o A006911     return total
%o A006911 print(A006911_list(35)) # _Steven Kotlarz_, Jun 23 2026
%Y A006911 Cf. A005933, A006909, A006910.
%K A006911 nonn,changed
%O A006911 0,3
