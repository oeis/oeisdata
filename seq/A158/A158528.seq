%T A158528 233148,329118,413586,584951,742021,927917,1209050,1500573,1815997,
%U A158528 2286198,2771420,3302411,3852425,4848999,5721599,6536322,7584155,8889048,10462469,12034300,14236344,15137532,18155279
%N A158528 Sum of primes between consecutive positive cubes.
%H A158528 Robert Israel, <a href="/A158528/b158528.txt">Table of n, a(n) for n = 1..600</a>
%e A158528 a(1) = 2 + 3 + 5 + 7 = 17, a(2) = 11 + 13 + 17 + 19 + 23 = 83.
%p A158528 R:= NULL: p:= 0:
%p A158528 for k from 2 to 50 do
%p A158528   t:= p;
%p A158528   do
%p A158528     p:= nextprime(p);
%p A158528     if p > k^3 then
%p A158528        R:= R,t; break
%p A158528     fi;
%p A158528     t:= t+p
%p A158528 od; od:
%p A158528 R; # _Robert Israel_, Jun 12 2026
%t A158528 Join[{17},Table[Total[Prime[Range[PrimePi[n^3]+1,PrimePi[(n+1)^3]]]],{n,2,35}]] (* _Harvey P. Dale_, Aug 16 2011 *)
