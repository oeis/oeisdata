%N A015538 Inverse of 1529th cyclotomic polynomial.
%C A015538 Periodic with period length 1529. - _Ray Chandler_, Apr 07 2017
%H A015538 Ray Chandler, <a href="/A015538/b015538.txt">Table of n, a(n) for n = 0..2000</a>
%H A015538 <a href="/index/Per#periodic">Index entries for periodic sequences</a>, period 1529.
%H A015538 <a href="/index/Rec#order_1380">Index entries for linear recurrences with constant coefficients</a>, order 1380.
%H A015538 <a href="/index/Pol#poly_cyclo_inv">Index to sequences related to inverse of cyclotomic polynomials</a>
%p A015538 with(numtheory,cyclotomic); c := n->series(1/cyclotomic(n,x),x,80);
%t A015538 CoefficientList[Series[1/Cyclotomic[1529,x],{x,0,120}],x,120] (* _Harvey P. Dale_, Jun 13 2025 *)
%o A015538 (PARI) first(n)=Vec(1/polcyclo(1529)+O(x^(n+1))) \\ _Charles R Greathouse IV_, Jun 01 2026
%K A015538 sign,easy,changed
%O A015538 0,1
%A A015538 _Simon Plouffe_
