%N A015504 Inverse of 1495th cyclotomic polynomial.
%C A015504 Periodic with period length 1495. - _Ray Chandler_, Apr 07 2017
%H A015504 Ray Chandler, <a href="/A015504/b015504.txt">Table of n, a(n) for n = 0..2000</a>
%H A015504 <a href="/index/Per#periodic">Index entries for periodic sequences</a>, period 1495.
%H A015504 <a href="/index/Rec#order_1056">Index entries for linear recurrences with constant coefficients</a>, order 1056.
%H A015504 <a href="/index/Pol#poly_cyclo_inv">Index to sequences related to inverse of cyclotomic polynomials</a>
%p A015504 with(numtheory,cyclotomic); c := n->series(1/cyclotomic(n,x),x,80);
%t A015504 CoefficientList[Series[1/Cyclotomic[1495,x],{x,0,120}],x] (* _Harvey P. Dale_, Jan 05 2021 *)
%o A015504 (PARI) first(n)=Vec(1/polcyclo(1495)+O(x^(n+1))) \\ _Charles R Greathouse IV_, Jun 01 2026
%K A015504 sign,easy,changed
%O A015504 0,24
%A A015504 _Simon Plouffe_
