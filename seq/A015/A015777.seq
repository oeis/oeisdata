%p A015777 with(numtheory,cyclotomic); c := n->series(1/cyclotomic(n,x),x,80);
%t A015777 CoefficientList[Series[1/Cyclotomic[1768,x],{x,0,120}],x] (* _Harvey P. Dale_, Dec 09 2024 *)
