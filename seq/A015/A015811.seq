%N A015811 Inverse of 1802nd cyclotomic polynomial.
%C A015811 Periodic with period length 1802. - _Ray Chandler_, Apr 07 2017
%H A015811 Ray Chandler, <a href="/A015811/b015811.txt">Table of n, a(n) for n = 0..2000</a>
%H A015811 <a href="/index/Per#periodic">Index entries for periodic sequences</a>, period 1802.
%H A015811 <a href="/index/Rec#order_832">Index entries for linear recurrences with constant coefficients</a>, order 832.
%H A015811 <a href="/index/Pol#poly_cyclo_inv">Index to sequences related to inverse of cyclotomic polynomials</a>
%p A015811 with(numtheory,cyclotomic); c := n->series(1/cyclotomic(n,x),x,80);
%t A015811 CoefficientList[Series[1/Cyclotomic[1802,x],{x,0,120}],x,120] (* _Harvey P. Dale_, May 15 2021 *)
%o A015811 (PARI) first(n)=Vec(1/polcyclo(1802)+O(x^(n+1))) \\ _Charles R Greathouse IV_, Jun 01 2026
%K A015811 sign,easy,changed
%O A015811 0,1
%A A015811 _Simon Plouffe_
