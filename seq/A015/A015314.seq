%N A015314 Inverse of 1305th cyclotomic polynomial.
%C A015314 Periodic with period length 1305. - _Ray Chandler_, Apr 07 2017
%H A015314 Ray Chandler, <a href="/A015314/b015314.txt">Table of n, a(n) for n = 0..2000</a>
%H A015314 <a href="/index/Per#periodic">Index entries for periodic sequences</a>, period 1305.
%H A015314 <a href="/index/Rec#order_672">Index entries for linear recurrences with constant coefficients</a>, order 672.
%H A015314 <a href="/index/Pol#poly_cyclo_inv">Index to sequences related to inverse of cyclotomic polynomials</a>
%p A015314 with(numtheory,cyclotomic); c := n->series(1/cyclotomic(n,x),x,80);
%t A015314 CoefficientList[Series[1/Cyclotomic[1305,x],{x,0,120}],x] (* _Harvey P. Dale_, Jan 17 2020 *)
%o A015314 (PARI) first(n)=Vec(1/polcyclo(1305)+O(x^(n+1))) \\ _Charles R Greathouse IV_, Jun 01 2026
%K A015314 sign,easy,changed
%O A015314 0,1
%A A015314 _Simon Plouffe_
