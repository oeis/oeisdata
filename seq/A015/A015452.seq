%p A015452 with(numtheory,cyclotomic); c := n->series(1/cyclotomic(n,x),x,80);
%t A015452 CoefficientList[Series[1/Cyclotomic[1443,x],{x,0,120}],x] (* _Harvey P. Dale_, Jan 03 2024 *)
%o A015452 (PARI) first(n)=Vec(1/polcyclo(1443)+O(x^(n+1))) \\ _Charles R Greathouse IV_, Jun 01 2026
