%p A015115 with(numtheory,cyclotomic); c := n->series(1/cyclotomic(n,x),x,80);
%t A015115 CoefficientList[Series[1/Cyclotomic[1106,x],{x,0,120}],x] (* _Harvey P. Dale_, Mar 19 2026 *)
