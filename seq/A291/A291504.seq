%I A291504 #31 May 02 2026 17:55:16
%S A291504 1,1,0,1,3,8,48,206,1838,13336,133764,1081556,11046816,108196128,
%T A291504 1555323224,16279258144,289771660328,3495882548784,66923393467216,
%U A291504 942785369844048,15625264115770992,315553823251866304,5974132307015712032,104979988889030774848
%N A291504 Number of permutations s_1,s_2,...,s_n of 1,2,...,n such that for all j=1,2,...,n, Sum_{i=1..j} s_i is not a prime.
%e A291504 1             is not a prime,
%e A291504 1 + 3         is not a prime,
%e A291504 1 + 3 + 2     is not a prime,
%e A291504 1 + 3 + 2 + 4 is not a prime.
%e A291504 So [1, 3, 2, 4] satisfies all the conditions.
%e A291504 ---------------------------------------------
%e A291504 a(1) = 1: [[1]];
%e A291504 a(3) = 1: [[1, 3, 2]];
%e A291504 a(4) = 3: [[1, 3, 2, 4], [1, 3, 4, 2], [4, 2, 3, 1]];
%e A291504 a(5) = 8: [[1, 3, 2, 4, 5], [1, 3, 4, 2, 5], [1, 5, 2, 4, 3], [1, 5, 4, 2, 3], [4, 2, 3, 1, 5], [4, 2, 3, 5, 1], [4, 5, 1, 2, 3], [4, 5, 3, 2, 1]].
%t A291504 Table[Count[Permutations@ Range@ n, _?(AllTrue[Accumulate@ #, ! PrimeQ@ # &] &)], {n, 0, 10}] (* _Michael De Vlieger_, Aug 26 2017 *)
%o A291504 (Python)
%o A291504 from functools import cache
%o A291504 from itertools import permutations
%o A291504 from sympy import primerange
%o A291504 def a(n):
%o A291504     @cache
%o A291504     def c(t, s): # count satisfying permutations where items in t must be placed and sum is s
%o A291504         if s in primes: return 0
%o A291504         if len(t) == 0: return 1
%o A291504         S = set(t)
%o A291504         return sum(c(tuple(sorted(S-{i})), s+i) for i in t)
%o A291504     primes = set(primerange(1, n*(n+1)//2+1))
%o A291504     if n == 0 or sum(range(1, n+1)) in primes: return int(n == 0)
%o A291504     return c(tuple(range(1, n+1)), 0)
%o A291504 print([a(n) for n in range(18)]) # _Michael S. Branicky_, May 02 2026
%Y A291504 Cf. A067957, A291355.
