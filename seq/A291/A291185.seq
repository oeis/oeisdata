%I A291185 #37 Mar 29 2026 08:59:20
%S A291185 1,2,2,6,6,6,12,30,30,60,120,210,420,420,840,2520,9240,9240,27720,
%T A291185 55440,120120,360360,720720,2162160,6126120,12252240,36756720,
%U A291185 116396280,232792560,698377680,2677114440,5354228880,26771144400,155272637520,465817912560
%N A291185 a(n) = the smallest number k such that sigma(k) / phi(k) >= n.
%C A291185 a(n) = the smallest number k such that A000203(k) / A000010(k) = A289336(k) / A289412(k) >= n.
%C A291185 From _David A. Corneth_, Mar 26 2026: (Start)
%C A291185 All terms come from A025487.
%C A291185 sigma(p^n)/phi(p^n) -> (p/(p-1))^2 as n->oo for prime p. This enables us to find the smallest value of omega(a(n)) where omega = A001221, the number of distinct prime factors. Knowing this smallest value of omega(a(n)) we can find an upper bound on a(n) to than whittle it down or verify it by checking the product of a "large" primorial and some product of primorials from A025487.
%C A291185 (End)
%H A291185 David A. Corneth, <a href="/A291185/b291185.txt">Table of n, a(n) for n = 1..125</a>
%e A291185 For n = 4; a(4) = 6 because 6 is the smallest number with sigma(6) / phi(6) = 12 / 2 = 6 >= 2.
%p A291185 b:= 0:
%p A291185 for n from 1 to 3*10^6 do
%p A291185 r:= floor(numtheory:-sigma(n)/numtheory:-phi(n));
%p A291185 if r > b then
%p A291185     for i from b+1 to r do A[i]:= n od:
%p A291185     b:= r;
%p A291185 fi
%p A291185 od:
%p A291185 seq(A[i],i=1..b); # _Robert Israel_, Aug 21 2017
%t A291185 r = 1; Reap[ Do[z = DivisorSigma[1, n]/EulerPhi@ n; While[z >= r, r++; Sow@ n], {n, 10^6}]][[2, 1]] (* _Giovanni Resta_, Aug 21 2017 *)
%o A291185 (Magma) a:=1; S:=[a]; for n in [2..24] do k:=0; flag:= true; while flag do k+:=1; if &+[d: d in Divisors(k)] / EulerPhi(k) ge n then Append(~S, k); a:=k; flag:=false; end if; end while; end for; S;
%o A291185 (Python)
%o A291185 from math import prod
%o A291185 from heapq import heappop, heappush
%o A291185 from sympy import prevprime, nextprime, factorint
%o A291185 def A291185(n):
%o A291185     h, hset = [1], {1}
%o A291185     while True:
%o A291185         m = heappop(h)
%o A291185         ps = factorint(m)
%o A291185         if prod(p**(e+2)-p for p, e in ps.items())>=n*m*prod((p-1)**2 for p, e in ps.items()):
%o A291185             return m
%o A291185         for p in ps:
%o A291185             if p == 2 or ps[prevprime(p)]>ps[p]:
%o A291185                 mp = m*p
%o A291185                 if mp not in hset:
%o A291185                     heappush(h,mp)
%o A291185                     hset.add(mp)
%o A291185         mp = m*nextprime(max(ps.keys(),default=1))
%o A291185         if mp not in hset:
%o A291185             heappush(h,mp)
%o A291185             hset.add(mp) # _Chai Wah Wu_, Mar 29 2026
%Y A291185 Cf. A000010, A000203, A001221, A025487, A055234, A289336, A289412.
%K A291185 nonn,changed
%O A291185 1,2
%A A291185 _Jaroslav Krizek_, Aug 19 2017
