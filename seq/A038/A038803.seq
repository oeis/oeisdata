%U A038803 675062237124119687705225516359940415764182261,6750622348964143051956305469326962117763788889781985387
%N A038803 Largest number with n prime factors of lengths 1, ..., n.
%H A038803 Robert Israel, <a href="/A038803/b038803.txt">Table of n, a(n) for n = 1..45</a>
%F A038803 a(n) = Product_{k=1..n} prev_prime(10^k). - _Sean A. Irvine_, Feb 14 2021
%p A038803 r:= 1: R:= NULL:
%p A038803 for n from 1 to 12 do
%p A038803 r:= r * prevprime(10^n);
%p A038803 R:= R,r;
%p A038803 od:
%p A038803 R; # _Robert Israel_, Apr 17 2026
