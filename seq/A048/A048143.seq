%S A048143 1,1,1,5,84,6348,7743728,2414572893530,56130437190053299918162,
%T A048143 286386577668298410118121281812003477723571
%N A048143 Number of labeled connected simplicial complexes with n nodes.
%C A048143 Also number of connected antichains on a labeled n-set.
%H A048143 Patrick De Causmaecker and Stefan De Wannemacker, <a href="https://arxiv.org/abs/1407.4288">On the number of antichains of sets in a finite universe</a>, arXiv:1407.4288 [math.CO], 2014.
%H A048143 Greg Huber, <a href="/A048143/a048143.pdf">Letters to N. J. A. Sloane, May 1983</a> [Annotated, corrected, scanned copy]
%H A048143 Gus Wiseman, <a href="http://www.mathematica-journal.com/2017/12/every-clutter-is-a-tree-of-blobs/">Every Clutter Is a Tree of Blobs</a>, The Mathematica Journal, Vol. 19, 2017.
%H A048143 Gus Wiseman, <a href="/A048143/a048143_4.txt">Sequences enumerating clutters, antichains, hypertrees, and hyperforests, organized by labeling, spanning, and allowance of singletons</a>.
%F A048143 Let u(n) = Sum_{j=0..n} ((-1)^j * binomial(n, j) * (A000372(n-j)-1)). Then a(0) = 1 and, for n >= 1, a(n) = u(n) - Sum_{k=1..n-1} (binomial(n-1, k-1) * a(k) * u(n-k)). - _Robert P. P. McKone_, Apr 15 2026
%e A048143 For n=3 we could have 2 edges (in 3 ways), 3 edges (1 way), or 3 edges and a triangle (1 way), so a(3)=5.
%e A048143 a(5) = 1+75+645+1655+2005+1345+485+115+20+2 = 6348.
%t A048143 a000372Terms0To9={2,3,6,20,168,7581,7828354,2414682040998,56130437228687557907788,286386577668298411128469151667598498812366}; u[n_]:=u[n]=Sum[(-1)^j Binomial[n,j](a000372Terms0To9[[n-j+1]]-1),{j,0,n}]; a[0]=1; a[n_]:=a[n]=u[n]-Sum[Binomial[n-1,k-1] a[k] u[n-k],{k,1,n-1}]; Table[a[n],{n,0,Length[a000372Terms0To9]-1}] (* _Robert P. P. McKone_, Apr 14 2026 *)
