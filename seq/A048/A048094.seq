%I A048094 #10 May 26 2026 01:13:39
%S A048094 0,0,1,2,6,13,25,45,91,175,322,570,975,1617,2607,7425,12753,21385,
%T A048094 35065,56302,88638,136986,208050,310840,1251606,1973706,3065931,
%U A048094 4694921,7092211,10575635,15576535,22674015,32637675,46480475
%N A048094 Number of nonempty subsets of {1,2,...,n} in which exactly 1/3 of the elements are <= sqrt(n).
%H A048094 Robert Israel, <a href="/A048094/b048094.txt">Table of n, a(n) for n = 1..10000</a>
%F A048094 From _Robert Israel_, May 25 2026: (Start)
%F A048094 a(n) = Sum_{1 <= k <= s} binomial(s,k) * binomial(n-s,2*k)
%F A048094      = s*(n-s-1)*(n-s)*hypergeom([1, 1-s, -1/2*n+1/2*s+1, -1/2*n+1/2*s+3/2],[3/2,
%F A048094 2, 2],-1)/2
%F A048094   where s = floor(sqrt(n)).
%F A048094 (End)
%p A048094 f:= proc(n) local s,m;
%p A048094    s:= floor(sqrt(n));
%p A048094    add(binomial(s,m) * binomial(n-s,2*m), m=1..s)
%p A048094 end proc:
%p A048094 map(f, [$1..100]); # _Robert Israel_, May 25 2026
%K A048094 nonn
%O A048094 1,4
%A A048094 _Clark Kimberling_
