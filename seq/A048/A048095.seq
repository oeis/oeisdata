%S A048095 0,0,0,2,3,4,5,6,18,21,24,27,30,33,36,138,156,175,195,216,238,261,285,
%T A048095 310,1150,1260,1375,1495,1620,1750,1885,2025,2170,2320,2475,11035,
%U A048095 11935,12880,13871,14909,15995,17130,18315,19551,20839,22180,23575,25025,111377,118895,126742,134925,143451
%N A048095 Number of nonempty subsets of {1,2,...,n} in which exactly 2/3 of the elements are <= sqrt(n).
%H A048095 Robert Israel, <a href="/A048095/b048095.txt">Table of n, a(n) for n = 1..10000</a>
%F A048095 From _Robert Israel_, May 25 2026: (Start)
%F A048095 a(n) = Sum_{1 <= k <= s/2} binomial(s,2*k) * binomial(n-s,2*k)
%F A048095      = (s-1)*s*(n-s)*hypergeom([1, -n+s+1, 1-1/2*s, -1/2*s+3/2],[3/2, 2, 2],-1)/2
%F A048095 where s = floor(sqrt(n)).
%F A048095 (End)
%p A048095 f:= proc(n) local s,m;
%p A048095    s:= floor(sqrt(n));
%p A048095    add(binomial(s,2*m) * binomial(n-s,m), m=1..s/2)
%p A048095 end proc:
%p A048095 map(f, [$1..100]); # _Robert Israel_, May 25 2026
%K A048095 nonn,changed
%O A048095 1,4
%A A048095 _Clark Kimberling_
