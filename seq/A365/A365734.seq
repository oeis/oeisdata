%N A365734 G.f. satisfies A(x) = 1 + x*A(x) / (1 - x^5*A(x)^2).
%H A365734 Robert Israel, <a href="/A365734/b365734.txt">Table of n, a(n) for n = 0..3268</a>
%F A365734 a(n) = Sum_{k=0..floor(n/5)} binomial(n-4*k-1,k) * binomial(n-3*k+1,n-5*k) / (n-3*k+1).
%F A365734 D-finite with recurrence: (40*n^2 + 100*n)*a(n) + (26*n^2 + 254*n + 528)*a(n + 3) + (-212*n^2 - 1874*n - 3744)*a(n + 4) + (-120*n^2 - 1500*n - 4500)*a(n + 5) + (4*n^2 + 64*n + 240)*a(n + 6) + (-123*n^2 - 1977*n - 7776)*a(n + 7) + (138*n^2 + 2142*n + 7464)*a(n + 8) + (104*n^2 + 3308*n + 23778)*a(n + 9) + (104*n^2 + 2348*n + 13080)*a(n + 10) + (60*n^2 + 1428*n + 8400)*a(n + 11) + (-44*n^2 - 1034*n - 5784)*a(n + 12) + (-68*n^2 - 2108*n - 16362)*a(n + 13) + (108*n^2 + 3366*n + 26166)*a(n + 14) + (-40*n^2 - 1300*n - 10500)*a(n + 15) = 0. - _Robert Israel_, Mar 02 2026
%p A365734 f:= gfun:-rectoproc({(40*n^2 + 100*n)*a(n) + (26*n^2 + 254*n + 528)*a(n + 3) + (-212*n^2 - 1874*n - 3744)*a(n + 4) + (-120*n^2 - 1500*n - 4500)*a(n + 5) + (4*n^2 + 64*n + 240)*a(n + 6) + (-123*n^2 - 1977*n - 7776)*a(n + 7) + (138*n^2 + 2142*n + 7464)*a(n + 8) + (104*n^2 + 3308*n + 23778)*a(n + 9) + (104*n^2 + 2348*n + 13080)*a(n + 10) + (60*n^2 + 1428*n + 8400)*a(n + 11) + (-44*n^2 - 1034*n - 5784)*a(n + 12) + (-68*n^2 - 2108*n - 16362)*a(n + 13) + (108*n^2 + 3366*n + 26166)*a(n + 14) + (-40*n^2 - 1300*n - 10500)*a(n + 15), a(0) = 1, a(1) = 1, a(2) = 1, a(3) = 1, a(4) = 1, a(5) = 1, a(6) = 2, a(7) = 5, a(8) = 11, a(9) = 21, a(10) = 36, a(11) = 58, a(12) = 94, a(13) = 163, a(14) = 306},a(n),remember):
%p A365734 map(f, [$0..40]);
%o A365734 (PARI) a(n) = sum(k=0, n\5, binomial(n-4*k-1, k)*binomial(n-3*k+1, n-5*k)/(n-3*k+1));
