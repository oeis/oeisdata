%N A365728 G.f. satisfies A(x) = 1 + x^4*A(x)^2*(1 + x*A(x)).
%H A365728 Robert Israel, <a href="/A365728/b365728.txt">Table of n, a(n) for n = 0..4364</a>
%F A365728 a(n) = Sum_{k=0..floor(n/4)} binomial(k,n-4*k) * binomial(n-2*k+1,k) / (n-2*k+1).
%F A365728 D-finite with recurrence: (-16*n^2 - 48*n - 32)*a(n) + (-108*n^2 - 648*n - 924)*a(n + 2) + (-12*n^2 + 180*n + 1056)*a(n + 3) + (16*n^2 + 216*n + 680)*a(n + 4) + (405*n^2 + 6075*n + 22500)*a(n + 5) + (351*n^2 + 5913*n + 24732)*a(n + 6) + (55*n^2 + 999*n + 4508)*a(n + 7) + (-3*n^2 - 63*n - 324)*a(n + 8) + (-60*n^2 - 1350*n - 7500)*a(n + 10) + (-12*n^2 - 306*n - 1944)*a(n + 11) = 0. - _Robert Israel_, Mar 02 2026
%p A365728 f:= gfun:-rectoproc({(-16*n^2 - 48*n - 32)*a(n) + (-108*n^2 - 648*n - 924)*a(n + 2) + (-12*n^2 + 180*n + 1056)*a(n + 3) + (16*n^2 + 216*n + 680)*a(n + 4) + (405*n^2 + 6075*n + 22500)*a(n + 5) + (351*n^2 + 5913*n + 24732)*a(n + 6) + (55*n^2 + 999*n + 4508)*a(n + 7) + (-3*n^2 - 63*n - 324)*a(n + 8) + (-60*n^2 - 1350*n - 7500)*a(n + 10) + (-12*n^2 - 306*n - 1944)*a(n + 11), a(0) = 1, a(1) = 0, a(2) = 0, a(3) = 0, a(4) = 1, a(5) = 1, a(6) = 0, a(7) = 0, a(8) = 2, a(9) = 5, a(10) = 3},a(n),remember):
%p A365728 map(f, [$0..50]); # _Robert Israel_, Mar 02 2026
%o A365728 (PARI) a(n) = sum(k=0, n\4, binomial(k, n-4*k)*binomial(n-2*k+1, k)/(n-2*k+1));
