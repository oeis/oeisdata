%N A365690 G.f. A(x) satisfies A(x) = 1 + x^2*A(x)^4 / (1 - x*A(x)).
%H A365690 Robert Israel, <a href="/A365690/b365690.txt">Table of n, a(n) for n = 0..1725</a>
%F A365690 a(n) = Sum_{k=0..floor(n/2)} binomial(n-k-1,n-2*k) * binomial(n+2*k+1,k) / (n+2*k+1).
%F A365690 D-finite with recurrence: -3*(3*n + 2)*(3*n + 1)*(1 + n)*a(n) + (n + 2)*(167*n^2 + 615*n + 522)*a(1 + n) - 6*(19*n^3 + 365*n^2 + 1448*n + 1628)*a(n + 2) - (887*n^3 + 6774*n^2 + 14397*n + 5494)*a(n + 3) + 3*(9 + 2*n)*(287*n^2 + 2583*n + 5482)*a(n + 4) - (887*n^3 + 17175*n^2 + 108006*n + 222008)*a(n + 5) - 6*(19*n^3 + 148*n^2 - 505*n - 4310)*a(n + 6) + (n + 7)*(167*n^2 + 2391*n + 8514)*a(n + 7) - 3*(3*n + 25)*(n + 8)*(3*n + 26)*a(n + 8) = 0. - _Robert Israel_, May 18 2026
%p A365690 f:= gfun:-rectoproc({(-27*n^3 - 54*n^2 - 33*n - 6)*a(n) + (167*n^3 + 949*n^2 + 1752*n + 1044)*a(1 + n) + (-114*n^3 - 2190*n^2 - 8688*n - 9768)*a(n + 2) + (-887*n^3 - 6774*n^2 - 14397*n - 5494)*a(n + 3) + (1722*n^3 + 23247*n^2 + 102633*n + 148014)*a(n + 4) + (-887*n^3 - 17175*n^2 - 108006*n - 222008)*a(n + 5) + (-114*n^3 - 888*n^2 + 3030*n + 25860)*a(n + 6) + (167*n^3 + 3560*n^2 + 25251*n + 59598)*a(n + 7) + (-27*n^3 - 675*n^2 - 5622*n - 15600)*a(n + 8), a(0) = 1, a(1) = 0, a(2) = 1, a(3) = 1, a(4) = 5, a(5) = 10, a(6) = 38, a(7) = 101}, a(n), remember):
%p A365690 map(f, [$0..30]); # _Robert Israel_, May 18 2026
%o A365690 (PARI) a(n) = sum(k=0, n\2, binomial(n-k-1, n-2*k)*binomial(n+2*k+1, k)/(n+2*k+1));
