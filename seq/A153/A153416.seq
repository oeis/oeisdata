%N A153416 Decimal expansion of Sum_{n>=0} 1/A000032(2*n+1).
%F A153416 From _Amiram Eldar_, Jul 05 2025: (Start)
%F A153416 Equals Sum_{n>=0} 1/A002878(n).
%F A153416 Equals A093540 - A153415. (End)
%F A153416 Equals g(r) - 2*g(r^2) + g(r^4) where r=1/phi and g(q)=(qpolygamma(1,q) + log(1-q))/log(q). - _Jwalin Bhatt_, Mar 20 2026
%e A153416 1.3966804973982612325...
%t A153416 RealDigits[ NSum[ 1/LucasL[2*n + 1], {n, 0, Infinity}, WorkingPrecision -> 110, NSumTerms -> 100], 10, 105] // First (* _Jean-François Alcover_, Feb 07 2013 *)
%t A153416 With[{x = 1/GoldenRatio, g = (QPolyGamma[1, #] + Log[1 - #])/Log[#] &}, RealDigits[ g[x] - 2*g[x^2] + g[x^4],10, 105][[1]]] (* _Jwalin Bhatt_, Mar 20 2026 *)
