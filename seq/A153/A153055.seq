%I A153055 #18 Mar 02 2026 15:57:32
%S A153055 11,13,27,29,45,53,54,59,61,79,83,101,103,106,107,109,115,121,125,139,
%T A153055 149,155,158,163,166,169,173,181,187,197,199,202,206,211,212,213,218,
%U A153055 227,235,237,251,293,298,310,311,319,326,329,345,346,349,353,361,362,369
%N A153055 Numbers k such that the binary expansion of k is a substring of the binary expansion of 1/k.
%e A153055 13 is a term because bin(13) = 1101 and bin(1/13) = .000100111011... (repeats infinitely) and 1101 appears in the binary expansion of the reciprocal.
%o A153055 (Python)
%o A153055 def isok(k):
%o A153055     s=bin(k)[2:]
%o A153055     digits=k+len(s)
%o A153055     t=bin(2**digits//k)[2:]
%o A153055     return k&(k-1)>0 and s in t
%o A153055 print([k for k in range(1,400) if isok(k)]) # _Jason Yuen_, Feb 25 2026
%K A153055 base,easy,nonn,changed
%O A153055 1,1
