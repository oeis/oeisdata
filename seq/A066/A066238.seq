%S A066238 1,2,12,18,40,56,304,550,748,1504,3230,3770,6976,29824,124672,351351,
%T A066238 382772,510464,537248,698528,791264,1081568,1279136,2065408,2279072,
%U A066238 211855016,561841408,731378944,3365232128,3557004544,8586723328,27339731968,549724880896,557827806208,2198959292416,6122014414784,629472767615810
%N A066238 floor(x/3)-perfect numbers, where f-perfect numbers for an arithmetical function f are defined in A066218.
%C A066238 It appears that there are more floor(x/N)-perfect numbers the larger N is. Here N = 3.
%H A066238 Max Alekseyev, <a href="/A066238/b066238.txt">Table of n, a(n) for n = 1..49</a>
%H A066238 Joseph L. Pe, <a href="https://vixra.org/abs/2503.0165">On a Generalization of Perfect Numbers</a>, J. Rec. Math. 31:3 (2002), 168-172.
%e A066238 Let f(x) = floor(x/3). Then f(12) = 6 = 3+2+1+0 = f(6)+f(4)+f(3)+f(1); so 12 is a term of the sequence.
%t A066238 f[x_] := Floor[x/3]; Select[ Range[1, 10^5], 2 * f[ # ] == Apply[ Plus, Map[ f, Divisors[ # ] ] ] & ]
%Y A066238 Cf. A066218, A066239, A066240.
%K A066238 nonn,changed
%O A066238 1,2
%A A066238 _Joseph L. Pe_, Dec 19 2001
%E A066238 a(15)-a(30) from _Amiram Eldar_, Sep 26 2019
%E A066238 a(1)=1 prepended and terms a(31) onward added by _Max Alekseyev_, Jun 22 2026
