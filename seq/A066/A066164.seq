%I A066164 #30 Apr 17 2026 17:47:16
%S A066164 180,360,540,720,900,1080,1260,1440,1620,1800,1980,2160,2340,2520,
%T A066164 2700,2880,3060,3240,3420,3600,3780,3960,4140,4320,4500,4680,4860,
%U A066164 5040,5220,5400,5580,5760,5940,6120,6300,6480,6660,6840,7020,7200,7380,7560,7740,7920,8100
%N A066164 Sum of interior angles in an n-sided polygon in degrees.
%H A066164 Harry J. Smith, <a href="/A066164/b066164.txt">Table of n, a(n) for n = 3..1000</a>
%H A066164 Tanya Khovanova, <a href="https://www.tanyakhovanova.com/RecursiveSequences/RecursiveSequences.html">Recursive Sequences</a>.
%H A066164 <a href="/index/Rec#order_02">Index entries for linear recurrences with constant coefficients</a>, signature (2,-1).
%F A066164 a(n) = (n-2)*180.
%F A066164 From _Elmo R. Oliveira_, Apr 17 2026: (Start)
%F A066164 G.f.: 180*x^3/(1 - x)^2.
%F A066164 E.g.f.: 180*((x - 2)*exp(x) + x + 2).
%F A066164 a(n) = 180*A000027(n-2) = 18*A008592(n-2).
%F A066164 a(n) = 2*a(n-1) - a(n-2) for n > 4. (End)
%e A066164 a(3) = 180, since the sum of the interior angles in a triangle is 180 degrees.
%t A066164 180 Range[36] (* _Alonso del Arte_, Sep 22 2017 *)
%t A066164 (* Alternative: *)
%t A066164 LinearRecurrence[{2,-1},{180,360},50] (* _Harvey P. Dale_, Apr 06 2022 *)
%o A066164 (PARI) a(n) = { (n - 2)*180 } \\ _Harry J. Smith_, Feb 03 2010
%Y A066164 Cf. A000027, A008592.
%K A066164 nonn,easy,changed
%O A066164 3,1
%A A066164 Ulrich Schimke (ulrschimke(AT)aol.com), Dec 12 2001
