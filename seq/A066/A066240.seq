%I A066240 #26 Jul 14 2026 00:25:25
%S A066240 1,18,20,70,104,464,1952,45356,91388,130304,254012,388076,437745,
%T A066240 522752,8382464,134193152,6800228816,11097907192,12985220152,
%U A066240 109170719992,279632332792,549754241024,1471763808896,1511712719992,8796086730752,19502341651712,32412520979992,118123076415296
%N A066240 floor(x/2)-perfect numbers, where f-perfect numbers for an arithmetical function f are defined in A066218.
%C A066240 The odd terms are shared with A066230. For k in A050414, 2^(k-1)*(2^k - 3) is a term, which is shared with A045768 and A088831. - _Max Alekseyev_, Jun 21 2026
%H A066240 Max Alekseyev, <a href="/A066240/b066240.txt">Table of n, a(n) for n = 1..43</a>
%H A066240 Joseph L. Pe, <a href="https://vixra.org/abs/2503.0165">On a Generalization of Perfect Numbers</a>, J. Rec. Math. 31:3 (2002), 168-172.
%e A066240 Let f(x) = floor(x/2). Then f(18) = 9 = 4+3+1+1+0 = f(9)+f(6)+f(3)+f(2)+f(1); so 18 is a term of the sequence.
%t A066240 f[x_] := Floor[x/2]; Select[ Range[ 1, 10^5], 2 * f[ # ] == Apply[ Plus, Map[ f, Divisors[ # ] ] ] & ]
%Y A066240 Cf. A045768, A050414, A066218, A066230, A066238, A066239, A088831.
%K A066240 nonn,changed
%O A066240 1,2
%A A066240 _Joseph L. Pe_, Dec 19 2001
%E A066240 a(8)-a(16) from _Amiram Eldar_, Sep 26 2019
%E A066240 a(1)=1 prepended and a(17) onward added by _Max Alekseyev_, Jul 13 2026
