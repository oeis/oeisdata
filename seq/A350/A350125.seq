%I A350125 #27 May 22 2026 01:02:25
%S A350125 1,8,40,345,3303,50225,833569,17045934,388654659,10039636255,
%T A350125 285508661853,8924967326015,302927979357701,11114722212099135,
%U A350125 437913155876193839,18447871416712820782,827249276230172525622,39347009369000530723017
%N A350125 a(n) = Sum_{k=1..n} k^2 * floor(n/k)^n.
%H A350125 Seiichi Manyama, <a href="/A350125/b350125.txt">Table of n, a(n) for n = 1..386</a>
%F A350125 a(n) = Sum_{k=1..n} k^2 * Sum_{d|k} (d^n - (d - 1)^n)/d^2.
%F A350125 a(n) = [x^n] (1/(1 - x)) * Sum_{k>=1} (k^n - (k - 1)^n) * x^k * (1 + x^k)/(1 - x^k)^3.
%F A350125 a(n) ~ n^n. - _Vaclav Kotesovec_, Dec 16 2021
%t A350125 a[n_] := Sum[k^2 * Floor[n/k]^n, {k, 1, n}]; Array[a, 18] (* _Amiram Eldar_, Oct 04 2023 *)
%o A350125 (PARI) a(n) = sum(k=1, n, k^2*(n\k)^n);
%o A350125 (PARI) a(n) = sum(k=1, n, k^2*sumdiv(k, d, (d^n-(d-1)^n)/d^2));
%o A350125 (Python)
%o A350125 def A350125(n):
%o A350125     c, j, v = 0, 1, 0
%o A350125     while j <= n:
%o A350125         k = n//j
%o A350125         m = n//k
%o A350125         c += k**n*(-v+(v:=m*(m+1)*(2*m+1)))
%o A350125         j = m+1
%o A350125     return c//6 # _Chai Wah Wu_, May 21 2026
%Y A350125 Cf. A332469, A350109, A350123, A350124, A350128.
%K A350125 nonn,changed
