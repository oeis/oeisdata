%U A212655 1099047771308032,68719476736,123969936031744,330952999960576,101155069755392,826832744087552,108860447242846208,3096224743817216
%N A212655 Denominator of Bernoulli(2*n,1/2) / Period of length 2: repeat 12, 60.
%C A212655 See A165949(n) = (A027642(n+1)=A027762(n))/A165734(n).
%C A212655 a(n) is divisible by 4^(n-1).
%H A212655 Paolo Xausa, <a href="/A212655/b212655.txt">Table of n, a(n) for n = 1..1000</a>
%F A212655 a(n) = A033469(n)/A040874(n).
%F A212655 a(n) = 4^(n-1) * A165949(n).
%e A212655 a(1) = (B(2,1/2)=12)/12=1, a(2)=240/60=4, a(3)=1344/12=112, a(4)=3840/60=64.
%t A212655 A212655[n_] := Denominator[BernoulliB[2*n, 1/2]]/If[OddQ[n], 12, 60];
%t A212655 Array[A212655, 25] (* _Paolo Xausa_, May 25 2026 *)
%o A212655 (PARI) a(n) = my(x=denominator(bernpol(2*n, 1/2))); if (n%2, x/12, x/60); \\ _Michel Marcus_, May 25 2026
%Y A212655 Cf. A000302, A027642, A027762, A033469, A040874, A165734, A165949.
