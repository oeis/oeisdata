%T A173835 10000000020,100000000022,1000000000024,10000000000026,
%U A173835 100000000000028,1000000000000030,10000000000000032,100000000000000034,1000000000000000036,10000000000000000038,100000000000000000040
%N A173835 a(n) = 10^n + 2*n.
%H A173835 Vincenzo Librandi, <a href="/A173835/b173835.txt">Table of n, a(n) for n = 0..100</a>
%H A173835 <a href="/index/Rec#order_03">Index entries for linear recurrences with constant coefficients</a>, signature (12,-21,10).
%F A173835 From _Vincenzo Librandi_, Jul 06 2012: (Start)
%F A173835 G.f.: (1-19*x^2)/((1-x)^2*(1-10*x)).
%F A173835 a(n) = 11*a(n-1) - 10*a(n-2) - 18. (End)
%F A173835 From _Elmo R. Oliveira_, Jul 22 2026: (Start)
%F A173835 E.g.f.: exp(10*x) + 2*x*exp(x).
%F A173835 a(n) = A011557(n) + A005843(n).
%F A173835 a(n) = 12*a(n-1) - 21*a(n-2) + 10*a(n-3). (End)
%t A173835 CoefficientList[Series[(1-19*x^2)/((1-x)^2*(1-10*x)),{x,0,40}],x] (* _Vincenzo Librandi_, Jul 06 2012 *)
%t A173835 (* Alternative: *)
%t A173835 LinearRecurrence[{12,-21,10},{1,12,104},20] (* _Harvey P. Dale_, Dec 01 2015 *)
%o A173835 (Magma) I:=[1, 12]; [n le 2 select I[n] else 11*Self(n-1)-10*Self(n-2)-18: n in [1..20]]; // _Vincenzo Librandi_, Jul 06 2012
%Y A173835 Cf. A005843, A011557.
