%N A173022 Number of numbers <= n whose binary representation is without isolated ones.
%H A173022 Reinhard Zumkeller, <a href="/A173022/b173022.txt">Table of n, a(n) for n = 0..10000</a>
%F A173022 a(A144795(n+1)) = a(A144795(n)) + 1.
%F A173022 a(2^n - 1) = A005251(n+2).
%F A173022 A173021(n) <= a(n) <= A173023(n).
%e A173022 a(20) = #{0,3,6,7,12,14,15} = #{0,11,110,111,1100,1110,1111} = 7.
%t A173022 Accumulate[Array[Boole[FreeQ[Split[IntegerDigits[#, 2]], {1}]] &, 100, 0]] (* _Paolo Xausa_, Oct 15 2024 *)
%o A173022 (Python)
%o A173022 from sympy import Matrix
%o A173022 def A173022(n):
%o A173022     s = bin(n)[-1:1:-1]
%o A173022     t = '0'+s+'0'
%o A173022     return sum((Matrix([[2,-1,1],[1,0,0],[0,1,0]])**i*Matrix([1,1,0]))[0] for i in range(len(s)) if s[i]=='1' and not '010' in '0'+t[i+2:])+('010' not in t) # _Chai Wah Wu_, Jun 10 2026
%Y A173022 Cf. A005251, A007088, A144795, A173021, A173023.
%K A173022 base,nonn,changed
%O A173022 0,4
