%I A173448 #14 May 20 2026 01:11:33
%S A173448 13,151,353,139,101,70451,97,15193,3821,9319,7717,103619,10883,18353,
%T A173448 108821,701,10091,99251,78497,3559,930043,99787,18671,12251,711751,
%U A173448 9293,10861,121921,103099,986189,74287,796567,323003,108707,365779,192377,393901,380251,98479,114343,329729
%N A173448 Smallest prime(k) such that the concatenation prime(k)//prime(k+1)//...//prime(k+n-1) represents an emirp.
%H A173448 Robert Israel, <a href="/A173448/b173448.txt">Table of n, a(n) for n = 1..125</a>
%e A173448 a(5) = 101 because 101103107109113 = A086041(6) is the smallest emirp formed by concatenating 5 consecutive primes (101, 103, 107, 109, 113).
%p A173448 f:= proc(n) local L,p,a,i,d,flag,x,y;
%p A173448       L:= [seq(ithprime(i),i=1..n)];
%p A173448       do
%p A173448         d:= ilog10(L[2]);
%p A173448         a:= floor(L[2]/10^d);
%p A173448         flag:= true;
%p A173448         if member(a,{2,6,8}) then p:= nextprime((a+1)*10^d)
%p A173448         elif member(a,{4,5}) then p:= nextprime(7*10^d)
%p A173448         else flag:= false
%p A173448         fi;
%p A173448         if flag then
%p A173448            L:= p; for i from 1 to n-1 do p:= nextprime(p); L:= L,p od;
%p A173448            L:= [L]
%p A173448         else
%p A173448           L:= [op(L[2..-1]),nextprime(L[-1])]
%p A173448         fi;
%p A173448         x:= lcat(L);
%p A173448         if isprime(x) then
%p A173448           y:= rev(x);
%p A173448           if isprime(y) and y <> x then return L[1] fi;
%p A173448         fi
%p A173448      od
%p A173448 end proc:
%p A173448 f(1):= 13:
%p A173448 map(f, [$1..50]); # _Robert Israel_, May 19 2026
%Y A173448 Cf. A006567, A167518, A030996.
%K A173448 nonn,base,changed
%O A173448 1,1
