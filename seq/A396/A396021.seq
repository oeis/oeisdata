%U A396021 2701,3272,3064,3544,3509,3709,4145,4068,4398,4793,4459,5082,5278,5693,6105,6451,6424,6298,6725,5777,6767
%N A396021 Sum of the distinct prime divisors of C(10*n, n).
%H A396021 Vincenzo Librandi, <a href="/A396021/b396021.txt">Table of n, a(n) for n = 1..1000</a>
%F A396021 a(n) = sopf(binomial(10*n,n)) = A008472(A169959(n)).
%e A396021 a(2) = 26 because binomial(20,2) = 190 = 2*5*19 and 2+5+19 = 26.
%e A396021 a(3) = 43 because binomial(30,3) = 4060 = 2^2*5*7*29 and 2+5+7+29 = 43.
%t A396021 a[n_]:=Total[FactorInteger[Binomial[10*n,n]][[All,1]]]; Table[a[n],{n,1,60}]
%o A396021 (Magma) a := func<n | &+PrimeDivisors(Binomial(10*n, n))>; N := 60; [a(n) : n in [1..N]];
%o A396021 (Python)
%o A396021 from collections import Counter
%o A396021 from sympy import factorint
%o A396021 def A396021(n):
%o A396021     c = Counter()
%o A396021     for i in range(9*n+1,10*n+1):
%o A396021         c += factorint(i)
%o A396021     for i in range(2,n+1):
%o A396021         c -= factorint(i)
%o A396021     return sum(c) # _Chai Wah Wu_, May 22 2026
%Y A396021 Cf. A008472, A034387, A169959, A394454, A394591, A394592, A394593, A395515, A395566, A395503, A396020.
