%e A396409 67 follows the path 67->75->91->123->59->27->11->3, so has distance 7 from the stem.
%e A396409 326730_10 = 1001111110001001010_2, whose run-length sequences are o = 1,6,1,1,1 and z = 2,3,2,1,1 with O = 1,7,8,9,10, so a(326730) = Sum_i 2*O_i*z_i-o_i = 2*1*2-1 + 2*7*3-6 + 2*8*2-1 + 2*9*1-1 + 2*10*1-1 = 106.
%t A396409 A396409[n_] := A396409[n] = Which[n == 0, 0, OddQ[n], A396409[Quotient[n, 2]], True, A396409[n/2] + 2*DigitSum[n/2, 2] - IntegerExponent[n/2 + 1, 2]];
%t A396409 Array[A396409, 100, 0] (* _Paolo Xausa_, Jun 03 2026 *)
%o A396409 (Python) #demonstration of sequence definition
%o A396409 Y=lambda f: (lambda g: g(g))(lambda x: f(lambda *a: x(x)(*a))) #Y combinator
%o A396409 A396409=Y(lambda f: lambda t: lambda x: f(t+1)(x^1<<x.bit_count()) if x&x+1 else t)(0)
%o A396409 (Python)
%o A396409 from itertools import groupby
%o A396409 trailing1s=lambda n: (~(n+1)&n).bit_length()
%o A396409 def A396409(n): # iterates over runs
%o A396409     bits=bin(n>>trailing1s(n))[2:]
%o A396409     onesSeen=0
%o A396409     steps=0
%o A396409     for val, grp in groupby(bits):
%o A396409         l = sum(1 for b in grp)
%o A396409         if val=='1': onesSeen += l
%o A396409         steps += l*(2*onesSeen if val=='0' else -1)
%o A396409     return steps
%o A396409 (Python) # alternative:
%o A396409 trailing1s=lambda n: (~(n+1)&n).bit_length()
%o A396409 A396409=lambda n: n and A396409(n>>1)+(~n&1 and (n.bit_count()*2-trailing1s(n>>1)))
%Y A396409 Cf. A000120, A007814, A326730.
