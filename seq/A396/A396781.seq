%U A396781 144209936106499234037676064081,34182189187166852111368841966125056,972786042517719014174576083150881262357,500026926136478545004035990584179037499817984
%N A396781 a(n) is the largest integer of the form r^k (with 0 < r < n and k > 0) whose base-n digital root is r, and whose number of digits in base-n is k.
%e A396781 a(2) = 1: the only solution is 1 (base 2: "1", r=1, k=1).
%e A396781 a(3) = 4: the solutions are 1, 2, and 4. The maximum is 4 (base 3: "11", r=2, k=2).
%e A396781 a(4) = 81: the solutions are 1, 2, 3, 9, 27, and 81. The maximum is 81 (base 4: "1101", r=3, k=4).
%e A396781 a(10) = 109418989131512359209: this is the maximum value found in base 10, corresponding to 9^21.
%o A396781 (Python)
%o A396781 import numpy as np
%o A396781 def f(n, b):
%o A396781     if n == 0: return 1
%o A396781     d = []
%o A396781     t = abs(n)
%o A396781     while t > 0:
%o A396781         d.append(t % b)
%o A396781         t //= b
%o A396781     return len(d)
%o A396781 def r(n, b):
%o A396781     if n == 0: return 0
%o A396781     return 1 + ((n - 1) % (b - 1))
%o A396781 def s(m=19):
%o A396781     o = []
%o A396781     for b in range(2, m + 1):
%o A396781         v = [1]
%o A396781         for i in range(2, b):
%o A396781             k_max = int(np.floor(1 / (1 - (np.log(i) / np.log(b)))))
%o A396781             for k in range(1, k_max + 1):
%o A396781                 n = int(i**k)
%o A396781                 if f(n, b) == k and r(n, b) == i:
%o A396781                     v.append(n)
%o A396781         o.append(str(max(v)))
%o A396781     print(", ".join(o))
%o A396781 s(19)
%Y A396781 Cf. A394570.
%K A396781 nonn,base,new
