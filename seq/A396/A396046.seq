%T A396046 149,150,158,160,169,178,187,190,197,206,215,221,225,226,235,244,253,
%U A396046 254,255,264,273,282,286,292,295,302,303,312,319,322,331,340,349,351
%N A396046 Numbers not of the form Sum_{k=1..m} floor(m/k^3).
%C A396046 Complement of A013937.
%H A396046 Chai Wah Wu, <a href="/A396046/b396046.txt">Table of n, a(n) for n = 1..10000</a>
%o A396046 (Python)
%o A396046 # uses Python function from A013937
%o A396046 from itertools import count, islice
%o A396046 def A396046_gen(): # generator of terms
%o A396046     c = 0
%o A396046     for i in count(0):
%o A396046         if (m:=A013937(i))!=i+c:
%o A396046             for j in range(i+c,m):
%o A396046                 yield j
%o A396046             c = m-i
%o A396046 A396046_list = list(islice(A396046_gen(),30))
%Y A396046 Cf. A013937.
%K A396046 nonn,new
%O A396046 1,1
