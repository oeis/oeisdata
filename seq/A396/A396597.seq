%I A396597 #35 Jun 07 2026 21:52:49
%S A396597 6,10,14,15,18,20,21,22,26,28,33,34,35,38,39,44,46,50,51,52,54,55,57,
%T A396597 58,62,65,68,69,74,75,76,77,82,85,86,87,88,91,92,93,94,95,98,99,100,
%U A396597 104,106,111,115,116,117,118,119,122,123,124,129,133,134,136,141,142
%N A396597 Numbers m with exactly two distinct prime factors q and p such that m = q^k * p^j and p > q^k with k, j >= 1.
%H A396597 James C. McMahon, <a href="/A396597/b396597.txt">Table of n, a(n) for n = 1..10000</a>
%e A396597 6 is included because its prime factors are 2,3 and 3 > 2.
%e A396597 92 is included because its prime factors are 2^2,23 and 23>2^2.
%e A396597 90 is not included because it has more than two distinct prime factors.
%e A396597 89 is not included because it has one prime factor (it is prime).
%e A396597 80 is not included because its prime factors are 2^4,5 and 5<2^4.
%t A396597 Select[Range[200], Length[f = FactorInteger[#]] == 2 && f[[2, 1]] > f[[1, 1]]^f[[1, 2]] &]
%o A396597 (Python)
%o A396597 from sympy import factorint
%o A396597 def ok(n):
%o A396597     factors = factorint(n)
%o A396597     if len(factors) != 2:
%o A396597         return False
%o A396597     p1, p2 = factors.keys()
%o A396597     pow1 = p1**factors[p1]
%o A396597     pow2 = p2**factors[p2]
%o A396597     return p2 > pow1 or p1 > pow2
%o A396597 print([m for m in range(1, 201) if ok(m)])
%Y A396597 Cf. A001358, A007774.
%K A396597 nonn,easy
%O A396597 1,1
