%T A396634 19164387060,174967592800,2869140960000,40133087723520,
%U A396634 3127024106264448,25223565722485248,2258240991512506000,26872163225600000000,740669714070800518620,12628324344759874304400
%N A396634 Number of distinct spanning trees of the coprime graph on vertices {1, 2, ..., n}.
%C A396634 The coprime graph G_n has vertices V = {1, 2, ..., n}. An undirected edge connects vertex u and v iff gcd(u, v) = 1. This sequence gives the number of distinct spanning trees of G_n, which, by Kirchhoff's Matrix Tree Theorem, is equivalent to any principal minor of the Laplacian matrix of G_n.
%H A396634 Wikipedia, <a href="https://en.wikipedia.org/wiki/Kirchhoff%27s_theorem">Kirchhoff's theorem</a>.
%e A396634 For n = 4, the vertices are {1, 2, 3, 4}. The valid edges are (1,2), (1,3), (1,4), (2,3), and (3,4). A spanning tree requires exactly 3 edges connecting all 4 vertices without cycles.
%e A396634 The 8 valid spanning trees are:
%e A396634   {(1,2), (1,3), (1,4)}
%e A396634   {(1,2), (1,3), (3,4)}
%e A396634   {(1,2), (1,4), (2,3)}
%e A396634   {(1,2), (1,4), (3,4)}
%e A396634   {(1,2), (2,3), (3,4)}
%e A396634   {(1,3), (1,4), (2,3)}
%e A396634   {(1,3), (2,3), (3,4)}
%e A396634   {(1,4), (2,3), (3,4)}
%e A396634 Therefore, a(4) = 8.
%t A396634 a[n_] := If[n == 1, 1, Det[Drop[DiagonalMatrix[Total[#]] - # &@ Table[Boole[i != j && CoprimeQ[i, j]], {i, n}, {j, n}], 1, 1]]];
%t A396634 Table[a[n], {n, 1, 22}]
%Y A396634 Cf. A000272, A005326, A009679.
%K A396634 nonn,new
%O A396634 1,3
