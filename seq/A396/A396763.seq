%H A396763 Hoang Nguyen, <a href="/A396763/b396763.txt">Table of n, a(n) for n = 1..10000</a>
%e A396763 6's aliquot divisors are 1, 2, and 3; their average is 2, an integer. Its divisors are 1, 2, 3, 6; their average is 3, also an integer.
%e A396763 30's aliquot divisors are 1, 2, 3, 5, 6, 10, 15; their average is 6, an integer. Its divisors are 1, 2, 3, 5, 6, 10, 15, and 30; their average is 9, also an integer.
%t A396763 q[k_] := Module[{d, s}, {d, s} = DivisorSigma[{0, 1}, k]; Divisible[s, d] && Divisible[s - k, d - 1]]; Select[Range[2, 200], q] (* _Amiram Eldar_, Jun 05 2026 *)
%o A396763 (Julia)
%o A396763 using Primes
%o A396763 function a(n)
%o A396763     num = 1
%o A396763     count = 0
%o A396763     while count < n
%o A396763         num += 1
%o A396763         list = divisors(num)
%o A396763         if sum(list) % length(list) == 0
%o A396763             pop!(list)
%o A396763             if sum(list) % length(list) == 0
%o A396763                 print("$num, ")
%o A396763                 count += 1
%o A396763             end
%o A396763         end
%o A396763     end
%o A396763 end
