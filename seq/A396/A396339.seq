%S A396339 1,1,1,1,5,27,117,977,7453,69167,574247,6717291,82601549,1079371121,
%T A396339 15313891593,208144354023,3379306725567,58183510570455,
%U A396339 1069781791027317,20224951014161981,405096149905237817,7980052217156236251,178086665671701480131,4098746917093640018307
%N A396339 Number of permutations p of [n] whose prefix sums Sum_{i=1..k} p(i) avoid triangular numbers for 1 <= k < n.
%C A396339 The largest prefix sum is always a triangular number: s(n) = A000217(n).
%H A396339 Wikipedia, <a href="https://en.wikipedia.org/wiki/Permutation">Permutation</a>
%e A396339 a(0) = 1: the empty permutation.
%e A396339 a(1) = 1: 1.
%e A396339 a(2) = 1: 21.
%e A396339 a(3) = 1: 231.
%e A396339 a(4) = 5: 2341, 4123, 4132, 4312, 4321.
%e A396339 a(5) = 27: 23451, 25134, 25143, 25413, 25431, 41253, 41352, 43152, 43251, 43512, 43521, 45213, 45231, 45312, 45321, 52134, 52143, 52413, 52431, 53124, 53142, 53412, 53421, 54213, 54231, 54312, 54321.
%e A396339 a(6) = 117: 234561, 236145, 236154, 236514, ..., 563214, 563241, 563412, 563421.
%p A396339 q:= proc(n) option remember; issqr(8*n+1) end:
%p A396339 b:= proc(s, p) option remember; (n-> `if`(n=0, 1, add(
%p A396339       `if`(n>1 and q(p+j), 0, b(s minus {j}, p+j)), j=s)))(nops(s))
%p A396339     end:
%p A396339 a:= n-> b({$1..n}, 0):
%p A396339 seq(a(n), n=0..17);
%Y A396339 Cf. A000217, A395652.
%K A396339 nonn
%O A396339 0,5
%A A396339 _Alois P. Heinz_, May 22 2026
