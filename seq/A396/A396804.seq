%I A396804 #15 Jun 09 2026 14:35:44
%S A396804 1,2,27,820,41005,2933046,277407235,33008920904,4775699432745,
%T A396804 819537205428010,163708079071865911,37510927241086166220,
%U A396804 9743252939007037322509,2841190409374953654166526,922635217730641257310962075,331365807244074316193652673936,130847111194991759214337098786385
%N A396804 E.g.f. satisfies A(x) = x*exp( A^4(x) ).
%C A396804 Conjecture: a(n) is odd iff n is odd for n >= 1.
%C A396804 Conjecture: a(n) == [1,2,0] repeating (mod 3) for n >= 1.
%C A396804 Conjecture: a(n) == [1,2,3,0] repeating (mod 4) for n >= 1.
%C A396804 Conjecture: a(n) (mod 5) is never congruent to 3.
%H A396804 Paul D. Hanna, <a href="/A396804/b396804.txt">Table of n, a(n) for n = 1..201</a>
%F A396804 E.g.f. A(x) = Sum_{n>=1} a(n)*x^n/n! satisfies the following formulas, in which A^n(x) denotes the n-th iteration of A(x).
%F A396804 (1.a) A^(-1)(x) = x * exp( -A^3(x) ).
%F A396804 (1.b) A(x) = x * exp( A^4(x) ).
%F A396804 (1.c) A^2(x) = A(x) * exp( A^5(x) ).
%F A396804 (1.d) A^3(x) = A^2(x) * exp( A^6(x) ).
%F A396804 (1.e) A^n(x) = A^(n-1)(x) * exp( A^(n+3)(x) ) for all n.
%F A396804 (2.a) A(x) = x * exp( A^3(x) * exp( A^6(x) * exp( A^9(x) * ... * exp( A^(3*n)(x) * exp( ... ))))), an infinite power tower.
%F A396804 (2.b) A^2(x) = A(x) * exp( A^4(x) * exp( A^7(x) * exp( A^10(x) * ... * exp( A^(3*n+1)(x) * exp( ... ))))), an infinite power tower.
%F A396804 (2.c) A^3(x) = A^2(x) * exp( A^5(x) * exp( A^8(x) * exp( A^11(x) * ... * exp( A^(3*n+2)(x) * exp( ... ))))), an infinite power tower.
%F A396804 (3.a) A^2(x) = x * exp(A^4(x) + A^5(x)).
%F A396804 (3.b) A^3(x) = x * exp(A^4(x) + A^5(x) + A^6(x)).
%F A396804 (3.c) A^n(x) = x * exp( Sum_{k=4..n+3} A^k(x) ) for n >= 1.
%F A396804 (3.d) A^n(x) = A^m(x) * exp( Sum_{k=m+4..n+3} A^k(x) ) for n >= m+1.
%F A396804 (4.a) A(x) = A^2(x) / exp(A^5(x)).
%F A396804 (4.b) A(x) = A^3(x) / exp(A^5(x) + A^6(x)).
%F A396804 (4.c) A(x) = A^4(x) / exp(A^5(x) + A^6(x) + A^7(x)).
%F A396804 (4.d) A(x) = A^n(x) / exp( Sum_{k=5..n+3} A^k(x) ) for n >= 2.
%F A396804 (5.a) A^4(x) = log( A(x)/x ).
%F A396804 (5.b) A^5(x) = log( A^2(x)/A(x) ).
%F A396804 (5.c) A^6(x) = log( A^3(x)/A^2(x) ).
%F A396804 (5.d) A^n(x) = log( A^(n-3)(x) / A^(n-4)(x) ) for all n.
%F A396804 From _Seiichi Manyama_, Jun 09 2026: (Start)
%F A396804 E.g.f. A(x) satisfies A(x) = x*exp(A^l(x)), where A^l(x) denotes the l-th iterate of A.
%F A396804 Let a(n,k,l) = n! * [x^n] A^k(x), where A^k(x) is the k-th iterate of A.
%F A396804 a(1,k,l) = 1; a(n,k,l) = (1/(n-1)) * Sum_{i=1..n-1} i * binomial(n,i) * a(n-i,k,l) * Sum_{j=1..k} a(i,j+l-1,l). (End)
%e A396804 E.g.f.: A(x) = x + 2*x^2/2! + 27*x^3/3! + 820*x^4/4! + 41005*x^5/5! + 2933046*x^6/6! + 277407235*x^7/7! + 33008920904*x^8/8! + ...
%e A396804 where A(x) = x * exp( A^4(x) ).
%e A396804 RELATED SERIES.
%e A396804 The series reversion of A(x) begins
%e A396804 A^(-1)(x) = x - 2*x^2/2! - 15*x^3/3! - 400*x^4/4! - 18775*x^5/5! - 1291056*x^6/6! - 118711019*x^7/7! + ...
%e A396804 where A^(-1)(x) = x * exp( -A^3(x) ).
%e A396804 The second iteration of A(x) begins
%e A396804 A^2(x) = x + 4*x^2/2! + 66*x^3/3! + 2204*x^4/4! + 116600*x^5/5! + 8665302*x^6/6! + 843135916*x^7/7! + ...
%e A396804 where A^2(x) = x * exp(A^4(x) + A^5(x)).
%e A396804 The third iteration of A(x) begins
%e A396804 A^3(x) = x + 6*x^2/2! + 117*x^3/3! + 4296*x^4/4! + 242025*x^5/5! + 18828468*x^6/6! + 1898172633*x^7/7! + ...
%e A396804 where A^3(x) = x * exp(A^4(x) + A^5(x) + A^6(x)).
%e A396804 The fourth iteration of A(x) begins
%e A396804 A^4(x) = x + 8*x^2/2! + 180*x^3/3! + 7240*x^4/4! + 435400*x^5/5! + 35615124*x^6/6! + 3738724696*x^7/7! + ...
%e A396804 where A^4(x) = log( A(x)/x ).
%o A396804 (PARI) \\ from A(x) = x * exp( A^4(x) ).
%o A396804 {a(n) = my(A=x,B); for(k=1, n, A = truncate(A) + x*O(x^k); B = subst(A,x,A);
%o A396804 A = x * exp( subst(B,x,B) ) +x*O(x^n); ); EGF=A; n!*polcoef(A, n)}
%o A396804 {upto(n) = a(n); Vec(serlaplace(EGF))}
%o A396804 upto(25)
%Y A396804 Cf. A000169, A396799, A396800, A000169, A140054, A396803, A396805, A396806.
%K A396804 nonn
%O A396804 1,2
