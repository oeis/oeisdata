%T A396072 73,76,79,82,87,91,93,94,95,100,105,106,107,111,113,118,119,121,122,
%U A396072 126,131,134,137,142,143,146,148,150,151,152,157,162,163,164,169,170
%N A396072 Numbers not of the form Sum_{k=1..m} floor(m/k^2).
%C A396072 Complement of A013936.
%H A396072 Chai Wah Wu, <a href="/A396072/b396072.txt">Table of n, a(n) for n = 1..10000</a>
%t A396072 Complement[Range[Last[#]], #] &@ Table[Sum[Floor[n/k^2], {k, n}], {n, 120}] (* _Michael De Vlieger_, May 16 2026 *)
%o A396072 (Python)
%o A396072 from itertools import count, islice
%o A396072 # uses Python function in A013936
%o A396072 def A396072_gen(): # generator of terms
%o A396072     c = 0
%o A396072     for i in count(0):
%o A396072         if (m:=A013936(i))!=i+c:
%o A396072             for j in range(i+c,m):
%o A396072                 yield j
%o A396072             c = m-i
%o A396072 A396072_list = list(islice(A396072_gen(),60))
%Y A396072 Cf. A013936, A396046, A396056.
%K A396072 nonn,new
%O A396072 1,1
%A A396072 _Chai Wah Wu_, May 15 2026
