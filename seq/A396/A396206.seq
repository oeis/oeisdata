%N A396206 a(1) = 1; for n > 1, a(n) is the smallest number > 3^(n-1) with exactly n divisors.
%F A396206 a(p) = 5^(p-1) for p prime. - _Michael S. Branicky_, May 24 2026
%e A396206 a(2) = 5 because it is the smallest number > 3^(2-1) with exactly 2 divisors;
%e A396206 a(3) = 25 because it is the smallest number > 3^(3-1) with exactly 3 divisors;
%e A396206 a(4) = 33 because it is the smallest number > 3^(4-1) with exactly 4 divisors.
%t A396206 a[n_]:=Module[{k=3^(n-1)},If[PrimeQ[n],5^(n-1),Until[DivisorSigma[0,k]==n,k++];k]];a[1]=1;Array[a,19] (* _James C. McMahon_, May 29 2026 *)
%o A396206 (PARI) a(n) = if(n<=1, return(1)); if(isprime(n), return(5^(n-1))); for(k=3^(n-1)+1, oo, if(numdiv(k) == n, return(k))); \\ _Daniel Suteu_, Jun 09 2026
%Y A396206 Cf. A000005, A000027, A000040, A000351, A001248, A030514.
