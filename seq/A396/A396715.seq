%S A396715 1,3,2,5,3,8,3,5,4,11,3,17,8,7,3,22,5,30,6,12,11,37,6,16,15,10,7,45,7,
%T A396715 56,9,17,21,19,6,65,27,19,7,76,10,90,12,17,35,104,11,38,14,27,15,118,
%U A396715 12,30,12,33,41,132,10,150,52,24,13,35,14,167,21,42,17
%N A396715 Number of semiprimes m with k <= m <= k^2 such that the largest divisor of k*m that is <= sqrt(k*m) equals k.
%C A396715 The largest divisor of n that is <= sqrt(n) is A033676(n). This sequence is the part of A163926(k) coming from m with bigomega(m) = 2; together with the count for bigomega(m) >= 3 it partitions A163926(k). For prime k it is asymptotic to k^2/(2*log(k)^2).
%e A396715 For k=3: the qualifying m are 4, 6, 9, so a(3)=3.
%t A396715 g[n_]:=Last[Select[Divisors[n],#^2<=n&]]; a[k_]:=Count[Range[k,k^2],m_/;PrimeOmega[m]==2&&g[k*m]==k]; Array[a,69,2]
%o A396715 (PARI) g(n)=my(d=divisors(n)); d[(#d+1)\2];
%o A396715 a(k)=sum(m=k, k^2, bigomega(m)==2 && g(k*m)==k);
%Y A396715 Cf. A033676, A163925, A163926.
%K A396715 nonn,new
%O A396715 2,2
%A A396715 _Eric Fodge_, Jun 03 2026
