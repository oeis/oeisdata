%I A396908 #12 Jul 21 2026 20:03:42
%S A396908 0,0,1,2,3,3,4,4,6,6,7,8,8,9,10,10,12,12,14,14,15,17,17,17,17,19,20,
%T A396908 20,22,23,24,25,25,25,26,26,28,28,30,30,32,32,34,35,35,36,37,38,39,39,
%U A396908 40,40,40,42,43,44,44,46,48,48,50,51,51,51,53,54,55,56,56
%N A396908 Number of decimal places which are known after using n terms of A390946 and treating them as the coefficients of a continued fraction.
%C A396908 The digits produced by the continued fraction are that of A392558.
%C A396908 Let c(n) be the n-th convergent resulting from A390946.
%C A396908 Further continued fraction terms are taken to be unknown and the worst case (maximum absolute difference) is a single additional 1.
%C A396908 a(n) is therefore the length of agreement between c(n) and c(n) appended with a 1.
%H A396908 Jwalin Bhatt, <a href="/A396908/b396908.txt">Table of n, a(n) for n = 0..5227</a>
%H A396908 Wikipedia, <a href="https://en.wikipedia.org/wiki/Lochs%27s_theorem">Lochs's theorem</a>
%F A396908 Conjecture: Limit_{n->oo} n/a(n) = A086819 (Lochs's constant).
%e A396908 For n=6, the continued fraction of 6 terms from A390946 is c(n) = [0; 1,2,2,2,1,1] = 29/41 and the worst case continuation is 46/65,
%e A396908      29/41 = 0.707 31...
%e A396908      46/65 = 0.707 69...
%e A396908              ^ ^^^ a(6) = 4 places agree
%o A396908 (Python)
%o A396908 from sympy import floor, prime, Rational, continued_fraction_iterator, continued_fraction_convergents
%o A396908 from collections import deque
%o A396908 from os.path import commonprefix
%o A396908 def reliable_digits_from_cf(coeffs, prec):
%o A396908     bound1, bound2 = deque(continued_fraction_convergents(coeffs+[1]), maxlen=2)
%o A396908     order = 10**prec
%o A396908     trunc_bound1 = floor(bound1*order) / order
%o A396908     trunc_bound2 = floor(bound2*order) / order
%o A396908     rel_digits = commonprefix([f'{trunc_bound1:.{prec}f}', f'{trunc_bound2:.{prec}f}'])
%o A396908     return len(rel_digits) - 1 if rel_digits else 0
%o A396908 A390946 = [cf for i in range(2, 12) for j in range(1, i) for cf in continued_fraction_iterator(Rational(prime(i), prime(j)))]
%o A396908 A396908 = [reliable_digits_from_cf([0]+A390946[:i], 1+int(i*1.031)) for i in range(len(A390946)+1)]
%Y A396908 Cf. A086819, A390946, A392558, A397150.
%K A396908 nonn,new
%O A396908 0,4
%A A396908 _Jwalin Bhatt_, Jul 16 2026
