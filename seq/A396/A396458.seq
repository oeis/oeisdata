%I A396458 #4 May 31 2026 18:12:58
%S A396458 20,100,864,988,1792,3125,7488,10416,11400,43560
%N A396458 Integers x such that there exist two integers 0<y<=z such that sigma(x)*psi(x)*phi(x)^2 = x^3 + y^3 + z^3.
%C A396458 The numbers x, y and z form a sigma*psi*phi^2-cubic triple.
%e A396458 (20, 21, 43) is such a triple because sigma(20) * psi(20) * phi(20)^2 = 42 * 36 * 8^2 = 20^3 + 21^3 + 43^3.
%o A396458 (PARI) isok(x)=
%o A396458 {
%o A396458   my(d=sigma(x)*dedekindpsi(x)*eulerphi(x)^2-x^3);
%o A396458   for(y=1, sqrtnint(d, 3),
%o A396458     if((t=d-y^3)<y^3, break);
%o A396458     if(ispower(t, 3), return(1))
%o A396458   );
%o A396458   0
%o A396458 }
%Y A396458 Cf. A000010, A000203, A001615, A003072, A385325, A391290, A395007, A396309, A396407.
%K A396458 nonn,hard,more
%O A396458 1,1
%A A396458 _S. I. Dimitrov_, May 26 2026
