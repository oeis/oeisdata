%S A396571 12,18,23,26,30,34,37,42,47,50,53,56,60,64,67,72,76,79,83,86,89,92,94,
%T A396571 97,102,108,113,116,118,120,122,124,127,131,134,138,142,144,146,150,
%U A396571 154,157,160,163,167,170,173,176,180,184,186,188,192,198,202,204,206,208,211,214,216,218
%N A396571 Averages of adjacent odd composite numbers.
%C A396571 The gaps between adjacent odd composites are only 2, 4, or 6. This sequence records the midpoints of all such gaps.
%C A396571 All odd terms are prime and belong to A007510. - _Michel Marcus_, Jul 12 2026
%H A396571 James C. McMahon, <a href="/A396571/b396571.txt">Table of n, a(n) for n = 1..10000</a>
%F A396571 a(n) = (A071904(n) + A071904(n+1))/2.
%e A396571 The odd composite numbers start: 9, 15, 21 ,...
%e A396571 Taking the average of each adjacent pair gives:
%e A396571   (9+15)/2 = 12,
%e A396571   (15+21)/2 = 18,
%e A396571   (21+25)/2 = 23,
%e A396571 Thus the sequence begins: 12, 18, 23, ...
%p A396571 # Generate sequence of averages of adjacent odd composites
%p A396571 GenSeq := proc(n)
%p A396571     local comps, avgs, i, N, L;
%p A396571     N := 10;
%p A396571     L := [];
%p A396571     while nops(L) < n do
%p A396571         comps := select(x -> x::odd and not isprime(x), [seq(1..N, 2)]);
%p A396571         if nops(comps) < 2 then
%p A396571             N := N * 2;
%p A396571             next;
%p A396571         fi;
%p A396571         avgs := [seq((comps[i] + comps[i+1]) / 2, i = 1 .. nops(comps)-1)];
%p A396571         L := sort(convert({op(avgs)}, list));
%p A396571         if nops(L) < n then
%p A396571             N := N * 2;
%p A396571         else
%p A396571             break;
%p A396571         fi;
%p A396571     od;
%p A396571     return L[1..n];
%p A396571 end proc:
%p A396571 # Example: first 100 terms
%p A396571 seq100 := GenSeq(100);
%p A396571 print(seq100);
%t A396571 MovingAverage[Select[Range[9,220,2],!PrimeQ[#]&],2] (* _James C. McMahon_, Jul 12 2026 *)
%o A396571 (PARI) a396571(upto) = my(c1=9); forcomposite(c2=10, upto, if(c2%2, print1((c1+c2)/2,", "); c1=c2)) \\ _Hugo Pfoertner_, Jul 11 2026
%o A396571 (Python)
%o A396571 from sympy import primepi, isprime
%o A396571 def A396571(n):
%o A396571     if n == 1: return 12
%o A396571     def f(x): return n+primepi(x)+(x>>1)
%o A396571     m, k = n, f(n)
%o A396571     while m != k:
%o A396571         m, k = k, f(k)
%o A396571     m2 = m+2
%o A396571     while isprime(m2):
%o A396571         m2 += 2
%o A396571     return m+m2>>1 # _Chai Wah Wu_, Jul 12 2026
%Y A396571 Cf. A071904, A007510.
%K A396571 nonn,easy,new
%O A396571 1,1
