%S A396470 2,3,7,12,23,29,43,54,77,93,111,139,181,198,241,268,299,319,341,430,
%T A396470 483,550,566,648,686,682,783,858,933,967,1051,1133,1149,1287,1275,
%U A396470 1400,1482,1635,1800,1856,1945,1987,2104,2139,2265,2435,2457,2685,2864,2928,3013,3281,3427,3220
%N A396470 Sum of the distinct prime divisors of C(prime(n), n).
%H A396470 Vincenzo Librandi, <a href="/A396470/b396470.txt">Table of n, a(n) for n = 1..1000</a>
%F A396470 a(n) = A008472(A060604(n)).
%e A396470 a(4) = 12 because binomial(7,4) = 35 = 5*7 and 5+7 = 12.
%e A396470 a(5) = 23 because binomial(11,5) = 462 = 2*3*7*11 and 2+3+7+11 = 23.
%t A396470 a[n_]:=Total[FactorInteger[Binomial[Prime[n],n]][[All,1]]];Table[a[n],{n,1,59}]
%o A396470 (Magma) a := func<n | &+PrimeDivisors(Binomial(NthPrime(n), n))>; N := 59; [a(n) : n in [1..N]];
%o A396470 (Python)
%o A396470 from collections import Counter
%o A396470 from sympy import prime, factorint
%o A396470 def A396470(n):
%o A396470     c, p = Counter(), prime(n)
%o A396470     for i in range(p-n+1,p):
%o A396470         c += factorint(i)
%o A396470     for i in range(2,n+1):
%o A396470         c -= factorint(i)
%o A396470     return sum(c)+p # _Chai Wah Wu_, May 27 2026
%Y A396470 Cf. A008472, A060604.
%K A396470 nonn
%O A396470 1,1
