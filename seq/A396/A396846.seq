%S A396846 1,15,805,75663,10440441,1954144335,474557013645,145167574085535,
%T A396846 54705485777334385,24940495354990708815,13546435008024043179957,
%U A396846 8650320332527108160364975,6419594395521780694929102825,5480898554845038728214683598735,5335669125810777047496719125206045,5876068749510620483756888028384950079
%N A396846 L.g.f. Sum_{n>=1} a(n)*x^n/n = log(1+x + Sum_{n>=2} 4*n/(4*n^2-1) * a(n)*x^n ).
%C A396846 Conjecture: a(n) == 1 (mod 3) iff n is a power of 3, otherwise a(n) is divisible by 3.
%C A396846 Conjecture: a(n) == [1,7,5,7] repeating (mod 8) for n >= 1.
%C A396846 The limit lim_{n->oo} a(n)/(4^n*n!*(n+1)!) appears to be finite and nonzero. At n = 900, a(900)/(4^900*900!*901!) = 0.218484994040...
%H A396846 Paul D. Hanna, <a href="/A396846/b396846.txt">Table of n, a(n) for n = 1..400</a>
%F A396846 L.g.f. L(x) = Sum_{n>=1} a(n)*x^n/n satisfies the following formulas.
%F A396846 (1) L(x) = log(1+x + Sum_{n>=2} 4*n/(4*n^2-1) * a(n)*x^n ).
%F A396846 (2) L(x) equals the logarithm of the g.f. of A397245.
%F A396846 (3) a(n) = (4*n^2-1)/(4*n) * A397245(n) for n > 1 with a(1) = 1.
%e A396846 L.g.f.: L(x) = x + 15*x^2/2 + 805*x^3/3 + 75663*x^4/4 + 10440441*x^5/5 + 1954144335*x^6/6 + 474557013645*x^7/7 + ...
%e A396846 where exponentiation yields the g.f. of A397245
%e A396846 exp(L(x)) = 1 + x + 8*x^2 + 276*x^3 + 19216*x^4 + 2109180*x^5 + 327968280*x^6 + 68141519908*x^7 + ... + 4*n/(4*n^2-1) * a(n)*x^n + ...
%o A396846 (PARI) {a(n) = my(L=[0, 1], A, m); for(i=2, n, L=concat(L, 0); A = exp(Ser(L)); m = #L-1;
%o A396846 L[#L] = (4*m^2-1)*polcoef(A, m) - 4*m^2*polcoef(log(A), m) ); GF=Ser(L); L[n+1]}
%o A396846 \\ returns a vector of terms a(k) for k = 1..n
%o A396846 {upto(n) = a(n); Vec(GF')}
%o A396846 upto(25)
%Y A396846 Cf. A397243, A397244, A397245.
%K A396846 nonn
%O A396846 1,2
%A A396846 _Paul D. Hanna_, Jun 24 2026
