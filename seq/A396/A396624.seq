%U A396624 22740746,41399828,74229365,132342905,241044147,431161540,778051684,1365541232,2454485501
%N A396624 a(n) = r(n,n), where r(1,k)=f(k)=round(k*c), r(n,k)=f(r(n-1,k)), c=sqrt(3).
%C A396624 a(n + 1)/a(n) approaches c erratically.
%t A396624 c = Sqrt[3]; f[k_] := f[k] = Round[c*k];
%t A396624 r[1, k_] := f[k]; r[n_, k_] := r[n, k] = f[r[n - 1, k]];
%t A396624 Table[r[n, n], {n, 1, 100}]
%Y A396624 Cf. A396385, A396622, A396624.
%K A396624 nonn,new
%O A396624 1,1
