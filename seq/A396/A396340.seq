%I A396340 #27 May 28 2026 18:39:30
%S A396340 3,5,7,13,19,31,43,61,73,97,103,109,139,151,181,193,199,229,241,271,
%T A396340 283,313,349,367,397,409,421,433,457,463,487,499,523,571,601,619,643,
%U A396340 661,691,709,727,751,769,811,823,829,859,883,919,937,991,1021,1033,1051
%N A396340 Primes prime(k) such that prime(k) - prime(k-1) is a Fibonacci number.
%C A396340 Fibonacci numbers grow exponentially while the average gap between consecutive primes grows logarithmically, thus this sequence's density decreases as k increases.
%C A396340 It is conjectured that this sequence is infinite as a consequence of the Polignac's conjecture.
%C A396340 Infinite if the Twin Prime conjecture holds. - _Michael S. Branicky_, May 24 2026
%H A396340 Vincenzo Manto, <a href="/A396340/b396340.txt">Table of n, a(n) for n = 1..1000</a>
%e A396340 7 (4th prime) is in the sequence because it follows 5 (3rd prime), and 7 - 5 = 2 in A000045.
%e A396340 61 (18th prime) is in the sequence because it follows 59 (17th prime), and 61 - 59 = 2 is in A000045.
%e A396340 11 (5th prime) is not in the sequence because it follows 7 (4th prime), and 11 - 7 = 4, is not in A000045.
%p A396340 q:= p-> (t-> ormap(issqr, [t-4, t+4]))(5*(p-prevprime(p))^2):
%p A396340 select(isprime and q, [$3..1055])[];  # _Alois P. Heinz_, May 23 2026
%t A396340 With[{p = Prime[Range[177]]}, p[[1 + Position[Differences[p], _?(Or @@ IntegerQ /@ Sqrt[5*#^2 + {-4, 4}] &), 1] // Flatten]]] (* _Amiram Eldar_, May 24 2026 *)
%o A396340 (Python)
%o A396340 from math import isqrt
%o A396340 from sympy import prime
%o A396340 def is_fibonacci(n):
%o A396340     def is_sq(x):
%o A396340         s = isqrt(x)
%o A396340         return s*s == x
%o A396340     return is_sq(5*n*n + 4) or is_sq(5*n*n - 4)
%o A396340 def sequence(n_terms):
%o A396340     results = []
%o A396340     for i in range(2, n_terms + 1):
%o A396340         gap = prime(i) - prime(i-1)
%o A396340         if is_fibonacci(gap):
%o A396340             results.append(prime(i))
%o A396340     return results
%o A396340 print(sequence(150))
%Y A396340 Supersequence of A006512.
%Y A396340 Cf. A000040, A000045, A001223, A014445, A151799.
