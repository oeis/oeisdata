%I A396430 #26 May 30 2026 15:51:44
%S A396430 1,1,0,1,2,0,1,4,9,0,1,6,26,52,0,1,8,51,202,340,0,1,10,84,498,1727,
%T A396430 2394,0,1,12,125,988,5257,15694,17710,0,1,14,174,1720,12410,58426,
%U A396430 148883,135720,0,1,16,231,2742,25050,162956,674034,1458740,1068012,0
%N A396430 Square array A(n,k), n>=0, k>=0, read by antidiagonals downwards, where A(n,k) = [x^n] F_k(x)/x and F_k(x) is the k-th iteration of x*G4(x)^2 with G4(x) = 1 + x*G4(x)^4.
%H A396430 Wikipedia, <a href="https://en.wikipedia.org/wiki/Fuss%E2%80%93Catalan_number">Fuss-Catalan number</a>
%F A396430 G.f. of column k: (1/x) * Series_Reversion( H_k(x) ), where H_k(x) is the k-th iteration of x*(1 - x*C(x))^2 with C(x) = 1 + x*C(x)^2.
%F A396430 A(n,k) = Sum_{0 = x_0 <= x_1 <= ... <= x_{k-1} <= x_k = n} Product_{j=0..k-1} (x_j + 1) * binomial(4*x_{j+1} - 2*x_j + 2,x_{j+1} - x_j)/(2*x_{j+1} - x_j + 1).
%F A396430 A(n,0) = 0^n; A(n,k) = Sum_{j=0..n} (j+1) * binomial(4*n-2*j+2,n-j)/(2*n-j+1) * A(j,k-1) for k > 0.
%e A396430 Square array begins:
%e A396430   1,     1,      1,      1,       1,       1,        1, ...
%e A396430   0,     2,      4,      6,       8,      10,       12, ...
%e A396430   0,     9,     26,     51,      84,     125,      174, ...
%e A396430   0,    52,    202,    498,     988,    1720,     2742, ...
%e A396430   0,   340,   1727,   5257,   12410,   25050,    45425, ...
%e A396430   0,  2394,  15694,  58426,  162956,  379330,   779114, ...
%e A396430   0, 17710, 148883, 674034, 2211038, 5913850, 13717305, ...
%e A396430   ...
%o A396430 (PARI)
%o A396430 a(n, k, p=4, s=2, r=2) = {
%o A396430   my(T=matrix(n+1, n+1, row, col, my(xr=row-1, xc=col-1); if(xc<xr, 0, (s*xr+r)*binomial(p*xc-(p-s)*xr+r, xc-xr)/(p*xc-(p-s)*xr+r))));
%o A396430   my(TK=T^k);
%o A396430   TK[1, n+1];
%o A396430 };
%Y A396430 Columns k=0..1 give A000007, A069271.
%Y A396430 Cf. A000108, A396431.
%K A396430 nonn,tabl,new
%O A396430 0,5
