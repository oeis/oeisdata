%S A396203 2,5,19,73,83,359,389,401,449,479,491,1039,1051,1153,1171,1249,1399,
%T A396203 1471,1627,1699,1723,1801,1879,2017,2029,4099,4397,4409,4549,4679,
%U A396203 4691,4801,4877,4919,5039,5087,5197,5261,5419,5507,5827,5927,6101,6151,6287,6607,6661
%N A396203 Primes p such that the gap to the next prime is floor(log_2(p)).
%C A396203 For any term p > 2, floor(log_2(p)) is an even integer. This is because the gap between any two primes greater than 2 is an even number, and because no prime p > 2 can have a gap equal to an odd integer. Consequently, this sequence contains zero terms in any interval [2k, 2*(k+1)-1] where k is an odd integer > 1.
%C A396203 Consequently, this sequence mathematically cannot contain any primes where the floor of the base-2 logarithm is an odd number (e.g., dimensions 3, 5, 7), completely bypassing intervals such as [8, 15] and [32, 63].
%C A396203 This sequence is conjectured to be infinite.
%H A396203 Alois P. Heinz, <a href="/A396203/b396203.txt">Table of n, a(n) for n = 1..10000</a>
%F A396203 Primes p such that nextprime(p) - p = floor(log_2(p)).
%F A396203 Primes p such that A001223(k) = A098388(k), where k is primepi(p).
%e A396203 73 is a term because the gap to the next prime is 79 - 73 = 6 = floor(log_2(73)).
%p A396203 q:= p-> isprime(p) and nextprime(p)-p=ilog2(p):
%p A396203 select(q, [$2..7000])[];  # _Alois P. Heinz_, May 20 2026
%t A396203 With[{ps = Prime[Range[860]]}, ps[[Position[Differences[ps] - Floor[Log2[Most[ps]]], 0] // Flatten]]] (* _Amiram Eldar_, May 22 2026 *)
%o A396203 (Python)
%o A396203 import sympy
%o A396203 def generate_boundary_primes(limit):
%o A396203     boundary_primes = []
%o A396203     p = 2
%o A396203     while len(boundary_primes) < limit:
%o A396203         next_p = sympy.nextprime(p)
%o A396203         gap = next_p - p
%o A396203         scale = p.bit_length() - 1 # A000523
%o A396203         if gap == scale:
%o A396203             boundary_primes.append(p)
%o A396203         p = next_p
%o A396203     return boundary_primes
%o A396203 print(generate_boundary_primes(50))
%Y A396203 Intersection of A000040 and A396279.
%Y A396203 Cf. A000523, A001223, A098388.
%K A396203 nonn,new
%O A396203 1,1
