%I A396726 #12 Jun 04 2026 09:35:02
%S A396726 1,3,4,5,6,6,7,7,7,8,8,8,8,9,9,9,9,9,9,9,10,10,10,10,10,10,10,10,10,
%T A396726 10,11
%N A396726 Greatest frequency depth of a word of length n.
%C A396726 The frequency depth of a sequence is the number of iterations of the run transform on a sequence required to reach 1. See A327662 for an equivalent definition using different terms.
%C A396726 Note that we only need to consider sequences consisting of 1s and 2s (or any two values, which serve to delineate the start and end of a run).
%e A396726 a(5) is 6 because the greatest number of iterations of the run transform before a sequence of length 5 reaches 1 is 6. For example, 1,2,2,1,2 -> 1,2,1,1 -> 1,1,2 -> 2,1 -> 1,1 -> 2 -> 1. This is 6 steps (the most we can get), so a(5) = 6.
%o A396726 (Python)
%o A396726 from itertools import groupby, product
%o A396726 def RT(t): # run transform of tuple t
%o A396726     return tuple(len(list(g)) for k, g in groupby(t))
%o A396726 def f(t):
%o A396726     i = 0
%o A396726     while t != (1,): t, i = RT(t), i+1
%o A396726     return i
%o A396726 def a(n):
%o A396726     return max(f((2,)+t) for t in product((1,2), repeat=n-1))
%o A396726 print([a(n) for n in range(1, 21)]) # _Michael S. Branicky_, Jun 03 2026
%Y A396726 Cf. A327662, A362228.
%K A396726 nonn,more,new
%O A396726 1,2
