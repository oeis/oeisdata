%S A396796 1,1,-4,32,-346,4472,-65292,1043753,-17921768,326358300,-6247293860,
%T A396796 124904785856,-2595750453348,55864370827852,-1241459233450784,
%U A396796 28421477429433280,-669049539675142690,16169348706143246816,-400669193608178111624,10168617943338798853142,-264065780322430320166880
%N A396796 G.f. A(x) satisfies A^3(x) = A^2(x) + x^2, where A^n(x) denotes the n-th iteration of A(x).
%H A396796 Paul D. Hanna, <a href="/A396796/b396796.txt">Table of n, a(n) for n = 1..450</a>
%F A396796 G.f. A(x) = Sum_{n>=1} a(n)*x^n satisfies the following formulas.
%F A396796 (1) A(x) = x + R^2(x)^2 where R(A(x)) = x and R(x) = x - R^3(x)^2 so that -R(-x) is the g.f. of A141372.
%F A396796 (2) A^2(x) = A(x) + R(x)^2 where R(A(x)) = x.
%F A396796 (3) A^3(x) = A^2(x) + x^2.
%F A396796 (4) A^4(x) = A^2(x) + A(x)^2 + x^2.
%F A396796 (5) A^5(x) = A^2(x) + A^2(x)^2 + A(x)^2 + x^2.
%F A396796 (6) A^6(x) = 2*A^2(x)^2 + (1 + 2*x^2)*A^2(x) + A(x)^2 + x^4 + x^2.
%e A396796 G.f.: A(x) = x + x^2 - 4*x^3 + 32*x^4 - 346*x^5 + 4472*x^6 - 65292*x^7 + 1043753*x^8 - 17921768*x^9 + 326358300*x^10 + ...
%e A396796 RELATED SERIES.
%e A396796 A(A(x)) = x + 2*x^2 - 6*x^3 + 45*x^4 - 472*x^5 + 5990*x^6 - 86368*x^7 + 1367930*x^8 - 23318000*x^9 + 422112720*x^10 + ...
%e A396796 A(A(A(x))) = x + 3*x^2 - 6*x^3 + 45*x^4 - 472*x^5 + 5990*x^6 - 86368*x^7 + 1367930*x^8 - 23318000*x^9 + 422112720*x^10 + ...
%e A396796 so that A(A(A(x))) = A(A(x)) + x^2.
%e A396796 Also, R(x) = sqrt( A^2(x) - A(x) ) begins
%e A396796 R(x) = x - x^2 + 6*x^3 - 57*x^4 + 684*x^5 - 9512*x^6 + 146848*x^7 - 2455208*x^8 + 43764802*x^9 + ... + (-1)^(n-1)*A141372(n)*x^n + ...
%e A396796 where A(R(x)) = x and A(x) = x + R^2(x)^2.
%o A396796 (PARI) {a(n) = my(V = [0,1],A,B,C); for(i=2, n, V = concat(V,0); A = Ser(V);
%o A396796 B = subst(A, x, A); C = subst(A, x, B);
%o A396796 V[#V] = polcoef(B + x^2 - C, #A) ); polcoef(GF=Ser(V), n)}
%o A396796 {upto(n) = a(n); Vec(GF)}
%o A396796 upto(30)
%Y A396796 Cf. A138740, A177751, A141372.
%K A396796 sign,new
%O A396796 1,3
%A A396796 _Paul D. Hanna_, Jul 04 2026
