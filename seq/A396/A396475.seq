%I A396475 #12 May 29 2026 01:15:24
%S A396475 1,2,4,38,136,752,3364,16808,78976,383432,1829824,8811728,42230416,
%T A396475 202907312,973605184,4674970448,22439347456,107728053392,517131722944,
%U A396475 2482550169968,11917410964096,57210095174672,274637466239104,1318404953282288,6329025514174336,30382633038219152
%N A396475 Expansion of g.f. (1 - 11*x^2 - 20*x^4)/(1 - 2*x - 11*x^2 - 8*x^3 - 20*x^4 + 10*x^5).
%C A396475 Sum of fifth powers of A396471 row entries.
%H A396475 Paolo Xausa, <a href="/A396475/b396475.txt">Table of n, a(n) for n = 0..1000</a>
%H A396475 Richard P. Stanley, <a href="https://www.gathering4gardner.org/g4g15gift/ExchangeArchive-FibArray-G15-087-1.pdf">A Fibonacci Array</a>, in Gathering for Gardner 15 Gift Exchange Book, 2024 (see p. 5).
%H A396475 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (2,11,8,20,-10).
%F A396475 a(n) = Sum_{k=0..A001911(n)} A396471(n,k)^5.
%F A396475 a(n) = 2*a(n-1) + 11*a(n-2) + 8*a(n-3) + 20*a(n-4) - 10*a(n-5), with a(0) = 1, a(1) = 2, a(2) = 4, a(3) = 38, a(4) = 136.
%t A396475 Module[{x}, CoefficientList[Series[(1 - 11*x^2 - 20*x^4)/(1 - 2*x - 11*x^2 - 8*x^3 - 20*x^4 + 10*x^5), {x, 0, 29}], x]]
%t A396475 (* Alternative: *)
%t A396475 LinearRecurrence[{2, 11, 8, 20, -10}, {1, 2, 4, 38, 136}, 30]
%Y A396475 Cf. A001911, A396471.
%Y A396475 Cf. other sum of r-th powers of A396471 row entries: A000079 (r=1), A052987 (r=2), A396473 (r=3), A396474 (r=4), A396516 (r=6).
%K A396475 nonn,easy
%O A396475 0,2
%A A396475 _Paolo Xausa_, May 28 2026
