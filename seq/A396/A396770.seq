%U A396770 36044048,71906735,143482301,286339916,571524114,1140868089,2277666987,4547647110,9080853526
%N A396770 Number of unlabeled connected nonnegative partially ordered sets ("posets") of size n and Dynkin type A.
%C A396770 a(n) is the number of distinct isomorphism classes of connected nonnegative posets of size n and Dynkin type A.
%C A396770 A poset I of size n is nonnegative if its symmetric Gram matrix G_I = (C_I + C_I^T)/2 is positive semidefinite, where C_I is the n X n relation matrix of the poset (with entries c_ij = 1 if i <= j, and 0 otherwise). Every such poset has a unique Dynkin type, defined as the simply-laced Dynkin diagram associated with the Z-congruence class of G_I (Simson, 2013).
%C A396770 For proof, see Gąsiorek (2022).
%D A396770 D. Simson, A Coxeter-Gram classification of positive simply laced edge-bipartite graphs, SIAM Journal on Discrete Mathematics, 27 (2013), 827-854.
%H A396770 Marcin Gąsiorek, <a href="https://arxiv.org/abs/2205.15032">Structure of non-negative posets of Dynkin type A_n</a>, arXiv:2205.15032 [math.CO], 2022.
%F A396770 a(n) = (1/(2*n)) * Sum_{d|n} (2^(n/d) * phi(d)) + floor(2^(n-2) + 2^(ceiling(n/2 - 2)) - (n+1)/2), where phi is the Euler totient function (A000010).
%p A396770 anum := proc(n::integer)
%p A396770     local d, term1, term2;
%p A396770     if n < 1 then
%p A396770         return 0;
%p A396770     end if;
%p A396770     term1 := iquo(add(2^iquo(n, d) * NumberTheory:-Totient(d), d in NumberTheory:-Divisors(n)), (2 * n));
%p A396770     term2 := floor(2^(n - 2) + 2^ceil(n / 2 - 2) - (n + 1) / 2);
%p A396770     return term1 + term2;
%p A396770 end proc;
%t A396770 anum[n_Integer?Negative] := 0;
%t A396770 anum[0] := 0;
%t A396770 anum[n_Integer?Positive] := DivisorSum[n, 2^(n/#) EulerPhi[#] &]/(2 n) + Floor[(2^n + 2^Ceiling[n/2])/4 - (n + 1)/2];
%o A396770 (Python)
%o A396770 from sympy import Integer, Rational, divisors, totient, ceiling, floor
%o A396770 def anum(n: int) -> int:
%o A396770     if n < 1:
%o A396770         return 0
%o A396770     n = Integer(n)
%o A396770     term1 = sum(2**(n // d) * totient(d) for d in divisors(n)) // (2 * n)
%o A396770     term2 = floor(2**(n - 2) + 2**ceiling(n / 2 - 2) - Rational(n + 1, 2))
%o A396770     return int(term1 + term2)
%o A396770 (SageMath)
%o A396770 def anum(n):
%o A396770     if n < 1:
%o A396770         return 0
%o A396770     term1 = sum(2^(n // d) * euler_phi(d) for d in divisors(n) ) // (2 * n)
%o A396770     term2 = floor(2^(n - 2) + 2^ceil(n/2 - 2) - (n + 1)/2)
%o A396770     return term1 + term2
%Y A396770 Cf. A000010.
%K A396770 nonn,easy,new
