%N A396583 Triangle read by rows: T(n, k) = binomial(n, k) * A396201(k).
%C A396583 If A396201 is seen as the generator of a two-sided sequence, then the main diagonal is the right branch, and the row sums of this triangle are the left branch of A396201.
%e A396583 Triangle starts:
%e A396583   [0]  1;
%e A396583   [1]  1,  3;
%e A396583   [2]  1,  6,  -2;
%e A396583   [3]  1,  9,  -6,   5;
%e A396583   [4]  1, 12, -12,  20,   -7;
%e A396583   [5]  1, 15, -20,  50,  -35,  12;
%e A396583   [6]  1, 18, -30, 100, -105,  72,  -19;
%e A396583   [7]  1, 21, -42, 175, -245, 252, -133,  31;
%e A396583   [8]  1, 24, -56, 280, -490, 672, -532, 248, -50;
%o A396583 (Python)
%o A396583 def Trow(n: int) -> list[int]:
%o A396583     gen = A396201gen(n + 1)
%o A396583     row = []
%o A396583     comb = 1
%o A396583     for k in range(n + 1):
%o A396583         a_k = next(gen)
%o A396583         t_nk = comb * a_k
%o A396583         row.append(t_nk)
%o A396583         if k < n:
%o A396583             comb = comb * (n - k) // (k + 1)
%o A396583     return row
%o A396583 for n in range(9): print(Trow(n))
%Y A396583 Cf. A396582, A396201 (main diagonal), A000285 (row sums), A100545 (related to alternating row sums).
