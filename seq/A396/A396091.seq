%N A396091 Number of integer partitions of 2*n with reverse-alternating sum 8.
%H A396091 Seiichi Manyama, <a href="/A396091/b396091.txt">Table of n, a(n) for n = 0..10000</a>
%F A396091 G.f.: (Product_{k>0} 1/(1-q^k)) * B(q), where B(q) is the g.f. of A396075.
%F A396091 a(n) = Sum_{k=0..n} A396075(k) * A000041(n-k).
%o A396091 (PARI) my(N=50, q='q+O('q^N)); concat([0, 0, 0, 0], Vec(1/prod(k=1, N, 1-q^k)*sum(j=1, 8, (-1)^(j-1)*q^(j*(j-1)/2+4)/prod(k=1, 8-j, 1-q^k))))
