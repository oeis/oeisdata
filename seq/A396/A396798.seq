%I A396798 #12 Jun 17 2026 00:54:11
%S A396798 1,1,9,133,2517,55609,1370321,36691293,1050059709,31765811601,
%T A396798 1007855339033,33345188250965,1145460034412005,40717411279314345,
%U A396798 1493765745364063009,56436741663524300685,2192115902521507267021,87410192361668819113985,3573820557441516192963049,149667971123475023087339525
%N A396798 G.f. satisfies A(x) = x + A^4(x)*A^5(x).
%C A396798 Conjecture: a(n) = [1,1,5,5] repeating (mod 8) for n >= 1.
%C A396798 Conjecture: [x^n] A^2(x) == 0 (mod 8) for n > 3.
%C A396798 Conjecture: [x^n] A^3(x) == [3,1,7,5] repeating (mod 8) for n > 1.
%C A396798 Conjecture: [x^n] A^4(x) == 0 (mod 8) for n > 2.
%C A396798 Conjecture: [x^n] A^5(x) == [5,1,1,5] repeating (mod 8) for n > 1.
%C A396798 Conjecture: [x^n] A^6(x) == 0 (mod 8) for n > 3.
%C A396798 Conjecture: [x^n] A^7(x) == [7,1,3,5] repeating (mod 8) for n > 1.
%C A396798 Conjecture: [x^n] A^8(x) == 0 (mod 8) for n > 1.
%H A396798 Paul D. Hanna, <a href="/A396798/b396798.txt">Table of n, a(n) for n = 1..400</a>
%F A396798 G.f. A(x) = Sum_{n>=1} a(n)*x^n has the following properties, where A^n(x) denotes the n-th iteration of A(x).
%F A396798 (1.a) A(x) = x + A^4(x)*A^5(x).
%F A396798 (1.b) A(x) = x + A^3(x)*A^5(x) + A^5(x)*A^7(x)*A^8(x).
%F A396798 (1.c) A(x) = x + A^4(x)^2 + A^4(x)*A^8(x)*A^9(x).
%F A396798 (2.a) A(x) = A^2(x) - A^5(x)*A^6(x).
%F A396798 (2.b) A(x) = A^3(x) - A^5(x)*A^6(x) - A^6(x)*A^7(x).
%F A396798 (2.c) A(x) = A^4(x) - A^5(x)*A^6(x) - A^6(x)*A^7(x) - A^7(x)*A^8(x).
%F A396798 (2.d) A(x) = A^n(x) - Sum_{k=1..n-1} A^(k+4)(x) * A^(k+5)(x) for n >= 1.
%F A396798 (3.a) A(x) = x + Sum_{n>=1} d^(n-1)/dx^(n-1) A^3(x)^n*A^4(x)^n / n!.
%F A396798 (3.b) A(x) = x * exp( Sum_{n>=1} d^(n-1)/dx^(n-1) ( A^3(x)^n*A^4(x)^n/x ) / n! ).
%F A396798 (4.a) x = A( x - A^3(x)*A^4(x) ).
%F A396798 (4.b) x = A( x - A^2(x)*A^4(x) - A^4(x)*A^6(x)*A^7(x) ).
%F A396798 (4.c) x = A( x - A^3(x)^2 - A^3(x)*A^7(x)*A^8(x) ).
%F A396798 (5.a) x = A^2( x - A^2(x)*A^3(x) - A^3(x)*A^4(x) ).
%F A396798 (5.b) x = A^2( x - A^2(x)^2 - A^3(x)*A^4(x) - A^2(x)*A^6(x)*A^7(x) ).
%F A396798 (5.c) x = A^2( x - A(x)*A^3(x) - A^3(x)*A^4(x) - A^3(x)*A^5(x)*A^6(x) ).
%F A396798 (6.a) x = A^3( x - A(x)*A^2(x) - A^2(x)*A^3(x) - A^3(x)*A^4(x) ).
%F A396798 (6.b) x = A^3( x - A(x)^2 - A^2(x)*A^3(x) - A^3(x)*A^4(x) - A(x)*A^5(x)*A^6(x) ).
%F A396798 (7.a) x = A^4( x - x*A(x) - A(x)*A^2(x) - A^2(x)*A^3(x) - A^3(x)*A^4(x) ).
%F A396798 (7.b) x = A^4( x-x^2 - A(x)*A^2(x) - A^2(x)*A^3(x) - A^3(x)*A^4(x) - x*A^4(x)*A^5(x) ).
%F A396798 (7.c) x = A^5( x-x^2 - x*A(x) - A(x)*A^2(x) - A^2(x)*A^3(x) - (1-x)*A^3(x)*A^4(x) ).
%e A396798 G.f.: A(x) = x + x^2 + 9*x^3 + 133*x^4 + 2517*x^5 + 55609*x^6 + 1370321*x^7 + 36691293*x^8 + 1050059709*x^9 + 31765811601*x^10 + ...
%e A396798 The second and third iterations of A(x) begin
%e A396798 A^2(x) = x + 2*x^2 + 20*x^3 + 312*x^4 + 6120*x^5 + 138856*x^6 + 3494600*x^7 + 95216968*x^8 + 2765855080*x^9 + ...
%e A396798 A^3(x) = x + 3*x^2 + 33*x^3 + 543*x^4 + 11053*x^5 + 258011*x^6 + 6645257*x^7 + 184633703*x^8 + 5454898261*x^9 + ...
%e A396798 The fourth and fifth iterations of A(x) begin
%e A396798 A^4(x) = x + 4*x^2 + 48*x^3 + 832*x^4 + 17584*x^5 + 422816*x^6 + 11161616*x^7 + 316757920*x^8 + 9534638032*x^9 + ...
%e A396798 A^5(x) = x + 5*x^2 + 65*x^3 + 1185*x^4 + 26005*x^5 + 644605*x^6 + 17460057*x^7 + 506756201*x^8 + 15562151149*x^9 + ...
%e A396798 where A(x) = x + A^4(x) * A^5(x).
%e A396798 Let R(x) = A^(-1)(x) satisfy R(A(x)) = x, then
%e A396798 R(x) = x - x^2 - 7*x^3 - 93*x^4 - 1651*x^5 - 34889*x^6 - 831311*x^7 - 21669957*x^8 - 606539163*x^9 + ...
%e A396798 where R(x) = x - A^3(x)*A^4(x).
%e A396798 Therefore, g.f. A(x) satisfies
%e A396798 A(x) = x + A^3(x)*A^4(x) + d/dx (A^3(x)*A^4(x))^2/2! + d^2/dx^2 (A^3(x)*A^4(x))^3/3! + d^3/dx^3 (A^3(x)*A^4(x))^4/4! + d^4/dx^4 (A^3(x)*A^4(x))^5/5! + ...
%e A396798 Also, g.f. A(x) is the unique solution to variable A in the infinite system of simultaneous equations starting with:
%e A396798   A = x + D*E;
%e A396798   B = A + E*F;
%e A396798   C = B + F*G;
%e A396798   D = C + G*H; ...
%e A396798 resulting in B = A^2(x), C = A^3(x), D = A^4(x), etc.
%o A396798 (PARI) \\ By definition A(x) = x + A^4(x)*A^5(x)
%o A396798 \\ ('truncate' is used here to reduce runtime)
%o A396798 {a(n) = my(A=x, A2, A3); for(i=1, n, A=truncate(A) +x^2*O(x^i);
%o A396798 A2 = subst(A, x, A); A3 = subst(A, x, A2);
%o A396798 A = x + subst(A2*A3, x, A2) +x*O(x^n)); polcoef(GF=A, n)}
%o A396798 {upto(n) = a(n); Vec(GF)}
%o A396798 upto(30)
%o A396798 (PARI) \\ Using series reversion of x - A^3(x)*A^4(x)
%o A396798 \\ ('truncate' is used here to reduce runtime)
%o A396798 {a(n) = my(A=x, A2, A3); for(i=1, n, A=truncate(A) +x^2*O(x^i);
%o A396798 A2 = subst(A, x, A); A3 = subst(A, x, A2);
%o A396798 A = serreverse(x - A3*subst(A, x, A3) +x*O(x^n)) ); polcoef(GF=A, n)}
%o A396798 {upto(n) = a(n); Vec(GF)}
%o A396798 upto(30)
%Y A396798 Cf. A396797, A396807, A396099, A213591.
%K A396798 nonn
%O A396798 1,3
%A A396798 _Paul D. Hanna_, Jun 16 2026
