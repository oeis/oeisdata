%T A396588 194481,0,1,6,85,1666,35949,711977,9765625,0,1,7,114,2615,68744,
%U A396588 1798518,40372828,594823321,0,1,8,147,3849,118465,3793614,113475099,2773990837,42618442977,0
%N A396588 Square array A(n,k), n>=0, k>=0, read by antidiagonals downwards, where A(n,k) = n! * [x^n] F_k(x)/x and F_k(x) is the k-th iteration of x*G(x) with G(x) = exp(x*G(x)^4).
%F A396588 E.g.f. of column k: (1/x) * Series_Reversion( H_k(x) ), where H_k(x) is the k-th iterate of U(x)*exp(-4*U(x)) and U(x) = -LambertW(-3*x)/3.
%F A396588 A(n,k) = Sum_{0 = x_0 <= x_1 <= ... <= x_{k-1} <= x_k = n} Product_{j=0..k-1} (x_j + 1) * (4*x_{j+1} - 3*x_j + 1)^(x_{j+1} - x_j - 1) * binomial(x_{j+1},x_j).
%F A396588 A(n,0) = 0^n; A(n,k) = Sum_{j=0..n} (j+1) * (4*n-3*j+1)^(n-j-1) * binomial(n,j) * A(j,k-1) for k > 0.
%e A396588 Square array begins:
%e A396588   1,      1,      1,       1,       1,       1, ...
%e A396588   0,      1,      2,       3,       4,       5, ...
%e A396588   0,      9,     22,      39,      60,      85, ...
%e A396588   0,    169,    479,     966,    1666,    2615, ...
%e A396588   0,   4913,  15880,   35949,   68744,  118465, ...
%e A396588   0, 194481, 711977, 1798518, 3793614, 7144655, ...
%e A396588   ...
%o A396588 (PARI)
%o A396588 a(n, k, p=4, s=1, r=1) = {
%o A396588   my(T=matrix(n+1, n+1, row, col, my(xr=row-1, xc=col-1); if(xc<xr, 0, (s*xr+r)*(p*xc-(p-s)*xr+r)^(xc-xr-1)*binomial(xc, xr))));
%o A396588   my(TK=T^k);
%o A396588   TK[1, n+1];
%o A396588 };
%Y A396588 Columns k=0..2 give A000007, A052774, A396592.
%Y A396588 Cf. A396413, A396498, A396499, A396500, A396504.
%K A396588 nonn,tabl
