%I A396983 #23 Jun 17 2026 17:24:46
%S A396983 0,1,1,-1,1,5,1,1,-1,7,1,1,1,9,8,-1,1,7,1,-1,10,13,1,11,-1,15,1,-3,1,
%T A396983 31,1,1,14,19,12,-13,1,21,16,13,1,41,1,-7,4,25,1,13,-1,23,20,-9,1,29,
%U A396983 16,15,22,31,1,17,1,33,2,-1,18,61,1,-13,26,59,1,1,1
%N A396983 a(n) = -n * Sum_{i=1..r} (-p_i)^(-e_i) where n = p_1^e_1 *...* p_r^e_r is the prime factorization of n.
%H A396983 Ctibor O. Zizka, <a href="/A396983/a396983.png">Plot of a(n) for n = 1 to 50000</a>
%F A396983 a(A000040(n)) = 1.
%F A396983 a(A246551(n)) = 1.
%F A396983 a(A056798(n)) = -1.
%e A396983 n = 6: n = 2^1*3^1, a(6) = -6*((-2)^(-1)+(-3)^(-1)) = 5.
%e A396983 n = 28: n = 2^2*7^1, a(28) = -28*((-2)^(-2)+(-7)^(-1)) = -3.
%t A396983 f[p_, e_] := (-p)^(-e); a[1] = 0; a[n_] := -n * Plus @@ f @@@ FactorInteger[n]; Array[a, 100] (* _Amiram Eldar_, Jun 12 2026 *)
%o A396983 (PARI) a(n) = my(f=factor(n)); -n*sum(k=1, #f~, (-f[k,1])^(-f[k,2])); \\ _Michel Marcus_, Jun 12 2026
%Y A396983 Cf. A000040, A056798, A246551.
%K A396983 sign,easy
%O A396983 1,6
%A A396983 _Ctibor O. Zizka_, Jun 12 2026
