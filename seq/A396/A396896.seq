%I A396896 #13 Jun 15 2026 16:59:45
%S A396896 3,3,7,7,17,7,13,11,11,13,17,13,19,17,19,31,29,23,31,29,23,43,47,41,
%T A396896 31,53,29,31,47,31,61,41,47,37,41,37,43,47,41,61,47,47,61,47,53,97,53,
%U A396896 61,67,53,59,67,59,61,61,59,61,67,89,71,79,71,67,67,1013,67,73,83,71,73,83,73,103,83,79
%N A396896 a(n) is the first prime p > n such that the concatenation of p - n and p is prime.
%C A396896 The first three primes that do not occur in the sequence are 2, 5 and 509. The next, if any, is greater than 10^6.
%C A396896 If a(n) has d digits, then n and 10^d + 1 must be coprime.
%H A396896 Robert Israel, <a href="/A396896/b396896.txt">Table of n, a(n) for n = 1..10000</a>
%e A396896 a(3) = 7 because the concatenation of 7-3 = 4 and 7 is 47, which is prime, while 25 is not prime.
%p A396896 f:= proc(n) local d,p,i;
%p A396896   for d from 1 + ilog10(n) do
%p A396896     if igcd(n, 10^d+1) > 1 then next fi;
%p A396896     p:= max(n, 10^(d-1));
%p A396896     do
%p A396896       p:= nextprime(p);
%p A396896       if p > 10^d then break fi;
%p A396896       if 2*p-n mod 3 = 0 then next fi;
%p A396896       if isprime((p-n)*10^d + p) then return p fi
%p A396896   od od;
%p A396896 end proc:
%p A396896 map(f, [$1..100]);
%t A396896 A396896[n_] := NestWhile[NextPrime, NextPrime[n], !PrimeQ[(# - n)*10^IntegerLength[#] + #] &];
%t A396896 Array[A396896, 100] (* _Paolo Xausa_, Jun 15 2026 *)
%Y A396896 Cf. A396878.
%K A396896 nonn,look,new
%O A396896 1,1
%A A396896 _Robert Israel_, Jun 09 2026
