%I A396651 #37 Jun 07 2026 07:27:01
%S A396651 1,0,4,1,0,4,0,5,0,4,1,0,9,0,4,0,6,0,13,0,4,1,0,15,0,17,0,4,0,7,0,28,
%T A396651 0,21,0,4,1,0,22,0,45,0,25,0,4,0,8,0,50,0,66,0,29,0,4,1,0,30,0,95,0,
%U A396651 91,0,33,0,4,0,9,0,80,0,161,0,120,0,37,0,4
%N A396651 Triangle read by rows: the coefficients of the polynomials P(n, x) = x * P(n-1, x) + P(n-2, x), where P(0, x) = 1 and P(1, x) = 4*x, ordered by ascending powers.
%C A396651 Define F(t, x) = (phi(x)^(-t) - (-phi(x))^t) / (2*phi(x) - x) and L(t, x) = (phi(x)^(-t) + (-phi(x))^t), where phi(x) = (x + sqrt(x^2 + 4))/2. On this page and in A396650, we examine LF(t, x) = (1/2) * L(t, x) + (7/2)*x*F(t, x). In expanded form this leads to a generalized Binet-type representation:
%C A396651   LF(t, x) = ((3*x + phi(x))*phi(x)^(-t) + (-phi(x))^t*(-4*x + phi(x)))/(2*phi(x) - x).
%C A396651 We dub this linear combination of the Lucas and the Fibonacci polynomials the Lucanacci polynomials, and LF(t, 1) the Lucanacci function. The coefficients of the polynomials LF(n, x) are for n >= 0 on the present page and for LF(-n, x) in A396650.
%C A396651 The Lucanacci function yields the sequences LF(n, 1) = A396201(n) and LF(-n, 1) = A000285(n) for n >= 0, which are the row sums of the corresponding triangles of coefficients.
%H A396651 Peter Luschny, <a href="/A396651/a396651.png">Illustration of the A396651 polynomials</a>.
%F A396651 T(n, k) are the coefficients of P(n, x) = i^n * U(n, -i*x/2) + i^(n-1) * 3*x * U(n-1, -i*x/2), where U(n, x) are the Chebyshev U polynomials and i is the imaginary unit.
%F A396651 The connection with the Lucas and Fibonacci polynomials:
%F A396651 P(n, x) = (Lucas(n, x) + 7*x*Fibonacci(n, x)) / 2.
%F A396651 The Binet representation of the polynomials:
%F A396651 P(n, x) = mu(x)*phi(x)^n + (1-mu(x))*(x-phi(x))^n, where phi(x) = (x + sqrt(x^2+4))/2, and mu(x) = (1 + 7*x/sqrt(x^2+4))/2. Note that phi(1) = A001622, and mu(1) = A189961.
%F A396651 G.f.: (1 + 3*x*y)/(1 - x*y - y^2).
%F A396651 E.g.f.: exp(x*y/2)*(cosh(h*y) + g*sinh(h*y)), where h = phi(x) - x/2, and g = 2*mu(x) - 1. Notice that the only difference between this and the EGF of A396650 is the minus sign in the leading exponential factor.
%F A396651 T(n, k) = 0 if n - k is odd, T(0, 0) = 1, T(n, n) = 4 for n > 0, otherwise T(n, k) = (n + 7*k)*binomial((n + k)/2 - 1, k) / (n - k). (See A095666.)
%F A396651 Sum_{k=0..n} T(n, k) = A000285(n) = A396201(-n), where A396201 is seen as a two-sided sequence.
%e A396651 Table starts:
%e A396651    0:   1;
%e A396651    1:   0,   4;
%e A396651    2:   1,   0,   4;
%e A396651    3:   0,   5,   0,   4;
%e A396651    4:   1,   0,   9,   0,   4;
%e A396651    5:   0,   6,   0,  13,   0,   4;
%e A396651    6:   1,   0,  15,   0,  17,   0,   4;
%e A396651    7:   0,   7,   0,  28,   0,  21,   0,   4;
%e A396651    8:   1,   0,  22,   0,  45,   0,  25,   0,   4;
%e A396651    9:   0,   8,   0,  50,   0,  66,   0,  29,   0,   4;
%e A396651   10:   1,   0,  30,   0,  95,   0,  91,   0,  33,   0,   4;
%e A396651   11:   0,   9,   0,  80,   0, 161,   0, 120,   0,  37,   0,   4;
%p A396651 # Using function 'PolyTriangle' from A396650.
%p A396651 A396651poly := n -> PolyTriangle(n, 4, true):
%p A396651 for row in A396651poly(11) do lprint(row) od;
%p A396651 # Alternative:
%p A396651 A396651poly := proc(n, x) option remember;
%p A396651 if n = 0 then 1 elif n = 1 then 4*x else x*procname(n-1, x) + procname(n-2, x) fi end:
%p A396651 Trow := n -> local k; seq(coeff(A396651poly(n, x), x, k), k = 0..n):
%p A396651 seq(print(Trow(n)), n = 0..11);
%t A396651 P[0] = 1; P[1] = 4 x; P[n_] := P[n] = Expand[x P[n - 1] + P[n - 2]];
%t A396651 Table[CoefficientList[P[n], x], {n, 0, 11}]
%t A396651 (* Alternative: Chebyshev polynomials *)
%t A396651 P[n_, x_] := Expand[I^n ChebyshevU[n, -(I x)/2] + I^(n - 1) 3 x ChebyshevU[n - 1, -(I x)/2]];
%t A396651 Table[CoefficientList[P[n, x], x], {n, 0, 11}]
%t A396651 (* Alternative: Lucas/Fibonacci connection *)
%t A396651 P[n_, x_] := (LucasL[n, x] + 7 x Fibonacci[n, x]) / 2
%t A396651 Table[CoefficientList[P[n, x], x], {n, 0, 11}]
%o A396651 (Python)
%o A396651 # Using function 'PolyTriangle' from A396650.
%o A396651 A396651poly = lambda n: PolyTriangle(n, 4, True)
%o A396651 for row in A396651poly(12): print(row)
%Y A396651 Cf. A000285 (row sums), A396201, A095666, A396650, A168561, A114525, A001622, A189961.
%Y A396651 Diagonals, T(n+m, n), n >= 0: A123932 (m=0), A016813 (m=2), A000384 (m=4), A002412 (m=6), A002417 (m=8), A034263 (m=10), A051947 (m=12), A050483 (m=14), A052181 (m=16), A055843 (m=18).
