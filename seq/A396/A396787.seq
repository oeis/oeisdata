%p A396787 b:= proc(n, p) option remember; `if`(n=0, 1, add(expand(
%p A396787       b(n-j, p+x^j)*x^add(coeff(p, x, i), i=1..j-1)), j=1..n))
%p A396787     end:
%p A396787 a:= n-> coeff(b(n, 0), x, n):
%p A396787 seq(a(n), n=0..30);
