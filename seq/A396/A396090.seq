%T A396090 3823,5382,7488,10357,14191,19331,26126,35124,46895,62306,82291,
%U A396090 108189,141492,184273,238857,308411,396537,508003,648309,824601,1045147,1320559,1663176,2088589,2615020
%N A396090 Number of integer partitions of 2*n with reverse-alternating sum 6.
%H A396090 Seiichi Manyama, <a href="/A396090/b396090.txt">Table of n, a(n) for n = 0..10000</a>
%F A396090 G.f.: (Product_{k>0} 1/(1-q^k)) * B(q), where B(q) is the g.f. of A395257.
%F A396090 a(n) = Sum_{k=0..n} A395257(k) * A000041(n-k).
%o A396090 (PARI) my(N=50, q='q+O('q^N)); concat([0, 0, 0], Vec(1/prod(k=1, N, 1-q^k)*sum(j=1, 6, (-1)^(j-1)*q^(j*(j-1)/2+3)/prod(k=1, 6-j, 1-q^k))))
%Y A396090 Column k=3 of A344610.
%Y A396090 Cf. A000041, A395257.
%K A396090 nonn,new
%O A396090 0,6
%A A396090 _Seiichi Manyama_, May 17 2026
