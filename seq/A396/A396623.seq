%N A396623 a(n) = r(n,n), where r(1,k)=f(k)=ceiling(k*c), r(n,k)=f(r(n-1,k)), c=sqrt(3).
%C A396623 a(n + 1)/a(n) approaches c erratically.
%t A396623 c = Sqrt[3]; f[k_] := f[k] = Ceiling[c*k];
%t A396623 r[1, k_] := f[k]; r[n_, k_] := r[n, k] = f[r[n - 1, k]];
%t A396623 Table[r[n, n], {n, 1, 100}]
%Y A396623 Cf. A396385, A396622, A396624.
%K A396623 nonn,new
%O A396623 1,1
