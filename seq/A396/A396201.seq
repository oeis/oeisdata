%I A396201 #42 May 30 2026 09:46:57
%S A396201 1,3,-2,5,-7,12,-19,31,-50,81,-131,212,-343,555,-898,1453,-2351,3804,
%T A396201 -6155,9959,-16114,26073,-42187,68260,-110447,178707,-289154,467861,
%U A396201 -757015,1224876,-1981891,3206767,-5188658,8395425,-13584083,21979508,-35563591,57543099
%N A396201 a(x) = psi * phi^(-x) + (1 - psi) * (-phi)^x, where phi = (1 + sqrt(5)) / 2 and psi = phi^4 / sqrt(5) - 1, evaluated at the nonnegative integers.
%C A396201 a(x) = (L(x) + 7*F(x)) / 2 is an analytic function where F(x) = (phi^(-x) - phi^x * exp(-I*Pi*x)) / sqrt(5) and L(x) = phi^(-x) + phi^x * exp(-I*Pi*x). L is the signed Lucas function and F the signed Fibonacci function.
%C A396201 a(n) is defined for all n in Z. For z = 0, 1, 2, ... a(z) = 1, 3, -2, 5, -7, ... and for z = 0, -1, -2, ... a(z) = 1, 4, 5, 9, ... This defines a two-sided sequence ..., 14, 9, 5, 4, 1, 3, -2, 5, -7, ... whose positive branch is this sequence and whose negative branch is A000285.
%C A396201 a(x) is for x >= 0 an oscillatory function whose codomain is the entire set R; for x <= 0, a(x) is a monotonic function that takes only values >= 1. (See the illustration in the links.) The function maintains the Cassini invariant a(x-1)*a(x+1) - a(x)^2 = 11*exp(i*Pi*x), which is 11*(-1)^n for integer n.
%C A396201 The function a(x) is a generalized Binet continuation of the second-order linear recurrence a(n) = a(n-2) - a(n-1) with seeds a(-2) = 5 and a(-1) = 4. The sequence never takes the value 0.
%H A396201 Paolo Xausa, <a href="/A396201/b396201.txt">Table of n, a(n) for n = 0..1000</a>
%H A396201 Peter Luschny, <a href="/A396201/a396201.pdf">The Lucanacci function</a>.
%H A396201 <a href="/index/Rec#order_02">Index entries for linear recurrences with constant coefficients</a>, signature (-1,1).
%F A396201 a(n) = (-1)^(n + 1) * (2*F(n-2) + F(n+1)), F(n) denotes Fibonacci numbers.
%F A396201 a(n) = (-1)^(n + 1) * (L(n) + 7*L(n-1))/5, L(n) denotes Lucas numbers.
%F A396201 a(n) = (-1)^(n + 1) * (F(n) + L(n-1)).
%F A396201 a(n) = A396583(n, n).
%F A396201 a(-n) = Sum_{k=0..n} binomial(n, k) * A396583(k).
%F A396201 a(-n) = Sum_{k=0..n} binomial(n, k) * a(k).
%F A396201 a(-n) = A000285(n).
%F A396201 A054486(n) = Sum_{k=0..n} binomial(n, k) * a(-k).
%F A396201 a(n) = [x^n] (1 + 4*x)/(1 + x - x^2).
%F A396201 a(n) = n! * [x^n] (((5+7*r)*exp((r-1)*x/2) + (5-7*r)*exp(-(r+1)*x/2))/10) where r = sqrt(5).
%F A396201 a(n) = n! * [x^n] (7/sqrt(5)*sinh(t) + cosh(t))/exp(x/2) where t = x*sqrt(5)/2.
%F A396201 Limit_{x->oo} abs(a(x) / a(-x)) = A396202.
%F A396201 Solution of phi^(2*x)*cos(Pi*x) = 1/A396202 is A395973, the first real root of a(x).
%p A396201 f := combinat:-fibonacci:
%p A396201 a := n -> (-1)^(n + 1) * (2*f(n - 2) + f(n + 1)):
%p A396201 seq(a(n), n = 0..37);
%p A396201 # Alternative: general, but floating-point-based:
%p A396201 phi := (1 + sqrt(5)) / 2:
%p A396201 F := x -> (phi^(-x) - phi^x * exp(-I*Pi*x)) / sqrt(5):
%p A396201 L := x -> (phi^(-x) + phi^x * exp(-I*Pi*x)):
%p A396201 a := x -> (L(x) + 7*F(x)) / 2:
%t A396201 A396201[n_] := (-1)^(n+1)*(2*Fibonacci[n-2] + Fibonacci[n+1]);
%t A396201 Array[A396201, 50, 0] (* _Paolo Xausa_, May 28 2026 *)
%t A396201 (* Alternative: *)
%t A396201 LinearRecurrence[{-1, 1}, {1, 3}, 50] (* _Paolo Xausa_, May 28 2026 *)
%o A396201 (SageMath)
%o A396201 a = BinaryRecurrenceSequence(-1, 1, 1, 3)
%o A396201 print([a(i) for i in range(38)])
%o A396201 # The function calculates also the values of the negative branch, for example with range(-3, 0) -> [14, 9, 5, 4].
%o A396201 (Python)
%o A396201 def A396201gen(bound):
%o A396201     a, b = 1, 3
%o A396201     if bound >= 1: yield a
%o A396201     if bound >= 2: yield b
%o A396201     for _ in range(2, bound):
%o A396201         c = a - b
%o A396201         yield c
%o A396201         a, b = b, c
%o A396201 for v in A396201gen(38): print(v, end=", ")
%o A396201 (PARI) a(n) = (-1)^(n+1)*(2*fibonacci(n-2) + fibonacci(n+1)); \\ _Michel Marcus_, May 28 2026
%Y A396201 Cf. A000285, A013655, A001622, A000045, A000032, A054486, A013655, A189961, A395973 (first real root), A396202, A396582, A396583.
