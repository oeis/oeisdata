%S A396306 5,17,23,25,43,53,59,73,79,83,97,103,137,157,181,193,197,223,251,263,
%T A396306 281,293,313,401,419,461,463,467,479,503,557,569,613,631,659,673,691,
%U A396306 709,739,751,757,853,863,877,971,1019,1039,1069,1229,1237,1259,1291,1303,1319
%N A396306 Initial terms of length-4 blocks in A280864.
%H A396306 Michael De Vlieger, <a href="/A396306/b396306.txt">Table of n, a(n) for n = 1..3398</a>
%e A396306 See A396305.
%t A396306 Block[{c, k, m, r, s, t, w, nn, rad},
%t A396306   nn = 3000; c[_] := False; r = 1; s = 1; t = {};
%t A396306   rad[n_] := rad[n] = Times @@ FactorInteger[n][[All, 1]];
%t A396306   Reap[ Do[w = GCD[r, s]; m = r/w; k = m;
%t A396306     While[Or[c[k], ! CoprimeQ[w, k] ], k += m]; c[k] = True;
%t A396306     s = r; r = rad[k];
%t A396306     If[CoprimeQ[s, r], If[Length[t] == 4, Sow[First[t] ] ]; t = {k},
%t A396306     AppendTo[t, k] ], {i, nn}] ][[-1, 1]] ] (* _Michael De Vlieger_, Jun 16 2026 *)
%Y A396306 Cf. A280864, A283832, A396300, A396301, A396305, A396307.
%K A396306 nonn
