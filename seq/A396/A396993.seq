%e A396993   0,  262,  760,  1608,  2944,  4930,   7752, ...
%e A396993   0, 2944, 8846, 19566, 37666, 66530, 110484, ...
%e A396993   ...
%Y A396993 Column k=1 gives A196523.
%Y A396993 Column k=4 gives A196523(n+1).
