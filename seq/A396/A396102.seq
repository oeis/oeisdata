%S A396102 1,1,-2,10,-71,616,-6119,67210,-799307,10152043,-136403576,1925530303,
%T A396102 -28412020568,436489070812,-6960212920001,114914150793724,
%U A396102 -1960409106724421,34499287415335777,-625380167235511394,11663137820014193356,-223541345425015147487,4399038934392019802758,-88806159394188157926365
%N A396102 G.f. A(x) satisfies A(A(A(x))) = (1+x) * A(A(x)).
%C A396102 Compare to: F(F(x)) = (1+x) * F(x) when F(x) is the g.f. of A067145, which shifts left under series reversion.
%C A396102 Conjecture: a(n) == 1 (mod 3) for n >= 1.
%H A396102 Paul D. Hanna, <a href="/A396102/b396102.txt">Table of n, a(n) for n = 1..400</a>
%F A396102 G.f. A(x) = Sum_{n>=1} a(n)*x^n satisfies the following formulas.
%F A396102 (1) A(A(A(x))) = (1+x) * A(A(x)).
%F A396102 (2) A( A(A(x))/A(x) - 1 ) = x.
%F A396102 (3) A( A(x)/x - 1 ) = A(A(x))/A(x) - 1.
%F A396102 (4) A(x) = x + x*R(R(x)) where R(A(x)) = x.
%F A396102 (5) R(x) = A(A(x))/A(x) - 1 where R(A(x)) = x and R(x) = x/(1 + R(R(R(x)))) and -R(-x) is the g.f. of A140094.
%F A396102 (6) A^4(x) = (1+x) * (1 + A(x)) * A(A(x)).
%e A396102 G.f.: A(x) = x + x^2 - 2*x^3 + 10*x^4 - 71*x^5 + 616*x^6 - 6119*x^7 + 67210*x^8 - 799307*x^9 + 10152043*x^10 + ...
%e A396102 where A(x) = x + x*R(R(x)) and R(A(x)) = x.
%e A396102 RELATED SERIES.
%e A396102 The second iteration of g.f. A(x) begins
%e A396102 A(A(x)) = x + 2*x^2 - 2*x^3 + 11*x^4 - 80*x^5 + 701*x^6 - 6998*x^7 + 77075*x^8 - 918059*x^9 + 11670572*x^10 + ...
%e A396102 where A( A(A(x))/A(x) - 1 ) = x.
%e A396102 The third iteration of g.f. A(x) begins
%e A396102 A(A(A(x))) = x + 3*x^2 + 0*x^3 + 9*x^4 - 69*x^5 + 621*x^6 - 6297*x^7 + 70077*x^8 - 840984*x^9 + 10752513*x^10 + ...
%e A396102 where A(A(A(x))) = (1+x) * A(A(x)).
%e A396102 The series R(x) = A(A(x))/A(x) - 1 satisfies A(R(x)) = x and begins
%e A396102 R(x) = x - x^2 + 4*x^3 - 25*x^4 + 199*x^5 - 1855*x^6 + 19387*x^7 - 221407*x^8 + 2717782*x^9 + ... + (-1)^(n-1)*A140094(n)*x^n + ...
%e A396102 where R(x) = x/(1 + R(R(R(x)))).
%o A396102 (PARI) \\ From A(x) = x + x*R(R(x)), R(A(x)) = x:
%o A396102 {a(n) = my(A=x, R); for(k=1,n, R = serreverse(A +x*O(x^k));
%o A396102 A = x + x*subst(R,x,R) +x*O(x^k); ); polcoef(GF=A,n)}
%o A396102 {upto(n) = a(n); Vec(GF)}
%o A396102 upto(25)
%Y A396102 Cf. A140094.
%K A396102 sign,new
%O A396102 1,3
