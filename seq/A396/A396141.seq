%I A396141 #5 May 18 2026 10:15:07
%S A396141 15552,2963088,201745589625,1613964717000,6560109033424,
%T A396141 177122943902448,820013629178000,22140367987806000,
%U A396141 3118893758274419229006000,122585000275217773376851824,171139938304033931934017232
%N A396141 Cubefull numbers whose sum of cubefull divisors is a cubefull number that is larger than 1.
%C A396141 If k is a term, then k*m is a term in A396140 for any cubefree number m that is coprime to k.
%C A396141 Any term in A396140 is of the form k*m where k is a term in this sequence and m is a cubefree number coprime to k. Therefore, A396140 can be generated from this sequence by multiplying with coprime cubefree numbers, and the asymptotic density of A396140 can be evaluated from the terms in this sequence (see the Comments section of A396140).
%C A396141 a(12) > 10^28, if it exists.
%e A396141 15552 = 2^6 * 3^5 is a term since it is a cubefull number (A036966), and A385005(15552) = 42592 = 2^5 * 11^3 is also a cubefull number.
%o A396141 (PARI) s(f) = {prod(i = 1, #f~, (f[i, 1]^(f[i, 2]+1) - 1)/(f[i, 1] - 1) - f[i, 1] - if(f[i, 2] > 1, f[i, 1]^2)); }
%o A396141 isok(k) = {my(f = factor(k), s1 = s(f)); s1 > 1 && vecmin(f[, 2]) > 2 && vecmin(factor(s1)[, 2]) > 2; }
%Y A396141 Intersection of A036966 and A396140.
%Y A396141 Cf. A002117, A004709, A349109, A385005.
%K A396141 nonn,more,new
%O A396141 1,1
%A A396141 _Amiram Eldar_, May 18 2026
