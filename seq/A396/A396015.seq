%I A396015 #38 Jun 26 2026 23:05:38
%S A396015 11,22,23,25,41,44,46,50,53,55,59,67,69,77,82,83,85,88,91,92,100,106,
%T A396015 110,113,118,123,129,134,137,138,143,149,154,159,160,161,163,164,166,
%U A396015 167,169,170,176,177,182,184,187,200,201,205,207,209,212,220,226,231,233,236,241,243,246,249,253,256,257,258,261,263,265
%N A396015 Numbers k such that A018804(k) = A018804(k - i) for some 1 <= i < k.
%C A396015 A018804(k) = A018804(k - i) requires k == (k - i) (mod 2), implying i must be an even number.
%e A396015 k = 11: A018804(11) = A018804(9) for i = 2, thus 11 is a term.
%t A396015 f[p_, e_] := (e*(p - 1)/p + 1) * p^e; pil[n_] := pil[n] = Times @@ f @@@ FactorInteger[n]; Select[Range[2, 265], MemberQ[Array[pil, #-1], pil[#]] &] (* _Amiram Eldar_, Jun 17 2026 *)
%o A396015 (Python)
%o A396015 from itertools import count, islice
%o A396015 from math import prod
%o A396015 from sympy import factorint
%o A396015 def A396015_gen(): # generator of terms
%o A396015     s = set()
%o A396015     for n in count(1):
%o A396015         a = prod(p**(e-1)*((p-1)*e+p) for p, e in factorint(n).items())
%o A396015         if a in s:
%o A396015             yield n
%o A396015         s.add(a)
%o A396015 A396015_list = list(islice(A396015_gen(),30)) # _Chai Wah Wu_, Jun 17 2026
%Y A396015 Cf. A018804.
%K A396015 nonn
%O A396015 1,1
%A A396015 _Ctibor O. Zizka_, Jun 16 2026
