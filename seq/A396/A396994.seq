%N A396994 Square array A(n,k), n >= 1, k >= 0, read by antidiagonals downwards, where column k is the expansion of B^k(x), where B(x) is the g.f. of A378575.
%H A396994 Seiichi Manyama, <a href="/A396994/b396994.txt">Antidiagonals n = 1..140, flattened</a>
%F A396994 G.f. B(x) satisfies B(x) = x*(1 + B^l(x)), where B^l(x) denotes the l-th iterate of B.
%F A396994 Let a(n,k,l) = [x^n] B^k(x), where B^k(x) is the k-th iterate of B.
%F A396994 a(n,0,l) = 0^(n-1) and a(n,k,l) = a(n,k-1,l) + Sum_{j=1..n-1} a(j,k+l-1,l) * a(n-j,k-1,l) for k > 0.
%F A396994 A(n,k) = a(n,k,5).
%e A396994 Square array begins:
%e A396994   1,    1,     1,     1,     1,      1,      1, ...
%e A396994   0,    1,     2,     3,     4,      5,      6, ...
%e A396994   0,    5,    12,    21,    32,     45,     60, ...
%e A396994   0,   45,   116,   219,   360,    545,    780, ...
%e A396994   0,  545,  1460,  2885,  4984,   7945,  11980, ...
%e A396994   0, 7945, 21820, 44483, 79648, 132005, 207340, ...
%e A396994   ...
%Y A396994 Column k=1 gives A378575.
%Y A396994 Column k=5 gives A378575(n+1).
