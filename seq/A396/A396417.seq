%U A396417 157873144335654,1768941777054026,19958280341201247,226582168902720276,2586743891050815135,29680684495369145698,342124733923224618231
%N A396417 Expansion of F_3(x)/x, where F_k(x) is the k-th iteration of x*G4(x) with G4(x) = 1 + x*G4(x)^4.
%F A396417 G.f.: (1/x) * Series_Reversion( H_3(x) ), where H_k(x) is the k-th iteration of x*(1 - x*G3(x)^2) with G3(x) = 1 + x*G3(x)^3.
%F A396417 a(n) = Sum_{0 = x_0 <= x_1 <= x_2 <= x_3 = n} Product_{k=0..2} (x_k + 1) * binomial(4*x_{k+1} - 3*x_k + 1,x_{k+1} - x_k)/(4*x_{k+1} - 3*x_k + 1).
%F A396417 a(n) = Sum_{k=0..n} (k+1) * binomial(4*n-3*k+1,n-k)/(4*n-3*k+1) * A396416(k).
%o A396417 (PARI)
%o A396417 lista(nn, k=3, p=4) = {
%o A396417   my(T=matrix(nn+1, nn+1, row, col, my(xr=row-1, xc=col-1); if(xc<xr, 0, (xr+1)*binomial(p*xc-(p-1)*xr+1, xc-xr)/(p*xc-(p-1)*xr+1))));
%o A396417   my(TK=T^k);
%o A396417   TK[1, ];
%o A396417 };
%Y A396417 Column k=3 of A396413.
%Y A396417 Cf. A001764, A002293, A396416.
