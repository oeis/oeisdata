%U A396263 2677834974477935233005523937,43881686326238030953299581260769,1438046780187215577831515887315227617
%N A396263 G.f. A(x) satisfies: A(x) = 1 + x * A(2*x)^2 / (1 - x).
%F A396263 a(0) = 1, for n > 0: a(n) = Sum_{j=0..n-1} Sum_{i=0..j} 2^j * a(i) * a(j-i).
%F A396263 a(n) ~ c * 2^(n*(n+1)/2), where c = 1.08196521469192597073952596757584721975493255637537195949... - _Vaclav Kotesovec_, May 26 2026
%t A396263 nmax = 15; A[_] = 0; Do[A[x_] = 1 + x A[2 x]^2/(1 - x) + O[x]^(nmax + 1) // Normal, nmax + 1]; CoefficientList[A[x], x]
%t A396263 (* Alternative: *)
%t A396263 a[0] = 1; a[n_] := a[n] = Sum[Sum[2^j a[i] a[j - i], {i, 0, j}], {j, 0, n - 1}]; Table[a[n], {n, 0, 15}]
%Y A396263 Cf. A002212, A015083, A028362, A135867.
%K A396263 nonn
