%S A396056 16,33,50,67,84,86,102,119,136,153,170,173,188,205,222,239,256,260,
%T A396056 274,275,292,309,326,343,348,361,378,395,412,429,435,447,464,481,498,
%U A396056 515,522,533,550,551,568,585,602,610,620,637,654,671,673,689,698,707,724
%N A396056 Numbers not of the form Sum_{k=1..m} floor(m/k^4).
%C A396056 Complement of A013938.
%H A396056 Chai Wah Wu, <a href="/A396056/b396056.txt">Table of n, a(n) for n = 1..10000</a>
%t A396056 Complement[Range[Last[#]], #] &@ Table[Sum[Floor[n/k^4], {k, n}], {n, 700}] (* _Michael De Vlieger_, May 16 2026 *)
%o A396056 (Python)
%o A396056 # uses Python function from A013938
%o A396056 from itertools import count, islice
%o A396056 def A396056_gen(): # generator of terms
%o A396056     c = 0
%o A396056     for i in count(0):
%o A396056         if (m:=A013938(i))!=i+c:
%o A396056             for j in range(i+c,m):
%o A396056                 yield j
%o A396056             c = m-i
%o A396056 A396056_list = list(islice(A396056_gen(), 60))
%Y A396056 Cf. A013938, A396046.
%K A396056 nonn
%O A396056 1,1
%A A396056 _Chai Wah Wu_, May 14 2026
