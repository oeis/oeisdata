%N A396891 Convolution of A001157 and A000219.
%F A396891 G.f.: Sum_{j>=1} (j^2*x^j/(1-x^j)) / Product_{k>=1} (1-x^k)^k.
%F A396891 a(n) ~ zeta(3)^(7/36) * exp(1/12 + 3*zeta(3)^(1/3)*n^(2/3)/2^(2/3)) * n^(11/36) / (A * 2^(11/36) * sqrt(3*Pi)), where A is the Glaisher-Kinkelin constant (A074962).
%t A396891 nmax = 40; CoefficientList[Series[Sum[j^2*x^j/(1-x^j),{j,1,nmax}] / Product[(1-x^k)^k, {k,1,nmax}], {x, 0, nmax}], x]
