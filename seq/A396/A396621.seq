%N A396621 a(n) = r(n,n), where r(1,k)=f(k)=round(k*c), r(n,k)=f(r(n-1,k)), c=Pi.
%C A396621 a(n + 1)/a(n) approaches c erratically.
%t A396621 c = Pi; f[k_] := f[k] = Round[c*k];
%t A396621 r[1, k_] := f[k]; r[n_, k_] := r[n, k] = f[r[n - 1, k]];
%t A396621 Table[r[n, n], {n, 1, 100}]
