%T A396907 240,120,226,932,1936,2972,3510,2760,1800,720,1532,6496,16568,27496,
%U A396907 36036,36120,26040,15120,5040,11880,54472,149136,286816,406056,464184,409920,272160,141120,40320
%N A396907 Triangular array T(n, k) of coefficients of the "Mish" activation function that is used in machine learning. Mish(x) = x*tan(log(1+exp(x))) = x*Sum_{n>=0} x^n*Sum_{k=0..n}t^k*T(n, k)/(k!*2^k), where t = tan(log(2)).
%H A396907 Diganta Misra, <a href="https://arxiv.org/abs/1908.08681">Mish: A Self Regularized Non-Monotonic Activation Function</a>, arXiv:1908.08681 [cs.LG], 2019-2020.
%F A396907 T(n, 0) = A009640(n+1)*(-1)^n, for n > 0.
%F A396907 T(n, n) = (n-1)!, for n > 0.
%F A396907 T(n, n-1) = A001286(n-1), for n > 2.
%F A396907 T(n+1, k) = Sum_{m=0..n} ( ((k+1) * T(n-m, k+1) + (k-1) * T(n-m, k-1)) * 2^(m+1) * mu(m) * (-n! * (m-n) / (n*(n-m)!)) ), for n >0 with mu(0) = 1/2, mu(m) = 0 if m is even else mu(m) = (2^(m+1)-1) * B(m+1) / (m+1)! where B(m) is the m-th Bernoulli number A027641(m)/A027642(m).
%F A396907 Some exact expressions for Sum_{k=0..n} t^k*T(n, k)/(k!*2^k):
%F A396907   n=1: tan(log(2))
%F A396907   n=2: (1/2)*sec(log(2))^2
%F A396907   n=3: (1/8)*(1+2*tan(log(2)))*sec(log(2))^2
%F A396907   n=4: (1/48)*(4+3*sin(log(4))-2*cos(log(4)))*sec(log(2))^4
%F A396907   n=5: (1/768)*(47*sin(log(2))-sin(log(8))+33*cos(log(2))-13*cos(log(8)))*sec(log(2))^5.
%e A396907 The triangle begins:
%e A396907   n | k=[0]   [1]    [2]    [3]    [4]    [5]    [6]   [7]    [8]
%e A396907  [0]     0
%e A396907  [1]     0,    1
%e A396907  [2]     1,    0,     1
%e A396907  [3]     1,    2,     1,     2
%e A396907  [4]     2,    6,     8,     6,     6
%e A396907  [5]    10,   22,    46,    46,    36,    24
%e A396907  [6]    46,  140,   256,   380,   330,   240,   120
%e A396907  [7]   226,  932,  1936,  2972,  3510,  2760,  1800,   720
%e A396907  [8]  1532, 6496, 16568, 27496, 36036, 36120, 26040, 15120, 5040
%e A396907  ...
%e A396907 x*tan(log(1+exp(x))) = x  *0.83064087786...
%e A396907                      + x^2*0.84498213398...
%e A396907                      + x^3*0.56218388427...
%e A396907                      + x^4*0.39163622310...
%e A396907                      ...
%e A396907                      = x  * t
%e A396907                      + x^2*(t^2 + 1)
%e A396907                      + x^3*(t^3 + 2*t^2 + t + 2)/2
%e A396907                      ...
%e A396907                      with t = tan(log(2)) = 0.83064087786...
%o A396907 (PARI)
%o A396907 T(n, k) = my(u(x) = log(cosh(x/2) + O(x^(n+1))) + x/2); if(n<1, 0, polcoeff(Vec((t + tan(u(x))) / (1 - t*tan(u(x))))[n]*(n-1)!*2^(n-1),k));
%Y A396907 Cf. A009640, A001286, A027641, A027642.
