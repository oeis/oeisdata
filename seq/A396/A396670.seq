%S A396670 4,11,16,38,68,151,312,684,1476,3293,7280,16358,36788,83311,189120,
%T A396670 431392,986244,2262307,5200848,11985862,27676612,64034953,148406240,
%U A396670 344507804,800902876,1864502925,4346071600,10142619038,23696518916,55420734751,129742923472
%N A396670 Binary colorings of the sunlet graph S_n up to rotation, with no monochromatic connected component of size 3 or more.
%C A396670 The sunlet graph S_n is obtained from the cycle C_n by attaching one pendant vertex to each cycle vertex.  Thus S_n has 2n vertices.
%C A396670 This is the rotation-only version.  Reflected colorings are not identified.
%C A396670 Equivalently, runs of equal colors around the cycle have length at most 2.  A pendant vertex attached to a cycle vertex in a run of length 2 is forced to have the opposite color, a pendant vertex attached to an isolated cycle vertex is free.
%H A396670 Robert P. P. McKone, <a href="/A396670/a396670.txt">The rotation-class representative Sunlets a(3) to a(11)</a>.
%H A396670 Robert P. P. McKone, <a href="/A396670/a396670.png">a(3) = 4 Sunlet Graphs</a>.
%H A396670 Robert P. P. McKone, <a href="/A396670/a396670_1.png">a(4) = 11 Sunlet Graphs</a>.
%H A396670 Robert P. P. McKone, <a href="/A396670/a396670_2.png">a(5) = 16 Sunlet Graphs</a>
%H A396670 Robert P. P. McKone, <a href="/A396670/a396670_3.png">a(6) = 38 Sunlet Graphs</a>.
%H A396670 Robert P. P. McKone, <a href="/A396670/a396670_4.png">a(7) = 68 Sunlet Graphs</a>.
%H A396670 Robert P. P. McKone, <a href="/A396670/a396670_5.png">a(8) = 151 Sunlet Graphs</a>.
%H A396670 Robert P. P. McKone, <a href="/A396670/a396670_6.png">a(9) = 312 Sunlet Graphs</a>.
%H A396670 Robert P. P. McKone, <a href="/A396670/a396670_7.png">a(10) = 684 Sunlet Graphs</a>.
%H A396670 Robert P. P. McKone, <a href="/A396670/a396670_8.png">a(11) = 1476 Sunlet Graphs</a>.
%H A396670 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/SunletGraph.html">Sunlet Graph</a>
%F A396670 a(n) = (1/n) * Sum_{d|n} (phi(n/d) * ((1+sqrt(2))^d + (1-sqrt(2))^d + 2*(-1)^d)).
%e A396670 Binary sunlet colorings up to rotation.  No monochromatic component has size 3 or more.  Blocks are rl around the cycle, ring color, then pendant color.
%e A396670 The a(3) = 4 rotation-class representative sunlets, {00,10,10}, {01,01,10}, {01,10,10}, {01,01,11}
%t A396670 a[n_] := Simplify[Sum[EulerPhi[n/d] ((1 + Sqrt[2])^d + (1 - Sqrt[2])^d + 2 (-1)^d), {d, Divisors[n]}]/n];
%t A396670 Table[a[n], {n, 3, 33}]
%Y A396670 Cf. A001868 (the total number of binary Sunlet colorings up to rotation before applying the restriction).
%K A396670 nonn,new
%O A396670 3,1
%A A396670 _Robert P. P. McKone_, Jun 02 2026
