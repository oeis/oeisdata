%S A396495 2,179,1347569,1866239,1985939,3426119,3825359,5100479,6698339,
%T A396495 7774829,7848089,8522009,9791459,9891809,9975599,10325879,13343579,
%U A396495 13575869,14337539,19826099,21306149,22082939,22213979,23344199,38984579,42733079,43546859,43853219,45031139
%N A396495 Primes p such that (4*p+1)/3, 2*p+1, (8*p+5)/3, 4*p+3, and 8*p+7 are all primes.
%C A396495 Any occurrence of 4 consecutive numbers in A395563, indices of 2 in A395473, is of the form (8*p+4, 8*p+5, 8*p+6, 8*p+7) exactly for p being in this sequence.
%C A396495 Terms other than 2 are congruent to 89 modulo 90.
%H A396495 Jianing Song, <a href="/A396495/b396495.txt">Table of n, a(n) for n = 1..10001</a>
%e A396495 For p = 179, (p, (4*p+1)/3, 2*p+1, (8*p+5)/3, 4*p+3, 8*p+7) = (179, 239, 359, 479, 719, 1439) are all primes. This corresponds to the 4 consecutive members (1436, 1437, 1438, 1439) in A395563.
%e A396495 For p = 1347569, (1347569, 1796759, 2695139, 3593519, 5390279, 10780559) are all primes. This corresponds to the 4 consecutive members (10780556, 10780557, 10780558, 10780559) in A395563.
%o A396495 (PARI) isA396495(p) = if(p%90==89, return(isprime(p) && isprime((4*p+1)/3) && isprime(2*p+1) && isprime((8*p+5)/3) && isprime(4*p+3) && isprime(8*p+7)), return(p==2))
%Y A396495 Cf. A396497 ({(p+1)/90}), A395473, A395563.
%K A396495 nonn
%O A396495 1,1
%A A396495 _Jianing Song_, May 28 2026
