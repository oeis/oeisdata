%I A396838 #18 Jun 19 2026 05:07:42
%S A396838 1,1,4,60,1632,65520,3544704,245996352,21235046400,2231325626112,
%T A396838 280674838195200,41685638070675456,7223877813760376832,
%U A396838 1445606308428682383360,331007654838657386741760,86017381995940934610124800,25183998396340800570318127104,8252981111215440504122897793024
%N A396838 G.f. A(x) satisfies (n+1)^2 * a(n) = n*(n+2)/2 * [x^n] A(x)^2 for n > 1.
%C A396838 The limit lim_{n->oo} a(n)/(n+1)!^2 appears to exist. At n = 1000, a(1000)/1001!^2 = 0.2396940540...
%C A396838 This constant is equal to 0.24041409853935500572940313545953342... - _Vaclav Kotesovec_, Jun 19 2026
%H A396838 Paul D. Hanna, <a href="/A396838/b396838.txt">Table of n, a(n) for n = 0..300</a>
%F A396838 G.f. A(x) = Sum_{n>=0} a(n)*x^n satisfies the following formulas.
%F A396838 (1) n*(n+2)/2 * [x^n] A(x)^2 = (n+1)^2 * a(n) for n > 1.
%F A396838 (2) A(x) = B(x*A(x)) where B(x) = A(x/B(x)) is the g.f. of A396808 and (n+1) * [x^n] B(x)^(n+1) = n * [x^n] B(x)^(n+2) for n > 1.
%F A396838 (3) a(n) = n*(n+2)/2 * Sum_{k=1..n-1} a(k)*a(n-k) for n > 1, with a(0) = a(1) = 1.
%e A396838 G.f.: A(x) = 1 + x + 4*x^2 + 60*x^3 + 1632*x^4 + 65520*x^5 + 3544704*x^6 + 245996352*x^7 + 21235046400*x^8 + ...
%e A396838 The square of the g.f. A(x) begins
%e A396838 A(x)^2 = 1 + 2*x + 9*x^2 + 128*x^3 + 3400*x^4 + 134784*x^5 + 7237104*x^6 + 499802112*x^7 + ... + A396839(n)*x^n + ...
%e A396838 where (n+1)^2 * a(n) = n*(n+2)/2 * A396839(n) like so
%e A396838   n = 2: 3^2 * 4 = 2*4/2 * 9,
%e A396838   n = 3: 4^2 * 60 = 3*5/2 * 128,
%e A396838   n = 4: 5^2 * 1632 = 4*6/2 * 3400,
%e A396838   n = 5: 6^2 * 65520 = 5*7/2 * 134784,
%e A396838   n = 6: 7^2 * 3544704 = 6*8/2 * 7237104,
%e A396838   n = 7: 8^2 * 245996352 = 7*9/2 * 499802112,
%e A396838   ...
%e A396838 Let B(x) be the g.f. of A396808, then
%e A396838 B(x) = 1 + x + 3*x^2 + 50*x^3 + 1395*x^4 + 57174*x^5 + 3142174*x^6 + 220805892*x^7 +  ... + A396808(n)*x^n + ...
%e A396838 where A(x) = B(x*A(x)) and B(x) = A(x/B(x)).
%o A396838 (PARI) \\ by definition (faster)
%o A396838 \\ returns vector of terms a(k) for k = 0..n
%o A396838 {a(n) = my(A=[1,1],m); for(i=1,n-1, A=concat(A,0); m=#A-1;
%o A396838 A[#A] = m*(m+2)/2 * polcoef(Ser(A)^2,m) ); A}
%o A396838 (PARI) \\ by recurrence (slower)
%o A396838 \\ print terms a(n) for n = 0..N
%o A396838 N = 20; A = vector(N+1);
%o A396838 {a(n) = A[n+1] = if(n<=1,1, n*(n+2)/2 * sum(k=1,n-1, a(k)*A[n-k+1]) )}
%o A396838 for(n=0,N, print1(a(n),", "))
%Y A396838 Cf. A396808, A396839.
%K A396838 nonn,new
%O A396838 0,3
%A A396838 _Paul D. Hanna_, Jun 18 2026
