%N A396395 a(n) = r(n,n), where r(1,k)=f(k)=round(k*c), r(n,k)=f(r(n-1,k)), c=(golden ratio)^2.
%C A396395 a(n + 1)/a(n) approaches c erratically.
%t A396395 c = GoldenRatio^2; f[k_] := f[k] = Round[c*k];
%t A396395 r[1, k_] := f[k]; r[n_, k_] := r[n, k] = f[r[n - 1, k]];
%t A396395 Table[r[n, n], {n, 1, 100}]
%Y A396395 Cf. A001622, A396385, A396390, A396393, A396394.
%K A396395 nonn
%O A396395 1,1
