%S A396795 1,5,-70,1540,-40305,1145350,-33764670,1002904355,-29325546100,
%T A396795 824787148730,-21655278144150,504085712482025,-9110922206439115,
%U A396795 51615623352237805,5805174966525591420,-393909525063709467300,17748880527870548493930,-678107727343251230458305,23585780107356637540576615
%N A396795 G.f. A(x) satisfies A^2(x) * A^3(x) = x^2 + 25*x^3, where A^n(x) is the n-th iteration of A(x).
%C A396795 Conjecture: a(n) == 0 (mod 5) for n > 1.
%H A396795 Paul D. Hanna, <a href="/A396795/b396795.txt">Table of n, a(n) for n = 1..400</a>
%F A396795 G.f. A(x) = Sum_{n>=1} a(n)*x^n satisfies the following formulas.
%F A396795 (1) A(A(x)) * A(A(A(x))) = x^2 + 25*x^3.
%F A396795 (2) A(x) * A(A(x)) = R(x)^2 + 25*R(x)^3 where R(A(x)) = x.
%F A396795 (3) A^4(x) = A(A(x)) * (A(x)^2 + 25*A(x)^3) / (x^2 + 25*x^3).
%F A396795 (4) A^5(x) = (x^2 + 25*x^3) * (A(A(x)) + 25*A(A(x))^2) / (A(x)^2 + 25*A(x)^3).
%e A396795 G.f.: A(x) = x + 5*x^2 - 70*x^3 + 1540*x^4 - 40305*x^5 + 1145350*x^6 - 33764670*x^7 + 1002904355*x^8 - 29325546100*x^9 + ...
%e A396795 RELATED SERIES.
%e A396795 The second and third iterations of g.f. A(x) begin
%e A396795 A(A(x)) = x + 10*x^2 - 90*x^3 + 1455*x^4 - 28460*x^5 + 596175*x^6 - 12421140*x^7 + 237680760*x^8 - 3533765950*x^9 + ...
%e A396795 A(A(A(x))) = x + 15*x^2 - 60*x^3 + 495*x^4 - 3715*x^5 - 275*x^6 + 719090*x^7 - 3315785*x^8 - 1079273300*x^9 + ...
%e A396795 where A(A(x)) * A(A(A(x))) = x^2 + 25*x^3.
%e A396795 The series reversion of A(x) begins
%e A396795 R(x) = x - 5*x^2 + 120*x^3 - 3915*x^4 + 146705*x^5 - 5940875*x^6 + 252484370*x^7 - 11079968555*x^8 + 497165223600*x^9 + ...
%e A396795 where A(x) * A(A(x)) = R(x)^2 + 25*R(x)^3.
%o A396795 (PARI) {a(n) = my(V=[0,1,5],A); for(i=1,n, V=concat(V,0); A=Ser(V);
%o A396795 V[#V] = -polcoef(subst(A,x,A) * subst(A,x,subst(A,x,A)), #V)/5; ); polcoef(GF=A,n)}
%o A396795 {upto(n) = a(n); Vec(GF)}
%o A396795 upto(25)
%Y A396795 Cf. A396793, A396794.
%K A396795 sign
