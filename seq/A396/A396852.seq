%U A396852 352,361,368,384,392,400,405,416,432,448,464,486,496,500,512,529,544,567,576,592
%N A396852 Numbers k such that bigomega(k) > omega(k)^2.
%H A396852 Alois P. Heinz, <a href="/A396852/b396852.txt">Table of n, a(n) for n = 1..20000</a>
%p A396852 q:= n-> (l-> is(add(i, i=l)>nops(l)^2))(ifactors(n)[2][.., 2]):
%p A396852 select(q, [$1..600])[];  # _Alois P. Heinz_, Jun 23 2026
%p A396852 # Alternative:
%p A396852 omega := n -> NumberTheory:-NumberOfPrimeFactors(n, 'distinct'):
%p A396852 bigomega := n -> NumberTheory:-NumberOfPrimeFactors(n):
%p A396852 select(n -> bigomega(n) > omega(n)^2, [seq(1..600)]);  # _Peter Luschny_, Jun 23 2026
%t A396852 A396852Q[k_] := Plus @@ # > Length[#]^2 & [FactorInteger[k][[All, 2]]];
%t A396852 Select[Range[1000], A396852Q] (* _Paolo Xausa_, Jun 24 2026 *)
%o A396852 (PARI) is_a396852(k) = bigomega(k) > omega(k)^2
