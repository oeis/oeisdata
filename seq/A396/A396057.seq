%N A396057 a(1)=1; if a(n-1) is odd then a(n) = a(n-1)*2+2; if a(n-1) is even then a(n) = a(n-1)/2 if not already in the sequence, otherwise a(n) = a(n-1)+1.
%C A396057 With these rules, no number will ever repeat, and every positive integer will appear eventually.
%t A396057 a[1] = 1; a[n_] := a[n] = If[OddQ[a[n-1]], 2*a[n-1] + 2, If[FreeQ[Array[a, n-1], a[n-1]/2], a[n-1]/2, a[n-1] + 1]]; Array[a, 67] (* _Amiram Eldar_, May 22 2026 *)
%o A396057 (Python)
%o A396057 def next_value(x, seen):
%o A396057     # Rule 2: odd -> 2x + 2
%o A396057     if x % 2 == 1:
%o A396057         return 2 * x + 2
%o A396057     # Rule 3: even -> x/2
%o A396057     half = x // 2
%o A396057     # Rule 4: but if x/2 already appeared -> x + 1 instead
%o A396057     if half in seen:
%o A396057         return x + 1
%o A396057     return half
%o A396057 def generate_sequence(limit):
%o A396057     seq = [1]
%o A396057     seen = {1}
%o A396057     while len(seq) < limit:
%o A396057         x = seq[-1]
%o A396057         nxt = next_value(x, seen)
%o A396057         seq.append(nxt)
%o A396057         seen.add(nxt)
%o A396057     return seq
%o A396057 print(generate_sequence(70))
