%S A396064 1,2,6,15,25,43,54,76,138,170,227,262,298,361,420,492,577,689,818,898,
%T A396064 964,1057,1130,1297,1439,1459,1639,1749,1892,2237,2585,2703,2902,3091,
%U A396064 3474,3933,4016,4305,4630,4999,5216,5427,5885,6151,6425,7052,7156,8073
%N A396064 Lexicographically earliest sequence, where for every term-pair the sum, difference and product is unique.
%o A396064 (Python)
%o A396064 def generate_sequence(length):
%o A396064     sequence = []
%o A396064     used_values = set()
%o A396064     candidate = 1
%o A396064     while len(sequence) < length:
%o A396064         is_valid = True
%o A396064         candidate_values = set()
%o A396064         for element in sequence:
%o A396064             s = candidate + element
%o A396064             d = candidate - element
%o A396064             p = candidate * element
%o A396064             pairs = {s, d, p}
%o A396064             if len(pairs) < 3 or not pairs.isdisjoint(used_values) or not pairs.isdisjoint(candidate_values):
%o A396064                 is_valid = False
%o A396064                 break
%o A396064             candidate_values.update(pairs)
%o A396064         if is_valid:
%o A396064             sequence.append(candidate)
%o A396064             used_values.update(candidate_values)
%o A396064         candidate += 1
%o A396064     return sequence
%Y A396064 Cf. A025582, A126428.
%K A396064 nonn
