%S A396840 1,1,1,1,4,1,1,27,27,1,1,256,1728,256,1,1,3125,200000,200000,3125,1,1,
%T A396840 46656,36450000,345600000,36450000,46656,1,1,823543,9605805552,
%U A396840 1111783050000,1111783050000,9605805552,823543,1,1,16777216,3454189699072,5968839799996416,72861813964800000,5968839799996416,3454189699072,16777216,1
%N A396840 Triangle of numbers T(n,k) = H(n)/(H(k)*H(n-k)) read by rows as k = 0..n for row n >= 0, where H(n) = Product_{k=0..n} k^k is the hyperfactorial of n (A002109).
%H A396840 Paul D. Hanna, <a href="/A396840/b396840.txt">Table of n, a(n) for n = 0..860 (rows 0..40)</a>
%F A396840 T(n,k) = H(n)/(H(k)*H(n-k)) for n >= 0, k = 0..n, where H(n) = Product_{k=0..n} k^k is the hyperfactorial of n (A002109) (definition).
%F A396840 T(n,k) = Product_{j=1..k} (n+1-j)^(n+1-j) / j^j for n >= 0.
%F A396840 G.f. A(x,y) = E(x)*E(y) = Sum_{n>=0} Sum_{k=0..n} T(n,k)*x^(n-k)*y^k/H(n) where E(z) = Sum_{n>=0} z^n/H(n), so that T(n,k) = H(n) * [x^(n-k)*y^k] E(x)*E(y) for n >= 0, k = 0..n.
%e A396840 This triangle of coefficients T(n,k) of x^(n-k)*y^k/H(n) in g.f. A(x,y) begins
%e A396840   1;
%e A396840   1, 1;
%e A396840   1, 4, 1;
%e A396840   1, 27, 27, 1;
%e A396840   1, 256, 1728, 256, 1;
%e A396840   1, 3125, 200000, 200000, 3125, 1;
%e A396840   1, 46656, 36450000, 345600000, 36450000, 46656, 1;
%e A396840   1, 823543, 9605805552, 1111783050000, 1111783050000, 9605805552, 823543, 1;
%e A396840 ...
%e A396840 GENERATING FUNCTION.
%e A396840 Let E(z) = Sum_{n>=0} z^n/H(n) = 1 + z + z^2/4 + z^3/108 + z^4/27648 + z^5/86400000 + z^6/4031078400000 + z^7/3319766398771200000 + ...
%e A396840 then
%e A396840 g.f. A(x,y) = E(x)*E(y) = 1 + (1*x + 1*y)/H(1) + (1*x^2 + 4*x*y + 1*y^2)/H(2) + (1*x^3 + 27*x^2*y + 27*x*y^2 + 1*y^3)/H(3) + (1*x^4 + 256*x^3*y + 1728*x^2*y^2 + 256*x*y^3 + 1*y^4)/H(4) + (1*x^5 + 3125*x^4*y + 200000*x^3*y^2 + 200000*x^2*y^3 + 3125*x*y^4 + 1*y^5)/H(5) + ...
%o A396840 (PARI) \\ by definition
%o A396840 {H(n) = prod(k=1,n,k^k)} \\ hyperfactorial of n
%o A396840 {T(n,k) = H(n)/(H(k)*H(n-k))}
%o A396840 \\ print the triangle
%o A396840 for(n=0,10, for(k=0,n, print1(T(n,k),", "));print(""))
%o A396840 (PARI) \\ by g.f. A(x,y) = E(x)*E(y)
%o A396840 {H(n) = prod(k=1,n,k^k)} \\ hyperfactorial of n
%o A396840 {E(z,N) = sum(n=0,N, z^n/H(n)) + z*O(z^N)}
%o A396840 {T(n,k) = H(n) * polcoef( polcoef( E(x,n)*E(y,n), n-k,x), k,y)}
%o A396840 \\ print the triangle
%o A396840 for(n=0,10, for(k=0,n, print1(T(n,k),", "));print(""))
%Y A396840 Cf. A396841 (row sums), A396842 (central terms), A002109, A193520.
%K A396840 nonn,tabl
%O A396840 0,5
%A A396840 _Paul D. Hanna_, Jul 05 2026
