%I A396569 #20 Jun 29 2026 11:03:39
%S A396569 0,1,4,16,66,270,1106,4530,18554,75994,311258,1274858,5221594,
%T A396569 21386730,87596282,358778954,1469495450,6018794730,24651923898,
%U A396569 100969941514,413555109594,1693848942634,6937707149306,28415627437642,116385408795418
%N A396569 Number of ways to tile a rectangular strip of length n, ending in a triangle, with three types of tiles.
%C A396569 a(n) counts the number of ways to tile this strip of length n
%C A396569    _________________       __
%C A396569   |  |  |  |  |  |  | ... |  |\
%C A396569   |__|__|__|__|__|__| ... |__|_\
%C A396569 with these three types of tiles (made up of one, two, and three right triangles)
%C A396569                ___
%C A396569   |\    / \   |   \
%C A396569   |_\, /___\, |____\.
%C A396569 See A397302 for the companion sequence which counts the same type of tilings but for a rectangular strip.
%H A396569 <a href="/index/Rec#order_03">Index entries for linear recurrences with constant coefficients</a>, signature (3,4,2).
%F A396569 a(n) = 3*a(n-1) + 4*a(n-2) + 2*a(n-3).
%F A396569 G.f.: x*(1 + x)/(1 - 3*x - 4*x^2 - 2*x^3).
%F A396569 a(n) = A397302(n-1) + a(n-1) + A397302(n-2).
%e A396569 As an example, here is one of the a(4)=66 ways to tile a strip of length 4 ending in a triangle.
%e A396569    _________
%e A396569   |\    | / \
%e A396569   |_\___|/___\
%t A396569 LinearRecurrence[{3, 4, 2}, {0, 1, 4}, 50]
%t A396569 (* Alternative: *)
%t A396569 CoefficientList[Series[x*(1 + x)/(1 - 3*x - 4*x^2 - 2*x^3),{x,0,24}],x] (* _Stefano Spezia_, Jun 27 2026 *)
%Y A396569 Cf. A397302.
%K A396569 nonn,easy,new
%O A396569 0,3
%A A396569 Daniel Bae and _Greg Dresden_, Jun 27 2026
