%I A396652 #12 Jun 02 2026 01:05:53
%S A396652 0,0,0,10,12,32,36,66,72,112,120,170,180,240,252,322,336,416,432,522,
%T A396652 540,640,660,770,792,912,936,1066,1092,1232,1260,1410,1440,1600,1632,
%U A396652 1802,1836,2016,2052,2242,2280,2480,2520,2730,2772,2992,3036,3266,3312,3552,3600,3850,3900,4160,4212,4482,4536,4816,4872
%N A396652 a(n) = (2*n-3-(-1)^n)*(6*n+1-(-1)^n)/8.
%C A396652 Sum of the perimeters of all composite rectangles formed by taking each of the distinct nonsquare L X W integer-sided rectangles with semiperimeter n = L + W, and gluing W X W squares to their widths (see example).
%H A396652 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (1,2,-2,-1,1).
%F A396652 G.f.: 2*x^3*(5+x)/((1-x)^3*(1+x)^2).
%F A396652 a(n) = 2*floor((n-1)/2)*(n+1+floor((n-1)/2)).
%F A396652 a(n) = a(n-1) + 2*a(n-2) - 2*a(n-3) - a(n-4) + a(n-5).
%e A396652 For n = 8, the L X W rectangles with semiperimeter n, including the squares on their widths are:
%e A396652 .
%e A396652      1             2               3
%e A396652      _            ___            _____
%e A396652   1 |_| 1     2  |   |  2       |     |
%e A396652     | |          |___|        3 |     | 3
%e A396652     | |          |   |          |_____|
%e A396652     | |          |   |          |     |
%e A396652   7 | | 7     6  |   |  6       |     |
%e A396652     | |          |   |        5 |     | 5
%e A396652     | |          |   |          |     |
%e A396652     |_|          |___|          |_____|
%e A396652   1 |_| 1     2  |   |  2       |     |
%e A396652                  |___|        3 |     | 3
%e A396652      1                          |_____|
%e A396652                    2
%e A396652                                    3
%e A396652 .
%e A396652 The sum of the perimeters = 20 + 24 + 28 = 72.
%t A396652 Table[(2n - 3 - (-1)^n)*(6n + 1 - (-1)^n)/8, {n, 0, 100}]
%t A396652 CoefficientList[Series[2*x^3*(5 + x)/((1 - x)^3*(1 + x)^2), {x, 0, 100}], x]
%o A396652 (Magma) [(2*n-3-(-1)^n)*(6*n+1-(-1)^n)/8 : n in [0..100]];
%o A396652 (Python)
%o A396652 def A396652(n): return ((n-1)*(3*n+1) if n&1 else 3*n*(n-2))>>1 # _Chai Wah Wu_, Jun 01 2026
