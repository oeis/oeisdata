%I A396197 #16 Jun 04 2026 13:21:31
%S A396197 1,4,-1,5,-8,1,9,-15,12,-1,14,-36,30,-16,1,23,-70,90,-50,20,-1,37,
%T A396197 -138,210,-180,75,-24,1,60,-259,483,-490,315,-105,28,-1,97,-480,1036,
%U A396197 -1288,980,-504,140,-32,1,157,-873,2160,-3108,2898,-1764,756,-180,36,-1
%N A396197 Triangle read by rows: T(n, k) = (-1)^k*binomial(n, k) * (2*F(n - k) + F(n - k + 2)) where F(n) are the Fibonacci numbers.
%H A396197 Paolo Xausa, <a href="/A396197/b396197.txt">Table of n, a(n) for n = 0..11475</a> (rows 0..150 of triangle, flattened).
%F A396197 T(n, k) = (-1)^k*binomial(n, k) * A000285(n - k).
%F A396197 T(n, k) = T(n-1, k) * T(n-k, 0) / T(n-k-1, 0) - T(n-1, k-1), where T(n, 0) = T(n-1, 0) + T(n-2, 0).
%F A396197 T(n, k) = (-1)^k*binomial(n, k) * (mu*phi^(n-k) + nu*psi^(n-k)) where r = sqrt(5), phi = (1+r)/2, psi = (1-r)/2, mu = (r+7)/(2*r), nu = (r-7)/(2*r).
%F A396197 A396584(n) = 2^n * P(n, 1/2) where P(n, x) = Sum_{k=0..n} T(n, k)*x^k.
%F A396197 A048878(n) = 2^n * P(n, -1/2).
%e A396197 Triangle starts:
%e A396197   [0]   1;
%e A396197   [1]   4,   -1;
%e A396197   [2]   5,   -8,    1;
%e A396197   [3]   9,  -15,   12,    -1;
%e A396197   [4]  14,  -36,   30,   -16,   1;
%e A396197   [5]  23,  -70,   90,   -50,  20,   -1;
%e A396197   [6]  37, -138,  210,  -180,  75,  -24,   1;
%e A396197   [7]  60, -259,  483,  -490, 315, -105,  28,  -1;
%e A396197   [8]  97, -480, 1036, -1288, 980, -504, 140, -32, 1;
%p A396197 f := combinat:-fibonacci:
%p A396197 T := (n, k) -> (-1)^k*binomial(n, k)*(2*f(n - k) + f(n - k + 2)):
%p A396197 # Alternative: Binet-type form.
%p A396197 r := sqrt(5): phi := (1+r)/2: psi := (1-r)/2: mu := (r+7)/(2*r): nu := (r-7)/(2*r):
%p A396197 T := (n, k) -> (-1)^k*binomial(n, k)*(mu*phi^(n-k) + nu*psi^(n-k)):
%p A396197 seq(seq(simplify(T(n, k)), k = 0..n), n = 0..8);
%p A396197 # Alternative: recurrence.
%p A396197 T := proc(n, k) option remember; if n = k then return (-1)^n fi;
%p A396197 if k = 0 then return ifelse(n=1, 4, T(n-1,0) + T(n-2, 0)) fi;
%p A396197 T(n - 1, k) * T(n - k, 0) / T(n - k - 1, 0) - T(n - 1, k - 1) end:
%p A396197 seq(print(seq(T(n, k), k = 0..n)), n = 0..8);
%t A396197 A396197[n_, k_] := (-1)^k*Binomial[n, k]*(2*Fibonacci[n-k] + Fibonacci[n-k+2]);
%t A396197 Table[A396197[n, k], {n, 0, 10}, {k, 0, n}] (* _Paolo Xausa_, Jun 04 2026 *)
%o A396197 (Python)
%o A396197 def A396197(num_rows):
%o A396197     A = [1, 4]
%o A396197     for _ in range(num_rows + 1): A.append(A[-1] + A[-2])
%o A396197     tri = [[1]] # T(0,0) = 1
%o A396197     for n in range(1, num_rows):
%o A396197         prev = tri[-1]; row = []
%o A396197         for k in range(n + 1):
%o A396197             a = b = 0
%o A396197             if k < n: a = prev[k] * A[n - k] // A[n - 1 - k]
%o A396197             if k > 0: b = prev[k - 1]
%o A396197             row.append(a - b)
%o A396197         tri.append(row)
%o A396197     return tri
%o A396197 T = A396197(9)
%o A396197 for i, row in enumerate(T):
%o A396197     r = ", ".join(f"{num:5}" for num in row)
%o A396197     print(f"[{i}] {r}")
%Y A396197 Cf. A000045, A000285, A396201 (row sums), A054486 (alternating row sums), A396584, A048878.
