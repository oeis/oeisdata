%S A396926 1,3,2,4,6,8,10,12,14,16,17,11,22,24,26,25,30,32,34,23,33,40,19,44,46,
%T A396926 20,50,52,27,39,49,60,54,62,66,57,70,72,74,35,65,59,47,32,86,43,90,92,
%U A396926 38,96,54,64,102,104,106,83,51,112,114,116,97,104,59,124,126
%N A396926 The smallest k for which the square of at least one integer among {n, n+1, ..., n+k} divides the sum of the remaining integers.
%e A396926 a(2) = 3, because with [2, 3, 4, 5] we obtain 2^2 | 3 + 4 + 5 = 12, and no shorter run of more than one consecutive integer starting at 2 produces such a division.
%e A396926 a(3) = 2, because with [3, 4, 5] we obtain 3^2 | 4 + 5 = 9, and no shorter run of more than one consecutive integer starting at 3 produces such a division.
%e A396926 a(4) = 4, because with [4, 5, 6, 7, 8] we obtain 5^2 | 4 + 6 + 7 + 8 = 25, and no shorter run of more than one consecutive integer starting at 4 produces such a division.
%o A396926 (PARI) isok(k,n) = my(v=vector(k+1, i, n+i-1), s=vecsum(v)); for (i=1, #v, if (!((s-v[i]) % v[i]^2), return(1))); 0;
%o A396926 a(n) = my(k=1); while (!isok(k,n), k++); k; \\ _Michel Marcus_, Jun 10 2026
%Y A396926 Cf. A396377.
%K A396926 nonn,new
%O A396926 1,2
