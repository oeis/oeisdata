%e A396764 6's aliquot divisors are 1, 2, and 3; their average is 2, an integer. Its divisors are 1, 2, 3, 6; their average is 3, also an integer.
%e A396764 30's aliquot divisors are 1, 2, 3, 5, 6, 10, 15; their average is 6, an integer. Its divisors are 1, 2, 3, 5, 6, 10, 15, and 30; their average is 9, also an integer.
%t A396764 q[k_] := CompositeQ[k] && Module[{d, s}, {d, s} = DivisorSigma[{0, 1}, k]; Divisible[s, d] && Divisible[s - k, d - 1]]; Select[Range[510], q] (* _Amiram Eldar_, Jun 05 2026 *)
%o A396764 (Julia)
%o A396764 using Primes
%o A396764 function a(n)
%o A396764     num = 1
%o A396764     count = 0
%o A396764     while count < n
%o A396764         num += 1
%o A396764         if !isprime(num)
%o A396764             list = divisors(num)
%o A396764             if sum(list) % length(list) == 0
%o A396764                 pop!(list)
%o A396764                 if sum(list) % length(list) == 0
%o A396764                     print("$num, ")
%o A396764                     count += 1
%o A396764                 end
%o A396764             end
%o A396764         end
%o A396764     end
%o A396764 end
