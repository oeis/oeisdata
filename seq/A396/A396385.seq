%N A396385 a(n) = r(n,n), where r(1,k)=f(k)=floor(k*c), r(n,k)=f(r(n-1,k)), c=3/2.
%C A396385 a(n + 1)/a(n) approaches c erratically.
%e A396385 (a(n)) is the main diagonal of the rectangular array (r(n,k)), having corner
%e A396385 1   3    4    6    7    9
%e A396385 1   4    6    9   10   13
%e A396385 1   6    9   13   15   19
%e A396385 1   9   13   19   22   28
%t A396385 c = 3/2; f[k_] := f[k] = Floor[c*k];
%t A396385 r[1, k_] := f[k]; r[n_, k_] := r[n, k] = f[r[n - 1, k]];
%t A396385 Table[r[n, n], {n, 1, 100}]
%Y A396385 Cf. A353220, A396386, A396390.
