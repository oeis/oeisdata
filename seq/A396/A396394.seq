%U A396394 12586269025,34787592002,95882625224,258802713816,710505581250,1946395332181,5235312997639
%N A396394 a(n) = r(n,n), where r(1,k)=f(k)=ceiling(k*c), r(n,k)=f(r(n-1,k)), c=(golden ratio)^2.
%C A396394 a(n + 1)/a(n) approaches c erratically.
%t A396394 c = GoldenRatio^2; f[k_] := f[k] = Ceiling[c*k];
%t A396394 r[1, k_] := f[k]; r[n_, k_] := r[n, k] = f[r[n - 1, k]];
%t A396394 Table[r[n, n], {n, 1, 100}]
%Y A396394 Cf. A001622, A396385, A396390, A396393, A396395.
%K A396394 nonn,new
%O A396394 1,1
