%S A396499 1,1,0,1,1,0,1,2,5,0,1,3,14,49,0,1,4,27,179,729,0,1,5,44,426,3384,
%T A396499 14641,0,1,6,65,826,9765,85337,371293,0,1,7,90,1415,22248,295878,
%U A396499 2702044,11390625,0,1,8,119,2229,43785,786574,11197863,103239173,410338673,0
%N A396499 Square array A(n,k), n>=0, k>=0, read by antidiagonals downwards, where A(n,k) = n! * [x^n] F_k(x)/x and F_k(x) is the k-th iteration of x*G(x) with G(x) = exp(x*G(x)^2).
%F A396499 E.g.f. of column k: (1/x) * Series_Reversion( H_k(x) ), where H_k(x) is the k-th iterate of U(x)*exp(-2*U(x)) and U(x) = -LambertW(-x).
%F A396499 A(n,k) = Sum_{0 = x_0 <= x_1 <= ... <= x_{k-1} <= x_k = n} Product_{j=0..k-1} (x_j + 1) * (2*x_{j+1} - x_j + 1)^(x_{j+1} - x_j - 1) * binomial(x_{j+1},x_j).
%F A396499 A(n,0) = 0^n; A(n,k) = Sum_{j=0..n} (j+1) * (2*n-j+1)^(n-j-1) * binomial(n,j) * A(j,k-1) for k > 0.
%e A396499 Square array begins:
%e A396499   1,     1,     1,      1,      1,       1, ...
%e A396499   0,     1,     2,      3,      4,       5, ...
%e A396499   0,     5,    14,     27,     44,      65, ...
%e A396499   0,    49,   179,    426,    826,    1415, ...
%e A396499   0,   729,  3384,   9765,  22248,   43785, ...
%e A396499   0, 14641, 85337, 295878, 786574, 1768655, ...
%e A396499   ...
%o A396499 (PARI)
%o A396499 a(n, k, p=2, s=1, r=1) = {
%o A396499   my(T=matrix(n+1, n+1, row, col, my(xr=row-1, xc=col-1); if(xc<xr, 0, (s*xr+r)*(p*xc-(p-s)*xr+r)^(xc-xr-1)*binomial(xc, xr))));
%o A396499   my(TK=T^k);
%o A396499   TK[1, n+1];
%o A396499 };
%Y A396499 Columns k=0..2 give A000007, A052750, A396589.
%Y A396499 Cf. A396498, A396500, A396588.
%K A396499 nonn,tabl,new
%O A396499 0,8
