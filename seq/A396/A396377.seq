%S A396377 1,2,3,4,4,3,5,4,5,5,5,4,7,6,5,6,7,6,5,4,7,6,5,4,5,8,8,7,6,5,8,7,6,6,
%T A396377 5,6,8,7,6,5,7,6,7,6,6,6,7,6,7,10,9,8,7,6,5,7,8,7,6,5,9,8,7,8,7,6,8,7,
%U A396377 7,7,7,6,7,6,7,8,7,7,7,6,9,8,7,6,8,9,8,8,7,6,9,8,9,8
%N A396377 Smallest k so that at least one of the k+1 integers in {n, n+1, n+2, ..., n+k} divides the product of the other integers.
%C A396377 Problem proposed by Paul Erdős (see link).
%C A396377 Sometimes there is only one such integer k that divides the product of the other integers, but sometimes there are several such integers, see examples.
%C A396377 There are some similarities with first terms of A059686: a(n) = A059686(n-1) for n = 2, 3, 4, 5, 6, 7, 8, then for n = 13, 14, 15.
%H A396377 David Radcliffe, <a href="/A396377/b396377.txt">Table of n, a(n) for n = 1..10000</a>
%H A396377 Paul Erdős, <a href="https://combinatorica.hu/~p_erdos/1963-14.pdf">Quelques problèmes de Théorie des Nombres</a>, Monographies de l'Enseignement Mathématique, No. 6, pp. 81-135, L'Enseignement Mathématique, Université, Geneva, 1963, Problem 15, p. 90.
%F A396377 a(k!) = k.
%F A396377 If n > k!, then a(n) > k.
%F A396377 For p prime >= 5, a(p+1) = a(p) - 1.
%F A396377 a(n) <= n with equality iff n = 1, 2, 3, 4.
%F A396377 For infinitely many values of n: a(n) > exp((log n)^(1/2-ε)) [Erdős].
%e A396377 a(9) = 5, because with (9,10,11,12,13,14), we get 12 | 9*10*11*13*14, and it is not possible to get such a division with (9,10), (9,10,11), (9,10,11,12), (9,10,11,12,13).
%e A396377 a(14) = 6, because with (14,15,16,17,18,19,20), we get 15 | 14*16*17*18*19*20 and also 20 | 14*15*16*17*18*19, and as there is at least one integer that satisfies the definition, a(14) = 6.
%p A396377 a := proc(n)
%p A396377 local m, L, i, j, P;
%p A396377 for m from 1 do
%p A396377     L := [seq(n+i, i=0..m)];
%p A396377     for i from 1 to m+1 do
%p A396377         P := 1;
%p A396377         for j from 1 to m+1 do
%p A396377             if j <> i then
%p A396377                 P := P * L[j];
%p A396377             end if;
%p A396377         end do;
%p A396377         if irem(P, L[i]) = 0 then
%p A396377             return m;
%p A396377         end if;
%p A396377     end do;
%p A396377 end do;
%p A396377 end proc:
%p A396377 seq(a(n), n=1..60);
%o A396377 (PARI) isok(k, n) = my(v=vector(k+1, i, n+i-1), P=vecprod(v)); for (i=1, k+1, if (denominator(P/v[i]^2) == 1, return(1)));
%o A396377 a(n) = my(k=1); while (!isok(k, n), k++); k; \\ _Michel Marcus_, May 28 2026
%o A396377 (Python)
%o A396377 def A396377(n: int) -> int:
%o A396377     k = 1
%o A396377     p = n * (n + 1)
%o A396377     while not any(p % (j*j) == 0 for j in range(n, n+k+1)):
%o A396377         k += 1
%o A396377         p *= (n + k)
%o A396377     return k # _David Radcliffe_, Jun 10 2026
%Y A396377 Cf. A059686, A396378, A396379.
%K A396377 nonn,new
%O A396377 1,2
%A A396377 _Bernard Schott_, May 24 2026
