%T A396087 5828,5828,5828,5828,7565,17574,17574,38624,38624,38624,38624,38624,
%U A396087 39589,39589,44250,44250,44250,52323,97524,97524,190991,190991,190991,960752,1448540,1448540,1448540
%N A396087 Smallest integer m such that the product of every 5 consecutive integers > m has a prime factor > prime(n).
%C A396087 This is the 5-consecutive-integer analog of A003032 (3 consecutive) and A003033 (4 consecutive). Equivalently, a(n) is the largest k such that each of k, k+1, ..., k+4 is prime(n)-smooth. A run of five consecutive prime(n)-smooth integers contains a run of four, so a(n) < A003033(n); the inequality is strict because the largest such 4-run cannot extend to a 5-run (its last four terms would form a later 4-run).
%C A396087 The b-file terms were found by exhaustive search up to m = 10^10.
%H A396087 Ken Clements, <a href="/A396087/b396087.txt">Table of n, a(n) for n = 3..102</a>
%F A396087 a(n) < A003033(n).
%o A396087 (Python)
%o A396087 # Prints terms to a(30)
%o A396087 from sympy import primefactors, primepi
%o A396087 M = [0] * 29
%o A396087 iota_m, iota_mp1, iota_mp2, iota_mp3 = 0, 1, 2, 1
%o A396087 for m in range(1, 612_360+1): # Range 1 to A003033(30)
%o A396087     iota_mp4 = int(primepi(primefactors(m+4)[-1]))
%o A396087     iota = max(iota_m, iota_mp1, iota_mp2, iota_mp3, iota_mp4)
%o A396087     if (iota - 2) < 29: M[iota-2] = m
%o A396087     iota_m, iota_mp1, iota_mp2, iota_mp3 = iota_mp1, iota_mp2, iota_mp3, iota_mp4
%o A396087 for i in range(1, 29):
%o A396087     if M[i] < M[i-1]: M[i] = M[i-1]
%o A396087 print(M[1:])
%Y A396087 Cf. A002072, A003032, A003033.
%K A396087 nonn,new
%O A396087 3,1
%A A396087 _Ken Clements_, May 16 2026
