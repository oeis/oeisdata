%T A396415 7979302648,67080255362,569335836460,4872950092054,42019441551195,
%U A396415 364747126728335,3185048868629538,27961717170478835,246666594628933346,2185543714195145651
%N A396415 Expansion of F_3(x)/x, where F_k(x) is the k-th iteration of x*G3(x) with G3(x) = 1 + x*G3(x)^3.
%F A396415 G.f.: (1/x) * Series_Reversion( H_3(x) ), where H_k(x) is the k-th iteration of x*(1 - x*C(x)) with C(x) = 1 + x*C(x)^2.
%F A396415 a(n) = Sum_{0 = x_0 <= x_1 <= x_2 <= x_3 = n} Product_{k=0..2} (x_k + 1) * binomial(3*x_{k+1} - 2*x_k + 1,x_{k+1} - x_k)/(3*x_{k+1} - 2*x_k + 1).
%F A396415 a(n) = Sum_{k=0..n} (k+1) * binomial(3*n-2*k+1,n-k)/(3*n-2*k+1) * A396414(k).
%o A396415 (PARI)
%o A396415 lista(nn, k=3, p=3) = {
%o A396415   my(T=matrix(nn+1, nn+1, row, col, my(xr=row-1, xc=col-1); if(xc<xr, 0, (xr+1)*binomial(p*xc-(p-1)*xr+1, xc-xr)/(p*xc-(p-1)*xr+1))));
%o A396415   my(TK=T^k);
%o A396415   TK[1, ];
%o A396415 };
%Y A396415 Column k=3 of A396412.
%Y A396415 Cf. A000108, A001764, A396414.
%K A396415 nonn,new
%O A396415 0,2
