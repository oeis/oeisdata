%S A396788 4,49,1369,50759,696191,8576377,249620207,1258298311,34740843443,
%T A396788 185275777513,4407073320449,27688341160559,535326087126601
%N A396788 (10^n)-th brilliant number.
%F A396788 a(n) = A078972(10^n).
%o A396788 (Python)
%o A396788 from math import isqrt, comb
%o A396788 from sympy import primepi, primerange
%o A396788 from oeis_sequences.OEISsequences import bisection
%o A396788 def A396788(n):
%o A396788     n10 = 10**n
%o A396788     def f(x):
%o A396788         s = isqrt(x)
%o A396788         a, c, k, l = 0, 0, 1, len(str(s))
%o A396788         for i in range(1,l):
%o A396788             k *= 10
%o A396788             c -= comb((b:=primepi(k-1))-a+1,2)
%o A396788             a = b
%o A396788         return c+int(n10+x+sum(max(i,primepi((m:=10**(len(str(p))-1))-1))-primepi(min(x//p,10*m-1)) for i,p in enumerate(primerange(10**(l-1),s+1),a)))
%o A396788     return bisection(f,n10,n10)
%Y A396788 Cf. A078972.
