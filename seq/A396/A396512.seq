%S A396512 1,1,4,32,436,9011,262731,10269469,518213374,32791782443,
%T A396512 2542620052511,237076215199362,26169956408743147,3375253146527926664,
%U A396512 502930199914263085965,85738904081626809938925,16581476316696251513176624,3610682865074032031867899316
%N A396512 Number of labeled histories for rooted at-most-5-furcating trees with n leaves, if simultaneous branching events are allowed.
%H A396512 Emily H. Dickey and Noah A. Rosenberg, <a href="https://doi.org/10.1016/j.dam.2026.04.032">Labeled histories and maximally probable labeled topologies with multifurcation</a>, Discr. Appl. Math. 391 (2026), 192-203. See Table 2.
%t A396512 A[1] := 1;
%t A396512 A[n_] := n! Sum[(1/((2!)^x2 (x2!))) Sum[(1/((3!)^x3 (x3!))) Sum[(1/((4!)^x4 (x4!))) Sum[(1/((5!)^x5 (x5!))) (1/(n - 2 x2 - 3 x3 - 4 x4 - 5 x5)!)*A[n - x2 - 2 x3 - 3 x4 - 4 x5], {x5, Max[Ceiling[(2 - 2 x2 - 3 x3 - 4 x4)/5], 0], Floor[(n - 2 x2 - 3 x3 - 4 x4)/5]}], {x4, 0, Floor[(n - 2 x2 - 3 x3)/4]}], {x3, 0, Floor[(n - 2 x2)/3]}], {x2, 0, Floor[n/2]}];
%t A396512 Table[A[n], {n, 1, 15}]
%Y A396512 Cf. A317059 (2-furcating), A396088 (at-most-3-furcating), A396488 (at-most-4-furcating), A393749 (non-simultaneous branching events only).
%K A396512 nonn
%O A396512 1,3
%A A396512 _Noah A Rosenberg_, May 28 2026
