%t A396073 Complement[Range[Last[#]], #] &@ Accumulate@ Array[DivisorSigma[0, #] &, 27] (* _Michael De Vlieger_, May 16 2026 *)
%o A396073 (Python)
%o A396073 from itertools import count, islice
%o A396073 # uses Python function in A006218
%o A396073 def A396073_gen(): # generator of terms
%o A396073     c = 0
%o A396073     for i in count(0):
%o A396073         if (m:=A006218(i))!=i+c:
%o A396073             for j in range(i+c,m):
%o A396073                 yield j
%o A396073             c = m-i
%o A396073 A396073_list = list(islice(A396073_gen(),70))
