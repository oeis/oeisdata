%I A396149 #13 May 24 2026 14:30:59
%S A396149 1,1,0,1,2,7,31,218,2644,62286,2954024,277508807,50209732882
%N A396149 Number of connected graphs on n vertices where every edge is part of at least one triangle.
%C A396149 A connected graph satisfies this property if every edge belongs to at least one 3-clique (triangle). Equivalently, for every edge (u, v), there exists at least one vertex w such that both (u, w) and (v, w) are also edges in the graph.
%C A396149 Terms for n >= 8 were computed by the author using a custom MapReduce algorithm.
%H A396149 Banri Ogawa, <a href="/A396149/a396149.cpp.txt">C++ program</a>
%H A396149 Banri Ogawa, <a href="https://github.com/b-ogawa/oeis-A396149-data">oeis-A396149-data</a>, GitHub repository containing statistical data of various graph invariants for these graphs.
%e A396149 For n = 3, the a(3) = 1 graph is the complete graph K_3.
%o A396149 (C++) // See Links
%o A396149 (PARI) a(n)={if(n<3, return(n<2)); my(E=concat(vector(n-1,i,vector(n-i,j,[i,i+j]))), R=List()); for(m=0, 2^#E-1, my(G=matrix(n,n)); for(e=1, #E, if(bittest(m,e-1), G[E[e][1],E[e][2]]=G[E[e][2],E[e][1]]=1)); if(vecmin(vecmin((matid(n)+G)^(n-1)))>0 && vecmin(vecmin(G^2-G))>=0, my(maxG=""); forperm(n, p, my(Gp=Str(matrix(n,n,i,j,G[p[i],p[j]]))); if(Gp>maxG, maxG=Gp)); listput(R,maxG))); #Set(R)}
%Y A396149 Cf. A001349.
%K A396149 nonn,hard,more,changed
%O A396149 0,5
%A A396149 _Banri Ogawa_, May 18 2026
