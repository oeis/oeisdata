%I A396137 #21 May 25 2026 22:48:14
%S A396137 583,823,853,877,941,953,983,1031,1063,1067,1073,1091,1139,1166,1193,
%T A396137 1237,1261,1303,1309,1313,1337,1339,1367,1379,1391,1403,1409,1417,
%U A396137 1427,1447,1451,1469,1477,1481,1487,1507,1517,1543,1549,1553,1559,1567,1571,1577,1579
%N A396137 Numbers that are neither the sum nor difference of two 5-smooth numbers.
%C A396137 Numbers k such that A391077(k) = 0.
%o A396137 (PARI)
%o A396137 M(v, u, lim)={vecsort(concat(vector(#v, i, my(m=lim\v[i]); v[i]*select(t->t<=m, u))))}
%o A396137 Gen(lim, k)={my(v=[1]); forprime(p=2, k, v=M(v, vector(logint(lim, p)+1, e, p^(e-1)), lim)); v}
%o A396137 lista(n, lim=10^30)={my(v=vector(n), G=Gen(lim, 5)); for(i=1, #G, my(t=G[i], k=i+1); while(k<=#G && G[k]-t<=n, v[G[k]-t]=G[k]; k++)); v}
%o A396137 A006530(n)=if(n>1, vecmax(factor(n)[, 1]), 1)
%o A396137 b(n)=for(t=1, n, A006530(t*(n-t))<=5&return(t))
%o A396137 A391077(n)=if(lista(n)[n]!=0, return(lista(n)[n]); lista(n)[n]==0&b(n)<n, return(n-b(n)); lista(n)[n]==0&b(n)==n, return(0))
%o A396137 for(n=1,2000,A391077(n)==0&print1(n", "))
%Y A396137 Cf. A391077.
%Y A396137 Intersection of A308456 and A323049.
%K A396137 nonn,new
%O A396137 1,1
%A A396137 _Zhicheng Wei_, May 17 2026
