%I A396455 #7 May 30 2026 18:11:47
%S A396455 2,11,31,43,47,67,71,73,103,107,131,137,149,167,193,197,199,211,223,
%T A396455 251,263,271,277,281,283,311,313,317,337,347,353,359,367,373,379,383,
%U A396455 401,433,439,443,457,463,467,479,487,491,509,521,557,563,571,599,601,607,613,617,619,641,643,659,661
%N A396455 Primes p such that p^2 = A075254(k) for some k.
%C A396455 Primes p such that k + sopfr(k) = p^2 has at least one solution, where sopfr(k) = A001414(k) is the sum of prime factors of k with multiplicity.
%H A396455 Robert Israel, <a href="/A396455/b396455.txt">Table of n, a(n) for n = 1..1065</a>
%e A396455 a(3) = 31 is a term because 31 is a prime and 31^2 = 961 = A075254(936).
%e A396455 The first term p for which k + sopfr(k) = p^2 has more than one solution is a(8) = 73, as 73^2 = 5329 = A075254(5008) = A075254(5278).
%e A396455 The first term for which there are 3 solutions is a(9) = 103, as 103^2 = 10609 = A075254(10486) = A075254(10545) = A075254(10556).
%p A396455 N:= 2*10^8: # for terms <= sqrt(N)
%p A396455 P:= {}:
%p A396455 for x from 1 to N do
%p A396455    v:= x + add(s[1]*s[2],s=ifactors(x)[2]);
%p A396455    if v <= N and issqr(v) then
%p A396455      p:= sqrt(v); if isprime(p) then P:= P union {p} fi;
%p A396455    fi;
%p A396455 od:
%p A396455 sort(convert(P,list));
%Y A396455 Cf. A001414, A075254, A396408.
%K A396455 nonn,new
%O A396455 1,1
%A A396455 _Will Gosnell_ and _Robert Israel_, May 26 2026
