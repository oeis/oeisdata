%I A396066 #8 May 19 2026 18:57:22
%S A396066 1,2,3,4,5,8,9,10,7,6,11,16,17,14,13,12,19,24,41,18,23,26,25,36,37,20,
%T A396066 29,22,15,62,27,28,33,34,35,52,21,38,39,32,31,42,53,40,43,44,47,50,61,
%U A396066 58,45,76,49,48,55,46,77,54,65,56,59,66,71,30,67,64,63
%N A396066 a(1) = 1; a(n) is the smallest positive integer not already in the sequence so that a(n)^4+a(n-1)^4 is prime.
%C A396066 A third-power counterpart (sum of cubes) does not exist as a^3 + b^3 = (a + b)*(a^2 - ab + b^2). For the product to be prime, either factor must be 1, but the only nonnegative solution where a < b is a = 0 and b = 1, which gives the nonprime 1. This also applies to any higher odd powers.
%C A396066 The list alternates between odd and even, as there would be an even sum otherwise.
%C A396066 It is conjectured that this list is a permutation of the natural numbers.
%H A396066 Hoang Nguyen, <a href="/A396066/b396066.txt">Table of n, a(n) for n = 1..2010</a>
%e A396066 a(2) = 2 as 1^4 + 2^4 = 17 which is prime.
%e A396066 a(6) = 8 as 5^4 + 6^4 = 1921 = 17 * 113, 5^4 + 7^4 is even, and 5^4 + 8^4 = 4721 which is prime.
%e A396066 a(9) = 7 as 10^4 + 7^4 = 12401 which is prime, and 7 is not already on the list.
%t A396066 a[n_] := a[n] = Module[{k = 2}, While[MemberQ[Array[a, n-1], k] || ! PrimeQ[k^4 + a[n-1]^4], k++]; k]; a[1] = 1; Array[a, 70] (* _Amiram Eldar_, May 16 2026 *)
%o A396066 (Julia)
%o A396066 function a(n)
%o A396066     used = []
%o A396066     num = 1
%o A396066     for _ in 2:n
%o A396066         push!(used, num)
%o A396066         prime = false
%o A396066         next = num % 2 - 1
%o A396066         while !prime
%o A396066             next += 2
%o A396066             if next in used
%o A396066                 continue
%o A396066             end
%o A396066             check = num^4 + next^4
%o A396066             for i in 3:2:floor(Int, sqrt(check))
%o A396066                 prime = true
%o A396066                 if check % i == 0
%o A396066                     prime = false
%o A396066                     break
%o A396066                 end
%o A396066             end
%o A396066         end
%o A396066         num = next
%o A396066     end
%o A396066     return num
%o A396066 end
%Y A396066 Cf. A395028, A055265, A284047.
%K A396066 nonn
%O A396066 1,2
%A A396066 _Hoang Nguyen_, May 15 2026
