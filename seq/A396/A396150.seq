%I A396150 #26 Jun 18 2026 17:08:02
%S A396150 1,7,183,9645,737695,70921523,7963415235,1000623153703,
%T A396150 136930650634157,20036588079999697,3094573064119084257,
%U A396150 499679108112870427517,83746068802101338496983,14487559600962560297819475,2575528604236890018394358475,468852034782298397633688669209
%N A396150 Number of words over the alphabet [4] with c(1) = n such that all prefixes satisfy c(1) >= c(2), c(1) >= c(3), c(2) >= c(4), and c(3) >= c(4), where c(i) is the number of occurrences of the letter i.
%C A396150 All terms are odd.
%H A396150 Alois P. Heinz, <a href="/A396150/b396150.txt">Table of n, a(n) for n = 0..165</a>
%e A396150 a(1) = 7: [1], [1,2], [1,3], [1,2,3], [1,3,2], [1,2,3,4], [1,3,2,4].
%p A396150 b:= proc(x, y, z, u) option remember; `if`(x=0, 1, 0)+
%p A396150       `if`(u=0, 0, `if`(x>0, b(x-1, y, z, u), 0)+
%p A396150       `if`(y>0 and y>x, b(x, y-1, z, u), 0)+
%p A396150       `if`(z>0 and z>x, b(x, sort([y, z-1])[], u), 0)+
%p A396150       `if`(u>0 and u>y and u>z, b(x, y, z, u-1), 0))
%p A396150     end:
%p A396150 a:= n-> b(n$4):
%p A396150 seq(a(n), n=0..15);  # _Alois P. Heinz_, Jun 18 2026
%Y A396150 Column sums of A395140.
%Y A396150 Cf. A114714, A176129, A207542, A384725.
