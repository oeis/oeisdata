%I A396969 #5 Jun 19 2026 00:54:02
%S A396969 40,48,63,80,96,98,104,112,117,136,160,171,176,189,192,208,224,232,
%T A396969 252,272,275,279,296,304,320,328,333,351,352,360,363,368,384,387,416,
%U A396969 424,448,450,459,464,468,475,488,496,504,507,513,520,528,539,544,549,567,578
%N A396969 Intersection of A332785 and A396324.
%C A396969 Does not intersect A366825, since for k in A366825, k = lpf(k)*rad(k). Therefore, since lpf(k)*rad(k) is the smallest number that exceeds rad(k), then all r < k such that rad(k) | r (i.e., rad(k) itself) also divide k.
%C A396969 Conjecture: A396324 is the union of this sequence and A001694 \ {1,4}.
%H A396969 Michael De Vlieger, <a href="/A396969/b396969.txt">Table of n, a(n) for n = 1..10000</a>
%t A396969 rad[x_] := Times @@ FactorInteger[x][[All, 1]];
%t A396969 Select[Select[Range[600],
%t A396969   Nor[SquareFreeQ[#], Divisible[#, rad[#]^2]] &],
%t A396969   Function[k, r = rad[k];
%t A396969     s = Select[Range[k], CoprimeQ[#, k] &];
%t A396969     t = Union@
%t A396969       Flatten@ Mod[
%t A396969         TensorProduct @@
%t A396969           Map[(p = #; NestWhileList[Mod[p*#, k] &, 1, UnsameQ, All]) &,
%t A396969           FactorInteger[k][[All, 1]] ], k];
%t A396969   Count[Complement[Range[0, k - 1], Union[s, t]], _?(Divisible[#, r] &)] > 0] ]
%Y A396969 Cf. A001694, A007947, A072777, A332785, A359280, A366825, A396324, A396968.
%K A396969 nonn,new
%O A396969 1,1
%A A396969 _Michael De Vlieger_, Jun 13 2026
