%I A396550 #9 May 31 2026 09:45:05
%S A396550 144,576,720,1008,1568,1584,1872,2448,2736,2880,3312,4032,4176,4464,
%T A396550 4704,5040,5328,5904,6192,6336,6768,7488,7632,7840,7920,8496,8784,
%U A396550 9360,9648,9792,10224,10512,10944,11088,11376,11952,12240,12816,13104,13248,13680,13968,14544,14832
%N A396550 Numbers that are equal to the sum of their coreful divisors that are not exponential unitary divisors.
%C A396550 Numbers k such that A396549(k) = k.
%C A396550 See A284318 and A361255 for the definitions of coreful divisors and exponential unitary divisors, respectively.
%C A396550 All the terms are nonsquarefree number (A013929) and abundant numbers (A005101).
%C A396550 If k is a term and m is a squarefree number coprime to k, then k*m is also a term. The primitive terms of this sequence (A396551) are the powerful (A001694) terms. All the terms are of the form k*m where k is primitive and m is a squarefree number coprime to k.
%C A396550 The asymptotic density of this sequence is Sum_{n>=1} f(A396551(n)) = 0.0028679763627..., where f(n) = (6/(Pi^2*n)) * Product_{prime p|n} (p/(p+1)).
%H A396550 Amiram Eldar, <a href="/A396550/b396550.txt">Table of n, a(n) for n = 1..10000</a>
%t A396550 f1[p_, e_] = (p^(e+1)-1)/(p-1) - 1;
%t A396550 f2[p_, e_] = DivisorSum[e, p^# &, CoprimeQ[#, e/#] &];
%t A396550 q[k_] := Module[{fct = FactorInteger[k]}, Times @@ f1 @@@ fct - Times @@ f2 @@@ fct == k]; q[1] = False; Select[Range[15000], q]
%o A396550 (PARI) isok(k) = {my(f = factor(k)); prod(i = 1, #f~, (f[i,1]^(f[i,2]+1) - 1)/(f[i,1]-1) - 1) - prod(i = 1, #f~, sumdiv(f[i,2], d, if(gcd(d, f[i,2]/d) == 1, f[i,1]^d))) == k;}
%Y A396550 Subsequence of A005101 and A013929.
%Y A396550 A396551 is a subsequence.
%Y A396550 Cf. A001694, A005117, A284318, A307958, A322858, A361255, A396545, A396549.
%K A396550 nonn
%O A396550 1,1
%A A396550 _Amiram Eldar_, May 29 2026
