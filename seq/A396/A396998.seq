%U A396998 8,84,951,10230,93343,636393,2744360,5721390,0,1,9,108,1435,18831,221750,2123259,14697888,62894577,129948787,0
%N A396998 Square array A(n,k), n >= 1, k >= 0, read by antidiagonals downwards, where column k is the expansion of e.g.f. F^k(x), where F(x) is the e.g.f. of A214645.
%F A396998 E.g.f. F(x) satisfies F'(x) = exp(F^l(x)), where F^l(x) denotes the l-th iterate of F, with F(0) = 0.
%F A396998 Let a(n,k,l) = n! * [x^n] F^k(x), where F^k(x) is the k-th iterate of F, and let b(n,k,l) = n! * [x^n] exp(F^k(x)).
%F A396998 a(n,0,l) = 0^(n-1), b(0,k,l) = 1,
%F A396998 a(n,k,l) = Sum_{j=0..n-1} binomial(n-1,j) * b(j,k+l-1,l) * a(n-j,k-1,l) for k > 0, and
%F A396998 b(n,k,l) = Sum_{j=1..n} binomial(n-1,j-1) * a(j,k,l) * b(n-j,k,l) for n > 0.
%F A396998 These recurrences are computationally expensive; in practice, direct iteration of the defining power series is much faster.
%e A396998 Square array begins:
%e A396998   1,    1,    1,     1,     1,      1,      1, ...
%e A396998   0,    1,    2,     3,     4,      5,      6, ...
%e A396998   0,    3,    9,    18,    30,     45,     63, ...
%e A396998   0,   16,   65,   165,   334,    590,    951, ...
%e A396998   0,  126,  657,  2058,  4974,  10230,  18831, ...
%e A396998   0, 1333, 8627, 32727, 93343, 221750, 463488, ...
%e A396998   ...
%Y A396998 Columns k=0..1 give A063524, A214645.
%Y A396998 Cf. A396999, A397000.
