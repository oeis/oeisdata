%U A396238 16282589303341,101435368987532,631912517383722,3936637423973502,24524174461033569,152779004164967032
%N A396238 a(n) = Sum_{i=0..n} Sum_{j=0..i} Sum_{k=0..j} binomial(n+i,2*i) * binomial(i+j,2*j) * binomial(j+k,2*k).
%H A396238 Seiichi Manyama, <a href="/A396238/b396238.txt">Table of n, a(n) for n = 0..200</a>
%H A396238 <a href="/index/Rec#order_08">Index entries for linear recurrences with constant coefficients</a>, signature (15,-83,220,-303,220,-83,15,-1).
%F A396238 G.f.: (1-x) * ((1-x)^2 - x) * (((1-x)^2 - x)^2 - x*(1-x)^2) / ((((1-x)^2 - x)^2 - x*(1-x)^2)^2 - x*(1-x)^2*((1-x)^2 - x)^2).
%F A396238 a(n) = 15*a(n-1) - 83*a(n-2) + 220*a(n-3) - 303*a(n-4) + 220*a(n-5) - 83*a(n-6) + 15*a(n-7) - a(n-8).
%F A396238 G.f.: 1 / ( (1-x) * (1-B(x)) * (1-B(B(x))) * (1-B(B(B(x)))) ), where B(x) = x/(1-x)^2.
%F A396238 G.f.: (C(x)/x)^(1/2), where C(x) is the g.f. of A396094.
%o A396238 (PARI) a(n) = sum(i=0, n, sum(j=0, i, sum(k=0, j, binomial(n+i, 2*i)*binomial(i+j, 2*j)*binomial(j+k, 2*k))));
%Y A396238 Cf. A396094.
