%N A396228 a(1) = 1; a(n+1) = -Sum_{k=1..n} (-1)^k * a(k) * floor(n/k).
%H A396228 Ilya Gutkovskiy, <a href="/A396228/a396228.jpg">Scatterplot of the second partial sums of A396228</a>
%F A396228 a(1) = 1, a(n) = -Sum_{k=1..n-1} Sum_{d|k} (-1)^d * a(d).
%F A396228 G.f.: x - ( x / (1 - x) ) * Sum_{n>=1} a(n) * (-x)^n / (1 - x^n).
%t A396228 a[1] = 1; a[n_] := a[n] = -Sum[(-1)^k a[k] Floor[(n - 1)/k], {k, 1, n - 1}]; Table[a[n], {n, 1, 80}]
