%T A396539 64413854851335,3036649176072765,147728685433584465,
%U A396539 7431492259342213440,383693601452301792795,20304027597295616632395,1096964233375116271929753,60410210457682687411896075,3383028314439620964543868575
%N A396539 Number of bracelets (turnover necklaces) of length 4 using exactly 4 colors, where the colors are chosen from a palette of size N = A000081(n) (the number of unlabeled rooted trees with n nodes), and each color corresponds to a distinct tree shape.
%C A396539 Let a(n) be the number of bracelets of length 4 using exactly 4 colors, where the colors are chosen from a set of size N = A000081(n) (unlabeled rooted trees with n nodes). For a fixed set of 4 colors, there are 24 linear arrangements and the dihedral group D4 has 8 elements, giving 24/8 = 3 distinct bracelets per color set. Hence a(n) = 3 * binomial(N,4).
%C A396539 This sequence is the r=4 slice (m=4) of the 3D array A338859(4,n) = A321791(4, A000081(n)). Not to be confused with A214312 (varying length) or A214309 (representatives).
%F A396539 a(n) = 3 * binomial(A000081(n), 4) for n >= 4.
%e A396539 For n=4, N = A000081(4) = 4 colors (A, B, C, D). The 3 bracelets are:
%e A396539          (1) A B C D
%e A396539          (2) A B D C
%e A396539          (3) A C B D
%e A396539 All rotations and reflections are considered identical.
%o A396539 (Python)
%o A396539 from math import comb
%o A396539 from functools import lru_cache
%o A396539 @lru_cache(maxsize=None)
%o A396539 def A000081(n):
%o A396539     if n <= 1:
%o A396539         return 1
%o A396539     total = 0
%o A396539     for j in range(1, n):
%o A396539         s = 0
%o A396539         for d in range(1, j + 1):
%o A396539             if j % d == 0:
%o A396539                 s += d * A000081(d)
%o A396539         total += s * A000081(n - j)
%o A396539     return total // (n - 1)
%o A396539 def a(k):
%o A396539     return 3 * comb(A000081(k), 4)
%o A396539 print([a(k) for k in range(4, 21)])
%Y A396539 Cf. A000081 (number of unlabeled rooted trees with n nodes, gives total colors N), A321791 (bracelets of length n using up to k colors), A338859 (unicyclic graphs with m cycle nodes and trees of size k).
%K A396539 nonn
