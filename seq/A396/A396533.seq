%I A396533 #29 Jun 03 2026 18:14:49
%S A396533 3,9,1,1,7,3,8,4,4,1,1,6,2,9,3,5,2,3,1,2,2,1,9,9,1,2,4,7,9,1,4,9,5,5,
%T A396533 1,7,8,0,3,9,5,9,5,4,6,6,3,5,9,1,5,1,9,1,5,7,4,8,1,9,1,9,6,5,4,8,1,3,
%U A396533 2,8,8,4,1,4,7,7,2,8,4,1,5,0,0,7,1
%N A396533 Decimal expansion of -P(0), where P(x) is the Lagrange interpolation polynomial that interpolates P(k!) = k for all integer k > 0 in the limit of infinite order.
%C A396533 The Lebesgue function for this interpolation evaluated at zero, has an upper limit in the case of infinite points: A396552.
%F A396533 Equals lim_{l->oo} Sum_{k=1..l} k*Product_{j=1..l,j<>k} -j!/(k!-j!).
%F A396533 Equals the root of the polynomial
%F A396533   Pol(x) = det [x,   1,      0,        0, ...,        0;
%F A396533                 1,   1,     1!,   (1!)^2, ...,   (1!)^n;
%F A396533                 2,   1,     2!,   (2!)^2, ...,   (2!)^n;
%F A396533                ...
%F A396533               n+1,   1, (n+1)!, (n+1)!^2, ..., (n+1)!^n]
%F A396533   = A203306(n+1)*x + c(n), in the limit n->oo.
%F A396533 Consider the function F(x) = Product_{k>=1}(1-x/k!), then this constant equals Sum_{k>=1} k/(k!*F'(k!)), where F'(x) is the derivative of F(x).
%e A396533 P(0) = -0.39117384411629352312219912479149551780395954... .
%e A396533 P(1) = 1.
%e A396533 P(2) = 2 = 2!.
%e A396533 P(3) = 6 = 3!.
%e A396533 ...
%o A396533 (PARI) prec = 200; default(realprecision, prec); -sum(k=1, prec, k*prod(j=1, prec, if(j==k, 1, -j!/(k!-j!))))*1.
%Y A396533 Cf. A092894, A203306, A396552.
%K A396533 nonn,cons
%O A396533 0,1
%A A396533 _Thomas Scheuerle_, May 28 2026
