%I A396801 #9 Jun 10 2026 08:52:19
%S A396801 1,2,21,820,80505,15563526,5101804351,2573353697160,1867728655398465,
%T A396801 1857834175953081610,2441012215844429226351,4116180320076721181161548,
%U A396801 8704606822282582735479025681,22652458086041932174807663045086,71406283145012432204148231249104415,269031985043231462963238717586991823376
%N A396801 Main diagonal of table A396800.
%H A396801 Paul D. Hanna, <a href="/A396801/b396801.txt">Table of n, a(n) for n = 1..75</a>
%F A396801 a(n) = A396800(n,n) for n >= 1. Row n of table A396800 is defined by A396800(n,k) = [x^k/k!] F(n,x) where F(n,x) satisfies F(n,x) = x * exp( F^n(n,x) ) for n >= 1.
%o A396801 (PARI) \\ a(n) = [x^n/n!] F(n,x) where F(n,x) = x * exp( F^n(n,x) )
%o A396801 \\ Routine to generate the n-th iteration of F:
%o A396801 {IT(n,F) = my(G=x); for(i=1,n, G = subst(F,x,G)); G}
%o A396801 \\ Calculate the terms T(n,k) of the table
%o A396801 {A396800(n,k) = my(Fn=x); for(j=1, k, Fn = truncate(Fn) + x*O(x^j);
%o A396801 Fn = x * exp( IT(n, Fn) ) +x*O(x^k); ); k!*polcoef(Fn, k)}
%o A396801 {for(n=1,20, print1(A396800(n,n),", "))}
%Y A396801 Cf. A396800.
%K A396801 nonn
%O A396801 1,2
%A A396801 _Paul D. Hanna_, Jun 09 2026
