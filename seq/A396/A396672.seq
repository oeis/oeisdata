%N A396672 Averages of two consecutive odd squarefree semiprimes p, q (A046388) that share a common factor > 1 with at least one of p and q.
%C A396672 The least terms not divisible by 3 are 127250, 494750, 578830, ... .
%e A396672   j A046388(j)
%e A396672          (A046388(j)+A046388(j+1))/2
%e A396672                  Factorizations
%e A396672                                 Terms
%e A396672   1 15           3 * 5
%e A396672          18      2 * 3^2       a(1) = 18
%e A396672   2 21           3 * 7
%e A396672          27      3^3           a(2) = 27
%e A396672   3 33           3 * 11
%e A396672          34      2 * 17
%e A396672   4 35           5 * 7
%e A396672          37      37
%e A396672   5 39           3 * 13
%e A396672          45      3^2 * 5       a(3) = 45
%e A396672   6 51           3 * 17
%e A396672          53      53
%e A396672   7 55           5 * 11
%e A396672     ...
%e A396672     127235       5 * 25447
%e A396672          127250  2 * 5^3 * 509 a(..) = 127250
%e A396672     127265       5 * 25453
%o A396672 (PARI) a396672(upto=7500) = my(p1=15,p2); forstep(k=21, upto, 2, my(f=factor(k), m); if(omega(f)==2 && bigomega(f)==2, p2=k; m=p1+p2; if(gcd(p1,m)!=1 || gcd(p2,m)!=1, print1(m/2, ", ")); p1=p2))
