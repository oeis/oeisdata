%e A396656       /   /             \   \
%e A396656      *   *   G---B---R   B   *
%e A396656     /   /   /         \   \   \
%e A396656    G   B   R   R---B   G   B   R
%e A396656   /   /   /   /     \   \   \   \
%e A396656  R   *   B   G   R---G   B   *   *
%e A396656   \   \   \   \         /   /   /
%e A396656    R   B   G   B---R---R   B   G
%e A396656     \   \   \             /   /
%e A396656      *   R   R---B---G---*   *
%e A396656       \   \                 /
%e A396656        G   *---R---*---*---B
%e A396656         \
%e A396656          G---G---*---B---B
