%U A396705 3,9,3,7,3,7,8,3,8,8,3,7,5,6,2,4,4,7,8,5,4,6,2,0,1,7,5,5,6,2,1,8,4,2,0
%N A396705 Decimal expansion of Sum_{k>=1} ((2*k-1)!! / (2^(k+1) * (k+1)!)) * zeta(2*k+1).
%C A396705 This constant is explicitly derived from the geometric properties of a hyperbola. Specifically, it evaluates the sum Sum_{n>=1} (n - sqrt(n^2 - 1) - 1/(2*n)). Expanding the radical using the generalized binomial theorem and rearranging the terms yields the exact infinite series expression involving the Riemann zeta function at odd integers. This approach emerges from exploring a novel geometric framework to determine the odd zeta values, analogous to how the even zeta values are fundamentally linked to the geometry of a circle.
%C A396705 PSLQ integer relation algorithms evaluated at 1000-digit precision show no linear relations with standard mathematical constants (Pi, e, zeta(3), log(2), Catalan's constant), strongly suggesting it is a transcendental number.
%F A396705 Equals Sum_{n>=1} (n - sqrt(n^2 - 1) - 1/(2*n)).
%F A396705 Equals 1/2 + Sum_{n>=1} ((2*n-1)!! / (2^(n+1) * (n+1)!)) * (zeta(2*n+1) - 1).
%e A396705 0.52795877664600437220134362373817481532906147535625...
%o A396705 (PARI) default(realprecision, 120); 1/2 + sumpos(n=1, (zeta(2*n+1)-1) * binomial(2*n,n) / (2^(2*n+1) * (n+1))) \\ _Vaclav Kotesovec_, Jun 03 2026
%o A396705 (Python)
%o A396705 from mpmath import mp, zeta, fac
%o A396705 mp.dps = 100
%o A396705 def double_factorial(k):
%o A396705     if k <= 0: return mp.mpf(1)
%o A396705     res = mp.mpf(1)
%o A396705     for i in range(k, 0, -2): res *= i
%o A396705     return res
%o A396705 S = mp.mpf('0.5')
%o A396705 for n in range(1, 200):
%o A396705     num = double_factorial(2*n - 1)
%o A396705     den = (mp.power(2, n+1)) * fac(n+1)
%o A396705     C_n = num / den
%o A396705     S += C_n * (zeta(2*n + 1) - mp.mpf(1))
%o A396705 print(S)
%K A396705 nonn,cons,new
%O A396705 0,1
%A A396705 _Yunjae Shin_, Jun 02 2026
