%I A396718 #11 Jun 04 2026 19:17:42
%S A396718 0,0,4,10,21,42,21,42,85,168,92,143,222,1144,665,143,341,170,84,46,
%T A396718 278,174,342,680,349,559,869,364,109,623,1389,2728,1365,170,85,554,
%U A396718 341,682,341,682,340,174,1111,682,341,682,341,682,1365,2698,1437,346,189
%N A396718 The ones in the binary expansion of a(n) are forbidden in A394166(n).
%C A396718 In other words, the ones in the binary expansion of a(n) are at one knight's move distance from the ones in the binary expansion of A394166(k) for k = max(0, n-2)..max(0, n-1).
%H A396718 Rémy Sigrist, <a href="/A396718/b396718.txt">Table of n, a(n) for n = 0..10000</a>
%H A396718 Rémy Sigrist, <a href="/A396718/a396718.png">Binary plot of the present sequence (as black pixels) and of A394166 (as yellow pixels) for n = 0..512</a>
%H A396718 Rémy Sigrist, <a href="/A396718/a396718.txt">C++ program</a>
%F A396718 a(n) = 2*A394166(n-2) OR floor(A394166(n-2)/2) OR 4*A394166(n-1) OR floor(A394166(n-1)/4) for n > 1 (where OR denotes the bitwise OR operator).
%F A396718 a(n) AND A394166(n) = 0 (where AND denotes the bitwise AND operator).
%e A396718 For n = 5:
%e A396718 - A394166(3) = 4 = 2^2, so 2^3 and 2^1 are forbidden in A394166(5),
%e A396718 - A394166(4) = 8 = 2^3, so 2^5 and 2^1 are forbidden in A394166(5),
%e A396718 - so a(5) = 2^5 + 2^3 + 2^1 = 42.
%o A396718 (C++) // See Links section.
%o A396718 (Python)
%o A396718 from itertools import count, islice
%o A396718 def agen(): # generator of terms
%o A396718     aset, m, an2, an1 = {0, 1}, 2, 0, 1
%o A396718     yield from [0, 0]
%o A396718     for n in count(2):
%o A396718         mask = (an1<<2)|(an1>>2)|(an2<<1)|(an2>>1)
%o A396718         yield mask
%o A396718         an2, an1 = an1, next(k for k in count(m) if not (k&mask or k in aset))
%o A396718         aset.add(an1)
%o A396718         while m in aset: m += 1
%o A396718 print(list(islice(agen(), 53))) # _Michael S. Branicky_, Jun 04 2026
%Y A396718 Cf. A394166.
%K A396718 nonn,base
%O A396718 0,3
%A A396718 _Rémy Sigrist_, Jun 03 2026
