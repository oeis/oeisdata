%T A396687 1,7,6,1,2,4,8,6,6,9,1,10,4,8,2,3,6,2,1,1,2,8,1,3,11,5,2,7,6,6,2,5,5,
%U A396687 3,2,6,5,1,5,7,5,4,3,2,4,2,2,4,3,5,4,14
%N A396687 Smallest k > 0 such that 2*prime(n) - prime(n-k) is prime.
%H A396687 Ruud H.G. van Tol, <a href="/A396687/b396687.txt">Table of n, a(n) for n = 3..10000</a>
%F A396687 A078611(n) = prime(n) - prime(n - a(n)).
%e A396687 a(3) = 1, because prime(3) = 5 and prime(3 - a(3)) = prime(2) = 3 and 5 + (5 - 3) = 7 is prime.
%e A396687 a(14) = 6, because 6 is the smallest k > 0 for which 2 * prime(14) - prime(14 - k) is prime.
%t A396687 a[n_]:=Module[{k=1},While[!PrimeQ[2Prime[n]-Prime[n-k]], k++]; k]; Array[a,86,3] (* _Stefano Spezia_, Jun 02 2026 *)
%o A396687 (PARI) a(n)= if(n<3, 0, my(p=prime(n), k=0); until(isprime(p*2-prime(n-k++)), ); k)
%o A396687 (PARI) a(n) = {my(p = prime(n), ptwice = 2*p, other); forprime(q = p+1, ptwice-1, if(isprime(ptwice - q), other = ptwice - q; break)); n-primepi(other)} \\ _David A. Corneth_, Jun 02 2026
%Y A396687 Cf. A000040, A078611, A179835.
%K A396687 easy,nonn
%O A396687 3,2
%A A396687 _Ruud H.G. van Tol_, Jun 02 2026
