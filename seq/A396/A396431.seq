%I A396431 #31 May 30 2026 15:51:52
%S A396431 1,1,0,1,3,0,1,6,15,0,1,9,48,91,0,1,12,99,434,612,0,1,15,168,1191,
%T A396431 4212,4389,0,1,18,255,2524,15120,42867,32890,0,1,21,360,4595,39600,
%U A396431 199242,451704,254475,0,1,24,483,7566,85860,640590,2700060,4889280,2017356,0
%N A396431 Square array A(n,k), n>=0, k>=0, read by antidiagonals downwards, where A(n,k) = [x^n] F_k(x)/x and F_k(x) is the k-th iteration of x*G4(x)^3 with G4(x) = 1 + x*G4(x)^4.
%H A396431 Wikipedia, <a href="https://en.wikipedia.org/wiki/Fuss%E2%80%93Catalan_number">Fuss-Catalan number</a>
%F A396431 G.f. of column k: (1/x) * Series_Reversion( H_k(x) ), where H_k(x) is the k-th iteration of x*(1 - x)^3.
%F A396431 A(n,k) = Sum_{0 = x_0 <= x_1 <= ... <= x_{k-1} <= x_k = n} Product_{j=0..k-1} 3 * (x_j + 1) * binomial(4*x_{j+1} - x_j + 3,x_{j+1} - x_j)/(4*x_{j+1} - x_j + 3).
%F A396431 A(n,0) = 0^n; A(n,k) = 3 * Sum_{j=0..n} (j+1) * binomial(4*n-j+3,n-j)/(4*n-j+3) * A(j,k-1) for k > 0.
%e A396431 Square array begins:
%e A396431   1,     1,      1,       1,        1,        1,        1, ...
%e A396431   0,     3,      6,       9,       12,       15,       18, ...
%e A396431   0,    15,     48,      99,      168,      255,      360, ...
%e A396431   0,    91,    434,    1191,     2524,     4595,     7566, ...
%e A396431   0,   612,   4212,   15120,    39600,    85860,   164052, ...
%e A396431   0,  4389,  42867,  199242,   640590,  1646415,  3637809, ...
%e A396431   0, 32890, 451704, 2700060, 10606864, 32205894, 82080264, ...
%e A396431   ...
%o A396431 (PARI)
%o A396431 a(n, k, p=4, s=3, r=3) = {
%o A396431   my(T=matrix(n+1, n+1, row, col, my(xr=row-1, xc=col-1); if(xc<xr, 0, (s*xr+r)*binomial(p*xc-(p-s)*xr+r, xc-xr)/(p*xc-(p-s)*xr+r))));
%o A396431   my(TK=T^k);
%o A396431   TK[1, n+1];
%o A396431 };
%Y A396431 Columns k=0..1 give A000007, A006632(n+1).
%Y A396431 Cf. A158825, A396413, A396429, A396430, A396448.
