%S A396803 1,2,21,472,17165,885696,60160723,5127074240,530302613625,
%T A396803 64973353873600,9257356758475991,1511769934160962752,
%U A396803 279682145706373041541,58057540187330485694816,13414714180015379333747835,3426657504978728578742096896,961999174393487608271419378673,295303661080767889887838509502848
%N A396803 E.g.f. satisfies A(x) = x*exp( A^3(x) ).
%C A396803 Conjecture: a(n) is odd iff n is odd for n >= 1.
%C A396803 Conjecture: a(n) == [1,2,0] repeating (mod 3) for n >= 1.
%H A396803 Paul D. Hanna, <a href="/A396803/b396803.txt">Table of n, a(n) for n = 1..220</a>
%F A396803 E.g.f. A(x) = Sum_{n>=1} a(n)*x^n/n! satisfies the following formulas, in which A^n(x) denotes the n-th iteration of A(x).
%F A396803 (1.a) A^(-1)(x) = x * exp( -A^2(x) ).
%F A396803 (1.b) A(x) = x * exp( A^3(x) ).
%F A396803 (1.c) A^2(x) = A(x) * exp( A^4(x) ).
%F A396803 (1.d) A^3(x) = A^2(x) * exp( A^5(x) ).
%F A396803 (1.e) A^n(x) = A^(n-1)(x) * exp( A^(n+2)(x) ) for all n.
%F A396803 (2.a) A(x) = x * exp( A^2(x) * exp( A^4(x) * exp( A^6(x) * ... * exp( A^(2*n)(x) * exp( ... ))))), an infinite power tower.
%F A396803 (2.b) A^2(x) = A(x) * exp( A^3(x) * exp( A^5(x) * exp( A^7(x) * ... * exp( A^(2*n+1)(x) * exp( ... ))))), an infinite power tower.
%F A396803 (3.a) A^2(x) = x * exp(A^3(x) + A^4(x)).
%F A396803 (3.b) A^3(x) = x * exp(A^3(x) + A^4(x) + A^5(x)).
%F A396803 (3.c) A^n(x) = x * exp( Sum_{k=3..n+2} A^k(x) ) for n >= 1.
%F A396803 (3.d) A^n(x) = A^m(x) * exp( Sum_{k=m+3..n+2} A^k(x) ) for n >= m+1.
%F A396803 (4.a) A(x) = A^2(x) / exp(A^4(x)).
%F A396803 (4.b) A(x) = A^3(x) / exp(A^4(x) + A^5(x)).
%F A396803 (4.c) A(x) = A^4(x) / exp(A^4(x) + A^5(x) + A^6(x)).
%F A396803 (4.d) A(x) = A^n(x) / exp( Sum_{k=4..n+2} A^k(x) ) for n >= 2.
%F A396803 (5.a) A^3(x) = log( A(x)/x ).
%F A396803 (5.b) A^4(x) = log( A^2(x)/A(x) ).
%F A396803 (5.c) A^5(x) = log( A^3(x)/A^2(x) ).
%F A396803 (5.d) A^n(x) = log( A^(n-2)(x) / A^(n-3)(x) ) for all n.
%F A396803 From _Seiichi Manyama_, Jun 09 2026: (Start)
%F A396803 E.g.f. A(x) satisfies A(x) = x*exp(A^l(x)), where A^l(x) denotes the l-th iterate of A.
%F A396803 Let a(n,k,l) = n! * [x^n] A^k(x), where A^k(x) is the k-th iterate of A.
%F A396803 a(1,k,l) = 1; a(n,k,l) = (1/(n-1)) * Sum_{i=1..n-1} i * binomial(n,i) * a(n-i,k,l) * Sum_{j=1..k} a(i,j+l-1,l). (End)
%e A396803 E.g.f.: A(x) = x + 2*x^2/2! + 21*x^3/3! + 472*x^4/4! + 17165*x^5/5! + 885696*x^6/6! + 60160723*x^7/7! + 5127074240*x^8/8! + ...
%e A396803 where A(x) = x * exp( A^3(x) ).
%e A396803 RELATED SERIES.
%e A396803 The series reversion of A(x) begins
%e A396803 A^(-1)(x) = x - 2*x^2/2! - 9*x^3/3! - 172*x^4/4! - 5735*x^5/5! - 279846*x^6/6! - 18251387*x^7/7! + ...
%e A396803 where A^(-1)(x) = x * exp( -A^2(x) ).
%e A396803 The second iteration of A(x) begins
%e A396803 A^2(x) = x + 4*x^2/2! + 54*x^3/3! + 1388*x^4/4! + 55000*x^5/5! + 3016782*x^6/6! + 214723432*x^7/7! + ...
%e A396803 where A^2(x) = x * exp(A^3(x) + A^4(x)).
%e A396803 The third iteration of A(x) begins
%e A396803 A^3(x) = x + 6*x^2/2! + 99*x^3/3! + 2892*x^4/4! + 125625*x^5/5! + 7396398*x^6/6! + 557483577*x^7/7! + ...
%e A396803 where A^3(x) = log( A(x)/x ).
%e A396803 The fourth iteration of A(x) begins
%e A396803 A^4(x) = x + 8*x^2/2! + 156*x^3/3! + 5128*x^4/4! + 244040*x^5/5! + 15477684*x^6/6! + 1242137008*x^7/7! + ...
%e A396803 where A^4(x) = log( A^2(x)/A(x) ).
%o A396803 (PARI) \\ from A(x) = x * exp( A^3(x) ).
%o A396803 {a(n) = my(A=x); for(k=1, n, A = truncate(A) + x*O(x^k);
%o A396803 A = x * exp( subst(A,x,subst(A,x,A)) ) +x*O(x^n); ); EGF=A; n!*polcoef(A, n)}
%o A396803 {upto(n) = a(n); Vec(serlaplace(EGF))}
%o A396803 upto(25)
