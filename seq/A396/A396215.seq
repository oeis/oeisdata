%N A396215 a(n) is the smallest number k so that the k-th n-simplex number has exactly n prime factors, counted with multiplicity.
%C A396215 Also smallest k so that A001222(binomial(n+k-1, n)) = n.
%H A396215 David A. Corneth, <a href="/A396215/b396215.txt">Table of n, a(n) for n = 1..1200</a> (first 100 terms from Hoang Nguyen)
%e A396215 For n = 1, the smallest 1-simplex number (positive integer) with 1 prime factor is 2, the 2nd number of the sequence, so a(1) = 2.
%e A396215 For n = 3, the smallest 3-simplex number (tetrahedral number) with 3 prime factors is 20 = 2*2*5, the 4th number of the sequence, so a(3) = 4.
%t A396215 a[n_] := Module[{k = 1}, While[PrimeOmega[Binomial[n + k - 1, n]] != n, k++]; k]; Array[a, 56] (* _Amiram Eldar_, May 21 2026 *)
%o A396215 (Julia)
%o A396215 using Primes
%o A396215 function a(n)
%o A396215     x = big(1)
%o A396215     while true
%o A396215         if length(factor(Vector, prod(x + i for i in 0:n-1) ÷ factorial(big(n)))) == n
%o A396215             return x
%o A396215         end
%o A396215         x += 1
%o A396215     end
%o A396215 end
%o A396215 (Python)
%o A396215 from itertools import count
%o A396215 from collections import deque
%o A396215 from sympy import factorint
%o A396215 def A396215(n):
%o A396215     a = deque([sum(factorint(i).values()) for i in range(1,n+1)])
%o A396215     b = n+sum(a)
%o A396215     for k in count(n+1):
%o A396215         if sum(a)==b:
%o A396215             return k-n
%o A396215         a.popleft()
%o A396215         a.append(sum(factorint(k).values())) # _Chai Wah Wu_, May 21 2026
%o A396215 (PARI) a(n) = {my(q = 0); for(i = 1, oo, q+=bigomega(i+n); q-=bigomega(i); if(q == n, return(i+1)))} \\ _David A. Corneth_, May 31 2026
