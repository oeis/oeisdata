%U A396242 1536163527444,8676392430091,49005068761405,276785191890984,1563308583923238,8829712806018085,49871042277386167,281676302989375947
%N A396242 Expansion of 1 / (1 - B(B(x))), where B(x) = x/(1-x)^3.
%H A396242 Seiichi Manyama, <a href="/A396242/b396242.txt">Table of n, a(n) for n = 0..1000</a>
%H A396242 <a href="/index/Rec#order_09">Index entries for linear recurrences with constant coefficients</a>, signature (13,-63,154,-215,189,-108,40,-9,1).
%F A396242 G.f.: ((1-x)^3 - x)^3 / (((1-x)^3 - x)^3 - x*(1-x)^6).
%F A396242 a(n) = 13*a(n-1) - 63*a(n-2) + 154*a(n-3) - 215*a(n-4) + 189*a(n-5) - 108*a(n-6) + 40*a(n-7) - 9*a(n-8) + a(n-9) for n > 9.
%F A396242 a(0) = 1; a(n) = Sum_{i=1..n} Sum_{j=1..i} binomial(n+2*i-1,3*i-1) * binomial(i+2*j-1,3*j-1).
%o A396242 (PARI) a(n) = if(n==0, 1, sum(i=1, n, sum(j=1, i, binomial(n+2*i-1, 3*i-1)*binomial(i+2*j-1, 3*j-1))));
%Y A396242 Cf. A052529, A396243.
%K A396242 nonn,new
%O A396242 0,3
