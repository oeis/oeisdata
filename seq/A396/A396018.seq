%I A396018 #8 May 19 2026 16:36:58
%S A396018 1,3,7,10,19,55,91,217,493,985,1767,7564,24307,44251,99382,357643,
%T A396018 1076215,2330887,46024744,49481506,84441507,452419978,1572429415,
%U A396018 2608566411
%N A396018 Smallest number m such that m*(m+1)*(m+2)*(m+3)*(m+4) has exactly n distinct prime factors.
%C A396018 a(27) >= 5000000000.
%C A396018 Conjecture: a(n) is an increasing sequence.
%e A396018 For n = 9, a(9) = 91 and a(9)*(a(9) + 1)*(a(9) + 2)*(a(9) + 3)*(a(9) + 4) = 91*92*93*94*95 = (7*13)*(2*2*23)*(3*31)*(2*47)*(5*19) with 9 distinct prime factors.
%t A396018 n = 3; mink = 1; maxk = 100000; For[k = mink, k <= maxk, k++, If[PrimeNu[Times @@ {k, k + 1, k + 2, k + 3, k + 4}] == n, Print[{n, k}]; n++]]
%o A396018 (Python)
%o A396018 from itertools import count, islice
%o A396018 from sympy import factorint
%o A396018 def agen(): # generator of terms
%o A396018     wlst, adict, n = [set(factorint(1+i)) for i in range(5)], dict(), 3
%o A396018     for m in count(1):
%o A396018         v = len(wlst[0] | wlst[1] | wlst[2] | wlst[3] | wlst[4])
%o A396018         if v >= n and v not in adict:
%o A396018             adict[v] = m
%o A396018             while n in adict:
%o A396018                 yield adict[n]
%o A396018                 n += 1
%o A396018         wlst = wlst[1:] + [set(factorint(m+5))]
%o A396018 print(list(islice(agen(), 15))) # _Michael S. Branicky_, May 14 2026
