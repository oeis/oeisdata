%N A396398 a(n) = r(n,n), where r(1,k)=f(k)=round(k*c), r(n,k)=f(r(n-1,k)), c=sqrt(2).
%C A396398 a(n + 1)/a(n) approaches c erratically.
%t A396398 c = Sqrt[2]; f[k_] := f[k] = Round[c*k];
%t A396398 r[1, k_] := f[k]; r[n_, k_] := r[n, k] = f[r[n - 1, k]];
%t A396398 Table[r[n, n], {n, 1, 100}]
%Y A396398 Cf. A002193, A396385, A396396, A396397.
%K A396398 nonn,new
%O A396398 1,2
