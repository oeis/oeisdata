%I A396842 #9 Jul 06 2026 03:28:11
%S A396842 1,4,1728,345600000,72861813964800000,28905635425965921062092800000,
%T A396842 33780183586631030974787781557922614476800000,
%U A396842 167627599126638571669276600807778631524061621985742526873600000,4810545661002836174990569404533880920652056952285149688108574310400000000000000000000
%N A396842 a(n) = H(2*n)/H(n)^2, where H(n) = Product_{k=0..n} k^k is the hyperfactorial of n (A002109).
%C A396842 Equals the central terms of triangle A396840.
%F A396842 a(n) = Product_{k=1..n} (n+k)^(n+k) / k^k for n >= 0.
%F A396842 a(n) ~ 2^(2*n^2 + n + 1/12) * n^(n^2 - 1/12) / (A * exp(n^2/2)), where A is the Glaisher-Kinkelin constant A074962. - _Vaclav Kotesovec_, Jul 06 2026
%e A396842 The initial terms are
%e A396842   a(0) = 1;
%e A396842   a(1) = 2^2/1^1 = 4;
%e A396842   a(2) = (3^3*4^4)/(1^1*2^2)= 1728,
%e A396842   a(3) = (4^4*5^5*6^6)/(1^1*2^2*3^3) = 345600000;
%e A396842   a(4) = (5^5*6^6*7^7*8^8)/(1^1*2^2*3^3*4^4) = 72861813964800000;
%e A396842   ...
%t A396842 Table[Hyperfactorial[2*n]/Hyperfactorial[n]^2, {n, 0, 10}] (* _Vaclav Kotesovec_, Jul 06 2026 *)
%o A396842 (PARI) {H(n) = prod(k=1, n, k^k)} \\ hyperfactorial of n
%o A396842 {a(n) = H(2*n)/H(n)^2}
%o A396842 for(n=0,10, print1(a(n),", "))
%Y A396842 Cf. A396840, A002109, A079478.
%K A396842 nonn,new
%O A396842 0,2
%A A396842 _Paul D. Hanna_, Jul 06 2026
