%I A396828 #8 Jun 11 2026 23:57:48
%S A396828 6,8,10,14,15,21,27,33,35,55,65,77,91,119,133,143,187,209,221,247,299,
%T A396828 323,377,391,437,493,527,551,589,667,713,817,851,899,989,1073,1147,
%U A396828 1189,1247,1271,1333,1457,1517,1591,1739,1763,1927,2021,2173,2279,2419,2491
%N A396828 Numbers in A080257 with record low abundancy index.
%C A396828 Also numbers with at least 4 divisors that are superdeficient.
%H A396828 Hoang Nguyen, <a href="/A396828/b396828.txt">Table of n, a(n) for n = 1..10000</a>
%e A396828 a(2) = 8 as 8's abundancy index is (1+2+4+8)/8 = 1.875 < 2, which is 6's abundancy index.
%e A396828 a(3) = 10 as 10's abundancy index is (1+2+5+10)/10 = 1.8 < 1.875.
%o A396828 (Julia)
%o A396828 using Primes
%o A396828 function a(n)
%o A396828     num = 1
%o A396828     i = 1
%o A396828     min = 3
%o A396828     while i <= n
%o A396828         num += 1
%o A396828         a_index = sum(divisors(num)) // num
%o A396828         if length(divisors(num)) > 3 && a_index < min
%o A396828             print("$num, ")
%o A396828             min = a_index
%o A396828             i += 1
%o A396828         end
%o A396828     end
%o A396828 end
%Y A396828 Cf. A004394, A080257, A000040, A001248.
%K A396828 nonn,new
%O A396828 1,1
