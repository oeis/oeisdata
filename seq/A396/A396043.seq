%I A396043 #6 May 18 2026 00:53:13
%S A396043 1,2,4,24,48,8,112,32,192,688,832,1168,272,496,1744,1920,656,1984,896,
%T A396043 1472,1520,3072,3328,3520,3664,1328,1152,2432,6528,7024,7408,2960,
%U A396043 9040,9088,9232,9472,10048,5120,10672,5552,11344,11392,11584,11920,12112,6416,12928,13360,14272,15040,3056,2560
%N A396043 a(n) is the least k >= 1 such that A396002(n) is the least prime factor of 2^k + 1.
%C A396043 a(n) is the index of the first appearance of A396002(n) in A002586.
%F A396043 A002586(a(n)) = A396002(n).
%F A396043 a(n) = A002326((A396002(n)-1)/2).
%e A396043 a(4) = 24 because the least prime factor of 2^24 + 1 = 16777217 = 97 * 257 * 673 is 97 = A396002(4), and this is the first appearance of 97 in A002586.
%p A396043 A:= NULL: V:= {}:
%p A396043 p:= 2:
%p A396043 while p < 10^6 do
%p A396043   p:= nextprime(p); v:= NumberTheory:-MultiplicativeOrder(2, p)/2;
%p A396043   if v::integer and andmap(w -> v mod w <> 0 or (v/w)::even, V) then
%p A396043     A:= A, v; V:= V union {v}
%p A396043   fi;
%p A396043 od:
%p A396043 A;
%Y A396043 Cf. A002326, A002586, A396002, A396044.
%K A396043 nonn
%O A396043 1,2
%A A396043 _Robert Israel_, May 14 2026
