%N A396716 Number of composite numbers m, Omega(m) >= 3, with k <= m <= k^2 such that the largest divisor of k*m that is <= sqrt(k*m) equals k.
%C A396716 The largest divisor of n that is <= sqrt(n) is A033676(n). This sequence is the part of A163926(k) coming from m with bigomega(m) >= 3; together with the count for bigomega(m) = 2 it partitions A163926(k).
%e A396716 For k=4: the qualifying m are 8 and 12, so a(4)=1.
%t A396716 g[n_]:=Last[Select[Divisors[n],#^2<=n&]]; a[k_]:=Count[Range[k,k^2],m_/;PrimeOmega[m]>=3&&g[k*m]==k]; Array[a,73,2]
%o A396716 (PARI) g(n)=my(d=divisors(n)); d[(#d+1)\2];
%o A396716 a(k)=sum(m=k, k^2, bigomega(m)>=3 && g(k*m)==k);
%Y A396716 Cf. A001222, A033676, A163925, A163926.
%K A396716 nonn,new
%O A396716 2,6
