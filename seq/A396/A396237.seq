%t A396237 A396237[n_] := BitAnd[n, BitNot[n^2]]; Array[A396237, 100, 0] (* _Paolo Xausa_, May 21 2026 *)
%o A396237 (C) unsigned long long a(unsigned long long n){return n & ~(n*n) ; }
%o A396237 (PARI) a(n) = bitand(n, bitneg(n^2)); \\ _Michel Marcus_, May 20 2026
