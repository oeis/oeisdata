%S A396093 0,1,6,33,174,892,4480,22149,108144,522685,2505112,11921919,56396508,
%T A396093 265403751,1243376476,5802001140,26979276974,125062092939,
%U A396093 578101278342,2665535043771,12262237690928,56292277012925,257928385148946,1179746378224461,5387375927372810,24565077404044268,111855801487635036
%N A396093 G.f. A(x) = B(B(B(x))), the third iteration of B(x) = x/(1-x)^2.
%C A396093 Equals the self-convolution of A166482.
%C A396093 Conjecture: a(2*n) is even for n >= 1.
%C A396093 Conjecture: a(2*n-1) is even iff n is of the form 5*k-2 (k >= 1) for n >= 1.
%H A396093 Paul D. Hanna, <a href="/A396093/b396093.txt">Table of n, a(n) for n = 0..500</a>
%H A396093 <a href="/index/Rec#order_08">Index entries for linear recurrences with constant coefficients</a>, signature (14,-75,196,-269,196,-75,14,-1).
%F A396093 G.f. A(x) = Sum_{n>=1} a(n)*x^n satisfies the following formulas.
%F A396093 (1) A(x) = B^3(x), the third iteration of B(x) = x/(1-x)^2.
%F A396093 (2) A(x) = x * (1-x)^2 * (1 - 3*x + x^2)^2 / (1 - 7*x + 13*x^2 - 7*x^3 + x^4)^2.
%F A396093 a(n) = Sum_{k=0..n-1} A166482(n-k-1)*A166482(k) for n >= 1, where A166482(n) = Sum_{k=0..n} binomial(n+k,2*k) * Fibonacci(2*k+1).
%F A396093 a(n) = Sum_{i=1..n} Sum_{j=1..i} j * binomial(n+i-1,2*i-1) * binomial(i+j-1,2*j-1). - _Seiichi Manyama_ May 19 2026
%F A396093 From _Vaclav Kotesovec_, May 19 2026: (Start)
%F A396093 a(n) ~ ((7 + sqrt(5) + sqrt(38 + 14*sqrt(5)))/4)^n * n / (5*(7 - 2*sqrt(5))).
%F A396093 a(n) ~ n*exp(2*n*arcsinh((1 + sqrt(5))/4) + 2*arccoth(5 + 3*sqrt(5)))/15. (End)
%F A396093 From _Seiichi Manyama_, May 20 2026: (Start)
%F A396093 a(n) = 14*a(n-1) - 75*a(n-2) + 196*a(n-3) - 269*a(n-4) + 196*a(n-5) - 75*a(n-6) + 14*a(n-7) - a(n-8).
%F A396093 G.f.: x / ( (1-x) * (1-B(x)) * (1-B(B(x))) )^2, where B(x) = x/(1-x)^2. (End)
%F A396093 (n+33)*a(n) +(n-374)*a(n-1) +6*(-8*n+237)*a(n-2) +6*(22*n-379)*a(n-3) +6*(-20*n+269)*a(n-4) +(43*n-496)*a(n-5) +(-5*n+51)*a(n-6)=0. - _R. J. Mathar_, May 28 2026
%e A396093 G.f.: A(x) = x + 6*x^2 + 33*x^3 + 174*x^4 + 892*x^5 + 4480*x^6 + 22149*x^7 + 108144*x^8 + 522685*x^9 + 2505112*x^10 + ...
%e A396093 where A(x) = B(B(B(x))), the third iteration of B(x) = x/(1-x)^2
%e A396093 B(x) = x + 2*x^2 + 3*x^3 + 4*x^4 + 5*x^5 + 6*x^6 + 7*x^7 + ...
%e A396093 RELATED SERIES.
%e A396093 Given B(x) = x/(1-x)^2, the g.f. of A030267 begins
%e A396093 B(B(x)) = x + 4*x^2 + 14*x^3 + 46*x^4 + 145*x^5 + 444*x^6 + 1331*x^7 + 3926*x^8 + ... + A030267(n)*x^n + ...
%e A396093 Also, this sequence equals the self-convolution of A166482:
%e A396093 sqrt(A(x)/x) = 1 + 3*x + 12*x^2 + 51*x^3 + 221*x^4 + 965*x^5 + 4227*x^6 + 18540*x^7 + 81363*x^8 + ... + A166482(n)*x^n + ...
%t A396093 Rest[CoefficientList[Series[x * (1-x)^2 * (1 - 3*x + x^2)^2 / (1 - 7*x + 13*x^2 - 7*x^3 + x^4)^2, {x, 0, 30}], x]] (* _Vaclav Kotesovec_, May 19 2026 *)
%o A396093 (PARI) {a(n) = my(A = x * (1-x)^2 * (1 - 3*x + x^2)^2 / (1 - 7*x + 13*x^2 - 7*x^3 + x^4 +x*O(x^n))^2); polcoef(GF=A,n)}
%o A396093 {upto(n) = a(n); Vec(GF)}
%o A396093 upto(30)
%Y A396093 Cf. A030267, A396094, A166482, A119821.
%Y A396093 Cf. A396209, A396210.
