%I A396755 #5 Jun 10 2026 16:46:20
%S A396755 6,8,20,24,30,40,42,56,68,70,80,90,96,110,120,130,144,156,160,170,176,
%T A396755 182,198,210,212,224,232,234,240,260,264,280,286,296,306,312,320,330,
%U A396755 336,350,360,390,400,408,410,416,418,420,440,442,444,450,452,456,458,462
%N A396755 Numbers k such that there exist primes p <= q < k with (p, q, k) a Heronian triangle.
%C A396755 Since no Heronian triangle has a side 2, p and q are odd primes. A triangle with three odd sides cannot be Heronian (semiperimeter half-integer), so k is even.
%H A396755 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/HeronianTriangle.html">Heronian Triangle</a>
%e A396755 6 is a term because (5, 5, 6) is a Heronian triangle.
%e A396755 20 is a term because (11, 13, 20) is a Heronian triangle.
%p A396755 f := proc(k)
%p A396755     local m, p, q, u, v;
%p A396755     if irem(k, 2) = 1 or k < 6 then return false end if;
%p A396755     q := nextprime(iquo(k,2));
%p A396755     while q < k do
%p A396755         m := max(3, k - q + 1);
%p A396755         if irem(m, 2) = 0 then m := m + 1 end if;
%p A396755         u := k + q;
%p A396755         v := k - q;
%p A396755         p := nextprime(m - 1);
%p A396755         while p <= q do
%p A396755             if issqr(iquo(p + u, 2)*iquo(u - p, 2)*iquo(p + v, 2)*iquo(p - v, 2)) then
%p A396755                 return true
%p A396755             end if;
%p A396755             p := nextprime(p)
%p A396755         end do;
%p A396755         q := nextprime(q)
%p A396755     end do;
%p A396755     false
%p A396755 end proc:
%p A396755 A396755 := proc(n) option remember;
%p A396755     local k;
%p A396755     if n = 1 then return 6 end if;
%p A396755     for k from A396755(n - 1) + 2 by 2 do
%p A396755         if f(k) then return k end if
%p A396755     end do
%p A396755 end proc:
%p A396755 seq(A396755(n), n = 1 .. 72);
%Y A396755 Cf. A054875, A123323, A239246, A395186, A396756.
%K A396755 nonn
%O A396755 1,1
%A A396755 _Felix Huber_, Jun 05 2026
