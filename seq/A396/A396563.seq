%p A396563 det := LinearAlgebra:-Determinant: StirlingCycle := abs@Stirling1:
%p A396563 m := (n, i, j) -> StirlingCycle(n + i + 2, n + j):
%p A396563 M := (n, k) -> Matrix(k, k, (i, j) -> m(n, i, j)): A := (n, k) -> det(M(n, k)):
%p A396563 seq(seq(A(n - k, k), k = 0..n), n = 0..9);  # _Peter Luschny_, May 31 2026
%o A396563 (PARI) A(n, k) = matdet(matrix(k, k, i, j, abs(stirling(n+i+2, n+j, 1))))
