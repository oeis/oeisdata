%N A396420 a(n) = r(n,n), where r(1,k)=f(k)=floor(k*c), r(n,k)=f(r(n-1,k)), c=4/3.
%C A396420 a(n + 1)/a(n) approaches c erratically.
%t A396420 c = 4/3; f[k_] := f[k] = Floor[c*k];
%t A396420 r[1, k_] := f[k]; r[n_, k_] := r[n, k] = f[r[n - 1, k]];
%t A396420 Table[r[n, n], {n, 1, 100}]
%Y A396420 Cf. A396385, A396421, A396422.
%K A396420 nonn
