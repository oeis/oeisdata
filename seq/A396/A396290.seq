%T A396290 3152,3553,3978,4427,4900,5397,5918,6463,7032,7625,8242,8883,9548,
%U A396290 10237,10950,11687,12448,13233,14042,14875,15732,16613,17518,18447,19400,20377,21378,22403,23452,24525,25622,26743,27888,29057,30250,31467,32708,33973
%N A396290 a(n) = n*(12*n+5).
%C A396290 This is one of a set of 12 sequences that specify the possible moves of a Glinski queen in hexagonal chess (see A396288 for further information).
%H A396290 Paolo Xausa, <a href="/A396290/b396290.txt">Table of n, a(n) for n = 0..10000</a>
%H A396290 <a href="/index/Rec#order_03">Index entries for linear recurrences with constant coefficients</a>, signature (3,-3,1).
%F A396290 Sum_{n>=1} 1/a(n) = 12/25 + (sqrt(3) - 2)*Pi/10 - 3*log(3)/10 - 3*log(2)/5 + sqrt(3)*log(2 + sqrt(3))/5. - _Amiram Eldar_, May 23 2026
%t A396290 A396290[n_] := n*(12*n + 5); Array[A396290, 60, 0] (* _Paolo Xausa_, May 21 2026 *)
