%N A396416 Expansion of F_2(x)/x, where F_k(x) is the k-th iteration of x*G4(x) with G4(x) = 1 + x*G4(x)^4.
%F A396416 G.f.: (1/x) * Series_Reversion( H_2(x) ), where H_k(x) is the k-th iteration of x*(1 - x*G3(x)^2) with G3(x) = 1 + x*G3(x)^3.
%F A396416 a(n) = Sum_{k=0..n} (k+1) * binomial(4*k+1,k) * binomial(4*n-3*k+1,n-k)/((4*k+1) * (4*n-3*k+1)).
%o A396416 (PARI)
%o A396416 lista(nn, k=2, m=4) = {
%o A396416   my(T=matrix(nn+1, nn+1, r, c, my(xr=r-1, xc=c-1); if(xc<xr, 0, (xr+1)*binomial(m*xc-(m-1)*xr+1, xc-xr)/(m*xc-(m-1)*xr+1))));
%o A396416   my(TK=T^k);
%o A396416   TK[1, ];
%o A396416 };
%Y A396416 Column k=2 of A396413.
%Y A396416 Cf. A001764, A002293.
%K A396416 nonn,new
