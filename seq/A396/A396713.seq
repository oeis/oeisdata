%N A396713 Expansion of e.g.f. -W_3(-x)/(1 + W_3(-x)), where W_k(x) is the k-th iterate of LambertW(x).
%F A396713 E.g.f.: exp(B(x)) - 1, where B(x) is the e.g.f. of A396680.
%F A396713 a(n) = Sum_{k=1..n} n^(n-k) * binomial(n-1,k-1) * A396712(k).
%F A396713 a(n) = (n-1)! * Sum_{i,j,k,l >= 0 and i+j+k+l=n-1} (l+1) * n^i * (n-i)^j * (n-i-j)^k / (i!*j!*k!).
%o A396713 (PARI) my(N=20, x='x+O('x^N)); Vec(serlaplace(-lambertw(lambertw(lambertw(-x)))/(1+lambertw(lambertw(lambertw(-x))))))
