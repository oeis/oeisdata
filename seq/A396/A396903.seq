%I A396903 #32 Jul 08 2026 10:59:10
%S A396903 1,9,29,82,129,261,349,804,897,1161,1341,2378,2209,3141,3741,8776,
%T A396903 4929,8073,6877,10578,10121,12069,12189,23316,18145,19881,33309,28618,
%U A396903 24417,33669,29821,74896,38889,44361,45021,73554,50689,61893,64061,103716,68961,91089,79549
%N A396903 a(n) = Sum_{k=1..n} gcd(k^4,n^3).
%H A396903 Seiichi Manyama, <a href="/A396903/b396903.txt">Table of n, a(n) for n = 1..10000</a>
%F A396903 Multiplicative with a(p^e) = p^(3*e) + Sum_{k=0..e-1} (p^(e-k) - p^(e-k-1)) * p^min(4*k,3*e).
%F A396903 Equivalently, a(p^e) = p^e * ( 1 + ((p-1)/p) * Sum_{k=1..3*e} p^floor(3*k/4) ).
%F A396903 Let s and t be positive integers, and let a_{s,t}(n) = Sum_{k=1..n} gcd(k^s,n^t).
%F A396903 a_{s,t}(p^e) = p^min(s*e,t*e) + Sum_{k=0..e-1} (p^(e-k) - p^(e-k-1)) * p^min(s*k,t*e).
%F A396903 a_{s,t}(n) is multiplicative if and only if t <= s.
%F A396903 For t <= s, a_{s,t}(p^e) = p^e * ( 1 + ((p-1)/p) * Sum_{k=1..t*e} p^floor(((s-1)*k)/s) ).
%o A396903 (PARI) a(n) = sum(k=1, n, gcd(k^4, n^3));
%Y A396903 Cf. A343498, A393808, A396901.
%K A396903 nonn,mult
%O A396903 1,2
%A A396903 _Seiichi Manyama_, Jul 08 2026
