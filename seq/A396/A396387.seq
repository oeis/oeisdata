%N A396387 a(n) = r(n,n), where r(1,k)=f(k)=floor(k*c), r(n,k)=f(r(n-1,k)), c=e.
%C A396387 a(n + 1)/a(n) approaches c erratically.
%t A396387 c = E; f[k_] := f[k] = Floor[c*k];
%t A396387 r[1, k_] := f[k]; r[n_, k_] := r[n, k] = f[r[n - 1, k]];
%t A396387 Table[r[n, n], {n, 1, 100}]
%Y A396387 Cf. A001113, A396385, A396388, A396389.
