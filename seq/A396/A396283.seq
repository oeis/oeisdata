%T A396283 467,642,587,755,812,971,982,1257,1188,1493,1517,1752,1859,2212,2068,
%U A396283 2499,2636,2991,2958,3513,3412,4021,4088,4447,4636,5397,5144,5890,6012,6603,6686,7645,7524,8415
%N A396283 a(n) = Sum_{k=1..n} (n mod k)^2.
%F A396283 a(n) = n^3 - Sum_{k=1..n} k * floor(n/k) * ( 2 * n - k * floor(n/k) ).
%F A396283 a(n) = n * ( A000290(n) - 2 * A024916(n) ) + A350123(n).
%F A396283 a(n) ~ n^3 * (1 - Pi^2/18 - zeta(3)/3).
%t A396283 Table[Sum[Mod[n, k]^2, {k, n}], {n, 55}]
%o A396283 (Python)
%o A396283 def A396283(n):
%o A396283     c, j = n**3, 1
%o A396283     while j <= n:
%o A396283         k = n//j
%o A396283         m = n//k
%o A396283         c += k**2*((a:=m*(m+1))*(2*m+1)-(b:=(j-1)*j)*(2*j-1))//6-n*k*(a-b)
%o A396283         j = m+1
%o A396283     return c # _Chai Wah Wu_, May 21 2026
%Y A396283 Cf. A000290, A004125, A024916, A051126, A067459, A309176, A350123, A396284.
