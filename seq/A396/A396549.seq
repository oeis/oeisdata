%U A396549 0,0,0,0,0,0,48,0,0,0,0,0,0,0,60,36,0,0,0,0,0,0,44,0,0,0,0,0,0,0,84,0,0,0,0
%N A396549 The sum of the coreful divisors of n that are not exponential unitary divisors of n.
%C A396549 All the exponential unitary divisors (A361255) of n are by definition coreful divisors (A284318) of n (see A396548).
%C A396549 The number of these divisors is A396548(n).
%H A396549 Amiram Eldar, <a href="/A396549/b396549.txt">Table of n, a(n) for n = 1..10000</a>
%F A396549 a(n) = A057723(n) - A322857(n).
%F A396549 a(n) = 0 if and only if n is cubefree (A004709).
%F A396549 a(n) = A396544(n) if and only if n is an exponentially squarefree number (A209061).
%t A396549 f1[p_, e_] = (p^(e+1)-1)/(p-1) - 1;
%t A396549 f2[p_, e_] = DivisorSum[e, p^# &, CoprimeQ[#, e/#] &];
%t A396549 a[n_] := Module[{fct = FactorInteger[n]}, Times @@ f1 @@@ fct - Times @@ f2 @@@ fct]; a[1] = 0; Array[a, 100]
%o A396549 (PARI) a(n) = {my(f = factor(n)); prod(i = 1, #f~, (f[i,1]^(f[i,2]+1) - 1)/(f[i,1]-1) - 1) - prod(i = 1, #f~, sumdiv(f[i,2], d, if(gcd(d, f[i,2]/d) == 1, f[i,1]^d)));}
%Y A396549 Cf. A004709, A057723, A209061, A284318, A322857, A361255, A396544, A396548.
%K A396549 nonn,easy
%O A396549 1,8
%A A396549 _Amiram Eldar_, May 29 2026
