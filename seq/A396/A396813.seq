%I A396813 #11 Jun 30 2026 07:26:02
%S A396813 0,1,1,4,6,11,13,20,24,33,37,48,54,67,73,88,96,113,121,140,150,171,
%T A396813 181,204,216,241,253,280,294,323,337,368,384,417,433,468,486,523,541,
%U A396813 580,600,641,661,704,726,771,793,840,864,913,937,988,1014,1067,1093,1148,1176,1233,1261,1320,1350
%N A396813 Lower (1/2,1) midsequence of (floor[n/2]^2) and (ceiling[n/2]^2); see Comments.
%C A396813 Suppose that s = (s(n)) and t = (t(n)) are sequences of numbers and h > 0 and k > 0. The lower (h, k)-midsequence of s and t is floor(h*s + k*t); the upper (h, k)-midsequence of s and t is ceiling(h*s + k*t).
%H A396813 <a href="/index/Rec#order_07">Index entries for linear recurrences with constant coefficients</a>, signature (1,1,-1,1,-1,-1,1).
%F A396813 a(n) = a(n-1) + a(n-2) - a(n-3) + a(n-6) - a(n-7) - a(n-8) + a(n-9), with (a(0),...,a(8)) = (0, 1, 1, 4, 6, 11, 13, 20).
%F A396813 G.f.: -x*(1 + 2*x^2 + 2*x^3 + x^4)/((-1 + x)^3*(1 + x)^2*(1 + x^2)).
%F A396813 (-n+2)*a(n) +a(n-1) +3*a(n-2) +a(n-3) +(n+1)*a(n-4) +4*(n-3)=0. - _R. J. Mathar_, Jun 30 2026
%e A396813 s(n) = A008794(n+1):  (0, 1, 1, 4, 4, 9, 9, 16, 16, ...).
%e A396813 t(n) = A008794(n+2):  (1, 1, 4, 4, 9, 9, 16, 16, 25, ...).
%e A396813 (u(n)) = (0, 1, 1, 4, 6, 11, 13, 20, 24, 33, 37, 48, ...).
%e A396813 (v(n)) = (0, 1, 2, 5, 6, 11, 14, 21, 24, 33, 38, 49, ...).
%t A396813 z = 60; f[n_] := Floor[n/2]^2; g[n_] := Ceiling[n/2]^2;
%t A396813 r = 1/2; s = 1;
%t A396813 u[n_] := Floor[r*f[n] + s*g[n]]
%t A396813 v[n_] := Ceiling[r*f[n] + s*g[n]]
%t A396813 Table[u[n], {n, 0, z}]
%t A396813 Table[v[n], {n, 0, z}]
%t A396813 (* Also *)
%t A396813 LinearRecurrence[{1, 1, -1, 1, -1, -1, 1}, {0, 1, 1, 4, 6, 11, 13}, 30]
%t A396813 LinearRecurrence[{1, 1, -1, 1, -1, -1, 1}, {0, 1, 2, 5, 6, 11, 14}, 30]
