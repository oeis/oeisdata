%N A396900 E.g.f. A(x) satisfies A(x) = 1 + x * exp(x) * A(x * exp(x)).
%F A396900 a(0) = 1; a(n) = n * Sum_{k=0..n-1} (k+1)^(n-k-1) * binomial(n-1,k) * a(k).
%o A396900 (PARI) a_vector(n, s=1, t=1) = my(v=vector(n+1)); v[1]=1; for(i=1, n, v[i+1]=i*sum(k=0, i-1, (s*k+t)^(i-k-1)*binomial(i-1, k)*v[k+1])); v;
