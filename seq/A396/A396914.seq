%N A396914 Expansion of e.g.f. cosh( 1 / (2 - exp(x)) - 1 ).
%F A396914 a(n) = Sum_{k=0..n} Stirling2(n,k) * A088312(k).
%t A396914 nmax = 22; CoefficientList[Series[Cosh[1/(2 - Exp[x]) - 1], {x, 0, nmax}], x] Range[0, nmax]!
%t A396914 (* Alternative: *)
%t A396914 Join[{1}, Table[Sum[Sum[StirlingS2[n, k] Binomial[k - 1, 2 j - 1] k!/(2 j)!, {j, 1, Floor[k/2]}], {k, 0, n}], {n, 1, 22}]]
