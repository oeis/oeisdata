%N A396833 The constant coefficient of (x + y + y^-1 + x^-1 + x^-1*y^-1)^n.
%C A396833 The Newton polytope of the Laurent polynomial x + y + y^-1 + x^-1 + x^-1*y^-1 is a reflexive polytope.
%H A396833 Vaclav Kotesovec, <a href="/A396833/b396833.txt">Table of n, a(n) for n = 0..1000</a>
%F A396833 From _Vaclav Kotesovec_, Jun 09 2026: (Start)
%F A396833 Recurrence: n^2*(115*n - 213)*a(n) = -2*(n-1)*(115*n^2 - 213*n + 119)*a(n-1) + (1955*n^3 - 7531*n^2 + 9184*n - 3612)*a(n-2) + (n-2)*(7015*n^2 - 20008*n + 12257)*a(n-3) + 43*(n-3)*(n-2)*(115*n - 98)*a(n-4).
%F A396833 a(n) ~ sqrt(37 - 52*(2/(23*(21551 + 2595*sqrt(69))))^(1/3) + 2*(2/23)^(2/3)*(21551 + 2595*sqrt(69))^(1/3)) * (((-1 + ((997 - 69*sqrt(69))/2)^(1/3) + ((997 + 69*sqrt(69))/2)^(1/3))/3)^n / (2*sqrt(15)*Pi*n)). (End)
%F A396833 a(n) = Sum_{k=0..floor(n/2)} binomial(n,k) * binomial(2*k,k) * binomial(k,n-2*k). - _Seiichi Manyama_, Jun 10 2026
%t A396833 Table[SeriesCoefficient[Expand[(x + y + y^-1 + x^-1 + x^-1*y^-1)^n], {x, 0, 0}, {y, 0, 0}], {n, 0, 25}] (* _Vaclav Kotesovec_, Jun 09 2026 *)
