%I A396570 #10 Jun 04 2026 21:46:07
%S A396570 2,8,14,98,398,404,518,698,788,908,1118,1148,1268,1358,3248,4208
%N A396570 Numbers == 2 (mod 6) that are not the sum of two distinct upper twin primes.
%C A396570 Members of A016933 that are not in A334160.
%C A396570 Conjecture: the sequence is finite and these are all the terms.
%e A396570 a(3) = 14 is a term because 14 == 2 (mod 6) and 14 is not the sum of two distinct members of A006512 (it is 7 + 7, but these are not distinct).
%p A396570 N:= 10^6: # for terms <= N
%p A396570 P:= select(t -> isprime(t) and isprime(t-2), [seq(i, i=7..N, 6)]):
%p A396570 sort(convert({seq(i,i=2..N,6)} minus select(`<=`, {seq(seq(P[i]+P[j], i=1..j-1), j=1..nops(P))}, N),list));
%Y A396570 Cf. A002375, A006512, A016933, A187759, A334160.
%K A396570 nonn,more,new
%O A396570 1,1
%A A396570 _Robert Israel_, May 29 2026
