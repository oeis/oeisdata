%T A396311 155671,316593,643864,1309437,2663032,5415868,11014368,22400164,
%U A396311 45555704,92647636,188419537,383192949,779307921,1584895648,3223237104,6555168131,13331389479,27112339739
%N A396311 Number of tilings of a 5 X n rectangle by unit squares and the Ferrers tile (3,2,1).
%C A396311 The Ferrers tile (3,2,1) has three columns of heights 3, 2, and 1.
%H A396311 Per Alexandersson and John Ahlberg, <a href="https://arxiv.org/abs/2605.03473">Polynomials from tilings of rectangles</a>, arXiv:2605.03473 [math.CO], 2026.
%H A396311 <a href="/index/Rec#order_07">Index entries for linear recurrences with constant coefficients</a>, signature (1,0,3,1,3,0,1).
%F A396311 G.f.: 1/((1 + x^2)*(1 - x - x^2 - 2*x^3 - x^5)).
%F A396311 a(n) = a(n-1) + 3*a(n-3) + a(n-4) + 3*a(n-5) + a(n-7) for n>=1, with a(0)=1 and a(n)=0 if n<0.
%p A396311 a:= proc(n) option remember; `if`(n<1, 1-signum(-n),
%p A396311       a(n-1)+3*a(n-3)+a(n-4)+3*a(n-5)+a(n-7))
%p A396311     end:
%p A396311 seq(a(n), n=0..35);  # _Alois P. Heinz_, May 21 2026
%t A396311 CoefficientList[Series[1/((1+x^2)*(1-x-x^2-2x^3-x^5)),{x,0,35}],x] (* _Stefano Spezia_, May 21 2026 *)
%Y A396311 Cf. A193147 for the same tile on 4 X n rows.
%K A396311 nonn,easy
%O A396311 0,4
%A A396311 _Per Alexandersson_, May 21 2026
