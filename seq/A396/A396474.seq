%I A396474 #12 May 29 2026 01:14:56
%S A396474 1,2,4,22,72,300,1108,4352,16560,64040,245616,946000,3635728,13988416,
%T A396474 53790080,206899840,795709696,3060423648,11770418496,45270022048,
%U A396474 174110593280,669640768800,2575475680256,9905435949216,38096882802688,146522877600928,563535604643584,2167391273031584
%N A396474 Expansion of g.f. (1 - 7*x^2 - 2*x^4)/(1 - 2*x - 7*x^2 - 2*x^4 + 2*x^5).
%C A396474 Sum of fourth powers of A396471 row entries.
%H A396474 Paolo Xausa, <a href="/A396474/b396474.txt">Table of n, a(n) for n = 0..1000</a>
%H A396474 Richard P. Stanley, <a href="https://www.gathering4gardner.org/g4g15gift/ExchangeArchive-FibArray-G15-087-1.pdf">A Fibonacci Array</a>, in Gathering for Gardner 15 Gift Exchange Book, 2024 (see p. 5).
%H A396474 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (2,7,0,2,-2).
%F A396474 a(n) = Sum_{k=0..A001911(n)} A396471(n,k)^4.
%F A396474 a(n) = 2*a(n-1) + 7*a(n-2) + 2*a(n-4) - 2*a(n-5), with a(0) = 1, a(1) = 2, a(2) = 4, a(3) = 22, a(4) = 72.
%t A396474 Module[{x}, CoefficientList[Series[(1 - 7*x^2 - 2*x^4)/(1 - 2*x - 7*x^2 - 2*x^4 + 2*x^5), {x, 0, 29}], x]]
%t A396474 (* Alternative *)
%t A396474 LinearRecurrence[{2, 7, 0, 2, -2}, {1, 2, 4, 22, 72}, 30]
%Y A396474 Cf. A001911, A396471.
%Y A396474 Cf. other sum of r-th powers of A396471 row entries: A000079 (r=1), A052987 (r=2), A396473 (r=3), A396475 (r=5), A396516 (r=6).
%K A396474 nonn,easy,new
%O A396474 0,2
%A A396474 _Paolo Xausa_, May 28 2026
