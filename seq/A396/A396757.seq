%N A396757 a(n) = Sum_{1 <= x_1, x_2, x_3, x_4 <= n} gcd(x_1, x_2, x_3, n)/gcd(x_1, x_2, x_3, x_4, n).
%F A396757 a(n) = Sum_{d|n} J_3(n/d) * (n/d) * sigma_2(d^2)/sigma(d^2), where J_k is the k-th Jordan totient function.
%F A396757 Multiplicative with a(p^e) = (p^(4*e)*(p^2+p+1)^2 - p^(2*e)*(p^2+1) + 1)/((p+1)^2*(p^2+1)).
%o A396757 (PARI) J(n, k) = sumdiv(n, d, d^k*moebius(n/d));
%o A396757 a(n) = sumdiv(n, d, J(n/d, 3)*n/d*sigma(d^2, 2)/sigma(d^2));
