%t A396561 Block[{c, k, m, q, r, s, w, nn, rad},
%t A396561   nn = 105; c[_] := False; q[_] := 0; r = s = 1;
%t A396561   rad[n_] := rad[n] = Times @@ FactorInteger[n][[All, 1]];
%t A396561   Reap[Do[w = GCD[r, s]; m = r/w; k = m;
%t A396561     While[Or[c[k], ! CoprimeQ[w, k] ], k += m];
%t A396561       c[k] = True; s = r; Sow[++q[r = rad[k]]], {i, nn}] ][[-1, 1]] ]
