%T A396712 12742007742904,576324591304332,28326059937391216,1503263422548587182,
%U A396712 85673269657292585160,5218695114377042993168,338364702623445370392640,23266198707708733214014098
%N A396712 Expansion of e.g.f. -W_2(-x)/(1 + W_2(-x)), where W_k(x) is the k-th iterate of LambertW(x).
%C A396712 a(n) is the number of lists of trees of trees on n labeled nodes. - _Natalia L. Skirrow_, Jun 28 2026
%F A396712 E.g.f.: exp(B(x)) - 1, where B(x) is the e.g.f. of A396679.
%F A396712 a(n) = Sum_{k=1..n} n^(n-k) * binomial(n-1,k-1) * k^k.
%F A396712 a(n) = (n-1)! * Sum_{i,j,k >= 0 and i+j+k=n-1} (k+1) * n^i * (n-i)^j / (i!*j!).
%F A396712 From _Natalia L. Skirrow_, Jun 28 2026: (Start)
%F A396712 a(n) = n! * [t^n] (1 - t/e^t) * e^(n*t*(1 + e^-t)).
%F A396712 a(n) ~ n^n * e^(n/e) * sqrt(1 - 1/e) ~ A290840(n) * (1 - 1/e).
%F A396712 a(n) = A290840(n) - Sum_{k=1..n} C(n, k) * k^(k-1) * A290840(n-k). (End)
%t A396712 Table[Sum[n^(n-k) * Binomial[n-1, k-1] * k^k, {k, 1, n}], {n, 1, 20}] (* _Vaclav Kotesovec_, Jun 29 2026 *)
%o A396712 (PARI) my(N=20, x='x+O('x^N)); Vec(serlaplace(-lambertw(lambertw(-x))/(1+lambertw(lambertw(-x)))))
%Y A396712 Column k=2 of A396711.
%Y A396712 Cf. A000312, A290840, A396679, A274390 (iterations of the tree function).
%K A396712 nonn
%O A396712 1,2
%A A396712 _Seiichi Manyama_, Jun 03 2026
