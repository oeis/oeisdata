%S A396464 1,1,2,3,5,8,4,12,3,15,3,18,6,24,2,26,13,39,3,42,7,49,7,56,7,63,9,72,
%T A396464 3,75,5,80,10,90,5,95,19,114,6,120,5,125,25,150,2,152,8,160,2,162,9,
%U A396464 171,9,180,2,182,7,189,3,192,8,200,8,208,8,216,3,219,73
%N A396464 a(1) = a(2) = 1. For even n, a(n) = a(n-1) + a(n-2). For odd n, a(n) = a(n-1) divided by the largest proper factor found in the previous terms. If no proper factor is present, then a(n) = a(n-1) + a(n-2).
%C A396464 Do all integers appear in this sequence? Through 100000 terms, the smallest number that is not present is 191.
%C A396464 This sequence grows in a very erratic fashion. There are long stretches of oscillation with relatively constant growth and then sudden jumps.
%H A396464 David Consiglio, Jr., <a href="/A396464/b396464.txt">Table of n, a(n) for n = 1..10000</a>
%e A396464 a(7) = 4 because a(6) = 8 and the largest proper divisor of 8 that appears in the sequence is 2. 8 / 2 = 4.
%t A396464 s={1,1,2};Do[If[EvenQ[n],AppendTo[s,s[[-1]]+s[[-2]]],pd=Rest@Drop[Divisors[s[[-1]] ],-1];If[ContainsAny[s,pd],AppendTo[s,s[[-1]]/Max[Select[pd,MemberQ[s,#]&]]],AppendTo[s,s[[-1]]+s[[-2]]]]],{n,2,67}];s (* _James C. McMahon_, May 31 2026 *)
%o A396464 (Python)
%o A396464 from sympy import divisors
%o A396464 def A396464(n):
%o A396464     terms = [1, 1]
%o A396464     addflag = False
%o A396464     while len(terms) < n:
%o A396464         if addflag:
%o A396464             terms.append(terms[-1] + terms[-2])
%o A396464         else:
%o A396464             le = list(reversed(list(divisors(terms[-1]))[1:-1]))
%o A396464             divflag = False
%o A396464             for x in le:
%o A396464                 if x in terms:
%o A396464                     terms.append(terms[-1] // x)
%o A396464                     divflag = True
%o A396464                     break
%o A396464             if not divflag:
%o A396464                 terms.append(terms[-1] + terms[-2])
%o A396464         addflag = not addflag
%o A396464     return terms
%K A396464 nonn,new
%O A396464 1,3
%A A396464 _David Consiglio, Jr._, May 26 2026
