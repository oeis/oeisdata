%I A396673 #8 Jun 04 2026 22:37:09
%S A396673 21,58895,4178503,141828181,2679208597,166157155763,145260505801
%N A396673 a(n)=s is the first occurrence of 3 consecutive odd squarefree semiprimes r, s, t (A046388) such that gcd(r,s,t) = prime(n).
%e A396673   n prime(n)       r      a(n)=s           t
%e A396673   2    3          15          21          33
%e A396673   3    5       58885       58895       58915
%e A396673   4    7     4178489     4178503     4178531
%e A396673   5   11   141828137   141828181   141828203
%e A396673   6   13  2679208571  2679208597  2679208649
%o A396673 (PARI) a396673(n) = if(n<2,return(-1)); my(p=prime(n), p1=15, p2=21); forstep(k=33, oo, 2, my(f=factor(k)); if(omega(f)==2 && bigomega(f)==2, p3=k; if(gcd([p1,p2,p3])==p, return(p2)); p1=p2; p2=p3));
%Y A396673 Cf. A046388.
%K A396673 nonn,hard,more,new
%O A396673 2,1
%A A396673 _Hugo Pfoertner_, Jun 02 2026
