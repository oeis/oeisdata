%I A396050 #7 May 18 2026 19:27:18
%S A396050 360,3024,113400,37122624,851350500,514926720,781539759000,
%T A396050 3808863131673600,42877225028137500,3762129424572110592000,
%U A396050 2423034863565078262500,13896347660226074115072000,7905151242381067831406250,84688371004458264623668408320000
%N A396050 Coefficient of S_m(n) in the linear equality by Plouffe for the odd values of the Riemann zeta function, where S_m(n) = Sum_{k>=1} 1/((k^n)*(exp(2*Pi*k)-1)).
%H A396050 Jwalin Bhatt, <a href="/A396050/b396050.txt">Table of n, a(n) for n = 1..225</a>
%H A396050 Simon Plouffe, <a href="http://www.plouffe.fr/simon/inspired2.pdf">Identities inspired by Ramanujan Notebooks (part 2)</a>, April 2006.
%H A396050 Linas Vepštas, <a href="https://doi.org/10.1007/s11139-011-9335-9">On Plouffe's Ramanujan identities</a>, The Ramanujan Journal, Vol. 27 (2012), pp. 387-408; <a href="https://arxiv.org/abs/math/0609775">arXiv preprint</a>, arXiv:math/0609775 [math.NT], 2006-2010.
%H A396050 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/RiemannZetaFunction.html">Riemann Zeta Function</a>.
%H A396050 Wikipedia, <a href="https://en.wikipedia.org/wiki/Particular_values_of_the_Riemann_zeta_function#%CE%B6(2n_+_1)">zeta(2n+1)</a>.
%F A396050 Let S_p(n) = Sum_{k>=1} 1/((k^n)*(exp(2*Pi*k)+1)) and S_m(n) = Sum_{k>=1} 1/((k^n)*(exp(2*Pi*k)-1)), then:
%F A396050 For odd n:
%F A396050   a(n) = 2*A395662(n).
%F A396050   A395662(n)*zeta(2n+1) - A395663(n)*Pi^(2n+1) + a(n)*S_m(2n+1) = 0.
%F A396050 For even n:
%F A396050   a(n) = 2*A395662(n) + A395748(n/2).
%F A396050   A395662(n)*zeta(2n+1) - A395663(n)*Pi^(2n+1) + a(n)*S_m(2n+1) + A395748(n/2)*S_p(2n+1) = 0.
%e A396050 180*zeta(3) - 7*Pi^(3) + 360*S_m(3) + 0*S_p(3) = 0.
%e A396050 1470*zeta(5) - 5*Pi^(5) + 3024*S_m(5) + 84*S_p(5) = 0.
%e A396050 56700*zeta(7) - 19*Pi^(7) + 113400*S_m(7) + 0*S_p(7) = 0.
%e A396050 18523890*zeta(9) - 625*Pi^(9) + 37122624*S_m(9) + 74844*S_p(9) = 0.
%t A396050 a[n_] := Module[{n0, s, s1, s2, f, sVal},
%t A396050   If[OddQ[n],
%t A396050    (* Case: 4n - 1 *)
%t A396050    n0 = Floor[n/2] + 1;
%t A396050    s = Sum[
%t A396050      (-1)^j * Binomial[4*n0, 2*j] * BernoulliB[4*n0 - 2*j] * BernoulliB[2*j],
%t A396050      {j, 0, 2*n0}
%t A396050    ];
%t A396050    2 * Denominator[-2^(4*n0 - 2) * s / Factorial[4*n0]]
%t A396050    ,
%t A396050    (* Case: 4n + 1 *)
%t A396050    n0 = n/2;
%t A396050    s1 = Sum[
%t A396050      (-4)^(n0 + j) * Binomial[4*n0 + 2, 4*j] * BernoulliB[4*n0 - 4*j + 2] * BernoulliB[4*j],
%t A396050      {j, 0, n0}
%t A396050    ];
%t A396050    s2 = Sum[
%t A396050      (-4)^j * Binomial[4*n0 + 2, 2*j] * BernoulliB[4*n0 - 2*j + 2] * BernoulliB[2*j],
%t A396050      {j, 0, 2*n0 + 1}
%t A396050    ];
%t A396050    sVal = 1 + (-4)^n0 - 2^(4*n0 + 1);
%t A396050    f = 2^(4*n0 + 1) * (s1 + s2/2) / Factorial[4*n0 + 2];
%t A396050    2 * Denominator[f] - 2 * Denominator[f] * sVal
%t A396050   ]
%t A396050 ]
%o A396050 (Python)
%o A396050 from sympy import binomial, bernoulli, factorial
%o A396050 def a(n):
%o A396050     if n%2 == 1: # 4n - 1
%o A396050         n = n//2 + 1
%o A396050         s = sum(
%o A396050             (-1)**j * binomial(4*n, 2*j) * bernoulli(4*n-2*j) * bernoulli(2*j)
%o A396050             for j in range(2*n + 1)
%o A396050         )
%o A396050         return 2*(-2**(4*n-2) * s / factorial(4*n)).denominator
%o A396050     else: # 4n + 1
%o A396050         n //= 2
%o A396050         s1 = sum(
%o A396050             (-4)**(n+j) * binomial(4*n+2, 4*j) * bernoulli(4*n-4*j+2) * bernoulli(4*j)
%o A396050             for j in range(n+1)
%o A396050         )
%o A396050         s2 = sum(
%o A396050             (-4)**j * binomial(4*n+2, 2*j) * bernoulli(4*n-2*j+2) * bernoulli(2*j)
%o A396050             for j in range(2*n+2)
%o A396050         )
%o A396050         s = 1 + (-4)**n - 2**(4*n+1)
%o A396050         f = 2**(4*n+1) * (s1+s2/2) / factorial(4*n+2)
%o A396050         return 2*f.q - 2*f.denominator*s
%Y A396050 Cf. A395662, A395663, A395748.
%K A396050 nonn
%O A396050 1,1
%A A396050 _Jwalin Bhatt_, May 14 2026
