%S A396573 11,17,29,37,41,43,59,67,71,79,97,101,103,107,109,127,131,137,149,151,
%T A396573 157,163,167,173,179,191,193,197,223,227,229,233,239,251,257,263,269,
%U A396573 271,277,281,307,311,313,331,347,349,353,367,373,379,383,397,419,431,433,439,443,457,461,463
%N A396573 Primes p such that the gap to the next prime is strictly less than floor(log_2(p)).
%C A396573 Terms are {p in primes | g < floor(log_2(p)) }, where g is the forward prime gap.
%e A396573 For p = 11: next prime is 13; gap = 2, floor(log_2(11)) = 3, 2 < 3 is true, so 11 is included.
%e A396573 For p = 13: next prime is 17; gap = 4, floor(log_2(13)) = 3, 4 < 3 is false, so 13 is excluded.
%t A396573 Select[Prime[Range[PrimePi[463]]],NextPrime[#]-#<Floor[Log2[#]]&] (* _James C. McMahon_, Jun 06 2026 *)
%o A396573 (Python)
%o A396573 from sympy import nextprime
%o A396573 def A000523(n): return n.bit_length() - 1
%o A396573 def sub_dimensional_primes(limit):
%o A396573     sub_primes = []
%o A396573     p = 11
%o A396573     while p < limit:
%o A396573         if nextprime(p) - p < A000523(p):
%o A396573             sub_primes.append(p)
%o A396573         p = nextprime(p)
%o A396573     return sub_primes
%o A396573 print(sub_dimensional_primes(500))
%Y A396573 Cf. A000040 (primes), A000523 (floor(log_2)), A151800 (next prime), A396203, A396279, A396282.
%K A396573 nonn,changed
%O A396573 1,1
%A A396573 _Sajid Hussain_, May 29 2026
