%S A396075 0,0,0,0,1,0,1,2,3,4,6,8,12,15,21,27,37,46,60,74,94,114,143,172,212,
%T A396075 254,307,364,436,511,605,706,827,958,1115,1282,1481,1694,1942,2210,
%U A396075 2520,2851,3233,3643,4109,4609,5176,5782,6465,7196,8012,8887,9861,10899,12051,13281,14636,16082,17671,19362
%N A396075 Number of strict integer partitions of 2*n with reverse-alternating sum 8.
%C A396075 Also the number of partitions of n+32 into 8 distinct parts containing the part 8.
%H A396075 <a href="/index/Rec#order_26">Index entries for linear recurrences with constant coefficients</a>, signature (0,2,2,0,-3,-3,-1,1,2,2,1,1,0,-1,-1,-2,-2,-1,1,3,3,0,-2,-2,0,1).
%F A396075 G.f.: Sum_{j=1..8} q^(j*(j-1)+4) * q_binomial(7,j-1) / Product_{k=1..j-1} (1-q^k).
%F A396075 G.f.: Sum_{j=1..8} (-1)^(j-1) * q^(j*(j-1)/2+4) / Product_{k=1..8-j} (1-q^k).
%F A396075 a(n) = 2*a(n-2) + 2*a(n-3) - 3*a(n-5) - 3*a(n-6) - a(n-7) + a(n-8) + 2*a(n-9) + 2*a(n-10) + a(n-11) + a(n-12) - a(n-14) - a(n-15) - 2*a(n-16) - 2*a(n-17) - a(n-18) + a(n-19) + 3*a(n-20) + 3*a(n-21) - 2*a(n-23) - 2*a(n-24) + a(n-26) for n > 58.
%o A396075 (PARI) my(N=60, q='q+O('q^N)); concat([0, 0, 0, 0], Vec(sum(j=1, 8, (-1)^(j-1)*q^(j*(j-1)/2+4)/prod(k=1, 8-j, 1-q^k))))
