%I A396105 #6 May 18 2026 10:13:10
%S A396105 1,3,4,11,13,17,23,29,37,43,47,51,58,67,71,73,79,97,103,109,131,134,
%T A396105 159,161,163,181,203,221,263,289,293,317,321,323,332,337,363,371,381,
%U A396105 391,401,409,413,463,473,485,535,577,581,599,601,607,623,667,673,687,697,701,713,737,757,767,773,781
%N A396105 Numbers k such that there are no solutions to A048050(x) + A048050(x+k) = k.
%C A396105 Numbers k such that there is no x where the sum of the nontrivial divisors of x and the nontrivial divisors of x+k is k.
%C A396105 If x has any nontrivial divisors, the sum of those divisors is at least sqrt(x).  Thus any solution to A048050(x) + A048050(x+k) is at most x^2.  This means that the search for solutions is finite.
%p A396105 g:= proc(n) NumberTheory:-sigma(n)-n-1 end proc:
%p A396105 g(1):= 0:
%p A396105 filter:= proc(n) local x,t;
%p A396105    for x from 1 to n^2   do
%p A396105      t:= g(x+n);
%p A396105      if t > n then next fi;
%p A396105      if g(x) + t = n then return false fi
%p A396105   od;
%p A396105 true
%p A396105 end proc:
%p A396105 select(filter, [$1..800]);
%Y A396105 Cf. A048050.
%K A396105 nonn
%O A396105 1,2
%A A396105 _Robert Israel_, May 17 2026
