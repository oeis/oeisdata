%I A396808 #14 Jun 19 2026 05:16:05
%S A396808 1,1,3,50,1395,57174,3142174,220805892,19256140611,2040647616110,
%T A396808 258537630188970,38634015569403132,6730609954951228398,
%U A396808 1353131342747149769244,311093740016328100851420,81133647339925611922901128,23830411667484185322778697571,7831883215439870449708077601374
%N A396808 G.f. A(x) satisfies (n+1) * [x^n] A(x)^(n+1) = n * [x^n] A(x)^(n+2) for n > 1.
%C A396808 Conjecture: for n > 0, a(n) is odd iff n is a power of 2.
%C A396808 Conjecture: for n > 1, a(n) == 2 (mod 3) iff n is a power of 3.
%C A396808 Conjecture: for n > 1, a(n) == 1 (mod 3) iff n = (3/2)*A038464(k) for some k, where A038464 lists the sums of 2 distinct powers of 3.
%C A396808 The limit lim_{n->oo} a(n)/(n+1)!^2 appears to exist. At n = 1000, a(1000)/1001!^2 = 0.23850081648...
%C A396808 This constant is equal to 0.24041409853935500572940313545953342... - _Vaclav Kotesovec_, Jun 19 2026
%H A396808 Paul D. Hanna, <a href="/A396808/b396808.txt">Table of n, a(n) for n = 0..300</a>
%F A396808 G.f. A(x) = Sum_{n>=0} a(n)*x^n satisfies the following formulas.
%F A396808 (1) (n+1) * [x^n] A(x)^(n+1) = n * [x^n] A(x)^(n+2) for n > 1.
%F A396808 (2) [x^n] A(x)^(n+1) = (n+1) * A396838(n) for n >= 0.
%F A396808 (3) [x^n] A(x)^(n+2) = (n+2)/2 * A396839(n) for n >= 0, where A396839 is the self-convolution of A396838.
%F A396808 (4) A(x) = B(x*A(x)) where B(x) = A(x/B(x)) is the g.f. of A396838, and (n+1)^2 * A396838(n) = n*(n+2)/2 * [x^n] B(x)^2 for n > 1.
%e A396808 G.f.: A(x) = 1 + x + 3*x^2 + 50*x^3 + 1395*x^4 + 57174*x^5 + 3142174*x^6 + 220805892*x^7 + 19256140611*x^8 + ...
%e A396808 The table of coefficients of x^k in A(x)^n begins
%e A396808   n = 1: [1, 1,  3,  50,  1395,  57174,  3142174, ...];
%e A396808   n = 2: [1, 2,  7, 106,  2899, 117438,  6409566, ...];
%e A396808   n = 3: [1, 3, 12, 169,  4521, 180969,  9807288, ...];
%e A396808   n = 4: [1, 4, 18, 240,  6271, 247956, 13340706, ...];
%e A396808   n = 5: [1, 5, 25, 320,  8160, 318601, 17015455, ...];
%e A396808   n = 6: [1, 6, 33, 410, 10200, 393120, 20837455, ...];
%e A396808   n = 7: [1, 7, 42, 511, 12404, 471744, 24812928, ...];
%e A396808   n = 8: [1, 8, 52, 624, 14786, 554720, 28948416, ...]; ...
%e A396808 from which we can illustrate the definition
%e A396808   (n+1) * [x^n] A(x)^(n+1) = n * [x^n] A(x)^(n+2) by
%e A396808   n = 2: 3*[x^2] A(x)^3 = 3*12 = 2*18 = 2*[x^2] A(x)^4;
%e A396808   n = 3: 4*[x^3] A(x)^4 = 4*240 = 3*320 = 3*[x^3] A(x)^5;
%e A396808   n = 4: 5*[x^4] A(x)^5 = 5*8160 = 4*10200 = 4*[x^4] A(x)^6;
%e A396808   n = 5: 6*[x^5] A(x)^6 = 6*393120 = 5*471744 = 5*[x^5] A(x)^7;
%e A396808   etc.
%e A396808 Also, we can obtain A396838 from the main diagonal
%e A396808 A396838 = [1/1, 2/2, 12/3, 240/4, 8160/5, 393120/6, ...]
%e A396808   = [1, 1, 4, 60, 1632, 65520, 3544704, ...].
%e A396808 Further, we can obtain A396839 from the secondary diagonal
%e A396808 A396839 = [1*2/2, 3*2/3, 18*2/4, 320*2/5, 10200*2/6, ...]
%e A396808   = [1, 2, 9, 128, 3400, 134784, 7237104, ...].
%o A396808 (PARI) \\ returns vector of terms a(k) for k = 0..n
%o A396808 {a(n) = my(A=[1,1],m); for(i=1,n-1, A=concat(A,0); m=#A-1;
%o A396808 A[#A] = m*polcoef(Ser(A)^(m+2),m) - (m+1)*polcoef(Ser(A)^(m+1),m) ); A}
%Y A396808 Cf. A396838, A396839.
%K A396808 nonn,new
%O A396808 0,3
%A A396808 _Paul D. Hanna_, Jun 18 2026
