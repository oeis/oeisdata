%N A396678 Expansion of e.g.f. log(1 - W_3(-x)), where W_k(x) is the k-th iterate of LambertW(x).
%F A396678 a(n) = Sum_{k=1..n} n^(n-k) * binomial(n-1,k-1) * A396677(k).
%F A396678 a(n) = (n-1)! * Sum_{i,j,k,l >= 0 and i+j+k+l=n-1} (-1)^l * n^i * (n-i)^j * (n-i-j)^k / (i!*j!*k!).
%o A396678 (PARI) my(N=20, x='x+O('x^N)); Vec(serlaplace(log(1-lambertw(lambertw(lambertw(-x))))))
