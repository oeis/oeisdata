%N A396010 Number of 3's in the partitions of n into exactly 4 parts.
%H A396010 Seiichi Manyama, <a href="/A396010/b396010.txt">Table of n, a(n) for n = 0..10000</a>
%H A396010 <a href="/index/Par#part">Index entries for sequences related to partitions</a>
%H A396010 <a href="/index/Rec#order_06">Index entries for linear recurrences with constant coefficients</a>, signature (1,1,0,-1,-1,1).
%F A396010 G.f.: q^4 * Sum_{j=1..4} q^(2*j) / Product_{k=1..4-j} (1 - q^k).
%F A396010 a(n) = a(n-1) + a(n-2) - a(n-4) - a(n-5) + a(n-6) for n > 18.
%F A396010 a(n) = A335583(n-2) - 1 for n > 12.
%o A396010 (PARI) my(N=70, q='q+O('q^N)); concat([0, 0, 0, 0, 0, 0], Vec(q^4*sum(j=1, 4, q^(2*j)/prod(k=1, 4-j, 1-q^k))))
%Y A396010 Cf. A335583, A396009.
%Y A396010 Cf. A024787.
%K A396010 nonn,easy,new
%O A396010 0,9
