%N A396746 Expansion of e.g.f. -W_3(-x)/(1 - W_3(-x)), where W_k(x) is the k-th iterate of LambertW(x).
%F A396746 E.g.f.: 1 - exp(-B(x)), where B(x) is the e.g.f. of A396678.
%F A396746 a(n) = Sum_{k=1..n} n^(n-k) * binomial(n-1,k-1) * A396745(k).
%F A396746 a(n) = (n-1)! * Sum_{i,j,k,l >= 0 and i+j+k+l=n-1} (-1)^l * (l+1) * n^i * (n-i)^j * (n-i-j)^k / (i!*j!*k!).
%o A396746 (PARI) my(N=20, x='x+O('x^N)); Vec(serlaplace(-lambertw(lambertw(lambertw(-x)))/(1-lambertw(lambertw(lambertw(-x))))))
