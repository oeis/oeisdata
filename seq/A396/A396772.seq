%S A396772 0,-1,1,4,6,6,5,5,7,10,12,12,11,11,13,16,18,18,17,17,19,22,24,24,23,
%T A396772 23,25,28,30,30,29,29,31,34,36,36,35,35,37,40,42,42,41,41,43,46,48,48,
%U A396772 47,47,49,52,54,54,53,53,55,58,60,60,59,59,61,64,66,66
%N A396772 Expansion of x*(-1 + 4*x - 3*x^2 + x^3)/((1 - x)^2 * (1 - x + x^2)).
%C A396772 Let P_n(x) be the unique polynomial of order n > 0 that interpolates a(k) = P_n(k) for k=0..n then p_n(-1) = a(n+1). This relation motivated the definition of this sequence.
%H A396772 Paolo Xausa, <a href="/A396772/b396772.txt">Table of n, a(n) for n = 0..10000</a>
%H A396772 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (3,-4,3,-1).
%F A396772 a(n) = Sum_{k=0..n-1} (-1)^k*binomial(n, k+1)*a(k), for n > 1.
%F A396772 a(n) = 3*a(n-1) - 4*a(n-2) + 3*a(n-3) - a(n-4) for n>=5.
%F A396772 a(n) = n - A057079(n) = n - 2*sin((2*n+1)*Pi/6), for n > 0.
%F A396772 E.g.f.: 1 + x*exp(x) - exp(x/2)*(sqrt(3)*cos(sqrt(3)*x/2) + 3*sin(sqrt(3)*x/2))/sqrt(3). - _Stefano Spezia_, Jun 05 2026
%t A396772 LinearRecurrence[{3, -4, 3, -1}, {0, -1, 1, 4, 6}, 100] (* _Paolo Xausa_, Jun 16 2026 *)
%o A396772 (PARI) a(n) = if(n<2,-n, sum(k=0, n-1, (-1)^k*binomial(n, k+1)*a(k)))
%Y A396772 Cf. A057079.
%K A396772 sign,easy,new
%O A396772 0,4
%A A396772 _Thomas Scheuerle_, Jun 05 2026
