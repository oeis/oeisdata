%U A396590 255560829213805068709,30760267090396521787484,4000581177927403588614023,559145600529361563615078176,83585413472030221622989528305
%N A396590 Expansion of e.g.f. F_2(x)/x and F_k(x) is the k-th iteration of x*G(x) with G(x) = exp(x*G(x)^3).
%F A396590 E.g.f.: (1/x) * Series_Reversion( H_2(x) ), where H_k(x) is the k-th iterate of U(x)*exp(-3*U(x)) and U(x) = -LambertW(-2*x)/2.
%F A396590 a(n) = Sum_{k=0..n} (k+1) * (3*k+1)^(k-1) * (3*n-2*k+1)^(n-k-1) * binomial(n,k).
%t A396590 a[n_]:=Sum[(k+1) * (3*k+1)^(k-1) * (3*n-2*k+1)^(n-k-1) * Binomial[n,k],{k,0,n}]; Array[a,18,0] (* _Stefano Spezia_, May 30 2026 *)
%o A396590 (PARI)
%o A396590 lista(nn, k=2, p=3, s=1, r=1) = {
%o A396590   my(T=matrix(nn+1, nn+1, row, col, my(xr=row-1, xc=col-1); if(xc<xr, 0, (s*xr+r)*(p*xc-(p-s)*xr+r)^(xc-xr-1)*binomial(xc, xr))));
%o A396590   my(TK=T^k);
%o A396590   TK[1, ];
%o A396590 };
%Y A396590 Column k=2 of A396500.
%Y A396590 Cf. A101878, A396589, A396592.
%K A396590 nonn,new
%O A396590 0,2
