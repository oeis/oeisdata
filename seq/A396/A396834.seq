%I A396834 #9 Jun 20 2026 18:42:00
%S A396834 0,0,1,2,4,5,9,11,16,19,25,28,36,40,49,54,64,69,81,87,100,107,121,128,
%T A396834 144,152,169,178,196,205,225,235,256,267,289,300,324,336,361,374,400,
%U A396834 413,441,455,484,499,529,544,576,592,625,642,676,693,729,747,784,803,841,860,900
%N A396834 Lower (2/3,1/3) midsequence of (floor[n/2]^2) and (ceiling[n/2]^2); see Comments.
%C A396834 Suppose that s = (s(n)) and t = (t(n)) are sequences of numbers and h > 0 and k > 0. The lower (h, k)-midsequence of s and t is floor(h*s + k*t); the upper (h, k)-midsequence of s and t is ceiling(h*s + k*t).
%H A396834 <a href="/index/Rec#order_09">Index entries for linear recurrences with constant coefficients</a>, signature (1,1,-1,0,0,1,-1,-1,1).
%F A396834 a(n) = a(n-1) + a(n-2) - a(n-3) + a(n-6) - a(n-7) - a(n-8) + a(n-9), with (a(0),...,a(8)) = (0, 0, 1, 2, 4, 5, 9, 11, 16).
%F A396834 G.f.: -(x^2*(1 + x + x^2 + 2 x^4 + x^5)/((-1 + x)^3*(1 + x)^2*(1 + x^2 + x^4)).
%e A396834 s(n) = A008794(n+1):  (0, 1, 1, 4, 4, 9, 9, 16, 16, ...).
%e A396834 t(n) = A008794(n+2):  (1, 1, 4, 4, 9, 9, 16, 16, 25, ...).
%e A396834 (u(n)) = (0, 0, 1, 2, 4, 5, 9, 11, 16, 19, 25, 28, 36, 40, 49, ...).
%e A396834 (v(n)) = (0, 1, 1, 2, 4, 6, 9, 12, 16, 19, 25, 29, 36, 41, 49, ...).
%t A396834 z = 60; f[n_] := Floor[n/2]^2; g[n_] := Ceiling[n/2]^2;
%t A396834 r = 2/3; s = 1/3;
%t A396834 u[n_] := Floor[r*f[n] + s*g[n]]
%t A396834 v[n_] := Ceiling[r*f[n] + s*g[n]]
%t A396834 Table[u[n], {n, 0, z}]
%t A396834 Table[v[n], {n, 0, z}]
%t A396834 (* Also *)
%t A396834 LinearRecurrence[{1, 1, -1, 0, 0, 1, -1, -1, 1}, {0, 0, 1, 2, 4, 5, 9, 11, 16}, 30]
%t A396834 LinearRecurrence[{1, 1, -1, 0, 0, 1, -1, -1, 1}, {0, 1, 1, 2, 4, 6, 9, 12, 16}, 30]
%Y A396834 Cf. A389123, A396811, A396812, A396813, A396835.
