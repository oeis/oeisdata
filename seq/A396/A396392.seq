%N A396392 a(n) = r(n,n), where r(1,k)=f(k)=round(k*c), r(n,k)=f(r(n-1,k)), c=golden ratio.
%C A396392 a(n + 1)/a(n) approaches c erratically.
%t A396392 c = GoldenRatio; f[k_] := f[k] = Round[c*k];
%t A396392 r[1, k_] := f[k]; r[n_, k_] := r[n, k] = f[r[n - 1, k]];
%t A396392 Table[r[n, n], {n, 1, 100}]
