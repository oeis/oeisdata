%I A396967 #4 Jun 23 2026 23:49:45
%S A396967 6,12,14,24,39,56,62,112,155,254,992,1984,3279,5219,16256,16382,19607,
%T A396967 32512,70643
%N A396967 Numbers k that are neither powers of primes nor have residues r (mod k) for which s = r + m*k is such that rad(s) | k but rad(r) does not divide k, and rad(k) does not divide r, where rad = A007947.
%C A396967 Numbers k in A024619 where row k of A381801 that does not contain numbers r in row k of A272619 such that rad(k) does not divide r.
%C A396967 Powers of primes k = p^m, m >= 1 (in A246655) have the quality described in the Name, since k has only one distinct prime factor p. Hence, if r shares a factor with p^m, it must be p, thus, rad(k) | r. This sequence lists numbers that are not powers of primes that share this property.
%C A396967 Is it true that A001221(a(n)) is always 2?
%e A396967 Let R(k) denote row k of A381801 and let S(k) denote row k of A272619.
%e A396967 6 is a term since there are no r < 6 that share a factor with 6, yet 6 has a factor that does not divide r.
%e A396967 10 is not a term since R(10) = {0,1,2,4,5,6,8} contains r = 6, which is even, but divisible by 3, whereas 10 is even but divisible by 5. (There are no other r with this property).
%e A396967 12 is a term since R(12) = {0,1,2,3,4,6,8,9} and S(12) = {10} do not intersect.
%e A396967 14 is a term since R(14) = {0,1,2,4,7,8} and S(14) = {6,10,12} do not intersect.
%e A396967 18 is not a term since R(18) = {0,1,2,3,4,6,8,9,10,12,14,16} and S(18) = {10,14,15} intersect.
%e A396967 20 is not a term since the intersection of R(20) and S(20) is {12}, etc.
%e A396967 56 = 2^3 * 7 is a term since, though R(56) includes m = 42 = 2 * 3 * 7 such that rad(m) does not divide 56, rad(56) = 14 and 14 | 42.
%e A396967 992 is a term since, though there exist 3 numbers m in R(992) such that rad(m) does not divide 992 = 2^5 *31, rad(992) | m in all cases. (i.e., 744 = 2^3 * 3 * 31, 868 = 2^2 * 7 * 31, 930 = 2 * 3 * 5 * 31), etc.
%t A396967 rad[x_] := rad[x] = Times @@ FactorInteger[x][[All, 1]];
%t A396967 a381801[x_] := Module[{p},
%t A396967   Union@ Flatten@
%t A396967     Mod[TensorProduct @@
%t A396967       Map[(p = #; NestWhileList[Mod[p*#, x] &, 1, UnsameQ, All]) &,
%t A396967         FactorInteger[x][[All, 1]]], x]];
%t A396967 s = Select[Range[2, 2^10], Not @* PrimePowerQ];
%t A396967 Select[s, Function[k,
%t A396967   NoneTrue[Rest@ a381801[k],
%t A396967     Nor[Divisible[k, rad[#] ], Divisible[#, rad[k] ] ] &] ] ]
%Y A396967 Cf. A000961, A007947, A024619, A246655, A272619, A381801.
%K A396967 nonn,more,hard,new
%O A396967 1,1
