%I A396580 #37 Jun 06 2026 16:15:17
%S A396580 4,39,391,3914,39158,391624,3916376,39164228,391643638,3916440779,
%T A396580 39164421455,391644258162,3916442718558,39164427619716,
%U A396580 391644277567403,3916442780010142,39164427813805085
%N A396580 a(n) is the number of n-digit terms in A396579.
%F A396580 a(n) = A396618(n) + 9*Sum_{k=0..n-2} 10^k*A396618(n-k-1).
%t A396580 a[n_]:=Module[{c=KroneckerDelta[n,1]},For[k=10^(n-1), k<=10^n-1, k++, If[AnyTrue[Table[Sqrt[IntegerReverse[Floor[IntegerReverse[k]/10^i]]],{i,0,IntegerLength[k]-1}],IntegerQ], c++]]; c]; Array[a,5]
%t A396580 (* Alternative: *)
%t A396580 A192689Q[k_]:=NoneTrue[Table[Mod[k, 10^d], {d, IntegerLength[k] - 1}], IntegerQ[Sqrt[#]] &]; A396618[n_]:=KroneckerDelta[n,1]+Length[Select[Range[Ceiling[Sqrt[10^(n - 1)]], Floor[Sqrt[10^n-1]]]^2, A192689Q]]; a[n_]:=A396618[n]+9*Sum[10^i*A396618[n-i-1],{i,0,n-2}]; Array[a,12]
%Y A396580 Cf. A011557, A063945, A192689, A396579, A396618.
%K A396580 nonn,base,more
%O A396580 1,1
%A A396580 _Stefano Spezia_, May 29 2026
