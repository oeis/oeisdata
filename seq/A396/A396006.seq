%I A396006 #9 May 15 2026 17:13:26
%S A396006 1,2,4,5,8,9,10,13,16,17,18,20,21,25,26,29,32,33,34,36,37,40,41,42,49,
%T A396006 50,52,53,57,58,61,64,65,66,68,69,72,73,74,77,80,81,82,84,85,97,98,
%U A396006 100,101,104,105,106,109,113,114,116,117,121,122,125,128,129
%N A396006 Numbers having a representation as the quotient of two fibbinary numbers (A003714).
%C A396006 For each individual n, it is easy to check whether n has a representation using Walnut.
%C A396006 For example, for n = 99 one can write
%C A396006   reg has11 msd_2 "(0|1)*11(0|1)*":
%C A396006   def no11 "~$has11(n)":
%C A396006   eval test99 "Ea,b $no11(a) & $no11(b) & b>=1 & a=99*b":
%C A396006 To test other numbers, just replace 99 with n in two places. Walnut returns TRUE if there is a representation and FALSE otherwise.
%C A396006 Meleshko has a conjectured characterization of the members of this sequence, but as of 2026 it has not been proved.
%H A396006 J. V. F. Meleshko, <a href="http://hdl.handle.net/10012/18952">Automata and ratio sets</a>, Master's thesis, University of Waterloo, 2022.
%Y A396006 Cf. A003714, A395143, A396007, A396008.
%K A396006 nonn,new
%O A396006 1,2
%A A396006 _Jeffrey Shallit_, May 13 2026
