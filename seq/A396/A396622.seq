%N A396622 a(n) = r(n,n), where r(1,k)=f(k)=floor(k*c), r(n,k)=f(r(n-1,k)), c=sqrt(3).
%C A396622 a(n + 1)/a(n) approaches c erratically.
%t A396622 c = Sqrt[3]; f[k_] := f[k] = Floor[c*k];
%t A396622 r[1, k_] := f[k]; r[n_, k_] := r[n, k] = f[r[n - 1, k]];
%t A396622 Table[r[n, n], {n, 1, 100}]
%Y A396622 Cf. A396385, A396623, A396624.
%K A396622 nonn
%O A396622 1,2
