%U A396544 0,0,0,0,0,0,48,0,0,0,0,0,0,0,40,27,0,0,0,0,0,0,44,0,0,0,0,0,0,0,84,0,0,0,0
%N A396544 The sum of the coreful divisors of n that are not exponential divisors of n.
%C A396544 All the exponential divisors (A322791) of n are by definition coreful divisors (A284318) of n (see A396543).
%C A396544 The number of these divisors is A396543(n).
%H A396544 Amiram Eldar, <a href="/A396544/b396544.txt">Table of n, a(n) for n = 1..10000</a>
%F A396544 a(n) = A057723(n) - A051377(n).
%F A396544 a(n) = 0 if and only if n is cubefree (A004709).
%F A396544 Sum_{k=1..n} a(n) ~ c * n^2 / 2, where c = A065487 - 2 * A275480 = 0.094720161394989654122... .
%t A396544 f1[p_, e_] = (p^(e+1)-1)/(p-1) - 1;
%t A396544 f2[p_, e_] = DivisorSum[e, p^# &];
%t A396544 a[n_] := Module[{fct = FactorInteger[n]}, Times @@ f1 @@@ fct - Times @@ f2 @@@ fct]; a[1] = 0; Array[a, 100]
%o A396544 (PARI) a(n) = {my(f = factor(n)); prod(i = 1, #f~, (f[i,1]^(f[i,2]+1) - 1)/(f[i,1]-1) - 1) - prod(i = 1, #f~, sumdiv(f[i,2], d, f[i,1]^d));}
%Y A396544 Cf. A004709, A051377, A065487, A275480, A284318, A322791, A396543, A396545, A396546.
%K A396544 nonn,easy
%O A396544 1,8
%A A396544 _Amiram Eldar_, May 29 2026
