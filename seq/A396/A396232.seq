%S A396232 1,3,8,18,38,58,78,98,118,138,158,178,198,218,238,258,278,298,318,338,
%T A396232 358,378,398,418,438,458,478,498,518,538,558,578,598,618,638,658,678,
%U A396232 698,718,738,758,778,798,818,838,858,878,898,918,938,958,978,998,1018
%N A396232 The smallest amount which cannot be made with fewer than n Indian coins.
%C A396232 a(n) is the smallest amount (in rupees) that cannot be made with fewer than n coins.
%C A396232 The coins included are those in common circulation in India: Rs. 1, Rs. 2, Rs. 5, Rs. 10 and Rs. 20.
%H A396232 <a href="/index/Rec#order_02">Index entries for linear recurrences with constant coefficients</a>, signature (2,-1).
%F A396232 From _Alois P. Heinz_, May 19 2026: (Start)
%F A396232 G.f.: x*(10*x^4+5*x^3+3*x^2+x+1)/(x-1)^2.
%F A396232 a(n) = 20*n - 62 for n>=4. (End)
%e A396232 For n = 3, 8 is the smallest number that requires 3 coins (1 + 2 + 5).
%o A396232 (Python)
%o A396232 from math import inf
%o A396232 def indianCoins(up_to=2000, coins=(1, 2, 5, 10, 20)):
%o A396232     coins_needed = [0] + [inf] * up_to
%o A396232     for c in coins:
%o A396232         for i in range(c, up_to + 1):
%o A396232             coins_needed[i] = min(coins_needed[i], coins_needed[i - c] + 1)
%o A396232     record = 0
%o A396232     return [n for n, x in enumerate(coins_needed) if x > record and (record := x)]
%Y A396232 Cf. A258272, A258274.
%K A396232 nonn,easy
%O A396232 1,2
