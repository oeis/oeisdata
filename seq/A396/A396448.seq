%S A396448 1,1,0,1,1,0,1,2,4,0,1,3,12,22,0,1,4,24,94,140,0,1,5,40,244,836,969,0,
%T A396448 1,6,60,500,2784,8025,7084,0,1,7,84,890,6960,34074,81136,53820,0,1,8,
%U A396448 112,1442,14620,103450,437608,852012,420732,0,1,9,144,2184,27300,255555,1608528,5823172,9210604,3362260,0
%N A396448 Square array A(n,k), n>=0, k>=0, read by antidiagonals downwards, where A(n,k) = [x^n] (F_k(x)/x)^(1/3) and F_k(x) is the k-th iteration of x*G4(x)^3 with G4(x) = 1 + x*G4(x)^4.
%H A396448 Wikipedia, <a href="https://en.wikipedia.org/wiki/Fuss%E2%80%93Catalan_number">Fuss-Catalan number</a>
%F A396448 G.f. of column k: ((1/x) * Series_Reversion( H_k(x) ))^(1/3), where H_k(x) is the k-th iteration of x*(1 - x)^3.
%F A396448 A(n,k) = Sum_{0 = x_0 <= x_1 <= ... <= x_{k-1} <= x_k = n} Product_{j=0..k-1} (3*x_j + 1) * binomial(4*x_{j+1} - x_j + 1,x_{j+1} - x_j)/(4*x_{j+1} - x_j + 1).
%F A396448 A(n,0) = 0^n; A(n,k) = Sum_{j=0..n} (3*j+1) * binomial(4*n-j+1,n-j)/(4*n-j+1) * A(j,k-1) for k > 0.
%e A396448 Square array begins:
%e A396448   1,    1,     1,      1,       1,       1,        1, ...
%e A396448   0,    1,     2,      3,       4,       5,        6, ...
%e A396448   0,    4,    12,     24,      40,      60,       84, ...
%e A396448   0,   22,    94,    244,     500,     890,     1442, ...
%e A396448   0,  140,   836,   2784,    6960,   14620,    27300, ...
%e A396448   0,  969,  8025,  34074,  103450,  255555,   548499, ...
%e A396448   0, 7084, 81136, 437608, 1608528, 4661748, 11478432, ...
%e A396448   ...
%o A396448 (PARI)
%o A396448 a(n, k, p=4, s=3, r=1) = {
%o A396448   my(T=matrix(n+1, n+1, row, col, my(xr=row-1, xc=col-1); if(xc<xr, 0, (s*xr+r)*binomial(p*xc-(p-s)*xr+r, xc-xr)/(p*xc-(p-s)*xr+r))));
%o A396448   my(TK=T^k);
%o A396448   TK[1, n+1];
%o A396448 };
%Y A396448 Columns k=0..2 give A000007, A002293, A396434.
%Y A396448 Cf. A396431, A396466.
%K A396448 nonn,tabl,changed
%O A396448 0,8
