%S A396806 1,2,39,1804,139625,15563526,2301954109,429238979912,97448808948561,
%T A396806 26265548559817450,8246447481748896101,2971440339379067974188,
%U A396806 1214267224194405821321401,557274809185779200405089214,284900693163075451689732319725,161133203118888170148042151877776,100221910268499941067362822586664481
%N A396806 E.g.f. satisfies A(x) = x*exp( A^6(x) ).
%C A396806 Conjecture: a(n) is odd iff n is odd for n >= 1.
%C A396806 Conjecture: a(n) == [1,2,0] repeating (mod 3) for n >= 1.
%C A396806 Conjecture: a(n) == [1,2,3,4,5,0] repeating (mod 6) for n >= 1.
%H A396806 Paul D. Hanna, <a href="/A396806/b396806.txt">Table of n, a(n) for n = 1..200</a>
%F A396806 E.g.f. A(x) = Sum_{n>=1} a(n)*x^n/n! satisfies the following formulas, in which A^n(x) denotes the n-th iteration of A(x).
%F A396806 (1.a) A^(-1)(x) = x * exp( -A^5(x) ).
%F A396806 (1.b) A(x) = x * exp( A^6(x) ).
%F A396806 (1.c) A^2(x) = A(x) * exp( A^7(x) ).
%F A396806 (1.d) A^3(x) = A^2(x) * exp( A^8(x) ).
%F A396806 (1.e) A^n(x) = A^(n-1)(x) * exp( A^(n+5)(x) ) for all n.
%F A396806 (2.a) A(x) = x * exp( A^5(x) * exp( A^10(x) * exp( A^15(x) * ... * exp( A^(5*n)(x) * exp( ... ))))), an infinite power tower.
%F A396806 (2.b) A^2(x) = A(x) * exp( A^6(x) * exp( A^11(x) * exp( A^16(x) * ... * exp( A^(5*n+1)(x) * exp( ... ))))), an infinite power tower.
%F A396806 (2.c) A^3(x) = A^2(x) * exp( A^7(x) * exp( A^12(x) * exp( A^17(x) * ... * exp( A^(5*n+2)(x) * exp( ... ))))), an infinite power tower.
%F A396806 (2.d) A^4(x) = A^3(x) * exp( A^8(x) * exp( A^13(x) * exp( A^18(x) * ... * exp( A^(5*n+3)(x) * exp( ... ))))), an infinite power tower.
%F A396806 (2.e) A^5(x) = A^4(x) * exp( A^9(x) * exp( A^14(x) * exp( A^19(x) * ... * exp( A^(5*n+4)(x) * exp( ... ))))), an infinite power tower.
%F A396806 (3.a) A^2(x) = x * exp(A^6(x) + A^7(x)).
%F A396806 (3.b) A^3(x) = x * exp(A^6(x) + A^7(x) + A^8(x)).
%F A396806 (3.c) A^n(x) = x * exp( Sum_{k=6..n+5} A^k(x) ) for n >= 1.
%F A396806 (3.d) A^n(x) = A^m(x) * exp( Sum_{k=m+6..n+5} A^k(x) ) for n >= m+1.
%F A396806 (4.a) A(x) = A^2(x) / exp(A^7(x)).
%F A396806 (4.b) A(x) = A^3(x) / exp(A^7(x) + A^8(x)).
%F A396806 (4.c) A(x) = A^4(x) / exp(A^7(x) + A^8(x) + A^9(x)).
%F A396806 (4.d) A(x) = A^n(x) / exp( Sum_{k=7..n+5} A^k(x) ) for n >= 2.
%F A396806 (5.a) A^6(x) = log( A(x)/x ).
%F A396806 (5.b) A^7(x) = log( A^2(x)/A(x) ).
%F A396806 (5.c) A^8(x) = log( A^3(x)/A^2(x) ).
%F A396806 (5.d) A^n(x) = log( A^(n-5)(x) / A^(n-6)(x) ) for all n.
%F A396806 From _Seiichi Manyama_, Jun 09 2026: (Start)
%F A396806 E.g.f. A(x) satisfies A(x) = x*exp(A^l(x)), where A^l(x) denotes the l-th iterate of A.
%F A396806 Let a(n,k,l) = n! * [x^n] A^k(x), where A^k(x) is the k-th iterate of A.
%F A396806 a(1,k,l) = 1; a(n,k,l) = (1/(n-1)) * Sum_{i=1..n-1} i * binomial(n,i) * a(n-i,k,l) * Sum_{j=1..k} a(i,j+l-1,l). (End)
%e A396806 E.g.f.: A(x) = x + 2*x^2/2! + 39*x^3/3! + 1804*x^4/4! + 139625*x^5/5! + 15563526*x^6/6! + 2301954109*x^7/7! + 429238979912*x^8/8! + ...
%e A396806 where A(x) = x * exp( A^6(x) ).
%e A396806 RELATED SERIES.
%e A396806 The series reversion of A(x) begins
%e A396806 A^(-1)(x) = x - 2*x^2/2! - 27*x^3/3! - 1144*x^4/4! - 84995*x^5/5! - 9241056*x^6/6! - 1342926053*x^7/7! + ...
%e A396806 where A^(-1)(x) = x * exp( -A^5(x) ).
%e A396806 The second iteration of A(x) begins
%e A396806 A^2(x) = x + 4*x^2/2! + 90*x^3/3! + 4412*x^4/4! + 352480*x^5/5! + 40104342*x^6/6! + 6020237944*x^7/7! + ...
%e A396806 where A^2(x) = x * exp(A^6(x) + A^7(x)).
%e A396806 The third iteration of A(x) begins
%e A396806 A^3(x) = x + 6*x^2/2! + 153*x^3/3! + 7968*x^4/4! + 660045*x^5/5! + 76973508*x^6/6! + 11768428455*x^7/7! + ...
%e A396806 where A^3(x) = x * exp(A^6(x) + A^7(x) + A^8(x)).
%e A396806 The fourth iteration of A(x) begins
%e A396806 A^4(x) = x + 8*x^2/2! + 228*x^3/3! + 12616*x^4/4! + 1086680*x^5/5! + 130304724*x^6/6! + 20350760752*x^7/7! + ...
%e A396806 where A^4(x) = x * exp(A^6(x) + A^7(x) + A^8(x) + A^9(x)).
%e A396806 The fifth iteration of A(x) begins
%e A396806 A^5(x) = x + 10*x^2/2! + 315*x^3/3! + 18500*x^4/4! + 1659625*x^5/5! + 205100730*x^6/6! + 32800139785*x^7/7! + ...
%e A396806 where A^5(x) = x * exp(A^6(x) + A^7(x) + A^8(x) + A^9(x) + A^10(x)).
%e A396806 The sixth iteration of A(x) begins
%e A396806 A^6(x) = x + 12*x^2/2! + 414*x^3/3! + 25764*x^4/4! + 2409000*x^5/5! + 307319706*x^6/6! + 50419780824*x^7/7! + ...
%e A396806 where A^6(x) = log( A(x)/x ).
%o A396806 (PARI) \\ from A(x) = x * exp( A^6(x) ).
%o A396806 {a(n) = my(A=x,B,C); for(k=1, n, A = truncate(A) + x*O(x^k); B = subst(A,x,A); C = subst(A,x,B);
%o A396806 A = x * exp( subst(C,x,C) ) +x*O(x^n); ); EGF=A; n!*polcoef(A, n)}
%o A396806 {upto(n) = a(n); Vec(serlaplace(EGF))}
%o A396806 upto(25)
