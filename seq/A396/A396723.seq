%S A396723 0,3,27,178,1027,5494,27982,137668,660067,3102158,14348570,65506748,
%T A396723 295828942,1323723868,5876586172,25910666248,113560491427,
%U A396723 495080074558,2148210301282,9282073849228,39954149237722,171389141251348,732898791689092,3125080788854968
%N A396723 a(n) = (-4^n/2) p(n, -1/2), where p(n,x) is the Lagrange interpolating polynomial through (1,0) and (k,1) for k=2..n+1.
%F A396723 Conjecture D-finite with recurrence n*a(n) +2*(-4*n-1)*a(n-1) +8*(2*n+1)*a(n-2)=0. - _R. J. Mathar_, Jun 30 2026
%t A396723 t[0] = {0}; t[n_] := t[n] = Join[t[n - 1], {1}];
%t A396723 p[n_, x_] := Expand[InterpolatingPolynomial[t[n], x]];
%t A396723 Table[(-4^n/2) p[n, -1/2], {n, 0, 40}]
%t A396723 Labeled[Plot[{p[1, x], p[2, x], p[3, x], p[4, x], p[5, x]}, {x, -1, 7}], "Plot of p[n,x] for n=1..5."]
