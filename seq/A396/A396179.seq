%t A396179 a=CoefficientList[Series[1/((1-x)^2 (1-x^8)),{x,0,100}],x]; b=Complement[Range[Max[a]],a]; b (* _Vincenzo Librandi_, May 29 2026 *)
%o A396179 (Magma) R<x> := PowerSeriesRing(Integers(), 40); a := Coefficients(1/((1-x)^2*(1-x^8))); b := [n : n in [1..Maximum(a)] | not n in a]; b; // _Vincenzo Librandi_, May 29 2026
%o A396179 (Python)
%o A396179 from math import isqrt
%o A396179 def A396179(n):
%o A396179     def f(x):
%o A396179         r = max(0,isqrt((x<<4)+9)-5>>3)
%o A396179         return n+min(r+1<<3,x//(r+1)+(r<<2))
%o A396179     m, k = n, f(n)
%o A396179     while m != k: m, k = k, f(k)
%o A396179     return m # _Chai Wah Wu_, May 29 2026
