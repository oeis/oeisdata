%I A396428 #7 Jun 04 2026 18:40:51
%S A396428 123201,246402,369603,492804,616005,739206,862407,985608,1108809,
%T A396428 1232010,1355211,1478412,1601613,1724814,1848015,1971216,196625,
%U A396428 2217618,105644,2464020,2587221,2710422,34398,2956824,3080025,3203226,3326427,3449628,59319,3696030,1990656,3942432,4065633,393250,4312035
%N A396428 a(n) is the largest number such that both a(n) and a(n) - n are 5-smooth numbers, or 0 if no such number exists.
%C A396428 All terms n>1 are currently conjectural.
%C A396428 a(1) is just A002072(6) + 1, which is proven by Størmer's theorem. This provides a(n) is not zero where n is 13-smooth. All other terms are conjectured, but the abc-conjecture can help.
%C A396428 a(n) can be less than n and this first occurs at a(35803) = 35035 because there is no answer to >35803. 35035 = 5 * 7^2 * 11 * 13 and 35035-35803 = -768 = -(2^8 * 3). Here we also consider negative numbers as smooth numbers.
%C A396428 There are no larger possible a(n) under 10^30 for every n.
%F A396428 If a(n) or a(p*n) exists then a(p*n) >= p * a(n) for p in {2, 3, 5, 7, 11, 13}.
%e A396428 a(3) = 369603 since both 369603 and 369603 - 3 = 369600 are 13-smooth numbers, and it is conjectured that no number k larger than 369603 such that both k and k - 3 are 13-smooth numbers.
%o A396428 (PARI)
%o A396428 M(v, u, lim)={vecsort(concat(vector(#v, i, my(m=lim\v[i]); v[i]*select(t->t<=m, u))))}
%o A396428 Gen(lim, k)={my(v=[1]); forprime(p=2, k, v=M(v, vector(logint(lim, p)+1, e, p^(e-1)), lim)); v}
%o A396428 lista(n, lim=10^30)={my(v=vector(n), G=Gen(lim, 13)); for(i=1, #G, my(t=G[i], k=i+1); while(k<=#G && G[k]-t<=n, v[G[k]-t]=G[k]; k++)); v}
%o A396428 A006530(n)=if(n>1, vecmax(factor(n)[, 1]), 1)
%o A396428 b(n)=for(t=1, n, A006530(t*(n-t))<=13&return(t))
%o A396428 A396428(n)=if(lista(n)[n]!=0, return(lista(n)[n]); lista(n)[n]==0&b(n)<n, return(n-b(n)); lista(n)[n]==0&b(n)==n, return(0))
%Y A396428 Cf. A002072, A080197.
%K A396428 nonn,new
%O A396428 1,1
%A A396428 _Zhicheng Wei_, May 25 2026
