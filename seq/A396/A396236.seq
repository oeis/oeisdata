%N A396236 a(n) = n^2 AND NOT n.
%C A396236 All terms are multiples of 4.
%H A396236 Mia Boudreau, <a href="/A396236/b396236.txt">Table of n, a(n) for n = 0..10000</a>
%F A396236 a(n) = A169810(n) - A396237(n).
%F A396236 a(n) = A007745(n) - n. - _Alois P. Heinz_, May 22 2026
%p A396236 a:= n-> Bits[Or](n, n^2)-n:
%p A396236 seq(a(n), n=0..54);  # _Alois P. Heinz_, May 22 2026
%t A396236 a[n_] := BitAnd[n^2, BitNot[n]]; Array[a, 55, 0] (* _Amiram Eldar_, May 22 2026 *)
%o A396236 (C) unsigned long long a(unsigned long long n){return n*n & ~n ;}
%o A396236 (PARI) a(n) = bitand(bitneg(n), n^2); \\ _Michel Marcus_, May 20 2026
%Y A396236 Cf. A169810 (XOR), A007745 (OR), A213541 (AND), A396237 (A AND NOT B).
