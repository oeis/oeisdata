%T A396312 66436,130699,257247,506154,995529,1957987,3851477,7576734,14904863,
%U A396312 29319295,57673054,113448372,223166548,438995465,863552302,1698697632,3341519128,6573134853
%N A396312 Number of tilings of an (h+3) X n rectangle by unit squares and the Ferrers tile (h,2,2,1), for h >= 4.
%C A396312 The sequence is independent of h for h >= 4.
%H A396312 Per Alexandersson and John Ahlberg, <a href="https://arxiv.org/abs/2605.03473">Polynomials from tilings of rectangles</a>, arXiv:2605.03473 [math.CO], 2026.
%H A396312 <a href="/index/Rec#order_13">Index entries for linear recurrences with constant coefficients</a>, signature (1,0,0,4,3,3,6,2,2,4,0,0,1).
%F A396312 G.f.: 1/(1 - x - 4*x^4 - 3*x^5 - 3*x^6 - 6*x^7 - 2*x^8 - 2*x^9 - 4*x^10 - x^13).
%F A396312 With a(0)=1, a(n) = a(n-1) + 4*a(n-4) + 3*a(n-5) + 3*a(n-6) + 6*a(n-7) + 2*a(n-8) + 2*a(n-9) + 4*a(n-10) + a(n-13) for n >= 1.
%t A396312 CoefficientList[Series[1/(1 - x - 4*x^4 - 3*x^5 - 3*x^6 - 6*x^7 - 2*x^8 - 2*x^9 - 4*x^10 - x^13),{x,0,35}],x] (* _Stefano Spezia_, May 21 2026 *)
