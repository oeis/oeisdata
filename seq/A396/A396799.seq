%U A396799 16843101697284562896,-2230002746655974502225,326367650557985432023936,-52485113772229506638866575,9226584510326784965254184640,-1764994657079434895818835078573
%N A396799 E.g.f. satisfies A(x) = exp(-x) * A(A(x)).
%H A396799 Paul D. Hanna, <a href="/A396799/b396799.txt">Table of n, a(n) for n = 1..256</a>
%F A396799 E.g.f. A(x) = Sum_{n>=1} a(n)*x^n/n! satisfies the following formulas.
%F A396799 (1.a) A(x) = x * exp( A^(-1)(x) ).
%F A396799 (1.b) A(x) = A^2(x) / exp(x).
%F A396799 (1.c) A^2(x) = A^3(x) / exp(A(x)).
%F A396799 (1.d) A^3(x) = A^4(x) / exp(A^2(x)).
%F A396799 (1.e) A^n(x) = A^(n+1)(x) / exp( A^(n-1)(x) ) for all n.
%F A396799 (1.f) A^n(x) = A^(n-1)(x) * exp( A^(n-2)(x) ) for all n.
%F A396799 (2.a) A(x) = x*exp( A^(-2)(x) * exp( A^(-4)(x) * exp( A^(-6)(x) * ... * exp( A^(-2*n)(x) * exp( ... ))))), an infinite power tower.
%F A396799 (2.b) A^2(x) = A(x) * exp( A^(-1)(x) * exp( A^(-3)(x) * exp( A^(-5)(x) * ... * exp( A^(-2*n+1)(x) * exp( ... ))))), an infinite power tower.
%F A396799 (3.a) A^(-1)(x) = log( A(x)/x ).
%F A396799 (3.b) x = log( A^2(x)/A(x) ).
%F A396799 (3.c) A(x) = log( A^3(x)/A^2(x) ).
%F A396799 (3.d) A^2(x) = log( A^4(x)/A^3(x) ).
%F A396799 (3.e) A^n(x) = log( A^(n+2)(x) / A^(n+1)(x) ) for all n.
%F A396799 (4.a) A(x) = A^3(x) / exp(x + A(x)).
%F A396799 (4.b) A(x) = A^4(x) / exp(x + A(x) + A^2(x)).
%F A396799 (4.c) A(x) = A^5(x) / exp(x + A(x) + A^2(x) + A^3(x)).
%F A396799 (4.d) A(x) = A^n(x) / exp( Sum_{k=0..n-2} A^k(x) ) for n >= 2.
%F A396799 (4.e) A^n(x) = A^m(x) * exp( Sum_{k=m-1..n-2} A^k(x) ) for n >= m+1.
%F A396799 a(n) = n*A087961(n-1) for n >= 1.
%e A396799 E.g.f.: A(x) = x + 2*x^2/2! - 3*x^3/3! + 40*x^4/4! - 795*x^5/5! + 22896*x^6/6! - 877625*x^7/7! + 42472704*x^8/8! + ...
%e A396799 where A(x) = exp(-x) * A^2(x).
%e A396799 RELATED SERIES.
%e A396799 The series reversion of e.g.f. A(x) begins
%e A396799 A^(-1)(x) = x - 2*x^2/2! + 15*x^3/3! - 220*x^4/4! + 5025*x^5/5! - 159606*x^6/6! + 6593041*x^7/7! + ... + (-1)^(n-1)*A140054(n)*x^n + ...
%e A396799 where A^(-1)(x) = log( A(x)/x ).
%e A396799 The second iteration of A(x) begins
%e A396799 A^2(x) = x + 4*x^2/2! + 6*x^3/3! + 44*x^4/4! - 600*x^5/5! + 18702*x^6/6! - 732704*x^7/7! + 36050968*x^8/8! + ...
%e A396799 where A^2(x) = exp(x) * A(x).
%e A396799 The third iteration of A(x) begins
%e A396799 A^3(x) = x + 6*x^2/2! + 27*x^3/3! + 156*x^4/4! + 225*x^5/5! + 17118*x^6/6! - 533547*x^7/7! + 27717784*x^8/8! + ...
%e A396799 where A^3(x) = exp(x + A(x)) * A(x).
%e A396799 The fourth iteration of A(x) begins
%e A396799 A^4(x) = x + 8*x^2/2! + 60*x^3/3! + 520*x^4/4! + 4200*x^5/5! + 54324*x^6/6! + 26656*x^7/7! + 26761984*x^8/8! + ...
%e A396799 where A^4(x) = exp(x + A(x) + A^2(x)) * A(x).
%o A396799 (PARI) \\ from A(x) = x * exp( A^(-1)(x) ).
%o A396799 {a(n) = my(A=x); for(k=1,n, A = truncate(A) + x*O(x^k);
%o A396799 A = x * exp( serreverse(A) ) +x*O(x^n);); EGF=A; n!*polcoef(A,n)}
%o A396799 {upto(n) = a(n); Vec(serlaplace(EGF))}
%o A396799 upto(25)
%o A396799 (Python)
%o A396799 from math import comb
%o A396799 def a_list(n: int) -> list[int]:
%o A396799     T = [[0] * (n + 1) for _ in range(n + 1)]
%o A396799     a = [0] * (n + 1); a[0] = 1
%o A396799     for m in range(0, n + 1):
%o A396799         g = [0] + [j * a[j - 1] * comb(m - 1, j - 1) for j in range(1, m + 1)]
%o A396799         T[m][1] = g[m]
%o A396799         for k in range(2, m + 1):
%o A396799             T[m][k] = sum(g[j] * T[m - j][k - 1] for j in range(1, m - k + 2))
%o A396799         a[m] = 1 - sum(a[k] * T[m][k] for k in range(1, m))
%o A396799     return [T[m][1] for m in range(1, n + 1)]
%o A396799 print(a_list(20))  # _Peter Luschny_, Jun 09 2026
%Y A396799 Cf. A140054, A087962, A087961.
