%I A396408 #16 May 31 2026 10:10:45
%S A396408 2,108,936,1820,2166,4437,5005,5008,5278,10486,10545,10556,10768,
%T A396408 16144,18582,22126,27420,27840,37014,37149,37170,38600,39321,44421,
%U A396408 49595,62830,68697,69046,72208,72700,78760,79935,91024,97820,100284,113145,113477,119470,123777,128616,128652,133494,138814
%N A396408 Numbers k such that A075254(k) is the square of a prime.
%C A396408 Numbers k such that k + sopfr(k) is a square, where sopfr(k) = A001414(k) is the sum of prime factors of k with multiplicity.
%C A396408 Except for 2, a subset of A386246.
%H A396408 Robert Israel, <a href="/A396408/b396408.txt">Table of n, a(n) for n = 1..1250</a>
%e A396408 a(3) = 936 is a term because 936 = 2^3 * 3^2 * 13, 936 + 3*2 + 2*3 + 13 = 961 = 31^2, and 31 is prime.
%p A396408 filter:= proc(n) local t,s;
%p A396408  s:= n + add(t[1]*t[2], t=ifactors(n)[2]);
%p A396408  issqr(s) and isprime(sqrt(s))
%p A396408 end proc:
%p A396408 A:=select(filter, [$1..10^6]);
%t A396408 a075254[n_]:=If[n==1, 1, n +Plus@@Times@@@FactorInteger@n];q[k_]:=PrimeQ[Sqrt[a075254[k]]];Select[Range[138814],q] (* _James C. McMahon_, May 29 2026 *)
%o A396408 (PARI) upto(nn)= my(f, s); [ k |k<-[1..nn], issquare(s=k+(f=factor(k))[, 1]~*f[, 2]) && isprime(sqrtint(s))]; \\ _Ruud H.G. van Tol_, May 31 2026
%Y A396408 Cf. A001248, A075254, A386246, A386954.
%K A396408 nonn
%O A396408 1,1
%A A396408 _Will Gosnell_ and _Robert Israel_, May 24 2026
