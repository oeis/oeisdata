%S A396910 1,2,5,6,5,10,11,19,42,19,40,26,23,47,62,45,56,92,55,86,74,62,67,85,
%T A396910 65,85,169,119,105,153,90,94,150,139,144,175,171,119,121,178,161,187,
%U A396910 234,301,203,206,226,173,217,406,178,216,160,372,208,341,175,281,234,301,322
%N A396910 Least k such that the set {J(n,1),J(n,2),...,J(n,k)} equals {1,2,...,n}, where J(n,k) is the Josephus survivor.
%C A396910 Let J(n,k) denote the survivor of the Josephus problem with n participants and step size k. Then a(n) is the least k such that every possible survivor 1,2,...,n has occurred among J(n,1),J(n,2),...,J(n,k).
%C A396910 The known terms were computed exactly by exhaustive evaluation of J(n,k).
%C A396910 The sequence is highly nonmonotonic. Large values occur when there is a long delay before the final previously unseen survivor is first observed. This is an empirical observation.
%C A396910 This sequence differs from A321793 by allowing the Josephus step size k=1. In A321793 the elimination parameter is restricted to q>1.
%H A396910 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/JosephusProblem.html">Josephus Problem</a>.
%F A396910 a(n) = min{k>=1 : {J(n,1),...,J(n,k)} = {1,2,...,n}} where J(1,k)=1 and J(n,k)=((J(n-1,k)+k-1) mod n)+1.
%e A396910 For n = 3, the Josephus survivors are J(3,1)=3, J(3,2)=3, J(3,3)=2, J(3,4)=2, J(3,5)=1. Thus every survivor {1,2,3} has appeared by k=5, so a(3)=5.
%e A396910 For n = 5, the survivor sequence begins 5, 3, 4, 1, 2, so every survivor {1,2,3,4,5} has appeared by k=5, and a(5)=5.
%o A396910 (Python)
%o A396910 def josephus_survivor(n, k):
%o A396910     survivor = 0
%o A396910     for size in range(2, n + 1):
%o A396910         survivor = (survivor + k) % size
%o A396910     return survivor + 1
%o A396910 def a(n):
%o A396910     discovered_survivors = set()
%o A396910     step_size = 1
%o A396910     while len(discovered_survivors) < n:
%o A396910         discovered_survivors.add(
%o A396910             josephus_survivor(n, step_size)
%o A396910         )
%o A396910         step_size += 1
%o A396910     return step_size - 1
%Y A396910 Cf. A321781, A321793, A321794.
%K A396910 nonn,new
%O A396910 1,2
