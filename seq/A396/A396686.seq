%N A396686 a(n) = floor(2*log_2(n)) + 2.
%C A396686 For n >= 4, a(n) is the tree-depth of the n-Moebius ladder graph.
%H A396686 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/MoebiusLadder.html">Moebius Ladder</a>.
%H A396686 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/Tree-Depth.html">Tree-Depth</a>.
%F A396686 a(n) = floor(2*log_2(n)) + 2.
%e A396686 a(1) = 2, a(2) = 4, a(3) = 5.
%t A396686 Table[Floor[2 Log2[n]] + 2, {n, 20}]
%t A396686 (* Alternative: *)
%t A396686 Floor[2 Log2[Range[20]]] + 2
