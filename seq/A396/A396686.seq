%N A396686 a(n) = floor(2*log_2(n)) + 2.
%F A396686 a(n) = floor(2*log_2(n)) + 2. - _Eric W. Weisstein_, Jul 07 2026
%F A396686 a(n) = A070939(2*n^2). - _Chai Wah Wu_, Jul 02 2026
%e A396686 a(1) = 2, a(2) = 4, a(3) = 5.
%p A396686 A396686 := proc(n)
%p A396686     2+floor(2*log[2](n)) ;
%p A396686 end proc:
%p A396686 seq(A396686(n),n=1..100) ; # _R. J. Mathar_, Jul 07 2026
