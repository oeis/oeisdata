%p A396981 A396981 := proc(n,k) option remember; local s;
%p A396981 if n  = 0 then return 1 fi;
%p A396981 if k <= 0 then return 0 fi;
%p A396981 s := ceil((sqrt(1 + 8*k) - 1)/2):
%p A396981 A396981(n, k - s) + ( n + s - 1) * A396981(n - 1, k) end:
%p A396981 for n from 0 to 6 do lprint(seq(A396981(n, k), k = 0..6)) od; # _Peter Luschny_, Jun 12 2026
%o A396981 (PARI) A002024(n) = (sqrtint(8*n-7)+1)\2
%o A396981 list_column(n, k) = my(v1 = vector(A002024(k+1), i, 0), v2 = vector(n+1, i, 0), v3); v1[1] = k; v2[1] = 1; for(i=2, #v1, v1[i] = v1[i-1] - A002024(v1[i-1])); v1 = Vecrev(v1); for(i=2, #v1, v3 = vector(n+1, i, 0); v3[1] = 1; A = v1[i] - v1[i-1]; for(j=1, n, v3[j+1] = v2[j+1] + (j+A-1)*v3[j]); v2 = v3); v2
%o A396981 (Python)
%o A396981 from functools import cache
%o A396981 from math import isqrt
%o A396981 @cache
%o A396981 def A396981(n: int, k: int) -> int:
%o A396981     if n == 0: return 1
%o A396981     if k <= 0: return 0
%o A396981     s = (isqrt(8*k) + 1) // 2
%o A396981     return A396981(n, k - s) + (n + s - 1) * A396981(n - 1, k)
%o A396981 for n in range(7): print([A396981(n, k) for k in range(7)])  # _Peter Luschny_, Jun 12 2026
