%I A396560 #12 Jun 21 2026 18:40:02
%S A396560 6,34,74,76,115,117,158,160,161,164,170,176,178,183,184,186,187,188,
%T A396560 192,193,195,211,213,214,216,219,220,225,226,227,228,229,231,233,236,
%U A396560 240,243,246,248,249,250,252,254,263,265,268,269,270,276,295,296,299,302,303
%N A396560 Which blocks in A280864 end in a prime.
%C A396560 Positions of primes in A396300.
%H A396560 Michael De Vlieger, <a href="/A396560/b396560.txt">Table of n, a(n) for n = 1..17195</a>
%F A396560 A280864(a(n)) = A280745(n).
%t A396560 Block[{c, j, k, m, q, r, s, w, nn, rad},
%t A396560   rad[n_] := rad[n] = Times @@ FactorInteger[n][[All, 1]];
%t A396560   nn = 4800; j = q = 0; r = s = 1; c[_] := False;
%t A396560   Reap[Do[w = GCD[r, s]; m = r/w; k = m;
%t A396560     While[Or[c[k], ! CoprimeQ[w, k]], k += m];
%t A396560     If[CoprimeQ[k, r], If[PrimeQ[j], Sow[q] ]; q++];
%t A396560      c[k] = True; s = r; j = k;
%t A396560      r = rad[k], {i, nn}] ][[-1, 1]] ]
%Y A396560 Cf. A280745, A280864, A396300.
%K A396560 nonn,new
%O A396560 1,1
%A A396560 _Michael De Vlieger_, Jun 13 2026
%E A396560 Definition edited by _N. J. A. Sloane_, Jun 21 2026
