%S A396744 1,1,-2,1,0,6,1,2,3,-24,1,4,12,16,120,1,6,33,116,165,-720,1,8,66,420,
%T A396744 1560,2016,5040,1,10,111,1072,7305,26982,30415,-40320,1,12,168,2216,
%U A396744 23280,162198,571816,539904,362880,1,14,237,3996,58245,637524,4398933,14364744,11049129,-3628800
%N A396744 Square array A(n,k), n>=1, k>=0, read by antidiagonals downwards, where A(n,k) = n! * [x^n] -W_k(-x)/(1 - W_k(-x)) and W_k(x) is the k-th iterate of LambertW(x).
%F A396744 A(n,0) = (-1)^(n-1) * n!; A(n,k) = Sum_{j=1..n} n^(n-j) * binomial(n-1,j-1) * A(j,k-1) for k > 0.
%F A396744 A(n,k) = (n-1)! * Sum_{x_1, x_2, ..., x_{k+1} >= 0 and x_1 + x_2 + ... + x_{k+1} = n-1} (-1)^(x_{k+1}) * (x_{k+1} + 1) * Product_{i=1..k} ((n - Sum_{j=1..i-1} x_j)^(x_i) / x_i!).
%e A396744 Square array begins:
%e A396744      1,    1,     1,      1,      1,       1, ...
%e A396744     -2,    0,     2,      4,      6,       8, ...
%e A396744      6,    3,    12,     33,     66,     111, ...
%e A396744    -24,   16,   116,    420,   1072,    2216, ...
%e A396744    120,  165,  1560,   7305,  23280,   58245, ...
%e A396744   -720, 2016, 26982, 162198, 637524, 1911060, ...
%e A396744   ...
%o A396744 (PARI) a(n, k) = if(k==0, (-1)^(n-1)*n!, sum(j=1, n, n^(n-j)*binomial(n-1, j-1)*a(j, k-1)));
%Y A396744 Columns k=0..3 give -A133942(n), A277458, A396745, A396746.
%Y A396744 Cf. A396675, A396711.
%K A396744 sign,tabl,new
%O A396744 1,3
%A A396744 _Seiichi Manyama_, Jun 04 2026
