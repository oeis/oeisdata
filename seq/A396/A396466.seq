%I A396466 #15 May 30 2026 15:52:52
%S A396466 1,1,0,1,2,0,1,4,9,0,1,6,28,52,0,1,8,57,236,340,0,1,10,96,632,2192,
%T A396466 2394,0,1,12,145,1320,7608,21650,17710,0,1,14,204,2380,19520,96564,
%U A396466 223272,135720,0,1,16,273,3892,41740,302580,1272828,2378336,1068012,0
%N A396466 Square array A(n,k), n>=0, k>=0, read by antidiagonals downwards, where A(n,k) = [x^n] (F_k(x)/x)^(2/3) and F_k(x) is the k-th iteration of x*G4(x)^3 with G4(x) = 1 + x*G4(x)^4.
%H A396466 Wikipedia, <a href="https://en.wikipedia.org/wiki/Fuss%E2%80%93Catalan_number">Fuss-Catalan number</a>
%F A396466 G.f. of column k: ((1/x) * Series_Reversion( H_k(x) ))^(2/3), where H_k(x) is the k-th iteration of x*(1 - x)^3.
%F A396466 A(n,k) = Sum_{0 = x_0 <= x_1 <= ... <= x_{k-1} <= x_k = n} Product_{j=0..k-1} (3*x_j + 2) * binomial(4*x_{j+1} - x_j + 2,x_{j+1} - x_j)/(4*x_{j+1} - x_j + 2).
%F A396466 A(n,0) = 0^n; A(n,k) = Sum_{j=0..n} (3*j+2) * binomial(4*n-j+2,n-j)/(4*n-j+2) * A(j,k-1) for k > 0.
%e A396466 Square array begins:
%e A396466   1,     1,      1,       1,       1,        1,        1, ...
%e A396466   0,     2,      4,       6,       8,       10,       12, ...
%e A396466   0,     9,     28,      57,      96,      145,      204, ...
%e A396466   0,    52,    236,     632,    1320,     2380,     3892, ...
%e A396466   0,   340,   2192,    7608,   19520,    41740,    78960, ...
%e A396466   0,  2394,  21650,   96564,  302580,   764110,  1666854, ...
%e A396466   0, 17710, 223272, 1272828, 4851456, 14425546, 36204616, ...
%e A396466   ...
%o A396466 (PARI)
%o A396466 a(n, k, p=4, s=3, r=2) = {
%o A396466   my(T=matrix(n+1, n+1, row, col, my(xr=row-1, xc=col-1); if(xc<xr, 0, (s*xr+r)*binomial(p*xc-(p-s)*xr+r, xc-xr)/(p*xc-(p-s)*xr+r))));
%o A396466   my(TK=T^k);
%o A396466   TK[1, n+1];
%o A396466 };
%Y A396466 Columns k=0..1 give A000007, A069271.
%Y A396466 Cf. A396431, A396448.
%K A396466 nonn,tabl
%O A396466 0,5
