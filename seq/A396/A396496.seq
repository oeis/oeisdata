%e A396496   1, 1, 17, 1, 16, 1, 14, 1, 12, 1, 10, 3,  9, 2, 8;
%e A396496   ...
%p A396496 b:= proc(n, i) option remember; `if`(i*(i+1)/2<n, 0, `if`(i=0,
%p A396496      `if`(n=0, 1, 0), b(n+i, i-1)+ `if`(i<=n, b(n-i, i-1), 0)))
%p A396496     end:
%p A396496 a:= proc(n) option remember; local k; for k from
%p A396496       floor((sqrt(1+8*n)-1)/2) while b(n, k)=0 do od; b(n, k)
%p A396496     end:
%p A396496 seq(a(n), n=0..90);
