%e A396496 Terms written as triangle give:
%e A396496   1;
%e A396496   1, 1;
%e A396496   1, 1,  1;
%e A396496   1, 1,  2, 1;
%e A396496   1, 1,  2, 1,  1;
%e A396496   1, 1,  2, 1,  3, 1;
%e A396496   1, 1,  2, 1,  2, 1,  2;
%e A396496   1, 1,  1, 1,  4, 1,  3, 1;
%e A396496   1, 1,  4, 1,  4, 1,  3, 1,  3;
%e A396496   1, 3,  1, 2,  1, 1,  8, 1,  7, 1;
%e A396496   1, 1,  6, 1,  5, 1,  5, 1,  4, 1,  5;
%e A396496   1, 4,  1, 3,  1, 3,  1, 2, 15, 1, 14, 1;
%e A396496   1, 1, 10, 1,  9, 1,  9, 1,  7, 2,  5, 1,  6;
