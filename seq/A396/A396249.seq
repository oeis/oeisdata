%I A396249 #27 Jul 04 2026 00:47:21
%S A396249 1,1,1,2,2,2,3,3,3,4,4,4,5,5,5,7,6,6,8,7,8,10,9,9,11,11,11,13,13,13,
%T A396249 16,15,15,18,17,19,21,20,21,24,24,24,28,27,28,33,31,32,36,36,38,41,41,
%U A396249 42,47,48,49,53,53,55,61,60,62,69,68,72,77,77,80,86,89,90
%N A396249 Number of strict partitions of n such that the difference between two adjacent parts is at most 2.
%H A396249 Alois P. Heinz, <a href="/A396249/b396249.txt">Table of n, a(n) for n = 0..10000</a>
%F A396249 G.f.: 1 + Sum_{i>0} x^(i*(i+1)/2) * (Product_{j=1..i-1} (1 + x^j))/(1 - x^i).
%e A396249 a(15) = 7: (15), (8,7), (7,5,3), (6,5,3,1), (6,5,4), (6,4,3,2), (5,4,3,2,1).
%p A396249 b:= proc(n,i) option remember; `if`(i*(i+1)/2<n, 0,
%p A396249       `if`(n=0 or i=n, 1, `if`(i>n, 0, b(n-i, i-1)+ b(n-i, i-2))))
%p A396249     end:
%p A396249 a:= n-> `if`(n=0, 1, add(b(n, i),i=1..n)):
%p A396249 seq(a(n), n=0..71);  # _Alois P. Heinz_, Jun 27 2026
%t A396249 a[n_]:=Length[Select[IntegerPartitions[n],ContainsOnly[Differences[#],{0,1,2,-1,-2}]&&DuplicateFreeQ[#]&]];Array[a,55,0] (* _James C. McMahon_, Jun 27 2026 *)
%o A396249 (PARI)
%o A396249 A_x(N) = {my(x='x+O('x^(N+1))); Vec(1 + sum(i=1,(sqrtint(8*N+1)-1)\2, x^(i*(i+1)/2) * prod(j=1,i-1,1 + x^j)/(1-x^i)))}
%Y A396249 Cf. A000009, A000041, A001227, A320387.
%K A396249 nonn,easy
%O A396249 0,4
%A A396249 _John Tyler Rascoe_, Jun 24 2026
