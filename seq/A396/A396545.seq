%I A396545 #11 May 31 2026 09:44:50
%S A396545 576,1568,2880,4032,4704,6336,7488,7840,9792,10944,13248,16704,17248,
%T A396545 17856,20160,20384,21312,23520,23616,24768,26656,27072,29792,30528,
%U A396545 31680,33984,35136,36064,37440,38592,40896,42048,44352,45472,45504,47808,48608,48960,51264
%N A396545 Numbers that are equal to the sum of their coreful divisors that are not exponential divisors.
%C A396545 Numbers k such that A396544(k) = k.
%C A396545 See A284318 and A322791 for the definitions of coreful divisors and exponential divisors, respectively.
%C A396545 All the terms are nonsquarefree numbers (A013929) and abundant numbers (A005101).
%C A396545 If k is a term and m is a squarefree number coprime to k, then k*m is also a term. The primitive terms of this sequence (A396546) are the powerful (A001694) terms. All the terms are of the form k*m where k is primitive and m is a squarefree number coprime to k.
%C A396545 The asymptotic density of this sequence is Sum_{n>=1} f(A396546(n)) = 0.00075706967604..., where f(n) = (6/(Pi^2*n)) * Product_{prime p|n} (p/(p+1)).
%H A396545 Amiram Eldar, <a href="/A396545/b396545.txt">Table of n, a(n) for n = 1..10000</a>
%t A396545 f1[p_, e_] = (p^(e+1)-1)/(p-1) - 1;
%t A396545 f2[p_, e_] = DivisorSum[e, p^# &];
%t A396545 q[k_] := Module[{fct = FactorInteger[k]}, Times @@ f1 @@@ fct - Times @@ f2 @@@ fct == k]; q[1] = False; Select[Range[60000], q]
%o A396545 (PARI) isok(k) = {my(f = factor(k)); prod(i = 1, #f~, (f[i,1]^(f[i,2]+1) - 1)/(f[i,1]-1) - 1) - prod(i = 1, #f~, sumdiv(f[i,2], d, f[i,1]^d)) == k;}
%Y A396545 Subsequence of A005101 and A013929.
%Y A396545 A396546 is a subsequence.
%Y A396545 Cf. A001694, A005117, A054979, A284318, A307958, A322791, A396544.
%K A396545 nonn
%O A396545 1,1
%A A396545 _Amiram Eldar_, May 29 2026
