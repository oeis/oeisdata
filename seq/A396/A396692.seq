%N A396692 Pandigital numbers that are anagrams of the concatenation of their prime factors.
%C A396692 This is a finite set of 184 composite numbers.
%H A396692 Robert G. Wilson v, <a href="/A396692/b396692.txt">Table of n, a(n) for n = 1..184</a>
%e A396692 a(1) = 1023485967 = 3^2 * 7 * 16245809;
%e A396692 a(184) = 9814765302 = 2 * 3^4 * 60584971.
%t A396692 fQ[n_] := Sort[ IntegerDigits[ n]] == Sort[ Flatten[ IntegerDigits[First /@ FactorInteger[ n]]]]; Select[ Range[1023456789, 9876543210, 9], fQ]
%o A396692 (Python)
%o A396692 from sympy import factorint
%o A396692 from itertools import islice, permutations
%o A396692 def agen(): # generator of terms
%o A396692     for first in "123456789":
%o A396692         for rest in permutations(sorted(set("0123456789")-{first})):
%o A396692             t = int(first + "".join(rest))
%o A396692             if sorted(str(t)) == sorted(e for p in factorint(t) for e in str(p)):
%o A396692                 yield t
%o A396692 print(list(islice(agen(), 24))) # _Michael S. Branicky_, Jul 08 2026
