%N A396424 a(n) = r(n,n), where r(1,k)=f(k)=ceiling(k*c), r(n,k)=f(r(n-1,k)), c=5/3.
%C A396424 a(n + 1)/a(n) approaches c erratically.
%t A396424 c = 5/3; f[k_] := f[k] = Ceiling[c*k];
%t A396424 r[1, k_] := f[k]; r[n_, k_] := r[n, k] = f[r[n - 1, k]];
%t A396424 Table[r[n, n], {n, 1, 100}]
