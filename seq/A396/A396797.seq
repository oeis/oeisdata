%I A396797 #22 Jun 17 2026 00:54:04
%S A396797 1,1,7,79,1135,18985,353677,7153189,154555171,3528840715,84488937127,
%T A396797 2109259815601,54672001265449,1466444914020193,40597143863727415,
%U A396797 1157550181151670775,33935309734728218959,1021438455577431070801,31528289881787590602421,996948751333216933836637,32266088358695070175276939
%N A396797 G.f. satisfies A(x) = x + A^3(x)*A^4(x).
%C A396797 Conjecture: a(n) = 1 (mod 6) for n >= 1.
%C A396797 Conjecture: [x^n] A^k(x) == k^(n-1) (mod 6) for n >= 1 and all integer k.
%H A396797 Paul D. Hanna, <a href="/A396797/b396797.txt">Table of n, a(n) for n = 1..401</a>
%F A396797 G.f. A(x) = Sum_{n>=1} a(n)*x^n has the following properties, where A^n(x) denotes the n-th iteration of A(x).
%F A396797 (1.a) A(x) = x + A^3(x)*A^4(x).
%F A396797 (1.b) A(x) = x + A^2(x)*A^4(x) + A^4(x)*A^5(x)*A^6(x).
%F A396797 (1.c) A(x) = x + A^3(x)^2 + A^3(x)*A^6(x)*A^7(x).
%F A396797 (2.a) A(x) = A^2(x) - A^4(x)*A^5(x).
%F A396797 (2.b) A(x) = A^3(x) - A^4(x)*A^5(x) - A^5(x)*A^6(x).
%F A396797 (2.c) A(x) = A^4(x) - A^4(x)*A^5(x) - A^5(x)*A^6(x) - A^6(x)*A^7(x).
%F A396797 (2.d) A(x) = A^n(x) - Sum_{k=1..n-1} A^(k+3)(x) * A^(k+4)(x) for n > 1.
%F A396797 (3.a) A(x) = x + Sum_{n>=1} d^(n-1)/dx^(n-1) A^2(x)^n*A^3(x)^n / n!.
%F A396797 (3.b) A(x) = x * exp( Sum_{n>=1} d^(n-1)/dx^(n-1) ( A^2(x)^n*A^3(x)^n/x ) / n! ).
%F A396797 (4.a) x = A( x - A^2(x)*A^3(x) ).
%F A396797 (4.b) x = A( x - A(x)*A^3(x) - A^3(x)*A^4(x)*A^5(x) ).
%F A396797 (4.c) x = A( x - A^2(x)^2 - A^2(x)*A^5(x)*A^6(x) ).
%F A396797 (5.a) x = A^2( x - A(x)*A^2(x) - A^2(x)*A^3(x) ).
%F A396797 (5.b) x = A^2( x - A(x)^2 - A^2(x)*A^3(x) - A(x)*A^4(x)*A^5(x) ).
%F A396797 (5.c) x = A^2( x - x*A^2(x) - A^2(x)*A^3(x) - A^2(x)*A^3(x)*A^4(x) ).
%F A396797 (6.a) x = A^3( x - x*A(x) - A(x)*A^2(x) - A^2(x)*A^3(x) ).
%F A396797 (6.b) x = A^3( x-x^2 - A(x)*A^2(x) - A^2(x)*A^3(x) - x*A^3(x)*A^4(x) ).
%F A396797 (6.c) x = A^4( x-x^2 - x*A(x) - A(x)*A^2(x) - (1-x)*A^2(x)*A^3(x) ).
%e A396797 G.f.: A(x) = x + x^2 + 7*x^3 + 79*x^4 + 1135*x^5 + 18985*x^6 + 353677*x^7 + 7153189*x^8 + 154555171*x^9 + 3528840715*x^10 + ...
%e A396797 The second iteration of A(x) begins
%e A396797 A^2(x) = x + 2*x^2 + 16*x^3 + 194*x^4 + 2926*x^5 + 50768*x^6 + 973930*x^7 + 20186054*x^8 + 445413976*x^9 + ...
%e A396797 where A^2(x) = A(x) + A^4(x)*A^5(x).
%e A396797 The third and fourth iterations of A(x) begin
%e A396797 A^3(x) = x + 3*x^2 + 27*x^3 + 351*x^4 + 5565*x^5 + 100413*x^6 + 1989705*x^7 + 42397779*x^8 + 958521855*x^9 + ...
%e A396797 A^4(x) = x + 4*x^2 + 40*x^3 + 556*x^4 + 9268*x^5 + 174148*x^6 + 3571396*x^7 + 78418660*x^8 + 1820923876*x^9 + ...
%e A396797 where A(x) = x + A^3(x)*A^4(x).
%e A396797 Let R(x) = A^(-1)(x), R(A(x)) = x, then
%e A396797 R(x) = x - x^2 - 5*x^3 - 49*x^4 - 647*x^5 - 10207*x^6 - 181943*x^7 - 3552901*x^8 - 74569013*x^9 + ...
%e A396797 where R(x) = x - A^2(x)*A^3(x).
%e A396797 Therefore, g.f. A(x) satisfies
%e A396797 A(x) = x + A^2(x)*A^3(x) + d/dx (A^2(x)*A^3(x))^2/2! + d^2/dx^2 (A^2(x)*A^3(x))^3/3! + d^3/dx^3 (A^2(x)*A^3(x))^4/4! + d^4/dx^4 (A^2(x)*A^3(x))^5/5! + ...
%e A396797 Also, g.f. A(x) is the unique solution to variable A in the infinite system of simultaneous equations starting with:
%e A396797   A = x + C*D;
%e A396797   B = A + D*E;
%e A396797   C = B + E*F;
%e A396797   D = C + F*G; ...
%e A396797 resulting in B = A^2(x), C = A^3(x), D = A^4(x), etc.
%o A396797 (PARI) \\ By definition A(x) = x + A^3(x)*A^4(x)
%o A396797 \\ ('truncate' is used here to reduce runtime)
%o A396797 {a(n) = my(A=x, A2); for(i=1, n, A=truncate(A) +x^2*O(x^i);
%o A396797 A2 = subst(A, x, A); A = x + subst(A*A2, x, A2) +x*O(x^n)); polcoef(GF=A, n)}
%o A396797 {upto(n) = a(n); Vec(GF)}
%o A396797 upto(30)
%o A396797 (PARI) \\ Using series reversion of x - A^2(x)*A^3(x)
%o A396797 \\ ('truncate' is used here to reduce runtime)
%o A396797 {a(n) = my(A=x, A2); for(i=1, n,  A=truncate(A) +x^2*O(x^i);
%o A396797 A2 = subst(A, x, A); A = serreverse(x - A2*subst(A, x, A2)) +x*O(x^n)); polcoef(GF=A, n)}
%o A396797 {upto(n) = a(n); Vec(GF)}
%o A396797 upto(30)
%Y A396797 Cf. A396798, A396807, A396099, A213591.
%K A396797 nonn,new
%O A396797 1,3
%A A396797 _Paul D. Hanna_, Jun 15 2026
