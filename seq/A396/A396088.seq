%I A396088 #7 May 19 2026 08:37:25
%S A396088 1,1,4,31,420,8625,250390,9755865,491081920,31014100075,2400955356800,
%T A396088 223572227064725,24651926498649450,3176457586849471925,
%U A396088 472922111178703686500,80565771445402030162375,15571265127003721138503500,3388824513487008434682468625
%N A396088 Number of labeled histories for rooted at-most-trifurcating trees with n leaves, if simultaneous branching events are allowed.
%H A396088 Emily H. Dickey and Noah A. Rosenberg, <a href="https://doi.org/10.1016/j.dam.2026.04.032">Labeled histories and maximally probable labeled topologies with multifurcation</a>, Discr. Appl. Math. 391 (2026), 192-203. See Table 2.
%F A396088 a(n) = Sum_{j2=0..floor(n/2)} Sum_{j3=max(ceiling((2-2*j2)/3),0)..floor((n-2*j2)/3)}(n!/((2^j2)*j2!*(6^j3)*j3!*(n-2*j2-3*j3)!))*a(n-j2-2*j3), a(1)=1.
%e A396088 For n=3, the a(3)=4 labeled histories for leaves A, B, and C are the three binary trees ((A,B),C), ((A,C),B), and ((B,C),A) and the ternary tree (A,B,C).
%t A396088 A[1] := 1;
%t A396088 A[n_] := A[n] = n! Sum[(1/((2!)^x2 (x2!))) Sum[1/((3!)^x3 (x3!) (n - 2 x2 - 3 x3)!)*A[n - x2 - 2 x3], {x3, Max[Ceiling[(2 - 2 x2)/3], 0], Floor[(n - 2 x2)/3]}], {x2, 0, Floor[n/2]}];
%t A396088 Table[A[n], {n, 1, 18}]
%Y A396088 Cf. A317059 if only bifurcations are allowed.
%Y A396088 Cf. A358072 if only non-simultaneous bifurcations and trifurcations are allowed.
%K A396088 nonn,new
%O A396088 1,3
%A A396088 _Noah A Rosenberg_, May 17 2026
