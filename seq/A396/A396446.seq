%S A396446 1,1,0,1,1,0,1,2,3,0,1,3,9,12,0,1,4,18,51,55,0,1,5,30,132,324,273,0,1,
%T A396446 6,45,270,1071,2208,1428,0,1,7,63,480,2665,9255,15792,7752,0,1,8,84,
%U A396446 777,5580,27870,83571,117048,43263,0,1,9,108,1176,10395,68460,303501,779808,891774,246675,0
%N A396446 Square array A(n,k), n>=0, k>=0, read by antidiagonals downwards, where A(n,k) = [x^n] (F_k(x)/x)^(1/2) and F_k(x) is the k-th iteration of x*G3(x)^2 with G3(x) = 1 + x*G3(x)^3.
%F A396446 G.f. of column k: ((1/x) * Series_Reversion( H_k(x) ))^(1/2), where H_k(x) is the k-th iteration of x*(1 - x)^2.
%F A396446 A(n,k) = Sum_{0 = x_0 <= x_1 <= ... <= x_{k-1} <= x_k = n} Product_{j=0..k-1} (2*x_j + 1) * binomial(3*x_{j+1} - x_j + 1,x_{j+1} - x_j)/(3*x_{j+1} - x_j + 1).
%e A396446 Square array begins:
%e A396446   1,    1,     1,     1,      1,      1,       1, ...
%e A396446   0,    1,     2,     3,      4,      5,       6, ...
%e A396446   0,    3,     9,    18,     30,     45,      63, ...
%e A396446   0,   12,    51,   132,    270,    480,     777, ...
%e A396446   0,   55,   324,  1071,   2665,   5580,   10395, ...
%e A396446   0,  273,  2208,  9255,  27870,  68460,  146328, ...
%e A396446   0, 1428, 15792, 83571, 303501, 872256, 2134524, ...
%e A396446   ...
%o A396446 (PARI)
%o A396446 a(n, k, l=3, p=2, r=1) = {
%o A396446   my(T=matrix(n+1, n+1, row, col, my(xr=row-1, xc=col-1); if(xc<xr, 0, (p*xr+r)*binomial(l*xc-(l-p)*xr+r, xc-xr)/(l*xc-(l-p)*xr+r))));
%o A396446   my(TK=T^k);
%o A396446   TK[1, n+1];
%o A396446 };
%Y A396446 Columns k=0..2 give A000007, A001764, A396432.
%Y A396446 Cf. A396429.
%K A396446 nonn,tabl,new
%O A396446 0,8
