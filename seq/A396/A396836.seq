%I A396836 #14 Jun 10 2026 08:51:52
%S A396836 1,2,3,5,6,7,13,4,14,10,11,8,15,31,26,21,27,23,63,30,29,53,55,126,20,
%T A396836 9,52,61,106,12,58,22,127,54,46,59,42,47,62,43,95,255,19,190,85,107,
%U A396836 125,110,45,16,17,109,122,87,111,93,18,117,123,91,251,39,213
%N A396836 Lexicographically earliest sequence of distinct positive integers whose binary values, when written on a square spiral, one bit per square, high order bits first, contain no pair of 0 bits that are a knight's move apart.
%C A396836 Although the terms equal to powers of 2 are delayed relative to similar size terms, e.g. a(4645) = 256, it is conjectured that the sequence contains all positive integers.
%H A396836 Scott R. Shannon, <a href="/A396836/b396836.txt">Table of n, a(n) for n = 1..5000</a>
%H A396836 Scott R. Shannon, <a href="/A396836/a396836.png">Image of the first 5000 terms on the square spiral</a>. Zoom in to see the details. The 1 bits are black while the 0 bits are light gray. The bits that comprise each term are connected by a red line.
%e A396836 The spiral begins:
%e A396836 .
%e A396836                                 .
%e A396836     0---0---0---1---1---1---0   1
%e A396836     |                       |   |
%e A396836     1   0---1---1---1---1   1   0
%e A396836     |   |               |   |   |
%e A396836     1   1   1---1---0   1   0   1
%e A396836     |   |   |       |   |   |   |
%e A396836     1   1   1   1---1   0   1   0
%e A396836     |   |   |           |   |   |
%e A396836     1   0   0---1---1---1   0   1
%e A396836     |   |                   |   |
%e A396836     1   0---1---1---1---0---1   0
%e A396836     |                           |
%e A396836     1---1---1---1---1---1---0---1
%e A396836 .
%e A396836 a(1) = 1 by definition.
%e A396836 a(2) = 2 as the 3rd square, the first to contain a 0 bit, is not a knight's move away from any other existing 0 bit.
%e A396836 a(4) = 5 = 101_2 as the 7th square, which contains the central 0 bit of 101_2, is not a knight's move away from the 3rd square, the only other square containing a 0 bit. Note that a(4) cannot equal 4 = 100_2 as that would place a 0 bit on the 8th square which is a knight's move away from the 3rd square.
%Y A396836 Cf. A396837 (start at 0), A007088, A396603, A396604, A396607, A396608.
%K A396836 nonn,base,new
%O A396836 1,2
