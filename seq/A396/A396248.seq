%T A396248 163,173,179,181,193,199,229,239,241,257,263,269,271,277,283,313,337,
%U A396248 349,359,373,379,389,421,433,439,449,463,509,523,547,563,569,571,577
%N A396248 Primes prime(k) such that prime(k) - prime(k-1) is a factorial.
%C A396248 The sequence consists of all primes prime(k) for which the gap to the previous prime prime(k-1) is a factorial.
%C A396248 Every upper member of a twin prime (A006512) pair belongs to the sequence, since 2 = 2!.
%e A396248 7 (4th prime) is in the sequence because it follows 5 (3rd prime), and 7 - 5 = 2 = 2!.
%e A396248 67 (19th prime) is in the sequence because it follows 61 (18th prime), and 67 - 61 = 6 = 3!.
%e A396248 11 (5th prime) is not in the sequence because it follows 7 (4th prime), and 11 - 7 = 4, which is not a factorial of any nonnegative integer.
%t A396248 seq[lim_] := Module[{ps = Select[Range[lim], PrimeQ], f = 1, k = 1, d, mxd}, d = Differences[ps]; mxd = Max[d]; While[f < mxd, k++; f *= k]; ps[[1 + Position[d, _?(MemberQ[Range[k]!, #] &)] // Flatten]]]; seq[600] (* _Amiram Eldar_, May 22 2026 *)
%o A396248 (Python)
%o A396248 from sympy import prime
%o A396248 import math
%o A396248 def sequence(n_max):
%o A396248     results = []
%o A396248     facts = [math.factorial(k) for k in range(0, 7)]
%o A396248     for i in range(2, n_max + 1):
%o A396248         gap = prime(i) - prime(i-1)
%o A396248         if gap in facts:
%o A396248             results.append(prime(i))
%o A396248     return results
%o A396248 print(sequence(200))
%Y A396248 Cf. A000142, A031925, A126720, A192434, A001223, A000040, A006512.
