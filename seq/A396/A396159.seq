%U A396159 -640669821436755,10265348737564125,-77871582933450075,9898775194885242435,-105666176941167049515,1744050969382356538475,12322967114104483154175
%N A396159 Numerators in the asymptotic expansion of Gamma(1 + 2*x)/(Gamma(1 + x)*Gamma(2 + x)) = (4^x/sqrt(Pi))*Sum_{k>=0} (1/x)^(3/2+k)*a(k)/A061549(k).
%C A396159 Gamma(1 + 2*n)/(Gamma(1 + n)*Gamma(2 + n)) interpolates the Catalan numbers A000108.
%H A396159 Neven Elezović, <a href="https://doi.org/10.7153/jmi-09-81">Asymptotic expansions of gamma and related functions, binomial coefficients, inequalities and means</a>, Journal of Mathematical Inequalities, Volume 9, Number 4 (2015), 1001-1054.
%F A396159 a(n) = numerator( (1/n)*Sum_{k=1..n} ( ((2^(-k)-2)*B_{k+1}/(k+1)) + (-1)^k )*a(n-k)/A061549(n-k) ), for n > 0 with a(0) = 1 where B_{k} is the Bernoulli number A027641(k)/A027642(k).
%F A396159 abs(A143503(n+2)) = abs(abs(a(n+1)) - abs(a(n))*A061549(n+1)/A061549(n)).
%o A396159 (PARI)
%o A396159 p(m) = if(m==0, 1, (1/m)*sum(k=1, m, (((2^(-k)-2)*bernfrac(k+1)/(k+1))+(-1)^k)*p(m-k)))
%o A396159 a(n) = numerator(p(n))
%Y A396159 Cf. A000108, A027641, A027642, A143503.
%Y A396159 Cf. A061549 (denominators).
%K A396159 sign,frac
%O A396159 0,2
