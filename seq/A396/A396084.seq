%I A396084 #11 May 21 2026 23:44:04
%S A396084 120,276,277,448,449,486,487,508,509,510,672,673,702,768,769,771,925,
%T A396084 1023,1059,1089,1104,1132,1233,1311,1334,1335,1416,1421,1422,1423,
%U A396084 1431,1989,2035,2061,2080,2081,2115,2296,2297,2304,2330,2416,2417,2461,2630,2682,2683
%N A396084 Numbers k whose orbit under k -> |sigma(k) - 2*k| avoids 0 and 1.
%C A396084 Let f(k) = |sigma(k) - 2*k|, where sigma(k) is the sum of the positive divisors of k. This sequence consists of all positive integers k whose forward orbit k, f(k), f(f(k)), ... never reaches 0 or 1.
%C A396084 Reaching 0 would force the orbit to terminate at a perfect number (A000396), while reaching 1 would trap the orbit at the fixed point 1.
%C A396084 All known orbits avoiding 0 and 1 reach a fixed point corresponding to a triperfect number (A005820). No nontrivial cycles (cycles of length > 1) are known.
%C A396084 Consecutive terms are common, reflecting the dense preimage structure of small values under f.
%H A396084 Felix Huber, <a href="/A396084/b396084.txt">Table of n, a(n) for n = 1..10000</a>
%F A396084 Disjoint from A000396, A000079, and A396083.
%e A396084 448 is a term since 448 -> 120 -> 120.
%p A396084 g := proc(n) option remember; NumberTheory:-sigma(n) end proc:
%p A396084 f := proc(n) option remember; abs(g(n) - 2*n) end proc:
%p A396084 r := table():
%p A396084 h := proc(l, v) global r; local i; for i in l do r[i] := v; end do; end proc:
%p A396084 q := proc(n) option remember;
%p A396084     global r; local d, l;
%p A396084     d := n; l := [];
%p A396084     while true do
%p A396084         if d = 0 or d = 1 then h(l, false); return false
%p A396084         elif assigned(r[d]) then h(l, r[d]); return r[d]
%p A396084         elif member(d, l) then h(l, true); return true
%p A396084         else l := [op(l), d]; d := f(d)
%p A396084         end if
%p A396084     end do
%p A396084 end proc:
%p A396084 A396084 := proc(n)
%p A396084     option remember;
%p A396084     local k, p;
%p A396084     if n = 1 then return 120 end if;
%p A396084     p := A(n - 1);
%p A396084     for k from p + 1 do
%p A396084         if q(k) then return k end if
%p A396084     end do
%p A396084 end proc:
%p A396084 seq(A396084(n), n = 1 .. 47);
%t A396084 q[k_] := Module[{s}, s[0] = 0; s[n_] := Abs[DivisorSigma[1, n] - 2*n]; NestWhile[s, k, UnsameQ, All] > 1]; Select[Range[2700], q] (* _Amiram Eldar_, May 18 2026 *)
%Y A396084 Supersequence of A005820.
%Y A396084 Cf. A000079, A000203, A000396, A001065, A033879, A033880, A396083.
%K A396084 nonn,easy
%O A396084 1,1
%A A396084 _Felix Huber_, May 18 2026
