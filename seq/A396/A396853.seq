%S A396853 2,19,71,79,89,107,127,151,199,223,233,251,271,359,433,487,557,593,
%T A396853 599,631,673,719,919,971,1031,1097,1279,1297,1321,1367,1777,1889,1913,
%U A396853 2017,2143,2179,2357,2557,2609,2647,2663,2791,2953
%N A396853 Primes p such that both Mordell equations y^2 = x^3 + p and y^2 = x^3 - p have integer solutions.
%H A396853 Zhining Yang, <a href="/A396853/b396853.txt">Table of n, a(n) for n = 1..1453</a>
%e A396853 Prime 89 is in the sequence because both Mordell equations y^2 = x^3 + 89 and y^2 = x^3 - 89 have integer solutions as {{-4, 5},{-2, 9},{10, 33},{55, 408}} and {{5, 6}}.
%o A396853 (SageMath)
%o A396853 def f(a, b):
%o A396853     for p in primes(a, b):
%o A396853         if EllipticCurve([0, 0, 0, 0, -p]).integral_points() and \
%o A396853            EllipticCurve([0, 0, 0, 0,  p]).integral_points():
%o A396853             print(p)
%o A396853 f(2, 200)
%Y A396853 Cf. A081120, A081119.
%K A396853 nonn
%O A396853 1,1
