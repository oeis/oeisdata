%S A396502 1,1,0,1,1,0,1,2,9,0,1,3,24,169,0,1,4,45,572,4913,0,1,5,72,1299,20768,
%T A396502 194481,0,1,6,105,2440,56457,1020432,9765625,0,1,7,144,4085,123392,
%U A396502 3302643,63471904,594823321,0,1,8,189,6324,235505,8360544,243901557,4788627328,42618442977,0
%N A396502 Square array A(n,k), n>=0, k>=0, read by antidiagonals downwards, where A(n,k) = n! * [x^n] (F_k(x)/x)^(1/2) and F_k(x) is the k-th iteration of x*G(x)^2 with G(x) = exp(x*G(x)^4).
%F A396502 E.g.f. of column k: ((1/x) * Series_Reversion( H_k(x) ))^(1/2), where H_k(x) is the k-th iterate of U(x)*exp(-4*U(x)) and U(x) = -LambertW(-2*x)/2.
%F A396502 A(n,k) = Sum_{0 = x_0 <= x_1 <= ... <= x_{k-1} <= x_k = n} Product_{j=0..k-1} (2*x_j + 1) * (4*x_{j+1} - 2*x_j + 1)^(x_{j+1} - x_j - 1) * binomial(x_{j+1},x_j).
%F A396502 A(n,0) = 0^n; A(n,k) = Sum_{j=0..n} (2*j+1) * (4*n-2*j+1)^(n-j-1) * binomial(n,j) * A(j,k-1) for k > 0.
%e A396502 Square array begins:
%e A396502   1,      1,       1,       1,       1,        1, ...
%e A396502   0,      1,       2,       3,       4,        5, ...
%e A396502   0,      9,      24,      45,      72,      105, ...
%e A396502   0,    169,     572,    1299,    2440,     4085, ...
%e A396502   0,   4913,   20768,   56457,  123392,   235505, ...
%e A396502   0, 194481, 1020432, 3302643, 8360544, 18121605, ...
%e A396502   ...
%o A396502 (PARI)
%o A396502 a(n, k, p=4, s=2, r=1) = {
%o A396502   my(T=matrix(n+1, n+1, row, col, my(xr=row-1, xc=col-1); if(xc<xr, 0, (s*xr+r)*(p*xc-(p-s)*xr+r)^(xc-xr-1)*binomial(xc, xr))));
%o A396502   my(TK=T^k);
%o A396502   TK[1, n+1];
%o A396502 };
%Y A396502 Columns k=0..1 give A000007, A052774.
%Y A396502 Cf. A396447, A396504.
%K A396502 nonn,tabl,changed
