%U A396011 617,657,704,748,800,847,903,955,1015,1071,1136,1196,1266,1331,1405,1475,1555
%N A396011 Number of 2's in the partitions of n into exactly 5 parts.
%H A396011 <a href="/index/Par#part">Index entries for sequences related to partitions</a>
%H A396011 <a href="/index/Rec#order_10">Index entries for linear recurrences with constant coefficients</a>, signature (1,1,0,0,-2,0,0,1,1,-1).
%F A396011 G.f.: q^5 * Sum_{j=1..5} q^j / Product_{k=1..5-j} (1 - q^k).
%F A396011 a(n) = a(n-1) + a(n-2) - 2*a(n-5) + a(n-8) + a(n-9) - a(n-10) for n > 20.
%F A396011 a(n) = A320592(n+2) - 1 for n > 10.
%o A396011 (PARI) my(N=60, q='q+O('q^N)); concat([0, 0, 0, 0, 0, 0], Vec(q^5*sum(j=1, 5, q^j/prod(k=1, 5-j, 1-q^k))))
%Y A396011 Cf. A394873, A396012.
%Y A396011 Cf. A024786, A026811, A320592, A394827.
%K A396011 nonn,easy,new
