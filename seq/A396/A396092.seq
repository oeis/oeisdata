%I A396092 #21 May 18 2026 10:15:35
%S A396092 1,1,4,17,86,462,2618,15353,92486,568718,3555584,22532138,144409916,
%T A396092 934418240,6095986470,40052678505,264800753862,1760313101910,
%U A396092 11759244064328,78897828614654,531444095774228,3592483097430356,24363311039781332,165714454300844298,1130212930252663324,7727553711056181772
%N A396092 G.f. satisfies A(x) = 1 + x*A(x)^2 + 2*x^2*A(x)^4.
%H A396092 Paul D. Hanna, <a href="/A396092/b396092.txt">Table of n, a(n) for n = 0..500</a>
%F A396092 G.f. A(x) = Sum_{n>=0} a(n)*x^n satisfies the following formulas.
%F A396092 (1) A(x) = 1 + x*A(x)^2 + 2*x^2*A(x)^4.
%F A396092 (2) A(x) = (1 - x*A(x) - sqrt(1 - 2*x*A(x) - 7*x^2*A(x)^2)) / (4*x^2*A(x)^2).
%F A396092 (3) A(x) = sqrt( (1/x) * Series_Reversion( x/(1 + x + 2*x^2)^2 ) ).
%F A396092 (4) A(x) = (1/x) * Series_Reversion(x/G(x)) where G(x) = (1-x - sqrt(1 - 2*x - 7*x^2))/(4*x^2) is the g.f. of A025235.
%F A396092 (5) a(n) = (1/(2*n+1)) * Sum_{k=[3*n/2]..2*n+1} 2^(2*n+1-k) * binomial(2*n+1,k) * binomial(k,2*k-2-3*n).
%F A396092 a(n) ~ 2^(2*n) * 7^(2*n + 3/2) / (sqrt(5*Pi) * n^(3/2) * 3^(3*n + 5/2)). - _Vaclav Kotesovec_, May 17 2026
%e A396092 G.f.: A(x) = 1 + x + 4*x^2 + 17*x^3 + 86*x^4 + 462*x^5 + 2618*x^6 + 15353*x^7 + 92486*x^8 + 568718*x^9 + ...
%t A396092 Table[Sum[2^(2*n + 1 - k) * Binomial[2*n + 1, k] * Binomial[k, 2*k - 2 - 3*n], {k, Floor[3*n/2], 2*n + 1}]/(2*n+1), {n, 0, 25}] (* _Vaclav Kotesovec_, May 17 2026 *)
%o A396092 (PARI) {a(n) = (1/(2*n+1))*sum(k=floor(3*n/2+1),2*n+1, 2^(2*n+1-k) * binomial(2*n+1,k) * binomial(k,2*k-2-3*n) )}
%o A396092 for(n=0,30,print1(a(n),", "))
%o A396092 (PARI) {a(n) = my(A = sqrt( 1/x*serreverse(x/(1 + x + 2*x^2)^2 +x^2*O(x^n)) )); polcoef(GF=A,n)}
%o A396092 {upto(n) = a(n); Vec(GF)}
%o A396092 upto(30)
%Y A396092 Cf. A025235.
%K A396092 nonn
%O A396092 0,3
%A A396092 _Paul D. Hanna_, May 17 2026
