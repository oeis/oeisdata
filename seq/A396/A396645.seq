%I A396645 #20 Jul 06 2026 03:53:20
%S A396645 1,1,1,2,6,30,290,5795,273131,33435365,11684100029,12420429123560,
%T A396645 42758167792063420,497197306541110815666,20499715659897938314285818,
%U A396645 3096905029809572116833551189888,1787271136443917603307861222439598096,4049832282285832299658439630909210798514596
%N A396645 a(n) = Sum_{j=1..n} |Stirling1(n-1,j-1)| * a(n-j) for n>=1, starting with a(0) = 1.
%H A396645 Alois P. Heinz, <a href="/A396645/b396645.txt">Table of n, a(n) for n = 0..59</a>
%H A396645 Wikipedia, <a href="https://en.wikipedia.org/wiki/Stirling_numbers_of_the_first_kind">Stirling numbers of the first kind</a>
%F A396645 a(n) = Sum_{j=1..n} A132393(n-1,j-1) * a(n-j) for n>=1, a(0) = 1.
%p A396645 b:= proc(n) option remember; expand(`if`(n=0, 1,
%p A396645       add(b(n-j)*x*binomial(n-1, j-1)*(j-1)!, j=1..n)))
%p A396645     end:
%p A396645 a:= proc(n) option remember; `if`(n=0, 1,
%p A396645       add(a(n-j)*coeff(b(n-1), x, j-1), j=1..n))
%p A396645     end:
%p A396645 seq(a(n), n=0..17);
%Y A396645 Cf. A000110, A132393, A329968, A381515.
%K A396645 nonn,new
%O A396645 0,4
