%I A396585 #12 Jun 12 2026 18:23:59
%S A396585 1,0,1,3,3,4,6,9,12,16,38,44,53,65,81,160,198,242,295,360,441,905,
%T A396585 1065,1263,1505,1800,2160,2601,4830,5735,6800,8063,9568,11368,13528,
%U A396585 16129,28308,33138,38873,45673,53736,63304,74672,88200,104329
%N A396585 Triangle read by rows: the Motzkin square. T(n, k) = T(n, k+1) - T(n-1, k) with initial values T(n, n) = A001006(n)^2.
%H A396585 Paolo Xausa, <a href="/A396585/b396585.txt">Table of n, a(n) for n = 0..11475</a> (rows 0..150 of triangle, flattened).
%F A396585 T(n, k) = Sum_{j=0..n-k} (-1)^j * binomial(n-k, j) * A001006(n-j)^2.
%e A396585 Triangle starts:
%e A396585   [0] [    1]
%e A396585   [1] [    0,     1]
%e A396585   [2] [    3,     3,     4]
%e A396585   [3] [    6,     9,    12,    16]
%e A396585   [4] [   38,    44,    53,    65,    81]
%e A396585   [5] [  160,   198,   242,   295,   360,   441]
%e A396585   [6] [  905,  1065,  1263,  1505,  1800,  2160,  2601]
%e A396585   [7] [ 4830,  5735,  6800,  8063,  9568, 11368, 13528, 16129]
%e A396585   [8] [28308, 33138, 38873, 45673, 53736, 63304, 74672, 88200, 104329]
%p A396585 T := proc(n, k) option remember; if n = k then return simplify(hypergeom([1/2-n/2, -n/2], [2], 4)^2) else T(n, k+1) - T(n-1, k) fi end:
%p A396585 seq(print(seq(T(n, k),k = 0..n)), n = 0..9);
%t A396585 A396585[n_, k_] := A396585[n, k] = If[n == k, Hypergeometric2F1[(1-n)/2, -n/2, 2, 4]^2, A396585[n, k+1] - A396585[n-1, k]];
%t A396585 Table[A396585[n, k], {n, 0, 10}, {k, 0, n}] (* _Paolo Xausa_, Jun 12 2026 *)
%o A396585 (Python)
%o A396585 def a_gen():
%o A396585     a, b, n, m = 0, 1, 1, 1
%o A396585     diffs = []
%o A396585     while True:
%o A396585         diffs.append(m * m)
%o A396585         for k in range(n - 1, 0, -1):
%o A396585             diffs[k - 1] = diffs[k] - diffs[k - 1]
%o A396585         # yield m generates A001006
%o A396585         # yield diffs[0] generates A172361.
%o A396585         # yield diffs[n-1] generates A133053.
%o A396585         # yield sum(diffs[:]) generates A396648.
%o A396585         yield diffs[:]
%o A396585         m = (3 * n * a + (2 * n + 1) * b) // ((n + 2) * n)
%o A396585         n += 1
%o A396585         a, b = b, n * m
%o A396585 A396585 = a_gen(); [next(A396585) for _ in range(9)]
%Y A396585 Cf. A001006, A133053, A172361, A396648 (row sums).
%K A396585 nonn,tabl,new
%O A396585 0,4
%A A396585 _Peter Luschny_, Jun 11 2026
