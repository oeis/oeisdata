%S A396996 1,1,4,31,370,6086,129264,3397296,107221505,3974548576,170115357149,
%T A396996 8294380016586,455673926870665,27952688153369566,1900153639104317684,
%U A396996 142211122695616511151,11652721820158989884350,1040275857867000296475931,100745703031483052123369619
%N A396996 E.g.f. A(x) satisfies A'(x) = exp(A^3(x)), with A(0) = 0.
%F A396996 E.g.f. A(x) satisfies A'(x) = exp(A^l(x)), where A^l(x) denotes the l-th iterate of A, with A(0) = 0.
%F A396996 Let a(n,k,l) = n! * [x^n] A^k(x), where A^k(x) is the k-th iterate of A, and let b(n,k,l) = n! * [x^n] exp(A^k(x)).
%F A396996 a(n,0,l) = 0^(n-1), b(0,k,l) = 1,
%F A396996 a(n,k,l) = Sum_{j=0..n-1} binomial(n-1,j) * b(j,k+l-1,l) * a(n-j,k-1,l) for k > 0, and
%F A396996 b(n,k,l) = Sum_{j=1..n} binomial(n-1,j-1) * a(j,k,l) * b(n-j,k,l) for n > 0.
%F A396996 These recurrences are computationally expensive; in practice, direct iteration of the defining power series is much faster.
%Y A396996 Column k=1 of A397000.
%Y A396996 Cf. A214645, A396803.
%K A396996 nonn
%O A396996 1,3
