%I A396285 #30 Jul 08 2026 01:03:39
%S A396285 0,2,30,190,772,2388,6152,13902,28458,53922,96020,162480,263452,
%T A396285 411970,624450,921230,1327152,1872180,2592060,3529022,4732518,6260002,
%U A396285 8177752,10561728,13498472,17086050,21435030,26669502,32928140,40365300,49152160,59477902,71550930,85600130
%N A396285 a(n) is the number of distinct triples of triangles chosen from the n^2 unit triangles of the triangular grid up to rotation.
%C A396285 Oblique coordinate system is defined taking X axis and Y axis along two edges of the triangular grid of unit triangles n^2. Side length of a unit triangle is taken as 3 units to obtain integer coordinates for the centroids of all unit triangles. Each triangle in the grid is uniquely denoted by coordinates of its centroid.
%H A396285 Paolo Xausa, <a href="/A396285/b396285.txt">Table of n, a(n) for n = 1..10000</a>
%H A396285 Janaka Rodrigo, <a href="/A396285/a396285.txt">Python Code for sets of triples of triangles</a>.
%H A396285 Janaka Rodrigo, <a href="/A396285/a396285_1.pdf">Illustration of configurations for n = 3</a>
%F A396285 a(n) = (1/3)*(binomial(n^2,3) + 2*floor(n^2/3)).
%e A396285 n = 2 has binomial(2^2,3) = 4 distinct sets of triples of triangles in total and those can be written in coordinates as follows:
%e A396285  {(1,1), (2,2), (4,1)},
%e A396285  {(1,1), (2,2), (1,4)},
%e A396285  {(4,1), (2,2), (1,4)},
%e A396285  {(1,1), (4,1), (1,4)}.
%e A396285 n = 2 has floor((2^2)/3) = 1 rotationally invariant set:
%e A396285  {(1,1),(4,1),(1,4)}
%e A396285 Therefore a(2) = (1/3)*(4 + 2*1) = 2.
%e A396285 Relevant sets of triples of triangles are:
%e A396285  {(1,1), (2,2), (4,1)},
%e A396285  {(1,1), (4,1), (1,4)}.
%t A396285 A396285[n_] := (Binomial[#, 3] + 2*Quotient[#, 3])/3 & [n^2];
%t A396285 Array[A396285, 35] (* _Paolo Xausa_, Jun 04 2026 *)
%K A396285 nonn
%O A396285 1,2
