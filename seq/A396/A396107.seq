%T A396107 29,140,25,143,22,151,19,153,12,162,317,472,315,150,323,146,324,137,
%U A396107 331,136,337,127,340,118,349,115,356,110,357,604,352,92,354,616,345,67
%N A396107 Recamán transform of the running sum of the decimal digits of Pi (A046974).
%C A396107 The 20 smallest numbers not occurring in the first million terms: 5, 9, 11, 21, 28, 31, 40, 41, 59, 61, 62, 64, 65, 68, 74, 76, 78, 79, 80, 81.
%H A396107 Ruud H.G. van Tol, <a href="/A396107/b396107.txt">Table of n, a(n) for n = 0..10000</a>
%o A396107 (PARI) first(nn)= localprec(nn+20); my(d=digits(Pi*10^nn\1), r=List(0), k=0, s=0, t=0); for(n=1, nn-1, k+=d[n]; s=bitor(s,1<<(t+=if(t<=k||bittest(s, t-k), k, -k))); listput(~r, t)); Vec(r);
%Y A396107 Cf. A005132, A046974, A064365.
%K A396107 nonn,base,easy,look,new
%O A396107 0,2
%A A396107 _Ruud H.G. van Tol_, May 17 2026
