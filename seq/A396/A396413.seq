%S A396413 1,1,0,1,1,0,1,2,4,0,1,3,10,22,0,1,4,18,65,140,0,1,5,28,135,480,969,0,
%T A396413 1,6,40,238,1134,3826,7084,0,1,7,54,380,2240,10215,32104,53820,0,1,8,
%U A396413 70,567,3960,22482,96552,279603,420732,0,1,9,88,805,6480,43795,236044,945660,2505336,3362260,0
%N A396413 Square array A(n,k), n>=0, k>=0, read by antidiagonals downwards, where A(n,k) = [x^n] F_k(x)/x and F_k(x) is the k-th iteration of x*G4(x) with G4(x) = 1 + x*G4(x)^4.
%H A396413 Wikipedia, <a href="https://en.wikipedia.org/wiki/Fuss%E2%80%93Catalan_number">Fuss-Catalan number</a>
%F A396413 G.f. of column k: (1/x) * Series_Reversion( H_k(x) ), where H_k(x) is the k-th iteration of x*(1 - x*G3(x)^2) with G3(x) = 1 + x*G3(x)^3.
%F A396413 A(n,k) = Sum_{0 = x_0 <= x_1 <= ... <= x_{k-1} <= x_k = n} Product_{j=0..k-1} (x_j + 1) * binomial(4*x_{j+1} - 3*x_j + 1,x_{j+1} - x_j)/(4*x_{j+1} - 3*x_j + 1).
%F A396413 A(n,0) = 0^n; A(n,k) = Sum_{j=0..n} (j+1) * binomial(4*n-3*j+1,n-j)/(4*n-3*j+1) * A(j,k-1) for k > 0.
%e A396413 Square array begins:
%e A396413   1,    1,     1,     1,      1,      1,      1, ...
%e A396413   0,    1,     2,     3,      4,      5,      6, ...
%e A396413   0,    4,    10,    18,     28,     40,     54, ...
%e A396413   0,   22,    65,   135,    238,    380,    567, ...
%e A396413   0,  140,   480,  1134,   2240,   3960,   6480, ...
%e A396413   0,  969,  3826, 10215,  22482,  43795,  78264, ...
%e A396413   0, 7084, 32104, 96552, 236044, 505252, 983556, ...
%e A396413   ...
%o A396413 (PARI)
%o A396413 a(n, k, p=4) = {
%o A396413   my(T=matrix(n+1, n+1, row, col, my(xr=row-1, xc=col-1); if(xc<xr, 0, (xr+1)*binomial(p*xc-(p-1)*xr+1, xc-xr)/(p*xc-(p-1)*xr+1))));
%o A396413   my(TK=T^k);
%o A396413   TK[1, n+1];
%o A396413 };
%Y A396413 Columns k=0..3 give A000007, A002293, A396416, A396417.
%Y A396413 Cf. A001764, A158825, A396412, A396588.
