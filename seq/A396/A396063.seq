%N A396063 E.g.f. A(x) satisfies A'(x) = 1/(1 - A(x)*A'(x))^2, with A(0)=0.
%F A396063 E.g.f. A(x) satisfies A'(x) = 1/(1 - A(x)*A'(x))^k, with A(0)=0.
%F A396063 Let R(x) = Series_Reversion( (1 - (1-2*(k+1)*x) * (1-x)^(2*k))/(2*(2*k+1)) ).
%F A396063 A(x) = R(x) * (1-R(x))^k.
%F A396063 For k > 0 and n > 1, k divides n! * [x^n] A(x).
%F A396063 From _Vaclav Kotesovec_, Jun 17 2026: (Start)
%F A396063 Recurrence: 97*a(n) = 10*(372*n - 1027)*a(n-1) - 20*(2670*n^2 - 17395*n + 28676)*a(n-2) + 20*(17000*n^3 - 191450*n^2 + 721220*n - 908733)*a(n-3) - 1296*(5*n - 23)*(5*n - 22)*(5*n - 21)*(5*n - 19)*a(n-4).
%F A396063 a(n) ~ 2^(n - 10/2) * 3^(4*n-2) * 5^(n - 3/2) * n^(n-2) / (exp(n) * 97^(n - 3/2)). (End)
%o A396063 (PARI) my(k=2, N=20, x='x+O('x^N), R=serreverse((1-(1-2*(k+1)*x)*(1-x)^(2*k))/(2*(2*k+1)))); Vec(serlaplace(R*(1-R)^k))
