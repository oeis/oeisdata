%I A396985 #8 Jun 17 2026 00:34:55
%S A396985 1,3,6,9,12,14,15,16,20,27,32,33,37,40,43,46,52,53,61,63,64,67,69,70,
%T A396985 71,75,84,85,87,98,101,106,108,116,121,122,130,136,137,139,142,158,
%U A396985 159,160,164,166,171,172,175,177,181,184,187,190,196,197,220,221,223,226,229,232,260,265,266,268
%N A396985 Numbers whose Fibonacci-Lucas and Lucas-Fibonacci representations have the same number of terms.
%C A396985 Numbers k such that A353655(k) = A353656(k).
%C A396985 Numbers k such that A353657(k) = 0.
%H A396985 Robert Israel, <a href="/A396985/b396985.txt">Table of n, a(n) for n = 1..10000</a>
%e A396985 a(3) = 6 is a term because the Fibonacci-Lucas representation 6 = 5 + 1 and the Lucas-Fibonacci representation 6 = 4 + 2 both have length 2.
%p A396985 Fibs:= [seq(combinat:-fibonacci(i),i=2..30)]:
%p A396985 Lucs:= [1,3,seq(Fibs[n+1]+Fibs[n-1],n=2..28)]:
%p A396985 f:= proc(n,t) local x,i; uses ListTools;
%p A396985   x:= n;
%p A396985   for i from 1 do
%p A396985     if i::t then x:= x - Fibs[BinaryPlace(Fibs,x+1)]
%p A396985     else x:= x - Lucs[BinaryPlace(Lucs,x+1)]
%p A396985     fi;
%p A396985     if x = 0 then return i fi;
%p A396985   od
%p A396985 end proc:
%p A396985 select(k -> f(k,odd) = f(k,even), [$1..300]);
%Y A396985 Cf. A353655, A353656, A353657.
%K A396985 nonn,new
%O A396985 1,2
%A A396985 _Robert Israel_, Jun 12 2026
