%T A396148 146,150,156,161,162,163,164,165,166,205,216,222,227,237,247,250,257,
%U A396148 261,267,272,273,274,275,276,277,305,316,327,333,338,348,350,358,361,368
%N A396148 Numbers reaching a fixed point in a single step of the Kaprekar mapping A151949.
%H A396148 Hugo Pfoertner, <a href="/A396148/b396148.txt">Table of n, a(n) for n = 1..10116</a> (terms 168..532 from Andrey Drozdov)
%t A396148 A396148Q[k_] := Equal @@ Rest[NestList[FromDigits[Reverse[#]] - FromDigits[#] & [Sort[IntegerDigits[#]]] &, k, 2]];
%t A396148 Select[Range[0, 500], A396148Q] (* _Paolo Xausa_, May 23 2026 *)
%o A396148 (PARI) is_a396148(n) = my(k(n)=fromdigits(vecsort(d=digits(n),,4)) - fromdigits(vecsort(d)), n1=k(n), n2=k(n1)); n1==n2
%o A396148 (Python)
%o A396148 def kaprekar(n): return int("".join(sorted(s:=str(n), reverse=True))) - int("".join(sorted(s)))
%o A396148 def ok(n): return kaprekar(m:=kaprekar(n)) == m
%o A396148 print([k for k in range(370) if ok(k)]) # _Michael S. Branicky_, May 24 2026
%Y A396148 Cf. A004185, A004186, A099009, A151949, A395936.
%K A396148 nonn,base,new
%O A396148 1,3
