%N A396307 Final terms of length-4 blocks in A280864.
%H A396307 Michael De Vlieger, <a href="/A396307/b396307.txt">Table of n, a(n) for n = 1..3398</a>
%e A396307 See A396305.
%t A396307 Block[{c, j, k, m, r, s, t, w, nn, rad},
%t A396307   nn = 3000; c[_] := False; r = 1; s = 1; t = {};
%t A396307   rad[n_] := rad[n] = Times @@ FactorInteger[n][[All, 1]];
%t A396307   Reap[ Do[w = GCD[r, s]; m = r/w; k = m;
%t A396307     While[Or[c[k], ! CoprimeQ[w, k] ], k += m]; c[k] = True;
%t A396307     s = r; r = rad[k];
%t A396307     If[CoprimeQ[s, r], If[Length[t] == 4, Sow[Last[t] ] ]; t = {k},
%t A396307     AppendTo[t, k] ], {i, nn}] ][[-1, 1]] ] (* _Michael De Vlieger_, Jun 16 2026 *)
