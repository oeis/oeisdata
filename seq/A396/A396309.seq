%I A396309 #16 Jun 02 2026 14:20:57
%S A396309 5,6,53,58,102,112,118,196,197,214,224,248,258,426,445,487,491,861,
%T A396309 885,1182,1299,1615,2082,2190,2465,2519,2679,3994,4035,4048,4210,4583,
%U A396309 5326,5506,5673,5690,6101,6237,6454,7778,7953,8062,8429,8585,9095,10194,11399,13015,14464,14723,16937,17790,18797
%N A396309 Integers x such that there exist two integers 0<y<=z such that sigma(x)^2*psi(x) = x^3 + y^3 + z^3.
%C A396309 The numbers x, y and z form a sigma^2*psi-cubic triple.
%H A396309 Charles R Greathouse IV, <a href="/A396309/b396309.txt">Table of n, a(n) for n = 1..447</a>
%H A396309 S. I. Dimitrov, <a href="https://hal.science/hal-05303937">On σψ-quadratic k-tuples and related generalizations</a>, hal-05303937, 2025.
%e A396309 (196, 245, 315) is such a triple because sigma(196)^2 * psi(196) = 399^2*336 = 196^3 + 245^3 + 315^3.
%o A396309 (PARI) dedekindpsi(n)=n*prod(p=factor(n)[,1],1+1/p)
%o A396309 isok(x)=
%o A396309 {
%o A396309   my(d = sigma(x)^2 * dedekindpsi(x) - x^3);
%o A396309   for(y = 1, sqrtnint(d, 3),
%o A396309     if((t = d - y^3) < y^3, break);
%o A396309     if(ispower(t, 3), return(1))
%o A396309   );
%o A396309   0
%o A396309 }
%o A396309 (PARI) T=thueinit('z^3+1);
%o A396309 isSumOfTwoCubes(n)=#select(v->min(v[1], v[2])>0, thue(T, n))>0
%o A396309 is(n, f=factor(n))=isSumOfTwoCubes(n*sigma(f)^2*sumdivmult(f, d, issquarefree(d)/d) - n^3) \\ _Charles R Greathouse IV_, May 22 2026
%Y A396309 Cf. A000203, A001615, A003072, A385325, A391290, A003325.
%K A396309 nonn,new
%O A396309 1,1
