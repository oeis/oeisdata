%S A396934 0,2,4,12,34,122,362,1130,3406,10506,31550,95260,285838,860244,
%T A396934 2581102,7746082,23227630,69761602,209332584,628052220,1884174908,
%U A396934 5652901362,16958154466,50873978096,152617806462,457866592352,1373595028524,4120789627226,12362289258892,37086728110804
%N A396934 Number of pairs (i,j) with 0 <= i,j < 2^n, i AND j = 0, and gcd(i,j) = 1.
%C A396934 The pairs with i AND j = 0 form the n-th step of the Sierpinski triangle (A047999); there are 3^n of them (A000244).
%C A396934 Equivalently, the number of odd binomial(m,k) with 0 <= k <= m < 2^n and gcd(k, m-k) = 1, since binomial(i+j,i) is odd iff i AND j = 0 (Kummer's theorem).
%C A396934 Note that gcd(0,k) = k, so the pairs (0,1) and (1,0) are counted.
%C A396934 Conjecture: a(n)/3^n converges to 16/(3*Pi^2) = 1 - A395134 = 0.5403796... .
%C A396934 From _Michael S. Branicky_, Jun 11 2026: (Start)
%C A396934 a(n) is even by symmetry, so it is enough to consider twice the sum for i < j.
%C A396934 Only j of opposite parity from i need be considered, else i AND j != 0.
%C A396934 Only i < 2^(n-1) need be considered else i AND j != 0 for i < j < 2^n. (End)
%e A396934 a(2) = 4: the pairs are (0,1), (1,0), (1,2), (2,1).
%o A396934 (Python)
%o A396934 from math import gcd
%o A396934 def a(n):
%o A396934     s = 1 << n
%o A396934     return sum(1 for i in range(s) for j in range(s) if i & j == 0 and gcd(i, j) == 1)
%o A396934 (Python)
%o A396934 from math import gcd
%o A396934 def a(n):
%o A396934     if n == 0: return 0
%o A396934     B1, B2 = 2**(n-1), 2**n
%o A396934     return 2*sum(1 for i in range(B1) for j in range(i+1, B2, 2) if i&j == 0 and gcd(i,j) == 1)
%o A396934 print([a(n) for n in range(15)]) # _Michael S. Branicky_, Jun 11 2026
%o A396934 (Python)
%o A396934 from math import gcd
%o A396934 from itertools import combinations
%o A396934 def A396934(n):
%o A396934     c, m = 0, 1<<n
%o A396934     for a in range(m):
%o A396934         s = bin(a)[:1:-1]
%o A396934         t = [1<<i for i in range(len(s)-1) if s[i]=='0']
%o A396934         for l in range(len(t)+1):
%o A396934             for k in combinations(t,l):
%o A396934                 if gcd(sum(k),a)==1:
%o A396934                     c += 2
%o A396934     return c # _Chai Wah Wu_, Jun 11 2026
%o A396934 (PARI) a(n) = sum(i=0, 2^n-1, sum(j=0, 2^n-1, (bitand(i,j)==0) && (gcd(i,j)==1))); \\ _Michel Marcus_, Jun 10 2026
