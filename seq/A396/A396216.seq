%S A396216 10340,41055,4360460,4890444,5206760,5692995,8553440,9912770,10494440,
%T A396216 14452760,14688960,15748425,29968224,32483660,34715450,35341460,
%U A396216 35680820,56332815,71819055,74486384,84155390,97964880,130883984,162596720,164862620,172622505,184107560,206108595,220342815
%N A396216 Smaller of a psi-betrothed (or psi-quasi-amicable) pair.
%C A396216 A pair (m, n) such that psi(m) = psi(n) = m + n + 1, with m < n, where psi = A001615. Each term in the sequence has opposite parity to its larger counterpart in A396217, which follows directly from psi(m) = psi(n) = m + n + 1 and the fact that psi(k) is even for k>=3. All terms are psi-abundant (A387893).
%e A396216 The pair (10340, 10395) is psi-betrothed because psi(10340) = psi(10395) = 20736 = 10340 + 10395 + 1.
%t A396216 f[n_] := n * Times @@ (1 + 1/Transpose[FactorInteger[n]][[1]]) - n - 1; seq[lim_] := Module[{s = {}, n}, Do[n = f[m]; If[n > m && f[n] == m, AppendTo[s, m]], {m, 1, lim}]; s]; seq[50000] (* _Amiram Eldar_, May 19 2026 *)
%Y A396216 Cf. A001615, A003502, A005276, A323329, A396217.
%K A396216 nonn
%O A396216 1,1
