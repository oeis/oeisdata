%U A396396 643419,949319,1346131,2017285,2937004,4283010,6272172,8950595,13315107,19026322,27857479
%N A396396 a(n) = r(n,n), where r(1,k)=f(k)=floor(k*c), r(n,k)=f(r(n-1,k)), c=sqrt(2).
%C A396396 a(n + 1)/a(n) approaches c erratically.
%t A396396 c = Sqrt[2]; f[k_] := f[k] = Floor[c*k];
%t A396396 r[1, k_] := f[k]; r[n_, k_] := r[n, k] = f[r[n - 1, k]];
%t A396396 Table[r[n, n], {n, 1, 100}]
%Y A396396 Cf. A002193, A396385, A396397, A396398.
%K A396396 nonn,new
%O A396396 1,2
%A A396396 _Clark Kimberling_, May 29 2026
