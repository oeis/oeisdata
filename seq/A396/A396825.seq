%S A396825 1,4,9,12,16,25,28,33,36,49,60,64,81,96,100,121,124,144,169,193,196,
%T A396825 225,228,256,288,289,324,336,361,385,400,420,441,484,529,576,625,676,
%U A396825 708,729,768,784,841,900,961,1024,1089,1152,1156,1216,1225,1296,1344,1369
%N A396825 Positive integers that don't occur in A397366.
%C A396825 The sequence complements the set of values in the linked table. The sequence contains all squares >= 1.
%H A396825 Ruud H.G. van Tol, <a href="/A396825/b396825.txt">Table of n, a(n) for n = 1..160</a>
%H A396825 Carl Pomerance and Andreas Weingartner, <a href="https://arxiv.org/abs/2511.16817">Exceptions to the Erdős-Straus-Schinzel conjecture</a>, arXiv:2511.16817 [math.NT], 2026.
%H A396825 Alan Swett, <a href="https://web.archive.org/web/20140826093525/http://math.uindy.edu/swett/other_form.htm">Alternative Calculation of S(n)</a>, 1999.
%H A396825 Alan Swett, <a href="https://web.archive.org/web/20140826084250/http://math.uindy.edu/swett/s_table.htm">Table of Values of S(n)</a>, 1999.
%F A396825 a(n) = {0, 1, 4, 9} (mod 12).
%o A396825 (PARI) first(nn, m=(nn\2+12)^3)= my(u=Map()); for(n=1, m, foreach((divisors(n^2)*-4)%(4*n-1), k, mapisdefined(u, k) || mapput(~u, k, 0))); [i|i<-[1..vecmax(Vec(u))], !mapisdefined(u, i)][1..nn]; \\ m is heuristic
