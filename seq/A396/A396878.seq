%U A396878 883,937,1039,1063,1123,1171,1231,1399,1459,1483,1543,1549,1597,1621,1723,1747,1789,1999,2143,2281,2389
%N A396878 Primes p such that the concatenation of p-1 and p is prime.
%C A396878 Except for 3, all terms == 1 (mod 6).
%C A396878 Prime p is a term if and only if p-1 is in A034591.
%H A396878 Robert Israel, <a href="/A396878/b396878.txt">Table of n, a(n) for n = 1..10000</a>
%e A396878 a(3) = 13 is a term because 13 and 1213 are prime.
%p A396878 tcat:= (a,b) -> a*10^(1+ilog10(b))+b:
%p A396878 select(t -> isprime(t) and isprime(tcat(t-1,t)), [3,seq(i,i=7..10000,6)]);
%t A396878 q[p_]:=PrimeQ[FromDigits[Join[IntegerDigits[p-1],IntegerDigits[p]]]];Select[Prime[Range[355]],q] (* _James C. McMahon_, Jun 13 2026 *)
%Y A396878 Cf. A034591.
%K A396878 nonn,base,changed
%O A396878 1,1
