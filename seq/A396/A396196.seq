%I A396196 #8 Jun 02 2026 19:01:46
%S A396196 1,1,0,1,2,1,2,2,1,2,3,3,1,1,1,1,2,1,1,1,3,1,2,1,1,2,1,1,1,2,1,2,1,3,
%T A396196 1,1,2,3,1,1,1,2,1,3,1,1,1,1,3,1,3,2,2,2,2,2,1,2,1,2,2,1,1,1,1,3,3,1,
%U A396196 1,3,2,2,2,2,1,1,1,2,1,2,1,3,1,1,2,3,1,3,1,2,1,3,1,1,2,3,3,2,2,1
%N A396196 The n-th digit of the n-th term of the Look-and-Say sequence (A005150), padded with 0 if the term has fewer than n digits.
%C A396196 The 0 padding is only needed for a(3) because the third Look-and-Say term is 21, which has a length of 2. For all n >= 4, the length of the n-th term grows exponentially according to Conway's constant and is strictly greater than n.
%D A396196 J. H. Conway, The Weird and Wonderful Chemistry of Audioactive Decay, Eureka, 46 (1986), 5-18.
%H A396196 Wikipedia, <a href="https://en.wikipedia.org/wiki/Look-and-say_sequence">Look-and-say sequence</a>
%e A396196 For n = 1, the 1st term of A005150 is 1. The 1st digit is 1, so a(1) = 1.
%e A396196 For n = 3, the 3rd term of A005150 is 21. Since it only has 2 digits, we pad with 0 to get the 3rd digit, so a(3) = 0.
%e A396196 For n = 6, the 6th term of A005150 is 312211. The 6th digit is 1, so a(6) = 1.
%e A396196 For n = 10, the 10th term of A005150 is 13211311123113112211. The 10th digit is 2, so a(10) = 2.
%o A396196 (Python)
%o A396196 # Optimized code: truncates terms to prevent exponential memory growth.
%o A396196 # Safe because a(n) depends only on the prefix of the (n-1)-th term.
%o A396196 def get_next_look_and_say_truncated(s, max_len):
%o A396196     result, i, chars_generated = [], 0, 0
%o A396196     while i < len(s) and chars_generated < max_len:
%o A396196         count = 1
%o A396196         while i + 1 < len(s) and s[i] == s[i+1]: i += 1; count += 1
%o A396196         chunk = f"{count}{s[i]}"
%o A396196         result.append(chunk); chars_generated += len(chunk); i += 1
%o A396196     return "".join(result)[:max_len]
%o A396196 def a(n):
%o A396196     current_term = "1"
%o A396196     for i in range(1, n + 1):
%o A396196         if i == n: return int(current_term[n-1]) if len(current_term) >= n else 0
%o A396196         current_term = get_next_look_and_say_truncated(current_term, n * 2)
%Y A396196 Cf. A005150 (Look and Say sequence).
%Y A396196 Cf. A005341 (Length of n-th term of A005150).
%Y A396196 Cf. A014715 (Conway's constant).
