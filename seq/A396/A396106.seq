%F A396106 a(n) = A151799(A069100(n+1)) for n > 1. - _Michael S. Branicky_, May 17 2026
%e A396106 a(2) = 103 since 101 is the 1st and 103 is the 2nd prime > 100.
%t A396106 a[n_] := NextPrime[10^n, n]; Array[a, 20] (* _Amiram Eldar_, May 17 2026 *)
%o A396106 (Python)
%o A396106 from sympy import nextprime
%o A396106 def a(n): return nextprime(10**n, ith=n)
%o A396106 print([a(n) for n in range(1, 21)]) # _Michael S. Branicky_, May 17 2026
