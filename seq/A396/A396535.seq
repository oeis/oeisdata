%S A396535 1,1,4,32,436,9012,262759,10270659,518275576,32795799470,
%T A396535 2542935515813,237105875108179,26173249067848883,3375679514676816347,
%U A396535 502993915142014441145,85749789537055013170801,16583584939893635319157502,3611142603347167151091560732
%N A396535 Number of labeled histories for rooted at-most-6-furcating trees with n leaves, if simultaneous branching events are allowed.
%H A396535 Emily H. Dickey and Noah A. Rosenberg, <a href="https://doi.org/10.1016/j.dam.2026.04.032">Labeled histories and maximally probable labeled topologies with multifurcation</a>, Discr. Appl. Math. 391 (2026), 192-203. See Table 2.
%t A396535 A[1] := 1;
%t A396535 A[n_] := n! Sum[(1/((2!)^x2 (x2!))) Sum[(1/((3!)^x3 (x3!))) Sum[(1/((4!)^x4 (x4!))) Sum[(1/((5!)^x5 (x5!))) Sum[(1/((6!)^x6 (x6!))) (1/(n - 2 x2 - 3 x3 - 4 x4 - 5 x5 - 6 x6)!)*A[n - x2 - 2 x3 - 3 x4 - 4 x5 - 5 x6], {x6, Max[Ceiling[(2 - 2 x2 - 3 x3 - 4 x4 - 5 x5)/6], 0], Floor[(n - 2 x2 - 3 x3 - 4 x4 - 5 x5)/6]}], {x5, 0, Floor[(n - 2 x2 - 3 x3 - 4 x4)/5]}], {x4, 0, Floor[(n - 2 x2 - 3 x3)/4]}], {x3, 0, Floor[(n - 2 x2)/3]}], {x2, 0, Floor[n/2]}];
%t A396535 Table[A[n], {n, 1, 14}]
%Y A396535 Cf. A317059 (2-furcating), A396088 (at-most-3-furcating), A396488 (at-most-4-furcating), A396512 (at-most-5-furcating), A393759 (non-simultaneous branching events only).
%K A396535 nonn
%O A396535 1,3
%A A396535 _Noah A Rosenberg_, May 28 2026
