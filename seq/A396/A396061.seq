%I A396061 #21 May 19 2026 23:55:32
%S A396061 12,13,102,103,112,113,122,1002,1003,1011,1012,1013,1021,1022,1031,
%T A396061 1102,1103,1112,1113,1121,1122,1202,1212,2012,2022,10002,10003,10011,
%U A396061 10012,10013,10021,10022,10031,10102,10103,10111,10112,10113,10121,10122,10202,10211,10212,10221
%N A396061 Numbers k such that k < reverse(k) and reverse(k^2) = reverse(k)^2.
%C A396061 The squares of these terms form a subset of A156316 where the squaring operation involves no arithmetic carries. Consequently, all terms consist exclusively of the digits {0, 1, 2, 3}. The k < reverse(k) constraint ensures palindromes and the larger halves of the reversed pairs are excluded.
%e A396061 a(1) = 12: 12 < 21, and 12^2 = 144. The reversal of 144 is 441, which is 21^2.
%e A396061 a(2) = 13: 13 < 31, and 13^2 = 169. The reversal of 169 is 961, which is 31^2.
%e A396061 33 is not in the sequence because while 33^2 = 1089 and its reversal 9801 = 99^2, the squaring involves an arithmetic carry (33=9, but 3030=900, and the middle terms sum to more than 10).
%p A396061 rev := n -> parse(StringTools:-Reverse(convert(n, string))):
%p A396061 select(n -> n < rev(n) and rev(n^2) = rev(n)^2, [$10..100000]);
%t A396061 Select[Range[100000], # < IntegerReverse[#] && IntegerReverse[#^2] == IntegerReverse[#]^2 &]
%o A396061 (C++)
%o A396061 #include <iostream>
%o A396061 using namespace std;
%o A396061 unsigned long long rev(unsigned long long n) {
%o A396061     unsigned long long ans = 0;
%o A396061     while (n > 0) {
%o A396061         ans *= 10;
%o A396061         ans += n % 10;
%o A396061         n /= 10;
%o A396061     }
%o A396061     return ans;
%o A396061 }
%o A396061 int main() {
%o A396061     for (unsigned long long i = 10; i < 100000; i++) {
%o A396061         unsigned long long r = rev(i);
%o A396061         if (i < r && rev(i * i) == r * r) {
%o A396061             cout << i << ", ";
%o A396061         }
%o A396061     }
%o A396061     return 0;
%o A396061 }
%o A396061 (PARI) rev(n) = fromdigits(Vecrev(digits(n))); \\ A004086
%o A396061 isok(k) = (k < rev(k)) && (rev(k^2) == rev(k)^2); \\ _Michel Marcus_, May 16 2026
%Y A396061 Cf. A004086, A035122, A156316, A033294, A129914.
%Y A396061 Subsequence of A061909.
%K A396061 nonn,base
