%I A396140 #11 May 18 2026 10:14:56
%S A396140 15552,77760,108864,171072,202176,264384,295488,357696,388800,451008,
%T A396140 482112,544320,575424,637632,668736,730944,762048,824256,855360,
%U A396140 917568,948672,1010880,1041984,1104192,1135296,1197504,1228608,1290816,1321920,1384128,1415232,1477440
%N A396140 Numbers whose sum of cubefull divisors is a cubefull number that is larger than 1.
%C A396140 If k is a term, and m is a cubefree number coprime to k, then k*m is also a term. The primitive terms in this sequence (A396141) are the cubefull terms.
%C A396140 The asymptotic density of this sequence is Sum_{n>=1} f(A396141(n)) = 0.00002126690552..., where f(n) = (1/(zeta(3)*n)) * Product_{prime p|n} (p^2/(p^2 + p + 1)).
%C A396140 The least odd term is a(4290506) = A396141(3) = 201745589625.
%H A396140 Amiram Eldar, <a href="/A396140/b396140.txt">Table of n, a(n) for n = 1..10000</a>
%e A396140 15552 is a term since A385005(15552) = 42592 = 2^5 * 11^3 is a cubefull number (A036966).
%t A396140 f[p_, e_] := (p^(e + 1) - 1)/(p - 1) - p - If[e > 1, p^2, 0]; s[1] = 1; s[k_] := Times @@ f @@@ FactorInteger[k]; q[k_] := AllTrue[FactorInteger[k][[;; , 2]], # > 2 &]; Select[Range[10^6], q[s[#]] &]
%o A396140 (PARI) s(k) = {my(f = factor(k)); prod(i = 1, #f~, (f[i, 1]^(f[i, 2]+1) - 1)/(f[i, 1] - 1) - f[i, 1] - if(f[i, 2] > 1, f[i, 1]^2)); }
%o A396140 isok(k) = {my(s1 = s(k)); s1 > 1 && vecmin(factor(s1)[, 2]) > 2; }
%Y A396140 A396141 is a subsequence.
%Y A396140 Cf. A002117, A004709, A036966, A376204, A385005.
%K A396140 nonn,new
%O A396140 1,1
%A A396140 _Amiram Eldar_, May 18 2026
