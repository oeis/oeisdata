%I A396351 #23 Jun 28 2026 09:50:20
%S A396351 0,1,0,4,2,0,10,64,3,0,20,831,240,4,0,35,6760,9641,624,5,0,56,40748,
%T A396351 244322,50018,1340,6,0,84,198496,4401281,2703376,183940,2544,7,0,120,
%U A396351 823058,60910912,108412740,17196520,549145,4424,8,0,165,3005484,683216362,3396389392,1223521735,80513160,1416331,7200,9,0
%N A396351 Square array read by antidiagonals: A(n,m) is the number of unsatisfiable 3-SAT formulas with n variables and m clauses in the multiset clause model, n >= 1, m >= 1.
%C A396351 A clause is a multiset of 3 literals chosen from {x_1, ..., x_n, not x_1, ..., not x_n}; repeated literals inside a clause are allowed. A formula is a multiset of m such clauses, so repeated clauses are also allowed.
%C A396351 This is the multiset clause model. It differs from the common random 3-SAT model in which clauses usually contain three distinct variables and tautological clauses are excluded.
%C A396351 The first row is A(1,m) = binomial(m+1,3). The first column is A(n,1)=0. The second column is A(n,2)=n.
%H A396351 Stephen A. Cook, <a href="https://doi.org/10.1145/800157.805047">The complexity of theorem-proving procedures</a>, Proceedings of the Third Annual ACM Symposium on Theory of Computing, 1971, 151-158.
%H A396351 Jian Ding, Allan Sly, and Nike Sun, <a href="https://doi.org/10.4007/annals.2022.196.1.1">Proof of the satisfiability conjecture for large k</a>, Annals of Mathematics 196 (2022), 1-388.
%H A396351 Marc Mézard, Giorgio Parisi, and Riccardo Zecchina, <a href="https://doi.org/10.1126/science.1073287">Analytic and algorithmic solution of random satisfiability problems</a>, Science 297 (2002), 812-815.
%F A396351 A(n,1) = 0.
%F A396351 A(n,2) = n.
%F A396351 A(1,m) = binomial(m+1,3).
%F A396351 A(n,3) = 2*n*(2*n^3 + 3*n^2 + 19*n - 18)/3.
%e A396351 Array begins:
%e A396351    m  | 1, 2,   3,     4,       5,         6, ...
%e A396351  -----------------------------------------------
%e A396351  n = 1| 0, 1,   4,    10,      20,        35, ...
%e A396351  n = 2| 0, 2,  64,   831,    6760,     40748, ...
%e A396351  n = 3| 0, 3, 240,  9641,  244322,   4401281, ...
%e A396351  n = 4| 0, 4, 624, 50018, 2703376, 108412740, ...
%o A396351 (Python)
%o A396351 from itertools import combinations_with_replacement
%o A396351 def clauses(n):
%o A396351     lits = list(range(-n, 0)) + list(range(1, n+1))
%o A396351     return list(combinations_with_replacement(lits, 3))
%o A396351 def lit_value(lit, a):
%o A396351     v = abs(lit)-1
%o A396351     val = (a >> v) & 1
%o A396351     return val if lit > 0 else 1-val
%o A396351 def unsat(n, formula):
%o A396351     for a in range(1 << n):
%o A396351         if all(any(lit_value(lit, a) for lit in clause) for clause in formula):
%o A396351             return False
%o A396351     return True
%o A396351 def A(n, m):
%o A396351     cl = clauses(n)
%o A396351     s = 0
%o A396351     for idxs in combinations_with_replacement(range(len(cl)), m):
%o A396351         if unsat(n, [cl[i] for i in idxs]):
%o A396351             s += 1
%o A396351     return s
%o A396351 def table_by_antidiagonals(N):
%o A396351     out = []
%o A396351     for s in range(2, N+2):
%o A396351         for n in range(1, s):
%o A396351             m = s-n
%o A396351             out.append(A(n, m))
%o A396351     return out
%o A396351 print(table_by_antidiagonals(10))
%Y A396351 Cf. A000027, A396353, A396354.
%K A396351 nonn,tabl,hard
