%I A396264 #16 May 22 2026 05:52:02
%S A396264 60,728,60512
%N A396264 Numbers j such that Sum_{d|j, d < j} (-1)^d * d is equal to j.
%C A396264 Also includes 1099176108032, 288229001763749888.
%C A396264 Numbers k such that A058344(k) = -k.
%C A396264 a(4) > 10^10. - _Amiram Eldar_, May 22 2026
%e A396264 60 is a term since 60 has 11 proper divisors {1, 2, 3, 4, 5, 6, 10, 12, 15, 20, 30} and -1 + 2 - 3 + 4 - 5 + 6 + 10 + 12 - 15 + 20 + 30 = 60.
%t A396264 f[p_, e_] := If[p == 2, 3 - 2^(e + 1), (p^(e + 1) - 1)/(p - 1)]; q[1] = False; q[k_] := Times @@ f @@@ FactorInteger[k] == k*(-(-1)^k - 1); Select[Range[10^5], q] (* _Amiram Eldar_, May 20 2026 *)
%o A396264 (PARI) isok(k) = {my(f = factor(k)); prod(i = 1, #f~, if(f[i,1] == 2, 3 - 2^(f[i,2] + 1), (f[i,1]^(f[i,2] + 1) - 1)/(f[i,1] - 1))) == k*(-(-1)^k - 1);} \\ _Amiram Eldar_, May 20 2026
