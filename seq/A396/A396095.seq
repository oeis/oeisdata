%S A396095 1,1,4,19,110,750,5880,52080,514080,5594400,66528000,858211200,
%T A396095 11935123200,177989011200,2833294464000,47948060160000,
%U A396095 859577951232000,16272699835392000,324386934423552000,6791851439493120000,149015248000819200000,3418835546990223360000,81864719673135759360000
%N A396095 O.g.f. Sum_{n>=0} n^n*x^n/(1 + n*x)^(n-1).
%C A396095 Compare to the following related identities.
%C A396095 (C.1) Sum_{n>=0} n^n*x^n/(1 + n*x)^(n+2) = 1/(1-x).
%C A396095 (C.2) Sum_{n>=0} n^n*x^n/(1 + n*x)^(n+1) = Sum_{n>=0} n!*x^n.
%C A396095 (C.3) Sum_{n>=0} n^n*x^n/(1 + n*x)^n = 1 + Sum_{n>=1} (n+1)/2 * n!*x^n.
%F A396095 O.g.f.: 1+x + Sum_{n>=2} (n+1)*(3*n + 10)/24 * n!*x^n.
%F A396095 E.g.f.: 1+x + x^2*(24 - 34*x + 13*x^2) / (12*(1-x)^3).
%e A396095 O.g.f.: A(x) = 1 + x + 4*x^2 + 19*x^3 + 110*x^4 + 750*x^5 + 5880*x^6 + 52080*x^7 + 514080*x^8 + ...
%e A396095 where
%e A396095 A(x) = 1 + x + 2^2*x^2/(1+2*x) + 3^3*x^3/(1+3*x)^2 + 4^4*x^4/(1+4*x)^3 + 5^5*x^5/(1+5*x)^4 + ... + n^n*x^n/(1 + n*x)^(n-1) + ...
%e A396095 Also,
%e A396095 A(x) = 1 + x + (3*16/24)*2!*x^2 + (4*19/24)*3!*x^3 + (5*22/24)*4!*x^4 + (6*25/24)*5!*x^5 + ... + (n+1)*(3*n+10)/24 * n!*x^n + ...
%o A396095 (PARI) \\ By definition
%o A396095 {a(n) = my(A = sum(m=0,n, m^m*x^m/(1 + m*x +x*O(x^n))^(m-1))); polcoef(GF=A,n)}
%o A396095 {upto(n) = a(n); Vec(GF)}
%o A396095 upto(25)
%o A396095 (PARI) \\ Formula for terms
%o A396095 {a(n) = if(n<2,1, (n+1)!*(3*n + 10)/24)}
%o A396095 for(n=0,25,print1(a(n),", "))
%K A396095 nonn
%O A396095 0,3
%A A396095 _Paul D. Hanna_, Jun 04 2026
