%U A396391 7366966,12237813,20633238,34217321,57543098,96631267,159877253,267914295,448424788,740496901
%N A396391 a(n) = r(n,n), where r(1,k)=f(k)=ceiling(k*c), r(n,k)=f(r(n-1,k)), c=golden ratio.
%C A396391 a(n + 1)/a(n) approaches c erratically.
%t A396391 c = GoldenRatio; f[k_] := f[k] = Ceiling[c*k];
%t A396391 r[1, k_] := f[k]; r[n_, k_] := r[n, k] = f[r[n - 1, k]];
%t A396391 Table[r[n, n], {n, 1, 100}]
%Y A396391 Cf. A001622, A396385, A396390, A396392, A396393.
%K A396391 nonn,new
%O A396391 1,1
