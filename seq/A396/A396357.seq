%e A396357      /    /    /          \    \    \
%e A396357    84   42   26   8---6    20   40   56
%e A396357   /    /    /    /      \    \    \    \
%e A396357  49   7   28    10   2---4   18   38   54
%e A396357   \    \    \    \          /    /    /
