%I A396378 #18 Jun 04 2026 16:19:02
%S A396378 1,2,3,4,6,6,8,8,12,10,12,12,15,15,15,16,18,18,24,24,21,24,24,24,30,
%T A396378 32,28,28,30,30,36,36,36,40,40,36,40,40,40,40,48,48,48,48,45,48,48,48,
%U A396378 56,50,54,60,60,60,60,56,60,60,60,60,63,63,63,64,72,72,72,72,72,70,72,72
%N A396378 Smallest m belonging to {n, n+1, n+2, ..., n+A396377(n)} that divides the product of the other integers.
%C A396378 After problem proposed by Paul Erdős (see link).
%H A396378 Paul Erdős, <a href="https://combinatorica.hu/~p_erdos/1963-14.pdf">Quelques problèmes de Théorie des Nombres</a>, Monographies de l'Enseignement Mathématique, No. 6, pp. 81-135, L'Enseignement Mathématique, Université, Geneva, 1963, Problem 15, p. 90.
%F A396378 a(p) = a(p+1) for p >= 5.
%F A396378 Fixed points are in A396379.
%e A396378 A396377(3) = 3 because in the set (3, 4, 5, 6), we have 3 | 4*5*6, then 4 does not divide 3*5*6, 5 does not divide 3*4*6 and 6 | 3*4*5. As 3 < 6, a(3) = 3.
%e A396378 A396377(9) = 5 because in the set (9, 10, 11, 12, 13, 14), we have 12 | 9*10*11*13*14, and 12 is the only integer belonging to (9, 10, 11, 12, 13, 14) that divides the product of the other integers, so a(9) = 12.
%p A396378 a := proc(n)
%p A396378 local k, L, i, j, t, g;
%p A396378 for k from 1 do
%p A396378     L := [seq(n+r, r=0..k)];
%p A396378     for i from 1 to k+1 do
%p A396378         t := L[i];
%p A396378         for j from 1 to k+1 do
%p A396378             if j <> i then
%p A396378                 g := gcd(t, L[j]);
%p A396378                 t := iquo(t, g);
%p A396378             end if;
%p A396378         end do;
%p A396378         if t = 1 then
%p A396378             return L[i];
%p A396378         end if;
%p A396378      end do;
%p A396378 end do;
%p A396378 end proc;
%p A396378 seq(a(n), n=1..100);
%o A396378 (PARI) isok(k, n) = my(v=vector(k+1, i, n+i-1), P=vecprod(v)); for (i=1, k+1, if (denominator(P/v[i]^2) == 1, return(i)));
%o A396378 a(n) = my(k=1, j); while (!(j=isok(k, n)), k++); n+j-1; \\ _Michel Marcus_, May 28 2026
%Y A396378 Cf. A396377, A396379.
%K A396378 nonn,new
%O A396378 1,2
%A A396378 _Bernard Schott_, May 24 2026
