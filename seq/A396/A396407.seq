%S A396407 5,6,24,53,58,60,102,118,197,214,216,240,258,426,445,487,491,600,668,
%T A396407 696,861,885,1182,1299,1615,1792,2082,2190,2465,2519,2679,3948,3994,
%U A396407 4035,4210,4583,4704,5326,5506,5673,5690,6101,6454,7778,7953,8062,8429,8585,8588,9095,10194,11399,12288,12975,13015
%N A396407 Integers x such that there exist two integers 0<y<=z such that sigma(x)*psi(x)^2 = x^3 + y^3 + z^3.
%C A396407 The numbers x, y and z form a sigma*psi^2-cubic triple.
%H A396407 S. I. Dimitrov, <a href="https://hal.science/hal-05303937">On σψ-quadratic k-tuples and related generalizations</a>, hal-05303937, 2025.
%e A396407 (60, 45, 147) is such a triple because sigma(60) * psi(60)^2 = 168 * 144^2 = 60^3 + 45^3 + 147^3.
%o A396407 (PARI)
%o A396407 dedekindpsi(n)=
%o A396407 {
%o A396407   my(f = factor(n)[,1]);
%o A396407   n * prod(i = 1, #f, 1 + 1/f[i])
%o A396407 }
%o A396407 isok(x)=
%o A396407 {
%o A396407   my(d = sigma(x) * dedekindpsi(x)^2 - x^3);
%o A396407   for(y = 1, sqrtnint(d, 3),
%o A396407     if((t = d - y^3) < y^3, break);
%o A396407     if(ispower(t, 3), return(1))
%o A396407   );
%o A396407   0
%o A396407 }
%Y A396407 Cf. A000203, A001615, A003072, A385325, A391290, A396309.
%K A396407 nonn
%O A396407 1,1
%A A396407 _S. I. Dimitrov_, May 24 2026
