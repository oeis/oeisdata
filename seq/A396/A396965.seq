%U A396965 163306868988824078336,25621879112031299758080,4524060645635205169643520,892453349895680565864595456,195425578879660458241000538112
%N A396965 E.g.f. A(x) satisfies A(x) = 1 + x * A(x * exp(2*x)).
%F A396965 a(0) = 1; a(n) = n * Sum_{k=0..n-1} (2*k)^(n-k-1) * binomial(n-1,k) * a(k).
%e A396965 A(x)         = 1 + x + x^2 + 3*x^3 + 9*x^4 + 109/3*x^5 + 521/3*x^6 + ...
%e A396965 A(x * exp(2*x)) =  1 + x   + 3*x^2 + 9*x^3 + 109/3*x^4 + 521/3*x^5 + ...
%o A396965 (PARI) a_vector(n, s=2, t=0) = my(v=vector(n+1)); v[1]=1; for(i=1, n, v[i+1]=i*sum(k=0, i-1, (s*k+t)^(i-k-1)*binomial(i-1, k)*v[k+1])); v;
%Y A396965 Cf. A000142, A395666.
%Y A396965 Cf. A397858.
%K A396965 nonn,new
%O A396965 0,3
