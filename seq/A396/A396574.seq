%S A396574 1,2,3,8,5,72,7,32,27,400,11,864,13,784,675,128,17,2592,19,1600,1323,
%T A396574 3872,23,3456,125,5408,243,3136,29,324000,31,512,9801,18496,6125,
%U A396574 31104,37,23104,13689,32000,41,254016,43,15488,30375,33856,47,41472,343,40000
%N A396574 a(n) is the smallest number k such that n divides binomial(k,m) for 1 <= m <= n-1.
%C A396574 a(n) is the smallest number k such that (I-B)^k == I (mod n), where I and B are the n X n identity matrix and lower shift matrix, respectively.
%F A396574 a(n) = n * Product_{prime p | n} p^floor(log_p(n-1)), n > 1.
%e A396574 For n = 4, binomial(8,1) = 8, binomial(8,2) = 28 and binomial(8,3) = 56 are all multiples of 4, and 8 is the smallest such number, so a(4) = 8.
%o A396574 (PARI) a(n)=if(n<2, 1, n*prod(i=1, #f=factor(n)[,1], f[i]^logint(n-1, f[i])));
%Y A396574 Cf. A007318.
