%T A396012 136,155,170,191,209,233,253,280,303,333,359,392,421,458,490,530,566,
%U A396012 610,649,697,740,792,839,895,946,1007,1062,1127,1187,1257,1321,1396,1465,1545,1619,1704,1783
%N A396012 Number of 3's in the partitions of n into exactly 5 parts.
%H A396012 <a href="/index/Par#part">Index entries for sequences related to partitions</a>
%H A396012 <a href="/index/Rec#order_10">Index entries for linear recurrences with constant coefficients</a>, signature (1,1,0,0,-2,0,0,1,1,-1).
%F A396012 G.f.: x^5 * Sum_{j=1..5} x^(2*j) / Product_{k=1..5-j} (1 - x^k).
%F A396012 a(n) = a(n-1) + a(n-2) - 2*a(n-5) + a(n-8) + a(n-9) - a(n-10) for n > 25.
%o A396012 (PARI) my(N=70, x='x+O('x^N)); concat([0, 0, 0, 0, 0, 0, 0], Vec(x^5*sum(j=1, 5, x^(2*j)/prod(k=1, 5-j, 1-x^k))))
%Y A396012 Cf. A394873, A396011.
%Y A396012 Cf. A026811.
%K A396012 nonn,easy,new
%O A396012 0,10
