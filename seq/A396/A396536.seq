%I A396536 #8 Jun 03 2026 19:25:24
%S A396536 1,9,18,53,45,65,78,96,120,171,204
%N A396536 a(n) is the smallest number k such that k^n is the sum of n^2 distinct positive n-th powers.
%e A396536 1^1 = 1^1;
%e A396536 9^2 = 6^2+5^2+4^2+2^2;
%e A396536 18^3 = 1^3+2^3+4^3+5^3+6^3+7^3+10^3+11^3+14^3;
%e A396536 53^4 = 40^4+36^4+34^4+32^4+30^4+20^4+18^4+16^4+15^4+14^4+12^4+10^4+8^4+6^4+4^4+2^4;
%e A396536 45^5 = 34^5+32^5+31^5+30^5+29^5+26^5+23^5+21^5+20^5+18^5+17^5+16^5+15^5+14^5+13^5+12^5+10^5+9^5+8^5+7^5+6^5+5^5+4^5+3^5+2^5;
%e A396536 ...
%t A396536 a[n_] := FirstCase[Range[n, 80], k_ /; Length[Select[IntegerPartitions[k^n, {n^2}, Range[k]^n], DuplicateFreeQ]] > 0]; Array[a, 5]
%Y A396536 Cf. A000217, A018935, A130012, A130022, A394979, A393280, A395180, A394259, A395432, A007666, A395519.
%K A396536 nonn,more,new
%O A396536 1,2
