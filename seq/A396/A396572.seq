%S A396572 2,3,2,5,4,4,8,9,8,8,32,8,64,16,16,17,16,16,512,16,64,64,2048,16,1024,
%T A396572 128,512,32,16384,32,32,33,32,32,4096,32,87382,1024,4096,32,1024,128,
%U A396572 128,128,4096,4096,8388608,32,2097152,2048,256,256,67108864,1024,1048576,64,512,32768,536870912
%N A396572 Number of distinct states before repetition for a circular array of n distinct elements under repeated adjacent XOR operations.
%C A396572 You have a sequence of nodes in a closed loop, with numbers at the vertices, say A,B,C that form the loop AB,BC,CA (let's called this layer 0). Perform XOR (^) on each connection so A XOR B, B XOR C, C XOR A results in a new layer (layer 1): ['A^B', 'B^C', 'A^C']. If you then repeat this and use XOR on layer 1 you get ['A^B^B^C', 'B^C^A^C', 'A^C^A^B'] which simplifies to ['A^C', 'B^A', 'C^B'] which is the same as layer 1, but just a different order. So a loop of 3 number (3 vertices), a triangle, has two unique layers, the original [A, B, C] and layer 1 ['A^B', 'B^C', 'A^C']. If you try this for closed loops with 4 vertices or 5, etc you get a different number of unique layers (as shown in the sequence) before the layers start repeating. Interesting they repeat in a cyclic fashion. For example for 5 vertices there are 4 unique layers (layers 0 to 3). Layer 4 is a repeat of layer 1 (in a different order) and layer 5 is repeat of layer 2, etc.
%F A396572 a(n) = A006519(n) + A085587(n).
%o A396572 (Python)
%o A396572 # Simulation
%o A396572 def next_layer(layer):
%o A396572     n = len(layer)
%o A396572     return tuple(
%o A396572         layer[i] ^ layer[(i + 1) % n]
%o A396572         for i in range(n)
%o A396572     )
%o A396572 def canonical_rotation(seq):
%o A396572     n = len(seq)
%o A396572     return min(
%o A396572         seq[i:] + seq[:i]
%o A396572         for i in range(n)
%o A396572     )
%o A396572 def a(n, max_layers=None):
%o A396572     # Each vertex is represented as one bit.
%o A396572     layer = tuple(1 << i for i in range(n))
%o A396572     seen = set()
%o A396572     if max_layers is None:
%o A396572         # Safe upper bound for small/medium n.
%o A396572         # The state space is finite, so the process must eventually cycle.
%o A396572         max_layers = (1 << n) + 1
%o A396572     for _ in range(max_layers):
%o A396572         key = canonical_rotation(layer)
%o A396572         if key in seen:
%o A396572             return len(seen)
%o A396572         seen.add(key)
%o A396572         layer = next_layer(layer)
%o A396572     raise RuntimeError("Cycle not found. Increase max_layers.")
%o A396572 print([a(n) for n in range(1, 47)])
%Y A396572 Cf. A006519, A085587.
%K A396572 nonn,new
%O A396572 1,1
