%T A396513 8,58,4,2,64,6,68,10,9,74,76,3,20,82,12,86,88,6,92,94,12,14,25,6,104,
%U A396513 106,36,11,16,38,116,118,5,122,4,2,128,130,12,134,136,6,20,142,18,146
%N A396513 a(n) is the minimum integer k such that rad(k)=rad(k+2n), where rad(x) is the squarefree kernel of x (A007947).
%C A396513 Note that the equation rad(k)=rad(k+n) has no solutions for odd n. Thus, parameterizing the difference as 2n is the natural formulation.
%C A396513 The existence of at least one solution for any n is guaranteed because k=2n always satisfies the condition. Thus, a(n)<=2n.
%C A396513 The prime factors of k must be a subset of the prime factors of 2n.
%H A396513 Banri Ogawa, <a href="/A396513/b396513.txt">Table of n, a(n) for n = 1..10000</a>
%e A396513 For n=10, rad(k)=rad(k+20). The minimum k satisfying this is a(10)=5 (rad(5)=rad(5+20)=5).
%t A396513 a[n_]:=Module[{k=1},Until[Times@@First/@FactorInteger@k==Times@@First/@FactorInteger@(k+2n),k++];k];Array[a,73] (* _James C. McMahon_, Jun 01 2026 *)
%o A396513 (Python)
%o A396513 from math import prod
%o A396513 from sympy import primefactors
%o A396513 def a(n): return next(k for k in range(1, 2*n+1) if prod(primefactors(k)) == prod(primefactors(k+2*n)))
%o A396513 (PARI) rad(n) = factorback(factorint(n)[, 1]); \\ A007947
%o A396513 a(n) = my(k=1); while(rad(k+2*n) != rad(k), k++); k; \\ _Michel Marcus_, May 28 2026
%Y A396513 Cf. A007947, A396510 (maximum k).
%K A396513 nonn
%O A396513 1,1
%A A396513 _Banri Ogawa_, May 28 2026
