%S A396096 1,6,-36,432,-6480,95904,-1461888,19346688,-143140608,-2659392000,
%T A396096 168811485696,-5147102610432,110998948451328,-1718388296054784,
%U A396096 10179494999617536,625318909680549888,-26211606164702650368,-103120012972030574592,35053137072549006114816,527714015153534702714880
%N A396096 G.f. A(x) satisfies: A(A(x)) - A(A(-x)) = 2*x and A(A(A(x))) + A(A(A(-x))) = 36*x^2.
%H A396096 Paul D. Hanna, <a href="/A396096/b396096.txt">Table of n, a(n) for n = 1..300</a>
%e A396096 G.f.: A(x) = x + 6*x^2 - 36*x^3 + 432*x^4 - 6480*x^5 + 95904*x^6 - 1461888*x^7 + 19346688*x^8 - 143140608*x^9 - 2659392000*x^10 + ...
%e A396096 RELATED SERIES.
%e A396096 The second iteration of g.f. A(x) begins
%e A396096 A(A(x)) = x + 12*x^2 - 18144*x^6 - 31104*x^8 + 569949696*x^10 + 109544555520*x^12 - 340554653779968*x^14 + 485740533814124544*x^16 + ...
%e A396096 where A(A(x)) - A(A(-x)) = 2*x.
%e A396096 The third iteration of g.f. A(x) begins
%e A396096 A(A(A(x))) = x + 18*x^2 + 108*x^3 - 1296*x^5 - 1119744*x^7 - 48708864*x^9 + 73086810624*x^11 + 20777931592704*x^13 - 35198553684455424*x^15 + ...
%e A396096 where A(A(A(x))) + A(A(A(-x))) = 36*x^2.
%o A396096 (PARI) \\ Routine returns the n-th iteration of F
%o A396096 {IT(n,F) = my(G=x); for(i=1,n, G = subst(F,x,G));G}
%o A396096 \\ Calculate and print the terms
%o A396096 {a(n) = my(V=[0,1,6],A); for(i=1,n, V = concat(V,0); A = Ser(V); if(#V%2==0,
%o A396096 V[#V] = -polcoef(IT(2,A) - subst(IT(2,A),x,-x),#V-1)/4,
%o A396096 V[#V] = -polcoef(IT(3,A) + subst(IT(3,A),x,-x),#V-1)/6) ); GF=A +x*O(x^n); V[n+1]}
%o A396096 {upto(n) = a(n); Vec(GF)}
%o A396096 upto(20)
%Y A396096 Cf. A196868.
%K A396096 sign
