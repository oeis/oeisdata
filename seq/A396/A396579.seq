%S A396579 0,1,4,9,10,11,14,16,19,20,21,24,25,29,30,31,34,36,39,40,41,44,49,50,
%T A396579 51,54,59,60,61,64,69,70,71,74,79,80,81,84,89,90,91,94,99,100,101,104,
%U A396579 109,110,111,114,116,119,120,121,124,125,129,130,131,134,136,139,140
%N A396579 Nonnegative integers that contain a square as a suffix.
%C A396579 The asymptotic density of this sequence is Sum_{k>0} A396618(k)/10^k.
%F A396579 a(n) ~ n/(Sum_{k>0} A396618(k)/10^k).
%t A396579 kmax=140; a={0}; For[k=0, k<=kmax, k++, If[AnyTrue[Table[Sqrt[IntegerReverse[ Floor[IntegerReverse[k]/10^i]]],{i,0,IntegerLength[k]-1}], IntegerQ], AppendTo[a,k]]]; a
