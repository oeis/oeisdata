%U A396589 435671054213077890372,40221240442162456568093,3989128727408613057955584,423028149715245312804772097
%N A396589 Expansion of e.g.f. F_2(x)/x and F_k(x) is the k-th iteration of x*G(x) with G(x) = exp(x*G(x)^2).
%F A396589 E.g.f.: (1/x) * Series_Reversion( H_2(x) ), where H_k(x) is the k-th iterate of U(x)*exp(-2*U(x)) and U(x) = -LambertW(-x).
%F A396589 a(n) = Sum_{k=0..n} (k+1) * (2*k+1)^(k-1) * (2*n-k+1)^(n-k-1) * binomial(n,k).
%t A396589 a[n_]:=Sum[(k+1) * (2*k+1)^(k-1) * (2*n-k+1)^(n-k-1) * Binomial[n,k],{k,0,n}]; Array[a,18,0] (* _Stefano Spezia_, May 30 2026 *)
%o A396589 (PARI)
%o A396589 lista(nn, k=2, p=2, s=1, r=1) = {
%o A396589   my(T=matrix(nn+1, nn+1, row, col, my(xr=row-1, xc=col-1); if(xc<xr, 0, (s*xr+r)*(p*xc-(p-s)*xr+r)^(xc-xr-1)*binomial(xc, xr))));
%o A396589   my(TK=T^k);
%o A396589   TK[1, ];
%o A396589 };
%Y A396589 Column k=2 of A396499.
%Y A396589 Cf. A101878, A396590, A396592.
%K A396589 nonn,new
