%I A396843 #7 Jul 03 2026 11:36:01
%S A396843 1,3,15,117,975,8631,79839,763209,7477701,74700315,758027205,
%T A396843 7792075341,80968633731,849122117991,8975430108207,95526419313969,
%U A396843 1022842349889807,11010529561615155,119088263248757523,1293532210166103045,14104280554140799413,154324033517611352655,1693907612722203671673
%N A396843 G.f. A(x) satisfies A( x*A(x) - 3*x*A(x)^2 ) = x^2.
%C A396843 Conjecture: all terms are odd.
%C A396843 Conjecture: for n > 3, a(n) == 1 (mod 9) iff n is of the form 4^k+1, otherwise a(n) is divisible by 9.
%H A396843 Paul D. Hanna, <a href="/A396843/b396843.txt">Table of n, a(n) for n = 1..500</a>
%F A396843 G.f. A(x) = Sum_{n>=1} a(n)*x^n, along with B(x) where B(A(x)) = x, satisfies the following formulas.
%F A396843 (1) B(x) = B(B(x)^2) / (x - 3*x^2).
%F A396843 (2) B(x^2) = x*A(x) - 3*x*A(x)^2.
%F A396843 (3) A(x) - 3*A(x)^2 is an odd function.
%F A396843 (4) A(x) = (1 - sqrt(1 - 12*B(x^2)/x)) / 6.
%F A396843 (5) A(x) = (1/3)*C( 3*B(x^2)/x ), where C(x) = x + C(x)^2 is a g.f. of the Catalan numbers A000108.
%F A396843 The radius of convergence r satisfies r^2 = A(r/12), A(r) = 1/6, and A(-r) = -(sqrt(2) - 1)/6 where r = 0.0851744830835713558952639250672135224689205067420655...
%e A396843 G.f.: A(x) = x + 3*x^2 + 15*x^3 + 117*x^4 + 975*x^5 + 8631*x^6 + 79839*x^7 + 763209*x^8 + 7477701*x^9 + 74700315*x^10 + 758027205*x^11 + ...
%e A396843 such that A( x*A(x) - 3*x*A(x)^2 ) = x^2
%e A396843 where
%e A396843 A(x)^2 = x^2 + 6*x^3 + 39*x^4 + 324*x^5 + 2877*x^6 + 26622*x^7 + 254403*x^8 + 2492532*x^9 + 24900105*x^10 + ...
%e A396843 and
%e A396843 A(x) - 3*A(x)^2 = x - 3*x^3 + 3*x^5 - 27*x^7 + 105*x^9 - 441*x^11 + 2439*x^13 - 12339*x^15 + 66171*x^17 - 369927*x^19 + ...
%e A396843 which is an odd function.
%e A396843 Compare with B(x), the series reversion of A(x), A(B(x)) = x:
%e A396843 B(x) = x - 3*x^2 + 3*x^3 - 27*x^4 + 105*x^5 - 441*x^6 + 2439*x^7 - 12339*x^8 + 66171*x^9 - 369927*x^10 + 2049849*x^11 - 11629629*x^12 + ...
%e A396843 which satisfies: B(B(x)^2) = (x - 3*x^2)*B(x).
%e A396843 SPECIFIC VALUES.
%e A396843 A(1/12) = 0.14268897893964261642826150469332250731789471498889...
%e A396843 where 1/12^2 = A( (1/12)*(A(1/12) - 3*A(1/12)^2) ).
%e A396843 A(1/13) = 0.11578086127592475021524047676064891417513763408741...
%e A396843 where 1/13^2 = A( (1/13)*(A(1/13) - 3*A(1/13)^2) ).
%e A396843 A(1/14) = 0.10085701820869542449578106824171060945513778395404...
%e A396843 where 1/14^2 = A( (1/14)*(A(1/14) - 3*A(1/14)^2) ).
%o A396843 (PARI) {a(n,k=3) = my(A=x); for(i=1, #binary(n), A = (1 - sqrt(1 - 4*k*subst(serreverse(A +x*O(x^n)), x, x^2)/x) )/(2*k) ); polcoeff(GF=A, n)}
%o A396843 {upto(n) = a(n,3); Vec(GF)}
%o A396843 upto(25)
