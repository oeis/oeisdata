%U A396722 137916592172,551523077078,2205587375972,8820559289228,35275854652472,141080547968978,564239857568636
%N A396722 a(n) = (4^n/2) * p(n, 5/2), where p(n,x) is the Lagrange interpolating polynomial through (1,0) and (k,1) for k=2..n+1.
%F A396722 Conjecture D-finite with recurrence n*a(n) +2*(-4*n+5)*a(n-1) +8*(2*n-5)*a(n-2)=0. - _R. J. Mathar_, Jun 30 2026
%t A396722 t[0] = {0}; t[n_] := t[n] = Join[t[n - 1], {1}];
%t A396722 p[n_, x_] := Expand[InterpolatingPolynomial[t[n], x]];
%t A396722 Table[(4^n/2) p[n, 5/2], {n, 0, 40}]
