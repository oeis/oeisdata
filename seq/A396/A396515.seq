%I A396515 #10 Jun 26 2026 17:04:17
%S A396515 1,2,3,4,5,7,7,9,11,13,11,18,13,19,25,22,17,30,19,36,37,31,23,48,37,
%T A396515 37,45,54,29,71,31,55,61,49,73,86,37,55,73,98,41,107,43,90,117,67,47,
%U A396515 126,79,108,97,108,53,131,121,148,109,85,59,204,61,91,175,136,145,179,67,144,133,215,71,237,73,109,207,162
%N A396515 a(n) = Sum_{k=1..n} gcd(k,n)^(ceiling(n/k) - floor(n/k)).
%C A396515 For each k from 1..n, add 1 if k|n, else add gcd(k,n).
%F A396515 a(n) = Sum_{d|n} ( d*phi(n/d)-d+1 ).
%F A396515 a(n) = A000005(n) + A396514(n).
%e A396515 a(10) = 13; For k = 1..10 we get a(10) = 1 + 1 + gcd(3,10) + gcd(4,10) + 1 + gcd(6,10) + gcd(7,10) + gcd(8,10) + gcd(9,10) + 1 = 13.
%t A396515 Table[Sum[GCD[n, k]^(Ceiling[n/k] - Floor[n/k]), {k, n}], {n, 100}]
%t A396515 (* Alternative: *)
%t A396515 Table[Sum[d*(EulerPhi[n/d] - 1) + 1, {d, Divisors[n]}], {n, 100}]
%Y A396515 Cf. A000005 (tau), A000010 (phi), A018804 (Pillai's arithmetical function), A396514.
%K A396515 nonn,easy
%O A396515 1,2
%A A396515 _Wesley Ivan Hurt_, Jun 25 2026
