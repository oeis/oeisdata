%I A396946 #25 Jun 18 2026 00:21:30
%S A396946 11,17,47,101,197,431,2027,2351,24337,27647,65537,90001,156817,184511,
%T A396946 284591,314927,414737,720299,746497,1726597,5532491
%N A396946 Primes p such that both Mordell equations y^2 = x^3 + p^2 and y^2 = x^3 - p^2 have nonzero integer solutions.
%C A396946 a(22) > 10^8.
%C A396946 Conjecture: All terms can be expressed in the form of 4*m^2 + 1 or 12*m^2 - 1.
%H A396946 XiaoYang Zhang, <a href="https://www.zhihu.com/question/2044768904506036330">How many prime numbers P are currently known to satisfy the equation y^2 = x^3 +- P^2?</a> (in Chinese).
%e A396946 Prime 101 is in the sequence because both Mordell equations y^2 = x^3 + 101^2 and y^2 = x^3 - 101^2 have integer solutions as {{24, 155}} and {{101, 1010}}.
%o A396946 (SageMath)
%o A396946 def f(p):
%o A396946     for k in primes(p, p + 1000):
%o A396946         try:
%o A396946             E1 = EllipticCurve([0,0,0,0, -k^2])
%o A396946             E2 = EllipticCurve([0,0,0,0,  k^2])
%o A396946             pts1 = E1.integral_points()
%o A396946             pts2 = E2.integral_points()
%o A396946             if any(pt[0] != 0 for pt in pts1) and any(pt[0] != 0 for pt in pts2):
%o A396946                 print(k)
%o A396946         except:
%o A396946             pass
%o A396946 f(1)
%Y A396946 Cf. A081120, A081119, A396853.
%K A396946 nonn,hard,more,new
%O A396946 1,1
