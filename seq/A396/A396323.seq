%N A396323 Numbers that are neither cubefree nor powerful with at least 3 distinct prime factors.
%C A396323 Numbers in A391319 with at least 3 distinct prime factors.
%C A396323 Intersection of A000977 and A391319.
%C A396323 Intersection of A390949 and A391319.
%C A396323 Intersection of A000977, A046099, and A332785.
%C A396323 Smallest term with m distinct prime factors is 4*A002110(m), m > 2.
%H A396323 Michael De Vlieger, <a href="/A396323/b396323.txt">Table of n, a(n) for n = 1..10000</a>
%e A396323 Table of n, a(n) for select n:
%e A396323     n    a(n)
%e A396323   ---------------------------------
%e A396323     1    120 = 2^3 * 3 * 5
%e A396323     2    168 = 2^3 * 3 * 7
%e A396323     3    240 = 2^4 * 3 * 5
%e A396323     4    264 = 2^3 * 3 * 11
%e A396323     5    270 = 2 * 3^3 * 5
%e A396323     6    280 = 2^3 * 5 * 7
%e A396323     7    312 = 2^3 * 3 * 13
%e A396323     8    336 = 2^4 * 3 * 7
%e A396323     9    360 = 2^3 * 3^2 * 5
%e A396323    38    840 = 2^3 * 3 * 5 * 7
%e A396323    45    945 = 3^3 * 5 * 7
%e A396323   855   9240 = 2^3 * 3 * 5 * 7 * 11
%t A396323 Select[Range[1200], And[Length[#] > 2, MemberQ[#, 1], AnyTrue[#, # > 2 &]] &[FactorInteger[#][[All, -1]] ] &]
%o A396323 (PARI) is(n) = my(f = factor(n)[,2]~); #f >= 3 && vecmin(f) == 1 && vecmax(f) >= 3 \\ _David A. Corneth_, Jun 06 2026
