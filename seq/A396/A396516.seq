%S A396516 1,2,4,70,264,1980,10708,68528,395952,2424344,14390256,86839936,
%T A396516 519292816,3121070512,18706256384,112286791600,673457709184,
%U A396516 4041008444880,24241560650688,145442362827088,872546655742592,5234850342616464,31405815793379456,188417511326840016,1130393107215058816
%N A396516 Expansion of g.f. (1 - 17*x^2 - 88*x^4 - 4*x^6)/(1 - 2*x - 17*x^2 - 28*x^3 - 88*x^4 + 26*x^5 - 4*x^6 + 4*x^7).
%C A396516 Sum of sixth powers of A396471 row entries.
%H A396516 Paolo Xausa, <a href="/A396516/b396516.txt">Table of n, a(n) for n = 0..1000</a>
%H A396516 Richard P. Stanley, <a href="https://www.gathering4gardner.org/g4g15gift/ExchangeArchive-FibArray-G15-087-1.pdf">A Fibonacci Array</a>, in Gathering for Gardner 15 Gift Exchange Book, 2024 (see p. 5).
%H A396516 <a href="/index/Rec#order_07">Index entries for linear recurrences with constant coefficients</a>, signature (2,17,28,88,-26,4,-4).
%F A396516 a(n) = Sum_{k=0..A001911(n)} A396471(n,k)^6.
%F A396516 a(n) = 2*a(n-1) + 17*a(n-2) + 28*a(n-3) + 88*a(n-4) - 26*a(n-5) + 4*a(n-6) - 4*a(n-7), with a(0) = 1, a(1) = 2, a(2) = 4, a(3) = 70, a(4) = 264, a(5) = 1980, a(6) = 10708.
%t A396516 Module[{x}, CoefficientList[Series[(1 - 17*x^2 - 88*x^4 - 4*x^6)/(1 - 2*x - 17*x^2 - 28*x^3 - 88*x^4 + 26*x^5 - 4*x^6 + 4*x^7), {x, 0, 24}], x]]
%t A396516 (* Alternative: *)
%t A396516 LinearRecurrence[{2, 17, 28, 88, -26, 4, -4}, {1, 2, 4, 70, 264, 1980, 10708}, 25]
%Y A396516 Cf. A001911, A396471.
%Y A396516 Cf. other sum of r-th powers of A396471 row entries: A000079 (r=1), A052987 (r=2), A396473 (r=3), A396474 (r=4), A396475 (r=5).
%K A396516 nonn,easy,new
%O A396516 0,2
