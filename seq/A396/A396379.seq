%I A396379 #14 Jun 17 2026 13:48:56
%S A396379 1,2,3,4,6,8,10,12,15,16,18,21,24,28,30,36,40,45,48,50,56,60,63,64,70,
%T A396379 72,80,81,90,96,100,105,108,112,120,126,128,135,140,144,150,160,162,
%U A396379 168,180,189,192,198,200,210,224,225,240,252,256,270,275,280,288,297,300,315,320,324,330,336,350
%N A396379 Fixed points of A396378: integers m so that m is the smallest integer of the interval (m, m+1, ..., m+A396377(m)) that divides the product of the other integers.
%C A396379 Prime factors with multiplicity of each term m appear immediately in the following integers (m+1,m+2,...).
%C A396379 Many powers of 2 are terms (but not 32); also many multiples of 6 (but not 42, 54, ...) and multiples of 10 (but not 20, 90,...) are terms.
%H A396379 Paul Erdős, <a href="https://combinatorica.hu/~p_erdos/1963-14.pdf">Quelques problèmes de Théorie des Nombres</a>, Monographies de l'Enseignement Mathématique, No. 6, pp. 81-135, L'Enseignement Mathématique, Université, Geneva, 1963, Problem 15, p. 90.
%e A396379 In the interval (8,9,10,11,12), we have 8 | 9*10*11*12 and also 12 | 8*9*10*11, but by definition, as we choose 8 < 12, 8 is a term.
%e A396379 In the interval (32,33,34,35,36,37,38,39) we have 36 | 32*33*34*35*37*38*39 and 32 that does not divide 33*34*35*36*37*38*39, so 32 is not a fixed point.
%p A396379 Fixes := proc(N)
%p A396379 local n, k, L, i, j, t, g, ok, S;
%p A396379 S := [];
%p A396379 n := 1;
%p A396379 while nops(S) < N do
%p A396379     ok := false;
%p A396379     for k from 1 do
%p A396379         L := [seq(n+r, r=0..k)];
%p A396379         for i from 1 to k+1 do
%p A396379             t := L[i];
%p A396379             for j from 1 to k+1 do
%p A396379                 if j <> i then
%p A396379                     g := gcd(t, L[j]);
%p A396379                     t := iquo(t, g);
%p A396379                 end if;
%p A396379             end do;
%p A396379             if t = 1 then
%p A396379                 if L[i] = n then
%p A396379                     ok := true;
%p A396379                 end if;
%p A396379                 break;
%p A396379             end if;
%p A396379         end do;
%p A396379         if ok or t = 1 then
%p A396379             break;
%p A396379         end if;
%p A396379     end do;
%p A396379     if ok then
%p A396379         S := [op(S), n];
%p A396379     end if;
%p A396379     n := n + 1;
%p A396379 end do;
%p A396379 return S;
%p A396379 end proc:
%p A396379 Fixes(150);
%Y A396379 Cf. A396377, A396378, A396380, A396950.
%K A396379 nonn
%O A396379 1,2
%A A396379 _Bernard Schott_, May 26 2026
