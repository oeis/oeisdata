%I A396002 #9 May 18 2026 00:53:09
%S A396002 3,5,17,97,193,257,449,641,769,2753,3329,4673,5441,5953,6977,7681,
%T A396002 7873,7937,10753,11777,12161,12289,13313,14081,14657,15937,18433,
%U A396002 19457,26113,28097,29633,35521,36161,36353,36929,37889,40193,40961,42689,44417,45377,45569,46337,47681,48449,51329,51713
%N A396002 Primes p that are the least prime factor of 2^k + 1 for some k >= 1.
%C A396002 Numbers that occur in A002586.
%C A396002 Odd primes p such that A002326((p-1)/2) is even and there is no smaller odd prime q such that A002326((p-1)/2)/A002326((q-1)/2) is an odd integer.
%H A396002 Robert Israel, <a href="/A396002/b396002.txt">Table of n, a(n) for n = 1..10000</a>
%e A396002 a(4) = 97 is a term because 2^24 + 1 = 16777217 = 97 * 257 * 673 whose least prime factor is 97.
%p A396002 A:= NULL: V:= {}:
%p A396002 p:= 2:
%p A396002 while p < 10^6 do
%p A396002   p:= nextprime(p); v:= NumberTheory:-MultiplicativeOrder(2, p)/2;
%p A396002   if v::integer and andmap(w -> v mod w <> 0 or (v/w)::even, V) then
%p A396002     A:= A, p; V:= V union {v}
%p A396002   fi;
%p A396002 od:
%p A396002 A;
%Y A396002 Includes A019434. Cf. A002326, A002586, A395931, A393641.
%K A396002 nonn
%O A396002 1,1
%A A396002 _Robert Israel_, May 13 2026
