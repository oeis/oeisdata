%S A396030 0,1,2,1,3,4,4,5,1,4,6,3,5,3,6,4,7,4,8,5,4,9,5,5,6,5,7,5,8,6,6,7,6,8,
%T A396030 7,7,8,8,9,6,9,7,9,8,10,7,10,8,11,10,9,9,10,10,11,11,12,6,10,12,7,11,
%U A396030 13,9,11,14,11,15,8,12,8,13,10,13,11,16,9,12,9
%N A396030 a(0) = 0, and then a(n) is the numbers of ways to write a(n-1) as a(i) + ... + a(j) with i <= j < n.
%C A396030 A variant of A331614 with initial value 0.
%C A396030 This sequence is unbounded:
%C A396030 - by contradiction, suppose that a(n) <= M for any n >= 0,
%C A396030 - by necessity, some value m <= M appears infinitely many times,
%C A396030 - so we have a(k_1) = ... = a(k_{M+1}) = m with k_1 < ... < k_{M+1},
%C A396030 - and a(k_{M+1}+1) > M, a contradiction.
%H A396030 Rémy Sigrist, <a href="/A396030/b396030.txt">Table of n, a(n) for n = 0..10000</a>
%H A396030 Rémy Sigrist, <a href="/A396030/a396030.txt">C++ program</a>
%F A396030 a(n) <= A000217(n).
%e A396030 The first terms, alongside the corresponding sums, are:
%e A396030   n   a(n)  Sums
%e A396030   --  ----  ---------------------------------------------------------
%e A396030    0     0
%e A396030    1     1  a(0)
%e A396030    2     2  a(0)+a(1), a(1)
%e A396030    3     1  a(2)
%e A396030    4     3  a(0)+a(1), a(1), a(3)
%e A396030    5     4  a(0)+...+a(2), a(1)+a(2), a(2)+a(3), a(4)
%e A396030    6     4  a(0)+...+a(3), a(1)+...+a(3), a(3)+a(4), a(5)
%e A396030    7     5  a(0)+...+a(3), a(1)+...+a(3), a(3)+a(4), a(5), a(6)
%e A396030    8     1  a(7)
%e A396030    9     4  a(0)+a(1), a(1), a(3), a(8)
%e A396030   10     6  a(0)+...+a(3), a(1)+...+a(3), a(3)+a(4), a(5), a(6), a(9)
%o A396030 (C++) // See Links section.
%o A396030 (Python)
%o A396030 from itertools import islice
%o A396030 from collections import Counter
%o A396030 def agen(): # generator of terms
%o A396030     alst, ways, partials = [0], Counter(), []
%o A396030     while True:
%o A396030         yield alst[-1]
%o A396030         partial = 0
%o A396030         for i in range(1, 1+len(alst)):
%o A396030             partial += alst[-i]
%o A396030             ways[partial] += 1
%o A396030         alst.append(ways[alst[-1]])
%o A396030 print(list(islice(agen(), 80))) # _Michael S. Branicky_, May 17 2026
%Y A396030 Cf. A000217, A331614, A358799, A395907.
