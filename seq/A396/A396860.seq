%T A396860 1,6,15,28,-255,5842,-125375,0,1,7,24,50,-240,6768,-198188,5309088,0,
%U A396860 1,8,35,90,-175,7044,-236439,8591354,-278224975,0,1,9,48,154,-24,7000,-252248,10476084,-458439952,17527766896,0
%N A396860 Square array A(n,k), n >= 0, k >= 0, read by antidiagonals downwards, where column k is the expansion of e.g.f. B(x)^k, where B(x) is the e.g.f. of A087961.
%F A396860 A(n,k) = k^n - Sum_{j=1..n-1} binomial(n,j) * A(j,k) * A(n-j,j).
%e A396860 Square array begins:
%e A396860   1,    1,    1,    1,    1,    1, ...
%e A396860   0,    1,    2,    3,    4,    5, ...
%e A396860   0,   -1,    0,    3,    8,   15, ...
%e A396860   0,   10,   14,   18,   28,   50, ...
%e A396860   0, -159, -232, -255, -240, -175, ...
%e A396860   0, 3816, 5842, 6768, 7044, 7000, ...
%e A396860   ...
%o A396860 (PARI) a(n,k) = k^n-sum(j=1, n-1, binomial(n, j)*a(j, k)*a(n-j, j));
%Y A396860 Columns k=0..1 give A000007, A087961.
%K A396860 sign,tabl
%O A396860 0,8
