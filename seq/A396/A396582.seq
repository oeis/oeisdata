%I A396582 #19 May 30 2026 10:31:54
%S A396582 1,6,-8,40,-112,384,-1216,3968,-12800,41472,-134144,434176,-1404928,
%T A396582 4546560,-14712832,47611904,-154075136,498597888,-1613496320,
%U A396582 5221384192,-16896753664,54679044096,-176945102848,572606382080,-1852993175552,5996411879424,-19404796461056
%N A396582 a(n) = 4*a(n - 2) - 2*a(n - 1) for n >= 2, a(0) = 1, a(1) = 6.
%H A396582 <a href="/index/Rec#order_02">Index entries for linear recurrences with constant coefficients</a>, signature (-2,4).
%F A396582 a(n) = -(-2)^n * (F(n) + L(n-1)) where F ~ Fibonacci A000045 and L ~ Lucas A000032.
%F A396582 a(n) = [x^n] (1 + 8*x) / (1 + 2*x - 4*x^2).
%F A396582 a(n) = n! * [x^n] exp(-x)*(7*sinh(r*x)/r + cosh(r*x)) where r = sqrt(5).
%F A396582 a(n) = ((1 - 7/r) * (-r - 1)^n + (1 + 7/r) * (r - 1)^n) / 2 where r = sqrt(5).
%F A396582 2^n * a(-n) = A000285(n).
%F A396582 a(n) / 2^n = A396201(n).
%p A396582 a := n -> ((1 - 7/sqrt(5)) * (-sqrt(5) - 1)^n + (1 + 7/sqrt(5)) * (sqrt(5) - 1)^n )/2: seq(simplify(a(n)), n = 0..26);
%t A396582 LinearRecurrence[{-2,4},{1,6},27] (* _James C. McMahon_, May 30 2026 *)
%o A396582 (Python)
%o A396582 def A396582gen(bound):
%o A396582     a, b = 1, 6
%o A396582     if bound >= 1: yield a
%o A396582     if bound >= 2: yield b
%o A396582     for _ in range(2, bound):
%o A396582         c = 4 * a - 2 * b
%o A396582         yield c
%o A396582         a, b = b, c
%o A396582 for v in A396582gen(27): print(v, end=", ")
%o A396582 (SageMath)
%o A396582 a = BinaryRecurrenceSequence(-2, 4, 1, 6)
%o A396582 print([a(i) for i in range(27)])
%Y A396582 Cf. A396201, A000032 (Lucas), A000045 (Fibonacci), A000285.
%K A396582 sign,easy,new
%O A396582 0,2
