%N A396745 Expansion of e.g.f. -W_2(-x)/(1 - W_2(-x)), where W_k(x) is the k-th iterate of LambertW(x).
%F A396745 E.g.f.: 1 - exp(-B(x)), where B(x) is the e.g.f. of A396677.
%F A396745 a(n) = Sum_{k=1..n} n^(n-k) * binomial(n-1,k-1) * A277458(k).
%F A396745 a(n) = (n-1)! * Sum_{i,j,k >= 0 and i+j+k=n-1} (-1)^k * (k+1) * n^i * (n-i)^j / (i!*j!).
%o A396745 (PARI) my(N=20, x='x+O('x^N)); Vec(serlaplace(-lambertw(lambertw(-x))/(1-lambertw(lambertw(-x)))))
