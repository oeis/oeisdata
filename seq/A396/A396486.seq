%e A396486   2, 4, 12,
%e A396486   4, 4.
%o A396486 (PARI) power_solution(invariant_factors, k) = vecprod(apply(x->gcd(x, k), invariant_factors)); \\ number of solutions to x^k = 1 in C_{k_1} X ... C_{k_r}
%o A396486 count_order(invariant_factors, k) = sumdiv(k, d, moebius(k/d)*power_solution(invariant_factors, d)); \\ number of elements of order k
%o A396486 row(n) = if(n<=2, [1], my(invariant_factors=znstar(n)[2], k=lcm(invariant_factors)/2); apply(x->count_order(invariant_factors, 2*x)+if(x%2==1, count_order(invariant_factors, x)), divisors(k)));
