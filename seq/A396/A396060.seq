%I A396060 #30 May 26 2026 16:41:11
%S A396060 2,4,6,16,90,120,156,204,210,280,384,396,406,436,490,496,636,826,960,
%T A396060 1066,1150,1210,1276,1324,1350,1366,1374,1416,1660,1686,1974,2034,
%U A396060 2050,2074,2080,2086,2106,2260,2304,2310,2314,2430,2464,2496,2536,2664,2730,2736
%N A396060 Numbers m such that m^2 + 1 and m^2 - m + 1 are both prime numbers.
%C A396060 Conjecture: There are infinitely many numbers m such that the two polynomials m^2 + 1 and m^2 - m + 1 are prime.
%H A396060 Robert Israel, <a href="/A396060/b396060.txt">Table of n, a(n) for n = 1..10000</a>
%H A396060 Paul T. Bateman and Roger A. Horn, <a href="https://doi.org/10.1090/S0025-5718-1962-0148632-7">A heuristic asymptotic formula concerning the distribution of prime numbers</a>, Mathematics of Computation, Vol. 16, No. 79 (1962), pp. 363-367.
%e A396060 6 is in the sequence because 6^2+1 = 37 and 37-6 = 31 is prime.
%e A396060 10 is not in the sequence because 10^2+1 = 101 is prime but 101-10 = 91 = 7*13 is not prime.
%p A396060 nn:=2800:
%p A396060 for m from 2 by 2 to nn do :
%p A396060 p:=m^2+1:if isprime(p) and isprime(p-m) then printf("%d, ",m):
%p A396060 else fi:
%p A396060 od:
%t A396060 Select[Range[3000], And @@ PrimeQ[#^2 + {1-#, 1}] &] (* _Amiram Eldar_, May 15 2026 *)
%o A396060 (PARI) isok(m) = isprime(m^2+1) && isprime(m^2-m+1); \\ _Michel Marcus_, May 16 2026
%Y A396060 Intersection of A005574 and A055494.
%K A396060 nonn,new
%O A396060 1,1
%A A396060 _Michel Lagneau_, May 15 2026
