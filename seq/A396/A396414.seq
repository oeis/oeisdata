%S A396414 1,2,8,40,224,1345,8472,55279,370654,2540077,17721429,125503679,
%T A396414 900203928,6527938601,47789674423,352775567896,2623245127682,
%U A396414 19633263372440,147792032838665,1118279627862837,8500864727233653,64892113815239073,497239000475553571
%N A396414 Expansion of F_2(x)/x, where F_k(x) is the k-th iteration of x*G3(x) with G3(x) = 1 + x*G3(x)^3.
%H A396414 Seiichi Manyama, <a href="/A396414/b396414.txt">Table of n, a(n) for n = 0..1000</a>
%F A396414 G.f.: (1/x) * Series_Reversion( H_2(x) ), where H_k(x) is the k-th iteration of x*(1 - x*C(x)) with C(x) = 1 + x*C(x)^2.
%F A396414 a(n) = Sum_{k=0..n} (k+1) * binomial(3*k+1,k) * binomial(3*n-2*k+1,n-k)/((3*k+1) * (3*n-2*k+1)).
%F A396414 a(n) ~ sqrt(55 - 7*sqrt(33)) * 3^(5*n + 3/2) / (sqrt(Pi) * n^(3/2) * 2^(n+5) * (9 + sqrt(33))^n). - _Vaclav Kotesovec_, May 25 2026
%t A396414 Table[Sum[(k+1) * Binomial[3*k+1, k] * Binomial[3*n-2*k+1, n-k] / ((3*k+1)*(3*n-2*k+1)), {k, 0, n}], {n, 0, 25}] (* _Vaclav Kotesovec_, May 25 2026 *)
%o A396414 (PARI)
%o A396414 lista(nn, k=2, l=3) = {
%o A396414   my(T=matrix(nn+1, nn+1, row, col, my(xr=row-1, xc=col-1); if(xc<xr, 0, (xr+1)*binomial(l*xc-(l-1)*xr+1, xc-xr)/(l*xc-(l-1)*xr+1))));
%o A396414   my(TK=T^k);
%o A396414   TK[1, ];
%o A396414 };
%Y A396414 Column k=2 of A396412.
%Y A396414 Cf. A000108, A001764.
%K A396414 nonn,new
%O A396414 0,2
%A A396414 _Seiichi Manyama_, May 25 2026
