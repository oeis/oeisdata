%S A396542 36,36,100,36,196,100,484,225,72,100,676,72,196,900,441,1156,225,1444,
%T A396542 100,1764,484,900,2116,108,196,1089,676,196,3364,1521,900,3844,1764,
%U A396542 4356,225,1156,4900,441,5476,900,1444,2601,6084,200,216,6724,1764,3249,7396,1225,484,900
%N A396542 Smallest powerful k (in A001694) that exceeds A332785(n) and has the same squarefree kernel as A332785(n).
%C A396542 Terms are in A286708 (powerful numbers with more than 1 distinct prime factor).
%C A396542 Let S(k) = { q : rad(q) = rad(k) } be the sequence of numbers with the same squarefree kernel as k. Then a(n) is the smallest powerful number q in S(k) that exceeds k, with k in A332785.
%C A396542 For k in A332785, S(k) is infinite, and such that its smallest term is rad(k) (squarefree). All the rest of the terms m are in A126706 (neither squarefree nor prime power), either in A332785 (neither squarefree nor powerful) or in A286708. Those terms m in A286708 generally become increasingly more common as m increases.
%C A396542 Let b = A332785.
%C A396542 Then b(n) is the A008479(b(n))-th term in S(b(n)), and a(n) is such that A008479(a(n)) > A008479(b(n)).
%C A396542 a(1) = 36 is the first term in A303606 (perfect powers of squarefree composites), A131605 (perfect powers that are not prime powers), and A001597 (perfect powers).
%C A396542 a(9) = 72 is the first Achilles number in the sequence as n increases.
%C A396542 a(73) = 400 is the first term in A386762 (perfect powers of numbers in A332785).
%C A396542 a(137704) = 354294 is the first term in A383394 (perfect powers of Achilles numbers).
%C A396542 A powerful number k appears a finite number of times in this sequence.
%H A396542 Michael De Vlieger, <a href="/A396542/b396542.txt">Table of n, a(n) for n = 1..10000</a>
%H A396542 Michael De Vlieger, <a href="/A396542/a396542.png">Log log scatterplot of a(n)</a>, n = 1..2^20.
%H A396542 Michael De Vlieger, <a href="/A396542/a396542_1.png">Annotated log log scatterplot of a(n)</a>, n = 1..2^18, showing perfect powers of squarefree composites (in A303606) in black, Achilles numbers (in A052486) in blue, perfect powers of numbers neither squarefree nor powerful (in A386762) in red, and perfect powers of Achilles numbers (in A383394) in green.
%e A396542 Let rad = A007947.
%e A396542 Table of n, b(n), and a(n) for select n:
%e A396542        n      b(n)                    a(n)
%e A396542   ---------------------------------------------------------
%e A396542        1       12 = 2^2 * 3            36 = 2^2 * 3^2
%e A396542        2       18 = 2 * 3^2            36 = 2^2 * 3^2
%e A396542        3       20 = 2^2 * 5           100 = 2^2 * 5^2
%e A396542        4       24 = 2^3 * 3            36 = 2^2 * 3^2
%e A396542        5       28 = 2^2 * 7           196 = 2^2 * 7^2
%e A396542        9       48 = 2^4 * 3            72 = 2^3 * 3^2
%e A396542       14       60 = 2^2 * 3 * 5       900 = 2^2 * 3^2 * 5^2
%e A396542       73      250 = 2 * 5^3           400 = 2^4 * 5^2
%e A396542      132      420 = 2 * 210         44100 = 210^2
%e A396542     1688     4620 = 2 * 2310      5336100 = 2310^2
%e A396542    23075    60060 = 2 * 30030   901800900 = 30030^2
%e A396542   137704   354294 = 2 * 3^11       373248 = 2^9 * 3^6
%t A396542 (* First, load the regs program from the Mathematica link in A369609, then: *)
%t A396542 rad[x_] := Times @@ FactorInteger[#][[All, -1]];
%t A396542 a332785 = Select[Range[180], Nor[SquareFreeQ[#], Divisible[#, rad[#]^2] ] &];
%t A396542 Map[Module[{k, m, r, s, t},
%t A396542   k = #; r = rad[#]; t = r^Ceiling[Log[r, k] + 1/3];
%t A396542   s = regs[-r, t]; m = 1 + FirstPosition[s, k][[1]];
%t A396542   While[!Divisible[s[[m]], r^2], m++]; s[[m]]] &, a332785]
%Y A396542 Cf. A001694, A007947, A008479, A013929, A052485, A126706, A286708, A332785, A396367.
%K A396542 nonn,new
%O A396542 1,1
