%I A396849 #20 Jul 05 2026 02:49:07
%S A396849 1,1,9,466,215886,1179016248,93600192522240,128279107718371482048,
%T A396849 3513759334852207908359983104,2185768594153456526298924848024027136,
%U A396849 34581807160108833790019663335524773648793600000,15406013385975245895188516020929211807249174582394880000000
%N A396849 G.f. A(x) satisfies [x^n] A(x)^(1/n) = 1 for n >= 1, where A(x) = Sum_{n>=0} a(n)*x^n/H(n) and H(n) = A002109(n) is the hyperfactorial of n.
%C A396849 Compare to [x^n] exp(x)^(1/n) = 1 / (n! * n^n) for n >= 1.
%C A396849 Compare to [x^n] W(x)^(1/n) = (n^2 + 1)^(n-1) / (n! * n^n) for n >= 1, where W(x) = LambertW(-x)/(-x) and W(x)^p = Sum_{n>=0} p*(n+p)^(n-1)*x^n/n!.
%H A396849 Paul D. Hanna, <a href="/A396849/b396849.txt">Table of n, a(n) for n = 0..50</a>
%H A396849 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/Hyperfactorial.html">Hyperfactorial</a>.
%e A396849 G.f.: A(x) = 1 + x/H(1) + 9*x^2/H(2) + 466*x^3/H(3) + 215886*x^4/H(4) + 1179016248*x^5/H(5) + 93600192522240*x^6/H(6) + ...
%e A396849 where H(n) = Product_{k=0..n} k^k is the hyperfactorial of n:
%e A396849   A002109 = [1, 1, 4, 108, 27648, 86400000, 4031078400000, ...].
%e A396849 As a series with reduced fractional coefficients,
%e A396849 A(x) = 1 + x + 9/4*x^2 + 233/54*x^3 + 35981/4608*x^4 + 49125677/3600000*x^5 + 338542363/14580000*x^6 + 8248399416047549/213462345600000*x^7 + ...
%e A396849 The table of reduced fractional coefficients in A(x)^(1/n) begins
%e A396849   n = 1: [1,   1,    9/4,    233/54,      35981/4608, ...];
%e A396849   n = 2: [1, 1/2,      1,   179/108,     71207/27648, ...];
%e A396849   n = 3: [1, 1/3,  23/36,         1,     20141/13824, ...];
%e A396849   n = 4: [1, 1/4,  15/32, 2459/3456,               1, ...];
%e A396849   n = 5: [1, 1/5, 37/100, 3719/6750, 6537931/8640000, 1, ...];
%e A396849   ...
%e A396849 in which a diagonal equals all 1's, illustrating [x^n] A(x)^(1/n) = 1.
%e A396849 The list of floor values of a(n)/H(n) begins
%e A396849 [a(n)/H(n)] = [1, 1, 2, 4, 7, 13, 23, 38, 63, 101, 160, 250, 386, 589, 890, 1334, 1982, 2922, 4276, 6216, 8978, 12891, 18406, 26141, 36941, 51953, 72734, 101388, 140746, 194611, 268074, ...].
%o A396849 (PARI) {H(n) = prod(k=1,n,k^k)} \\ hyperfactorial of n
%o A396849 {a(n) = my(V=[1,1],A); if(n==0,1, for(i=1,n, V=concat(V,0); A = Ser(V); m = #V-1;
%o A396849 V[m+1] = m*(1 - polcoef(A^(1/m),m)) ); H(n)*polcoef(GF=A,n))}
%o A396849 {upto(n) = a(n); for(k=0,n,print1(H(k)*polcoef(GF,k),", "))}
%o A396849 upto(15)
%Y A396849 Cf. A002109.
%K A396849 nonn
