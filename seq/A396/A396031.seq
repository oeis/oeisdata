%I A396031 #22 Jun 09 2026 08:47:37
%S A396031 1,8,40,168,546,1512,3642,7800,15108,27320,46620,75720,117590,176664,
%T A396031 257790,366536,508664,692472,926544,1220440,1583514,2029064,2570674,
%U A396031 3222888,3999404,4919976,6004180,7272296,8743694,10445768,12404582,14647928,17201648
%N A396031 Growth series of higher Heisenberg group H_2, with standard generators.
%C A396031 Generating function is transcendental (Stoll, 1996).
%H A396031 Michael Stoll, <a href="https://doi.org/10.1007/s002220050090">Rational and transcendental growth series for the higher Heisenberg groups</a>, Invent. math. 126, 85-109 (1996).
%o A396031 (Python)
%o A396031 from sympy import ImmutableMatrix, Matrix
%o A396031 def getGens(r):
%o A396031 # Construct the standard set of 2r generators and their inverses
%o A396031    gens = []
%o A396031    for i in range(r):
%o A396031       gen = Matrix.eye(r+2)
%o A396031       gen[i+1,r+1] = 1
%o A396031       gens.append(ImmutableMatrix(gen))
%o A396031       inv = Matrix.eye(r+2)
%o A396031       inv[i+1,r+1] = -1
%o A396031       gens.append(ImmutableMatrix(inv))
%o A396031    for j in range(r):
%o A396031       gen = Matrix.eye(r+2)
%o A396031       gen[0,j+1] = 1
%o A396031       gens.append(ImmutableMatrix(gen))
%o A396031       inv = Matrix.eye(r+2)
%o A396031       inv[0,j+1] = -1
%o A396031       gens.append(ImmutableMatrix(inv))
%o A396031    return gens
%o A396031 def growthHr(r, radius):
%o A396031 # Construct the growth sequence of H_r, up to the given radius
%o A396031    ball = {ImmutableMatrix.eye(r+2)}
%o A396031    sphere = {ImmutableMatrix.eye(r+2)}
%o A396031    series = [1]
%o A396031    gens = getGens(r)
%o A396031    for _ in range(radius):
%o A396031       new_sphere = set()
%o A396031       for g in sphere:
%o A396031          for gen in gens:
%o A396031             newelt = g*gen
%o A396031             if newelt not in ball:
%o A396031                new_sphere.add(newelt)
%o A396031       sphere = new_sphere
%o A396031       ball.update(sphere)
%o A396031       series.append(len(sphere))
%o A396031    return series
%o A396031 print(growthHr(2, 13))
