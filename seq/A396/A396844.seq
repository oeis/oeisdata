%I A396844 #7 Jul 03 2026 11:36:08
%S A396844 1,4,28,288,3204,37984,470864,6031872,79213292,1060777376,14430659088,
%T A396844 198871682304,2770567442480,38955095818496,552076498222272,
%U A396844 7878133131149312,113101684573952804,1632423925911360864,23673430851581280880,344778022864540259584,5040638170835559670704,73950693064094931483136
%N A396844 G.f. A(x) satisfies A( x*A(x) - 4*x*A(x)^2 ) = x^2.
%C A396844 Conjecture: for n > 8, a(n) == 12 (mod 16) iff n is of the form 2*4^k+1 otherwise a(n) is divisible by 16.
%H A396844 Paul D. Hanna, <a href="/A396844/b396844.txt">Table of n, a(n) for n = 1..500</a>
%F A396844 G.f. A(x) = Sum_{n>=1} a(n)*x^n, along with B(x) where B(A(x)) = x, satisfies the following formulas.
%F A396844 (1) B(x) = B(B(x)^2) / (x - 4*x^2).
%F A396844 (2) B(x^2) = x*A(x) - 4*x*A(x)^2.
%F A396844 (3) A(x) - 4*A(x)^2 is an odd function.
%F A396844 (4) A(x) = (1 - sqrt(1 - 16*B(x^2)/x)) / 8.
%F A396844 (5) A(x) = (1/4)*C( 4*B(x^2)/x ), where C(x) = x + C(x)^2 is a g.f. of the Catalan numbers A000108.
%F A396844 The radius of convergence r satisfies r^2 = A(r/16), A(r) = 1/8, and A(-r) = -(sqrt(2) - 1)/8 where r = 0.06352128125958677556461487421731054327616092881345260...
%e A396844 G.f.: A(x) = x + 4*x^2 + 28*x^3 + 288*x^4 + 3204*x^5 + 37984*x^6 + 470864*x^7 + 6031872*x^8 + 79213292*x^9 + 1060777376*x^10 + ...
%e A396844 such that A( x*A(x) - 4*x*A(x)^2 ) = x^2
%e A396844 where
%e A396844 A(x)^2 = x^2 + 8*x^3 + 72*x^4 + 800*x^5 + 9496*x^6 + 117728*x^7 + 1507968*x^8 + 19803264*x^9 + 265194344*x^10 + ...
%e A396844 and
%e A396844 A(x) - 4*A(x)^2 = x - 4*x^3 + 4*x^5 - 48*x^7 + 236*x^9 - 1136*x^11 + 7728*x^13 - 47424*x^15 + 299812*x^17 - 2029840*x^19 + ...
%e A396844 which is an odd function.
%e A396844 Compare with B(x), the series reversion of A(x), A(B(x)) = x:
%e A396844 B(x) = x - 4*x^2 + 4*x^3 - 48*x^4 + 236*x^5 - 1136*x^6 + 7728*x^7 - 47424*x^8 + 299812*x^9 - 2029840*x^10 + ...
%e A396844 which satisfies: B(B(x)^2) = (x - 4*x^2)*B(x).
%e A396844 SPECIFIC VALUES.
%e A396844 A(1/16) = 0.109404141212207849842040510587940860902504786975894...
%e A396844 where 1/16^2 = A( (1/16)*(A(1/16) - 4*A(1/16)^2) ).
%e A396844 A(1/17) = 0.091503974418542141555933525662101694555654038638333...
%e A396844 where 1/17^2 = A( (1/17)*(A(1/17) - 4*A(1/17)^2) ).
%e A396844 A(1/18) = 0.081329999297442485424987574247482179399328698189716...
%e A396844 where 1/18^2 = A( (1/18)*(A(1/18) - 4*A(1/18)^2) ).
%o A396844 (PARI) {a(n,k=4) = my(A=x); for(i=1, #binary(n), A = (1 - sqrt(1 - 4*k*subst(serreverse(A +x*O(x^n)), x, x^2)/x) )/(2*k) ); polcoeff(GF=A, n)}
%o A396844 {upto(n) = a(n,4); Vec(GF)}
%o A396844 upto(25)
