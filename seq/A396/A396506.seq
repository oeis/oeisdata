%S A396506 1,2,1,1,3,1,4,1,1,2,1,5,1,1,6,1,2,1,1,3,1,2,1,1,7,1,1,8,1,2,1,1,9,1,
%T A396506 3,1,2,1,1,4,1,1,2,1,10,1,1,11,1,2,1,3,1,1,5,1,2,1,1,12,1,1,2,1,4,1,1,
%U A396506 3,1,2,1,1,13,1,14,1,2,1,1,6,1,1,3,1,2
%N A396506 A sequence constructed by greedily sampling the probability distribution given by 1/log_2(i+1)^2 - 1/log_2(i+2)^2 to minimize discrepancy.
%C A396506 The probability mass function used here is a simple example of a heavy log tail distribution. It can be seen as a discrete analog of the log-Cauchy distribution. As a consequence of the heavy tail, the arithmetic mean of this sequence diverges to infinity but it has a finite geometric mean.
%C A396506 A general family of these distributions is given by 1/log_2(i+1)^p - 1/log_2(i+2)^p where p>0.
%C A396506 Properties change sharply at p=1, the arithmetic mean remains infinite for all p but the geometric mean becomes finite for p>1 and infinite for p<=1.
%C A396506 | mean       | 0 < p <= 1 | p > 1  |
%C A396506 | ---------- | ---------- | ------ |
%C A396506 | arithmetic |     oo     |   oo   |
%C A396506 | geometric  |     oo     | finite |
%C A396506 The geometric mean equals Product_{i>=1} (1+1/i)^(1/log_2(i+2)^2) = 2.097184811... and for general power p in the family above it equals Product_{i>=1} (1+1/i)^(1/log_2(i+2)^p).
%C A396506 The Fisher information is always finite and given by Sum_{i>=1} ((ln(log_2(i+2))/(log_2(i+2))^p - ln(log_2(i+1))/(log_2(i+1))^p)^2) / (1/(log_2(i+1))^p - 1/(log_2(i+2))^p).
%H A396506 Jwalin Bhatt, <a href="/A396506/b396506.txt">Table of n, a(n) for n = 1..10000</a>
%e A396506 Let p(k) denote the probability of k and c(k) denote the number of occurrences of k among the first n-1 terms; then the expected number of occurrences of k among n random terms is given by n*p(k).
%e A396506 We subtract the actual occurrences c(k) from the expected occurrences and pick the one with the highest value.
%e A396506 | n | n*p(1) - c(1) | n*p(2) - c(2) | n*p(3) - c(3) | n*p(4) - c(4) | choice |
%e A396506 |---|---------------|---------------|---------------|---------------|--------|
%e A396506 | 1 |     0.601     |       -       |       -       |       -       |   1    |
%e A396506 | 2 |     0.203     |     0.296     |       -       |       -       |   2    |
%e A396506 | 3 |     0.805     |    -0.555     |     0.193     |       -       |   1    |
%e A396506 | 4 |     0.407     |    -0.407     |     0.258     |       -       |   1    |
%e A396506 | 5 |     0.009     |    -0.259     |     0.322     |       -       |   3    |
%e A396506 | 6 |     0.611     |    -0.111     |    -0.612     |     0.214     |   1    |
%e A396506 | 7 |     0.213     |     0.036     |    -0.548     |     0.250     |   4    |
%t A396506 probCountDiff[j_, k_, count_] := k*(1/Log2[j+1]^2 - 1/Log2[j+2]^2) - Lookup[count, j, 0]
%t A396506 samplePDF[n_] := Module[{coeffs, unreachedVal, counts, k, probCountDiffs, mostProbable},
%t A396506   coeffs = ConstantArray[0, n]; unreachedVal = 1; counts = <||>;
%t A396506   Do[probCountDiffs = Table[probCountDiff[i, k, counts], {i, 1, unreachedVal}];
%t A396506     mostProbable = First@FirstPosition[probCountDiffs, Max[probCountDiffs]];
%t A396506     If[mostProbable == unreachedVal, unreachedVal++]; coeffs[[k]] = mostProbable;
%t A396506     counts[mostProbable] = Lookup[counts, mostProbable, 0] + 1; , {k, 1, n}]; coeffs]
%t A396506 A396506 = samplePDF[120]
%o A396506 (Python)
%o A396506 from mpmath import iv
%o A396506 def prob_count_diff(j, k, count):
%o A396506     return k*(1/iv.log(j+1, 2)**2 - 1/iv.log(j+2, 2)**2) - count
%o A396506 def sample_log_tail_distribution(num_coeffs):
%o A396506     coeffs, unreached_val, counts = [], 1, {}
%o A396506     for k in range(1, num_coeffs+1):
%o A396506         prob_count_diffs = [prob_count_diff(i, k, counts.get(i, 0)) for i in range(1, unreached_val+1)]
%o A396506         most_probable = prob_count_diffs.index(max(prob_count_diffs)) + 1
%o A396506         unreached_val += most_probable == unreached_val
%o A396506         coeffs.append(most_probable)
%o A396506         counts[most_probable] = counts.get(most_probable, 0) + 1
%o A396506     return coeffs
%o A396506 A396506 = sample_log_tail_distribution(120)
%Y A396506 Cf. A393100, A394370, A394401, A396405.
%K A396506 nonn
