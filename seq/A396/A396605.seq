%I A396605 #68 Jun 08 2026 18:18:35
%S A396605 0,3,2,15,0,35,0,3,8,99,0,143,12,5,8,255,6,323,0,15,20,483,8,5,24,21,
%T A396605 14,783,10,899,0,27,32,7,12,1295,36,33,0,1599,0,1763,36,9,44,2115,0,7,
%U A396605 10,45,44,2703,0,35,14,51,56,3363,12,3599,60,9,32,45,44,4355,60,63,14
%N A396605 The smallest difference between n and the product of a nontrivial divisor of n with the totient of that divisor.
%C A396605 The subsequence indexed by prime squares is exactly the sequence of prime numbers.
%C A396605 It appears empirically that zeros are relatively rare and that the values at composite n are usually much smaller than those at prime n.
%C A396605 Conjecture: the set of n such that a(n) = 0 has natural density 0.
%H A396605 Pierre Colmant, <a href="/A396605/b396605.txt">Table of n, a(n) for n = 2..1000</a>
%F A396605 a(n) = minimum of abs(n - d * phi(d)) taken over all divisors d > 1 of n.
%F A396605 For prime p, a(p) = |p - p*phi(p)| = p*(p - 2).
%e A396605 For n = 6 the divisors greater than 1 are 2, 3 and 6. Since phi(2) = 1, phi(3) = 2 and phi(6) = 2, the values d*phi(d) are 2, 6 and 12. The absolute differences |6-2|, |6-6| and |6-12| are 4, 0 and 6, so the minimum is 0 and a(6) = 0.
%e A396605 For n = 10 the divisors greater than 1 are 2, 5 and 10. Since phi(2) = 1, phi(5) = 4 and phi(10) = 4, the values d*phi(d) are 2, 20 and 40. The absolute differences |10-2|, |10-20| and |10-40| are 8, 10 and 30, so the minimum is 8 and a(10) = 8.
%e A396605 For n = 11 (a prime) the only divisor greater than 1 is 11. Since phi(11) = 10, we have d*phi(d) = 110 and |11-110| = 99, so a(11) = 99.
%p A396605 a := proc(n)
%p A396605   local d, L;
%p A396605   L := [op(divisors(n))];
%p A396605   L := remove(x -> x = 1, L);
%p A396605   min(seq(abs(n - d*phi(d)), d in L));
%p A396605 end:
%p A396605 seq(a(n), n=2..70);
%t A396605 a[n_] := Module[{d},
%t A396605   d = Rest[Divisors[n]];
%t A396605   Min[ Abs[n - #*EulerPhi[#]] & /@ d ]
%t A396605 ];
%t A396605 Table[a[n], {n, 2, 70}]
%o A396605 (PARI) a(n)={
%o A396605   my(m = -1);
%o A396605   fordiv(n,d,
%o A396605     if(d>1,
%o A396605       my(v = abs(n - d*eulerphi(d)));
%o A396605       if(m < 0 || v < m, m = v)
%o A396605     )
%o A396605   );
%o A396605   m
%o A396605 };
%Y A396605 Cf. A000010, A000005, A027750, A001358, A082473 (zeros).
%K A396605 nonn,easy,new
%O A396605 2,2
%A A396605 _Pierre Colmant_, May 30 2026
