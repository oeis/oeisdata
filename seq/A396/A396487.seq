%I A396487 #12 May 28 2026 06:12:33
%S A396487 12,18,20,24,26,32,36,38,44,48,56,62,66,68,78,86,108,110,114,128,140,
%T A396487 144,156,176,186,188,198,204,218,230,234,246,266,276,278,288,308,318,
%U A396487 354,362,416,426,438,446,458,468,488,528,548,560,576,606,608,624,638,648,666,668,686,728,740,758,776
%N A396487 Numbers with exactly one representation as the sum of two distinct upper twin primes.
%C A396487 Numbers k such that there is exactly one pair (p,q) with p < q, p and q in A006512, and p + q = k.
%C A396487 Includes 5 + p for all p > 5 in A006512.  All other terms == 2 (mod 6).
%C A396487 Is a(484) = 24536 the largest term == 2 (mod 6)?
%H A396487 Robert Israel, <a href="/A396487/b396487.txt">Table of n, a(n) for n = 1..10000</a>
%e A396487 a(3) = 20 is a term because 20 = 7 + 13 and there is no other pair of distinct members of A006512 whose sum is 20.
%p A396487 N:= 1000: # for terms <= N
%p A396487 P:= select(t -> isprime(t) and isprime(t-2), [5,seq(i,i=7..N,6)]):
%p A396487 R:= sort(select(`<=`,[seq(seq(P[i]+P[j],i=1..j-1),j=1..nops(P))],N)):
%p A396487 J:= select(proc(i) i=1 or (R[i-1] < R[i] and R[i] < R[i+1]) end proc, [$1..nops(R)-1]):
%p A396487 R[J];
%Y A396487 Cf. A006512, A334160.
%K A396487 nonn
%O A396487 1,1
%A A396487 _Robert Israel_, May 28 2026
