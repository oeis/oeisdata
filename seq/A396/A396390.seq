%U A396390 6852739,11405775,19286971,32039014,54018522,90928382,150649790,252983945,424266973,701408734
%N A396390 a(n) = r(n,n), where r(1,k)=f(k)=floor(k*c), r(n,k)=f(r(n-1,k)), c=golden ratio.
%C A396390 a(n + 1)/a(n) approaches c erratically.
%t A396390 c = GoldenRatio; f[k_] := f[k] = Floor[c*k];
%t A396390 r[1, k_] := f[k]; r[n_, k_] := r[n, k] = f[r[n - 1, k]];
%t A396390 Table[r[n, n], {n, 1, 100}]
%Y A396390 Cf. A001622, A396385, A396391, A396392, A396393.
%K A396390 nonn
%O A396390 1,2
