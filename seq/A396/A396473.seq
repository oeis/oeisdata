%I A396473 #13 May 29 2026 01:14:48
%S A396473 1,2,4,14,40,128,388,1208,3712,11480,35392,109280,337168,1040672,
%T A396473 3211456,9911264,30587008,94396160,291317824,899046272,2774571520,
%U A396473 8562692480,26425578496,81552783872,251682496768,776724972032,2397074363392,7397683621376,22830214752256,70457015263232
%N A396473 Expansion of g.f. (1 - 4*x^2)/(1 - 2*x - 4*x^2 + 2*x^3).
%C A396473 Sum of third powers of A396471 row entries.
%H A396473 Paolo Xausa, <a href="/A396473/b396473.txt">Table of n, a(n) for n = 0..1000</a>
%H A396473 Richard P. Stanley, <a href="https://www.gathering4gardner.org/g4g15gift/ExchangeArchive-FibArray-G15-087-1.pdf">A Fibonacci Array</a>, in Gathering for Gardner 15 Gift Exchange Book, 2024 (see p. 5).
%H A396473 <a href="/index/Rec#order_03">Index entries for linear recurrences with constant coefficients</a>, signature (2,4,-2).
%F A396473 a(n) = Sum_{k=0..A001911(n)} A396471(n,k)^3.
%F A396473 a(n) = 2*a(n-1) + 4*a(n-2) - 2*a(n-3), with a(0) = 1, a(1) = 2, a(2) = 4.
%t A396473 Module[{x}, CoefficientList[Series[(1 - 4*x^2)/(1 - 2*x - 4*x^2 + 2*x^3), {x, 0, 29}], x]]
%t A396473 (* Alternative: *)
%t A396473 LinearRecurrence[{2, 4, -2}, {1, 2, 4}, 30]
%Y A396473 Cf. A001911, A396471.
%Y A396473 Cf. other sum of r-th powers of A396471 row entries: A000079 (r=1), A052987 (r=2), A396474 (r=4), A396475 (r=5), A396516 (r=6).
%K A396473 nonn,easy,new
%O A396473 0,2
