%I A396768 #6 Jun 10 2026 17:24:03
%S A396768 0,0,1,0,0,2,0,0,0,1,0,2,1,0,0,0,0,2,0,0,2,0,0,2,4,1,0,0,5,2,0,0,1,0,
%T A396768 1,0,4,0,0,0,0,2,0,1,1,0,0,0,0,3,2,0,5,0,1,0,1,0,3,1,0,0,0,0,1,1,0,1,
%U A396768 0,3,4,0,0,3,0,0,1,3,3,3,0,3,0,1,0,0,0,5
%N A396768 a(n) is the number of primes p < q = prime(n) for which there exists an integer k such that (p, q, k) is a Heronian triangle.
%C A396768 Let s = (p + q + k)/2. Then (p, q, k) is Heronian iff |p - q| < k < p + q, p and q are odd primes, k is even (so that s, s - p, s - q, s - k are integers), and s*(s - p)*(s - q)*(s - k) is a perfect square.
%C A396768 For a fixed pair of odd primes (p, q), the number of admissible k is 0, 1, or 2. This sequence only records existence (p is counted once if at least one k exists).
%C A396768 If p == q == 3 (mod 4), then no k exists. If q - p == 4 (mod 8), then no k exists.
%H A396768 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/HeronianTriangle.html">Heronian Triangle</a>
%e A396768 a(6) = 2, since for q = prime(6) = 13 two Heronian triangles with p < 13 exist: (5, 12, 13) and (11, 13, 20).
%p A396768 f := proc(x, y) option remember;
%p A396768     local k, l, r, s, t, u, v;
%p A396768     if x = 2 then return false end if;
%p A396768     if irem(x, 4) = 3 and irem(y, 4) = 3 then return false end if;
%p A396768     if irem(x - y, 8) = 4 then return false end if;
%p A396768     l := max(2, abs(x - y) + 1); if type(l, odd) then l := l + 1 end if;
%p A396768     u := x + y - 1;
%p A396768     for k from l by 2 to u do
%p A396768         s := (x + y + k)/2; v := (x + y - k)/2; r := (-x + y + k)/2; t := (x - y + k)/2;
%p A396768         if issqr(s*v*r*t) then return true end if;
%p A396768     end do;
%p A396768     false
%p A396768 end proc:
%p A396768 A := proc(n) option remember;
%p A396768     local a, i, p, q;
%p A396768     q := ithprime(n); a := 0;
%p A396768     for i from 2 to n - 1 do
%p A396768         p := ithprime(i);
%p A396768         if f(p, q) then a := a + 1 end if;
%p A396768     end do;
%p A396768     a
%p A396768 end proc:
%p A396768 seq(A(n), n = 1 .. 88);
%Y A396768 Cf. A123323, A229746, A239246, A395186, A396755, A396756.
%K A396768 nonn,new
%O A396768 1,6
