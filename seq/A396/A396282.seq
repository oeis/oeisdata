%I A396282 #16 Jun 03 2026 18:29:11
%S A396282 3,5,7,17,23,67,79,89,367,397,409,457,487,499,1031,1049,1061,1163,
%T A396282 1181,1259,1409,1481,1637,1709,1733,1811,1889,2027,2039,4111,4409,
%U A396282 4421,4561,4691,4703,4813,4889,4931,5051,5099,5209,5273,5431,5519,5839,5939,6113,6163
%N A396282 Primes q such that q - p = floor(log_2(q)), where p is the largest prime strictly less than q.
%e A396282 3 is a term because the previous prime is 2, the gap is 3-2=1, and floor(log_2(3))=1.
%e A396282 17 is a term because the previous prime is 13, the gap is 17-13=4, and floor(log_2(17))=4.
%e A396282 79 is a term because the previous prime is 73, the gap is 79-73=6, and floor(log_2(79))=6.
%t A396282 With[{ps = Prime[Range[810]]}, ps[[1 + Position[Differences[ps] - Floor[Log2[Rest[ps]]], 0] // Flatten]]] (* _Amiram Eldar_, May 21 2026 *)
%o A396282 (Python)
%o A396282 import sympy
%o A396282 def A000523(n): return n.bit_length() - 1
%o A396282 def generate_arrival_boundary_primes(limit):
%o A396282     arrival_primes = []
%o A396282     p = 2
%o A396282     while len(arrival_primes) < limit:
%o A396282         q = sympy.nextprime(p)
%o A396282         if q - p == A000523(q):
%o A396282             arrival_primes.append(q)
%o A396282         p = q
%o A396282     return arrival_primes
%o A396282 print(generate_arrival_boundary_primes(50))
%Y A396282 Cf. A000040, A000523, A001223, A396203, A396279.
