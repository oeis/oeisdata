%I A396800 #18 Jun 09 2026 19:41:38
%S A396800 1,1,2,1,2,9,1,2,15,64,1,2,21,220,625,1,2,27,472,5025,7776,1,2,33,820,
%T A396800 17165,159606,117649,1,2,39,1264,41005,885696,6593041,2097152,1,2,45,
%U A396800 1804,80505,2933046,60160723,338977416,43046721,1,2,51,2440,139625,7365456,277407235,5127074240,21032339985,1000000000
%N A396800 Rectangular table of coefficients T(n,k) of x^k/k! in F(n,x) that satisfies F(n,x) = x * exp( F^n(n,x) ) for n >= 1, as read by ascending antidiagonals.
%H A396800 Paul D. Hanna, <a href="/A396800/b396800.txt">Table of n, a(n) for n = 1..1275</a>
%F A396800 From _Seiichi Manyama_, Jun 09 2026: (Start)
%F A396800 E.g.f. F(x) satisfies F(x) = x*exp(F^l(x)), where F^l(x) denotes the l-th iterate of F.
%F A396800 Let b(n,k,l) = n! * [x^n] F^k(x), where F^k(x) is the k-th iterate of F.
%F A396800 b(1,k,l) = 1; b(n,k,l) = (1/(n-1)) * Sum_{i=1..n-1} i * binomial(n,i) * b(n-i,k,l) * Sum_{j=1..k} b(i,j+l-1,l).
%F A396800 T(n,k) = b(k,1,n). (End)
%e A396800 Let F(n,x) satisfy F(n,x) = x * exp( F^n(n,x) ) for n >= 1; then the table of coefficients T(n,k) of x^k/k! in F(n,x) begins
%e A396800   n = 1: [1, 2,  9,   64,    625,     7776, ...] = A000169;
%e A396800   n = 2: [1, 2, 15,  220,   5025,   159606, ...] = A140054;
%e A396800   n = 3: [1, 2, 21,  472,  17165,   885696, ...] = A396803;
%e A396800   n = 4: [1, 2, 27,  820,  41005,  2933046, ...] = A396804;
%e A396800   n = 5: [1, 2, 33, 1264,  80505,  7365456, ...] = A396805;
%e A396800   n = 6: [1, 2, 39, 1804, 139625, 15563526, ...] = A396806;
%e A396800   ...
%e A396800 This sequence may also be presented as a triangle:
%e A396800   1;
%e A396800   1, 2;
%e A396800   1, 2,  9;
%e A396800   1, 2, 15,   64;
%e A396800   1, 2, 21,  220,    625;
%e A396800   1, 2, 27,  472,   5025,    7776;
%e A396800   1, 2, 33,  820,  17165,  159606,    117649;
%e A396800   1, 2, 39, 1264,  41005,  885696,   6593041,    2097152;
%e A396800   1, 2, 45, 1804,  80505, 2933046,  60160723,  338977416,    43046721;
%e A396800   1, 2, 51, 2440, 139625, 7365456, 277407235, 5127074240, 21032339985, 1000000000;
%e A396800   ...
%o A396800 (PARI) \\ T(n,k) = [x^k/k!] F(n,x) = x * exp( F^n(n,x) )
%o A396800 \\ Routine to generate the n-th iteration of F:
%o A396800 {IT(n,F) = my(G=x); for(i=1,n, G = subst(F,x,G)); G}
%o A396800 \\ Calculate the terms T(n,k) of the table
%o A396800 {T(n,k) = my(Fn=x); for(j=1, k, Fn = truncate(Fn) + x*O(x^j);
%o A396800 Fn = x * exp( IT(n, Fn) ) +x*O(x^k); ); k!*polcoef(Fn, k)}
%o A396800 \\ Print as a table
%o A396800 {for(n=1,8, for(k=1,8, print1(T(n,k),", "));print(""))}
%o A396800 \\ Print as a triangle
%o A396800 {for(n=1,12, for(k=1,n, print1(T(n-k+1,k),", "));print(""))}
%Y A396800 Rows n=1..6 give A000169, A140054, A396803, A396804, A396805, A396806.
%Y A396800 Cf. A396801 (main diagonal), A396802 (antidiagonal sums).
%K A396800 nonn,tabl
%O A396800 1,3
%A A396800 _Paul D. Hanna_, Jun 09 2026
