%I A396514 #20 Jun 27 2026 16:29:42
%S A396514 0,0,1,1,3,3,5,5,8,9,9,12,11,15,21,17,15,24,17,30,33,27,21,40,34,33,
%T A396514 41,48,27,63,29,49,57,45,69,77,35,51,69,90,39,99,41,84,111,63,45,116,
%U A396514 76,102,93,102,51,123,117,140,105,81,57,192,59,87,169,129,141,171,65,138,129,207,69,225,71,105,201,156
%N A396514 a(n) = Sum_{k=1..n, k does not divide n} gcd(k,n).
%C A396514 Dirichlet convolution of n and phi(n)-1.
%F A396514 a(n) = Sum_{k=1..n} gcd(k,n) * (ceiling(n/k) - floor(n/k)).
%F A396514 a(n) = Sum_{d|n} d * (phi(n/d)-1).
%F A396514 a(n) = A018804(n) - A000203(n).
%e A396514 The numbers k, 1 <= k <= 10 that do not divide 10 are: {3,4,6,7,8,9}, so a(10) = gcd(3,10) + gcd(4,10) + gcd(6,10) + gcd(7,10) + gcd(8,10) + gcd(9,10) = 1 + 2 + 2 + 1 + 2 + 1 = 9.
%t A396514 Table[Sum[GCD[n, k]*(Ceiling[n/k] - Floor[n/k]), {k, n}], {n, 100}]
%t A396514 (* Alternative: *)
%t A396514 Table[Sum[d (EulerPhi[n/d] - 1), {d, Divisors[n]}], {n, 100}]
%Y A396514 Cf. A000010 (phi), A000203 (sigma), A018804 (Pillai's arithmetical function).
%K A396514 nonn,easy,changed
%O A396514 1,5
%A A396514 _Wesley Ivan Hurt_, Jun 25 2026
