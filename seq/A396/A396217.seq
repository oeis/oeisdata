%U A396217 45653355,40959435,69742064,74494160,74812815,104956929,170276015,134536815,188380815,186405219,175742294,235091415,229347404,239498720
%N A396217 Larger of a psi-betrothed (or psi-quasi-amicable) pair.
%C A396217 A pair (m, n) such that psi(m) = psi(n) = m + n + 1, with m < n, where psi = A001615. Each term in the sequence has opposite parity to its smaller counterpart in A396216, which follows directly from psi(m) = psi(n) = m + n + 1 and the fact that psi(k) is even for k>=3.
%C A396217 The terms are ordered according to the order of their smaller counterparts (A396216).
%e A396217 The pair (41055, 41888) is psi-betrothed because psi(41055) = psi(41888) = 82944 = 41055 + 41888 + 1.
%t A396217 f[n_] := n * Times @@ (1 + 1/Transpose[FactorInteger[n]][[1]]) - n - 1; seq[lim_] := Module[{s = {}, n}, Do[n = f[m]; If[n > m && f[n] == m, AppendTo[s, n]], {m, 1, lim}]; s]; seq[50000] (* _Amiram Eldar_, May 19 2026 *)
%Y A396217 Cf. A001615, A003503, A005276, A323330, A396216.
%K A396217 nonn,new
