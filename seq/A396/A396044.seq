%I A396044 #11 May 18 2026 10:13:14
%S A396044 0,1,2,5,6,4,9,10,7,18,14,12,8,15,24,11,30,26,22,13,25,21,42,33,78,34,
%T A396044 46,36,17,20,16,35,27,19,50,54,62,38,105
%N A396044 a(n) is the least k >= 1 such that A393641(n) is the greatest prime factor of 2^k + 1.
%C A396044 a(n) is the index of the first appearance of A393641(n) in A002587.
%F A396044 A002587(a(n)) = A393641(n).
%F A396044 a(n) = A002326((A393641(n)-1)/2) for n >= 2.
%e A396044 a(4) = 5 because the greatest prime factor of 2^5 + 1 = 33 = 3 * 11 is 11 = A393641(4), and this is the first appearance of 11 in A002587.
%p A396044 A:= 0: count:= 1: P:= {}: p:= 2:
%p A396044 while count < 37 do
%p A396044   p:= nextprime(p);
%p A396044   m:= NumberTheory:-MultiplicativeOrder(2, p);
%p A396044   if m::odd then next fi;
%p A396044   m:= m/2;
%p A396044   t:= 2^m+1;
%p A396044   t:= t/p^padic:-ordp(t, p);
%p A396044   for q in P do if t mod q = 0 then
%p A396044     t:= t/q^padic:-ordp(t, q);
%p A396044     if t = 1 then break fi;
%p A396044   fi od;
%p A396044   if t = 1 then count:= count+1; A:= A, m; fi;
%p A396044   P:= P union {p};
%p A396044 od:
%p A396044 A;
%Y A396044 Cf. A002326, A002587, A393641, A396043.
%K A396044 nonn,more
%O A396044 1,3
%A A396044 _Robert Israel_, May 14 2026
