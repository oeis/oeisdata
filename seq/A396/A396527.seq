%I A396527 #6 May 28 2026 19:37:34
%S A396527 12,50,116,242,290,212,704,662,1292,1334,2072,1892,2342,3722,3614,
%T A396527 2312,3542,4790,4412,6122,4202,3572,5702,5252,6722,5852,6512,8402,
%U A396527 10892,8192,6932,10952,10292,11972,10922,14282,11552,16382,17252,17222,18062,16172,18482,13862,20132,17852,16592,23102,22472,28382,24992,29822,28562,21212
%N A396527 a(n) is the least number that is the sum of two distinct upper twin primes in exactly n ways, or -1 if there is no such number.
%C A396527 Conjecture: a(n) > 0 for all n.
%H A396527 Robert Israel, <a href="/A396527/b396527.txt">Table of n, a(n) for n = 1..500</a>
%e A396527 a(3) = 116 because 116 = 7 + 109 = 13 + 103 = 43 + 73 is the sum of two upper twin primes in exactly 3 ways, and no smaller number works.
%p A396527 N:= 60: V:= Vector(N): V[1]:= 12: count:= 1:
%p A396527 P:= select(t -> isprime(t) and isprime(t-2), [seq(i,i=7..10^5,6)]):
%p A396527 for k from 14 by 6 to 10^5 while count < N do
%p A396527   t:= 0:
%p A396527   for i from 1 do
%p A396527     q:= k - P[i];
%p A396527     if q <= P[i] then break fi;
%p A396527     if member(q,P) then t:= t+1 fi;
%p A396527   od;
%p A396527   if t >= 2 and t <= N and V[t] = 0 then V[t]:= k; count:= count+1;  fi
%p A396527 od:
%p A396527 convert(V,list);
%Y A396527 Cf. A006512, A334160, A396487.
%K A396527 nonn
%O A396527 1,1
%A A396527 _Robert Israel_, May 28 2026
