%U A396289 10121,10830,11563,12320,13101,13906,14735,15588,16465,17366,18291,19240,20213,21210,22231,23276,24345,25438,26555,27696,28861,30050,31263,32500,33761
%N A396289 a(n) = n*(12*n+1).
%C A396289 This is one of a set of 12 sequences that specify the possible moves of a Glinski queen in hexagonal chess (see A396288 for further information).
%H A396289 Paolo Xausa, <a href="/A396289/b396289.txt">Table of n, a(n) for n = 0..10000</a>
%H A396289 <a href="/index/Rec#order_03">Index entries for linear recurrences with constant coefficients</a>, signature (3,-3,1).
%F A396289 Sum_{n>=1} 1/a(n) = 12 - 3*log(2) - 3*log(3)/2 - sqrt(3)*log(2 + sqrt(3)) - (1 + sqrt(3)/2)*Pi. - _Amiram Eldar_, May 23 2026
%t A396289 A396289[n_] := n*(12*n + 1); Array[A396289, 60, 0] (* _Paolo Xausa_, May 21 2026 *)
