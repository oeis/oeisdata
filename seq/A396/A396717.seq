%S A396717 1,2,184,1438,1972,17634,33169,45336,77352,78234,141778,167542,174852,
%T A396717 178714,184534,187616,242638,249632,313657,333635,334781,337824,
%U A396717 352744,372198,372384,442636,742169,751448,781528,785128,815456,827254,842717
%N A396717 Numbers k such that the sum of the divisors of k equals the product of the d-th triangular numbers for each digit d of k.
%C A396717 The d-th triangular number for a decimal digit d is d*(d+1)/2 = A000217(d).
%C A396717 As all triangular numbers k*(k+1)/2 where 1 <= k <= 9 are 7-smooth we must have sigma(a(n)) is 7-smooth. - _David A. Corneth_, Jun 05 2026
%H A396717 David A. Corneth, <a href="/A396717/b396717.txt">Table of n, a(n) for n = 1..15654</a> (terms <= 10^13)
%H A396717 David A. Corneth, <a href="/A396717/a396717_1.gp.txt">PARI program</a>
%F A396717 {k | A000203(k) = Product_{i=1..m} A000217(d_i), where d_i are the m digits of k}.
%e A396717 184 is a term since A000203(184) = 360 = 1*36*10 = A000217(1)*A000217(8)*A000217(4).
%t A396717 Select[Range[1, 1000000], DivisorSigma[1, #] == Times @@ ( # (# + 1)/2 & /@ IntegerDigits[#]) &]
%o A396717 (Python)
%o A396717 from math import prod
%o A396717 from sympy import divisor_sigma
%o A396717 def ok(k): return divisor_sigma(k) == prod(d*(d+1)//2 for d in map(int, str(k)))
%o A396717 print([k for k in range(1, 10**5) if ok(k)]) # _Michael S. Branicky_, Jun 03 2026
%o A396717 (PARI) isok(k) = my(d=digits(k)); sigma(k) == vecprod(vector(#d, i, d[i]*(d[i]+1)/2)); \\ _Michel Marcus_, Jun 04 2026
