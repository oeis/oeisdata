%F A396541 a(p) = 11^(p-1) for p prime. - _Daniel Suteu_, Jun 09 2026
%e A396541 a(2) = 11 because it is the smallest number > 7^(2-1) with exactly 2 divisors;
%e A396541 a(3) = 121 because it is the smallest number > 7^(3-1) with exactly 3 divisors;
%e A396541 a(4) = 346 because it is the smallest number > 7^(4-1) with exactly 4 divisors.
%o A396541 (Magma) [1] cat [Min([k: k in [7^(n-1)+1..11^(n-1)] | #Divisors(k) eq n]): n in [2..7]];
%o A396541 (PARI) a(n) = if(n<=1, return(1)); if(isprime(n), return(11^(n-1))); for(k=7^(n-1)+1, oo, if(numdiv(k) == n, return(k))); \\ _Daniel Suteu_, Jun 09 2026
