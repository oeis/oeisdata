%T A396284 2329,3208,3395,5048,4735,6649,7042,9083,9238,12583,12084,16091,16421,
%U A396284 20146,21065,26798,25518,32351,33716,40181,40290,49977,48848,59977,61006,70041,72268,87295,84266,100524,102726
%N A396284 a(n) = Sum_{k=1..n} (n mod k)^3.
%F A396284 a(n) = n^4 - Sum_{k=1..n} k * floor(n/k) * ( 3 * n^2 - 3 * n * k * floor(n/k) + ( k * floor(n/k) )^2 ).
%F A396284 a(n) = n * ( A000578(n) - 3 * ( n * A024916(n) - A350123(n) ) ) - A356249(n).
%F A396284 a(n) ~ n^4 * (1 - Pi^2/24 - Pi^4/360 - zeta(3)/4).
%t A396284 Table[Sum[Mod[n, k]^3, {k, n}], {n, 50}]
%o A396284 (Python)
%o A396284 def A396284(n):
%o A396284     c, j = n**4, 1
%o A396284     while j <= n:
%o A396284         k = n//j
%o A396284         m = n//k
%o A396284         c += (n*k**2*((a:=m*(m+1))*(2*m+1)-(b:=(j-1)*j)*(2*j-1))-3*n**2*k*(e:=a-b)>>1)-(k**3*e*(a+b)>>2)
%o A396284         j = m+1
%o A396284     return c # _Chai Wah Wu_, May 21 2026
%Y A396284 Cf. A000578, A004125, A024916, A051126, A309176, A350123, A356249, A396283.
