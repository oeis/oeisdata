%I A396041 #20 Jun 03 2026 23:37:50
%S A396041 71,79,89,199,241,271,311,409,449,479,521,569,601,631,641,751,761,769,
%T A396041 881,929,991,1031,1039,1049,1129,1151,1361,1439,1489,1831,1871,1951,
%U A396041 2081,2161,2239,2281,2311,2351,2591,2609,2671,2711,2719,2729,2791,2879,3001
%N A396041 Primes q such that q^2+1 divides p*(p+2)-1 for some prime p.
%C A396041 This list is not currently provably complete.
%C A396041 To obtain confidence that no missing q values are within the range up to prime 4999 extended searches for all compliant q values (using both expressions) were conducted using p values up to the 100000000th prime, with no new compliant q values <5000 being found, at p values beyond the 30000000th prime in either expression.
%C A396041 Particularly interesting is that the same set of primes q allows q^2+1 to divide the expression p*(p-2)-1, though, clearly, a different set of p values applies in this second case.
%e A396041 The smallest prime p that has a compliant prime q value is p=2011, with q=89. The next largest is p=6991 with q=569.
%t A396041 compliantQvalues = {};
%t A396041 Do[
%t A396041   p = Prime[n];
%t A396041   numerator = p*(p + 2) - 1;
%t A396041   Do[
%t A396041    q = Prime[i];
%t A396041    denominator = q^2 + 1;
%t A396041    If[Divisible[numerator, denominator], AppendTo[compliantQvalues, q];
%t A396041     Print[{n, p, q}]]; (*optional code to see details of each compliant event*)
%t A396041    If[denominator > numerator/2 , Break[]]
%t A396041    , {i, 1, n}];
%t A396041   If[Mod[n, 1000] == 0,
%t A396041    Print[DateObject[], " n=", n, "   ", Tally[Sort[compliantQvalues]]]]
%t A396041   , {n, 1, 100000}];
%t A396041 (* NOTE: A much larger range than this is required for any confidence*)
%K A396041 nonn,new
%O A396041 1,1
%A A396041 _Richard R. Forberg_, May 14 2026
