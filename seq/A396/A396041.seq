%I A396041 #39 Jul 15 2026 18:04:25
%S A396041 71,79,89,199,241,271,311,409,449,479,521,569,601,631,641,751,761,769,
%T A396041 881,929,991,1031,1039,1049,1129,1151,1361,1439,1489,1831,1871,1951,
%U A396041 2081,2161,2239,2281,2311,2351,2591,2609,2671,2711,2719,2729,2791,2879,3001
%N A396041 Primes q such that each prime factor of (q^2+1)/2 is congruent to 1 modulo 8.
%C A396041 Primes q such that q^2+1 divides p*(p+2)-1 for some prime p.
%C A396041 Also, primes q such that q^2+1 divides p*(p-2)-1 for some prime p.
%C A396041 In the above, the existence of an infinite number of p follows from Dirichlet's theorem on arithmetic progressions.
%C A396041 All terms are congruent to 1 or 7 modulo 8.
%C A396041 All terms are congruent to 1 or 9 modulo 10.
%C A396041 These same primes q arise with a different pair of simple algebraic expressions, again requiring an integer value. They are: (2p^2+q^2+1)^(1/2) with q<p, and (2p^2-q^2-1)^(1/2) with q^2<2p^2. But the latter expression allows for q=7 and q=41, in violation of defining rule above. - _Richard R. Forberg_, Jun 21 2026
%H A396041 Wikipedia, <a href="https://en.wikipedia.org/wiki/Dirichlet%27s_theorem_on_arithmetic_progressions">Dirichlet's theorem on arithmetic progressions</a>.
%e A396041 89 is a term since (89^2 + 1)/2 = 3961 = 17 * 233 and both 17 and 233 are primes congruent to 1 modulo 8. The least prime p such that p*(p+2)-1 is a multiple of 3961 is 2011. The least prime p such that p*(p-2)-1 is a multiple of 3961 is 5741.
%t A396041 listA396041 = {};
%t A396041 Do[q = Prime[j];
%t A396041   flist = FactorInteger[(q^2 + 1)/2];
%t A396041   pflist = {};
%t A396041   qStatus = True;  (*Assume True at this point*)
%t A396041 Do[pf = flist[[f]][[1]];
%t A396041    If[Mod[(pf^2 + 1)/2, 8] != 1, qStatus = False;
%t A396041     Break[]],
%t A396041 {f, 1, Length[flist]}];
%t A396041   If[qStatus == False, Continue[], AppendTo[listA396041, q]],
%t A396041 {j, 2, 500}];
%Y A396041 Cf. A004625, A007519.
%K A396041 nonn,changed
%O A396041 1,1
