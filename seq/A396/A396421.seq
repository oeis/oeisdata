%N A396421 a(n) = r(n,n), where r(1,k)=f(k)=ceiling(k*c), r(n,k)=f(r(n-1,k)), c=4/3.
%C A396421 a(n + 1)/a(n) approaches c erratically.
%t A396421 c = 4/3; f[k_] := f[k] = Ceiling[c*k];
%t A396421 r[1, k_] := f[k]; r[n_, k_] := r[n, k] = f[r[n - 1, k]];
%t A396421 Table[r[n, n], {n, 1, 100}]
%Y A396421 Cf. A396385, A396420, A396422.
%K A396421 nonn
