%S A396904 2,5,21,46,80,155,9,20,35,16,30,1,6,13,25,41,21,78,154,255,380,72,146,
%T A396904 245,370,14,42,88,88,150,150,250,250,375,117,117,228,375,375,525,525,
%U A396904 700,700,111,220,365,515,690,8,11,15,36,43,56,65,65,75,175,191,191,208,25
%N A396904 a(n) = number of total diagonals in Johnson solid J_n.
%C A396904 The total number of diagonals is the number of space diagonals plus the number of diagonals in all faces.
%H A396904 Paolo Xausa, <a href="/A396904/b396904.txt">Table of n, a(n) for n = 1..92</a> (the full sequence).
%H A396904 Wikipedia, <a href="https://en.wikipedia.org/wiki/List_of_Johnson_solids">List of Johnson solids</a>.
%F A396904 a(n) = A396905(n) + A396906(n).
%F A396904 a(n) = binomial(A242733(n),2) - A242732(n).
%e A396904 a(6) = 90 + 65 = 155 because Johnson solid J_6 (pentagonal rotunda) has 90 space diagonals and 65 face diagonals (see A396906 Example).
%t A396904 Binomial[#, 2] - #2 & @@@ Array[PolyhedronData[{"Johnson", #}, {"VertexCount", "EdgeCount"}] &, 92]
%Y A396904 Cf. A242732, A242733, A396905, A396906.
%K A396904 nonn,fini,full,new
%O A396904 1,1
%A A396904 _Paolo Xausa_, Jun 09 2026
