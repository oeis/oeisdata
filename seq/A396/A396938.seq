%T A396938 1,6,1,1,1,4,1,1,1,2,2,1,1,8,2,3,1,2,1,9,1,4,1,1,1,2,1,1,2,32,1,1,1,2,
%U A396938 1,1,1,12,1,1,3,2,1,1,1,8,8,1,1,2,1,1
%N A396938 a(1) = 1, a(n) = Product_{i=1..omega(n)} prime(i)^(m_i-1), with n = Product_{i=1..omega(n)} p_i^m_i, omega = A001221, and p_i < p_(i+1).
%C A396938 Similar to A071364, which instead furnishes Product_{i=1..omega(k)} prime(i)^m_i.
%C A396938 a(A151821(i)) = i represents a record in this sequence.
%H A396938 Michael De Vlieger, <a href="/A396938/b396938.txt">Table of n, a(n) for n = 1..10000</a>
%H A396938 Michael De Vlieger, <a href="/A396938/a396938.png">Log log scatterplot of a(n)</a>, n = 1..2^20.
%F A396938 a(k) = A003557(k) for k in A055932.
%F A396938 a(p^m) = 2^(m-1) for prime p and m > 0.
%F A396938 a(k) = 1 for squarefree k.
%e A396938 Let s = A071364.
%e A396938 Table of n, a(n), s(n) for select n:
%e A396938       n    a(n)                s(n)
%e A396938   ---------------------------------------------
%e A396938       1      1                   2
%e A396938       2      1                   2
%e A396938       3      1                   2
%e A396938       4      2                   4 = 2^2
%e A396938       5      1                   2
%e A396938       6      1                   6 = 2   * 3
%e A396938      18      3                  18 = 2   * 3^2
%e A396938      20      2                  12 = 2^2 * 3
%e A396938     100      6 = 2   * 3        36 = 2^2 * 3^2
%e A396938     108     18 = 2   * 3^2     108 = 2^2 * 3^3
%e A396938     144     24 = 2^3 * 3       144 = 2^4 * 3^2
%e A396938   11664   1944 = 2^3 * 3^5   11664 = 2^4 * 3^6
%t A396938 f[x_] := Times @@ MapIndexed[Prime[First[#2] ]^(#1 - 1) &, FactorInteger[x][[All, -1]] ]; Array[f, 100]
%Y A396938 Cf. A001221, A003557, A007947, A055932, A071364, A124010, A151821.
