%N A396677 Expansion of e.g.f. log(1 - W_2(-x)), where W_k(x) is the k-th iterate of LambertW(x).
%F A396677 a(n) = Sum_{k=1..n} n^(n-k) * binomial(n-1,k-1) * A133297(k).
%F A396677 a(n) = (n-1)! * Sum_{i,j,k >= 0 and i+j+k=n-1} (-1)^k * n^i * (n-i)^j / (i!*j!).
%o A396677 (PARI) my(N=20, x='x+O('x^N)); Vec(serlaplace(log(1-lambertw(lambertw(-x)))))
