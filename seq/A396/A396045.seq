%S A396045 1,3,62,1727,55626,1948659,72105322,2772842625,109721840634,
%T A396045 4438489469522,182721040524420,7630236473954845,322425648343135346,
%U A396045 13761231269729899515,592367065584110897850,25687882751764659893607,1121148131510985381011466,49210890372474137661480894
%N A396045 a(n) = T(n, 2*n), where T(n, m) is the forward-difference table of the Catalan numbers.
%C A396045 This is the r = 2 case of the family a_r(n) = T(n, r*n), where T is the forward-difference table of the Catalan numbers. The cases r = 0 and r = 1 give A005043 and A220097, respectively.
%H A396045 Paolo Xausa, <a href="/A396045/b396045.txt">Table of n, a(n) for n = 0..597</a>
%F A396045 a(n) = T(n, 2*n), where T(0, m) = A000108(m) and T(n, m) = T(n - 1, m + 1) - T(n - 1, m) for n>0.
%F A396045 a(n) = Sum_{k=0..n} (-1)^(n - k)*binomial(n, k)*A000108(2*n + k).
%F A396045 a(n) = (2/Pi)*Integral_{t=0..1} sqrt((1-t)/t)*(64*t^3-16*t^2)^n dt.
%F A396045 a(n) = (-1)^n*A000108(2*n)*hypergeom([-n, 2*n + 1/2], [2*n + 2], 4). - _Peter Luschny_ and _Paolo Xausa_, May 20 2026
%e A396045 The array T(n, m) begins (with T(n, 2*n) entries bracketed):
%e A396045   row n=0  [1]   1    2     5     14    42      132      429        1430
%e A396045   row n=1   0    1   [3]    9     28    90      297     1001        3432
%e A396045   row n=2   1    2    6    19    [62]   207     704     2431        8502
%e A396045   row n=3   1    4   13    43    145    497   [1727]    6071       21554
%e A396045   row n=4   3    9   30   102    352   1230    4344    15483      [55626]
%t A396045 A396045[n_] := Sum[(-1)^(n-k)*Binomial[n, k]*CatalanNumber[2*n + k], {k, 0, n}];
%t A396045 Array[A396045, 20, 0] (* _Paolo Xausa_, May 19 2026 *)
%t A396045 (* Alternative: *)
%t A396045 A396045[n_] := (-1)^n*CatalanNumber[2*n]*Hypergeometric2F1[-n, 2*n + 1/2, 2*n + 2, 4];
%t A396045 Array[A396045, 20, 0] (* _Paolo Xausa_, May 19 2026 *)
%Y A396045 Cf. A000108, A005043, A220097.
%K A396045 nonn
%O A396045 0,2
