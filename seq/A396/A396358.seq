%N A396358 a(n) = J((n-1)*(n+1))/(J(n-1)*J(n+1)), where J(n) is the n-th Jacobsthal number A001045(n).
%H A396358 Alois P. Heinz, <a href="/A396358/b396358.txt">Table of n, a(n) for n = 0..58</a>
%F A396358 a(n) = J((n-1)*(n+1))/(J(n-1)*J(n+1)) with J(n) = ((1+sqrt(9))^n - (1-sqrt(9))^n)/(2^n*sqrt(9)). a(1) = 2 is found by taking the limit of the quotient for n->1.
%F A396358 a(n) mod 3 = A000034(n).
%F A396358 a(n) mod 2 = A060576(n).
%p A396358 J:= n-> ((1+sqrt(9))^n-(1-sqrt(9))^n)/(2^n*sqrt(9)):
%p A396358 a:= n-> `if`(n=1, 2, J((n-1)*(n+1))/(J(n-1)*J(n+1))):
%p A396358 seq(a(n), n=0..14);
