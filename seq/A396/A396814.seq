%I A396814 #10 Jun 30 2026 07:27:10
%S A396814 0,1,2,5,6,11,14,21,24,33,38,49,54,67,74,89,96,113,122,141,150,171,
%T A396814 182,205,216,241,254,281,294,323,338,369,384,417,434,469,486,523,542,
%U A396814 581,600,641,662,705,726,771,794,841,864,913,938,989,1014,1067,1094,1149,1176,1233,1262,1321,1350
%N A396814 Upper (1/2,1) midsequence of (floor[n/2]^2) and (ceiling[n/2]^2); see Comments.
%C A396814 Suppose that s = (s(n)) and t = (t(n)) are sequences of numbers and h > 0 and k > 0. The lower (h, k)-midsequence of s and t is floor(h*s + k*t); the upper (h, k)-midsequence of s and t is ceiling(h*s + k*t).
%H A396814 <a href="/index/Rec#order_07">Index entries for linear recurrences with constant coefficients</a>, signature (1,1,-1,1,-1,-1,1).
%F A396814 a(n) = a(n-1) + a(n-2) - a(n-3) + a(n-6) - a(n-7) - a(n-8) + a(n-9), with (a(0),...,a(8)) = (0, 1, 2, 5, 6, 11, 14, 21).
%F A396814 G.f.: x*(-1 - x - 2*x^2 - x^4 - x^5)/((-1 + x)^3*(1 + x)^2*(1 + x^2)).
%F A396814 (-n+2)*a(n) +a(n-1) +3*a(n-2) +a(n-3) +(n+1)*a(n-4) +4*(n-4)=0. - _R. J. Mathar_, Jun 30 2026
%e A396814 s(n) = A008794(n+1):  (0, 1, 1, 4, 4, 9, 9, 16, 16, ...).
%e A396814 t(n) = A008794(n+2):  (1, 1, 4, 4, 9, 9, 16, 16, 25, ...).
%e A396814 (u(n)) = (0, 1, 1, 4, 6, 11, 13, 20, 24, 33, 37, 48, ...).
%e A396814 (v(n)) = (0, 1, 2, 5, 6, 11, 14, 21, 24, 33, 38, 49, ...).
%t A396814 z = 60; f[n_] := Floor[n/2]^2; g[n_] := Ceiling[n/2]^2;
%t A396814 r = 1/2; s = 1;
%t A396814 u[n_] := Floor[r*f[n] + s*g[n]]
%t A396814 v[n_] := Ceiling[r*f[n] + s*g[n]]
%t A396814 Table[u[n], {n, 0, z}]
%t A396814 Table[v[n], {n, 0, z}]
%t A396814 (* Also *)
%t A396814 LinearRecurrence[{1, 1, -1, 1, -1, -1, 1}, {0, 1, 1, 4, 6, 11, 13}, 30]
%t A396814 LinearRecurrence[{1, 1, -1, 1, -1, -1, 1}, {0, 1, 2, 5, 6, 11, 14}, 30]
