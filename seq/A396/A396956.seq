%I A396956 #14 Jun 22 2026 21:28:41
%S A396956 -1,-2,-1,-3,1,-2,2,-1,2,1,6,-1,6,5,7,2,13,5,14,4,11,12,18,6,16,15,15,
%T A396956 12,24,12,25,13,21,25,25,13,31,29,22,20,35,23,37,27,29,34,40,21,40,32,
%U A396956 42,35,47,32,42,35,47,47,52,29,52,49,45,37,49,42,59,50,54
%N A396956 a(n) = n - Omega(|Re((3 + 2*i)^n)|) - Omega(|Im((3 + 2*i)^n)|), where Omega is A001222.
%C A396956 Let u(n) + i*v(n) = (3 + 2*i)^n, so that u(n)^2 + v(n)^2 = 13^n, where 13 == 1 (mod 4); such primes admit a representation as a sum of two squares. Then a(n) = n - Omega(u(n)) - Omega(v(n)) = Omega(u(n)^2 + v(n)^2) - Omega(u(n)) - Omega(v(n)). The values u(n) and v(n) can be computed via the recurrence u(n + 1) = 3*u(n) - 2*v(n), v(n + 1) = 2*u(n) + 3*v(n), with u(1) = 3 and v(1) = 2.
%C A396956 Since u(n)^2 + v(n)^2 = 13^n and gcd(u(n), v(n)) = 1 (any common divisor must divide 13^n), the triple (u(n)^2 - v(n)^2, 2*u(n)*v(n), u(n)^2 + v(n)^2) is a primitive Pythagorean triple for all n >= 1.
%C A396956 Thus a(n) compares the additive prime factor count of the norm 13^n with that of its Gaussian components u(n) and v(n).
%C A396956 Large positive values of a(n) occur when both u(n) and v(n) have relatively few prime factors.
%C A396956 Since |u(n)| and |v(n)| are of order about p^(n/2), probabilistic number theory suggests that Omega(u(n)) and Omega(v(n)) grow roughly like log log |u(n)|, which is about log(n). A refined heuristic suggests a(n) ~ n - 2*log(n) - C_p, where C_p = 2*(log(log(p)) - log(2) + B), with p = u(1)^2 + v(1)^2 and B the Meissel-Mertens constant (A077761). Fluctuations around this trend are of order sqrt(log(n)) and are governed by Erdős-Kac type behavior of Omega. For p = 13 this gives C_p ~ 1.02, explaining the observed downward shift, see linked graph.
%H A396956 Felix Huber, <a href="/A396956/a396956.pdf">Growth of a(n)</a>.
%H A396956 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/Erdos-KacTheorem.html">Erdős-Kac Theorem</a>.
%H A396956 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/Hardy-RamanujanTheorem.html">Hardy-Ramanujan Theorem</a>.
%H A396956 Wikipedia, <a href="https://en.wikipedia.org/wiki/Fermat%27s_theorem_on_sums_of_two_squares">Fermat's theorem on sums of two squares</a>.
%F A396956 a(n) = n - A001222(A188983(n)) - A001222(A188982(n)).
%e A396956 a(2) = -2 since (3 + 2*i)^2 = 5 + 12*i, so Omega(5) = 1, Omega(12) = 3 and hence 2 - 1 - 3 = -2.
%e A396956 a(11) = 6 since (3 + 2*i)^11 = 341525 + 2529647*i, so Omega(341525) = 4, Omega(2529647) = 1 and hence 11 - 4 - 1 = 6.
%p A396956 with(NumberTheory):
%p A396956 A396956List := proc(N)
%p A396956     local a, b, k, u, v;
%p A396956     u := 3;
%p A396956     v := 2;
%p A396956     a := Vector(N);
%p A396956     for k from 1 to N do
%p A396956         a[k] := k - Omega(abs(u)) - Omega(abs(v));
%p A396956         b := 3*u - 2*v;
%p A396956         v := 2*u + 3*v;
%p A396956         u := b;
%p A396956     end do;
%p A396956     convert(a, list)
%p A396956 end proc:
%p A396956 A396956List(70);
%t A396956 Table[n - PrimeOmega@ Abs@ Re[#] - PrimeOmega@ Abs@ Im[#] &[(3 + 2*I)^n], {n, 69}] (* _Michael De Vlieger_, Jun 18 2026 *)
%Y A396956 Cf. A000351, A001222, A002144, A077761, A188982, A188983, A396955, A396957, A396958, A396959.
%K A396956 sign,new
%O A396956 1,2
