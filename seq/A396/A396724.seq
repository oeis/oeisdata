%U A396724 854091531907,3920036136778,17862714586762,80870371149748,363985389650602,1629529723109308,7259813777148532
%N A396724 a(n) = (-4^n/2) p(n, -3/2), where p(n,x) is the Lagrange interpolating polynomial through (1,0) and (k,1) for k=2..n+1.
%t A396724 t[0] = {0}; t[n_] := t[n] = Join[t[n - 1], {1}];
%t A396724 p[n_, x_] := Expand[InterpolatingPolynomial[t[n], x]];
%t A396724 Table[(-4^n/2) p[n, -3/2], {n, 0, 40}]
%t A396724 Labeled[Plot[{p[1, x], p[2, x], p[3, x], p[4, x], p[5, x]}, {x, -1, 7}], "Plot of p[n,x] for n=1..5."]
