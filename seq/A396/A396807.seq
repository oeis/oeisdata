%I A396807 #9 Jun 18 2026 00:43:54
%S A396807 1,1,11,201,4721,129671,3976201,132554541,4724742051,178052854981,
%T A396807 7038323735281,290148008603631,12419333556374881,550091361259038561,
%U A396807 25145997103468438771,1183773515790240935841,57289367885575671008761,2846138707414273744227111,144972933910530413441182881
%N A396807 G.f. satisfies A(x) = x + A^5(x)*A^6(x).
%C A396807 Conjecture: a(n) = 1 (mod 10) for n >= 1.
%C A396807 Conjecture: [x^n] A^k(x) == k^(n-1) (mod 10) for n >= 1 and all integer k.
%H A396807 Paul D. Hanna, <a href="/A396807/b396807.txt">Table of n, a(n) for n = 1..400</a>
%F A396807 G.f. A(x) = Sum_{n>=1} a(n)*x^n has the following properties, where A^n(x) denotes the n-th iteration of A(x).
%F A396807 (1.a) A(x) = x + A^5(x)*A^6(x).
%F A396807 (1.b) A(x) = x + A^4(x)*A^6(x) + A^6(x)*A^9(x)*A^10(x).
%F A396807 (1.c) A(x) = x + A^5(x)^2 + A^5(x)*A^10(x)*A^11(x).
%F A396807 (2.a) A(x) = A^2(x) - A^6(x)*A^7(x).
%F A396807 (2.b) A(x) = A^3(x) - A^6(x)*A^7(x) - A^7(x)*A^8(x).
%F A396807 (2.c) A(x) = A^4(x) - A^6(x)*A^7(x) - A^7(x)*A^8(x) - A^8(x)*A^9(x).
%F A396807 (2.d) A(x) = A^n(x) - Sum_{k=1..n-1} A^(k+5)(x) * A^(k+6)(x) for n >= 1.
%F A396807 (3.a) A(x) = x + Sum_{n>=1} d^(n-1)/dx^(n-1) A^4(x)^n*A^5(x)^n / n!.
%F A396807 (3.b) A(x) = x * exp( Sum_{n>=1} d^(n-1)/dx^(n-1) ( A^4(x)^n*A^5(x)^n/x ) / n! ).
%F A396807 (4.a) x = A( x - A^4(x)*A^5(x) ).
%F A396807 (4.b) x = A( x - A^3(x)*A^5(x) - A^5(x)*A^8(x)*A^9(x) ).
%F A396807 (4.c) x = A( x - A^4(x)^2 - A^4(x)*A^9(x)*A^10(x) ).
%F A396807 (5.a) x = A^2( x - A^3(x)*A^4(x) - A^4(x)*A^5(x) ).
%F A396807 (5.b) x = A^2( x - A^3(x)^2 - A^4(x)*A^5(x) - A^3(x)*A^8(x)*A^9(x) ).
%F A396807 (5.c) x = A^2( x - A^2(x)*A^4(x) - A^4(x)*A^5(x) - A^4(x)*A^7(x)*A^8(x) ).
%F A396807 (6.a) x = A^3( x - A^2(x)*A^3(x) - A^3(x)*A^4(x) - A^4(x)*A^5(x) ).
%F A396807 (6.b) x = A^3( x - A^2(x)^2 - A^3(x)*A^4(x) - A^4(x)*A^5(x) - A^2(x)*A^7(x)*A^8(x) ).
%F A396807 (7.a) x = A^4( x - A(x)*A^2(x) - A^2(x)*A^3(x) - A^3(x)*A^4(x) - A^4(x)*A^5(x) ).
%F A396807 (7.b) x = A^4( x - A(x)^2 - A^2(x)*A^3(x) - A^3(x)*A^4(x) - A^4(x)*A^5(x) - A(x)*A^6(x)*A^7(x) ).
%F A396807 (8.a) x = A^5( x - x*A(x) - A(x)*A^2(x) - A^2(x)*A^3(x) - A^3(x)*A^4(x) - A^4(x)*A^5(x) ).
%F A396807 (8.b) x = A^5( x-x^2 - A(x)*A^2(x) - A^2(x)*A^3(x) - A^3(x)*A^4(x) - A^4(x)*A^5(x) - x*A^5(x)*A^6(x) ).
%F A396807 (8.c) x = A^6( x-x^2 - x*A(x) - A(x)*A^2(x) - A^2(x)*A^3(x) - A^3(x)*A^4(x) - (1-x)*A^4(x)*A^5(x) ).
%e A396807 G.f.: A(x) = x + x^2 + 11*x^3 + 201*x^4 + 4721*x^5 + 129671*x^6 + 3976201*x^7 + 132554541*x^8 + 4724742051*x^9 + 178052854981*x^10 + ...
%e A396807 The initial iterations of A(x) begin as follows.
%e A396807 A^2(x) = x + 2*x^2 + 24*x^3 + 458*x^4 + 11066*x^5 + 310332*x^6 + 9672854*x^7 + 326832718*x^8 + 11783490796*x^9 + ...
%e A396807 A^3(x) = x + 3*x^2 + 39*x^3 + 777*x^4 + 19331*x^5 + 554243*x^6 + 17585629*x^7 + 603117347*x^8 + 22025611951*x^9 + ...
%e A396807 A^4(x) = x + 4*x^2 + 56*x^3 + 1164*x^4 + 29836*x^5 + 875444*x^6 + 28308636*x^7 + 986652484*x^8 + 36542654956*x^9 + ...
%e A396807 A^5(x) = x + 5*x^2 + 75*x^3 + 1625*x^4 + 42925*x^5 + 1289875*x^6 + 42546665*x^7 + 1508506325*x^8 + 56721159775*x^9 + ...
%e A396807 A^6(x) = x + 6*x^2 + 96*x^3 + 2166*x^4 + 58966*x^5 + 1815496*x^6 + 61128146*x^7 + 2206529506*x^8 + 84303753136*x^9 + ...
%e A396807 where A(x) = x + A^5(x) * A^6(x).
%e A396807 Let R(x) = A^(-1)(x) satisfy R(A(x)) = x, then
%e A396807 R(x) = x - x^2 - 9*x^3 - 151*x^4 - 3369*x^5 - 89281*x^6 - 2664499*x^7 - 86925021*x^8 - 3043228149*x^9 + ...
%e A396807 where R(x) = x - A^4(x)*A^5(x).
%e A396807 Therefore, g.f. A(x) satisfies
%e A396807 A(x) = x + A^4(x)*A^5(x) + d/dx (A^4(x)*A^5(x))^2/2! + d^2/dx^2 (A^4(x)*A^5(x))^3/3! + d^3/dx^3 (A^4(x)*A^5(x))^4/4! + d^4/dx^4 (A^4(x)*A^5(x))^5/5! + ...
%e A396807 Also, g.f. A(x) is the unique solution to variable A in the infinite system of simultaneous equations starting with:
%e A396807   A = x + E*F;
%e A396807   B = A + F*G;
%e A396807   C = B + G*H;
%e A396807   D = C + H*I;
%e A396807   E = D + I*J; ...
%e A396807 resulting in B = A^2(x), C = A^3(x), D = A^4(x), etc.
%o A396807 (PARI) \\ By definition A(x) = x + A^5(x)*A^6(x)
%o A396807 \\ ('truncate' is used here to reduce runtime)
%o A396807 {a(n) = my(A=x, A2, A3); for(i=1, n, A=truncate(A) +x^2*O(x^i);
%o A396807 A2 = subst(A, x, A); A3 = subst(A, x, A2);
%o A396807 A = x + subst(A2*A3, x, A3) +x*O(x^n)); polcoef(GF=A, n)}
%o A396807 {upto(n) = a(n); Vec(GF)}
%o A396807 upto(30)
%o A396807 (PARI) \\ Using series reversion of x - A^4(x)*A^5(x)
%o A396807 \\ ('truncate' is used here to reduce runtime)
%o A396807 {a(n) = my(A=x, A2, A3); for(i=1, n, A=truncate(A) +x^2*O(x^i);
%o A396807 A2 = subst(A, x, A); A3 = subst(A, x, A2);
%o A396807 A = serreverse(x - subst(A2*A3, x, A2) +x*O(x^n)) ); polcoef(GF=A, n)}
%o A396807 {upto(n) = a(n); Vec(GF)}
%o A396807 upto(30)
%Y A396807 Cf. A396797, A396798, A396099, A213591.
%K A396807 nonn
%O A396807 1,3
%A A396807 _Paul D. Hanna_, Jun 16 2026
