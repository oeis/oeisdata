%N A396675 Square array A(n,k), n>=1, k>=0, read by antidiagonals downwards, where A(n,k) = n! * [x^n] log(1 - W_k(-x)) and W_k(x) is the k-th iterate of LambertW(x).
%F A396675 A(n,0) = (-1)^(n-1) * (n-1)!; A(n,k) = Sum_{j=1..n} n^(n-j) * binomial(n-1,j-1) * A(j,k-1) for k > 0.
%F A396675 A(n,k) = (n-1)! * Sum_{x_1, x_2, ..., x_{k+1} >= 0 and x_1 + x_2 + ... + x_{k+1} = n-1} (-1)^(x_{k+1}) * Product_{i=1..k} ((n - Sum_{j=1..i-1} x_j)^(x_i) / x_i!).
%e A396675 Square array begins:
%e A396675      1,    1,     1,      1,       1,       1,       1, ...
%e A396675     -1,    1,     3,      5,       7,       9,      11, ...
%e A396675      2,    5,    20,     47,      86,     137,     200, ...
%e A396675     -6,   34,   206,    654,    1522,    2954,    5094, ...
%e A396675     24,  329,  2884,  12129,   35384,   82849,  167604, ...
%e A396675   -120, 4056, 51222, 282318, 1023324, 2871660, 6782586, ...
%e A396675   ...
%o A396675 (PARI) a(n, k) = if(k==0, (-1)^(n-1)*(n-1)!, sum(j=1, n, n^(n-j)*binomial(n-1, j-1)*a(j, k-1)));
%Y A396675 Columns k=0..3 give A133942(n-1), A133297, A396677, A396678.
%Y A396675 Cf. A274391, A396498, A396676.
%K A396675 sign,tabl
%O A396675 1,6
%A A396675 _Seiichi Manyama_, Jun 02 2026
