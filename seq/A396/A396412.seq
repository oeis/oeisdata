%S A396412 1,1,0,1,1,0,1,2,3,0,1,3,8,12,0,1,4,15,40,55,0,1,5,24,90,224,273,0,1,
%T A396412 6,35,168,595,1345,1428,0,1,7,48,280,1280,4184,8472,7752,0,1,8,63,432,
%U A396412 2415,10306,30730,55279,43263,0,1,9,80,630,4160,21895,86336,233216,370654,246675,0
%N A396412 Square array A(n,k), n>=0, k>=0, read by antidiagonals downwards, where A(n,k) = [x^n] F_k(x)/x and F_k(x) is the k-th iteration of x*G3(x) with G3(x) = 1 + x*G3(x)^3.
%F A396412 G.f. of column k: (1/x) * Series_Reversion( H_k(x) ), where H_k(x) is the k-th iteration of x*(1 - x*C(x)) with C(x) = 1 + x*C(x)^2.
%F A396412 A(n,k) = Sum_{0 = x_0 <= x_1 <= ... <= x_{k-1} <= x_k = n} Product_{j=0..k-1} (x_j + 1) * binomial(3*x_{j+1} - 2*x_j + 1,x_{j+1} - x_j)/(3*x_{j+1} - 2*x_j + 1).
%e A396412 Square array begins:
%e A396412   1,    1,    1,     1,     1,      1,      1, ...
%e A396412   0,    1,    2,     3,     4,      5,      6, ...
%e A396412   0,    3,    8,    15,    24,     35,     48, ...
%e A396412   0,   12,   40,    90,   168,    280,    432, ...
%e A396412   0,   55,  224,   595,  1280,   2415,   4160, ...
%e A396412   0,  273, 1345,  4184, 10306,  21895,  41923, ...
%e A396412   0, 1428, 8472, 30730, 86336, 205848, 436856, ...
%e A396412   ...
%o A396412 (PARI)
%o A396412 a(n, k, m=3) = {
%o A396412   my(T=matrix(n+1, n+1, r, c, my(xr=r-1, xc=c-1); if(xc<xr, 0, (xr+1)*binomial(m*xc-(m-1)*xr+1, xc-xr)/(m*xc-(m-1)*xr+1))));
%o A396412   my(TK=T^k);
%o A396412   TK[1, n+1];
%o A396412 };
%Y A396412 Columns k=0..3 give A000007, A001764, A396414, A396415.
%Y A396412 Cf. A000108, A158825, A396413.
%K A396412 nonn,tabl,new
