%N A396393 a(n) = r(n,n), where r(1,k)=f(k)=floor(k*c), r(n,k)=f(r(n-1,k)), c=(golden ratio)^2.
%C A396393 a(n + 1)/a(n) approaches c erratically.
%t A396393 c = GoldenRatio^2; f[k_] := f[k] = Floor[c*k];
%t A396393 r[1, k_] := f[k]; r[n_, k_] := r[n, k] = f[r[n - 1, k]];
%t A396393 Table[r[n, n], {n, 1, 100}]
