%T A396547 233,251,257,353,359,383,401,421,433,463,479,487,563,569,571,577,631,
%U A396547 641,769,809,839,857,859,863,929,1051,1097,1153,1171,1193,1283,1291,1297,1303,1319,1409,1429,1433,1459
%N A396547 Primes p such that the sum of the distinct prime factors of p-1 is prime.
%H A396547 Vincenzo Manto, <a href="/A396547/b396547.txt">Table of n, a(n) for n = 1..10000</a>
%p A396547 filter:= proc(n) isprime(n) and isprime(convert(NumberTheory:-PrimeFactors(n-1),`+`)) end proc:
%p A396547 select(filter, [seq(i,i=3..2000)]); # _Robert Israel_, May 29 2026
%t A396547 Select[Prime[Range[300]], PrimeQ[Total[FactorInteger[# - 1][[All, 1]]]] &]
%o A396547 (Python)
%o A396547 from sympy import isprime, primerange, primefactors
%o A396547 def sequence(limit):
%o A396547     res = []
%o A396547     for p in primerange(2, limit):
%o A396547         if isprime(sum(primefactors(p - 1))):
%o A396547             res.append(p)
%o A396547     return res
%o A396547 print(sequence(2000))
%Y A396547 Cf. A008472, A023507.
%K A396547 nonn
%O A396547 1,1
%A A396547 _Vincenzo Manto_, May 28 2026
