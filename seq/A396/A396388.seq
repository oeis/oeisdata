%N A396388 a(n) = r(n,n), where r(1,k)=f(k)=ceiling(k*c), r(n,k)=f(r(n-1,k)), c=e.
%C A396388 a(n + 1)/a(n) approaches c erratically.
%t A396388 c = E; f[k_] := f[k] = Ceiling[c*k];
%t A396388 r[1, k_] := f[k]; r[n_, k_] := r[n, k] = f[r[n - 1, k]];
%t A396388 Table[r[n, n], {n, 1, 100}]
