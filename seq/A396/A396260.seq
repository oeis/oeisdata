%U A396260 6,0,9,5,7,3,6,9,4,6,1,8,5,3,7,2,7,8,2,7,5,2
%N A396260 Decimal expansion of the largest root to 8*x^3 - 42*x - 7 = 0.
%C A396260 Real part of the Gauss sum tau(chi^2) = Sum_{a=0..6} chi(a)^2*exp(2*Pi*i/7), where chi is the Dirichlet character modulo 7 such that chi(3) = exp(2*Pi*i/6). Note that tau(chi^2) is a root to x^6 - 7*x^3 + 343 = 0.
%H A396260 Paolo Xausa, <a href="/A396260/b396260.txt">Table of n, a(n) for n = 1..10000</a>
%H A396260 <a href="/index/Al#algebraic_03">Index entries for algebraic numbers, degree 3</a>.
%e A396260 2.37046940557620059157...
%t A396260 First[RealDigits[Root[8*#^3 - 42*# - 7 &, 3], 10, 100]] (* _Paolo Xausa_, May 21 2026 *)
%o A396260 (PARI) solve(x=2.3, 2.4, 8*x^3 - 42*x - 7)
%Y A396260 See A396258 for table of Gauss sums of nontrivial Dirichlet characters modulo 7.
%K A396260 nonn,cons,easy
%O A396260 1,1
