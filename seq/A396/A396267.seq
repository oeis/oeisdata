%I A396267 #7 May 28 2026 21:35:48
%S A396267 10,17,22,53,37,48,47,109,66,74,78
%N A396267 a(n) is the smallest number k such that k^n is the sum of 4n distinct positive n-th powers.
%e A396267 10^1 = 4^1+3^1+2^1+1^1;
%e A396267 17^2 = 11^2+8^2+7^2+5^2+4^2+3^2+2^2+1^2;
%e A396267 22^3 = 16^3+13^3+12^3+11^3+8^3+7^3+6^3+5^3+4^3+3^3+2^3+1^3;
%e A396267 53^4 = 40^4+36^4+34^4+32^4+30^4+20^4+18^4+16^4+15^4+14^4+12^4+10^4+8^4+6^4+4^4+2^4;
%e A396267 37^5 = 30^5+28^5+27^5+25^5+17^5+15^5+14^5+13^5+12^5+11^5+10^5+9^5+8^5+7^5+6^5+5^5+4^5+3^5+2^5+1^5;
%e A396267 ...
%t A396267 a[n_] := FirstCase[Range[n, 60], k_ /; Length[Select[IntegerPartitions[k^n, {4 n}, Range[k - 1]^n], DuplicateFreeQ]] > 0]; Array[a, 7]
