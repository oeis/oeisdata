%I A396268 #6 May 21 2026 07:53:08
%S A396268 -1,-1,2,3,7,-1,53,2557,1831,7417,241,-1,211,17761,91873,2971,10531,
%T A396268 238801,6581,22193,311041,979651,29641,1205779,912871,535879,2066329,
%U A396268 17689267,159361,-1,3728561,44823187,19020961,746776801,510187681,4060716103,28057681,527049541,1183533067
%N A396268 a(n) is the least prime p such that, if q is the next prime after p, (p mod n) > (q mod n) while (p mod k) <= (q mod k) for all k < n, or -1 of there is no such p.
%C A396268 a(n) = prime(k) for the least k such that A121889(k) = n, or -1 if there is no such k.
%e A396268 a(5) = 7 because 7 is prime, the next prime is 11, (7 mod 5) = 2 > (11 mod 5) = 1, while (7 mod k) <= (11 mod k) for k = 1, 2, 3 and 4.
%e A396268 a(6) = -1 because there are no such p.  The only possibility for (p,q) mod 6 where p and q are primes > 6 and (p mod 6) > (q mod 6) is (5,1), but in that case (p mod 3) = 2 > (q mod 3) = 1.
%p A396268 V:= Vector(39):
%p A396268 check:= proc(m) local P, nP, Cands,i,j,D;
%p A396268    P:= select(t -> igcd(t,m) = 1, [$1 .. m-1]); nP:= nops(P);
%p A396268    Cands:= [seq(seq([P[i],P[j]],i=1..j-1),j=2..nP)];
%p A396268    D:= NumberTheory:-Divisors(m) minus {1,m};
%p A396268    ormap(c -> andmap(d -> (c[1] mod d) >= (c[2] mod d), D),Cands)
%p A396268 end proc:
%p A396268 g:= proc(a,b) local m;
%p A396268      for m from 2 do if (a mod m) > (b mod m) then return m fi od
%p A396268 end proc:
%p A396268 V[remove(check, [$1..39])] := -1:
%p A396268 q:= 2:
%p A396268 for x from 1 while has(V,0) do
%p A396268   p:= q; q:= nextprime(q);
%p A396268   v:=  g(p,q);
%p A396268   if v <= 39 and V[v] = 0 then V[v]:= p fi;
%p A396268 od:
%p A396268 convert(V,list);
%Y A396268 Cf. A121889.
%K A396268 sign,new
%O A396268 1,3
%A A396268 _Robert Israel_, May 20 2026
