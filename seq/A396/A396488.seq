%S A396488 1,1,4,32,435,8990,262045,10241105,516730165,32695631150,
%T A396488 2535035953450,236360124837375,26090155215824700,3364884806051643875,
%U A396488 501376248710735022625,85472745980408926013875,16529805690582269815479750,3599395786174214973693997250,876646125180991830612351278875
%N A396488 Number of labeled histories for rooted at-most-4-furcating trees with n leaves, if simultaneous branching events are allowed.
%H A396488 Emily H. Dickey and Noah A. Rosenberg, <a href="https://doi.org/10.1016/j.dam.2026.04.032">Labeled histories and maximally probable labeled topologies with multifurcation</a>, Discr. Appl. Math. 391 (2026), 192-203. See Table 2.
%t A396488 A[1] := 1;
%t A396488 A[n_] := n! Sum[(1/((2!)^x2 (x2!))) Sum[(1/((3!)^x3 (x3!))) Sum[(1/((4!)^x4 (x4!))) (1/(n - 2 x2 - 3 x3 - 4 x4)!)*A[n - x2 - 2 x3 - 3 x4], {x4, Max[Ceiling[(2 - 2 x2 - 3 x3)/4], 0], Floor[(n - 2 x2 - 3 x3)/4]}], {x3, 0, Floor[(n - 2 x2)/3]}], {x2, 0, Floor[n/2]}];
%t A396488 Table[A[n], {n, 1, 15}]
%Y A396488 Cf. A317059 (bifurcation only), A396088 (bifurcation and trifurcation only), A396065 (nonsimultaneous branching events only).
%K A396488 nonn
%O A396488 1,3
%A A396488 _Noah A Rosenberg_, May 28 2026
