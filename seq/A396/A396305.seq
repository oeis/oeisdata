%e A396305 Blocks 4, 7, 9, 10, ... have length 4.
%t A396305 Block[{c, j, k, m, q, r, s, t, w, nn, rad},
%t A396305   rad[n_] := rad[n] = Times @@ FactorInteger[n][[All, 1]];
%t A396305   nn = 2^12; c[_] := False; q = 0; r = 1; s = 1; t = {};
%t A396305   Reap[ Do[w = GCD[r, s]; m = r/w; k = m;
%t A396305     While[Or[c[k], ! CoprimeQ[w, k] ], k += m];
%t A396305     c[k] = True; s = r; r = rad[k];
%t A396305     If[CoprimeQ[s, r], If[Length[t] == 4, Sow[q] ]; q++; t = {k},
%t A396305     AppendTo[t, k]], {i, nn}] ][[-1, 1]] ] (* _Michael De Vlieger_, Jun 16 2026 *)
