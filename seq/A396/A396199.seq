%I A396199 #14 May 19 2026 16:39:58
%S A396199 1,6,18,52,130,324,756,1768,3978,8980,19756,43608,94484,205352,440040,
%T A396199 945616,2009434,4281012,9037692,19123960,40160316,84514936,176713048,
%U A396199 370203312,771256900,1609622664,3343062456,6954560368,14405875048,29885491920,61763349968,127821667232
%N A396199 a(n) = (n + 1)*(2^(n + 1) - binomial(n, floor(n / 2))), row sums of A396200.
%H A396199 Paolo Xausa, <a href="/A396199/b396199.txt">Table of n, a(n) for n = 0..1000</a>
%F A396199 From _Vaclav Kotesovec_, May 19 2026: (Start)
%F A396199 Recurrence: (n-1)*n*a(n) = 2*(n-1)*(n+1)*a(n-1) + 4*(n-2)*n*a(n-2) - 8*(n-1)*n*a(n-3).
%F A396199 a(n) ~ n * 2^(n+1).
%F A396199 a(n) = (n+1)*2^(n+1) - 4*(n+1)*Gamma(n)/(n*Gamma(n/2)^2) if n is even and n>0.
%F A396199 a(n) = (n+1)*2^(n+1) - 2*n*Gamma(n)/Gamma((n+1)/2)^2 if n is odd. (End)
%p A396199 a := n -> (n + 1)*(2^(n + 1) - binomial(n, iquo(n, 2))):
%p A396199 seq(a(n), n = 0..31);
%t A396199 Table[Sum[Sum[Binomial[2*i, i] * Binomial[n-2*i, k-i], {i, 0, n}], {k, 0, n}], {n, 0, 30}] (* _Vaclav Kotesovec_, May 19 2026 *)
%t A396199 (* Alternative: *)
%t A396199 A396199[n_] := (n + 1)*(2^(n + 1) - Binomial[n, Quotient[n, 2]]);
%t A396199 Array[A396199, 35, 0] (* _Paolo Xausa_, May 19 2026 *)
%Y A396199 Cf. A396200.
%K A396199 nonn,new
%O A396199 0,2
%A A396199 _Peter Luschny_, May 19 2026
