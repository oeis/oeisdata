%S A396429 1,1,0,1,2,0,1,4,7,0,1,6,22,30,0,1,8,45,138,143,0,1,10,76,372,933,728,
%T A396429 0,1,12,115,780,3258,6630,3876,0,1,14,162,1410,8390,29688,48849,21318,
%U A396429 0,1,16,217,2310,17985,93260,278652,370056,120175,0,1,18,280,3528,34083,235920,1062762,2676966,2866188,690690,0
%N A396429 Square array A(n,k), n>=0, k>=0, read by antidiagonals downwards, where A(n,k) = [x^n] F_k(x)/x and F_k(x) is the k-th iteration of x*G3(x)^2 with G3(x) = 1 + x*G3(x)^3.
%H A396429 Wikipedia, <a href="https://en.wikipedia.org/wiki/Fuss%E2%80%93Catalan_number">Fuss-Catalan number</a>
%F A396429 G.f. of column k: (1/x) * Series_Reversion( H_k(x) ), where H_k(x) is the k-th iteration of x*(1 - x)^2.
%F A396429 A(n,k) = Sum_{0 = x_0 <= x_1 <= ... <= x_{k-1} <= x_k = n} Product_{j=0..k-1} 2 * (x_j + 1) * binomial(3*x_{j+1} - x_j + 2,x_{j+1} - x_j)/(3*x_{j+1} - x_j + 2).
%F A396429 A(n,0) = 0^n; A(n,k) = 2 * Sum_{j=0..n} (j+1) * binomial(3*n-j+2,n-j)/(3*n-j+2) * A(j,k-1) for k > 0.
%e A396429 Square array begins:
%e A396429   1,    1,     1,      1,       1,       1,       1, ...
%e A396429   0,    2,     4,      6,       8,      10,      12, ...
%e A396429   0,    7,    22,     45,      76,     115,     162, ...
%e A396429   0,   30,   138,    372,     780,    1410,    2310, ...
%e A396429   0,  143,   933,   3258,    8390,   17985,   34083, ...
%e A396429   0,  728,  6630,  29688,   93260,  235920,  515298, ...
%e A396429   0, 3876, 48849, 278652, 1062762, 3161712, 7938483, ...
%e A396429   ...
%o A396429 (PARI)
%o A396429 a(n, k, p=3, s=2, r=2) = {
%o A396429   my(T=matrix(n+1, n+1, row, col, my(xr=row-1, xc=col-1); if(xc<xr, 0, (s*xr+r)*binomial(p*xc-(p-s)*xr+r, xc-xr)/(p*xc-(p-s)*xr+r))));
%o A396429   my(TK=T^k);
%o A396429   TK[1, n+1];
%o A396429 };
%Y A396429 Columns k=0..1 give A000007, A006013.
%Y A396429 Cf. A001764, A158825, A396412, A396431.
%K A396429 nonn,tabl
%O A396429 0,5
