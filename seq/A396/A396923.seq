%U A396923 20065170143,73078329208,266457851640,972564737120,3553204341505,12992712317401,47547503312715,174131574438586,638154433630592
%N A396923 a(n) is the number of grand Motzkin paths with air pockets of length n.
%H A396923 Lei Dong, Bowie Liu, Dennis Wong, Lin Chen, Chan-Tong Lam, and Sio-Kei Im, <a href="https://arxiv.org/abs/2606.05470">Generating 2-Gray codes for grand Motzkin paths and grand Dyck paths with air pockets in constant amortized time</a>, arXiv:2606.05470 [math.CO], 2026. See pp. 2, 13-14.
%F A396923 a(n) = 1 + Sum_{d=1..floor(n/2)} binomial(n - d + 1, d)*Sum_{i=0..n-2*d} binomial(n - d, i)*binomial(n - d - i - 1, d - 1).
%t A396923 a[n_]:=1+Sum[Binomial[n-d+1,d]*Sum[Binomial[n-d,i]*Binomial[n-d-i-1,d-1],{i,0,n-2d}],{d,Floor[n/2]}]; Array[a,29,0]
