%U A396397 711356,1027758,1502904,2209445,3158774,4667348,6703861,9789108,14193833,20557162
%N A396397 a(n) = r(n,n), where r(1,k)=f(k)=ceiling(k*c), r(n,k)=f(r(n-1,k)), c=sqrt(2).
%C A396397 a(n + 1)/a(n) approaches c erratically.
%t A396397 c = Sqrt[2]; f[k_] := f[k] = Ceiling[c*k];
%t A396397 r[1, k_] := f[k]; r[n_, k_] := r[n, k] = f[r[n - 1, k]];
%t A396397 Table[r[n, n], {n, 1, 100}]
%Y A396397 Cf. A002193, A396385, A396396, A396398.
%K A396397 nonn
%O A396397 1,1
