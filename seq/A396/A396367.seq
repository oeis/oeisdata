%I A396367 #26 Jul 14 2026 22:33:05
%S A396367 48,96,160,162,162,224,250,384,375,384,384,448,640,486,567,704,640,
%T A396367 768,768,1215,832,896,1250,1458,960,1408,1458,1250,2673,1215,1458,
%U A396367 2176,1715,1458,1701,1664,1792,2432,3159,1792,2560,3072,2016,1920,2662,3072,2560,3645
%N A396367 Smallest number k that is neither squarefree nor powerful (in A332785) that exceeds A286708(n) and has the same squarefree kernel as A286708(n).
%C A396367 A286708(n) is the sequence of powerful numbers with more than 1 distinct prime factor (i.e., that are not prime powers).
%C A396367 Let sorted S(k) = { q : rad(q) = rad(k) } be the sequence of numbers with the same squarefree kernel as k. Then a(n) is the smallest number q in S(k) that exceeds k, but isn't powerful, with k in A286708.
%C A396367 For k in A286708, S(k) is infinite, and such that its smallest term is rad(k) (squarefree). All the rest of the terms m are in A126706 (neither squarefree nor prime power), either in A332785 (neither squarefree nor powerful) or in A286708. Those terms m in A332785 generally become increasingly rare as m increases.
%C A396367 Let b = A286708.
%C A396367 Then b(n) is the A008479(b(n))-th term in S(b(n)), and a(n) is such that A008479(a(n)) > A008479(b(n)).
%H A396367 Michael De Vlieger, <a href="/A396367/b396367.txt">Table of n, a(n) for n = 1..10000</a>
%H A396367 Michael De Vlieger, <a href="/A396367/a396367.png">Log log scatterplot of a(n)</a>, n = 1..2^16.
%e A396367 Let rad = A007947.
%e A396367 Table of n, b(n), and a(n) for select n:
%e A396367      n       b(n)                       a(n)
%e A396367   --------------------------------------------------------------------
%e A396367      1        36 = 2^2 * 3^2             48 = 2^4 * 3
%e A396367      2        72 = 2^3 * 3^2             96 = 2^5 * 3
%e A396367      3       100 = 2^2 * 5^2            160 = 2^5 * 5
%e A396367      4       108 = 2^2 * 3^3            162 = 2 * 3^4
%e A396367      5       144 = 2^4 * 3^2            162 = 2 * 3^4
%e A396367      6       196 = 2^2 * 7^2            224 = 2^5 * 7
%e A396367      7       200 = 2^3 * 5^2            250 = 2 * 5^3
%e A396367      8       216 = 2^3 * 3^3            384 = 2^7 * 3
%e A396367      9       225 = 3^2 * 5^2            375 = 3 * 5^3
%e A396367     25       900 = 2^2 * 3^2 * 5^2      960 = 2^6 * 3 * 5
%e A396367    322     44100 = 210^2              45360 = 2^4 * 3^4 * 5 * 7
%e A396367   4320   5336100 = 2310^2           5433120 = 2^5 * 3^2 * 5 * 7^3 * 11
%e A396367 .
%e A396367 b(1) = 36, rad(36) = 6, thus S(6) = A033845 begins {6, 12, 18, 24, 36, 48, ...}; 36 is the 5th term, and the 6th is 48, not powerful. Thus a(1) = 48.
%e A396367 b(2) = 72, rad(72) = 6. In S(6), 96 follows 72 and is not powerful, hence a(2) = 96.
%e A396367 b(3) = 100, rad(100) = 10. In S(10) = A033846, 160 follows 100 and is not powerful, hence a(3) = 160.
%e A396367 b(4) = 108, rad(108) = 6. In S(6), 144 follows 108, but is powerful; 162 comes next and is not powerful, hence a(4) = 162.
%e A396367 b(5) = 144, rad(144) = 6, obviously following b(4) in S(6), so a(5) = a(4) = 162, etc.
%t A396367 (* First, load the regs program from the Mathematica link in A369609, then: *)
%t A396367 rad[x_] := Times @@ FactorInteger[#][[All, -1]];
%t A396367 a286708 = Rest@ Select[
%t A396367   With[{lim = 2^11}, Union@ Flatten@ Table[a^2*b^3,
%t A396367     {b, Surd[lim, 3]}, {a, Sqrt[lim/b^3]} ] ],
%t A396367   Not @* PrimePowerQ];
%t A396367 Map[Module[{k, m, r, s, t},
%t A396367   k = #; r = rad[#]; t = r^Ceiling[Log[r, k] + 1/3];
%t A396367   s = regs[-r, t]; m = 1 + FirstPosition[s, k][[1]];
%t A396367   While[Divisible[s[[m]], r^2], m++]; s[[m]] ] &, a286708]
%Y A396367 Cf. A001694, A007947, A008479, A052485, A126706, A286708, A332785, A396542.
%K A396367 nonn,new
%O A396367 1,1
%A A396367 _Michael De Vlieger_, Jul 05 2026
