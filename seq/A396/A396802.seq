%I A396802 #7 Jun 10 2026 08:52:15
%S A396802 1,3,12,82,869,13303,295276,9618200,445200263,27444329035,
%T A396802 2129433119980,201200084582118,22786158749348209,3069473259006319111,
%U A396802 488980558986964547188,91458642914624687166988,19896779300012557196974899,4981304404757558800593264011,1420363003443264647976713255812,457155391957458782620526634512250
%N A396802 Antidiagonal sums of table A396800.
%H A396802 Paul D. Hanna, <a href="/A396802/b396802.txt">Table of n, a(n) for n = 1..72</a>
%F A396802 a(n) = Sum_{k=1..n} A396800(n-k+1,k) for n >= 1. Row n of table A396800 is defined by A396800(n,k) = [x^k/k!] F(n,x) where F(n,x) satisfies F(n,x) = x * exp( F^n(n,x) ) for n >= 1.
%o A396802 (PARI) \\ a(n) = [x^n/n!] F(n,x) where F(n,x) = x * exp( F^n(n,x) )
%o A396802 \\ Routine to generate the n-th iteration of F:
%o A396802 {IT(n,F) = my(G=x); for(i=1,n, G = subst(F,x,G)); G}
%o A396802 \\ Calculate the terms T(n,k) of the table A396800
%o A396802 {A396800(n,k) = my(Fn=x); for(j=1, k, Fn = truncate(Fn) + x*O(x^j);
%o A396802 Fn = x * exp( IT(n, Fn) ) +x*O(x^k); ); k!*polcoef(Fn, k)}
%o A396802 \\ Get antidiagonal sums
%o A396802 {a(n) = sum(k=1,n, A396800(n-k+1,k))}
%o A396802 {for(n=1,20, print1(a(n),", "))}
%Y A396802 Cf. A396800.
%K A396802 nonn,new
%O A396802 1,2
%A A396802 _Paul D. Hanna_, Jun 09 2026
