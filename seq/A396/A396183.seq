%U A396183 58,60,61,62,63,64,65,66,67,69,70,71,72,73,74,75,76,77,78,79,80,82,83,85,86,87,88,89,90,92,93,94,95,96,97,98,99,100
%N A396183 Consider the square spiral with its cells numbered starting at 0, as in A308884 and A274641. Three players, X, Y, and Z, play in rotation, beginning with X. When it is a player's turn, he places a queen at the smallest unoccupied cell not attacked by an existing queen belonging to a different player. Sequence lists squares not occupied by a queen.
%C A396183 This sequence together with A396180-A396182 partition the nonnegative integers.
%H A396183 Jonas Karlsson, <a href="/A396183/b396183.txt">Table of n, a(n) for n = 0..19999</a>
%H A396183 Michael S. Branicky, <a href="/A396180/a396180.py.txt">Python program for OEIS A396180-A396183</a>
%H A396183 Michael S. Branicky, <a href="/A396180/a396180_2.png">Illustration of central 2001 X 2001 square</a>
%H A396183 Michael S. Branicky, <a href="/A396180/a396180_3.png">Illustration of central 10001 X 10001 square</a>
%H A396183 Jonas Karlsson, <a href="/A396180/a396180.png">The initial cells of the spiral together with the first few queens.</a>
%H A396183 Jonas Karlsson, <a href="/A396180/a396180_1.png">Illustration showing 20K queens of each color./a>
%t A396183 spiral[n_]:=Module[{k,m},If[n==0,{0,0},k=Ceiling[(Sqrt[n+1]-1)/2]; m=(2 k+1)^2-1; Which[n>=m-2 k,{k-(m-n),-k},n>=m-4 k,{-k,-k+(m-2 k-n)},n>=m-6 k,{-k+(m-4 k-n),k},True,{k,k-(m-6 k-n)}]]]; attackQ[a_,b_]:=Module[{u=spiral[a],v=spiral[b]},u[[1]]==v[[1]]||u[[2]]==v[[2]]||Abs[u[[1]]-v[[1]]]==Abs[u[[2]]-v[[2]]]]; players={{},{},{}}; occ={}; Do[p=Mod[n-1,3]+1; k=0; While[MemberQ[occ,k]||AnyTrue[Delete[players,p],AnyTrue[#,attackQ[k,#]&]&],k++]; AppendTo[players[[p]],k]; AppendTo[occ,k],{n,20}]; Complement[Range[0,Max[occ]],occ] (* _Vincenzo Librandi_, May 31 2026 *)
%o A396183 (Magma) function S(n) if n eq 0 then return 0,0; end if; k := Ceiling((Sqrt(n+1)-1)/2);
%o A396183     m := (2*k+1)^2-1; if n ge m-2*k then return k-(m-n),-k; end if;
%o A396183     if n ge m-4*k then return -k,-k+(m-2*k-n); end if;
%o A396183     if n ge m-6*k then return -k+(m-4*k-n),k; end if;
%o A396183     return k,k-(m-6*k-n); end function;
%o A396183 function A(a,b) x1,y1 := S(a); x2,y2 := S(b);
%o A396183     return x1 eq x2 or y1 eq y2 or Abs(x1-x2) eq Abs(y1-y2); end function;
%o A396183 P := [[],[],[]]; O := []; for n in [1..20] do q := ((n-1) mod 3)+1;
%o A396183 k := 0; repeat ok := not (k in O); for j in [1..3] do if j ne q then
%o A396183 for r in P[j] do if A(k,r) then ok := false; end if; end for; end if;
%o A396183 end for; if not ok then k +:= 1; end if; until ok;
%o A396183 Append(~P[q],k);Append(~O,k); end for; [n : n in [0..Maximum(O)]| not (n in O)]; // _Vincenzo Librandi_, May 31 2026
%Y A396183 Cf. A273059, A395348, A395349, A396180-A396182.
