%S A396432 1,2,9,51,324,2208,15792,117048,891774,6945132,55065450,443123190,
%T A396432 3610688562,29734801768,247114697784,2069956220472,17458923389109,
%U A396432 148151533500666,1263935257689417,10834739103363243,93276111162618594,806112305086842072
%N A396432 Expansion of (F_2(x)/x)^(1/2), where F_k(x) is the k-th iteration of x*G3(x)^2 with G3(x) = 1 + x*G3(x)^3.
%H A396432 Seiichi Manyama, <a href="/A396432/b396432.txt">Table of n, a(n) for n = 0..1000</a>
%H A396432 Wikipedia, <a href="https://en.wikipedia.org/wiki/Fuss%E2%80%93Catalan_number">Fuss-Catalan number</a>
%F A396432 G.f.: ((1/x) * Series_Reversion( H_2(x) ))^(1/2), where H_k(x) is the k-th iteration of x*(1 - x)^2.
%F A396432 a(n) = Sum_{k=0..n} (2*k+1) * binomial(3*k+1,k) * binomial(3*n-k+1,n-k)/((3*k+1) * (3*n-k+1)).
%o A396432 (PARI)
%o A396432 lista(nn, k=2, p=3, s=2, r=1) = {
%o A396432   my(T=matrix(nn+1, nn+1, row, col, my(xr=row-1, xc=col-1); if(xc<xr, 0, (s*xr+r)*binomial(p*xc-(p-s)*xr+r, xc-xr)/(p*xc-(p-s)*xr+r))));
%o A396432   my(TK=T^k);
%o A396432   TK[1, ];
%o A396432 };
%Y A396432 Column k=2 of A396446.
%K A396432 nonn,new
%O A396432 0,2
%A A396432 _Seiichi Manyama_, May 25 2026
