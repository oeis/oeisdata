%S A396584 1,7,5,35,25,175,125,875,625,4375,3125,21875,15625,109375,78125,
%T A396584 546875,390625,2734375,1953125,13671875,9765625,68359375,48828125,
%U A396584 341796875,244140625,1708984375,1220703125,8544921875,6103515625,42724609375,30517578125,213623046875
%N A396584 a(n) = (4 - 3*(-1)^n) * 5^floor(n/2).
%H A396584 <a href="/index/Rec#order_02">Index entries for linear recurrences with constant coefficients</a>, signature (0,5).
%F A396584 a(n) = [x^n] (1 + 7*x)/(1 - 5*x^2).
%F A396584 a(n) = n! * [x^n] (((5 - 7*sqrt(5))*exp(-sqrt(5)*x))/10 + exp(sqrt(5)*x)*(5 + 7*sqrt(5))/10).
%F A396584 a(n) = n! * [x^n] (7*sinh(sqrt(5)*x))/sqrt(5) + cosh(sqrt(5)*x).
%F A396584 a(n) = 2^n * P(n, 1/2) where P(n, x) = Sum_{k=0..n} A396197(n, k)*x^k.
%F A396584 a(n) = 5^floor(n/2)*(4 - 3*(F(n+1)*F(n-1) - F(n)^2)) where F(n) are the Fibonacci numbers.
%p A396584 a := n -> ifelse(irem(n, 2) = 0, 5^iquo(n, 2), 7*5^((n-1)/2)): seq(a(n), n = 0..31);
%t A396584 a[n_] := (4 - 3*(-1)^n) * 5^Floor[n/2]; Array[a, 32, 0] (* _Amiram Eldar_, Jun 01 2026 *)
%o A396584 (Python)
%o A396584 def a_gen():
%o A396584     even = 1; odd  = 7
%o A396584     while True:
%o A396584         yield even
%o A396584         even *= 5
%o A396584         odd, even = even, odd
%o A396584 A396584gen = a_gen()
%o A396584 for _ in range(32): print(next(A396584gen), end=", ")
%o A396584 (Python)
%o A396584 def A396584(n): return (7 if n&1 else 1)*5**(n>>1) # _Chai Wah Wu_, Jun 01 2026
