%I A396955 #22 Jun 16 2026 17:53:07
%S A396955 0,-1,1,-1,2,0,4,0,5,4,8,2,10,7,8,5,14,7,16,10,15,14,18,9,17,18,20,16,
%T A396955 24,16,27,17,25,26,25,19,32,30,33,25,37,28,38,32,31,36,42,27,43,36,44,
%U A396955 38,46,35,43,36,47,48,53,38,54,52,50,44,52,49,61,53,60,51
%N A396955 a(n) = n - Omega(|Re((2 + i)^n)|) - Omega(|Im((2 + i)^n)|), where Omega is A001222.
%C A396955 Let u(n) + i*v(n) = (2 + i)^n, so that u(n)^2 + v(n)^2 = 5^n, where 5 == 1 (mod 4); such primes admit a representation as a sum of two squares. Then a(n) = n - Omega(u(n)) - Omega(v(n)) = Omega(u(n)^2 + v(n)^2) - Omega(u(n)) - Omega(v(n)). The values u(n) and v(n) can be computed via the recurrence u(n + 1) = 2*u(n) - v(n), v(n + 1) = u(n) + 2*v(n), with u(1) = 2 and v(1) = 1.
%C A396955 Since u(n)^2 + v(n)^2 = 5^n and gcd(u(n), v(n)) = 1 (any common divisor must divide 5^n), the triple (u(n)^2 - v(n)^2, 2*u(n)*v(n), u(n)^2 + v(n)^2) is a primitive Pythagorean triple for all n >= 1.
%C A396955 Thus a(n) compares the additive prime factor count of the norm 5^n with that of its Gaussian components u(n) and v(n).
%C A396955 Large positive values of a(n) occur when both u(n) and v(n) have relatively few prime factors.
%C A396955 Since |u(n)| and |v(n)| are of order about p^(n/2), probabilistic number theory suggests that Omega(u(n)) and Omega(v(n)) grow roughly like log log |u(n)|, which is about log(n). A refined heuristic suggests a(n) ~ n - 2*log(n) - C_p, where C_p = 2*(log(log(p)) - log(2) + B), with p = u(1)^2 + v(1)^2 and B the Meissel-Mertens constant (A077761). Fluctuations around this trend are of order sqrt(log(n)) and are governed by Erdős-Kac type behavior of Omega. For p = 5 this gives C_p ~ 0.09, explaining the very small vertical shift observed in numerical plots, see linked graph.
%H A396955 Felix Huber, <a href="/A396955/a396955.pdf">Growth of a(n)</a>
%H A396955 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/Erdos-KacTheorem.html">Erdős-Kac theorem</a>.
%H A396955 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/Hardy-RamanujanTheorem.html">Hardy-Ramanujan theorem</a>.
%H A396955 Wikipedia, <a href="https://en.wikipedia.org/wiki/Fermat%27s_theorem_on_sums_of_two_squares">Fermat's theorem on sums of two squares</a>.
%F A396955 a(n) = n - A001222(|A139011(n)|) - A001222(|A099456(n)|).
%e A396955 a(1) = 0 since (2 + i)^1 = 2 + i, so Omega(2) = 1, Omega(1) = 0 and hence 1 - 1 - 0 = 0.
%e A396955 a(2) = -1 since (2 + i)^2 = 3 + 4*i, so Omega(3) = 1, Omega(4) = 2 and hence 2 - 1 - 2 = -1.
%e A396955 a(3) = 1 since (2 + i)^3 = 2 + 11*i, so Omega(2) = 1, Omega(11) = 1 and hence 3 - 1 - 1 = 1.
%p A396955 with(NumberTheory):
%p A396955 A396955List := proc(N)
%p A396955     local a, b, k, u, v;
%p A396955     u := 2;
%p A396955     v := 1;
%p A396955     a := Vector(N);
%p A396955     for k from 1 to N do
%p A396955         a[k] := k - Omega(abs(u)) - Omega(abs(v));
%p A396955         b := 2*u - v;
%p A396955         v := u + 2*v;
%p A396955         u := b;
%p A396955     end do;
%p A396955     convert(a, list)
%p A396955 end proc:
%p A396955 A396955List(70);
%t A396955 a[n_] := n - Total[PrimeOmega[ReIm[(2 + I)^n]]]; Array[a, 70] (* _Amiram Eldar_, Jun 12 2026 *)
%o A396955 (PARI) a(n) = n - bigomega(abs(real((2 + I)^n))) - bigomega(abs(imag((2 + I)^n))); \\ _Michel Marcus_, Jun 12 2026
