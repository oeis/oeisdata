%S A396528 1,372,13323497472,472853407434632312389632,
%T A396528 90982672283588230980362497816774332068659200,
%U A396528 358130602007876868195143063983995555706363969888321536000000000000000000,85624351120586671152249617844764977581131439385013331522372239403293887155959286988800000000000000000000000
%N A396528 Number of Eulerian cycles in the complete tripartite graph K_{n,n,n}.
%H A396528 Robert P. P. McKone, <a href="/A396528/a396528.txt">The Eulerian cycles for complete tripartite graph K_{n,n,n} n = 1 to n = 2</a>.
%H A396528 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/CompleteTripartiteGraph.html">Complete Tripartite Graph</a>.
%H A396528 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/EulerianCycle.html">Eulerian Cycle</a>.
%e A396528 a(1) = 1 since K_{1,1,1} is the cycle graph C_3, which has one Eulerian cycle.
%t A396528 e[n_]:=Select[Subsets[Range[3 n],{2}],Quotient[#[[1]]-1,n]!=Quotient[#[[2]]-1,n]&];
%t A396528 a[n_,r_:1]:=Module[{v,k,u,p,q,l,z,c},v=Range[3 n]; k=DeleteCases[v,r]; u=Array[x,3 n]; p[i_]:=Quotient[i-1,n]; q[i_,j_]:=1/(u[[i]]+u[[j]]); l=Table[Which[i==j,Sum[If[i!=t&&p[i]!=p[t],q[i,t],0],{t,v}],p[i]!=p[j],-q[i,j],True,0],{i,v},{j,v}]; z=Cancel[Times@@((u[[#[[1]]]]+u[[#[[2]]]])&/@e[n])*Times@@u[[k]]*Det[l[[k,k]]]]; c=Coefficient[z,Times@@(u^n)]; Factorial[n-1]^(3 n) c/2];
%t A396528 a/@Range[3] (* _Robert P. P. McKone_, Jul 02 2026 *)
%Y A396528 Cf. A234365 (number of directed Hamiltonian cycles in the same graph).
%Y A396528 Cf. A234616 (number of undirected cycles in the same graph).
%Y A396528 Cf. A297383 (number of Eulerian cycles in cocktail party graphs).
%K A396528 nonn,new
%O A396528 1,2
%A A396528 _Eric W. Weisstein_, Jun 27 2026
%E A396528 a(4)-a(7) from _Robert P. P. McKone_, Jul 02 2026
