%U A396771 4,4,3,7,3,4,4,5,3,5,3,6,4,4,3,8,3,4,4,5,3,7,3,5,4
%N A396771 Second least non-divisor of n.
%C A396771 An integer m >= 3 appears in the sequence if and only if m is a prime power or twice a prime power.
%H A396771 David Radcliffe, <a href="/A396771/b396771.txt">Table of n, a(n) for n = 1..10000</a>
%H A396771 Bakir Farhi, <a href="http://www.integers-ejcnt.org/j42/j42.Abstract.html">On the average asymptotic behavior of a certain type of sequences of integers</a>, Integers 9 (2009), 555-567.
%F A396771 Sum_{n=1..N} a(n) = c*N + O((log N)^2 / (log log N)), where
%F A396771 c = Sum_{m >= 0} (1 + Sum_{m/2 < p^a <= m} (p-1)) / lcm(1,2,...,m) ~ 4.287434141625.
%t A396771 f[n_, q_ : 1] := Module[{c, k}, c = 0; k = 2; While[If[! Divisible[n, k], c++]; c < q, k++]; k]; Table[f[n, 2], {n, 120}] (* _Michael De Vlieger_, Jun 08 2026 *)
%o A396771 (Python)
%o A396771 from itertools import count, islice
%o A396771 def A396771(n: int, rank: int = 2) -> int:
%o A396771     assert n > 0 and rank > 0, "Arguments must be positive integers."
%o A396771     return next(islice(filter(lambda x: n % x, count(2)), rank - 1, rank))
%o A396771 (PARI) a(n) = my(nb=0, i=1); while(nb !=2, i++; if (n % i, nb++)); i; \\ _Michel Marcus_, Jun 08 2026
