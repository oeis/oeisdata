%N A396068 Product of squarefree divisors of n that are <= sqrt(n).
%t A396068 a[n_] := Times @@ Select[Divisors[n], SquareFreeQ[#] && # <= Sqrt[n] &]; Array[a, 85]
%o A396068 (PARI) a(n) = vecprod(select(x->(x<=sqrt(n) && issquarefree(x)), divisors(n))); \\ _Michel Marcus_, May 15 2026
%o A396068 (Python)
%o A396068 from math import isqrt, prod
%o A396068 from itertools import combinations
%o A396068 from sympy import primefactors
%o A396068 def A396068(n):
%o A396068     c, ps, m = 1, primefactors(n), isqrt(n)
%o A396068     for l in range(1,len(ps)+1):
%o A396068         for p in combinations(ps,l):
%o A396068             if (q:=prod(p)) <= m:
%o A396068                 c *= q
%o A396068     return c # _Chai Wah Wu_, May 20 2026
