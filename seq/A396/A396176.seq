%S A396176 1,2,3,4,5,7,10,15,21,30,42,62,92,137,204,306,462,701,1066,1634,2504,
%T A396176 3842,5927,9135,14132,21881,33958,52779,82185,128158,200065,312748,
%U A396176 489472,766792,1202449,1887463,2965181,4662549,7337565,11555256,18210876,28719623
%N A396176 a(n) = primepi(A394720(n)).
%C A396176 This is surprisingly difficult to compute! - _N. J. A. Sloane_, May 26 2026
%H A396176 Chai Wah Wu, <a href="/A396176/b396176.txt">Table of n, a(n) for n = 1..100</a>
%F A396176 a(n) = A000720(A394720(n)).
%e A396176 A394720(10) = 113 is the 30-th prime, so a(10) = 30.
%p A396176 b:= proc(n) option remember;
%p A396176       `if`(n<3, n+1, (s-> ((x, y)-> `if`(y-s<s-x, y, x))(
%p A396176           prevprime(s+1), nextprime(s-1)))(b(n-1)+b(n-2)))
%p A396176     end:
%p A396176 a:= n-> numtheory[pi](b(n)):
%p A396176 seq(a(n), n=1..40);  # _Alois P. Heinz_, May 25 2026
%Y A396176 Cf. A000720, A394720.
%K A396176 nonn,new
%O A396176 1,2
%A A396176 _N. J. A. Sloane_, May 25 2026
%E A396176 a(31)-a(42) from _Alois P. Heinz_, May 25 2026
