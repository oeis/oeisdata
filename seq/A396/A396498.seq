%I A396498 #27 May 30 2026 15:09:21
%S A396498 1,1,0,1,1,0,1,2,3,0,1,3,10,16,0,1,4,21,83,125,0,1,5,36,237,976,1296,
%T A396498 0,1,6,55,514,3729,14957,16807,0,1,7,78,950,10136,75693,283732,262144,
%U A396498 0,1,8,105,1581,22525,256254,1888725,6433975,4782969,0
%N A396498 Square array A(n,k), n>=0, k>=0, read by antidiagonals downwards, where A(n,k) = n! * [x^n] F_k(x)/x and F_k(x) is the k-th iteration of x*G(x) with G(x) = exp(x*G(x)).
%F A396498 E.g.f. of column k: (1/x) * Series_Reversion( H_k(x) ), where H_k(x) is the k-th iterate of x*exp(-x).
%F A396498 E.g.f. of column k: -W_k(-x)/x, where W_k(x) is the k-th iterate of LambertW(x).
%F A396498 A(n,k) = Sum_{0 = x_0 <= x_1 <= ... <= x_{k-1} <= x_k = n} Product_{j=0..k-1} (x_j + 1) * (x_{j+1} + 1)^(x_{j+1} - x_j - 1) * binomial(x_{j+1},x_j).
%F A396498 A(n,0) = 0^n; A(n,k) = Sum_{j=0..n} (j+1) * (n+1)^(n-j-1) * binomial(n,j) * A(j,k-1) for k > 0.
%e A396498 Square array begins:
%e A396498   1,    1,     1,     1,      1,      1, ...
%e A396498   0,    1,     2,     3,      4,      5, ...
%e A396498   0,    3,    10,    21,     36,     55, ...
%e A396498   0,   16,    83,   237,    514,    950, ...
%e A396498   0,  125,   976,  3729,  10136,  22525, ...
%e A396498   0, 1296, 14957, 75693, 256254, 681830, ...
%e A396498   ...
%p A396498 A:= (n,k)-> n!*coeff(series(-expand((LambertW@@k)(-x))/x,x,n+3),x,n):
%p A396498 seq(seq(A(n, d-n), n=0..d), d=0..9);  # _Alois P. Heinz_, May 29 2026
%o A396498 (PARI)
%o A396498 a(n, k, p=1, s=1, r=1) = {
%o A396498   my(T=matrix(n+1, n+1, row, col, my(xr=row-1, xc=col-1); if(xc<xr, 0, (s*xr+r)*(p*xc-(p-s)*xr+r)^(xc-xr-1)*binomial(xc, xr))));
%o A396498   my(TK=T^k);
%o A396498   TK[1, n+1];
%o A396498 };
%Y A396498 Columns k=0..3 give A000007, A000272(n+1), A101878, A227278(n+1)/(n+1).
%Y A396498 Main diagonal gives A396567.
%Y A396498 Cf. A396499, A396500, A396588.
%K A396498 nonn,tabl
%O A396498 0,8
%A A396498 _Seiichi Manyama_, May 28 2026
