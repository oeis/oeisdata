%I A396980 #11 Jun 16 2026 17:47:10
%S A396980 12,30,48,120,126,132,150,168,186,234,240,246,252,288,294,330,408,426,
%T A396980 432,510,588,594,600,630,660,666,672,690,714,720,792,846,852,888,960,
%U A396980 1008,1014,1020,1026,1050,1074,1080,1110,1128,1134,1170,1248,1254,1260,1266
%N A396980 Abundant numbers whose preceding five numbers and following five numbers are nonabundant.
%C A396980 6 divides a(n) since all multiples of 6 (other than 6 itself) are abundant.
%C A396980 Other than 12, the abundant numbers preceding and following a(n) are a(n)-6 and a(n)+6, respectively.
%H A396980 Hoang Nguyen, <a href="/A396980/b396980.txt">Table of n, a(n) for n = 1..10000</a>
%e A396980 12 is an abundant number, and its preceding five numbers (7, 8, 9, 10, and 11) and following five numbers (13, 14, 15, 16, 17) are nonabundant.
%e A396980 48 is an abundant number, and its preceding five numbers (43, 44, 45, 46, and 47) and following five numbers (49, 50, 51, 52, 53) are nonabundant.
%t A396980 seq[lim_] := Module[{t = Table[Boole[DivisorSigma[1, n] > 2*n], {n, 1, lim}], s = ConstantArray[0, 11]}, s[[6]] = 1; SequencePosition[t, s][[;; , 1]] + 5]; seq[1300] (* _Amiram Eldar_, Jun 12 2026 *)
%o A396980 (Julia)
%o A396980 using Primes
%o A396980 function a(n)
%o A396980     num = 6
%o A396980     i = 1
%o A396980     while i <= n
%o A396980         num += 6
%o A396980         check = true
%o A396980         for i in 1:5
%o A396980             if sum(divisors(num + i)) > 2(num + i) || sum(divisors(num - i)) > 2(num - i)
%o A396980                 check = false
%o A396980             end
%o A396980         end
%o A396980         if check
%o A396980             print("$num, ")
%o A396980             i += 1
%o A396980         end
%o A396980     end
%o A396980 end
%Y A396980 Cf. A263837, A005101, A316099.
%K A396980 easy,nonn,new
%O A396980 1,1
%A A396980 _Hoang Nguyen_, Jun 12 2026
