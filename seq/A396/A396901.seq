%I A396901 #23 Jul 08 2026 10:59:30
%S A396901 1,5,11,34,29,55,55,164,249,145,131,374,181,275,319,1096,305,1245,379,
%T A396901 986,605,655,551,1804,3145,905,2691,1870,869,1595,991,5264,1441,1525,
%U A396901 1595,8466,1405,1895,1991,4756,1721,3025,1891,4454,7221,2755,2255,12056,16849,15725,3355
%N A396901 a(n) = Sum_{k=1..n} gcd(k^4,n^2).
%H A396901 Seiichi Manyama, <a href="/A396901/b396901.txt">Table of n, a(n) for n = 1..10000</a>
%F A396901 Multiplicative with a(p^e) = p^(2*e) + Sum_{k=0..e-1} (p^(e-k) - p^(e-k-1)) * p^min(4*k,2*e).
%F A396901 Equivalently, a(p^e) = p^e * ( 1 + ((p-1)/p) * Sum_{k=1..2*e} p^floor(3*k/4) ).
%F A396901 Let s and t be positive integers, and let a_{s,t}(n) = Sum_{k=1..n} gcd(k^s,n^t).
%F A396901 a_{s,t}(p^e) = p^min(s*e,t*e) + Sum_{k=0..e-1} (p^(e-k) - p^(e-k-1)) * p^min(s*k,t*e).
%F A396901 a_{s,t}(n) is multiplicative if and only if t <= s.
%F A396901 For t <= s, a_{s,t}(p^e) = p^e * ( 1 + ((p-1)/p) * Sum_{k=1..t*e} p^floor(((s-1)*k)/s) ).
%o A396901 (PARI) a(n) = sum(k=1, n, gcd(k^4, n^2));
%Y A396901 Cf. A343498, A393808, A396903.
%K A396901 nonn,mult
%O A396901 1,2
%A A396901 _Seiichi Manyama_, Jul 08 2026
