%U A396386 2380306,3742125,5817009,8858274,13779572,21459147,32726430,50605770,78738044,122481402
%N A396386 a(n) = r(n,n), where r(1,k)=f(k)=round(k*c), r(n,k)=f(r(n-1,k)), c=3/2, using banker's rounding.
%C A396386 a(n+1)/a(n) approaches c erratically.
%t A396386 c = 3/2; f[k_] := f[k] = Round[c*k];
%t A396386 r[1, k_] := f[k]; r[n_, k_] := r[n, k] = f[r[n - 1, k]];
%t A396386 Table[r[n, n], {n, 1, 100}]
%Y A396386 Cf. A353220, A396385.
%K A396386 nonn
%O A396386 1,1
%A A396386 _Clark Kimberling_, May 24 2026
