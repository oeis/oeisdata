%I A396151 #54 Jun 07 2026 19:04:03
%S A396151 1,3,9,21,41,73,129,241,481,993,2049,4161,8321,16513,32769,65281,
%T A396151 130561,261633,524289,1049601,2099201,4196353,8388609,16773121,
%U A396151 33546241,67100673,134217729,268451841,536903681,1073774593,2147483649,4294901761,8589803521,17179738113
%N A396151 a(n) = 2^(n+1) + 1 - 2*Re((1+i)^n), where i is the imaginary unit.
%C A396151 Norm sum invariant from paired affine spirals on Z^2.
%C A396151 a(n) = (|P(n)|^2 + |N(n)|^2)/5, where P(n) and N(n) are iteration points arising from a paired-square geometric construction on the integer lattice Z^2.
%C A396151 The construction begins with two unit squares sharing the corner P(0)=(0,0). At each step, a new square is constructed outwardly on the hypotenuse of the isosceles right triangle formed by the outer edges.
%C A396151 The points satisfy the affine recurrence P(n+1) = AP(n) + (2,1), N(n+1) = AN(n), with matrix A = [[1,-1],[1,1]] and N(0)=(-1,2).
%C A396151 They are related by the invariant P(n) + N(n) = (-1,2) for all n.
%C A396151 Units digits are periodic with period 4: 1, 3, 9, 1.
%H A396151 Chuck Wrathall, <a href="/A396151/a396151.png">Illustration of the paired affine spiral construction (P_n in red, N_n in blue)</a>
%H A396151 Chuck Wrathall, <a href="/A396151/a396151.jpg">Illustration of the paired squares iterations for n = 0 to 8</a>
%H A396151 Chuck Wrathall, <a href="https://chuckwrathall.github.io/dual-affine-spiral-orbits/">Dual Affine Spiral Orbits on Z^2 from Paired Unit Squares</a> (full paper and animation)
%H A396151 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (5,-10,10,-4).
%F A396151 a(n) = 2^(n+1) + 1 - 2*Re((1+i)^n), where i is the imaginary unit.
%F A396151 G.f.: (1 - 2*x + 4*x^2 - 4*x^3)/((1 - x)*(1 - 2*x)*(1 - 2*x + 2*x^2)). - _Stefano Spezia_, May 18 2026
%F A396151 a(n) = 2*A000749(n+2) + 1. - _Hugo Pfoertner_, May 26 2026
%F A396151 a(n) = 2^(n+1) + 1 - 2^(n/2 + 1)*cos(Pi*n/4). - _Vaclav Kotesovec_, May 26 2026
%e A396151 a(0) = 2^(0+1) + 1 - 2*Re((1+i)^0) = 2 + 1 - 2*1 = 1.
%e A396151 a(1) = 2^(1+1) + 1 - 2*Re((1+i)^1) = 4 + 1 - 2*1 = 3.
%e A396151 a(2) = 2^(2+1) + 1 - 2*Re((1+i)^2) = 8 + 1 - 2*0 = 9.
%t A396151 a[n_] := 2^(n+1) + 1 - 2*Re[(1+I)^n]; Array[a, 34, 0] (* _Amiram Eldar_, May 23 2026 *)
%o A396151 (Python)
%o A396151 def A396151(n):
%o A396151     if n < 3: return [1,3,9][n]
%o A396151     a0,a1,a2 = 1,3,9
%o A396151     for _ in range(3,n+1):
%o A396151         a0,a1,a2 = a1,a2,4*a2-6*a1+4*a0-1
%o A396151     return a2
%o A396151 (Python)
%o A396151 def A396151(n): return ((1<<n+1)|1)-(0 if n&3==2 else (1<<(n>>1)+1) if n&7<2 or n&7==7 else -(1<<(n>>1)+1)) # _Chai Wah Wu_, May 31 2026
%Y A396151 Cf. A000749.
%K A396151 nonn,easy
%O A396151 0,2
