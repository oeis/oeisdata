%N A396620 a(n) = r(n,n), where r(1,k)=f(k)=ceiling(k*c), r(n,k)=f(r(n-1,k)), c=Pi.
%C A396620 a(n + 1)/a(n) approaches c erratically.
%t A396620 c = Pi; f[k_] := f[k] = Ceiling[c*k];
%t A396620 r[1, k_] := f[k]; r[n_, k_] := r[n, k] = f[r[n - 1, k]];
%t A396620 Table[r[n, n], {n, 1, 100}]
