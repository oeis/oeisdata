%I A396848 #9 Jul 07 2026 07:56:37
%S A396848 1,2,-12,144,-2336,45280,-990656,23706240,-608588032,16547968000,
%T A396848 -472331629568,14060901615616,-434441992339456,13879699397251072,
%U A396848 -457176711837663232,15489094745859571712,-538740771473323065344,19207279391107747938304,-700999459763409071112192,26161201324727110586335232
%N A396848 G.f. satisfies: A(x) = A^3(x) - 4*x^2.
%C A396848 Herein, A^n(x) denotes the n-th iteration of A(x).
%H A396848 Paul D. Hanna, <a href="/A396848/b396848.txt">Table of n, a(n) for n = 1..400</a>
%F A396848 G.f. A(x) = Sum_{n>=1} a(n)*x^n satisfies the following formulas.
%F A396848 (1) A(x) = A^3(x) - 4*x^2.
%F A396848 (2) A(x) = sqrt( A^4(x) - A^2(x) )/2.
%F A396848 (3) A(x) = R(x) + 4*R^2(x)^2 where A(R(x)) = x and R^2(x) + 4*R^3(x)^2 = x so that -R(-x) is the g.f. of A373314.
%F A396848 (4) A(x) = A( x + 4*R(x)^2 ) - 4*x^2 where A(R(x)) = x.
%F A396848 (5) A^2(x) = x + 4*R(x)^2 where A(R(x)) = x.
%F A396848 (6) A^2(x) = A( A(x) + 4*x^2 ) - 4*A(x)^2.
%e A396848 G.f.: A(x) = x + 2*x^2 - 12*x^3 + 144*x^4 - 2336*x^5 + 45280*x^6 - 990656*x^7 + 23706240*x^8 + ...
%e A396848 The third iteration of A(x) begins
%e A396848 A^3(x) = x + 6*x^2 - 12*x^3 + 144*x^4 - 2336*x^5 + 45280*x^6 - 990656*x^7 + 23706240*x^8 + ...
%e A396848 where A(x) = A^3(x) - 4*x^2.
%e A396848 Other pertinent iterations of A(x) begin as follows.
%e A396848 A^2(x) = x + 4*x^2 - 16*x^3 + 176*x^4 - 2752*x^5 + 52288*x^6 - 1129728*x^7 + 26801152*x^8 + ...
%e A396848 A^4(x) = x + 8*x^2 + 96*x^4 - 1792*x^5 + 36480*x^6 - 818688*x^7 + 19907584*x^8 + ...
%e A396848 where A^4(x) - A^2(x) = 4*A(x)^2.
%e A396848 Let R(x) satisfy R(A(x)) = x, then
%e A396848 R(x) = x - 2*x^2 + 20*x^3 - 304*x^4 + 5728*x^5 - 123680*x^6 + 2942016*x^7 - 75356544*x^8 + ... + (-1)^(n-1)*A373314(n)*x^n + ...
%e A396848 where R(x) = sqrt( A^2(x) - x ) / 2.
%o A396848 (PARI) {a(n) = my(V=[0,1,2],A,C); for(i=3,n, V = concat(V,0);
%o A396848 A = Ser(V); C = subst(A,x,subst(A,x,A));
%o A396848 V[#V] = -polcoef(C-A,#V-1)/2; ); polcoef(GF=Ser(V),n)}
%o A396848 {upto(n) = a(n); Vec(GF +x*O(x^n))}
%o A396848 upto(30)
%Y A396848 Cf. A373314, A138740, A292809, A396796.
%K A396848 sign
%O A396848 1,2
