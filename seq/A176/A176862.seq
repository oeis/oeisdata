%N A176862 Triangle read by rows: T(n,m) = (-1)^m * (n-m)! * binomial(n-1, m) + (-1)^(n-m+1) * (m-1)! * binomial(n - 1, n - m + 1), n>=3, 2<=m<n.
%C A176862 Triangle is symmetric.
%D A176862 F. S. Roberts, Applied Combinatorics, Prentice-Hall, 1984, p. 576 and 270.
%e A176862 Triangle begin:
%e A176862   {2},
%e A176862   {5, 5},
%e A176862   {37, -16, 37},
%e A176862   {239, -50, -50, 239},
%e A176862   {1801, -492, 180, -492, 1801},
%e A176862   {15119, -4186, 714, 714, -4186, 15119},
%e A176862   {141121, -40336, 8568, -2688, 8568, -40336, 141121},
%e A176862   {1451519, -423342, 90504, -13104, -13104, 90504, -423342, 1451519},
%e A176862   ...
%t A176862 t[n_, m_] := (-1)^m*(n - m)!*Binomial[n - 1, m] + (-1)^(n - m + 1)*(n - (n - m + 1))!*Binomial[n - 1, n - m + 1];
%t A176862 Table[Table[t[n, m], {m, 2, n - 1}], {n, 3, 10}];
