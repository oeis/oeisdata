%S A176933 2,103,10009,100000081
%N A176933 Primes of the form 3^k + 100^k.
%C A176933 a(5), if it exists, corresponds to k > 10000 and has > 20000 digits. - _Michael S. Branicky_, May 07 2026
%t A176933 Select[Table[3^n+100^n, {n,0,100}], PrimeQ]  (* _Harvey P. Dale_, Apr 04 2011 *)
%o A176933 (Magma) [ a: n in [0..1500] | IsPrime(a) where a is 3^n+100^n ];
