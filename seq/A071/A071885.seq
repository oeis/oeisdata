%N A071885 Trajectory of 38 under map x -> A002487(x)*A002487(x+1).
%H A071885 Alois P. Heinz, <a href="/A071885/b071885.txt">Table of n, a(n) for n = 0..56</a>
%p A071885 b:= proc(n) option remember; `if`(n<2, n,
%p A071885      (q-> b(q)+(n-2*q)*b(n-q))(iquo(n, 2)))
%p A071885     end:
%p A071885 a:= proc(n) option remember; `if`(n=0, 38,
%p A071885      (t-> b(t)*b(t+1))(a(n-1)))
%p A071885     end:
%p A071885 seq(a(n), n=0..26);  # _Alois P. Heinz_, Apr 27 2026
