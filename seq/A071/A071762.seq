%I A071762 #27 May 03 2026 00:53:49
%S A071762 0,1,2,11,21,12,111,211,121,112,1111,2111,1211,1121,1112,11111,21111,
%T A071762 12111,11211,11121,11112,111111,211111,121111,112111,111211,111121,
%U A071762 111112,1111111,2111111,1211111,1121111,1112111,1111211,1111121,1111112,11111111,21111111
%N A071762 Leftmost 1 is converted to a 2, which then propagates one step at a time until it is rightmost; then it changes to a pair of 1's and the process repeats.
%C A071762 Arises in analysis of Bulgarian solitaire.
%C A071762 From _J.N. Cressey_, Apr 24 2026: (Start)
%C A071762 To construct a(n) for n > 0: repeat the digit 1 A003056(n) times. Let r = A002262(n). If r > 0, replace the digit at position r, 1-indexed from the left, with the digit 2.
%C A071762 The run lengths of 1's from either end in the decimal representation are given by: A128138(n) from the left end, for n >= 1; and A025581(n) from the right end. (End)
%H A071762 Harvey P. Dale, <a href="/A071762/b071762.txt">Table of n, a(n) for n = 0..1000</a>
%F A071762 a(n) = A002275(A003056(n)) + (1-A010054(n))*10^A025581(n). - _J.N. Cressey_, Apr 19 2026
%t A071762 f1[{a_,b_}]:={a,NestList[FromDigits[RotateRight[IntegerDigits[#]]]&, b, IntegerLength[ b]-1]}; Join[{0},f1/@Table[{FromDigits[PadRight[{},n,1]], FromDigits[ PadRight[{2},n,1]]},{n,7}]//Flatten] (* _Harvey P. Dale_, May 15 2018 *)
%o A071762 (Python)
%o A071762 from math import comb, isqrt
%o A071762 def a(n):
%o A071762     L, i = (isqrt(1+8*n)-1)//2, n-comb((1+isqrt(8+8*n))//2,2) # A003056(n), A002262(n)
%o A071762     return 10**L//9 + int(i > 0)*10**(L-i)
%o A071762 print([a(n) for n in range(38)]) # _Michael S. Branicky_, Apr 24 2026
%Y A071762 Cf. A071761.
%Y A071762 Cf. A003056, A002262, A002275, A010054, A025581, A057944, A128138.
%K A071762 nonn,easy,changed
%O A071762 0,3
