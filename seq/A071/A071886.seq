%N A071886 Trajectory of 41 under map x -> A002487(x)*A002487(x+1).
%H A071886 Alois P. Heinz, <a href="/A071886/b071886.txt">Table of n, a(n) for n = 0..59</a>
%p A071886 b:= proc(n) option remember; `if`(n<2, n,
%p A071886      (q-> b(q)+(n-2*q)*b(n-q))(iquo(n, 2)))
%p A071886     end:
%p A071886 a:= proc(n) option remember; `if`(n=0, 41,
%p A071886      (t-> b(t)*b(t+1))(a(n-1)))
%p A071886     end:
%p A071886 seq(a(n), n=0..29);  # _Alois P. Heinz_, Apr 27 2026
