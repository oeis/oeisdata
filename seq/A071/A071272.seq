%T A071272 232,242,252,262,272,303,313,323,333,343,353,363,404,414,424,434,444,
%U A071272 454,505,515,525,535,545,606,616,626,636,707,717,727,808,818,909,10001
%N A071272 Palindromes in A066492.
%C A071272 Conjecture: m is a term if and only if 1<=m<=9 or m is a palindrome of odd length 2k+1 such that the sum of the k-th and (k+1)-th decimal digits is less than or equal to 9. - _Chai Wah Wu_, May 30 2026
%C A071272 Also palindromes p such that 11*p is a palindrome with an even number of digits. - _David A. Corneth_, May 30 2026
%H A071272 David A. Corneth, <a href="/A071272/b071272.txt">Table of n, a(n) for n = 1..10000</a>
%o A071272 (Python)
%o A071272 from itertools import count, islice
%o A071272 def A071272_gen():
%o A071272     for n in count(1):
%o A071272         m = (n*10**len(s:=str(n))+int(s[::-1]))//11
%o A071272         if (t:=str(m))==t[::-1]:
%o A071272             yield m
%o A071272 A071272_list = list(islice(A071272_gen(),40)) # _Chai Wah Wu_, May 30 2026
%o A071272 (PARI) is(n) = {if(!ispal(n), return(0));	ispal(11*n) && #digits(11*n) % 2 == 0}
%o A071272 ispal(n) = n == fromdigits(Vecrev(digits(n))) \\ _David A. Corneth_, May 30 2026
