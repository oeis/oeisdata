%S A211393 1,1,5,69,2057,111465,9704397,1244894637,221232748305,52050205317969,
%T A211393 15662965291361685,5867751811494701205,2677887724787888962329,
%U A211393 1462537391313912349354425,941812152929331549233701725,706153411932893616967191153405
%N A211393 E.g.f.: exp( Sum_{n>=1} x^(2*n) / (2*n*(2*n-1)) ) = Sum_{n>=0} a(n)*x^(2*n)/(2*n)!.
%C A211393 Sum_{n>=0} a(n)/(2*n)! = 2.
%H A211393 Seiichi Manyama, <a href="/A211393/b211393.txt">Table of n, a(n) for n = 0..225</a>
%F A211393 E.g.f.: sqrt(1-x^2)*exp(x*arctanh(x)). - _Vladimir Kruchinin_, Feb 26 2015
%F A211393 From _Seiichi Manyama_, Mar 31 2026: (Start)
%F A211393 a(0) = 1; a(n) = Sum_{k=1..n} binomial(2*n-1,2*k-1) * (2*(k-1))! * a(n-k).
%F A211393 E.g.f. A(x) satisfies A'(x)/A(x) = arctanh(x). (End)
%e A211393 E.g.f.: A(x) = 1 + x^2/2! + 5*x^4/4! + 69*x^6/6! + 2057*x^8/8! +... where log(A(x)) = x^2/(1*2) + x^4/(3*4) + x^6/(5*6) + x^8/(7*8) +...
%t A211393 nmax = 20; CoefficientList[Series[(1 - Sqrt[x])^((1 - Sqrt[x])/2) * (1 + Sqrt[x])^((1 + Sqrt[x])/2), {x, 0, nmax}], x] * (2*Range[0, nmax])! (* _Vaclav Kotesovec_, Oct 28 2024 *)
%o A211393 (PARI) {a(n)=(2*n)!*polcoeff(exp(sum(m=1, n, x^(2*m)/(2*m*(2*m-1)))+x*O(x^(2*n))), 2*n)}
%o A211393 for(n=0, 20, print1(a(n), ", "))
%Y A211393 Cf. A255432, A394728.
%K A211393 nonn,changed
%O A211393 0,3
%A A211393 _Paul D. Hanna_, Feb 08 2013
