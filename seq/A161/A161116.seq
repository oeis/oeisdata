%S A161116 0,0,0,1,0,0,2,0,0,2,0,1,2,0,0,2,2,0,2,0,0,4,0,1,2,0,2,2,0,0,4,2,0,2,
%T A161116 0,0,4,2,0,3,0,2,2,0,2,2,2,0,4,0,0,6,0,0,2,0,2,4,2,1,2,2,0,2,0,2,6,0,
%U A161116 0,2,2,2,4,0,0,4,2,0,2,2,0,6,0,1,4,0,4,2,0,0,2
%N A161116 a(n) is the number of nontrivial positive divisors of 2n+3.
%C A161116 a(n) = 0 iff n is in A067076, i.e., 2n+3 is prime.
%C A161116 a(n) is the number of positive integers of the form (n-3k)/(2k+1), 1 <= k <= n/3.
%H A161116 Amiram Eldar, <a href="/A161116/b161116.txt">Table of n, a(n) for n = 0..10000</a>
%F A161116 a(n) = A070824(2n+3).
%F A161116 For n >= 1, a(n) = A160973(n) + A079978(n). - _Vladimir Shevelev_, Jun 07 2009
%F A161116 Sum_{k=1..n} a(k) ~ (log(n) + 2*gamma + 3*log(2) - 5)*n/2, where gamma is Euler's constant (A001620). - _Amiram Eldar_, Mar 10 2026
%e A161116 Since for n = 3 we have 2n+3 = 9 and only nontrivial divisor of 9 is 3, then a(3) = 1.
%t A161116 a[n_] := DivisorSigma[0, 2*n+3] - 2; Array[a, 100, 0] (* _Amiram Eldar_, Mar 10 2026 *)
%o A161116 (PARI) a(n) = numdiv(2*n+3) - 2; \\ _Michel Marcus_, Feb 08 2016
%o A161116 (Magma) [NumberOfDivisors(2*n+3)-2: n in [0..100]]; // _Vincenzo Librandi_, Feb 08 2016
