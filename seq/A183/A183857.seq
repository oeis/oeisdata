%T A183857 314,344,375,407,441,476,512,550,589,629,671,714,758,804,851,899,949,
%U A183857 1000,1052,1106,1161,1217,1275,1334,1394,1456,1519,1583,1649,1716,1784,1854,1925,1997,2071
%N A183857 a(n) = n - 1 + ceiling((2/3)*n^2); complement of A183874.
%H A183857 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (2,-1,1,-2,1).
%F A183857 a(n) = n - 1 + ceiling((2/3)*n^2).
%F A183857 From _Elmo R. Oliveira_, Apr 01 2026: (Start)
%F A183857 a(n) = 2*a(n-1) - a(n-2) + a(n-3) - 2*a(n-4) + a(n-5).
%F A183857 G.f.: x*(1 + 2*x + x^2 + x^3 - x^4)/((1 - x^3)*(1 - x)^2). (End)
%F A183857 E.g.f.: (9 + exp(x)*(6*x^2 + 15*x - 7) - 2*exp(-x/2)*cos(sqrt(3)*x/2))/9. - _Stefano Spezia_, Apr 02 2026
%t A183857 a=3/2; b=0;
%t A183857 Table[n+Floor[(a*n+b)^(1/2)],{n,100}]
%t A183857 Table[n-1+Ceiling[(n*n-b)/a],{n,80}]
%t A183857 LinearRecurrence[{2,-1,1,-2,1},{1,4,8,14,21},60] (* _Harvey P. Dale_, Apr 12 2020 *)
