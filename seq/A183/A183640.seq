%U A183640 50774508856,168710304812,573264314632,1991498803100,7067664046936,25588350776972,94331862730792,353313581186300,1341314218007416
%N A183640 Number of (n+1) X 8 0..3 arrays with every 2 X 2 subblock summing to 6.
%H A183640 Paolo Xausa, <a href="/A183640/b183640.txt">Table of n, a(n) for n = 1..1000</a> (terms 1..22 from R. H. Hardin).
%H A183640 Christian Krause, <a href="/A183640/a183640.txt">Proof of formula</a>, Jun 23 2026.
%F A183640 a(n) = 10*a(n-1) - 35*a(n-2) + 50*a(n-3) - 24*a(n-4).
%F A183640 From _Colin Barker_, Mar 31 2018: (Start)
%F A183640 G.f.: 4*x*(19793 - 170932*x + 465350*x^2 - 393216*x^3) / ((1 - x)*(1 - 2*x)*(1 - 3*x)*(1 - 4*x)).
%F A183640 a(n) = 52670 + 3025*2^(2+n) + 254*3^(1+n) + 4^(1+n).
%F A183640 (End) [proved by _Christian Krause_, Jun 23 2026]
%e A183640 Some solutions for 3 X 8:
%e A183640   2 0 3 0 3 1 3 0      0 3 1 3 1 3 1 3      1 3 1 2 1 1 0 3
%e A183640   2 2 1 2 1 1 1 2      1 2 0 2 0 2 0 2      2 0 2 1 2 2 3 0
%e A183640   2 0 3 0 3 1 3 0      0 3 1 3 1 3 1 3      2 2 2 1 2 0 1 2
%t A183640 A183640[n_] := 52670 + 3025*2^(n+2) + 254*3^(n+1) + 4^(n+1);
%t A183640 Array[A183640, 25] (* _Paolo Xausa_, Jun 24 2026 *)
