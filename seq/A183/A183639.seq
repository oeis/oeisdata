%S A183639 21016,31060,53512,105604,231736,551380,1398952,3743524,10479256,
%T A183639 30483700,91664392,283832644,902755576,2945024020,9845481832,
%U A183639 33704772964,118040932696,422335788340,1540872323272,5720102724484,21554302962616,82246991512660,317093511900712,1232723098807204
%N A183639 Number of (n+1) X 7 0..3 arrays with every 2 X 2 subblock summing to 6.
%H A183639 Paolo Xausa, <a href="/A183639/b183639.txt">Table of n, a(n) for n = 1..1000</a> (terms 1..77 from R. H. Hardin).
%H A183639 Christian Krause, <a href="/A183639/a183639.txt">Proof of formula</a>, Jun 23 2026.
%F A183639 a(n) = 10*a(n-1) - 35*a(n-2) + 50*a(n-3) - 24*a(n-4).
%F A183639 From _Colin Barker_, Mar 31 2018: (Start)
%F A183639 G.f.: 4*x*(5254 - 44775*x + 119618*x^2 - 98304*x^3) / ((1 - x)*(1 - 2*x)*(1 - 3*x)*(1 - 4*x)).
%F A183639 a(n) = 12138 + 483*2^(3+n) + 14*3^(3+n) + 4^(1+n).
%F A183639 (End) [proved by _Christian Krause_, Jun 23 2026]
%F A183639 E.g.f.: 2*(2*exp(4*x) + 189*exp(3*x) + 1932*exp(2*x) + 6069*exp(x) - 8192). - _Stefano Spezia_, Jun 24 2026
%e A183639 Some solutions for 3 X 7:
%e A183639   0 0 1 3 1 2 3     3 2 3 3 0 0 1     3 0 1 0 3 1 3
%e A183639   3 3 2 0 2 1 0     0 1 0 0 3 3 2     1 2 3 2 1 1 1
%e A183639   0 0 1 3 1 2 3     3 2 3 3 0 0 1     2 1 0 1 2 2 2
%t A183639 A183639[n_] := 12138 + 483*2^(n+3) + 14*3^(n+3) + 4^(n+1);
%t A183639 Array[A183639, 25] (* _Paolo Xausa_, Jun 24 2026 *)
