%T A183859 199,215,233,251,269,289,309,329,351,373,395,419,443,467,493,519,545,
%U A183859 573,601,629,659,689,719,751,783,815,849,883,917,953,989,1025,1063,1101
%N A183859 a(n) = n - 1 + ceiling((n^2)/3); complement of A183858.
%H A183859 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (2,-1,1,-2,1).
%F A183859 a(n) = n - 1 + ceiling((n^2)/3).
%F A183859 From _Elmo R. Oliveira_, Apr 01 2026: (Start)
%F A183859 a(n) = 2*a(n-1) - a(n-2) + a(n-3) - 2*a(n-4) + a(n-5).
%F A183859 G.f.: x*(1 + x + x^3 - x^4)/((1 - x)^3*(1 + x + x^2)). (End)
%F A183859 E.g.f.: (9 + exp(x)*(3*x^2 + 12*x - 5) - 4*exp(-x/2)*cos(sqrt(3)*x/2))/9. - _Stefano Spezia_, Apr 02 2026
%t A183859 a=3; b=0;
%t A183859 Table[n+Floor[(a*n+b)^(1/2)],{n,100}]
%t A183859 Table[n-1+Ceiling[(n*n-b)/a],{n,80}]
