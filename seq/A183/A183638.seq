%S A183638 5684,9256,17612,38056,90524,231736,629132,1793416,5328764,16413016,
%T A183638 52195052,170891176,574845404,1983103096,7003319372,25265467336,
%U A183638 92897360444,347253741976,1316323506092,5047850897896,19540336713884,76210671209656,298995707859212,1178452000398856,4661235708265724
%N A183638 Number of (n+1) X 6 0..3 arrays with every 2 X 2 subblock summing to 6.
%H A183638 R. H. Hardin, <a href="/A183638/b183638.txt">Table of n, a(n) for n = 1..200</a>
%H A183638 Christian Krause, <a href="/A183638/a183638.txt">Proof of formula</a>, Jun 20 2026
%H A183638 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (10,-35,50,-24).
%F A183638 a(n) = 10*a(n-1) - 35*a(n-2) + 50*a(n-3) - 24*a(n-4).
%F A183638 From _Colin Barker_, Mar 31 2018: (Start)
%F A183638 G.f.: 4*x*(1421 - 11896*x + 30998*x^2 - 24576*x^3) / ((1 - x)*(1 - 2*x)*(1 - 3*x)*(1 - 4*x)).
%F A183638 a(n) = 2702 + 301*2^(2+n) + 62*3^(1+n) + 4^(1+n).
%F A183638 (End) [proved by _Christian Krause_, Jun 20 2026]
%e A183638 Some solutions for 3 X 6:
%e A183638   2 0 1 2 3 0    2 1 2 3 1 1    1 1 1 1 1 1    2 3 3 3 1 0
%e A183638   1 3 2 1 0 3    1 2 1 0 2 2    3 1 3 1 3 1    1 0 0 0 2 3
%e A183638   1 1 0 3 2 1    2 1 2 3 1 1    0 2 0 2 0 2    2 3 3 3 1 0
%t A183638 A183638[n_] := 2702 + 301*2^(n+2) + 62*3^(n+1) + 4^(n+1);
%t A183638 Array[A183638, 25] (* _Paolo Xausa_, Jun 22 2026 *)
