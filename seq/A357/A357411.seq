%S A357411 1,1,2,2,3,5,6,6,7,9,10,10,11,13,26,26,27,45,46,74,93,99,100,162,163,
%T A357411 165,166,458,459,865,866,866,1647,1669,2724,4386,4387,4425,4714,9114,
%U A357411 9115,17577,17578,19228,38223,38273,38274,76228,76229,76341,78248,157650
%N A357411 Number of nonempty subsets of {1..n} whose elements have an odd harmonic mean.
%H A357411 Martin Fuller, <a href="/A357411/b357411.txt">Table of n, a(n) for n = 1..75</a>
%F A357411 a(p) = a(p-1) + 1 for prime p > 2. - _Michael S. Branicky_, Sep 30 2022
%e A357411 a(11) = 10 subsets: {1}, {3}, {5}, {7}, {9}, {11}, {2, 6}, {2, 3, 6}, {3, 6, 10} and {3, 5, 6, 10}.
%o A357411 (Python)
%o A357411 from fractions import Fraction
%o A357411 from functools import lru_cache
%o A357411 def cond(s, c): h = c/s; return h.denominator == 1 and h.numerator&1
%o A357411 @lru_cache(maxsize=None)
%o A357411 def b(n, s, c):
%o A357411     if n == 0: return int (c > 0 and cond(s, c))
%o A357411     return b(n-1, s, c) + b(n-1, s+Fraction(1, n), c+1)
%o A357411 a = lambda n: b(n, 0, 0)
%o A357411 print([a(n) for n in range(1, 18)]) # _Michael S. Branicky_, Sep 29 2022
%o A357411 (PARI) gppf(n)=if(abs(n)>1, vecmax(apply(pe->pe[1]^pe[2], Col(factor(n)))), n);
%o A357411 N(s,k,v,m)={
%o A357411   /* number of ways to sum to s using k distinct reciprocals from v[1..m] */
%o A357411   /* v must be in ascending order of greatest prime-power factor gppf() */
%o A357411   if(k==1, return(if(numerator(s)==1, sum(i=1, m, v[i]==denominator(s)))));
%o A357411   my(r=0, f=gppf(denominator(s)));
%o A357411   forstep(i=m, k, -1, if(gppf(v[i]) < f, break); if(s > 1/v[i], r += N(s - 1/v[i], k-1, v, i-1)));
%o A357411   r};
%o A357411 a(n)=my(v=vecsort([1..n], gppf)); (n+1)\2 + sum(k=2, n, sum(j=2, n-1, if(j%2, N(k/j, k, v, n))));
%o A357411 \\ _Martin Fuller_, Apr 24 2026
