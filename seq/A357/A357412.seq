%U A357412 5847,11834,11834,23409,23409,23470,47202,47203,47203,94762,94762,94763,94763,195092
%N A357412 Number of nonempty subsets of {1..n} whose elements have an even harmonic mean.
%H A357412 Martin Fuller, <a href="/A357412/b357412.txt">Table of n, a(n) for n = 1..75</a>
%F A357412 a(p) = a(p-1) for prime p > 2. - _Michael S. Branicky_, Sep 30 2022
%e A357412 a(11) = 9 subsets: {2}, {4}, {6}, {8}, {10}, {3, 6}, {1, 3, 6}, {3, 4, 6} and {1, 2, 3, 6}.
%o A357412 (Python)
%o A357412 from fractions import Fraction
%o A357412 from functools import lru_cache
%o A357412 def cond(s, c): h = c/s; return h.denominator == 1 and h.numerator&1 == 0
%o A357412 @lru_cache(maxsize=None)
%o A357412 def b(n, s, c):
%o A357412     if n == 0: return int (c > 0 and cond(s, c))
%o A357412     return b(n-1, s, c) + b(n-1, s+Fraction(1, n), c+1)
%o A357412 a = lambda n: b(n, 0, 0)
%o A357412 print([a(n) for n in range(1, 18)]) # _Michael S. Branicky_, Sep 29 2022
%o A357412 (PARI) gppf(n)=if(abs(n)>1, vecmax(apply(pe->pe[1]^pe[2], Col(factor(n)))), n);
%o A357412 N(s,k,v,m)={
%o A357412   /* number of ways to sum to s using k distinct reciprocals from v[1..m] */
%o A357412   /* v must be in ascending order of greatest prime-power factor gppf() */
%o A357412   if(k==1, return(if(numerator(s)==1, sum(i=1, m, v[i]==denominator(s)))));
%o A357412   my(r=0, f=gppf(denominator(s)));
%o A357412   forstep(i=m, k, -1, if(gppf(v[i]) < f, break); if(s > 1/v[i], r += N(s - 1/v[i], k-1, v, i-1)));
%o A357412   r};
%o A357412 a(n)=my(v=vecsort([1..n], gppf)); n\2 + sum(k=2, n, sum(j=2, n-1, if(j%2==0, N(k/j, k, v, n))));
%o A357412 \\ _Martin Fuller_, Apr 24 2026
