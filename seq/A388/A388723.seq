%S A388723 1,2,2,2,2,4,4,2,2,4,6,6,4,6,4,4,6,4,6,6,8,6,8,8,6,10,8,6,8,8,6,10,8,
%T A388723 6,8,6,12,6,10,10,10,12,8,10,14,12,14,12,14,12,8,14,16,10,16,10,12,14,
%U A388723 12,8,10,14,18,14,12,10,12,12,14,12,10,16,14
%N A388723 Manhattan distance of prime(n) on the Ulam spiral from origin.
%F A388723 a(n) = abs(A214664(n)) + abs(A214665(n)).
%e A388723 For n = 2 the 2nd prime is 3. On the Ulam spiral, 3 is at coordinates (1, 1). a(2) = |1| + |1| = 2.
%o A388723 (Python)
%o A388723 import math
%o A388723 from sympy import isprime
%o A388723 def A388723(n):
%o A388723     if n == 1:
%o A388723         return 0
%o A388723     k = math.ceil((math.sqrt(n) - 1) / 2)
%o A388723     t = 2 * k
%o A388723     m = (t + 1) * (t + 1)
%o A388723     if n >= m - t:
%o A388723         x, y = k - (m - n), -k
%o A388723     elif n >= m - 2 * t:
%o A388723         x, y = -k, -k + (m - t - n)
%o A388723     elif n >= m - 3 * t:
%o A388723         x, y = -k + (m - 2 * t - n), k
%o A388723     else:
%o A388723         x, y = k, k - (m - 3 * t - n)
%o A388723     return abs(x) + abs(y)
%o A388723 def gen(limit):
%o A388723     sequence = []
%o A388723     count = 0
%o A388723     n = 2
%o A388723     while count < limit:
%o A388723         if isprime(n):
%o A388723             sequence.append(A388723(n))
%o A388723             count += 1
%o A388723         n += 1
%o A388723     return sequence
%o A388723 print(gen(30))
%Y A388723 Cf. A000040, A214526, A214664, A214665.
