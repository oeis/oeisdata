%T A388418 330,126,336,248,412,590,64,1406,282,672,90,250,378,712,80,138,1236,
%U A388418 514,256,60,32,390,1644,1684,2538,612,150,1212,3276,616,2286,4824,124,690,1284
%N A388418 a(n) is the least k such that prime(n)^prime(n) - k is prime.
%H A388418 Robert Israel, <a href="/A388418/b388418.txt">Table of n, a(n) for n = 1..206</a>
%p A388418 f:= proc(n) local p,t;
%p A388418  p:= ithprime(n); t:= p^p;
%p A388418  t - prevprime(t)
%p A388418 end proc:
%p A388418 map(f, [$1..70]); # _Robert Israel_, Mar 20 2026
%t A388418 a[n_]:=Module[{k=1},While[!PrimeQ[Prime[n]^Prime[n]-k],k++];k];Array[a,56] (* _James C. McMahon_, Sep 19 2025 *)
%o A388418 (PARI) a388418(n) = my(p=prime(n)^prime(n),k=0); until(ispseudoprime(p-k), k++); k
%Y A388418 Cf. A051674, A388417.
%K A388418 nonn
