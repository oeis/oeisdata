%I A026180 #12 Mar 23 2026 17:00:28
%S A026180 1,4,10,12,16,22,28,30,34,36,40,46,48,52,58,64,66,70,76,82,84,88,90,
%T A026180 94,100,102,106,108,112,118,120,124,130,136,138,142,144,148,154,156,
%U A026180 160,166,172,174,178,184,190,192,196,198,202,208
%N A026180 a(n) = s(k), where k is the n-th number such that s(j)<s(k) for all j<k, where s = A026177.
%C A026180 RECORDS transform of A026177. - _R. J. Mathar_, Mar 23 2026
%H A026180 F. M. Dekking, <a href="https://arxiv.org/abs/2001.08915">Permutations of N generated by left-right filling algorithms</a>, arXiv:2001.08915 [math.CO], 2020, see R_orec in section 2.3.
%F A026180 a(n) = A026177(A026179(n)). - _R. J. Mathar_, Mar 23 2026
%p A026180 A026180 := proc(n)
%p A026180     option remember ;
%p A026180     if n = 1 then
%p A026180         1;
%p A026180     else
%p A026180         for j from 1 do
%p A026180             if A026177(j) > procname(n-1) then
%p A026180                 return A026177(j) ;
%p A026180             end if;
%p A026180         end do:
%p A026180     end if;
%p A026180 end proc:
%p A026180 seq(A026180(n),n=1..300) ; # _R. J. Mathar_, Mar 23 2026
%Y A026180 Cf. A026177, A026179 (positions of records).
%K A026180 nonn,changed
%O A026180 1,2
%A A026180 _Clark Kimberling_
