%N A021026 Decimal expansion of 1/22.
%H A021026 <a href="/index/Rec#order_02">Index entries for linear recurrences with constant coefficients</a>, signature (0,1).
%F A021026 G.f.: x*(4+5*x)/(1-x^2). - _Jaume Oliver Lafont_, Mar 20 2009
%F A021026 From _Rayhan Ahmed_, May 30 2026: (Start)
%F A021026 a(n) = (9+(-1)^n)*(1-0^n)/2.
%F A021026 a(n) = 5 - A000035(n) for n >= 1.
%F A021026 a(n) = A010710(n-1) for n >= 1. (End)
%F A021026 E.g.f.: 5*(cosh(x) - 1) + 4*sinh(x). - _Stefano Spezia_, Jun 09 2026
%t A021026 Join[{0},RealDigits[1/22,10,120][[1]]] (* _Harvey P. Dale_, Apr 29 2011 *)
%t A021026 (* Alternative: *)
%t A021026 CoefficientList[ Series[ x (4+5x)/(1-x^2),{x,0,120}],x] (* _Harvey P. Dale_, Apr 29 2011 *)
%Y A021026 Cf. A000035, A010710.
%K A021026 nonn,cons,easy,changed
