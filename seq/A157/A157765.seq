%S A157765 2,18,194,2066,22018,234642,2500546,26647954,283983362,3026369298,
%T A157765 32251576514,343700350226,3662764537858,39033547830162,
%U A157765 415974830066626,4432983135477394,47241655165240322,503447433600744978,5365165922164132034,57175791256846535186
%N A157765 Expansion of 2*(1 - x) / (1 - 10*x - 7*x^2).
%C A157765 Number of independent vertex sets in the hexagonal snake graph on 5*n + 1 vertices with cut vertices at distance 3. - _Andrew Howroyd_, Jul 19 2026
%H A157765 Colin Barker, <a href="/A157765/b157765.txt">Table of n, a(n) for n = 0..900</a>
%H A157765 Tomislav Došlić and Frode Måløy, <a href="https://doi.org/10.1016/j.disc.2009.11.026">Chain hexagonal cacti: Matchings and independent sets</a>, Discr. Math., 310 (2010), 1676-1690.
%H A157765 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/IndependentVertexSet.html">Independent Vertex Set</a>.
%H A157765 <a href="/index/Rec#order_02">Index entries for linear recurrences with constant coefficients</a>, signature (10,7).
%F A157765 From _Colin Barker_, Nov 25 2017: (Start)
%F A157765 a(n) = ((5-4*sqrt(2))^n*(-1+sqrt(2)) + (1+sqrt(2))*(5+4*sqrt(2))^n) / sqrt(2).
%F A157765 a(n) = 10*a(n-1) + 7*a(n-2) for n > 1. (End)
%F A157765 E.g.f.: exp(5*x)*(2*cosh(4*sqrt(2)*x) + sqrt(2)*sinh(4*sqrt(2)*x)). - _Stefano Spezia_, Jul 19 2026
%e A157765 From _Andrew Howroyd_, Jul 18 2026: (Start)
%e A157765 Illustration of the hexagonal snake graph for n = 3:
%e A157765         o---o   o---o   o---o
%e A157765        /     \ /     \ /     \
%e A157765       o       o       o       o
%e A157765        \     / \     / \     /
%e A157765         o---o   o---o   o---o
%e A157765 (End)
%t A157765 CoefficientList[Series[(2-2x)/(1-10x-7x^2),{x,0,30}],x] (* _Harvey P. Dale_, Feb 25 2020 *)
%t A157765 (* Alternative: *)
%t A157765 LinearRecurrence[{10,7},{2,18},30] (* _Harvey P. Dale_, Feb 25 2020 *)
%o A157765 (PARI) Vec(2*(1 - x) / (1 - 10*x - 7*x^2) + O(x^40)) \\ _Colin Barker_, Nov 25 2017
