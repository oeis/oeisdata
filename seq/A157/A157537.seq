%I A157537 #12 May 26 2026 01:06:05
%S A157537 1,3,42,310,1965,12621,86828,614664,4137255,24696507,135776850,
%T A157537 704076594,3499379975,16814719845,78438871176,355384933088,
%U A157537 1560604589541,6638708644299,27407266803082,110092581701214,431253742334877
%N A157537 Half the number of length n integer sequences with sum zero and sum of squares 50.
%H A157537 Robert Israel, <a href="/A157537/b157537.txt">Table of n, a(n) for n = 2..10000</a> (n=2..50 from R. H. Hardin)
%F A157537 [cache enabling] count(n,s,ss)->count(n,t,tt) where t=s mod n, q=(t-s)/n, tt=ss+2*q*s+n*q^2; count(n,t,tt)=sum[i^2<=tt]{ count(n-1,t-i,tt-i^2) }. a(n)=count(n,0,50)/2.
%F A157537 Sum_{0<=i<=51} binomial(51,i)*(-1)^i*a(n+i) = 0. - _Robert Israel_, May 25 2026
%p A157537 States:= [seq(seq([a,b],a=-b..b),b=0..50)]: nS:= nops(States):
%p A157537 with(LinearAlgebra):
%p A157537 T:= Matrix(nS,nS,storage=sparse):
%p A157537 for i from 1 to nS do
%p A157537    s:= States[i];
%p A157537    for x in [$-7 .. 7] do
%p A157537      sp:= s + [x,x^2];
%p A157537      if sp[2] <= 50 then
%p A157537        member(sp,States,'j');
%p A157537        T[i,j]:= 1;
%p A157537      fi
%p A157537  od od:
%p A157537 member([0,0],States,'i0');
%p A157537 member([0,50],States,'i1');
%p A157537 M:= Vector[row](nS): M[i0]:= 1:
%p A157537 W:= Vector(nS): W[i1]:= 1/2:
%p A157537 A:= NULL:
%p A157537 for i from 1 to 100 do
%p A157537  M:= M . T;
%p A157537  A:= A, M . W;
%p A157537 od:
%p A157537 A[2..100]; # _Robert Israel_, May 25 2026
%K A157537 nonn
%O A157537 2,2
%A A157537 _R. H. Hardin_, Mar 02 2009
