%S A397449 1,1,-1,-5,35,595,-18445,-1198925,152263475,39131713075,
%T A397449 -19996305381325,-20496213015858125,41955748043461581875,
%U A397449 171892699734062100941875,-1407973103521702668814898125,-23069639301203098228532105778125,755922870982521919654311510031821875
%N A397449 a(n) = Sum_{k=0..n-1} a(k)*(-2)^k, with a(0) = 1.
%C A397449 Up to sign the denominators in the Engel-type expansion given by _Peter Bala_ in A014551.
%F A397449 a(n) = Product_{k=2..n} ((-2)^(k-1)+1).
%F A397449 a(n+1)/a(n) = A014551(n)*(-1)^n, for n > 0.
%F A397449 a(n) = QPochhammer(1/2; -2)_{n+1}, for n > 0, where QPochhammer is the q-analog of the Pochhammer symbol: (a; q)_n.
%F A397449 Sum_{k>=0} (-2)^k/a(k) = -3.
%F A397449 a(n) ~ c * (-2)^(n*(n-1)/2), where c = QPochhammer(1/2, -1/2) = A330863. - _Vaclav Kotesovec_, Jun 27 2026
%t A397449 Join[{1}, Table[QPochhammer[1/2, -2, n+1], {n, 1, 20}]] (* _Vaclav Kotesovec_, Jun 27 2026 *)
%o A397449 (PARI) a(n) = prod(k=2, n, ((-2)^(k-1)+1))
%Y A397449 Cf. A014551, A015013, A216206, A269694, A330863.
%K A397449 sign,easy
%O A397449 0,4
