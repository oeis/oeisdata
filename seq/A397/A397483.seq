%N A397483 Numbers k such that tau(k - d) = tau(k) = tau(k + d), where 1 <= d <= k/4 is some divisor of k and tau(i) = A000005(i).
%e A397483 k = 8: tau(8 - 2) = tau(8) = tau(8 + 2), thus 8 is a term.
%t A397483 q[k_] := AnyTrue[Divisors[k], # <= k/4 && Equal @@ DivisorSigma[0, k + {-#, 0, #}] &]; Select[Range[700], q] (* _Amiram Eldar_, Jun 27 2026 *)
%o A397483 (PARI) isok(k) = fordiv(k, d, if ((d <= k\4) && (numdiv(k-d) == numdiv(k)) && (numdiv(k) == numdiv(k+d)), return(1))); \\ _Michel Marcus_, Jun 27 2026
%Y A397483 Cf. A000005.
%Y A397483 A169834 is a subsequence (d = 1).
%K A397483 nonn
%O A397483 1,1
