%T A397018 1069929,1081872,1081917,1092250,1153242,1155277,1158550,1165684,
%U A397018 1172800,1181587,1181952,1193472,1204992,1207899,1208482,1213632,1230700,1236384,1253304,1276717,1279372
%N A397018 Vampire numbers in base 16: decimal values of base-16 numbers that are the products of two equal-length fangs whose combined base-16 digits perfectly permute the product's digits (excluding double trailing zeros).
%C A397018 A base-16 vampire number is a number that can be factored into two equal-length fangs in hexadecimal representation, where the combined hexadecimal digits of the two fangs are a perfect permutation of the hexadecimal digits of the original product. Following standard definitions, a valid pair cannot consist of two fangs that both end in a trailing zero (e.g., product 123000_16 from fangs 120_16 and 300_16 is disallowed, though a single trailing zero fang like 90_16 is valid).
%C A397018 There are 8, 191 and 5860 terms with 4, 6 and 8 hexadecimal digits, respectively.
%D A397018 Clifford A. Pickover, "Keys to Infinity", Wiley, 1995, Chapter 30 ("Vampire Numbers").
%H A397018 Jaideep Padhi, <a href="/A397018/b397018.txt">Table of n, a(n) for n = 1..6059</a>
%H A397018 Jaideep Padhi, <a href="https://github.com/jaideepsaipadhi/hex-vampire-numbers">Hex Vampire Numbers</a>, GitHub.
%H A397018 Wikipedia, <a href="https://en.wikipedia.org/wiki/Vampire_number">Vampire number</a>.
%e A397018 4752 is a term since 4752 = 1290_16 = 21_16 * 90_16.
%e A397018 1253304 is a term since 1253304 = 131FB8_16 = 138_16 * FB1_16.
%o A397018 (C) // See GitHub link
%o A397018 (Python)
%o A397018 from gmpy2 import digits
%o A397018 from sympy import divisors
%o A397018 def ok(n, base=16):
%o A397018     s = "".join(sorted(digits(n, base)))
%o A397018     if len(s)&1: return False
%o A397018     divs, L, U = divisors(n), base**((len(s)//2)-1), base**(len(s)//2)
%o A397018     for i in range((len(divs)+1)//2+1):
%o A397018         x, y = divs[i], divs[-1-i]
%o A397018         if L <= x < U and L <= y < U and (x%base or y%base):
%o A397018             t, u = digits(x, base), digits(y, base)
%o A397018             if "".join(sorted(t+u)) == s:
%o A397018                 return True
%o A397018     return False
%o A397018 print([k for k in range(1_280_000) if ok(k)]) # _Michael S. Branicky_, Jun 13 2026
%Y A397018 Cf. A014575, A392325, A394373.
