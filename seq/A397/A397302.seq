%S A397302 1,2,10,40,164,672,2752,11272,46168,189096,774504,3172232,12992904,
%T A397302 53216648,217966024,892750472,3656548808,14976580360,61341437256,
%U A397302 251243730824,1029050102216,4214808104456,17263112183880,70706669173896,289602072466120,1186159118461704
%N A397302 Number of ways to tile a strip of length n with three types of tiles.
%C A397302 a(n) counts the ways to tile this strip of length n
%C A397302    _________________       __
%C A397302   |  |  |  |  |  |  | ... |  |
%C A397302   |__|__|__|__|__|__| ... |__|
%C A397302 with these three types of tiles (made up of one, two, and three right triangles)
%C A397302                ___
%C A397302   |\    / \   |   \
%C A397302   |_\, /___\, |____\.
%H A397302 <a href="/index/Rec#order_03">Index entries for linear recurrences with constant coefficients</a>, signature (3,4,2).
%F A397302 a(n) = 3*a(n-1) + 4*a(n-2) + 2*a(n-3).
%F A397302 G.f.: (1 - x)/(1 - 3*x - 4*x^2 - 2*x^3).
%F A397302 a(n) = 2*(A396569(n) + A396569(n-1)).
%F A397302 a(2*n) = a(n)^2 +2*b(n)*(b(n) + 2*a(n-1)) for b(n) = A396569(n).
%e A397302 As an example, here is one of the a(4)=164 ways to tile a strip of length 4.
%e A397302    ___________
%e A397302   |\    | / \ |
%e A397302   |_\___|/___\|
%t A397302 LinearRecurrence[{3, 4, 2}, {1, 2, 10}, 50]
%Y A397302 Cf. A396569.
%K A397302 nonn,easy,changed
%O A397302 0,2
%A A397302 Daniel Bae and _Greg Dresden_, Jun 20 2026
