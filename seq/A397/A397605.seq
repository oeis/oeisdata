%N A397605 a(n) = Sum_{k=0..n} n^(n - k)*hypergeom([k - 1, k - n], [], -1/n) for n > 0, a(0) = 1. Row sums of A397647.
%p A397605 a := n -> local k; ifelse(n = 0, 1, add(n^(n-k) * hypergeom([k-1, k-n], [], -1/n), k = 0..n)): seq(simplify(a(n)), n = 0..20);
%o A397605 (SageMath)
%o A397605 def T(n, k):
%o A397605     return sum(binomial(n-k, j)*rising_factorial(k-1, j)*n^(n-k-j) for j in range(n-k+1))
%o A397605 A = [sum(T(n, k) for k in range(n+1)) for n in range(21)]; print(A)
