%I A397368 #6 Jul 01 2026 22:58:18
%S A397368 4,8,9,27,16,32,25,125,49,343,64,128,81,243,121,1331,169,2197,256,512,
%T A397368 289,4913,361,6859,529,12167,625,3125,729,2187,841,24389,961,29791,
%U A397368 1024,2048,1369,50653,1681,68921,1849,79507,2209,103823,2401,16807,2809,148877
%N A397368 Lexicographically earliest sequence of distinct proper prime powers p^m, m >= 2, such that for any prime p, any run of consecutive multiples of p has length exactly 2.
%C A397368 Variant of A280864 confined to A246547.
%C A397368 Permutation of A246547.
%C A397368 We may partition A280864 into blocks according to a(n-1) coprime to a(n). In A280864, the blocks have variable lengths.
%C A397368 Doing same in this sequence, all resultant blocks are duplexes (a(n), a(n+1)) such that a(n) | a(n+1) and rad(a(n+1)) | a(n) but a(n+1) > a(n). Indeed, in a duplex block, a(n) = p^m implies a(n+1) = p^(m+1).
%C A397368 a(n) is a perfect square (in A000290) for odd n.
%H A397368 Michael De Vlieger, <a href="/A397368/b397368.txt">Table of n, a(n) for n = 1..16384</a>
%e A397368 Table of n, a(n) for n = 1..16:
%e A397368    n    a(n)   2^m 3^m 5^m 7^m 11^m
%e A397368   ---------------------------------
%e A397368    1      4 =  2^2
%e A397368    2      8 =  2^3
%e A397368    3      9 =      3^2
%e A397368    4     27 =      3^3
%e A397368    5     16 =  2^4
%e A397368    6     32 =  2^5
%e A397368    7     25 =          5^2
%e A397368    8    125 =          5^3
%e A397368    9     49 =              7^2
%e A397368   10    343 =              7^3
%e A397368   11     64 =  2^6
%e A397368   12    128 =  2^7
%e A397368   13     81 =      3^4
%e A397368   14    243 =      3^5
%e A397368   15    121 =                  11^2
%e A397368   16   1331 =                  11^3
%t A397368 Block[{s, t, c, f, i, j, k, m, u, nn}, nn = 2^8;
%t A397368   s = {1}~Join~Union@ Flatten@
%t A397368     Table[Array[p^# &, Floor@ Log[p, #] - 1, 2],
%t A397368     {p, Prime@ Range@ PrimePi@ Sqrt[#] } ] &[nn*2^20];
%t A397368   m = Length[s]; c[_] := False; i = u = 1; j = 1; c[s[[i]] ] = True;
%t A397368   Reap[Do[Set[{i, k}, {u, s[[i]] } ];
%t A397368     If[CoprimeQ[j, k],
%t A397368       While[Set[k, s[[i]]]; Or[c[k], ! CoprimeQ[j, k] ], i++];
%t A397368         If[i == u, While[c[s[[u]] ], u++] ],
%t A397368       k = #1^(#2 + 1) & @@ FactorInteger[j][[1]] ];
%t A397368     Set[{c[k], j}, {True, k}]; Sow[k], {n, nn}] ][[-1, 1]] ]
%Y A397368 Cf. A000290, A007947, A246547, A280864, A338444 (squarefree variant), A397126 (powerful variant).
%K A397368 nonn,easy
%O A397368 1,1
%A A397368 _Michael De Vlieger_, Jun 24 2026
