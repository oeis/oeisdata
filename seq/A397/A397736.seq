%I A397736 #7 Jul 20 2026 00:24:34
%S A397736 1,2,5,13,35,97,276,804,2391,7239,22256,69328,218387,694543,2227117,
%T A397736 7192463,23372569,76366271,250720848,826694172,2736354861,9088860681,
%U A397736 30284174103,101197593597,339052905519,1138715832513,3832945044762,12928471234602,43691301318927,147917185540719
%N A397736 a(n) is the number of Motzkin paths of length n in which level steps on even levels come in 2 colors.
%C A397736 Motzkin paths have up steps (1, 1), down steps (1, -1), and level steps (1, 0), never go below the x-axis, and end on the x-axis. Here the level steps at even heights have two colors, while level steps at odd heights have one color.
%C A397736 This is the companion sequence to A176677, where the two-colored level steps occur on odd levels instead. Prodinger obtains this sequence by switching the roles of even and odd levels in the model for A176677.
%H A397736 Felix Huber, <a href="/A397736/b397736.txt">Table of n, a(n) for n = 0..1811</a>
%H A397736 Helmut Prodinger, <a href="https://arxiv.org/abs/2605.10113">Motzkin paths with two variants of level steps on odd levels - a kernel method approach</a>, arXiv:2605.10113 [math.CO], 2026.
%F A397736 G.f.: (1 - 3*x + 2*x^2 - sqrt((1 - x)*(1 - 2*x)*(1 - 3*x - 2*x^2)))/(2*(1 - 2*x)*x^2).
%F A397736 a(n) = 3*a(n - 1) - 2*a(n - 2) + c(n - 2) - 2*c(n - 3) for n >= 3, where c(n) = Sum_{k = 0 .. n} a(k)*a(n - k).
%F A397736 a(n) = (4*(n - 3)*a(n - 4) + 2*a(n - 3) - (9*n - 1)*a(n - 2) + (6*n + 5)*a(n - 1))/(n + 2) for n >= 4.
%e A397736 a(0)=1: the empty path.
%e A397736 a(1)=2: the two colors of the single level step at height 0.
%e A397736 a(2)=5: four paths with two level steps at height 0, each in two colors, and one up-down path.
%p A397736 A397736 := proc(n) option remember; `if`(n = 0, 1, `if`(n = 1, 2, `if`(n = 2, 5, `if`(n = 3, 13, (4*(n - 3)*A397736(n - 4) + 2*A397736(n - 3) - (9*n - 1)*A397736(n - 2) + (6*n + 5)*A397736(n - 1))/(n + 2))))) end proc: seq(A397736(n), n = 0 .. 29);
%t A397736 CoefficientList[Series[(1 - 3*x + 2*x^2 - Sqrt[(1 - x)*(1 - 2*x)*(1 - 3*x - 2*x^2)])/(2*(1 - 2*x)*x^2),{x,0,29}],x] (* _Stefano Spezia_, Jul 14 2026 *)
%Y A397736 Cf. A001006, A090345, A176677.
%K A397736 nonn,easy,new
%O A397736 0,2
