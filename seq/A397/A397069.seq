%I A397069 #12 Jun 24 2026 20:01:31
%S A397069 2,23,83,197,863,1607,2083,6389,9539,16319,27127,31337,35911,38303,
%T A397069 43399,48809,51647,108971,127133,226379,252617,259429,357031,443017,
%U A397069 624037,714887,726697,812191,863179,998111,1174519,1399709,1627357,1757221,1776277,1992589
%N A397069 Primes equal to the sum of the k primes beginning with prime(k) for some k.
%C A397069 Subsequence of A161463.
%H A397069 James C. McMahon, <a href="/A397069/b397069.txt">Table of n, a(n) for n = 1..1000</a>
%F A397069 a(n) = A161463(A397068(n)).
%F A397069 a(n) = Sum_{i=A397068(n)..2*A397068(n)-1} A000040(i).
%e A397069 5 is the third prime. The sum of the three primes beginning with 5 is 5 + 7 + 11 = 23, which is prime; therefore, 23 is a term.
%e A397069 11 is the fifth prime. The sum of the five primes beginning with 11 is 11 + 13 + 17 + 19 + 23 = 83, which is prime; therefore, 83 is a term.
%t A397069 q[k_]:=PrimeQ[Sum[Prime[i], {i, k, k+k-1}]];fs[k_]:=Sum[Prime[i], {i, k, k+k-1}];fs/@Select[Range[425],q]
%Y A397069 Cf. A000040, A013918, A161463, A397067, A397068.
%K A397069 nonn,new
%O A397069 1,1
%A A397069 _James C. McMahon_ and _Vincenzo Manto_, Jun 17 2026
