%I A397365 #35 Jun 28 2026 18:08:18
%S A397365 0,1,4,2,4,5,3,5,7,5,4,6,8,6,7,5,7,9,7,9,7,6,7,9,8,9,8,9,7,9,8,9,11,9,
%T A397365 11,9,8,9,11,9,11,10,11,10,11,9,11,10,11,10,11,13,11,13,11,10,11,13,
%U A397365 11,13,11,13,12,13,12,13,11,13,12,13,12,13,12,13,15,13,15,13,12
%N A397365 Number of jumps of increasing length 1, 2, 3, ... to reach n starting from 0 and jumping to left or right but landing only on nonnegative numbers.
%H A397365 Alois P. Heinz, <a href="/A397365/b397365.txt">Table of n, a(n) for n = 0..20100</a>
%F A397365 a(A000217(n)) = n.
%F A397365 a(n) >= A003056(n) with equality only for n in { A000217 }.
%F A397365 a(n*(n+3)/2) = 3 + 2*floor(n/2) for n >= 2. - _Alois P. Heinz_, Jun 28 2026
%e A397365 a(4) = 4 jumps from 0 to 4:
%e A397365   1 jump from 0 to 1  (length 1),
%e A397365   1 jump from 1 to 3  (length 2),
%e A397365   1 jump from 3 to 0  (length 3, to the left),
%e A397365   1 jump from 0 to 4  (length 4).
%e A397365 Terms written as a triangle:
%e A397365    0;
%e A397365    1,  4;
%e A397365    2,  4,  5;
%e A397365    3,  5,  7,  5;
%e A397365    4,  6,  8,  6,  7;
%e A397365    5,  7,  9,  7,  9,  7;
%e A397365    6,  7,  9,  8,  9,  8,  9;
%e A397365    7,  9,  8,  9, 11,  9, 11,  9;
%e A397365    8,  9, 11,  9, 11, 10, 11, 10, 11;
%e A397365    9, 11, 10, 11, 10, 11, 13, 11, 13, 11;
%e A397365   10, 11, 13, 11, 13, 11, 13, 12, 13, 12, 13;
%e A397365   11, 13, 12, 13, 12, 13, 12, 13, 15, 13, 15, 13;
%e A397365   12, 13, 15, 13, 15, 13, 15, 13, 15, 14, 15, 14, 15;
%e A397365   ...
%p A397365 b:= proc(n, i) option remember; i*(i+1)/2>=n and
%p A397365       (i=0 and n=0 or b(n+i, i-1) or i<=n and b(n-i, i-1))
%p A397365     end:
%p A397365 a:= proc(n) option remember; local k; for k from
%p A397365       floor((sqrt(1+8*n)-1)/2) while not b(n, k) do od; k
%p A397365     end:
%p A397365 seq(a(n), n=0..78);  # _Alois P. Heinz_, Jun 22 2026
%Y A397365 Cf. A000096, A000217, A003056, A109613.
%K A397365 nonn,easy
%O A397365 0,3
