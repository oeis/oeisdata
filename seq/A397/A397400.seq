%e A397400   [5] 0, 6,  432,   6183,   44704,   219470,   836940,   2667854, ...
%e A397400   [6] 0, 7, 1120,  26082,  269696,  1762600,  8544816,  33523482, ...
%e A397400   [7] 0, 8, 2816, 105948, 1557504, 13480500, 82696032, 397660326, ...
%e A397400   [A000007,A000027,A001793,...]
%p A397400 A := proc(n, k) local j; k^(n - k) * add(Stirling1(k, j)*binomial(n+j, k)*k^j, j = 0..k) end:
%p A397400 seq(lprint(seq(A(n, k), k = 0..7)), n = 0..7); # _Peter Luschny_, Jun 24 2026
%t A397400 A397400[n_, k_] :=  If[n == 0, 1, k^(n - k)*Sum[StirlingS1[k, j]*Binomial[n + j, k]*k^j, {j, k}]];
%t A397400 Table[A397400[n - k, k], {n, 0, 10}, {k, 0, n}] (* _Paolo Xausa_, Jun 24 2026 *)
%o A397400 (PARI) A(n, k) = sum(j=0, min(n,k), k^(n-j) * binomial(n+k-j,k) * stirling(k,k-j,1))
