%U A397274 9154603179,27463809537,82391426694,247174280082,741522840246,2224568514995,6673705544985,20021116634955
%N A397274 G.f. A(x) satisfies (1-3*x)*A(x) + A(x^3) = x.
%F A397274 G.f.: Sum_{j>=0} (-1)^j*x^(3^j) / Product_{k=0..j} (1 - 3*x^(3^k)).
%F A397274 a(1) = 1; for n >= 2, a(n) = 3*a(n-1) - a(n/3) if 3|n, and a(n) = 3*a(n-1) otherwise.
%F A397274 a(n) = 3^(n-1) - Sum_{k=1..floor(n/3)} 3^(n-3*k) * a(k).
%o A397274 (Ruby)
%o A397274 def A397274(n)
%o A397274   a = [0]
%o A397274   (1..n).each{|i|
%o A397274   a << (1..i / 3).inject(3 ** (i - 1)){|s, k| s - 3 ** (i - 3 * k) * a[k]}}
%o A397274   a[1..-1]
%o A397274 end
%o A397274 p A397274(30)
%Y A397274 Cf. A045694, A397064, A398036.
%K A397274 nonn,new
