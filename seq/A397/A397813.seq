%S A397813 1,3,6,11,4,15,28,45,26,49,20,51,14,55,12,59,112,171,110,177,106,33,
%T A397813 113,30,119,22,123,226,333,224,111,238,369,232,93,242,91,248,85,252,
%U A397813 425,246,65,256,63,260,459,670,447,220,449,216,455,214,465,208,471,202
%N A397813 a(0) = 1; for n > 0, with p = the n-th prime, a(n) = a(n-1) - p if that value is positive, previously unused, and not prime, otherwise a(n) is the least unused number >= a(n-1) + p,.
%C A397813 Unlike Recaman's sequence (A005132), which avoids repeated values using natural number steps with no primality condition, this sequence uses prime steps and avoids landing on prime values when subtracting; 1 is treated as passing the compositeness filter (i.e., not excluded as prime).
%F A397813 |a(n) - a(n-1)| = prime(n) for all n >= 1 (by construction).
%e A397813 a(0)=1. p=prime(1)=2. 1-2=-1 is not positive, so a(1)=1+2=3. p=prime(2)=3. 3-3=0 is not positive, so a(2)=3+3=6. p=prime(3)=5. 6-5=1, already used (it's a(0)), so a(3)=6+5=11.
%o A397813 (Python)
%o A397813 from sympy import prime, primerange, isprime
%o A397813 def A_seq(N):
%o A397813     a = [1]
%o A397813     seen = {1}
%o A397813     for p in primerange(prime(N)):
%o A397813         c = a[-1] - p
%o A397813         if c > 0 and c not in seen and not isprime(c):
%o A397813             nxt = c
%o A397813         else:
%o A397813             nxt = a[-1] + p
%o A397813             while nxt in seen: nxt += 1
%o A397813         a.append(nxt); seen.add(nxt)
%o A397813     return a
%o A397813 print(A_seq(60))
%o A397813 (PARI) lista(N) = my(v=[1], s=Set(1)); for(n=2, N, my(p=prime(n-1), c=v[#v]-p, nxt); if(c>0 && !setsearch(s,c) && !isprime(c), nxt=c, nxt=v[#v]+p; while(setsearch(s,nxt), nxt++)); v=concat(v,nxt); s=setunion(s,Set(nxt))); v
%Y A397813 Cf. A005132 (Recaman's sequence), A000040 (the primes).
%K A397813 nonn,new
%O A397813 0,2
