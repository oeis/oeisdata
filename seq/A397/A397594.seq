%I A397594 #15 Jul 11 2026 03:53:33
%S A397594 1,3,27,528,16512,705195,37887834,2442170091,183244178880,
%T A397594 15675764998821,1505681872695420,160476900178362804,
%U A397594 18799367838421680984,2401670597893104602064,332382395344108056499278,49549320572895140393543289,7916911857698298814547857788,1349889314907247276753745833113
%N A397594 G.f. A(x) such that the sum of the first n coefficients in A(x/n)^n equals 4^(n-1) for n >= 1.
%C A397594 Conjecture: for n > 3, a(n) is odd iff n is of the form 2^k-1 or 2^k+1 (k > 1).
%H A397594 Paul D. Hanna, <a href="/A397594/b397594.txt">Table of n, a(n) for n = 0..400</a>
%F A397594 G.f. A(x) = Sum_{n>=0} a(n)*x^n has the following properties.
%F A397594 (1) 4^(n-1) = Sum_{k=0..n-1} [x^k] A(x/n)^n for n >= 1.
%F A397594 (2) (4*n)^(n-1) = [x^(n-1)] A(x)^n / (1 - n*x) for n >= 1.
%F A397594 (3) (4*n)^(n-1) = [x^(n-1)] B'(x) / (1 - n*B(x)) for n >= 1 where B(x) = x*A(B(x)) and B(x) = Series_Reversion(x/A(x)).
%F A397594 (4) [x^(n-1)] B'(x)/(1 - B(x)) = Sum_{k=0..n-1} [x^k] A(x)^n for n >= 1 where B(x) = x*A(B(x)).
%F A397594 a(n) = Sum_{k=0..n} 4^k * A397590(n,k) for n >= 0.
%F A397594 a(n) ~ (exp(1) - 1/4) * exp(-3*exp(-1)/4) * 4^n * n^(n-1). - _Vaclav Kotesovec_, Jul 11 2026
%e A397594 G.f.: A(x) = 1 + 3*x + 27*x^2 + 528*x^3 + 16512*x^4 + 705195*x^5 + 37887834*x^6 + 2442170091*x^7 + 183244178880*x^8 + ...
%e A397594 where 4^(n-1) = Sum_{k=0..n-1} [x^k] A(x/n)^n for n >= 1, as illustrated below.
%e A397594 The table of coefficients of x^k in A(x)^n begins
%e A397594   n = 1: [1,  3,  27,  528,  16512,  705195, ...];
%e A397594   n = 2: [1,  6,  63, 1218,  36921, 1537974, ...];
%e A397594   n = 3: [1,  9, 108, 2097,  61956, 2519154, ...];
%e A397594   n = 4: [1, 12, 162, 3192,  92427, 3672468, ...];
%e A397594   n = 5: [1, 15, 225, 4530, 129225, 5024808, ...];
%e A397594   n = 6: [1, 18, 297, 6138, 173322, 6606468, ...]; ...
%e A397594 The sums of the first n coefficients in A(x/n)^n are
%e A397594   n = 1: 4^0 = 1;
%e A397594   n = 2: 4^1 = 1 + 6/2;
%e A397594   n = 3: 4^2 = 1 + 9/3 + 108/3^2;
%e A397594   n = 4: 4^3 = 1 + 12/4 + 162/4^2 + 3192/4^3;
%e A397594   n = 5: 4^4 = 1 + 15/5 + 225/5^2 + 4530/5^3 + 129225/5^4;
%e A397594   n = 6: 4^5 = 1 + 18/6 + 297/6^2 + 6138/6^3 + 173322/6^4 + 6606468/6^5;
%e A397594   etc.
%e A397594 RELATED SERIES.
%e A397594 Let B(x) = Series_Reversion(x/A(x)) then
%e A397594 B(x) = x + 3*x^2 + 36*x^3 + 798*x^4 + 25845*x^5 + 1101078*x^6 + 58218699*x^7 + 3681384168*x^8 + ...
%e A397594 where B(x) = x*A(B(x)) and
%e A397594 B'(x)/(1 - B(x)) = 1 + 7*x + 118*x^2 + 3367*x^3 + 133996*x^4 + 6786244*x^5 + 416216494*x^6 + ...
%e A397594 the coefficients of which are partial sums of [x^k] A(x)^n:
%e A397594 1 = 1, 7 = (1 + 6), 118 = (1 + 9 + 108), 3367 = (1 + 12 + 162 + 3192), ...
%e A397594 The table of coefficients in B'(x)/(1 - n*B(x)) begins
%e A397594   n = 1: [1,  7, 118, 3367, 133996, ...];
%e A397594   n = 2: [1,  8, 130, 3572, 139321, ...];
%e A397594   n = 3: [1,  9, 144, 3813, 145326, ...];
%e A397594   n = 4: [1, 10, 160, 4096, 152161, ...];
%e A397594   n = 5: [1, 11, 178, 4427, 160000, ...]; ...
%e A397594 in which the main diagonal equals
%e A397594 [1, 8, 144, 4096, 160000, ..., (4*n)^(n-1), ...].
%o A397594 (PARI) \\ by definition
%o A397594 {a(n,y=4) = my(A=[1], m, V); for(i=1, n, A = concat(A, 0); m=#A; V=Vec( subst(Ser(A)^m, x, x/m) );
%o A397594 A[m] = (y^(m-1) - sum(k=1, #V, V[k]) )*m^(m-2) ); GF=Ser(A); polcoef(GF,n)}
%o A397594 {upto(n,y=4) = a(n,y); Vec(GF)}
%o A397594 upto(25)
%o A397594 (PARI) \\ from (4*n)^(n-1) = [x^(n-1)] A(x)^n / (1 - n*x)
%o A397594 {a(n,y=4) = my(A=[1], m, V); for(i=1, n, A = concat(A, 0); m=#A;
%o A397594 A[m] = ((y*m)^(m-1) - polcoef(Ser(A)^m/(1-m*x),m-1))/m ); GF=Ser(A); polcoef(GF,n)}
%o A397594 {upto(n,y=4) = a(n,y); Vec(GF)}
%o A397594 upto(25)
