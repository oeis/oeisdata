%S A397253 1,2,4,0,5,2,4,9,5,9,6,6,6,8,6,2,1,3,1,3,7,5,1,4,3,9,7,4,7,5,0,7,1,6,
%T A397253 9,1,1,2,2,3,3,6,8,8,7,1,5,7,5,7,3,6,2,7,7,1,2,8,7,9,1,7,6,6,5,3,4,4,
%U A397253 4,7,0,2,6,0,4,1,4,6,8,2,0,7,6,1,5,7,8,3,3,9,2,8,0,4
%N A397253 Decimal expansion of the limit of the area of the sequence of inscribed polygons formed by angular bisection.
%C A397253 This constant represents the limiting area of a sequence of inscribed polygons within a unit circle. The construction initiates with a base triangle having vertices at angles 0, 180, and 270 degrees. Subsequent iterations add new vertices by bisecting the angular interval between the last added vertex and the reference vertex at 0 degrees, effectively constructing new triangles that occupy the remaining circular sector. The sequence of polygons is formed by the union of these triangles, and the constant is the limit of their total area as the number of vertices tends to infinity.
%C A397253 For the initial triangle (3 vertices), the area is 1.0.
%C A397253 For n=1 (4 vertices: 0, 180, 270, 315), the area is 1.2071067811865475244...
%C A397253 For n=2 (5 vertices: 0, 180, 270, 315, 337.5), the area is 1.2362368229583635339...
%F A397253 Equals 1 + (1/2) * Sum_{n>=1} (2*sin(Pi/2^(n+1)) - sin(Pi/2^n)).
%e A397253 1.24052495966686213137514397475071691122336887157573...
%o A397253 (Julia)
%o A397253 function constant(digits::Int=100)
%o A397253     setprecision(BigFloat, ceil(Int, (digits + 10) * 3.4))
%o A397253     C = BigFloat(1.0)
%o A397253     n = 1
%o A397253     eps = BigFloat(10)^(-digits - 5)
%o A397253     while true
%o A397253         t = 0.5 * (2 * sin(pi / BigFloat(2)^(n+1)) - sin(pi / BigFloat(2)^n))
%o A397253         if abs(t) < eps
%o A397253             break
%o A397253         end
%o A397253         C += t
%o A397253         n += 1
%o A397253     end
%o A397253     return C, n
%o A397253 end
%o A397253 C, iters = constant(100)
%o A397253 println("Constant = ", string(C)[1:102])
%o A397253 println("Iterations used: ", iters)
%o A397253 (PARI) sumpos(k = 1, sin(Pi/2^k))/2 \\ _Amiram Eldar_, Jun 25 2026
%K A397253 nonn,cons
%O A397253 1,2
