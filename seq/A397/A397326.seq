%T A397326 12280539434300,661023349607292,36508629551535721,2060317980658182742,
%U A397326 118419883047448076661,6914394165963180356081,409287604316981708784617,24519889762423217285608656,1484639382027874852276490192
%N A397326 a(n) = Sum_{j=0..n} (-1)^j*binomial(n, j) * A001006(2*n - j)^2.
%F A397326 a(n) = A396585(2*n, n).
%F A397326 a(n) ~ 2^(3*n+7) * 3^(2*n+3) / (4913*Pi*n^3). - _Vaclav Kotesovec_, Jul 02 2026
%p A397326 a := n -> add((-1)^j*binomial(n, j) * add(binomial(2*n - j, 2*k) * binomial(2*k, k) / (k + 1), k = 0..iquo((2*n - j),2))^2, j = 0..n): seq(a(n), n = 0..17);
%t A397326 Table[Sum[(-1)^j*Binomial[n, j] * Hypergeometric2F1[(1 + j - 2*n)/2, (j - 2*n)/2, 2, 4]^2, {j, 0, n}], {n, 0, 20}] (* _Vaclav Kotesovec_, Jul 02 2026 *)
%o A397326 (Python)
%o A397326 def a(n: int) -> int:
%o A397326     if n == 0: return 1
%o A397326     M = [1, 1] + [0] * (2 * n - 1)
%o A397326     for i in range(2, 2 * n + 1):
%o A397326         M[i] = ((2 * i + 1) * M[i - 1] + (3 * i - 3) * M[i - 2]) // (i + 2)
%o A397326     ret = 0
%o A397326     c = 1
%o A397326     for j in range(n + 1):
%o A397326         term = c * (M[2 * n - j] ** 2)
%o A397326         ret = ret - term if j % 2 == 1 else ret + term
%o A397326         c = c * (n - j) // (j + 1)
%o A397326     return ret
%o A397326 A = [a(n) for n in range(17)]; print(A)
%Y A397326 Cf. A001006, A396585.
%K A397326 nonn
%O A397326 0,2
%A A397326 _Peter Luschny_, Jul 01 2026
