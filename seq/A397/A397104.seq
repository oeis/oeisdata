%I A397104 #30 Jul 03 2026 18:29:20
%S A397104 1,2,3,4,4,6,5,6,7,7,6,10,7,8,9,9,11,10,8,10,12,14,9,10,11,13,15,12,
%T A397104 10,12,16,14,11,12,13,13,15,14,17,14,15,16,12,16,18,22,13,14,15,15,17,
%U A397104 16,19,16,17,18,23,17,14,16,18,18,24,26,15,16,17,21,18,25,27,22
%N A397104 Triangle read by rows: T(n, k) = n + A275314(k) - 1, for 1 <= k <= n and gcd(n, k) = 1.
%C A397104 Row n has length phi(n) (A000010) for n >= 2; row 1 has length 1.
%C A397104 Arises from an asymmetric musical dissonance metric f(p/q) = p + (A275314(q) - 1) for the interval p/q in lowest terms, where p is the upper note's position in the harmonic series (cost p), and A275314(q) - 1 is the prime complexity of the lower note's position (cost of establishing harmonic context).
%C A397104 The symmetric combination A275314(n) + A275314(k) - 1 recovers Euler's Gradus Suavitatis G(n/k) = 1 + Omega*(n) + Omega*(k).
%C A397104 The rightmost populated diagonal T(n, n-1), n >= 2, gives the two-stage dissonance of the superparticular intervals n/(n-1); see A397106, where the index is the lower partial n-1.
%H A397104 David De Roure, <a href="/A397104/b397104.txt">Table of n, a(n) for n = 1..10060</a>
%H A397104 David De Roure, <a href="https://arxiv.org/abs/2606.16412">An Asymmetric Formula for Interval Consonance and its Relation to Harmonic Coincidence</a>, arXiv:2606.16412 [math.HO], 2026.
%F A397104 T(n, k) = n + A275314(k) - 1, for 1 <= k <= n and gcd(n, k) = 1.
%F A397104 T(n, k) = n + A001414(k) - A001222(k), for 1 <= k <= n and gcd(n, k) = 1.
%e A397104 Triangle begins:
%e A397104   n=1: 1
%e A397104   n=2: 2
%e A397104   n=3: 3, 4
%e A397104   n=4: 4, 6
%e A397104   n=5: 5, 6, 7, 7
%e A397104   n=6: 6, 10
%e A397104   n=7: 7, 8, 9, 9, 11, 10
%e A397104   ...
%e A397104 T(5,4) = 7: the major third 5/4. The upper note is the 5th partial (cost 5); Omega*(4) = A001414(4) - A001222(4) = 4 - 2 = 2. Total 5 + 2 = 7.
%t A397104 os[1] = 0; os[n_Integer /; n > 1] := Total[#[[2]] * (#[[1]] - 1) & /@ FactorInteger[n]];
%t A397104 Flatten[Table[If[GCD[n, k] == 1, n + os[k], Nothing], {n, 1, 15}, {k, 1, n}]]
%o A397104 (PARI) os(n) = if(n<=1, 0, my(f=factor(n)); sum(i=1, #f~, f[i,2]*(f[i,1]-1)));
%o A397104 for(n=1, 15, for(k=1, n, if(gcd(n,k)==1, print1(n + os(k), ", "))))
%Y A397104 Cf. A000010, A001222, A001414, A275314, A397106.
%K A397104 tabf,nonn,new
%O A397104 1,2
%A A397104 _David De Roure_, Jun 16 2026
