%e A397585  10: 110 120 130 140 150 160 170 180 190
%e A397585  11: 132 143 154 165 176 187 198 209 220 231
%e A397585  12: 156 168 180 192 204 216 228 240 252 264 276
%e A397585  ...
%e A397585 Removing the first column and the rightmost diagonal in the triangle of A100345 creates this triangle. References to many columns and diagonal sequences in the triangle also are given in A100345.
%t A397585 (* applying Union[ ] instead of Join[ ] in a397585[ ] produces A001284 *)
%t A397585 aTriangle[n_] := Map[Table[#(#+i), {i, #-1}]&, Range[2, n]] (* formula from A001284 *)
%t A397585 a397585[n_] := Apply[Join, aTriangle[n+1]]
%t A397585 a397585[11] (* sequence data of first 11 rows *)
%Y A397585 Cf. A001284, A067742, A100345, A237270.
%K A397585 nonn,tabl,easy,new
