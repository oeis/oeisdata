%U A397353 -1199401402393262799,80693261546418456489,-5830350871594366616607,450285723221396179732659,-37018510650991024242317991,3227720176723752730946340405
%N A397353 E.g.f. A(x) satisfies Sum_{n>=0} 3^n * (A(x)^n - x)^n / n! = 1.
%C A397353 Related identity: Sum_{n>=0} (q^n + p)^n * r^n/n! = Sum_{n>=0} exp(p*q^n*r) * q^(n^2) * r^n/n!; here, q = A(x), p = -x, r = 3.
%H A397353 Paul D. Hanna, <a href="/A397353/b397353.txt">Table of n, a(n) for n = 1..300</a>
%F A397353 E.g.f. A(x) = Sum_{n>=0} a(n)*x^n/n! satisfies the following formulas.
%F A397353 (1) 1 = Sum_{n>=0} 3^n * (A(x)^n - x)^n / n!.
%F A397353 (2) 1 = Sum_{n>=0} 3^n * exp(-3*x*A(x)^n) * A(x)^(n^2) / n!.
%F A397353 a(n) = Sum_{k=0..n-1} 3^k * A397350(n,k) for n >= 1.
%e A397353 E.g.f.: A(x) = x - 3*x^2/2! + 27*x^3/3! - 279*x^4/4! + 4671*x^5/5! - 99063*x^6/6! + 2663361*x^7/7! - 85576095*x^8/8! + 3191917995*x^9/9! + ...
%e A397353 where e.g.f. A(x) satisfies the following sums.
%e A397353 (1) 1 = 1 + 3*(A(x) - x) + 3^2*(A(x)^2 - x)^2/2! + 3^3*(A(x)^3 - x)^3/3! + 3^4*(A(x)^4 - x)^4/4! + 3^5*(A(x)^5 - x)^5/5! + ...
%e A397353 (2) 1 = exp(-3*x) + 3*exp(-3*x*A(x))*A(x) + 3^2*exp(-3*x*A(x)^2)*A(x)^4/2! + 3^3*exp(-3*x*A(x)^3)*A(x)^9/3! + 3^4*exp(-3*x*A(x)^4)*A(x)^16/4! + ...
%e A397353 SPECIFIC VALUES.
%e A397353 A(t) = 1/6 at t = 0.202488738779495804472233738078414271203888871247768...
%e A397353 A(1/5) = 0.164827465316830270155988990718934893574691462279221...
%e A397353 A(1/6) = 0.140057351455193489929932713428488208788936327726000...
%e A397353 A(1/7) = 0.122078827182647218909683891025077320391374145745046...
%e A397353 A(-1/5) = -0.408895802000411343334486906433158249757436979664533...
%e A397353 A(-1/6) = -0.252465478168267208844939599189540463748435718957588...
%e A397353 A(-1/7) = -0.196497266317868349523988388161707485684207482209384...
%o A397353 (PARI) /* 1 = Sum_{n>=0} r^n * exp(-r*x*A(x)^n) * A(x)^(n^2) / n! */
%o A397353 {a(n,r=3) = my(A=[0, 1]); for(i=2, n, A = concat(A, 0);
%o A397353 A[#A] = -polcoeff( sum(m=0, sqrtint(#A+1), r^m*exp(-r*Ser(A)^m*x +O(x^#A)) * Ser(A)^(m^2)/m! ), #A-1)/r; ); EGF=Ser(A); n!*A[n+1]}
%o A397353 {upto(n) = a(n); Vec(serlaplace(EGF))}
%o A397353 upto(25)
%o A397353 (PARI) /* 1 = Sum_{n>=0} r^n * (A(x)^n - x)^n / n! */
%o A397353 {a(n,r=3) = my(A=[0, 1]); for(i=2, n, A = concat(A, 0);
%o A397353 A[#A] = -polcoeff( sum(m=0, #A+1, r^m*(Ser(A)^m - x)^m/m! ), #A-1)/r ); EGF=Ser(A); n!*A[n+1]}
%o A397353 {upto(n) = a(n); Vec(serlaplace(EGF))}
%o A397353 upto(25)
