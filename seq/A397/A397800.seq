%N A397800 Lexicographically earliest sequence of distinct squarefree semiprimes whose sum of reciprocals is 1.
%C A397800 A greedy Egyptian fraction representation of 1 using distinct squarefree semiprimes.
%C A397800 Includes the first 37 squarefree semiprimes (A006881).
%H A397800 Amiram Eldar, <a href="/A397800/b397800.txt">Table of n, a(n) for n = 1..45</a>
%H A397800 Amiram Eldar, <a href="/A397800/a397800.txt">Table of factorizations of a(n) for n = 1..45</a>.
%H A397800 <a href="/index/Ed#Egypt">Index entries for sequences related to Egyptian fractions</a>.
%t A397800 sfsemiQ[n_] := FactorInteger[n][[;; , 2]] == {1, 1};
%t A397800 next[sum_, prev_] := Module[{m = Max[prev + 1, Ceiling[1/(1 - sum)]]}, While[!sfsemiQ[m], m++]; m];
%t A397800 seq[lenmax_] := Module[{sum = 0, prev = 1, c = 0, s = {}}, While[c < lenmax && sum < 1, n = next[sum, prev]; AppendTo[s, n]; prev = n; sum += 1/n; c++]; s];
%t A397800 seq[42]
%o A397800 (PARI) issfsemi(n) = factor(n)[, 2] == [1, 1]~;
%o A397800 nxt(sm, prev) = {my(m = max(prev + 1, ceil(1/(1 - sm)))); while(!issfsemi(m), m++); m;}
%o A397800 list(lenmax) = {my(sm = 0, prev = 1, c = 0, s = []); while(c < lenmax && sm < 1, n = nxt(sm, prev); s = concat(s, n); prev = n; sm += 1/n; c++); s;}
%o A397800 list(42)
%Y A397800 Cf. A006881.
%Y A397800 Similar sequences: A000058, A075442, A225669, A181503, A225670.
