%I A397047 #14 Jun 24 2026 00:32:18
%S A397047 4,17,252,2418,19767,171765,1708002
%N A397047 a(n) is the number of n-digit terms in A397046.
%F A397047 Conjecture: lim_{n->oo} a(n+1)/a(n) = 10.
%t A397047 nmax=3; a={2}; For[k=3, k<=10^nmax-1, k++, If[AllTrue[a, Mod[DigitSum[k],#]!=0 &], AppendTo[a,k]]]; Table[Length[Select[a, IntegerLength[#]==i &]], {i, nmax}]
%Y A397047 Cf. A397046, A397051 (counting only primes).
%K A397047 nonn,base,hard,more,new
%O A397047 1,1
%A A397047 _Stefano Spezia_, Jun 14 2026
