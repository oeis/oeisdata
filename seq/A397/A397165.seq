%I A397165 #10 Jun 17 2026 15:46:48
%S A397165 33,120,171,201,203,210,213,230,238,264,286,288,294,322,354,373,395,
%T A397165 479,486,506,542,553,563,583,609,628,646,659,688,700,719,724,730,744,
%U A397165 749,770,814,862,883,963,975,1009,1020,1056,1103,1115,1119,1182,1247,1260,1273,1324,1358
%N A397165 Apply PrimePi to A397164.
%C A397165 These are the indices of the primes in A280864 that begin a block of length 4 that both begins and ends with a prime.
%H A397165 Michael De Vlieger, <a href="/A397165/b397165.txt">Table of n, a(n) for n = 1..2856</a>
%t A397165 Block[{c, j, k, m, q, r, s, t, w, nn, rad},
%t A397165   nn = 24000; c[_] := False; q = 0; r = s = 1; t = {};
%t A397165   rad[n_] := rad[n] = Times @@ FactorInteger[n][[All, 1]];
%t A397165   Monitor[Reap[Do[w = GCD[r, s]; m = r/w; k = m;
%t A397165     While[Or[c[k], ! CoprimeQ[w, k]], k += m];
%t A397165       c[k] = True; s = r; r = rad[k];
%t A397165     If[CoprimeQ[s, r],
%t A397165       If[Length[t] == 4,
%t A397165         If[AllTrue[{First[t], Last[t]}, PrimeQ], Sow[PrimePi@ First[t] ] ] ];
%t A397165       q++; t = {k}, AppendTo[t, k] ], {i, nn}] ][[-1, 1]], i] ] (* _Michael De Vlieger_, Jun 17 2026 *)
%Y A397165 Cf. A000720, A280774, A280864, A283832, A396300, A396301, A397102, A397164.
%K A397165 nonn,new
%O A397165 1,1
%A A397165 _N. J. A. Sloane_, Jun 17 2026
