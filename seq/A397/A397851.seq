%I A397851 #7 Jul 18 2026 09:17:43
%S A397851 0,1,2,3,6,5,8,7,24,9,14,11,30,25,26,15,120,17,32,31,54,27,38,23,144,
%T A397851 121,122,33,126,29,56,55,720,39,62,35,150,145,146,123,264,41,128,127,
%U A397851 174,57,86,47,840,721,722,63,726,125,152,151,744,147,134,59,270
%N A397851 The factorial base expansion of a(n) equals the canonical snowball representation of n.
%C A397851 See A397794 for the definition of the canonical snowball representation of a number.
%C A397851 All terms are distinct.
%H A397851 <a href="/index/Fa#facbase">Index entries for sequences related to factorial base representation</a>
%F A397851 a(n) >= n.
%e A397851 For n = 67:
%e A397851     67 = 33 * 2 + 1
%e A397851     33 = 11 * 3 + 0
%e A397851     11 =  5 * 2 + 1
%e A397851      5 =  1 * 3 + 2
%e A397851      1 =  0 * 4 + 1
%e A397851 Hence the canonical snowball representation of 67 is "12101", and a(67) = 1 * 5! + 2 * 4! + 1 * 3! + 0 * 2! + 1 * 1! = 175.
%o A397851 (PARI) a(n) = { my (v = 0, b = 2, d = 0); for (k = 1, oo, if (n==0, return (v), d = n % b; v += d * k!; n \= b; b = d+2;);); }
%Y A397851 Cf. A007623, A397794.
%K A397851 nonn,base,new
%O A397851 0,3
%A A397851 _Rémy Sigrist_, Jul 12 2026
