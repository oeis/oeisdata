%S A397241 1,1,1,11,191,5279,205739,10703027,716263967,60007934687,
%T A397241 6159516697319,760922950978079,111439352705250767,
%U A397241 19099613791207659215,3788267248224271857407,861094585808165492945279,222400263765951289376315519,64774569176157368362705595519,21131550073441906994234621392031
%N A397241 G.f. A(x) satisfies n * [x^n] A(x)^n = (n-1) * [x^n] A(x)^(n+1) for n > 1.
%C A397241 Conjecture: all terms are odd.
%C A397241 Conjecture: a(n) == 2 (mod 3) for n > 2.
%C A397241 Conjecture: a(n) == 3 (mod 4) for n > 2.
%C A397241 The limit lim_{n->oo} a(n)/n!^2 appears to be finite and nonzero. At n = 1000, a(1000)/1000!^2 = 0.576238922856...
%C A397241 This constant is equal to 0.5773928444790959583518657851093628462973104143119... - _Vaclav Kotesovec_, Jun 20 2026
%H A397241 Paul D. Hanna, <a href="/A397241/b397241.txt">Table of n, a(n) for n = 0..500</a>
%F A397241 G.f. A(x) = Sum_{n>=0} a(n)*x^n satisfies the following formulas.
%F A397241 (1) n * [x^n] A(x)^n = (n-1) * [x^n] A(x)^(n+1) for n > 1.
%F A397241 (2) [x^n] A(x)^n = A397243(n) for n >= 1, where A397243 forms the logarithmic derivative of A397242.
%F A397241 (3) [x^n] A(x)^(n+1) = (n+1) * A397242(n) for n >= 0, where Sum_{n>=0} A397242(n)*x^n = exp(x + Sum_{n>=2} (n^2-1) * A397242(n)*x^n/n^2 ).
%F A397241 (4) A(x) = F(x*A(x)) where F(x) = A(x/F(x)) is the g.f. of A397242.
%e A397241 G.f.: A(x) = 1 + x + x^2 + 11*x^3 + 191*x^4 + 5279*x^5 + 205739*x^6 + 10703027*x^7 + 716263967*x^8 + 60007934687*x^9 + ...
%e A397241 The table of coefficients of x^k in A(x)^n begins
%e A397241   n=1: [1, 1,  1,  11,  191,  5279,  205739, 10703027, ...];
%e A397241   n=2: [1, 2,  3,  24,  405, 10962,  422539, 21832292, ...];
%e A397241   n=3: [1, 3,  6,  40,  645, 17085,  651040, 33405174, ...];
%e A397241   n=4: [1, 4, 10,  60,  915, 23688,  891932, 45439952, ...];
%e A397241   n=5: [1, 5, 15,  85, 1220, 30816, 1145960, 57955870, ...];
%e A397241   n=6: [1, 6, 21, 116, 1566, 38520, 1413930, 70973208, ...];
%e A397241   n=7: [1, 7, 28, 154, 1960, 46858, 1696716, 84513360, ...];
%e A397241   n=8: [1, 8, 36, 200, 2410, 55896, 1995268, 98598920, ...]; ...
%e A397241 from which we can illustrate the definition
%e A397241   n * [x^n] A(x)^n = (n-1) * [x^n] A(x)^(n+1) by
%e A397241   n = 2: 2*[x^2] A(x)^2 = 2*3 = 1*6 = 1*[x^2] A(x)^3;
%e A397241   n = 3: 3*[x^3] A(x)^3 = 3*40 = 2*60 = 2*[x^3] A(x)^4;
%e A397241   n = 4: 4*[x^4] A(x)^4 = 4*915 = 3*1220 = 3*[x^4] A(x)^5;
%e A397241   n = 5: 5*[x^5] A(x)^5 = 5*30816 = 4*38520 = 4*[x^5] A(x)^6;
%e A397241   etc.
%e A397241 Also, we obtain A397242 from the main diagonal
%e A397241 A397242 = [1/1, 2/2, 6/3, 60/4, 1220/5, 38520/6, ...]
%e A397241   = [1, 1, 2, 15, 244, 6420, 242388, 12324865, ...].
%e A397241 Further, we obtain A397243 from the secondary diagonal
%e A397241 A397243 = [1, 3, 40, 915, 30816, 1413930, ...]
%e A397241 which forms the logarithmic derivative of A397242.
%o A397241 (PARI) \\ returns vector of terms a(k) for k = 0..n
%o A397241 {a(n) = my(A=[1, 1], m); for(i=1, n-1, A=concat(A, 0); m=#A-1;
%o A397241 A[#A] = (m-1)*polcoef(Ser(A)^(m+1), m) - m*polcoef(Ser(A)^m, m) ); GF=Ser(A); A}
%Y A397241 Cf. A396808, A397242, A397243.
%K A397241 nonn,new
%O A397241 0,4
%A A397241 _Paul D. Hanna_, Jun 19 2026
