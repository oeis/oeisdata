%I A397524 #36 Jul 17 2026 13:28:35
%S A397524 1,3,93,219,267,387,685,1333,2814,2973,6723,9807,10173,10293,10333,
%T A397524 10917,12234,13167,21786,22113,22167,23643,24114,24183,25093,30387,
%U A397524 30817,35623,39861,40986,41712,43417,51864,53193,53754,56565,59757,60537,60564,62007,62343
%N A397524 Numbers k such that the sums of the digits of k^2, k^3 and k^4 coincide, excluding multiples of 10.
%C A397524 While the sequence of numbers k such that the sums of the digits of k^2, k^3 and k^4 coincide is infinite, since it is always possible to append zeros to obtain a new term, it is not known whether there are an infinite number of terms without trailing zeros (when excluding multiples of 10, A008592).
%C A397524 For any term k, k^2 == k^3 == k^4 (mod 9), which implies that k mod 9 must belong to {0, 1, 3, 6}.
%H A397524 David A. Corneth, <a href="/A397524/b397524.txt">Table of n, a(n) for n = 1..10000</a> (first 1000 terms from Vincenzo Manto)
%H A397524 David A. Corneth, <a href="/A397524/a397524.gp.txt">PARI program</a>
%e A397524 k = 3 is a term since k^2 = 9, k^3 = 27, k^4 = 81 and s(9) = 9, s(27) = 9, s(81) = 9, where s(k) is the sum of digits of k.
%p A397524 filter:=proc(n) local t;
%p A397524   t:= convert(convert(n^2,base,10),`+`);
%p A397524   t = convert(convert(n^4,base,10),`+`) and
%p A397524   t = convert(convert(n^3,base,10),`+`)
%p A397524 end proc:
%p A397524 select(filter, [seq(seq(10*i+j, j=1..9),i=0..10^4)]); # _Robert Israel_, Jul 12 2026
%t A397524 Select[Range[70000], Mod[#, 10] != 0 && DigitSum[#^2] == DigitSum[#^3] == DigitSum[#^4] &] (* _Stefano Spezia_, Jun 30 2026 *)
%o A397524 (Python)
%o A397524 def ok(k):
%o A397524     return k % 10 != 0 and sum(map(int, str(k**2))) == sum(map(int, str(k**3))) == sum(map(int, str(k**4)))
%o A397524 print([k for k in range(1, 70000) if ok(k)])
%o A397524 (PARI) \\ See Corneth link
%Y A397524 Cf. A111434, A058369, A070276, A004164, A004159, A055565, A011557, A007953, A008592.
%Y A397524 Subsequence of A055264.
%K A397524 nonn,base,new
