%S A397644 0,0,1,0,1,1,0,1,3,1,2,1,2,3,3,1,1,3,7,4,4,3,5,5,3,4,5,7,7,4,3,3,7,15,
%T A397644 10,9,9,10,9,7,10,11,11,7,9,9,11,15,15,10,9,7,7,15,31,21,20,21,20,19,
