%I A397592 #18 Jul 11 2026 03:34:44
%S A397592 1,1,5,54,898,19917,548044,17940677,680086642,29294681995,
%T A397592 1413807023402,75607085142678,4440059654051322,284176653575882142,
%U A397592 19695181716987428444,1469867840650603330447,117549769431112320256034,10030434129698947313479027,909727826811067450745636622,87400575808522677367480159818
%N A397592 G.f. A(x) such that the sum of the first n coefficients in A(x/n)^n equals 2^(n-1) for n >= 1.
%C A397592 Conjecture: for n > 3, a(n) is odd iff n is of the form 2^k-1 or 2^k+1 (k > 1).
%H A397592 Paul D. Hanna, <a href="/A397592/b397592.txt">Table of n, a(n) for n = 0..400</a>
%F A397592 G.f. A(x) = Sum_{n>=0} a(n)*x^n has the following properties.
%F A397592 (1) 2^(n-1) = Sum_{k=0..n-1} [x^k] A(x/n)^n for n >= 1.
%F A397592 (2) (2*n)^(n-1) = [x^(n-1)] A(x)^n / (1 - n*x) for n >= 1.
%F A397592 (3) (2*n)^(n-1) = [x^(n-1)] B'(x) / (1 - n*B(x)) for n >= 1 where B(x) = x*A(B(x)) and B(x) = Series_Reversion(x/A(x)).
%F A397592 (4) [x^(n-1)] B'(x)/(1 - B(x)) = Sum_{k=0..n-1} [x^k] A(x)^n for n >= 1 where B(x) = x*A(B(x)).
%F A397592 a(n) = Sum_{k=0..n} 2^k * A397590(n,k) for n >= 0.
%F A397592 a(n) ~ c * 2^n * n^(n-1), where c = (exp(1) - 1/2) * exp(-exp(-1)/2) = 1.8455793231607918646323538... - _Vaclav Kotesovec_, Jul 11 2026
%e A397592 G.f.: A(x) = 1 + x + 5*x^2 + 54*x^3 + 898*x^4 + 19917*x^5 + 548044*x^6 + 17940677*x^7 + 680086642*x^8 + 29294681995*x^9 + ...
%e A397592 where 2^(n-1) = Sum_{k=0..n-1} [x^k] A(x/n)^n for n >= 1, as illustrated below.
%e A397592 The table of coefficients of x^k in A(x)^n begins
%e A397592   n = 1: [1, 1,  5,  54,  898,  19917, ...];
%e A397592   n = 2: [1, 2, 11, 118, 1929,  42170, ...];
%e A397592   n = 3: [1, 3, 18, 193, 3108,  66996, ...];
%e A397592   n = 4: [1, 4, 26, 280, 4451,  94652, ...];
%e A397592   n = 5: [1, 5, 35, 380, 5975, 125416, ...];
%e A397592   n = 6: [1, 6, 45, 494, 7698, 159588, ...]; ...
%e A397592 The sum of the first n coefficients in A(x/n)^n are
%e A397592   n = 1: 2^0 = 1;
%e A397592   n = 2: 2^1 = 1 + 2/2;
%e A397592   n = 3: 2^2 = 1 + 3/3 + 18/3^2;
%e A397592   n = 4: 2^3 = 1 + 4/4 + 26/4^2 + 280/4^3;
%e A397592   n = 5: 2^4 = 1 + 5/5 + 35/5^2 + 380/5^3 + 5975/5^4;
%e A397592   n = 6: 2^5 = 1 + 6/6 + 45/6^2 + 494/6^3 + 7698/6^4 + 159588/6^5;
%e A397592   etc.
%e A397592 RELATED SERIES.
%e A397592 Let B(x) = Series_Reversion(x/A(x)) then
%e A397592 B(x) = x + x^2 + 6*x^3 + 70*x^4 + 1195*x^5 + 26598*x^6 + 727335*x^7 + 23577848*x^8 + 884550753*x^9 + ...
%e A397592 where B(x) = x*A(B(x)) and
%e A397592 B'(x)/(1 - B(x)) = 1 + 3*x + 22*x^2 + 311*x^3 + 6396*x^4 + 167832*x^5 + 5299162*x^6 + 194983343*x^7 + ...
%e A397592 the coefficients of which are partial sums of [x^k] A(x)^n:
%e A397592 1 = 1, 3 = (1 + 2), 22 = (1 + 3 + 18), 311 = (1 + 4 + 26 + 280), ...
%e A397592 The table of coefficients in B'(x)/(1 - n*B(x)) begins
%e A397592   n = 1: [1, 3, 22, 311,  6396, ...];
%e A397592   n = 2: [1, 4, 28, 356,  6931, ...];
%e A397592   n = 3: [1, 5, 36, 421,  7646, ...];
%e A397592   n = 4: [1, 6, 46, 512,  8631, ...];
%e A397592   n = 5: [1, 7, 58, 635, 10000, ...]; ...
%e A397592 in which the main diagonal equals
%e A397592 [1, 4, 36, 512, 10000, ..., (2*n)^(n-1), ...].
%o A397592 (PARI) \\ by definition
%o A397592 {a(n,y=2) = my(A=[1], m, V); for(i=1, n, A = concat(A, 0); m=#A; V=Vec( subst(Ser(A)^m, x, x/m) );
%o A397592 A[m] = (y^(m-1) - sum(k=1, #V, V[k]) )*m^(m-2) ); GF=Ser(A); polcoef(GF,n)}
%o A397592 {upto(n,y=2) = a(n,y); Vec(GF)}
%o A397592 upto(25)
%o A397592 (PARI) \\ from (2*n)^(n-1) = [x^(n-1)] A(x)^n / (1 - n*x)
%o A397592 {a(n,y=2) = my(A=[1], m, V); for(i=1, n, A = concat(A, 0); m=#A;
%o A397592 A[m] = ((y*m)^(m-1) - polcoef(Ser(A)^m/(1-m*x),m-1))/m ); GF=Ser(A); polcoef(GF,n)}
%o A397592 {upto(n,y=2) = a(n,y); Vec(GF)}
%o A397592 upto(25)
