%U A397169 841,1044,1035,943,41,697,799,47,1081,989,43,1333,1457,1643,53,901,1003,59,1711,1537,1769,61,1037,1207,71,1349,1501,79,2291,2059,2117,73
%N A397169 The leading diagonal of A397219.
%H A397169 Michael S. Branicky, <a href="/A397169/b397169.txt">Table of n, a(n) for n = 0..1416</a> (terms 0..150 from N. J. A. Sloane)
%o A397169 (Python)
%o A397169 from math import gcd
%o A397169 from itertools import count, islice
%o A397169 def A397169_gen():
%o A397169     T, m, am, aset = {(0,0): 2}, 3, 2, set()
%o A397169     yield 2
%o A397169     for n in count(1):
%o A397169         for k in range(n+1):
%o A397169             aset.add(am)
%o A397169             if k == 0: neighs = {T[n-1,0]}
%o A397169             elif 1 <= k < n: neighs = {T[n-1,k-1], T[n-1,k], T[n,k-1]}
%o A397169             else: neighs = {T[n-1,k-1], T[n,k-1]}
%o A397169             am = next(k for k in count(m) if k not in aset and all(gcd(v, k)>1 for v in neighs))
%o A397169             T[n, k] = am
%o A397169             if k == 0: yield am
%o A397169 print(list(islice(A397169_gen(), 71))) # _Michael S. Branicky_, Jun 19 2026
