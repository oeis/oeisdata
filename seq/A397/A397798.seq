%T A397798 10177109,34455559927283,345034572451741929283368509,
%U A397798 32045760216910530201354361636240670563707488922238541
%N A397798 Lexicographically earliest sequence of distinct 5-rough numbers greater than 1 whose sum of reciprocals is 1.
%C A397798 A greedy Egyptian fraction representation of 1 using distinct 5-rough numbers greater than 1.
%C A397798 The next term has 106 digits and is too large to include in the data section.
%C A397798 This sequence is finite with 43 terms.
%C A397798 The next 17 terms are 1.495...*10^105, 1.375...*10^211, 1.807...*10^422, 1.814...*10^844, 1.008...*10^1689, 1.779...*10^3378, 2.394...*10^6756, 9.932...*10^13512, 1.091...*10^27026, 1.001...*10^54053, 2.385...*10^108106, 3.207...*10^216212, 5.862...*10^432424, 2.810...*10^864850, 4.416...*10^1729700, 2.156...*10^3459401, 1.660...*10^6918802.
%C A397798 If we replace 5-rough numbers with prime(k)-rough numbers (numbers with no prime factor less than prime(k); 2-rough numbers are all the positive integers, and 3-rough numbers are the odd integers), then for k = 1 the sequence has 3 terms: 2, 3, and 6 (1/2 + 1/3 + 1/6 = 1), for k = 2 it has 13 terms (A130738), and for k = 3 (this sequence) it has 43 terms. Is the sequence finite for every k >= 1? For k = 4 it has at least 83 terms, and the 83rd term has 5736562824 digits.
%H A397798 Amiram Eldar, <a href="/A397798/b397798.txt">Table of n, a(n) for n = 1..30</a>
%H A397798 <a href="/index/Ed#Egypt">Index entries for sequences related to Egyptian fractions</a>.
%t A397798 next[sum_, prev_] := Module[{m = Max[prev + 1, Ceiling[1/(1 - sum)]]}, While[!CoprimeQ[m, 6], m++]; m];
%t A397798 seq[lenmax_] := Module[{sum = 0, prev = 1, c = 0, s = {}}, While[c < lenmax && sum < 1, n = next[sum, prev]; AppendTo[s, n]; prev = n; sum += 1/n; c++]; s]; seq[26]
%o A397798 (PARI) nxt(sm, prev) = {my(m = max(prev + 1, ceil(1/(1 - sm)))); while(gcd(m, 6) > 1, m++); m;}
%o A397798 list(lenmax) = {my(sm = 0, prev = 1, c = 0, s = []); while(c < lenmax && sm < 1, n = nxt(sm, prev); s = concat(s, n); prev = n; sm += 1/n; c++); s;}
%o A397798 list(26)
%Y A397798 Cf. A007310 (5-rough numbers), A130738 (odd analog), A397799.
%K A397798 nonn,fini,new
%O A397798 1,1
