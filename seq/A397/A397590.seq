%S A397590 1,-1,1,-1,-1,2,-4,-3,-2,9,-28,-17,-14,-9,68,-281,-155,-101,-110,-68,
%T A397590 715,-3658,-1955,-1061,-902,-1236,-715,9527,-58257,-31001,-15162,
%U A397590 -10062,-10986,-17794,-9527,152789,-1093228,-585565,-269486,-152494,-125856,-168622,-308944,-152789,2856984,-23558599,-12753441,-5642485,-2879239,-1962738,-1963630,-3102146,-6242850,-2856984,60962112
%N A397590 Triangle of coefficients T(n,k) of x^n*y^k in g.f. A(x,y) satisfying y^(n-1) = Sum_{k=0..n-1} [x^k] A(x/n, y)^n for n >= 1 with T(0,0) = 1, read by rows n >= 0 as k = 0..n.
%H A397590 Paul D. Hanna, <a href="/A397590/b397590.txt">Table of n, a(n) for n = 0..5150</a>
%F A397590 G.f. A(x,y) = Sum_{n>=0} Sum_{k=0..n} T(n,k)*x^n*y^k has the following properties.
%F A397590 (1) y^(n-1) = Sum_{k=0..n-1} [x^k] A(x/n, y)^n for n >= 1.
%F A397590 (2) (n*y)^(n-1) = [x^(n-1)] A(x,y)^n / (1 - n*x) for n >= 1.
%F A397590 (3) (n*y)^(n-1) = [x^(n-1)] B'(x,y) / (1 - n*B(x,y)) for n >= 1 where B(x,y) = x*A(B(x,y),y) and B(x,y) = Series_Reversion(x/A(x,y)), with derivative and reversion taken wrt x.
%F A397590 (4) [x^(n-1)] B'(x,y)/(1 - B(x,y)) = Sum_{k=0..n-1} [x^k] A(x,y)^n for n >= 1 where B(x,y) = x*A(B(x,y),y), with derivative taken wrt x.
%F A397590 (5) A(x,1) = 1; thus, row sums are all zeros after an initial 1.
%F A397590 (6) A(x,0) = 1 - F(x) where F(x) is the g.f. of A397591.
%F A397590 (7.a) Sum_{k=0..n} 2^k * T(n,k) = A397592(n) for n >= 0.
%F A397590 (7.b) Sum_{k=0..n} 3^k * T(n,k) = A397593(n) for n >= 0.
%F A397590 (7.c) Sum_{k=0..n} 4^k * T(n,k) = A397594(n) for n >= 0.
%F A397590 (7.d) Sum_{k=0..n} 5^k * T(n,k) = A397595(n) for n >= 0.
%F A397590 (8) T(n,n) = -T(n+1,n) = A180747(n) for n >= 0, where the g.f. D(x) of A180747 satisfies D(x) = Sum_{n>=0} (n+1)^(n-1) * x^n/D(x)^n and [x^n] D(x)^(n+1) = (n+1)^n for n >= 0.
%e A397590 This triangle of coefficients T(n,k) of x^n*y^k in g.f. A(x,y) begins
%e A397590   n = 0: [1];
%e A397590   n = 1: [-1, 1];
%e A397590   n = 2: [-1, -1, 2];
%e A397590   n = 3: [-4, -3, -2, 9];
%e A397590   n = 4: [-28, -17, -14, -9, 68];
%e A397590   n = 5: [-281, -155, -101, -110, -68, 715];
%e A397590   n = 6: [-3658, -1955, -1061, -902, -1236, -715, 9527];
%e A397590   n = 7: [-58257, -31001, -15162, -10062, -10986, -17794, -9527, 152789];
%e A397590   n = 8: [-1093228, -585565, -269486, -152494, -125856, -168622, -308944, -152789, 2856984];
%e A397590   ...
%e A397590 GENERATING FUNCTION.
%e A397590 G.f.: A(x,y) = 1 + (-1 + y)*x + (-1 - y + 2*y^2)*x^2 + (-4 - 3*y - 2*y^2 + 9*y^3)*x^3 + (-28 - 17*y - 14*y^2 - 9*y^3 + 68*y^4)*x^4 + (-281 - 155*y - 101*y^2 - 110*y^3 - 68*y^4 + 715*y^5)*x^5 + (-3658 - 1955*y - 1061*y^2 - 902*y^3 - 1236*y^4 - 715*y^5 + 9527*y^6)*x^6 + (-58257 - 31001*y - 15162*y^2 - 10062*y^3 - 10986*y^4 - 17794*y^5 - 9527*y^6 + 152789*y^7)*x^7 + ...
%e A397590 where
%e A397590   y^(n-1) = Sum_{k=0..n-1} [x^k] A(x/n, y)^n for n >= 1,
%e A397590 as illustrated by the following examples.
%e A397590 (1) A(x,y) = 1 + (-1 + 1*y)*x + ...
%e A397590 Check: y^0 = 1;
%e A397590 (2) A(x/2,y)^2 = 1 + (-2 + 2*y)*x/2 + (-1 - 4*y + 5*y^2)*x^2/2^2 + ...
%e A397590 Check: y = 1 + (-2 + 2*y)/2;
%e A397590 (3) A(x/3,y)^3 = 1 + (-3 + 3*y)*x/3 + (0 - 9*y + 9*y^2)*x^2/3^2 + (-7 - 6*y - 27*y^2 + 40*y^3)*x^3/3^3 + ...
%e A397590 Check: y^2 = 1 + (-3 + 3*y)/3 + (0 - 9*y + 9*y^2)/3^2;
%e A397590 (4) A(x/4,y)^4 = 1 + (-4 + 4*y)*x/4 + (2 - 16*y + 14*y^2)*x^2/4^2 + (-8 + 0*y - 56*y^2 + 64*y^3)*x^3/4^3 + (-69 - 60*y - 44*y^2 - 256*y^3 + 429*y^4)*x^4/4^4 + ...
%e A397590 Check: y^3 = 1 + (-4 + 4*y)/4 + (2 - 16*y + 14*y^2)/4^2 + (-8 + 0*y - 56*y^2 + 64*y^3)/4^3;
%e A397590 etc.
%e A397590 RELATED SERIES.
%e A397590 Let D(x) be the g.f. of the main diagonal (A180747), then
%e A397590 D(x) = 1 + x + 2*x^2 + 9*x^3 + 68*x^4 + 715*x^5 + 9527*x^6 + 152789*x^7 + 2856984*x^8 + ... + A180747(n)*x^n + ...
%e A397590 where D(x) = Sum_{n>=0} (n+1)^(n-1) * x^n/D(x)^n
%e A397590 and [x^n] D(x)^(n+1) = (n+1)^n for n >= 0.
%o A397590 (PARI) {GFupto(n) = my(A=[1], m, V); for(i=0, n, A = concat(A, 0); m=#A; V=Vec( subst(Ser(A)^m, x, x/m) );
%o A397590 A[m] = (y^(m-1) - sum(k=1, #V, V[k]) )*m^(m-2) ); GFxy=Ser(A)}
%o A397590 {T(n,k) = polcoef(polcoef(GFxy,n,x),k,y)}
%o A397590 {TriangleRows(r) = GFupto(r); for(n=0,r, for(k=0,n, print1(T(n,k),", "));print(""))}
%o A397590 TriangleRows(12)
%Y A397590 Cf. A397592 (y=2), A397593 (y=3), A397594 (y=4), A397595 (y=5), A397596.
%Y A397590 Cf. A180747 (main diagonal), A397591 (column 0).
%Y A397590 Cf. A375457.
%K A397590 sign,tabl,new
%O A397590 0,6
%A A397590 _Paul D. Hanna_, Jul 08 2026
