%S A397193 6,18,30,60,72,102,108,150,180,192,198,270,420,432,570,660,810,882,
%T A397193 1032,1320,1428,1872,2088,2130,2550,2730,2790,3252,3330,3390,3852,
%U A397193 4158,4230,4338,4482,4650,5418,5850,5868,6270,6300,6552,6780,6948,7308,7350,7560,8388,8628,8820,9282,9720
%N A397193 Average k of twin prime pairs such that d*2^(k/d) is also the average of twin prime pairs for some d.
%e A397193 6 is in the sequence because 6 - 1 = 5, 6 + 1 = 7, 3*2^(6/3) - 1 = 11 and 3*2^(6/3) + 1 = 13 are all primes.
%t A397193 midQ[k_] := And @@ PrimeQ[k + {-1, 1}]; q[k_] := midQ[k] && AnyTrue[Divisors[k], midQ[#*2^(k/#)] &]; Select[Range[10^4], q] (* _Amiram Eldar_, Jun 18 2026 *)
%o A397193 (Magma) [k: k in [1..10000] | IsPrime(k - 1) and IsPrime(k + 1) and not #[d: d in Divisors(k) | IsPrime(d*2^(k div d) - 1) and IsPrime(d*2^(k div d) + 1)] eq 0];
%Y A397193 Cf. A014574, A394795.
%K A397193 nonn
%O A397193 1,1
%A A397193 _Juri-Stepan Gerasimov_, Jun 17 2026
