%t A397126 Block[{c, k, m, r, s, w, nn, rad},
%t A397126   nn = 120; c[_] := False; r = s = 1;
%t A397126   rad[n_] := rad[n] = Times @@ FactorInteger[n][[All, 1]];
%t A397126   Reap[Do[w = GCD[r, s]; m = r/w; k = m;
%t A397126     While[Or[c[k], ! Divisible[k, rad[k]^2], ! CoprimeQ[w, k] ], k += m];
%t A397126     Sow[k]; Set[{c[k], s, r}, {True, r, rad[k] } ],
%t A397126   {i, nn}] ][[-1, 1]] ]
