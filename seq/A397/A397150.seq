%I A397150 #15 Jul 21 2026 21:36:57
%S A397150 0,1,2,2,3,4,5,5,6,8,9,10,10,11,11,11,12,14,15,16,17,17,17,19,21,22,
%T A397150 22,23,24,25,25,26,27,27,28,29,30,31,32,34,34,35,35,35,36,37,38,38,39,
%U A397150 39,41,43,44,45,45,47,48,48,49,49,50,50,50,52,53,53,55,56
%N A397150 Number of decimal places which are known after using n terms of A072193 and treating them as the coefficients of a continued fraction.
%C A397150 The digits produced by the continued fraction are that of A392472.
%C A397150 Let c(n) be the n-th convergent resulting from A072193.
%C A397150 Further continued fraction terms are taken to be unknown and the worst case (maximum absolute difference) is a single additional 1.
%C A397150 a(n) is therefore the length of agreement between c(n) and c(n) appended with a 1.
%H A397150 Jwalin Bhatt, <a href="/A397150/b397150.txt">Table of n, a(n) for n = 0..5107</a>
%H A397150 Wikipedia, <a href="https://en.wikipedia.org/wiki/Lochs%27s_theorem">Lochs's theorem</a>
%F A397150 Conjecture: Limit_{n->oo} n/a(n) = A086819 (Lochs's constant).
%e A397150 For n=6, the continued fraction of 6 terms from A072193 is c(n) = [0; 2,3,1,2,4,2] = 107/243 and the worst case continuation is 155/352,
%e A397150     107/243 = 0.4403 29...
%e A397150     155/352 = 0.4403 40...
%e A397150               ^ ^^^^ a(6) = 5 places agree
%o A397150 (Python)
%o A397150 from sympy import floor, Rational, continued_fraction_iterator, continued_fraction_convergents
%o A397150 from collections import deque
%o A397150 from os.path import commonprefix
%o A397150 def reliable_digits_from_cf(coeffs, prec):
%o A397150     bound1, bound2 = deque(continued_fraction_convergents(coeffs+[1]), maxlen=2)
%o A397150     order = 10**prec
%o A397150     trunc_bound1 = floor(bound1*order) / order
%o A397150     trunc_bound2 = floor(bound2*order) / order
%o A397150     rel_digits = commonprefix([f'{trunc_bound1:.{prec}f}', f'{trunc_bound2:.{prec}f}'])
%o A397150     return len(rel_digits) - 1 if rel_digits else 0
%o A397150 A072193 = [cf for i in range(2, 12) for j in range(1, i) for cf in continued_fraction_iterator(Rational(i, j))]
%o A397150 A397150 = [reliable_digits_from_cf([0]+A072193[:i], 1+int(i*1.031)) for i in range(len(A072193)+1)]
%Y A397150 Cf. A086819, A072193, A390737, A392472, A393695, A396908.
%K A397150 nonn,new
%O A397150 0,3
