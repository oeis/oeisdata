%U A397660 937209,1427697,1992661,2882893,3895625,5533313,7318269,14935245,17861257,26943769,36567149
%N A397660 Number of compositions of n into distinct parts whose list is divided into nonempty blocks.
%C A397660 All terms are odd.
%H A397660 Alois P. Heinz, <a href="/A397660/b397660.txt">Table of n, a(n) for n = 0..10000</a>
%F A397660 G.f.: Sum_{k>=0} ceiling(2^(k-1)) * k! * x^(k*(k+1)/2)/Product_{j=1..k} (1-x^j).
%F A397660 a(n) = Sum_{k=0..A003056(n)} A011782(n) * A000142(n) * A008289(n,k).
%F A397660 a(n) = Sum_{k=0..A003056(n)} A011782(n) * A216652(n,k).
%F A397660 a(n) = A032005(n)/2 for n>=1.
%F A397660 a(n) = A032043(n) - 1 for n>=1.
%e A397660 a(0) = 1: the empty composition.
%e A397660 a(1) = 1: 1.
%e A397660 a(2) = 1: 2.
%e A397660 a(3) = 5: 12, 1|2, 21, 2|1, 3.
%e A397660 a(4) = 5: 13, 1|3, 31, 3|1, 4.
%e A397660 a(5) = 9: 23, 2|3, 32, 3|2, 14, 1|4, 41, 4|1, 5.
%e A397660 a(6) = 33: 123, 12|3, 1|23, 1|2|3, 132, 13|2, 1|32, 1|3|2, 213, 21|3, 2|13, 2|1|3, 231, 23|1, 2|31, 2|3|1, 312, 31|2, 3|12, 3|1|2, 321, 32|1, 3|21, 3|2|1, 24, 2|4, 42, 4|2, 15, 1|5, 51, 5|1, 6.
%e A397660 a(7) = 37: 124, 12|4, 1|24, 1|2|4, 142, 14|2, 1|42, 1|4|2, 214, 21|4, 2|14, 2|1|4, 241, 24|1, 2|41, 2|4|1, 412, 41|2, 4|12, 4|1|2, 421, 42|1, 4|21, 4|2|1, 34, 3|4, 43, 4|3, 25, 2|5, 52, 5|2, 16, 1|6, 61, 6|1, 7.
%p A397660 b:= proc(n, i, p) option remember; `if`(i*(i+1)/2<n, 0, `if`(n=0,
%p A397660       p!*ceil(2^(p-1)), b(n, i-1, p)+b(n-i, min(n-i, i-1), p+1)))
%p A397660     end:
%p A397660 a:= n-> b(n$2, 0):
%p A397660 seq(a(n), n=0..39);
%p A397660 # Alternative:
%p A397660 b:= proc(n, k) option remember; `if`(k<0 or n<0, 0,
%p A397660       `if`(k=0, `if`(n=0, 1, 0), b(n-k, k) +k*b(n-k, k-1)))
%p A397660     end:
%p A397660 a:= n-> add(b(n, k)*ceil(2^(k-1)), k=0..floor((sqrt(8*n+1)-1)/2)):
%p A397660 seq(a(n), n=0..39);
%t A397660 b[n_,i_,p_]:=b[n,i,p]=Which[i*(i+1)/2<n,0,n==0,p!*Ceiling[2^(p-1)],True,b[n,i-1,p]+b[n-i,Min[n-i,i-1],p+1]];Table[b[n, n, 0], {n, 0, 39}] (* From the Maple code *) (* _Shenghui Yang_, Jul 18 2026 *)
