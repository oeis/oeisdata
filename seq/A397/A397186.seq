%T A397186 122010,365196,8820,930,42,7,27594,7588770,5039580,4057620,28830,1806,
%U A397186 56,8,364722,61144062,1002984060,88738020,28542630,77658,3192,72,9,18512790,4092816966,14406086604,43868210820,910768530,146775426,181944,5256,90,10
%N A397186 Array read by ascending antidiagonals: A(n,k) = ((k + 1)^prime(n) - k^prime(n) - 1)/prime(n).
%C A397186 A(n,k) is integer (see Theorem in Dunham).
%D A397186 William Dunham, Journey Through Genius, Wiley, 1990, Chapter 10, pp. 226-227.
%e A397186 The array begins as:
%e A397186     1,      2,       3,        4,         5, ...
%e A397186     2,      6,      12,       20,        30, ...
%e A397186     6,     42,     156,      420,       930, ...
%e A397186    18,    294,    2028,     8820,     28830, ...
%e A397186   186,  15918,  365196,  4057620,  28542630, ...
%e A397186   630, 122010, 5039580, 88738020, 910768530, ...
%e A397186   ...
%p A397186 A:= (n,k)-> (p-> ((k+1)^p-k^p-1)/p)(ithprime(n)):
%p A397186 seq(seq(A(1+d-k, k), k=1..d), d=1..10);  # _Alois P. Heinz_, Jun 17 2026
%t A397186 A[n_,k_]:=((k+1)^Prime[n]-k^Prime[n]-1)/Prime[n]; Table[A[n-k+1,k],{n,10},{k,n}]//Flatten
%Y A397186 Columns k=1..2 give: A064535, A127071.
%Y A397186 Rows n=1..3 give: A000027, A002378, A169938.
%Y A397186 Main diagonal gives A397187.
%Y A397186 Antidiagonal sums gives A397188.
%K A397186 nonn,easy,tabl
%O A397186 1,2
%A A397186 _Stefano Spezia_, Jun 17 2026
