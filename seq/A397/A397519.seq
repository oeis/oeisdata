%I A397519 #12 Jun 30 2026 10:46:37
%S A397519 0,1,2,3,6,4,7,15,5,8,13,31,21,10,23,11,29,14,37,30,61,26,53,27,55,42,
%T A397519 63,43,85,46,87,47,12,28,79,95,9,25,127,111,20,62,119,18,183,126,22,
%U A397519 38,54,190,86,110,94,174,118,175,214,191,215,58,93,59,117,106
%N A397519 Lexicographically earliest sequence of distinct nonnegative integers whose binary plot has no two 0 bits a knight's move apart.
%C A397519 A variation of A394166 where the 0 bits, as opposed to the 1 bits, cannot be a knight's move apart.
%C A397519 It is conjectured that all nonnegative numbers appear.
%H A397519 Scott R. Shannon, <a href="/A397519/b397519.txt">Table of n, a(n) for n = 0..10000</a>
%e A397519 The terms, with their binary values, begin:
%e A397519   n   a(n)   A007088(a(n))
%e A397519   --  ----  --------------
%e A397519    0     0               0
%e A397519    1     1               1
%e A397519    2     2              10
%e A397519    3     3              11
%e A397519    4     6             110
%e A397519    5     4             100
%e A397519    6     7             111
%e A397519    7    15            1111
%e A397519    8     5             101
%e A397519    9     8            1000
%e A397519   10    13            1101
%e A397519   11    31           11111
%e A397519   12    21           10101
%e A397519   13    10            1010
%e A397519   14    23           10111
%e A397519   15    11            1011
%e A397519   16    29           11101
%e A397519   17    14            1110
%e A397519   18    37          100101
%e A397519   19    30           11110
%e A397519   20    61          111101
%e A397519 .
%o A397519 (Python)
%o A397519 from itertools import count, islice
%o A397519 def comp(k): return (~k)&((1<<k.bit_length())-1)
%o A397519 def agen(): # generator of terms
%o A397519     aset, m, an2, an1 = {0, 1}, 2, 0, 1
%o A397519     yield from [0, 1]
%o A397519     for n in count(2):
%o A397519         can1, can2 = comp(an1), comp(an2)
%o A397519         mask = (can1<<2)|(can1>>2)|(can2<<1)|(can2>>1)
%o A397519         an2, an1 = an1, next(k for k in count(m) if not (comp(k)&mask or k in aset))
%o A397519         yield an1
%o A397519         aset.add(an1)
%o A397519         while m in aset: m += 1
%o A397519 print(list(islice(agen(), 64))) # _Michael S. Branicky_, Jun 30 2026
%Y A397519 Cf. A394166, A007088, A396836, A109812, A396694.
