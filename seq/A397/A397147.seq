%N A397147 G.f. A(x), with A(0) = 0, satisfies A(x-x^3) = x + A(x)^2.
%F A397147 a(1) = 1; a(n) = Sum_{k=1..n-1} a(k)*a(n-k) + Sum_{r=1..floor(n/3)} (-1)^(r+1) * binomial(n-2*r,r) * a(n-2*r).
%o A397147 (PARI) my(A=x, N=30, g=serreverse(x-x^3+x*O(x^N))); for(k=1, N, A=g+subst(A, x, g)^2); Vec(A)
