%I A397113 #15 Jun 30 2026 07:34:06
%S A397113 0,-1,1,-2,4,-1,9,2,16,7,25,14,36,23,49,34,64,47,81,62,100,79,121,98,
%T A397113 144,119,169,142,196,167,225,194,256,223,289,254,324,287,361,322,400,
%U A397113 359,441,398,484,439,529,482,576,527,625,574,676,623,729,674,784,727,841,782,900
%N A397113 Lower (2,-1) midsequence of (floor[n/2]^2) and (ceiling[n/2]^2); see Comments.
%C A397113 Suppose that s = (s(n)) and t = (t(n)) are sequences of numbers and h > 0 and k > 0. The lower (h, k)-midsequence of s and t is floor(h*s + k*t); the upper (h, k)-midsequence of s and t is ceiling(h*s + k*t). The upper (2,-1) midsequence of (floor[n/2]^2) and (ceiling[n/2]^2) is identical to this lower sequence.
%H A397113 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (1,2,-2,-1,1).
%F A397113 a(n) = a(n-1) + 2 a(n-2) - 2 a(n-3) - a(n-4) + a(n-5), with (a(0),...,a(5)) = (0, -1, 1, -2, 4).
%F A397113 G.f.: -x*(2*x-1)*(x^2+1) / ( (1+x)^2*(x-1)^3 ). - _R. J. Mathar_, Jun 30 2026
%F A397113 a(n)-a(n-1) = (-1)^n*A043547(n). - _R. J. Mathar_, Jun 30 2026
%t A397113 z = 60;
%t A397113 f[n_] := Floor[n/2]^2; g[n_] := Ceiling[n/3]^2;
%t A397113 r = 1/2; s = 1;
%t A397113 u[n_] := Floor[r*f[n] + s*g[n]]; v[n_] := Ceiling[r*f[n] + s*g[n]]
%t A397113 Table[u[n], {n, 0, z}]
%t A397113 Table[v[n], {n, 0, z}]
%t A397113 (* Also *)
%t A397113 LinearRecurrence[{1, 2, -2, -1, 1}, {0, -1, 1, -2, 4}, 30]
%Y A397113 Cf. A389123, A397110.
%K A397113 sign,easy,changed
%O A397113 0,4
%A A397113 _Clark Kimberling_, Jun 20 2026
