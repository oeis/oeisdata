%S A397136 1,2,2,2,2,4,2,0,3,4,2,4,2,4,4,0,2,6,2,4,4,4,2,0,5,4,0,4,2,8,2,0,4,4,
%T A397136 4,6,2,4,4,0,2,8,2,4,6,4,2,0,7,10,4,4,2,0,4,0,4,4,2,8,2,4,6,0,4,8,2,4,
%U A397136 4,8,2,0,2,4,10,4,4,8,2,0,0,4,2,8,4,4,4,0,2,12,4,4,4,4,4,0,2,14,6,10
%N A397136 Dirichlet g.f.: Product_{p prime} (1 + 2/p^s + 1/p^(2*s-1)).
%H A397136 Vaclav Kotesovec, <a href="/A397136/b397136.txt">Table of n, a(n) for n = 1..10000</a>
%H A397136 Vaclav Kotesovec, <a href="/A397136/a397136.jpg">Graph - the asymptotic ratio (10000 terms)</a>
%F A397136 Let f(s) = Product_{primes p} (p^s-1)^2 * (p^(2*s)-p) * (p^(2*s) + 2*p^s + p) / p^(6*s).
%F A397136 Dirichlet g.f.: zeta(s)^2 * zeta(2*s-1) * f(s).
%F A397136 Sum_{k=1..n} a(k) ~ f(1) * n * (log(n)^2 + 2*(4*gamma - 1 + f'(1)/f(1))*log(n) + 2 - 8*gamma + 10*gamma^2 - 12*sg1 + (2*(4*gamma - 1)*f'(1) + f''(1))/f(1)) / 4, where
%F A397136 f(1) = Product_{primes p} (1 - 6/p^2 + 8/p^3 - 3/p^4) = A319592 = 0.1148840440802287887292512767015990978487135526872830176248484...,
%F A397136 f'(1) = f(1) * Sum_{primes p} 16*log(p)/((p-1)*(p+3)) = 0.7329537986688178103828762539130015065766096293897775989858128...,
%F A397136 f''(1) = f'(1)^2/f(1) + f(1) * Sum_{primes p} -2*(23*p^2 + 26*p - 1) * log(p)^2 / ((p-1)^2 * (p+3)^2) = 1.3073198533301549336255068891648606199737582186092200289304...,
%F A397136 gamma is the Euler-Mascheroni constant A001620 and sg1 is the first Stieltjes constant (see A082633).
%F A397136 Multiplicative with a(p) = 2, a(p^2) = p, and a(p^e) = 0 for e >= 3. - _Amiram Eldar_, Jul 21 2026
%t A397136 f[p_, 1] := 2; f[p_, 2] := p; f[p_, e_] := 0; a[1] = 1; a[n_] := Times @@ f @@@ FactorInteger[n]; Array[a, 100] (* _Amiram Eldar_, Jul 21 2026 *)
%o A397136 (PARI) for(n=1, 100, print1(direuler(p=2, n, (1 + 2*X + p*X^2))[n], ", "))
%Y A397136 Cf. A047994, A396336, A319592.
%K A397136 nonn,mult,easy,new
%O A397136 1,2
