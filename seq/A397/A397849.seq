%I A397849 #24 Jul 21 2026 22:11:40
%S A397849 1175711,1178711,101373101,101919101,111050111,111272111,111848111,
%T A397849 113535311,117272711,117323711,117797711,119595911,119646911,
%U A397849 119676911,119787911,119868911,151353151,181797181,191313191,191727191,191757191,313383313,373353373,373929373,919191919,919797919,929151929
%N A397849 Palindromic primes that are the concatenation of two or more palindromic primes >= 11.
%C A397849 Members of A002385 that are the concatenation of two or more multi-digit members of A002385.
%C A397849 The first term not in A177678 is a(250) = 1110110110111, which is the concatenation of the palindromic primes 11, 101, 101, 101 and 11.
%C A397849 Prime repunits (see A004023) provide many examples that are the concatenation of multi-digit members of A002385 in many different ways.  Thus A002275(317) is prime and is the concatenation (in any order) of 149 copies of A002275(2) and one of A002275(19), or 147 copies of A002275(2) and one of A002275(23), or many other possibilities. - _David A. Corneth_, Jul 15 2026.
%C A397849 11757117871175711 and 11787117871178711 are concatenations of palindromic primes in more than one way. - _David A. Corneth_, Jul 16 2026
%H A397849 David A. Corneth, <a href="/A397849/b397849.txt">Table of n, a(n) for n = 1..10000</a> (first 1385 terms from Robert Israel)
%H A397849 David A. Corneth, <a href="/A397849/a397849.gp.txt">PARI program</a>
%e A397849 a(3) = 101373101 is a term because it is a palindromic prime and is the concatenation of 101, 373 and 101 which are multi-digit palindromic primes.
%p A397849 getpp:= proc(d) local R,n,x,L,xr,i,y,z;
%p A397849   R:= 11;
%p A397849   for n from 1 to d do
%p A397849     for x from 10^(n-1) to 10^n-1 do
%p A397849       L:= convert(x,base,10);
%p A397849       xr:= add(L[-i]*10^(i-1),i=1..n);
%p A397849       for y from 0 to 9 do
%p A397849         z:= 10^(1+n)*x + 10^n*y +xr;
%p A397849         if isprime(z) then R:= R,z fi
%p A397849  od od od;
%p A397849  [R]
%p A397849 end proc:
%p A397849 R:= getpp(4):
%p A397849 filter:= proc(n) local d,x,k;
%p A397849   d:= 1+ilog10(n);
%p A397849   for k from 2 to d do
%p A397849     x:= n mod 10^k;
%p A397849     if x >= 10^(k-1) and ListTools:-BinarySearch(R,x)<>0 and g((n-x)/10^k) then return true fi
%p A397849   od;
%p A397849   false
%p A397849 end proc:
%p A397849 g:= proc(n) local d,x,k;
%p A397849   option remember;
%p A397849   if ListTools:-BinarySearch(R,n)<>0 then return true fi;
%p A397849   filter(n)
%p A397849 end proc:
%p A397849 select(filter, R);
%o A397849 (PARI) \\ See Corneth link
%Y A397849 Cf. A002275, A002385, A004023, A177678.
%K A397849 nonn,base,new
%O A397849 1,1
%A A397849 _Will Gosnell_ and _Robert Israel_, Jul 12 2026
