%S A397902 1,4,81,4613,499365,86490945,21711123675,7426809498347,
%T A397902 3318066306513632,1876382142968013290,1310814559539441899210,
%U A397902 1109240944856969790364390,1118719879809977225905381923,1326386735101880486293479967805,1827111679569868928475026305597123,2894518898325626553553785806040962331
%N A397902 G.f. A(x) satisfies [x^(n-1)] (1 - A(x))^(n^2) / (1 - n^2*x) = 0 for n > 1.
%C A397902 Conjecture: for n > 2, a(n) is odd iff n is of the form 2^k, 2^k-1, 2^k-2, or 2^k-3 (k > 1).
%H A397902 Paul D. Hanna, <a href="/A397902/b397902.txt">Table of n, a(n) for n = 1..215</a>
%F A397902 G.f. A(x) = Sum_{n>=1} a(n)*x^n has the following properties.
%F A397902 (1) [x^(n-1)] (1 - A(x))^(n^2) / (1 - (n^2)*x) = 0 for n > 1.
%F A397902 (2) Sum_{k=0..n-1} [x^k] (1 - A(x/n^2))^(n^2) = 0 for n > 1.
%F A397902 (3) Sum_{k=0..n-1} (n^2)^(n-k) * [x^k] (1 - A(x))^(n^2) = 0 for n > 1.
%F A397902 (4) Sum_{k=0..n-1} (n^2)^(n-k) * Sum_{j=0..n^2} (-1)^j * binomial(n^2,j) * [x^k] A(x)^j = 0 for n > 1.
%F A397902 a(n) ~ 2*sinh(1)*exp(exp(-2)) * n^(2*n-2). - _Vaclav Kotesovec_, Jul 20 2026
%e A397902 G.f.: A(x) = x + 4*x^2 + 81*x^3 + 4613*x^4 + 499365*x^5 + 86490945*x^6 + 21711123675*x^7 + 7426809498347*x^8 + ...
%e A397902 The table of coefficients of x^k in (1 - A(x))^(n^2) begins
%e A397902   n = 1: [1,  -1,  -4,   -81,  -4613,   -499365, ...];
%e A397902   n = 2: [1,  -4, -10,  -280, -17431,  -1939364, ...];
%e A397902   n = 3: [1,  -9,   0,  -525, -35991,  -4161375, ...];
%e A397902   n = 4: [1, -16,  56,  -896, -57348,  -6943168, ...];
%e A397902   n = 5: [1, -25, 200, -1925, -76875, -10041955, ...];
%e A397902   n = 6: [1, -36, 486, -5016, -80703, -13268772, ...];
%e A397902   ...
%e A397902 from which we may illustrate that the sum of the first n coefficients in (1 - A(x/n^2))^(n^2) equals 0 for n > 1 by:
%e A397902   n = 1: 1 = 1;
%e A397902   n = 2: 0 = 1 - 4/2^2;
%e A397902   n = 3: 0 = 1 - 9/3^2 + 0/3^4;
%e A397902   n = 4: 0 = 1 - 16/4^2 + 56/4^4 - 896/4^6;
%e A397902   n = 5: 0 = 1 - 25/5^2 + 200/5^4 - 1925/5^6 - 76875/5^8;
%e A397902   n = 6: 0 = 1 - 36/6^2 + 486/6^4 - 5016/6^6 - 80703/6^8 - 13268772/6^10;
%e A397902   etc.
%o A397902 (PARI) {a(n) = my(A=[0, 1]); for(i=2, n, A=concat(A, 0); m=#A; A[m] = Vec( (1-Ser(A))^(m^2) / (1 - (m^2)*x  +x^2*O(x^m)) )[m]/m^2 ); GF=Ser(A); A[n+1]}
%o A397902 {upto(n) = a(n); Vec(GF)}
%o A397902 upto(25)
