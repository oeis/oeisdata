%I A397024 #26 Jul 06 2026 19:06:05
%S A397024 0,2,4,8,8,12,16,20,16,20,24,28,32,32,40,60,32,36,40,44,48,48,56,60,
%T A397024 64,56,64,88,80,72,120,92,64,68,72,76,80,80,88,100,96,88,96,100,112,
%U A397024 132,120,124,128,104,112,156,128,120,176,176,160,136,144,148,240,152
%N A397024 a(n) is the sum of gcd(k,n) over all numbers k obtained by changing any subset of the 1-bits of n to 0-bits in its binary representation.
%C A397024 a(n) = Sum_{k AND n = k} gcd(k,n); these integers are given by row n of A295989.
%C A397024 In other words, k is obtained from n by changing an arbitrary subset of the 1-bits of n to 0-bits, including the empty subset (so k = n is allowed).
%C A397024 The defining sum for a(n) has 2^A000120(n) terms.
%C A397024 The function is not multiplicative and depends on the binary structure of n rather than only on its prime factorization.
%H A397024 Felix Huber, <a href="/A397024/b397024.txt">Table of n, a(n) for n = 0..10000</a>
%F A397024 a(n) >= 2*n + 2^A000120(n) - 2.
%F A397024 a(2^m) = 2^(m + 1).
%F A397024 a(p) = 2*p + (2^(A000120(p)) - 2) for primes p.
%e A397024 a(45) = 132, since 45 = 2^0 + 2^2 + 2^3 + 2^5 and A007088(45) = 101101. Changing any subset of the 1-bits to 0-bits yields the values k = 0, 1, 4, 5, 8, 9, 12, 13, 32, 33, 36, 37, 40, 41, 44, 45, and gcd(k,45) = 45, 1, 1, 5, 1, 9, 3, 1, 1, 3, 9, 1, 5, 1, 1, 45, summing to 132.
%p A397024 b := proc(n)
%p A397024     local i, l, t;
%p A397024     t := n; i := 0; l := [];
%p A397024     while t > 0 do
%p A397024         if irem(t, 2) = 1 then l := [op(l), i] end if;
%p A397024         t := iquo(t, 2); i := i + 1
%p A397024     end do;
%p A397024     l
%p A397024 end proc:
%p A397024 A397024 := proc(n)
%p A397024     local a, j, k, m, s, x, y;
%p A397024     s := b(n); k := nops(s); a := 0;
%p A397024     for m from 0 to 2^k - 1 do
%p A397024         x := 0; y := 0;
%p A397024         for j from 1 to k do
%p A397024             if irem(iquo(m, 2^(j - 1)), 2) = 1 then x := x + 2^(s[j])
%p A397024             else y := y + 2^(s[j])
%p A397024             end if
%p A397024         end do;
%p A397024         if x = 0 then a := a + y
%p A397024         elif y = 0 then a := a + x
%p A397024         else a := a + igcd(x, y)
%p A397024         end if
%p A397024     end do;
%p A397024     a
%p A397024 end proc:
%p A397024 seq(A397024(n), n = 0 .. 61);
%t A397024 a[n_] := Sum[GCD[n, k], {k, Select[Range[0, n], BitAnd[n, #] == # &]}]; Array[a, 100, 0] (* _Amiram Eldar_, Jun 29 2026 *)
%o A397024 (PARI) f(n) = select(x->bitand(x, n) == x, [0..2^(1+logint(n,2))]); \\ A295989
%o A397024 a(n) = my(v=f(n)); sum(k=1,#v, gcd(n,v[k])); \\ _Michel Marcus_, Jun 29 2026
%o A397024 (Python)
%o A397024 from math import gcd
%o A397024 from itertools import combinations
%o A397024 def A397024(n):
%o A397024     m = [i for i, j in enumerate(bin(n)[-1:1:-1]) if j=='1']
%o A397024     return sum(gcd(sum(1<<j for j in d),n) for l in range(len(m)+1) for d in combinations(m,l)) # _Chai Wah Wu_, Jun 29 2026
%Y A397024 Cf. A000079, A000120, A001316, A007088, A050873, A295989.
