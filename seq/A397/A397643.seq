%I A397643 #33 Jul 07 2026 16:09:00
%S A397643 1,2,3,11,12,13,22,23,33,111,112,113,122,123,133,222,223,233,333,1111,
%T A397643 1112,1113,1122,1123,1133,1222,1223,1233,1333,2222,2223,2233,2333,
%U A397643 3333,11111,11112,11113,11122,11123,11133,11222,11223,11233,11333,12222,12223,12233,12333
%N A397643 Numbers with digits in nondecreasing order having only digits 1 through 3.
%C A397643 For k >= 1 there are binomial(k + 2, 2) terms with k digits.
%H A397643 David A. Corneth, <a href="/A397643/b397643.txt">Table of n, a(n) for n = 1..10000</a>
%e A397643 11123 is a term since all digits are <= 3 and they are in nondecreasing order: 1 <= 1 <= 1 <= 2 <= 3.
%o A397643 (PARI) is(n) = if(n == 0, return(0)); my(d = digits(n)); d == vecsort(d) && d[#d] <= 3
%o A397643 (PARI) first(n) = {my(res = List()); for(i = 1, oo, forvec(x = vector(i, j, [1, 3]), listput(res, fromdigits(x)); if(#res >= n, return(res)), 1))}
%o A397643 (Python)
%o A397643 from itertools import count, islice, combinations_with_replacement as cwr
%o A397643 def agen(): yield from (int("".join(t)) for d in count(1) for t in cwr("123", d))
%o A397643 print(list(islice(agen(), 50))) # _Michael S. Branicky_, Jul 03 2026
%Y A397643 Cf. A007932, A009994.
