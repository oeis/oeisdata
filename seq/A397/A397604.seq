%U A397604 14,30,52,86,141,232,252,126,70,49,48,62,92,144,230,371,603
%N A397604 Triangle read by rows: T(n, k) = T(n, k+1) - T(n-1, k) with initial values T(n, n) = A005043(n).
%e A397604 Triangle starts:
%e A397604   [0]    1;
%e A397604   [1]   -1,   0;
%e A397604   [2]    2,   1,   1;
%e A397604   [3]   -3,  -1,   0,  1;
%e A397604   [4]    6,   3,   2,  2,  3;
%e A397604   [5]  -10,  -4,  -1,  1,  3,  6;
%e A397604   [6]   20,  10,   6,  5,  6,  9, 15;
%e A397604   [7]  -35, -15,  -5,  1,  6, 12, 21, 36;
%e A397604   [8]   70,  35,  20, 15, 16, 22, 34, 55,  91;
%e A397604   [9] -126, -56, -21, -1, 14, 30, 52, 86, 141, 232;
%p A397604 T := proc(n, k) option remember; if n = k then simplify((-1)^n*hypergeom([-n, 1/2], [2], 4)) else T(n, k+1) - T(n-1, k) fi end: seq(seq(T(n, k), k = 0..n), n = 0..10);
%o A397604 (Python)
%o A397604 def row_gen():
%o A397604     b, a, n, r = 1, 0, 1, 0
%o A397604     diffs = [1]
%o A397604     yield diffs[:]
%o A397604     while True:
%o A397604         diffs.append(r)
%o A397604         for k in range(n, 0, -1):
%o A397604             diffs[k - 1] = diffs[k] - diffs[k - 1]
%o A397604         # yield r generates A005043.
%o A397604         # yield diffs[0] generates A126930.
%o A397604         yield diffs[:]
%o A397604         r = n * (2 * a + 3 * b) // (n + 2)
%o A397604         b, a, n = a, r, n + 1
%o A397604 A397604_row = row_gen()
%o A397604 for _ in range(12): print(next(A397604_row))
