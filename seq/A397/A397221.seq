%I A397221 #10 Jun 27 2026 00:28:15
%S A397221 2,3,5,7,11,12,13,17,19,20,23,28,29,31,37,41,43,44,47,52,53,59,61,67,
%T A397221 68,71,73,76,79,83,89,90,92,97,101,103,107,109,113,116,124,126,127,
%U A397221 131,137,139,148,149,151,157,163,164,167,172,173,179,181,188,191,193,197,198,199
%N A397221 Numbers m such that rad(m) * omega(m) = m.
%C A397221 Primes p are terms since rad(p) * omega(p) = p * 1 = p.
%C A397221 Prime powers p^k (k > 1) are never terms since p * 1 != p^k.
%C A397221 Composite terms classified by r = omega(m):
%C A397221 - r = 2: m = 4*p for odd primes p (e.g., 12, 20, 28, 44).
%C A397221 - r = 3: m = 9*p*q for distinct primes p, q != 3 (e.g., 90).
%C A397221 - r = 4: m = 8*p*q*s for distinct odd primes p, q, s (e.g., 840).
%H A397221 Vincenzo Manto, <a href="/A397221/b397221.txt">Table of n, a(n) for n = 1..10000</a>
%e A397221 m = 12 is a term since rad(12) * omega(12) = 6 * 2 = 12.
%e A397221 m = 8 is not a term since rad(8) * omega(8) = 2 * 1 = 2 != 8.
%t A397221 q[m_] := Module[{p = FactorInteger[m][[;; , 1]]}, Length[p] * Times @@ p == m]; q[1] = False; Select[Range[200], q] (* _Amiram Eldar_, Jun 21 2026 *)
%o A397221 (Python)
%o A397221 from math import prod
%o A397221 from sympy import primefactors
%o A397221 def ok(m): return len(f := primefactors(m)) * prod(f) == m
%o A397221 print([m for m in range(1, 200) if ok(m)])
%Y A397221 Cf. A000040, A001221, A007947, A065512.
%K A397221 nonn,new
%O A397221 1,1
%A A397221 _Vincenzo Manto_ and _James C. McMahon_, Jun 19 2026
