%I A397907 #17 Jul 20 2026 23:48:07
%S A397907 1,1,7,295,78151,132944679,1493914780135,114001703650886247,
%T A397907 60459498052470905351015,226939880898889972239387567463,
%U A397907 6115597181959736880651348835447363943,1196542264810093278351630651930775144882143591,1715126592161267169765985121294588995848310662204281191
%N A397907 Central terms of triangle A152795.
%C A397907 Triangle T(n,k) = A152795(n,k) is defined by T(n,k) = T(n-1,k-1) + Sum_{j=k..n-2} T(n-1,j)*2^j*T(j,k-1) for n > k > 0 with T(n,n) = T(n,0) = 1.
%H A397907 Paul D. Hanna, <a href="/A397907/b397907.txt">Table of n, a(n) for n = 0..50</a>
%F A397907 a(n) = A152795(2*n, n).
%e A397907 Triangle A152795 begins:
%e A397907   1;
%e A397907   1,   1;
%e A397907   1,   1,   1;
%e A397907   1,   3,   1,   1;
%e A397907   1,  11,   7,   1,  1;
%e A397907   1,  59,  63,  15,  1, 1;
%e A397907   1, 507, 847, 295, 31, 1, 1;
%e A397907   ...
%e A397907 the central terms of even-indexed rows of which form this sequence.
%e A397907 Triangular matrix T = A152795 may be generated by
%e A397907   ShiftUp(T) = T + (T - I)*D*(T - I),
%e A397907 where D = diagonal matrix of powers of 2, I = identity matrix, and ShiftUp(T) = T shifted 1 row up and 1 column left.
%o A397907 (PARI) \\ Generate A152795 Using Matrix Products
%o A397907 {A152795(n,k) = my(M=matrix(2,2,r,c,if(r>=c,1)),D,L,S); for(i=1,n,
%o A397907 D = matrix(#M,#M,r,c, if(r==c, 2^(r-1))); \\ D = Diagonal of powers of 2
%o A397907 L = M - M^0; \\ L = M without diagonal of 1's
%o A397907 S = M + L*D*L; \\ N = New matrix, but shifted up 1 row, 1 column
%o A397907 M = matrix(#M+1,#M+1,r,c, if(c==1,1, if(r==1,0, S[r-1,c-1])) ));
%o A397907 TM = M; M[n+1,k+1]}
%o A397907 \\ Print central terms of triangle A152795
%o A397907 {upto(n) = A152795(2*n,n); for(r=0,n, print1(TM[2*r+1,r+1],", "))}
%o A397907 upto(15)
%Y A397907 Cf. A152795.
%K A397907 nonn,new
%O A397907 0,3
%A A397907 _Paul D. Hanna_, Jul 14 2026
