%I A397350 #16 Jun 25 2026 00:49:49
%S A397350 1,0,-1,0,6,1,0,-12,-24,-1,0,0,300,70,1,0,0,-2160,-2400,-180,-1,0,0,
%T A397350 7560,51240,13650,434,1,0,0,0,-695520,-618240,-65772,-1008,-1,0,0,
%U A397350 -60480,5533920,18416160,5498640,288288,2286,1,0,0,0,-17236800,-368928000,-297561600,-41151600,-1191720,-5100,-1
%N A397350 Triangle, read by rows, of coefficients of x^n*y^k/n! in e.g.f. A(x,y) satisfying Sum_{n>=0} y^n * (A(x,y)^n - x)^n / n! = 1.
%C A397350 Related identity: Sum_{n>=0} (q^n + p)^n * r^n/n! = Sum_{n>=0} exp(p*q^n*r) * q^(n^2) * r^n/n!; here, q = A(x,y), p = -x, r = y.
%H A397350 Paul D. Hanna, <a href="/A397350/b397350.txt">Table of n, a(n) for n = 1..1275 (rows 1..50).</a>
%F A397350 E.g.f. A(x,y) = Sum_{n>=0} x^n/n! * Sum_{k=0..n} T(n,k)*y^k satisfies the following formulas.
%F A397350 (1) 1 = Sum_{n>=0} y^n * (A(x,y)^n - x)^n / n!.
%F A397350 (2) 1 = Sum_{n>=0} y^n * exp(-y*x*A(x,y)^n) * A(x,y)^(n^2) / n!.
%F A397350 T(n,n-1) = (-1)^(n-1) for n >= 1.
%F A397350 T(n,n-2) = (-1)^(n-1) * 2*n * (2^(n-2) - 1) for n >= 2.
%e A397350 E.g.f.: A(x,y) = x - y*x^2/2! + (6*y + y^2)*x^3/3! + (-12*y - 24*y^2 - y^3)*x^4/4! + (300*y^2 + 70*y^3 + y^4)*x^5/5! + (-2160*y^2 - 2400*y^3 - 180*y^4 - y^5)*x^6/6! + (7560*y^2 + 51240*y^3 + 13650*y^4 + 434*y^5 + y^6)*x^7/7! + (-695520*y^3 - 618240*y^4 - 65772*y^5 - 1008*y^6 - y^7)*x^8/8! + (-60480*y^2 + 5533920*y^3 + 18416160*y^4 + 5498640*y^5 + 288288*y^6 + 2286*y^7 + y^8)*x^9/9! + ...
%e A397350 where Sum_{n>=0} y^n * (A(x,y)^n - x)^n / n! = 1.
%e A397350 This triangle of coefficients of x^n*y^k/n! in A(x,y) begins
%e A397350   n = 1: [1];
%e A397350   n = 2: [0, -1];
%e A397350   n = 3: [0, 6, 1];
%e A397350   n = 4: [0, -12, -24, -1];
%e A397350   n = 5: [0, 0, 300, 70, 1];
%e A397350   n = 6: [0, 0, -2160, -2400, -180, -1];
%e A397350   n = 7: [0, 0, 7560, 51240, 13650, 434, 1];
%e A397350   n = 8: [0, 0, 0, -695520, -618240, -65772, -1008, -1];
%e A397350   n = 9: [0, 0, -60480, 5533920, 18416160, 5498640, 288288, 2286, 1];
%e A397350   n =10: [0, 0, 0, -17236800, -368928000, -297561600, -41151600, -1191720, -5100, -1]; ...
%o A397350 (PARI) \\ 1 = Sum_{n>=0} y^n * exp(-y*x*A^n) * A^(n^2) / n!
%o A397350 {a(n,k) = my(A=[0, 1]); for(i=2, n, A = concat(A, 0);
%o A397350 A[#A] = -polcoeff( sum(m=0, sqrtint(#A+1), y^m*exp(-y*Ser(A)^m*x +O(x^#A)) * Ser(A)^(m^2)/m! ), #A-1)/y; ); EGF=Ser(A); n!*polcoef(polcoef(EGF,n,x),k,y)}
%o A397350 \\ Define the element of the triangle
%o A397350 {T(n,k) = n!*polcoef(polcoef(EGF,n,x),k,y)}
%o A397350 \\ Print the triangle of N rows
%o A397350 N=12;
%o A397350 {a(N,N); for(n=1,N, for(k=0,n-1, print1(T(n,k),", "));print(""))}
%Y A397350 Cf. A371710 (y=1), A397352 (y=2), A397353 (y=3), A397354 (y=4), A397355 (y=5).
%Y A397350 Cf. A397351 (central terms).
%Y A397350 Cf. A361540 (related triangle).
%K A397350 sign,tabl,new
%O A397350 1,5
%A A397350 _Paul D. Hanna_, Jun 22 2026
