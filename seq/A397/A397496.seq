%N A397496 Triangle read by rows: T(n, k) is the concatenation of numbers from n down to n + 1 - k, n >= k >= 1.
%H A397496 Michael S. Branicky, <a href="/A397496/b397496.txt">Table of n, a(n) for n = 1..10011</a> (rows 1..141)
%e A397496 Triangle begins:
%e A397496   1;
%e A397496   2, 21;
%e A397496   3, 32, 321;
%e A397496   4, 43, 432, 4321;
%e A397496   ...
%p A397496 T:= (n,k)-> parse(cat("",n-i$i=0..k-1)):
%p A397496 seq(seq(T(n,k), k=1..n), n=1..10);  # _Alois P. Heinz_, Jun 28 2026
%t A397496 T[n_,k_]:=FromDigits[Range[n,n-k+1,-1]]; Table[T[n,k],{n,10},{k,n}]//Flatten (* _Stefano Spezia_, Jun 29 2026 *)
%o A397496 (Python)
%o A397496 def T(n, k): return int("".join(map(str, range(n, k-1, -1))))
%o A397496 def row(n): return [T(n, k) for k in range(n, 0, -1)]
%o A397496 print([e for n in range(1, 11) for e in row(n)])
