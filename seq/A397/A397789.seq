%S A397789 3,5,11,19,37,47,71,83,109,157,173,227,263,281,317,383,457,479,547,
%T A397789 599,619,701,757,839,953,1013,1049,1109,1129,1201,1433,1499,1601,1637,
%U A397789 1823,1861,1973,2081,2161,2273,2393,2437,2633,2683,2767,2803,3067,3331,3413
%N A397789 a(n) = nearest prime to prime(n)^(3/2).
%C A397789 There is no solution for p^3 = q^2 when p and q are distinct prime numbers.
%H A397789 James C. McMahon, <a href="/A397789/b397789.txt">Table of n, a(n) for n = 1..10000</a>
%F A397789 Conjecture: A397790(n) = a(n)^2. [In other words, it is conjectured that there are no consecutive primes p1 < p2 and a prime q such that (p1 + p2)^2/4 < q^3 < (p1^2 + p2^2)/2. - _Jianing Song_, Jul 14 2026]
%e A397789 Prime(2)^(3/2) = 5.196...; the nearest prime is 5, so a(2) = 5.
%t A397789 a[n_]:=Sqrt[Nearest[{NextPrime[Prime[n]^1.5,-1]^2,NextPrime[Prime[n]^1.5]^2},Prime[n]^3][[1]]];Array[a,49]
%o A397789 (PARI) a(n) = my(t=prime(n)^(3/2), mn=precprime(t), mx=nextprime(t)); if(mx-t<t-mn, mx, mn); \\ _Michel Marcus_, Jul 13 2026
