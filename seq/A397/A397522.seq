%N A397522 Row 8 of A365673.
%C A397522 This a weighted generalized Catalan sequence (A365673) with the octagonal numbers as weights.
%F A397522 a(n) ~ 2^(4*n + 5/3) * 3^n * n^(2*n - 1/6) / (Gamma(1/3) * exp(2*n) * Pi^(2*n - 1/6)).
%t A397522 pn[n_,k_]:=pn[n, k] = Which[k==0, 1, k==n, pn[n, k-1], True, PolygonalNumber[8, n-k+1]*pn[n, k-1] + pn[n-1, k]]; Table[pn[n, n], {n, 0, 20}]
