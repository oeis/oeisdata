%I A397978 #8 Jul 24 2026 00:57:16
%S A397978 0,1,5,12,21,32,46,63,82,103,127,154,183,214,248,285,324,365,409,456,
%T A397978 505,556,610,667,726,787,851,918,987,1058,1132,1209,1288,1369,1453,
%U A397978 1540,1629,1720,1814,1911,2010,2111,2215,2322,2431,2542,2656,2773,2892,3013
%N A397978 Lower (1/2,1) midsequence of triangular numbers (A000217) and squares (A000290); see Comments.
%C A397978 Suppose that s = (s(n)) and t = (t(n)) are sequences of numbers and h > 0 and k > 0. The lower (h, k)-midsequence of s and t is floor(h*s + k*t); the upper (h, k)-midsequence of s and t is ceiling(h*s + k*t). See A397972 for a guide to related sequences.
%H A397978 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (3,-4,4,-3,1).
%F A397978 a(n) = 3*a(n-1) - 4*a(n-2) + 4*a(n-3) - 3*a(n-4) + a(n-5), with (a(0),...,a(4)) = (0,1,5,12,21).
%F A397978 G.f.: -x*(1 + 2*x + x^2 + x^3)/((-1 + x)^3*(1 + x^2)).
%F A397978 E.g.f.: (exp(x)*(5*x^2 + 6*x - 1) + cos(x) - sin(x))/4. - _Stefano Spezia_, Jul 21 2026
%t A397978 z = 60;
%t A397978 f[n_] := (n^2 + n)/2; g[n_] := n^2; r = 1/2; s = 1;
%t A397978 u[n_] := Floor[r*f[n] + s*g[n]]; v[n_] := Ceiling[r*f[n] + s*g[n]]
%t A397978 Table[u[n], {n, 0, z}]
%Y A397978 Cf. A000217, A000290, A397979.
%K A397978 nonn,easy,new
%O A397978 0,3
%A A397978 _Clark Kimberling_, Jul 21 2026
