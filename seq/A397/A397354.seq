%U A397354 -9666135535841837056,758829911892593606656,-63977540723189889630208,5765689192533129791799296,-553116658836850216617902080,56277267936886426894621212672
%N A397354 E.g.f. A(x) satisfies Sum_{n>=0} 4^n * (A(x)^n - x)^n / n! = 1.
%C A397354 Related identity: Sum_{n>=0} (q^n + p)^n * r^n/n! = Sum_{n>=0} exp(p*q^n*r) * q^(n^2) * r^n/n!; here, q = A(x), p = -x, r = 4.
%H A397354 Paul D. Hanna, <a href="/A397354/b397354.txt">Table of n, a(n) for n = 1..300</a>
%F A397354 E.g.f. A(x) = Sum_{n>=0} a(n)*x^n/n! satisfies the following formulas.
%F A397354 (1) 1 = Sum_{n>=0} 4^n * (A(x)^n - x)^n / n!.
%F A397354 (2) 1 = Sum_{n>=0} 4^n * exp(-4*x*A(x)^n) * A(x)^(n^2) / n!.
%F A397354 a(n) = Sum_{k=0..n-1} 4^k * A397350(n,k) for n >= 1.
%e A397354 E.g.f.: A(x) = x - 4*x^2/2! + 40*x^3/3! - 496*x^4/4! + 9536*x^5/5! - 235264*x^6/6! + 7343232*x^7/7! - 274278400*x^8/8! + 11916694528*x^9/9! + ...
%e A397354 where e.g.f. A(x) satisfies the following sums.
%e A397354 (1) 1 = 1 + 4*(A(x) - x) + 4^2*(A(x)^2 - x)^2/2! + 4^3*(A(x)^3 - x)^3/3! + 4^4*(A(x)^4 - x)^4/4! + 4^5*(A(x)^5 - x)^5/5! + ...
%e A397354 (2) 1 = exp(-4*x) + 4*exp(-4*x*A(x))*A(x) + 4^2*exp(-4*x*A(x)^2)*A(x)^4/2! + 4^3*exp(-4*x*A(x)^3)*A(x)^9/3! + 4^4*exp(-4*x*A(x)^4)*A(x)^16/4! + ...
%e A397354 SPECIFIC VALUES.
%e A397354 A(t) = 1/8 at t = 0.156089894926436212932253457148012589251008363910873...
%e A397354 A(1/6) = 0.132193478623018074795959490768992387239159805186906...
%e A397354 A(1/7) = 0.115888228589719945217681463047168835774621011098994...
%e A397354 A(1/8) = 0.103344874757035078153683264624205566263574837721050...
%e A397354 A(t) = -1/3 at t = -0.168183792032250849008953798954440638882781859086486...
%e A397354 A(-1/6) = -0.322244506140233989523209572252634662080206060255866...
%e A397354 A(-1/7) = -0.225174539226134857186721518398079544796721543038053...
%e A397354 A(-1/8) = -0.179752567904142920077627858170165165910748103505313...
%o A397354 (PARI) /* 1 = Sum_{n>=0} r^n * exp(-r*x*A(x)^n) * A(x)^(n^2) / n! */
%o A397354 {a(n,r=4) = my(A=[0, 1]); for(i=2, n, A = concat(A, 0);
%o A397354 A[#A] = -polcoeff( sum(m=0, sqrtint(#A+1), r^m*exp(-r*Ser(A)^m*x +O(x^#A)) * Ser(A)^(m^2)/m! ), #A-1)/r; ); EGF=Ser(A); n!*A[n+1]}
%o A397354 {upto(n) = a(n); Vec(serlaplace(EGF))}
%o A397354 upto(25)
%o A397354 (PARI) /* 1 = Sum_{n>=0} r^n * (A(x)^n - x)^n / n! */
%o A397354 {a(n,r=4) = my(A=[0, 1]); for(i=2, n, A = concat(A, 0);
%o A397354 A[#A] = -polcoeff( sum(m=0, #A+1, r^m*(Ser(A)^m - x)^m/m! ), #A-1)/r ); EGF=Ser(A); n!*A[n+1]}
%o A397354 {upto(n) = a(n); Vec(serlaplace(EGF))}
