%S A397352 1,-2,16,-128,1776,-30752,672512,-17625344,533387776,-18350262272,
%T A397352 704859314688,-29915325532160,1389871536386048,-70163519711768576,
%U A397352 3824605075155533824,-223890991044012670976,14009376453331418284032,-933108265990875822424064,65915097595341634909503488
%N A397352 E.g.f. A(x) satisfies Sum_{n>=0} 2^n * (A(x)^n - x)^n / n! = 1.
%C A397352 Related identity: Sum_{n>=0} (q^n + p)^n * r^n/n! = Sum_{n>=0} exp(p*q^n*r) * q^(n^2) * r^n/n!; here, q = A(x), p = -x, r = 2.
%H A397352 Paul D. Hanna, <a href="/A397352/b397352.txt">Table of n, a(n) for n = 1..300</a>
%F A397352 E.g.f. A(x) = Sum_{n>=0} a(n)*x^n/n! satisfies the following formulas.
%F A397352 (1) 1 = Sum_{n>=0} 2^n * (A(x)^n - x)^n / n!.
%F A397352 (2) 1 = Sum_{n>=0} 2^n * exp(-2*x*A(x)^n) * A(x)^(n^2) / n!.
%F A397352 a(n) = Sum_{k=0..n-1} 2^k * A397350(n,k) for n >= 1.
%e A397352 E.g.f.: A(x) = x - 2*x^2/2! + 16*x^3/3! - 128*x^4/4! + 1776*x^5/5! - 30752*x^6/6! + 672512*x^7/7! - 17625344*x^8/8! + 533387776*x^9/9! + ...
%e A397352 where e.g.f. A(x) satisfies the following sums.
%e A397352 (1) 1 = 1 + 2*(A(x) - x) + 2^2*(A(x)^2 - x)^2/2! + 2^3*(A(x)^3 - x)^3/3! + 2^4*(A(x)^4 - x)^4/4! + 2^5*(A(x)^5 - x)^5/5! + ...
%e A397352 (2) 1 = exp(-2*x) + 2*exp(-2*x*A(x))*A(x) + 2^2*exp(-2*x*A(x)^2)*A(x)^4/2! + 2^3*exp(-2*x*A(x)^3)*A(x)^9/3! + 2^4*exp(-2*x*A(x)^4)*A(x)^16/4! + ...
%e A397352 SPECIFIC VALUES.
%e A397352 A(t) = 1/5 at t = 0.22948067096561305556954365996608536286628462176442...
%e A397352 A(1/5) = 0.175838358407752064352993886198726762071150034646465...
%e A397352 A(1/6) = 0.148416480462506693882066254102774271757085566514194...
%e A397352 A(1/7) = 0.128630428266321401787589534343139343731946057468804...
%e A397352 A(-1/5) = -0.2827370028113802635409704421601080603893182200258...
%e A397352 A(-1/6) = -0.2148113713294142018448715334955674080904350667811...
%e A397352 A(-1/7) = -0.1748151778489168915940985552569748354830916840380...
%o A397352 (PARI) /* 1 = Sum_{n>=0} r^n * exp(-r*x*A(x)^n) * A(x)^(n^2) / n! */
%o A397352 {a(n,r=2) = my(A=[0, 1]); for(i=2, n, A = concat(A, 0);
%o A397352 A[#A] = -polcoeff( sum(m=0, sqrtint(#A+1), r^m*exp(-r*Ser(A)^m*x +O(x^#A)) * Ser(A)^(m^2)/m! ), #A-1)/r; ); EGF=Ser(A); n!*A[n+1]}
%o A397352 {upto(n) = a(n); Vec(serlaplace(EGF))}
%o A397352 upto(25)
%o A397352 (PARI) /* 1 = Sum_{n>=0} r^n * (A(x)^n - x)^n / n! */
%o A397352 {a(n,r=2) = my(A=[0, 1]); for(i=2, n, A = concat(A, 0);
%o A397352 A[#A] = -polcoeff( sum(m=0, #A+1, r^m*(Ser(A)^m - x)^m/m! ), #A-1)/r ); EGF=Ser(A); n!*A[n+1]}
%o A397352 {upto(n) = a(n); Vec(serlaplace(EGF))}
%o A397352 upto(25)
