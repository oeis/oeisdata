%S A397812 0,1,0,3,4,27,68,315,980,3883,13188,49355,173716,635483,2268676,
%T A397812 8224667,29529044,106669131,383840260,1384587819,4986809492,
%U A397812 17978203387,64774493572,233469116027,841296459988,3032043498091,10926465128068,39377714668171,141907245404308
%N A397812 Number of tilings of a 3 X n rectangle, with all four corners removed, using dominoes and right trominoes.
%C A397812 Compare to A165716 which counts the same type of tiling on a 3 X n rectangle, but including the four corners.
%H A397812 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (2,6,-4,11,2).
%F A397812 a(n) = 2*a(n-1) + 6*a(n-2) - 4*a(n-3) + 11*a(n-4) + 2*a(n-5) for n >= 7.
%F A397812 G.f.: x^2*(1 - 2*x - 3*x^2 + 2*x^3 - 10*x^4)/(1 - 2*x - 6*x^2 + 4*x^3 - 11*x^4 - 2*x^5). - _Stefano Spezia_, Jul 11 2026
%e A397812 a(4) = 3, because there are 3 tilings of a 3 X 4 rectangle (missing the four corners) using dominoes and right trominoes:
%e A397812      ___        ___        ___
%e A397812    _| | |_    _|___|_    _|___|_
%e A397812   |___|___|  |_  |  _|  |___|___|
%e A397812     |___|      |_|_|      |___|
%t A397812 CoefficientList[Series[x^2*(1 - 2*x - 3*x^2 + 2*x^3 - 10*x^4)/(1 - 2*x - 6*x^2 + 4*x^3 - 11*x^4 - 2*x^5),{x,0,29}],x] (* _Stefano Spezia_, Jul 11 2026 *)
%Y A397812 Cf. A165716.
%K A397812 nonn,easy,new
