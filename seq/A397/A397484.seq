%e A397484 a(1) = 152:
%e A397484   |\ 2 for position of upper indicator,
%e A397484   |  1 for vertical position of regulator,
%e A397484   I  5 for lower indicator pointing upwards
%e A397484 .
%e A397484 a(43) = 163:
%e A397484     _
%e A397484    |  3 upper indicator pointing right,
%e A397484    |  1 vertical position of regulator,
%e A397484   \|  6 angle of lower indicator
%e A397484 .
%e A397484 a(50) = 383:
%e A397484  _ _ _  3 horizontal position of regulator,
%e A397484      /  8 angle of right indicator, rear 3: angle of left indicator
