%S A397268 0,2,1,7,4,14,9,23,16,34,25,47,36,62,49,79,64,98,81,119,100,142,121,
%T A397268 167,144,194,169,223,196,254,225,287,256,322,289,359,324,398,361,439,
%U A397268 400,482,441,527,484,574,529,623,576,674,625,727,676,782,729,839,784,898,841,959,900
%N A397268 Lower (-1,2) midsequence of (floor[n/2]^2) and (ceiling[n/2]^2); see Comments.
%C A397268 Suppose that s = (s(n)) and t = (t(n)) are sequences of numbers and h > 0 and k > 0. The lower (h, k)-midsequence of s and t is floor(h*s + k*t); the upper (h, k)-midsequence of s and t is ceiling(h*s + k*t). The upper (-1,2) midsequence of (floor[n/2]^2) and (ceiling[n/2]^2) is identical to this lower sequence.
%H A397268 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (1,2,-2,-1,1).
%F A397268 a(n) = a(n-1) + 2 a(n-2) - 2 a(n-3) - a(n-4) + a(n-5), with (a(0),...,a(4)) = (0, 2, 1, 7, 4).
%t A397268 z = 60; r = -1; s = 2;
%t A397268 f[n_] := Floor[n/2]^2; g[n_] := Ceiling[n/2]^2;
%t A397268 u[n_] := Floor[r*f[n] + s*g[n]]; v[n_] := Ceiling[r*f[n] + s*g[n]]
%t A397268 Table[u[n], {n, 0, z}]
%Y A397268 Cf. A389123, A397110.
%K A397268 nonn,easy,new
%O A397268 0,2
