%I A397549 #36 Jul 10 2026 18:07:40
%S A397549 1,6,6,18,6,36,6,40,18,36,6,108,6,36,36,75,6,108,6,108,36,36,6,240,18,
%T A397549 36,40,108,6,216,6,126,36,36,36,324,6,36,36,240,6,216,6,108,108,36,6,
%U A397549 450,18,108,36,108,6,240,36,240,36,36,6,648,6,36,108,196,36,216,6,108,36,216,6,720
%N A397549 Multiplicative with a(p^e) = (e+1)^2*(e+2)/2.
%C A397549 First differences of A331077.
%C A397549 Inverse Mobius transform of A061391.
%C A397549 Second inverse Mobius transform of A048785.
%C A397549 Third inverse Mobius transform of A074816.
%C A397549 Dirichlet convolution of A000005 and A048785.
%C A397549 Dirichlet convolution of A035116 and A055076.
%C A397549 Dirichlet convolution of A007425 and A074816.
%C A397549 Dirichlet convolution of A074823 and A007426.
%H A397549 Ridouane Oudra, <a href="/A397549/b397549.txt">Table of n, a(n) for n = 1..10000</a>
%H A397549 Vaclav Kotesovec, <a href="/A397549/a397549.jpg">Graph - the asymptotic ratio (1000000 terms)</a>
%F A397549 a(n) = tau(n)*tau_3(n), where tau = A000005 and tau_3 = A007425.
%F A397549 a(n) = Sum_{d|n} A061391(d).
%F A397549 a(n) = Sum_{d|n} tau(d^3)*tau(n/d).
%F A397549 a(n) = Sum_{d|n} 2^g(d)*tau(n/d)^2, where g(n) = A162642(n).
%F A397549 a(n) = Sum_{d|n} 3^omega(d)*tau_3(n/d), where omega = A001221.
%F A397549 a(n) = Sum_{d|n} 2^omega(d)*mu(d)^2*tau_4(n/d), where tau_4 = A007426.
%F A397549 G.f.: Sum_{k>=1} A061391(k)*x^k/(1-x^k).
%F A397549 L.g.f.: -log(Product_{k>=1} (1 - x^k)^(A061391(k)/k)).
%F A397549 From _Vaclav Kotesovec_, Jul 02 2026: (Start)
%F A397549 Let f(s) = Product_{primes p} (1 - 3/p^(2*s) + 2/p^(3*s)).
%F A397549 Dirichlet g.f.: zeta(s)^6 * f(s).
%F A397549 Sum_{k=1..n} a(k) ~ f(1)*n*log(n)^5/120 + ((6*gamma - 1)*f(1) + f'(1))*n*log(n)^4/24 + (2*f(1)*(1 - 6*gamma + 15*gamma^2 - 6*sg1) + 2*(6*gamma - 1)*f'(1) + f''(1))*n*log(n)^3/12 + O(n*log(n)^2), where
%F A397549 f(1) = A065473 = Product_{p prime} (1 - 3/p^2 + 2/p^3) = 0.2867474284344787341078927127898384464343318440970569956414778593366522431319...
%F A397549 f'(1) = f(1) * Sum_{p prime} 6*(p-1)*log(p)/p^3 = f(1) * 2.0540013229488842401079381321468900308805217888946737533671766656726701315148...
%F A397549 f''(1) = f'(1)^2/f(1) + f(1) * Sum_{prime p} 6*(3-2*p)*log(p)^2 / p^3 = f'(1)^2/f(1) + f(1) * (-6.199523741636096654183407082028743443824858040525288708433229810703317110...),
%F A397549 gamma is the Euler-Mascheroni constant A001620 and sg1 is the first Stieltjes constant (see A082633). (End)
%p A397549 with(numtheory): seq(tau(n)*add(tau(d), d in divisors(n)), n=1..100);
%t A397549 f[p_, e_] := (e+1)^2*(e+2)/2; a[1] = 1; a[n_] := Times @@ f @@@ FactorInteger[n]; Array[a, 100] (* _Amiram Eldar_, Jun 30 2026 *)
%t A397549 (* Alternative: *)
%t A397549 Table[DivisorSigma[0, n] * Sum[DivisorSigma[0, d], {d, Divisors[n]}], {n, 1, 100}] (* _Vaclav Kotesovec_, Jul 02 2026 *)
%o A397549 (PARI) a(n) = my(f=factor(n)); for (i=1, #f~, f[i,1]=(f[i,2]+1)^2*(f[i,2]+2)/2; f[i,2]=1); factorback(f); \\ _Michel Marcus_, Jul 02 2026
%Y A397549 Cf. A007425, A007426, A062367, A062368, A397645, A397686.
%Y A397549 Cf. A000005, A001221, A008966, A035116, A048785, A061391.
%Y A397549 Cf. A331077, A162642, A055076, A074816, A074823, A002411.
%K A397549 nonn,easy,mult,new
%O A397549 1,2
%A A397549 _Ridouane Oudra_, Jun 30 2026
