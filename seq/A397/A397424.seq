%S A397424 0,1,2,1,2,3,2,1,6,1,2,5,2,13,10,1,2,3,2,1,10,17,2,1,18,19,25,5,2,9,2,
%T A397424 1,10,23,20,9,2,25,10,33,2,9,2,37,42,29,2,33,17,9,10,13,2,3,45,33,10,
%U A397424 35,2,25,2,37,12,1,34,15,2,9,10,69,2,9,2,43,30
%N A397424 a(n) = A074854(n) mod n.
%F A397424 a(p) = 2 for prime p > 2.
%F A397424 a(2^n) = 1.
%e A397424 For n = 1: a(1) = Sum_{d|1} (2^(1-d)) (mod 1) = 2^0 (mod 1) = 0.
%e A397424 For n = 4: a(4) = Sum_{d|4} (2^(4-d)) (mod 4) = (2^3 + 2^2 + 2^0) (mod 4) = 1.
%t A397424 a[n_]:=Mod[Sum[2^(n - d),{d,Divisors[n]}],n]; Array[a,75] (* _Stefano Spezia_, Jun 24 2026 *)
%o A397424 (PARI) a(n) = my(m = Mod(2, n)); lift(sumdiv(n, d, m^(n - d))); \\ _Amiram Eldar_, Jun 24 2026
%o A397424 (Python)
%o A397424 from sympy import divisors
%o A397424 def A397424(n): return sum(pow(2,n-d,n) for d in divisors(n,generator=True))%n # _Chai Wah Wu_, Jun 27 2026
%Y A397424 Cf. A000040 (primes), A000079 (2^n), A074854.
