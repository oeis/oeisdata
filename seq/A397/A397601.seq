%p A397601 T := proc(n, k) option remember; if n = k then simplify((-1)^n*hypergeom([-n, 1/2], [2], 4)) else T(n, k+1) + T(n-1, k) fi end: seq(print([n], seq(T(n, k), k = 0..n)), n = 0..10);
%o A397601 (Python)
%o A397601 def row_gen():
%o A397601     a, b, n, m = 1, 0, 0, 1
%o A397601     row = []
%o A397601     while True:
%o A397601         row.append(m)
%o A397601         for k in range(n, 0, -1):
%o A397601             row[k - 1] += row[k]
%o A397601         yield row[:]
%o A397601         m = n * (2 * b + 3 * a) // (n + 2)
%o A397601         a, b = (a, b) if n == 0 else (b, m)
%o A397601         n += 1
%o A397601 A397601_row = row_gen()
%o A397601 for _ in range(10): print(next(A397601_row))
%Y A397601 Cf. A005043 (main diagonal), A000108 (column 1), A106640 (row sums), A220097 (central terms), A059346 (row reversed), A397604, A396585.
