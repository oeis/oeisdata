%U A397282 1009678394601676800,24351043061689344000,1840959876590714880000,55521177659283835699200,4265926777156289236992000
%N A397282 Expansion of e.g.f. (1/x) * Series_Reversion( x + log(1-x^3) ).
%F A397282 E.g.f. A(x) satisfies A(x) = 1 - log(1 - (x * A(x))^3)/x.
%F A397282 a(n) = (1/(n+1)) * Sum_{k=ceiling(n/3)..floor(n/2)} (3*k)!/k! * |Stirling1(k,3*k-n)|.
%F A397282 a(n) ~ s^(3/2) * n^(n-1) / (sqrt(1 - r^2*s^2) * exp(n) * r^(n-1)), where r = log(3/(4*cos(Pi/9)^2)) + 1/(2*cos(Pi/9)) = 0.3688117265019738592374707829947052754248977432167... and s = 1/(1 + 2*cos(Pi/9)*log(3/(4*cos(Pi/9)^2))) = 1.442711410736850204679427036492559444698447763659... are the roots of the system of equations log(3*r^2*s^2) = r*(1-s), 3*r^2*s^2 = 1 - r^3*s^3. - _Vaclav Kotesovec_, Jun 20 2026
%t A397282 Table[1/(n+1) * Sum[(3*k)!/k! * Abs[StirlingS1[k,3*k-n]], {k,Ceiling[n/3],Floor[n/2]}], {n,0,20}] (* _Vaclav Kotesovec_, Jun 20 2026 *)
%o A397282 (PARI) my(N=30, x='x+O('x^N)); Vec(serlaplace(serreverse(x+log(1-x^3))/x))
%Y A397282 Cf. A213641, A397283.
%K A397282 nonn,new
%O A397282 0,3
%A A397282 _Seiichi Manyama_, Jun 20 2026
