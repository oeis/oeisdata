%S A397108 0,1,3,6,12,17,27,34,48,57,75,86,108,121,147,162,192,209,243,262,300,
%T A397108 321,363,386,432,457,507,534,588,617,675,706,768,801,867,902,972,1009,
%U A397108 1083,1122,1200,1241,1323,1366,1452,1497,1587,1634,1728,1777,1875,1926,2028,2081,2187,2242,2352,2409,2523,2582,2700
%N A397108 Lower (2,1) midsequence of (floor[n/2]^2) and (ceiling[n/2]^2); see Comments.
%C A397108 Suppose that s = (s(n)) and t = (t(n)) are sequences of numbers and h > 0 and k > 0. The lower (h, k)-midsequence of s and t is floor(h*s + k*t); the upper (h, k)-midsequence of s and t is ceiling(h*s + k*t). The upper (1,2) midsequence of (floor[n/2]^2) and (ceiling[n/2]^2) is identical to this lower sequence.
%H A397108 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (1,2,-2,-1,1).
%F A397108 a(n) = a(n-1) + 2 a(n-2) - 2 a(n-3) - a(n-4) + a(n-5), with (a(0),...,a(4)) = (0, 1, 3, 6, 12).
%F A397108 G.f.: -x*(1 + 2*x + x^2 + 2*x^3)/((-1 + x)^3*(1 + x)^2).
%F A397108 a(n)-a(n-1) = A043547(n-1). - _R. J. Mathar_, Jun 30 2026
%t A397108 z = 60;
%t A397108 f[n_] := Floor[n/2]^2; g[n_] := Ceiling[n/2]^2;
%t A397108 r = 2; s = 1; u[n_] := Floor[r*f[n] + s*g[n]];
%t A397108 Table[u[n], {n, 0, z}]
%t A397108 (* Also *)
%t A397108 LinearRecurrence[{1, 2, -2, -1, 1}, {0, 1, 3, 9, 12}, 30]
%Y A397108 Cf. A389123, A396811, A396834, A397107, A397109.
%K A397108 nonn,easy,changed
%O A397108 0,3
