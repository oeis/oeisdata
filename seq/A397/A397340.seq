%t A397340 Block[{c, i, j, k, m, w, nn},
%t A397340   nn = 120; c[_] := False; c[1] = True; i = j = 1;
%t A397340   Reap[Do[
%t A397340     w = GCD[i, j]; m = j/w; k = m;
%t A397340     While[Or[c[k], PrimeQ[k], ! SquareFreeQ[k], ! CoprimeQ[w, k] ], k += m];
%t A397340     Sow[k]; Set[{c[k], i, j}, {True, j, k}],
%t A397340   {n, nn}] ][[-1, 1]] ]
