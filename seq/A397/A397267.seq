%I A397267 #7 Jun 24 2026 17:06:11
%S A397267 0,1,2,2,6,6,9,14,17,17,29,29,34,43,50,50,68,68,77,90,99,99,125,125,
%T A397267 136,153,166,166,198,198,213,234,249,249,289,289,306,331,350,350,396,
%U A397267 396,417,446,467,467,521,521,544,577,602,602,662,662,689,726,753,753,821,821,850
%N A397267 Upper (1/2,1) midsequence of (floor[n/2]^2) and (ceiling[n/3]^2); see Comments.
%C A397267 Suppose that s = (s(n)) and t = (t(n)) are sequences of numbers and h > 0 and k > 0. The lower (h, k)-midsequence of s and t is floor(h*s + k*t); the upper (h, k)-midsequence of s and t is ceiling(h*s + k*t).
%H A397267 Index entries for linear recurrences with constant coefficients, signature (-1,0,2,3,1,-1,-3,-2,0,1,1).
%F A397267 a(n) = - a(n-1) + 2 a(n-3) + 3 a(n-4) +  a(n-5) - a(n-6) - 3 a(n-7) - 2 a(n-8) + a(n-10) + a(n-11), with (a(0),...,a(11)) = (0, 1, 1, 1, 6, 6, 8, 13, 17, 17, 28).
%t A397267 z = 60;
%t A397267 f[n_] := Floor[n/2]^2; g[n_] := Ceiling[n/3]^2;
%t A397267 r = 1/2; s = 1;
%t A397267 u[n_] := Floor[r*f[n] + s*g[n]]; v[n_] := Ceiling[r*f[n] + s*g[n]]
%t A397267 Table[v[n], {n, 0, z}]
%t A397267 (* Alternative: *)
%t A397267 LinearRecurrence[{-1, 0, 2, 3, 1, -1, -3, -2, 0, 1, 1}, {0, 1, 2, 2, 6, 6, 9, 14, 17, 17, 29}, 30]
%Y A397267 Cf. A389123, A397110, A397266.
%K A397267 nonn,easy,new
%O A397267 0,3
