%I A397552 #31 Jul 02 2026 08:50:07
%S A397552 0,0,0,0,4,1,5,0,16,0,0,0,0,29,0,0,0,0,0,0,0,0,264,1185,0,110,420,
%T A397552 2730,0,1760,2328,308,0,0,9870,5808,16416,2233,24200,0,7938,36498,198,
%U A397552 38313,41075,85362,26274,61446,71274,8250,125818,218889,21252,270963,52360
%N A397552 a(n) = n! mod A000041(n), where A000041 is the partition function.
%C A397552 The symmetric group has p(n) conjugacy classes and order n!.
%C A397552 The next zero term after a(39), if it exists, is at index n > 2000000. See A046668.
%D A397552 A. NiShe, Commutativity and Generalizations in Finite Groups, PhD Thesis, University College Cork (2000).
%H A397552 Robert Heffernan and Des Machale, <a href="https://doi.org/10.33232/BIMS.0093.39.41">The genesis of a conjecture in number theory</a>, Irish Math. Soc. Bulletin Number 93, Summer 2024, 39-41 ISSN 0791-5578.
%e A397552 a(4) = 4! mod p(4) = 24 mod 5 = 4.
%p A397552 a:= n-> n! mod combinat:-numbpart(n):
%p A397552 seq(a(n), n=0..100);
%t A397552 a[n_] := Mod[n!, PartitionsP[n]]; Array[a, 100]
%o A397552 (Python) from sympy import factorial, npartitions
%o A397552 def a(n):
%o A397552     return factorial(n) % npartitions(n)
%o A397552 print([a(n) for n in range(1, 101)])
%Y A397552 Cf. A000041, A000142, A046668, A192885.
%K A397552 nonn,easy,new
%O A397552 0,5
