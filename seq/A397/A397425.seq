%I A397425 #12 Jul 03 2026 20:01:49
%S A397425 3,13,7,23,17,181,43,37,241,11,53,47,421,41,31,73,67,631,71,61,401,83,
%T A397425 97,691,101,131,491,523,103,107,811,191,151,701,683,13,113,127,1021,
%U A397425 211,251,761,743,43,7,163,137,1051,281,271,911,983,103,37,47,173,157,1171,311,331,1381,1163,113,67
%N A397425 Array, listed by falling antidiagonals: row n consists of the primes p such that A091633(n) is the concatenation of the last digits of consecutive primes starting with p.
%C A397425 If m = A091633(n) is the n-th prime whose digits are all in {1,3,7,9} and has d digits, then A(n,k) is the k-th prime p = prime(r) such that the digits of m are A007652(r) to A007652(r+d-1), the last digits of the d consecutive primes beginning with p.
%H A397425 Robert Israel, <a href="/A397425/b397425.txt">Table of n, a(n) for n = 1..10011</a> (first 141 antidiagonals)
%e A397425 Array begins
%e A397425    3   13   23   43    53    73    83   103 ...
%e A397425    7   17   37   47    67    97   107   127 ...
%e A397425  181  241  421  631   691   811  1021  1051 ...
%e A397425   11   41   71  101   191   211   281   311 ...
%e A397425   31   61  131  151   251   271   331   541 ...
%e A397425  401  491  701  761   911  1381  1571  2161 ...
%e A397425  523  683  743  983  1163  1193  1373  1523 ...
%e A397425   13   43  103  113   163   193   223   293 ...
%e A397425 A[5,4] = 151 is a term because A091633(5) = 17 and the two consecutive primes starting with 151 are 151 and 157, whose last digits are 1 and 7 respectively.
%p A397425 S[0]:= [0]:
%p A397425 for i from 1 to 3 do
%p A397425   S[i]:= map(s -> (10*s+1, 10*s+3, 10*s+7, 10*s+9), S[i-1]);
%p A397425   P[i]:= select(isprime, S[i])
%p A397425 od:
%p A397425 PP:= map(op, [seq(P[i], i=1..3)]): nPP:= nops(PP):
%p A397425 A:= Matrix(nPP,10): counts:= Vector(nPP):tcount:= 0:
%p A397425 Q:= [0$2,2]: target:= 10*nPP:
%p A397425 while tcount < target do
%p A397425   Q:= [op(Q[2..-1]), nextprime(Q[-1])];
%p A397425   for k from 1 to 3 do
%p A397425     q:= add((Q[3-k+i] mod 10)*10^(k-i), i=1..k);
%p A397425     j:= ListTools:-BinarySearch(PP, q);
%p A397425     if j <> 0 and counts[j]<10 then
%p A397425       counts[j]:= counts[j]+1; A[j,counts[j]]:= Q[4-k]; tcount:= tcount+1 fi
%p A397425   od:
%p A397425 od:
%p A397425 A;
%Y A397425 Cf. A007962, A091633, A397072, A397073, A397344.
%K A397425 nonn,base,tabl,new
%O A397425 1,1
