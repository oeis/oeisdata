%I A397242 #23 Jun 27 2026 16:30:25
%S A397242 1,1,2,15,244,6420,242388,12324865,810684392,67006108512,
%T A397242 6803416119620,832987194339102,121085005294993752,
%U A397242 20621650951816841784,4067949993992310915720,920310487969205847989925,236712838139758271370227152,68691669611602570130840047368,22336711628862870570627842359140
%N A397242 O.g.f. satisfies A(x) = exp( x + Sum_{n>=2} (n^2-1) * a(n)*x^n / n^2 ).
%C A397242 Conjecture: a(n) is odd iff n+1 is a power of 2.
%C A397242 Conjecture: for n > 0, a(n) == 1 (mod 3) iff n+2 is of the form 3^k or 2*3^k.
%C A397242 Conjecture: for n > 0, a(n) == 2 (mod 3) iff n+2 is a sum of 2 distinct powers of 3 (A038464).
%C A397242 The limit lim_{n->oo} a(n)/n!^2 appears to be finite and nonzero. At n = 1000, a(1000)/1000!^2 = 0.57681544970...
%C A397242 This constant is equal to 0.5773928444790959583518657851093628462973104143119... - _Vaclav Kotesovec_, Jun 19 2026
%H A397242 Paul D. Hanna, <a href="/A397242/b397242.txt">Table of n, a(n) for n = 0..500</a>
%F A397242 G.f. A(x) = Sum_{n>=0} a(n)*x^n satisfies the following formulas.
%F A397242 (1) A(x) = exp( A(x) - 1 - Sum_{n>=2} a(n)*x^n / n^2 ).
%F A397242 (2) A(x) = B(x*A(x)) where B(x) = A(x/B(x)) is the g.f. of A397241 which satisfies n*[x^n] B(x)^n = (n-1)*[x^n] B(x)^(n+1) for n > 1.
%F A397242 (3) A'(x) = A(x) * (1 + Sum_{n>=1} n*(n+2)/(n+1) * a(n+1) * x^n ).
%F A397242 (4) a(n) = n^2/(n^2-1) * [x^n] log(A(x)) for n > 1.
%F A397242 (5) a(n) = n*A397243(n)/(n^2-1) for n > 1, where A397243 is the logarithmic derivative of this sequence.
%F A397242 (6) a(n) = n*a(n-1) + n*Sum_{k=1..n-2} k*(k+2)/(k+1) * a(k+1)*a(n-k-1) for n > 1, with a(0) = a(1) = 1.
%F A397242 (7) A(x) = 1+x + x*(A(x)-1)*(A'(x) + x*A''(x))/A(x) + x^2*A'(x)^2/A(x)^2. - _Paul D. Hanna_, Jun 26 2026
%e A397242 G.f.: A(x) = 1 + x + 2*x^2 + 15*x^3 + 244*x^4 + 6420*x^5 + 242388*x^6 + 12324865*x^7 + 810684392*x^8 + 67006108512*x^9 + ...
%e A397242 where
%e A397242 A(x) = exp( x + 3*2*x^2/2^2 + 8*15*x^3/3^2 + 15*244*x^4/4^2 + 24*6420*x^5/5^2 + 35*242388*x^6/6^2 + 48*12324865*x^7/7^2 + ... + (n^2-1)*a(n)*x^n/n^2 + ... ).
%e A397242 RELATED SERIES.
%e A397242 The logarithm of the g.f. A(x) begins
%e A397242 log(A(x)) = x + 3*x^2/2 + 40*x^3/3 + 915*x^4/4 + 30816*x^5/5 + 1413930*x^6/6 + 84513360*x^7/7 + ... + A397243(n)*x^n/n + ...
%e A397242 where A397243(n) = (n^2-1)*a(n)/n for n > 1.
%e A397242 The logarithmic derivative equals the sum given by
%e A397242 A'(x)/A(x) = 1 + (1*3/2)*a(2)*x + (2*4/3)*a(3)*x^2 + (3*5/4)*a(4)*x^3 + (4*6/5)*a(5)*x^4 + ... + n*(n+2)/(n+1) * a(n+1)*x^n + ...
%e A397242 Let B(x) be the g.f. of A397241, which begins
%e A397242 B(x) = 1 + x + x^2 + 11*x^3 + 191*x^4 + 5279*x^5 + 205739*x^6 + 10703027*x^7 + 716263967*x^8 + ... + A397241(n)*x^n + ...
%e A397242 then A(x) = B(x*A(x)) and B(x) = A(x/B(x)).
%e A397242 The terms a(n) are divisible by n for n > 0:
%e A397242 a(n)/n = [1, 1, 5, 61, 1284, 40398, 1760695, 101335549, ...].
%o A397242 (PARI) \\ by a(n) = n^2/(n^2-1) * [x^n] log(A)  for n > 1:
%o A397242 {a(n) = my(V=[1,1],A,m); for(i=2,n, V=concat(V,0); A = Ser(V); m = #V-1;
%o A397242 V[#V] = (m^2-1)*polcoef(A,m) - m^2*polcoef(log(A),m) ); GF=Ser(V); V[n+1]}
%o A397242 \\ returns a vector of terms a(k) for k = 0..n
%o A397242 {upto(n) = a(n); Vec(GF)}
%o A397242 upto(20)
%o A397242 (PARI) \\ by recurrence (slower)
%o A397242 \\ print terms a(n) for n = 0..N
%o A397242 N = 20; A = vector(N+1);
%o A397242 {a(n) = A[n+1] = if(n<=1, 1, n*A[n] + n*sum(k=1,n-2, k*(k+2)/(k+1) * a(k+1) * A[n-k]) )}
%o A397242 for(n=0, N, print1(a(n), ", "))
%Y A397242 Cf. A397241, A397243.
%K A397242 nonn,new
%O A397242 0,3
%A A397242 _Paul D. Hanna_, Jun 19 2026
