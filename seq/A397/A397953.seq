%I A397953 #22 Jul 18 2026 08:50:45
%S A397953 0,1,2,4,6,8,12,18,24,36,56,72,110,170,330,510
%N A397953 Polydivisible numbers in base 3.
%C A397953 A number k is polydivisible in base b if, for all 1 <= i <= d, floor(k/b^(d-i)) is divisible by i, where d is the number of digits of k in base b.
%H A397953 Wikipedia, <a href="https://en.wikipedia.org/wiki/Polydivisible_number">Polydivisible number</a>.
%F A397953 a(A271374(3)) = A109032(3).
%e A397953 510 is a term because 510_10 = 200220_3 and all of the following conditions are true:
%e A397953   2_3      =   2_10 is divisible by 1;
%e A397953   20_3     =   6_10 is divisible by 2;
%e A397953   200_3    =  18_10 is divisible by 3;
%e A397953   2002_3   =  56_10 is divisible by 4;
%e A397953   20022_3  = 170_10 is divisible by 5;
%e A397953   200220_3 = 510_10 is divisible by 6.
%t A397953 polyDivQ[k_, b_:3] := k < b || (Divisible[k, IntegerLength[k, b]] && polyDivQ[Quotient[k, b], b]);
%t A397953 Select[Range[0, 510], polyDivQ] (* Gives the full sequence *)
%t A397953 (* Alternative: *)
%t A397953 (* polyDivFullList is defined at A144688 *)
%t A397953 polyDivFullList[3]
%o A397953 (Python)
%o A397953 def polydiv(base=3): # generator of terms
%o A397953     yield 0
%o A397953     magic, biggermagic, digits = list(range(1, base)), [], 2
%o A397953     while len(magic) > 0:
%o A397953         yield from magic
%o A397953         for i in magic:
%o A397953             for d in range(base):
%o A397953                 t = base*i + d
%o A397953                 if t%digits == 0:
%o A397953                     biggermagic.append(t)
%o A397953         magic, biggermagic, digits = biggermagic, [], digits+1
%o A397953 print([an for an in polydiv()]) # _Michael S. Branicky_, Jul 16 2026
%Y A397953 Cf. polydivisible numbers in other bases b: A397954 (b = 4), A397955 (b = 5), A397956 (b = 6), A397957 (b = 7), A397958 (b = 8), A397959 (b = 9), A144688 (b = 10).
%Y A397953 Cf. A109032, A271373, A271374.
%K A397953 nonn,base,easy,fini,full,new
%O A397953 1,3
%A A397953 _Paolo Xausa_, Jul 16 2026
