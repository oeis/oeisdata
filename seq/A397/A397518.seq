%S A397518 2,0,0,2,2,4,0,0,0,0,0,4,2,0,4,0,0,0,4,0,0,4,0,0,2,0,4,0,0,0,0,2,0,4,
%T A397518 0,4,0,0,4,4,2,0,0,0,0,0,0,0,0,4,0,0,0,4,4,0,4,0,0,0,6,0,0,4,0,0,0,0,
%U A397518 4,0,0,0,0,0,4,4,0,0,0,0,4,4,0,0,2,0,0,2,0,4,0,0,0,0,0,4,4,0,4,0
%N A397518 a(n) is the number of integer solutions of x^2 + 7*y^2 = 2*n + 1.
%H A397518 J. V. Uspensky and M. A. Heaslet, Elementary Number Theory, McGraw-Hill, NY, 1939, Exercise n. 5 at p. 346.
%F A397518 a(n) = 2*Sum_{d | 2*n+1} JacobiSymbol(-7,d) (see Uspensky and Heaslet).
%e A397518 a(0) = 2 since 2*0 + 1 = 1  equals 1^2 + 7*0^2 and (-1)^2 + 7*0^2;
%e A397518 a(3) = 2 since 2*3 + 1 = 7 equals 0^2 + 7*1^2 and 0^2 + 7*(-1)^2;
%e A397518 a(5) = 4 since 2*5 + 1 = 11 equals 2^2 + 7*1^2, (-2)^2 + 7*1^2, 2^2 + 7*(-1)^2, and (-2)^2 + 7*(-1)^2.
%t A397518 a[n_]:=2*Sum[JacobiSymbol[-7,d],{d,Divisors[2n+1]}]; Array[a,100,0]
%Y A397518 Cf. A005881, A274658.
%K A397518 nonn,new
%O A397518 0,1
%A A397518 _Stefano Spezia_, Jun 29 2026
