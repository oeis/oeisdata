%I A397841 #14 Jul 21 2026 19:55:23
%S A397841 1769877,570363636,572956716,3564772725,3580979475
%N A397841 Numbers k such that sigma(k) = psi(k) + tau(k)^6 + omega(k)^6.
%C A397841 From _David A. Corneth_, Jul 12 2026: (Start)
%C A397841 The sequence is infinite as it contains 3 * 193 * 246271 * p^2 where gcd(p, 3 * 193 * 246271) = 1 and p prime.
%C A397841 It also contains 3 * 1663 * 28711 * p^2 where gcd(p, 3 * 1663 * 28711) = 1 and p prime. (End)
%e A397841 1769877 is a term since sigma(1769877) = 2622080 = 2359872 + 8^6 + 2^6 = psi(1769877) + tau(1769877)^6 + omega(1769877)^6.
%o A397841 (PARI) isok(k) = {my(f = factor(k)); sigma(f) == prod(i=1, #f~, (f[i, 1]+1) * f[i, 1]^(f[i, 2]-1)) + numdiv(f)^6 + omega(f)^6; } \\ _Amiram Eldar_, Jul 12 2026
%o A397841 (Python)
%o A397841 from math import prod
%o A397841 from sympy import factorint
%o A397841 def ok(n):
%o A397841     f = factorint(n)
%o A397841     sigma = prod((p**(e+1)-1)//(p-1) for p, e in f.items())
%o A397841     omega = len(f)
%o A397841     tau = prod((e+1) for p, e in f.items())
%o A397841     psi = prod((p+1)*p**(e-1) for p, e in f.items())
%o A397841     return sigma == psi + tau**6 + omega**6
%o A397841 # _Michael S. Branicky_, Jul 16 2026
%Y A397841 Cf. A000203 (sigma), A001615 (psi), A000005 (tau), A001221 (omega), A392384.
%K A397841 nonn,hard,more,new
%O A397841 1,1
%A A397841 _S. I. Dimitrov_, Jul 12 2026
%E A397841 a(4)-a(5) from _Amiram Eldar_, Jul 12 2026
