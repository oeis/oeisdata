%T A397097 7,5,6,3,6,9,9,0,9,4,7,2,2,5,1,5,6,3,6,2,9,5,6,1,5,3,9,8,3,1,8,1,7,6,
%U A397097 3,6,3,4,9,0,3,1,8,2,3,0,8,5,9,3,9,8,5,2,2,9,3,3,9,5,9,3,9,5,5,1,9,6,9,6,4
%N A397097 Decimal expansion of Sum_{n>=2} (n*log(n) - (n-1)*log(n-1))/(n^2-1).
%C A397097 This is the analog of the constant A396759, where the summation runs over all integers n >= 2 instead of only over the primes.
%C A397097 The summand (n*log(n) - (n-1)*log(n-1))/(n^2-1) is the same closed form that appears (restricted to primes) in the totient-entropy constant A396759.
%F A397097 Equals Sum_{n>=2} (n*log(n) - (n-1)*log(n-1))/(n^2-1).
%e A397097 1.6249211848027444626782297460495837563699094722515636295615398318176363490318...
%t A397097 digits = 60; (NSum[(n*Log[n] - (n - 1)*Log[n - 1])/(n^2 - 1), {n, 2, Infinity}, WorkingPrecision -> digits + 20, NSumTerms -> 1000] // RealDigits[#, 10, digits] &)[[1]]
%o A397097 (PARI) default(realprecision, 200); sumpos(n=2, (n*log(n)-(n-1)*log(n-1))/(n^2-1))
%Y A397097 Cf. A396759 (analogous sum over primes only).
%K A397097 nonn,cons,new
%O A397097 1,2
%A A397097 _Vaclav Kotesovec_ and _Vladimir Khomyakov_, Jun 16 2026
