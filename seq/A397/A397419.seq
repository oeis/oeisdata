%T A397419 710137300,5750979288,47224773405,392536909320,3298058212320,
%U A397419 27976268700480,239354631743268,2063696517194016,17917829988706056,156562239801890352,1375981317571505910,12157754181729121176
%N A397419 a(n) = Sum_{j=0..n} binomial(n, j) * A005043(j)^2.
%F A397419 a(n) = A397603(n, 0).
%F A397419 a(n) ~ 2^(n-3) * 5^(n+3) / (27*Pi*n^3). - _Vaclav Kotesovec_, Jul 05 2026
%p A397419 a := n -> local j; add(binomial(n, j) * simplify(hypergeom([-j, 1/2], [2], 4))^2, j = 0..n): seq(a(n), n = 0..24);
%o A397419 (Python)
%o A397419 def gen():
%o A397419     a, b, n, m = 1, 0, 0, 1
%o A397419     row = []
%o A397419     while True:
%o A397419         row.append(m * m)
%o A397419         for k in range(n, 0, -1): row[k - 1] += row[k]
%o A397419         yield row[0]
%o A397419         m = n * (2 * b + 3 * a) // (n + 2)
%o A397419         a, b = (a, b) if n == 0 else (b, m)
%o A397419         n += 1
%o A397419 A397419 = gen()
%o A397419 print([next(A397419) for _ in range(25)])
%Y A397419 Cf. A005043, A397603.
%K A397419 nonn,new
%O A397419 0,3
%A A397419 _Peter Luschny_, Jul 02 2026
