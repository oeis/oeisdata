%T A397833 156647,325616,674436,1392570,2867433,5889840,12071527,24692662,
%U A397833 50420348,102789856,209250377,425413364,863844579,1752204420,3550576068,7188094422,14539918861,29388174664,59357010539
%N A397833 Number of binary words of length n containing the consecutive word abab.
%H A397833 Wikipedia, <a href="https://en.wikipedia.org/wiki/Autocorrelation_%28words%29">Autocorrelation (words)</a>
%H A397833 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (4,-5,4,-5,2).
%F A397833 G.f.: x^4/((1-2*x) * (x^4 + (1-2*x) * (1+x^2))). Equivalently, 1/(1-2*x) - (1+x^2)/(x^4 + (1-2*x) * (1+x^2)).
%F A397833 a(n) = 4*a(n-1) - 5*a(n-2) + 4*a(n-3) - 5*a(n-4) + 2*a(n-5).
%F A397833 a(n) = 2^n - A118870(n).
%e A397833 a(5) = 4: the words are aabab, ababa, ababb, babab.
%o A397833 (PARI) my(N=40, x='x+O('x^N)); concat([0, 0, 0, 0], Vec(x^4/((1-2*x)*(x^4+(1-2*x)*(1+x^2)))))
%Y A397833 Cf. A000079, A118870, A397834, A397835.
%K A397833 nonn,easy,new
%O A397833 0,6
