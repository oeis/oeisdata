%T A397645 26,64,60,208,8,512,8,196,64,64,64,676,8,64,64,480,8,512,8,208,208,64,
%U A397645 8,920,26,208,64,208,8,480,64,480,64,64,8,1664,8,64,208,308,64,512,8,208,64,512,8,1560
%N A397645 Multiplicative with a(p^e) = (e+1)*(e+2)*(5*e+3)/6.
%C A397645 Inverse Mobius transform of A358380.
%C A397645 Second inverse Mobius transform of A344328.
%C A397645 Third inverse Mobius transform of A082476.
%C A397645 Dirichlet convolution of A000005 and A344328.
%C A397645 Dirichlet convolution of A082476 and A007425.
%C A397645 Dirichlet convolution of A351521 and A007426.
%H A397645 Ridouane Oudra, <a href="/A397645/b397645.txt">Table of n, a(n) for n = 1..10000</a>
%F A397645 a(n) = Sum_{d|n} A358380(d).
%F A397645 a(n) = Sum_{d|n} tau(d^5)*tau(n/d).
%F A397645 a(n) = Sum_{d|n} 4^g(d)*tau(n/d)^2, where g(n) = A162642(n).
%F A397645 a(n) = Sum_{d|n} 5^omega(d)*tau_3(n/d), where omega = A001221 and tau_3 = A007425.
%F A397645 a(n) = Sum_{d|n} 4^omega(d)*mu(d)^2*tau_4(n/d), where tau_4 = A007426.
%F A397645 G.f.: Sum_{k>=1} A358380(k)*x^k/(1-x^k).
%F A397645 L.g.f.: -log(Product_{k>=1} (1 - x^k)^(A358380(k)/k)).
%F A397645 Dirichlet g.f.: zeta(s)^4 * Product_{primes p} (1 + 4*p^(-s)).
%p A397645 seq(mul((m[2]+1)*(m[2]+2)*(5*m[2]+3)/6, m in ifactors(n)[2]), n=1..120);
%t A397645 f[p_, e_] := (e+1)*(e+2)*(5*e+3)/6; a[1] = 1; a[n_] := Times @@ f @@@ FactorInteger[n]; Array[a, 100] (* _Amiram Eldar_, Jul 04 2026 *)
