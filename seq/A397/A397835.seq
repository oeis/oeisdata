%S A397835 0,0,0,0,0,0,1,6,27,107,399,1431,4995,17088,57564,191566,631245,
%T A397835 2063151,6697025,21611763,69391278,221823603,706365597,2241617814,
%U A397835 7091927137,22375536327,70421481081,221135899148,692982636540,2167554598533,6768129949038,21099727981134,65682021601737,204185060237611,633943652397234
%N A397835 Number of ternary words of length n over {a,b,c} containing the consecutive word abcabc.
%H A397835 Wikipedia, <a href="https://en.wikipedia.org/wiki/Autocorrelation_%28words%29">Autocorrelation (words)</a>
%H A397835 <a href="/index/Rec#order_07">Index entries for linear recurrences with constant coefficients</a>, signature (6,-9,-1,6,-9,-1,3).
%F A397835 G.f.: x^6/((1-3*x) * (x^6 + (1-3*x) * (1+x^3))). Equivalently, 1/(1-3*x) - (1+x^3)/(x^6 + (1-3*x) * (1+x^3)).
%F A397835 a(n) = 6*a(n-1) - 9*a(n-2) - a(n-3) + 6*a(n-4) - 9*a(n-5) - a(n-6) + 3*a(n-7).
%F A397835 a(n) = 3^n - A397837(n).
%e A397835 a(7) = 6: the words are aabcabc, abcabca, abcabcb, abcabcc, babcabc, cabcabc.
%o A397835 (PARI) my(N=40, x='x+O('x^N)); concat([0, 0, 0, 0, 0, 0], Vec(x^6/((1-3*x)*(x^6+(1-3*x)*(1+x^3)))))
%Y A397835 Cf. A000244, A397833, A397837.
%K A397835 nonn,easy,new
%O A397835 0,8
%A A397835 _Seiichi Manyama_, Jul 12 2026
