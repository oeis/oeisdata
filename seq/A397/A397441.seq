%U A397441 18,36,8,54,16,32,1,56,20,40,8,66,16,32,4,72,26,52,8,78,16
%N A397441 a(n) is the number of partitions of n into parts of the form 2^r*(2^s - 1) with each r distinct.
%C A397441 Recurrence relation implies that the only odd a(n) are of the form n = 2^i for some i.
%C A397441 Number of the form 2^r*(2^s - 1) are given in A023758.
%H A397441 Katherine Anders, Melissa Dennison, Jennifer Weber Lansing, and Bruce Reznick, <a href="https://doi.org/10.1007/s00026-013-0188-3">Congruence Properties of Binary Partition Functions</a>, Annals of Combinatorics 17, 1 (2013), 15-26; <a href="https://tensen.net/research/static/logos/number-theory/partitions-restricted/reznick-stern-ch7.pdf">alternative link</a>.
%F A397441 a(2*n) = a(n), a(2*n + 1) = Sum_{i = 0..floor(log_2(n + 1))} a(n - (2^i - 1)).
%F A397441 G.f.: Product_{r>=0} (1 + Sum_{s>=1} x^(2^r*(2^s - 1))).
%e A397441 The a(7) = 4 partitions are: 7, 6 + 1, 4 + 3, 4 + 2 + 1.
%o A397441 (Python)# Returns a list of a(i) up to a specified n.
%o A397441 def lista(n):
%o A397441   partitions = []
%o A397441   for i in range(0, n + 1):
%o A397441     if i == 0:
%o A397441       partitions.append(1)
%o A397441       continue
%o A397441     if i % 2 == 0:
%o A397441       partitions.append(partitions[int(i/2)])
%o A397441       continue
%o A397441     total = 0
%o A397441     j = 0
%o A397441     while (i - 1)/2 - (2**j - 1) >= 0:
%o A397441       index = int((i - 1)/2 - (2**j - 1))
%o A397441       total += partitions[index]
%o A397441       j += 1
%o A397441     partitions.append(total)
%o A397441   return partitions
%o A397441 (PARI) seq(n) = Vec(prod(r=0, logint(n,2), 1 + sum(s=1, logint(n\2^r+1,2), x^(2^r*(2^s - 1))) + O(x*x^n))) \\ _Andrew Howroyd_, Jul 05 2026
%Y A397441 Cf. A023758.
%K A397441 nonn,new
%O A397441 0,4
