%I A397626 #13 Jul 11 2026 15:48:59
%S A397626 5,45,4275,35589375,2567439755859375,13095603841268264247894287109375,
%T A397626 344140652015198625875749693961963987661874853074550628662109375,
%U A397626 236469480456720007759495261943320224964765046289836150832791859467108586214219439493831875775953221818781457841396331787109375
%N A397626 Number of vertex clique partitions of a recursively constructed bridged dual-graph sequence starting with a triangle.
%F A397626 a(n) = a(n-1)^2 + 2*a(n-1)*a(n-2)^2, for n>=2, with a(0) = 5, a(1) = 45.
%e A397626      .
%e A397626    /   \
%e A397626   .     .
%e A397626  / \   / \
%e A397626 .___. .___.  a(1)=45.
%p A397626 a:= proc(n) option remember;
%p A397626     if n = 0 then 5
%p A397626   elif n = 1 then 45
%p A397626   else a(n-1)^2 + 2 * a(n-1) * a(n-2)^2
%p A397626     fi;
%p A397626 end proc:
%p A397626 # To print the first 5 terms (n = 0 to 4):
%p A397626 seq(a(n), n=0..4);
%t A397626 RecurrenceTable[{a[n] == a[n-1]^2 + 2*a[n-1]*a[n-2]^2, a[0] == 5, a[1] == 45}, a, {n, 0, 7}]
%o A397626 (Python)
%o A397626 def a(n):
%o A397626     if n == 0: return 5
%o A397626     if n == 1: return 45
%o A397626     # Initialize the base terms
%o A397626     z = [5, 45]
%o A397626     for i in range(2, n + 1):
%o A397626         z.append(z[-1]**2 + 2 * z[-1] * z[-2]**2)
%o A397626     return z[n]
%o A397626 print([a(n) for n in range(8)])
%K A397626 nonn,easy,new
%O A397626 0,1
