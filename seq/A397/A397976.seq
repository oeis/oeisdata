%I A397976 #8 Jul 21 2026 09:27:30
%S A397976 0,2,9,19,34,52,75,101,132,166,205,247,294,344,399,457,520,586,657,
%T A397976 731,810,892,979,1069,1164,1262,1365,1471,1582,1696,1815,1937,2064,
%U A397976 2194,2329,2467,2610,2756,2907,3061,3220,3382,3549,3719,3894,4072,4255,4441
%N A397976 Lower (1,3/2) midsequence of triangular numbers (A000217) and squares (A000290); see Comments.
%C A397976 Suppose that s = (s(n)) and t = (t(n)) are sequences of numbers and h > 0 and k > 0. The lower (h, k)-midsequence of s and t is floor(h*s + k*t); the upper (h, k)-midsequence of s and t is ceiling(h*s + k*t). See A397972 for a guide to related sequences.
%H A397976 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (2,0,-2,1).
%F A397976 a(n) = 2 a(n-1) - a(n-3) + a(n-4), with (a(0),...,a(4)) = (0, 2, 9, 19, 34).
%F A397976 G.f.: -((x (2 + 5 x + x^2))/((-1 + x)^3 (1 + x))).
%t A397976 z = 60;
%t A397976 f[n_] := (n^2 + n)/2; g[n_] := n^2; r = 1; s = 3/2;
%t A397976 u[n_] := Floor[r*f[n] + s*g[n]]; v[n_] := Ceiling[r*f[n] + s*g[n]]
%t A397976 Table[u[n], {n, 0, z}]
%Y A397976 Cf. A000217, A000290, A397977.
%K A397976 nonn,easy,new
%O A397976 0,2
%A A397976 _Clark Kimberling_, Jul 20 2026
