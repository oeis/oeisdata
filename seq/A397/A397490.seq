%T A397490 239,179,23,61,43,19,151,3,37,157,43,283,367,3,67,79,53,41,421,7,53,
%U A397490 239,37,251,191,647,1759,251,311,59,443,193,97,317,631,103,193,563,719,461,17,71,613,811,419,257
%N A397490 a(n) is the first prime p such that the concatenation in reverse order of the last digits of n consecutive primes starting with p is prime.
%H A397490 Robert Israel, <a href="/A397490/b397490.txt">Table of n, a(n) for n = 1..1000</a>
%e A397490 a(5) = 43 because the 5 consecutive primes starting with 43 are 43, 47, 53, 59, 61, the concatenation in reverse orders of their last digits is 19373 which is prime, and no prime smaller than 43 works.
%p A397490 P:= select(isprime, [2, seq(i, i=3..10^6, 2)]):
%p A397490 rcat:= proc(L) local i;
%p A397490   add((L[i] mod 10)*10^(i-1), i=1..nops(L))
%p A397490 end proc:
%p A397490 f:= proc(n) local i, j, v;
%p A397490   for i from 1 do
%p A397490     v:= rcat(P[i..i+n-1]);
%p A397490     if isprime(v) then return P[i] fi
%p A397490   od
%p A397490 end proc:
%p A397490 map(f, [$1..100]);
%t A397490 a[n_]:=Module[{p=0},Until[PrimeQ[IntegerReverse[FromDigits[Last/@IntegerDigits/@Prime[Range[p,p+n-1]]]]],p++];Prime[p]];Array[a,69] (* _James C. McMahon_, Jul 06 2026 *)
