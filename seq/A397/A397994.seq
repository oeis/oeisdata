%N A397994 E.g.f. A(x) satisfies A(-log(1-3*x)/3) = 4*A(x) - 3*x.
%F A397994 a(1) = 1; a(n+1) = Sum_{k=1..n} 3^(n-k) * |Stirling1(n+1,k)| * a(k).
%o A397994 (PARI) a_vector(n) = my(v=vector(n)); v[1]=1; for(i=1, n-1, v[i+1]=sum(j=1, i, 3^(i-j)*abs(stirling(i+1, j, 1))*v[j])); v;
