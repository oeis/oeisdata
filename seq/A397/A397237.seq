%I A397237 #15 Jun 19 2026 09:38:51
%S A397237 1,2,3,5,11,25,52,103,206,422,870,1782,3631,7400,15113,30891,63113,
%T A397237 128879,263162,537453,1097740,2242060,4579036,9351820,19099597,
%U A397237 39008270,79668895,162711793,332313975,678701189,1386146256,2830997779,5781890234,11808645298
%N A397237 Expansion of 1/(1 - 2*x + x^2 - x^3 - 2*x^4 - x^5).
%H A397237 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (2,-1,1,2,1).
%F A397237 a(n) = 2*a(n-1) - a(n-2) + a(n-3) + 2*a(n-4) + a(n-5).
%F A397237 Let Sum_{n>=0} b(n) * x^n = 1/( P(x^s) * Q(x^s)^(s-1-k) * R(x^s)^k * (Q(x^s) - x^m * R(x^s)) ), where s >= 2, m >= 1, 0 <= k <= s-1, gcd(m,s)=1, and P(0)*Q(0)*R(0) != 0. Then Sum_{n>=0} b(s*n+m*k) * x^n = 1/( P(x) * (Q(x)^s - x^m * R(x)^s) ).
%F A397237 Here s=2, m=3, k=1, P(x)=1, Q(x)=1-x, R(x)=1+x, and b(n) = A397236(n). Therefore a(n) = b(2*n+3) = A397236(2*n+3), and Sum_{n>=0} a(n) * x^n = 1/(1 - 2*x + x^2 - x^3 - 2*x^4 - x^5).
%p A397237 a:= proc(n) option remember; `if`(n<1, 1+signum(n),
%p A397237       2*a(n-1)-a(n-2)+a(n-3)+2*a(n-4)+a(n-5))
%p A397237     end:
%p A397237 seq(a(n), n=0..33);  # _Alois P. Heinz_, Jun 19 2026
%o A397237 (PARI) my(N=40, x='x+O('x^N)); Vec(1/(1-2*x+x^2-x^3-2*x^4-x^5))
%Y A397237 Cf. A397236.
%K A397237 nonn,easy
%O A397237 0,2
%A A397237 _Seiichi Manyama_, Jun 19 2026
