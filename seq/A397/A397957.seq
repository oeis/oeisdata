%N A397957 Polydivisible numbers in base 7.
%C A397957 For the definition of polydivisible number in base b, see A397953.
%H A397957 Michael S. Branicky, <a href="/A397957/b397957.txt">Table of n, a(n) for n = 1..1068</a> (full sequence)
%H A397957 Wikipedia, <a href="https://en.wikipedia.org/wiki/Polydivisible_number">Polydivisible number</a>.
%F A397957 a(A271374(7)) = A109032(7).
%e A397957 970792 is a term because 970792_10 = 11152204_7 and all of the following conditions are true:
%e A397957   1_7        =      1_10 is divisible by 1;
%e A397957   11_7       =      9_10 is divisible by 2;
%e A397957   111_7      =     57_10 is divisible by 3;
%e A397957   1115_7     =    404_10 is divisible by 4;
%e A397957   11152_7    =   2830_10 is divisible by 5;
%e A397957   111522_7   =  19812_10 is divisible by 6;
%e A397957   1115220_7  = 138684_10 is divisible by 7;
%e A397957   11152204_7 = 970792_10 is divisible by 8.
%t A397957 (* polyDivQ is defined at A397953 *)
%t A397957 Select[Range[0, 300], polyDivQ[#, 7] &]
%t A397957 (* Alternative: *)
%t A397957 (* polyDivFullList is defined at A144688 *)
%t A397957 polyDivFullList[7][[;; 70]]
%o A397957 (Python) # uses polydiv in A397953
%o A397957 print([an for an in polydiv(base=7)]) # _Michael S. Branicky_, Jul 16 2026
