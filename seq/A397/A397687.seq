%T A397687 95,30,98,31,119,29,33,27,33,111,24,95,33,96,26,1,90,1,26,95,1,103,26,
%U A397687 110,90,21,109,23,103,104,102,21,25,101,23,19,19,103,18,280
%N A397687 a(n) is the least k >= 1 such that Sum_{i = 0..n} A000005(k + i) / (n + 1) is an integer.
%H A397687 Ctibor O. Zizka, <a href="/A397687/b397687.txt">Table of n, a(n) for n = 0..1000</a>
%F A397687 a(A050226(n) - 1) = 1.
%e A397687 For n = 0: A000005(k)/1 is an integer for the least k = 1, thus a(0) = 1.
%e A397687 For n = 2: (A000005(k) + A000005(k + 1) + A000005(k + 2)) / 3 is an integer for the least k = 4, thus a(2) = 4.
%t A397687 seq[max_] := With[{d = DivisorSigma[0, Range[max]]}, TakeWhile[Table[FirstPosition[MovingAverage[d, n], _?IntegerQ][[1]], {n, 1, max}], NumberQ]]; seq[350] (* _Amiram Eldar_, Jul 05 2026 *)
%o A397687 (PARI) a(n) = my(k=1); while (denominator(sum(i=0, n, numdiv(k+i))/(n+1)) != 1, k++); k; \\ _Michel Marcus_, Jul 05 2026
%Y A397687 Cf. A000005, A050226.
