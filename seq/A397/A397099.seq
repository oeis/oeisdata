%I A397099 #8 Jun 21 2026 18:20:23
%S A397099 3,9,10,18,20,44,70,88,104,136,464,650,1888,1952,4030,5830,8384,17816,
%T A397099 18632,32128,32896,116624,130304,442365,521728,522752,1848964,5546958,
%U A397099 5546994,5547018,5547138,5547162,5547174,5547306,5547342,5547606,5547702,5547846
%N A397099 Excluding powers of 2 and perfect numbers, numbers whose abundancy is closer to 2 than any smaller number.
%C A397099 The smallest n values where a(n) is odd are 1, 2, 24, and 95166.
%C A397099 For n > 22, the smallest n values where a(n) is deficient are 95163, 95165, and 95166.
%H A397099 Hoang Nguyen, <a href="/A397099/b397099.txt">Table of n, a(n) for n = 1..10000</a>
%e A397099 3's abundancy is (1+3)/3 = 4/3, which is 2/3 away from 2.
%e A397099 9's abundancy is (1+3+9)/9 = 13/9, which is 5/9 (< 2/3) away from 2.
%e A397099 10's abundancy is (1+2+5+10)/10 = 9/5, which is 1/5 (< 5/9) away from 2.
%o A397099 (Julia)
%o A397099 using Primes
%o A397099 function a(n)
%o A397099     min = 2
%o A397099     i = 1
%o A397099     num = 0
%o A397099     while i <= n
%o A397099         num += 1
%o A397099         diff = abs(sum(divisors(num)) // num - 2)
%o A397099         if diff < min && diff != 0 && !ispow2(num)
%o A397099             min = diff
%o A397099             print("$num, ")
%o A397099             i += 1
%o A397099         end
%o A397099     end
%o A397099 end
%Y A397099 Subsequence of the union of A071927 and A228450.
%Y A397099 Cf. A171929.
%K A397099 nonn
%O A397099 1,1
%A A397099 _Hoang Nguyen_, Jun 16 2026
