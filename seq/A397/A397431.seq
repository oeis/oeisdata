%I A397431 #14 Jul 07 2026 21:35:11
%S A397431 55,77,91,143,203,275,295,323,355,395,407,415,515,517,533,535,553,559,
%T A397431 575,595,637,671,703,731,755,767,847,895,943,1037,1043,1067,1079,1081,
%U A397431 1111,1147,1157,1159,1183,1189,1243,1267,1271,1331,1333,1357,1363,1391,1411,1435,1463,1507
%N A397431 Composites in A161601 whose binary reversal is prime.
%H A397431 Vincenzo Librandi, <a href="/A397431/b397431.txt">Table of n, a(n) for n = 1..34316</a>
%t A397431 p[f_] := Module[{n = 1, c = 0}, Reap[While[c < f, With[{d = IntegerDigits[n, 2]}, With[{r = Reverse[d]}, If[d =!= r && n < FromDigits[r, 2],
%t A397431 Sow[{n, FromDigits[r, 2]}]; c++]]]; n += 2]][[2, 1]]];
%t A397431 u = Select[p[300], !PrimeQ[#[[1]]] && PrimeQ[#[[2]]] &];
%t A397431 Map[First, u]
%t A397431 (* _Peter J. C. Moses_, Jun 24 2026 *)
%Y A397431 Cf. A000040, A002808, A161601, A161603, A397429, A397430, A397432.
