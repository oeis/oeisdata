%N A397998 E.g.f. A(x) satisfies A((exp(4*x) - 1)/4) = 5*A(x) - 4*x.
%F A397998 a(1) = 1; a(n+1) = Sum_{k=1..n} 4^(n-k) * Stirling2(n+1,k) * a(k).
%o A397998 (PARI) a_vector(n) = my(v=vector(n)); v[1]=1; for(i=1, n-1, v[i+1]=sum(j=1, i, 4^(i-j)*stirling(i+1, j, 2)*v[j])); v;
