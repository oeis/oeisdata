%T A397654 2625,451,2250,1617,1134,679,1748,1431,1760,985,2024,1057,2028,1285,
%U A397654 106900,24448,2912,1387,108783,4752,3240,2005,146500,2649,3920,2047,5456,28384,6993,2509,352388,2761,287392
%N A397654 Least composite number in base n, that is an anagram of the concatenation of its distinct prime factors in base n, but presented in base 10.
%C A397654 a(n) > (n+1)^2.
%H A397654 Robert G. Wilson v, <a href="/A397654/b397654.txt">Table of n, a(n) for n = 2..136</a>
%e A397654 a(2) = 126 since 126 = 2 * 3^2 * 7 and 126_10 = 1111110_2 and {2, 3, 7}_10 = {10, 11, 111}_2;
%e A397654 a(3) = 150 since 150 = 2 * 3 * 5 and 150_10 = 12120_3 and {2, 3, 5}_10 = {2, 10, 12}_3;
%e A397654 a(10) = 735 since 735 = 3 * 5 * 7^2;
%e A397654 a(14) = 4119 since 4119 = 3 * 1373 and 4119_10 = 1703_14 and (3, 1373}_10 = {3, 701}_14; etc.
%t A397654 a[n_] := Block[{k = 4}, While[ PrimeQ[k] || Sort[ IntegerDigits[k, n]] != Sort[ Flatten[ IntegerDigits[ First /@ FactorInteger[ k], n]]], k++]; k]; Array[a, 50, 2]
%o A397654 (Python)
%o A397654 from itertools import count
%o A397654 from sympy import factorint
%o A397654 from sympy.ntheory import digits
%o A397654 def a(n): return next(k for k in count(4) if len(f:=factorint(k)) > 1 and sorted(digits(k, n)[1:]) == sorted(e for p in f for e in digits(p, n)[1:]))
%o A397654 print([a(n) for n in range(2, 52)]) # _Michael S. Branicky_, Jul 03 2026
