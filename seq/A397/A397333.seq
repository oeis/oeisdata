%I A397333 #38 Jun 24 2026 17:47:08
%S A397333 1,2,1,9,7,1,64,61,15,1,625,671,217,26,1,7776,9031,3465,565,40,1,
%T A397333 117649,144495,62401,12410,1220,57,1,2097152,2685817,1265607,289821,
%U A397333 35350,2324,77,1,43046721,56953279,28702801,7309722,1041831,85974,4046,100,1
%N A397333 Triangle read by rows: T(n, k) = P(n, k, 1) where P(n, k, x) = (1/k!) * Sum_{j=0..k}((-1)^(k - j) * binomial(k, j) * (n + x + j)^n).
%C A397333 This triangle is motivated by the fact that the defining polynomials yield, for x = 1 and k = 0, the coefficients (n + 1)^n of the tree-function A000169. That is why the polynomials may be referred to as the 'tree polynomials' and their coefficients as the 'Lambert-Abel-Newton triangle'. 'Lambert' because the tree function T(z) = -W(-z) is the analytical backbone; 'Abel' because it has the polynomial shift structure of (n + x)^n; and 'Newton' to indicate that the polynomials can be represented naturally by normalized forward differences.
%C A397333 Here we focus on the polynomials at fixed x = a = 1. For the cases -1, 0, and 1/2, see the cross references. The case a = 0 was first considered by _Werner Schulte_ in A397048. For (n + x)^n see A071207.
%H A397333 R. M. Corless, G. H. Gonnet, D. E. G. Hare, D. J. Jeffrey and D. E. Knuth, <a href="https://doi.org/10.1007/BF02124750">On the Lambert W Function</a>, Advances in Computational Mathematics (1996) Vol. 5, 329-359; <a href="https://www.uwo.ca/apmaths/faculty/jeffrey/pdfs/W-adv-cm.pdf">alternative link</a>.
%H A397333 Alan D. Sokal, <a href="https://arxiv.org/abs/1910.14519">A remark on the enumeration of rooted labeled trees</a>, arXiv:1910.14519 [math.CO], 2019 and Discrete Math. 343, 111865 (2020).
%F A397333 P(n, k, x) = (1/k!) * Delta^{x, k} (n + x)^n.
%F A397333 Representation as an exponential Riordan array R(g, f)_{n, k} = (n!/k!)*[z^n](g(z), f(z)^k).
%F A397333 R(exp(a*t(z))/(1 - t(z)); exp(t(z)) - 1), where t(z) = -W(-z) and W is Lambert's function.
%F A397333 T(n, k) = (n!/k!)*[z^n] exp(a*t(z)) * (exp(t(z)) - 1)^k / (1 - t(z)).
%F A397333 T(n, k) = T(n - 1, k - 1) + (n + 2 * k + 1) * T(n - 1, k) + (n + k + 1) * (k + 1) * T(n - 1, k + 1) for 0 <= k < n, and T(n, n) = 1.
%F A397333 T(n, k) = [x^k] b_a(n, n) where b_a(n, k) = (k + a)*b_a(n-1, k) + x*b_a(n-1, k+1) if n > 0 and b_a(0, k) = 1. Here a = 1; for a = 0 this is a formula of _Alois P. Heinz_ in A397048.
%F A397333 Sum_{k=0..n} T(n, k) = A397332(n) = A395288(n + 1) / (n + 1).
%F A397333 Sum_{k=0..n} (k+1) * T(n,k) = A124824(n+1). - _Alois P. Heinz_, Jun 24 2026
%e A397333 The triangle of the polynomials starts:
%e A397333   0:  1;
%e A397333   1:  1 + x    , 1;
%e A397333   2: (2 + x)^2 , 5 + 2*x                      , 1;
%e A397333   3: (3 + x)^3 , 37 + 21*x + 3*x^2            , 3*(4 + x)          , 1;
%e A397333   4: (4 + x)^4 , 369 + 244*x + 54*x^2 + 4*x^3 , 151 + 60*x + 6*x^2 , 22 + 4*x, 1;
%e A397333 See the SageMath function 'P_row' below that computes the polynomials via forward differences. The polynomials evaluated at x = -1, 0, 1/2, 1 are A397331, A397048, A397329 (normalized), and this sequence, respectively.
%e A397333 The triangle of the values at x = 1 begins:
%e A397333   0:        1;
%e A397333   1:        2,         1;
%e A397333   2:        9,         7,         1;
%e A397333   3:       64,        61,        15,       1;
%e A397333   4:      625,       671,       217,      26,       1;
%e A397333   5:     7776,      9031,      3465,     565,      40,     1;
%e A397333   6:   117649,    144495,     62401,   12410,    1220,    57,    1;
%e A397333   7:  2097152,   2685817,   1265607,  289821,   35350,  2324,   77,    1;
%e A397333   8: 43046721,  56953279,  28702801, 7309722, 1041831, 85974, 4046,  100,  1;
%p A397333 T := proc(n, k) option remember; if n = k then return 1 fi; if k < 0 or k > n then return 0 fi; T(n - 1, k - 1) + (n + 2 * k + 1) * T(n - 1, k) + (n + k + 1) * (k + 1) * T(n - 1, k + 1) end:
%p A397333 # Alternative:
%p A397333 f := proc(a, n, k) local t, m; t := add(m^(m-1) * z^m/m!, m = 1..n); (n!/k!) * coeff( series( exp(a*t) / (1 - t) * (exp(t) - 1)^k, z, n + 1), z, n) end: seq(seq(f(1, n, k), k = 0..n), n = 0..8);
%p A397333 # Alternative:
%p A397333 b:= proc(n, k) option remember; `if`(n=0, 1,
%p A397333       (k+1)*b(n-1, k)+expand(x*b(n-1, k+1)))
%p A397333     end:
%p A397333 T:= (n, k)-> coeff(b(n$2), x, k):
%p A397333 seq(seq(T(n, k), k=0..n), n=0..8);  # _Alois P. Heinz_, Jun 24 2026
%t A397333 (* Generalizing the Euler/Lambert Tree function: *)
%t A397333 t[z_] := -ProductLog[-z];
%t A397333 P[n_, k_, x_] := n! SeriesCoefficient[
%t A397333    Exp[x t[z] + y (Exp[t[z]] - 1)]/(1 - t[z]),
%t A397333 {z, 0, n}, {y, 0, k} ];
%t A397333 Table[P[n, k, 1], {n, 0, 8}, {k, 0, n}] // Flatten
%t A397333 (* Alternative: *)
%t A397333 T[n_, k_] := Module[{x}, DifferenceDelta[(n + x)^n, {x, k}]/k! /. x -> 1];
%t A397333 Table[Table[T[n, k], {k, 0, n}], {n, 0, 8}]
%o A397333 (SageMath)
%o A397333 R.<x> = ZZ[]
%o A397333 def Delta(f, x): return f(x + 1) - f(x)
%o A397333 # Generates the polynomials via forward differences:
%o A397333 def P_row(n: int) -> list[Polynomial]:
%o A397333     f = (n + x)^n
%o A397333     row = [f]
%o A397333     for k in range(n):
%o A397333         f = Delta(f, x) / (k + 1)
%o A397333         row.append(f)
%o A397333     return row
%o A397333 T_row = lambda n: [p(x=1) for p in P_row(n)]
%o A397333 for n in range(10): print(T_row(n))
%o A397333 (SageMath) # Presumably the most direct, efficient way:
%o A397333 R.<z> = ZZ[]
%o A397333 @cached_function
%o A397333 def b(a, n, k):
%o A397333     if n == 0: return R(1)
%o A397333     return (k + a)*b(a, n-1, k) + z*b(a, n-1, k+1)
%o A397333 def T_row(a, n) -> list[int]: return list(b(a, n, n))
%o A397333 for n in range(10): print(T_row(1, n))
%o A397333 (SageMath) # As the first (N+1) rows of an exponential Riordan array:
%o A397333 R.<z> = PowerSeriesRing(QQ)
%o A397333 def RiordanArray(g, f, N) -> list[list[int]]:
%o A397333     return [[falling_factorial(n, n-k) * (g * f^k)[n]
%o A397333              for k in range(n + 1)] for n in range(N + 1)]
%o A397333 def tree(N):
%o A397333     return sum(n^(n-1) * z^n / factorial(n) for n in range(1, N + 1))
%o A397333 def gf(a, N):
%o A397333     t = tree(N)
%o A397333     g = (exp(a*t)/(1 - t)).add_bigoh(N + 1)
%o A397333     f = (exp(t) - 1).add_bigoh(N + 1)
%o A397333     return g, f
%o A397333 N = 8
%o A397333 g, f = gf(1, N)
%o A397333 RiordanArray(g, f, N)
%Y A397333 Cf. A000169 (column 0), A005449 (subdiagonal), A397332 (row sums), A397331 (p(x=-1)), A397329 (p(x=1/2)), A397048 (p(x=0)), A395288, A071207.
%Y A397333 Cf. A124824.
