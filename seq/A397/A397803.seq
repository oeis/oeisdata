%I A397803 #6 Jul 10 2026 10:24:59
%S A397803 1,2,16,8192,1099511627776,2658455991569831745807614120560689152,
%T A397803 37576681324381331646231689548629392438010920782533117931316655544515344401833735095419183974156299248510959616
%N A397803 a(n) = 2^((3^n - 1)/2).
%C A397803 a(n) is the Laman number of the n-Dorogovtsev-Goltsev-Mendes graph, using the indexing convention that DGM(0) = P_2.
%C A397803 For n >= 1, a(n) is also the Laman number of the n-Sierpinski gasket graph.
%H A397803 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/Dorogovtsev-Goltsev-MendesGraph.html">Dorogovtsev-Goltsev-Mendes Graph</a>.
%H A397803 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/LamanNumber.html">Laman Number</a>.
%H A397803 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/SierpinskiGasketGraph.html">Sierpinski Gasket Graph</a>.
%F A397803 a(n) = 2^((3^n - 1)/2).
%F A397803 a(n+1) = 2*a(n)^3, a(0) = 1.
%e A397803 a(3) = 8192.
%t A397803 Table[2^((3^n - 1)/2), {n, 0, 7}]
%t A397803 2^((3^Range[0, 7] - 1)/2)
%t A397803 RecurrenceTable[{a[0] == 1, a[n + 1] == 2*a[n]^3}, a, {n, 0, 7}]
%K A397803 nonn,easy,new
%O A397803 0,2
%A A397803 _Eric W. Weisstein_, Jul 10 2026
