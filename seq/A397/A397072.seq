%T A397072 23,2,349,79,67,139,271,2,281,31,97,37,383,239,263,127,137,157,97,593,
%U A397072 11,167,113,389,449,307,179,617,199,349,127,127,131,7,397,317,179,577,1487,659,307,31,379,37
%N A397072 a(n) is the first prime p such that the concatenation of the last digits of n consecutive primes starting with p is prime.
%H A397072 Robert Israel, <a href="/A397072/b397072.txt">Table of n, a(n) for n = 1..1000</a>
%e A397072 a(5) = 31 because the 5 consecutive primes starting with 31 are 31, 37, 41, 43 and 47, the concatenation of their last digits is 17137, which is prime, and no prime less than 31 works.
%p A397072 P:= select(isprime,[2,seq(i,i=3..10^6,2)]):
%p A397072 lcat:= proc(L) local i,t;
%p A397072   add((L[i] mod 10)*10^(nops(L)-i),i=1..nops(L))
%p A397072 end proc:
%p A397072 f:= proc(n) local i,j,v;
%p A397072   for i from 1 do
%p A397072     v:= lcat(P[i..i+n-1]);
%p A397072     if isprime(v) then return P[i] fi
%p A397072   od
%p A397072 end proc:
%p A397072 map(f, [$1..100]);
%t A397072 a[n_]:=Module[{p=0},Until[PrimeQ[FromDigits[Last/@IntegerDigits/@Prime[Range[p,p+n-1]]]],p++];Prime[p]];Array[a,70] (* _James C. McMahon_, Jul 05 2026 *)
%o A397072 (Python)
%o A397072 from itertools import islice
%o A397072 from gmpy2 import mpz, is_prime
%o A397072 from sympy import primerange
%o A397072 def agen(LIM=10**6): # generator of terms, capped by LIM
%o A397072     primes = list(primerange(1, LIM+1))
%o A397072     L = [str(p%10) for p in primes] # last digits of primes
%o A397072     n, an = 1, True
%o A397072     while an:
%o A397072         an = next((primes[i] for i in range(len(primes)-n) if is_prime(mpz("".join(L[i:i+n])))), None)
%o A397072         if an: yield an; n += 1
%o A397072 print(list(islice(agen(), 70))) # _Michael S. Branicky_, Jul 05 2026
