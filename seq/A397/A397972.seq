%H A397972 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (2,-1,1,-2,1).
%F A397972 a(n) = 2 a(n-1) - a(n-2) + a(n-3) - 2 a(n-4) + a(n-5), with (a(0),...,a(4)) = (0, 1, 4, 9, 15).
%F A397972 G.f.: -((x (1 + 2 x + 2 x^2))/((-1 + x)^3 (1 + x + x^2))).
%t A397972 z = 60;
%t A397972 f[n_] := (n^2 + n)/2; g[n_] := n^2; r = 1; s = 1/3;
%t A397972 u[n_] := Floor[r*f[n] + s*g[n]]; v[n_] := Ceiling[r*f[n] + s*g[n]]
%t A397972 Table[u[n], {n, 0, z}]
%t A397972 (* Alternative: *)
%t A397972 LinearRecurrence[{2, -1, 1, -2, 1}, {0, 1, 4, 9, 15}, 30]
%Y A397972 Cf. A000217, A000290, A397973.
%K A397972 nonn,easy,new
