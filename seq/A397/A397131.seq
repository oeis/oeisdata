%N A397131 E.g.f. A(x) satisfies A'(x) = (1 + A(x)*A'(x))^3, with A(0)=0.
%F A397131 E.g.f. A(x) satisfies A'(x) = (1 + A(x)*A'(x))^k, with A(0)=0.
%F A397131 Let R(x) = Series_Reversion( (1 - (1-(2*k-1)*x) * (1-x)^(2*k-1))/(2*(2*k-1)) ).
%F A397131 A(x) = R(x) * (1-R(x))^(k-1).
%F A397131 For k > 0 and n > 1, k divides n! * [x^n] A(x).
%F A397131 From _Vaclav Kotesovec_, Jun 17 2026: (Start)
%F A397131 Recurrence: 793*a(n) = 5*(7802*n - 24263)*a(n-1) - 15*(51160*n^2 - 369120*n + 677197)*a(n-2) + 5*(1509200*n^3 - 18586200*n^2 + 76934170*n - 107012127)*a(n-3) - 2*(18545000*n^4 - 341420000*n^3 + 2363610250*n^2 - 7292192800*n + 8459160303)*a(n-4) + 112500*(2*n - 11)*(3*n - 16)*(3*n - 14)*(6*n - 31)*(6*n - 29)*a(n-5).
%F A397131 a(n) ~ 2^(n - 15/2) * 3^(6*n - 5/2) * 5^(n - 3/2) * n^(n-2) / (exp(n) * 793^(n - 3/2)). (End)
%o A397131 (PARI) my(k=3, N=20, x='x+O('x^N), R=serreverse((1-(1-(2*k-1)*x)*(1-x)^(2*k-1))/(2*(2*k-1)))); Vec(serlaplace(R*(1-R)^(k-1)))
