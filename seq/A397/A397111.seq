%T A397111 882,990,1006,1084,1132,1368,1384,1410,1414,1472,1494,1620,1636,1724,
%U A397111 1966,2044,2058,2132,2184,2430,2608,2640,2792,2856,2918,2986,3060,3090,3144
%N A397111 Numbers k such that A000201(k) and A001950(k) are both prime.
%e A397111 The numbers floor(2*tau) = 3 and floor(2*tau^2) = 5, where tau = golden ratio, are prime, so 2 is in the sequence.
%t A397111 r = (1 + Sqrt[5])/2;
%t A397111 Select[Range[8000], PrimeQ[Floor[#*r]] && PrimeQ[Floor[# r^2]] &]
%Y A397111 Cf. A000040, A000201, A001950, A001622, A397112.
