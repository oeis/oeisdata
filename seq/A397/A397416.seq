%T A397416 288,289,292,305,313,337,369,388,404,409,424,449,457,481,520,521,544,
%U A397416 548,584,585,592,612,628,640,656,673,697,724,745,772,793,800,801,808,809
%N A397416 Numbers k such that both k and k+1 can be written as the sum of two nonzero and nonunit squares.
%C A397416 These are entries k in A085989 such that k+1 is also in A085989. - _R. J. Mathar_, Jul 14 2026
%H A397416 Friedjof Tellkamp, <a href="/A397416/b397416.txt">Table of n, a(n) for n = 1..10000</a>
%e A397416 40 is a term since 40 = 2^2 + 6^2 and 40 + 1 = 4^2 + 5^2.
%t A397416 kmax = 809; squares = Range[2, Floor@Sqrt@kmax]^2; S = Outer[Plus, squares, squares] // Flatten // Union; Select[Intersection[S, S - 1], # <= kmax &]
%Y A397416 Cf. A000290, A085989, A355769.
%K A397416 nonn,changed
%O A397416 1,1
%A A397416 _Friedjof Tellkamp_, Jun 24 2026
