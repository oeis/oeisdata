%I A397586 #10 Jul 13 2026 00:37:02
%S A397586 1,1,1,2,4,7,11,19,33,57,98,168,288,495,851,1462,2511,4313,7409,12728,
%T A397586 21865,37560,64521,110836,190398,327072,561854,965169,1657996,2848156,
%U A397586 4892649,8404740,14437915,24801885,42605426,73188886,125726075,215976041,371010153
%N A397586 Number of ways to tile a strip of length n with tiles of length equivalent to 1,3,4, or 5 (mod 6).
%C A397586 The tiles can be of length 1, 3,4,5, 7, 9,10,11, 13, 15,16,17, 19, ... = A047251.
%H A397586 <a href="/index/Rec#order_06">Index entries for linear recurrences with constant coefficients</a>, signature (1,0,1,1,1,1).
%F A397586 G.f.: (1 - x^6)/(1 - x - x^3 - x^4 - x^5 - x^6).
%F A397586 a(n) = A079816(n) - A079816(n-6) for n >= 6.
%F A397586 a(n) = a(n-1) + a(n-3) + a(n-4) + a(n-5) + a(n-6) for n >= 7.
%t A397586 a[0] = 1;
%t A397586 a[n_] := a[n] = Sum[If[Mod[i, 2] == 1 || Mod[i, 3] == 1, a[n - i], 0], {i, 1, n}];
%t A397586 Table[a[n],{n,0,40}]
%Y A397586 Cf. A047251, A079816.
%K A397586 nonn,easy,new
%O A397586 0,4
%A A397586 _Greg Dresden_ and Yilan Yuo, Jul 01 2026
