%I A397344 #18 Jul 05 2026 00:06:26
%S A397344 3,7,181,11,31,401,523,13,7,47,17,89,181,521,11,71,151,131,2971,491,
%T A397344 2861,401,683,1193,523,1153,283,43,13,83,397,3407,47,547,467,179,2969,
%U A397344 109,89,2879,139,709,4831,15091,2521,16831,41,1031,3391,1621,3221,6451,8761,6011,6581,1381,701,62081,683
%N A397344 a(n) is the first prime p such that A091633(n) is the concatenation of the last digits of consecutive primes starting with p.
%C A397344 If k = A091633(n) is the n-th prime whose digits are all in {1,3,7,9} and has d digits, then a(n) is the first prime p = prime(m) such that the digits of k are A007652(m) to A007652(m+d-1), the last digits of the d consecutive primes beginning with p.
%H A397344 Robert Israel, <a href="/A397344/b397344.txt">Table of n, a(n) for n = 1..10000</a>
%e A397344 a(5) = 31 because A091633(5) = 17 is the concatenation of the last digits of consecutive primes 31 and 37, and no smaller consecutive primes work.
%p A397344 S[0]:= [0]:
%p A397344 for i from 1 to 4 do
%p A397344   S[i]:= map(s -> (10*s+1,10*s+3,10*s+7,10*s+9),S[i-1]);
%p A397344   P[i]:= select(isprime,S[i])
%p A397344 od:
%p A397344 PP:= map(op,[seq(P[i],i=1..4)]): nPP:= nops(PP):
%p A397344 A:= Vector(nPP): count:= 0:
%p A397344 Q:= [0$3,2]:
%p A397344 while count < nPP do
%p A397344   Q:= [op(Q[2..-1]),nextprime(Q[-1])];
%p A397344   for k from 1 to 4 do
%p A397344     q:= add((Q[4-k+i] mod 10)*10^(k-i),i=1..k);
%p A397344     j:= ListTools:-BinarySearch(PP,q);
%p A397344     if j <> 0 and A[j] = 0 then
%p A397344       A[j]:= Q[5-k]; count:= count+1;
%p A397344     fi
%p A397344   od
%p A397344 od:
%p A397344 convert(A,list);
%Y A397344 Cf. A007962, A091633, A397072, A397073, A397425.
%K A397344 nonn,base,new
%O A397344 1,1
%A A397344 _Will Gosnell_ and _Robert Israel_, Jun 21 2026
