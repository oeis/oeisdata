%I A397345 #16 Jun 29 2026 11:03:32
%S A397345 1,1,10,435,38020,5230600,1018608180,264913746965,88621644616840,
%T A397345 37106835501772080,19032814746744521300,11748299375863573225670,
%U A397345 8596935122712285091333560,7362218998987792131814830260,7296589220644143960722463335320,8287897151012428617897315173422425,10697012705062013398689191049953630480
%N A397345 O.g.f. satisfies A(x) = exp( x + Sum_{n>=2} (5*n^2 - 1) * a(n)*x^n / (5*n^2) ).
%C A397345 Conjecture: a(n) is odd iff n+1 is a power of 2.
%C A397345 The limit lim_{n->oo} a(n)/(5^n * n!^2) appears to be finite and nonzero. At n = 800, a(800)/(5^800 * 800!^2) = 0.179674333697210...
%H A397345 Paul D. Hanna, <a href="/A397345/b397345.txt">Table of n, a(n) for n = 0..400</a>
%F A397345 G.f. A(x) = Sum_{n>=0} a(n)*x^n satisfies the following formulas.
%F A397345 (1) A(x) = exp( A(x) - 1 - Sum_{n>=2} a(n)*x^n / (5*n^2) ).
%F A397345 (2) A(x) = B(x*A(x)^q) where B(x) = A(x/B(x)^q) satisfies (q*n)*[x^n] B(x)^(q*n) = (q*n-1)*[x^n] B(x)^(q*n+1) for n > 1, where q = sqrt(5).
%F A397345 (3) A'(x) = A(x) * (1 + Sum_{n>=1} (5*(n+1)^2 - 1)/(5*(n+1)) * a(n+1) * x^n ).
%F A397345 (4) A(x) = 1+x + 5*x*(A(x)-1)*(A'(x) + x*A''(x))/A(x) + 5*x^2*A'(x)^2/A(x)^2.
%F A397345 (5) a(n) = 5*n^2/(5*n^2 - 1) * [x^n] log(A(x)) for n > 1.
%F A397345 (6) a(n) = 5*n*a(n-1) + n*Sum_{k=1..n-2} (5*(k+1)^2-1)/(k+1) * a(k+1)*a(n-k-1) for n > 1, with a(0) = a(1) = 1.
%e A397345 G.f.: A(x) = 1 + x + 10*x^2 + 435*x^3 + 38020*x^4 + 5230600*x^5 + 1018608180*x^6 + 264913746965*x^7 + 88621644616840*x^8 + ...
%e A397345 where
%e A397345 A(x) = exp( x + 19*10*x^2/(5*2^2) + 44*435*x^3/(5*3^2) + 79*38020*x^4/(5*4^2) + 124*5230600*x^5/(5*5^2) + 179*1018608180*x^6/(5*6^2) + ... + (5*n^2-1)*a(n)*x^n/(5*n^2) + ... ).
%e A397345 RELATED SERIES.
%e A397345 The logarithm of the g.f. A(x) begins
%e A397345 log(A(x)) = x + 19*x^2/2 + 1276*x^3/3 + 150179*x^4/4 + 25943776*x^5/5 + 6077695474*x^6/6 + 1846827264556*x^7/7 + ... + (5*n^2-1)*a(n)*x^n/(5*n^2) + ...
%e A397345 The terms a(n) are divisible by n for n > 0:
%e A397345 a(n)/n = [1, 5, 145, 9505, 1046120, 169768030, ...].
%o A397345 (PARI) \\ by a(n) = 5*n^2/(5*n^2-1) * [x^n] log(A) for n > 1:
%o A397345 {a(n) = my(V=[1, 1], A, m); for(i=2, n, V=concat(V, 0); A = Ser(V); m = #V-1;
%o A397345 V[#V] = (5*m^2-1)*polcoef(A, m) - 5*m^2*polcoef(log(A), m) ); GF=Ser(V); V[n+1]}
%o A397345 \\ returns a vector of terms a(k) for k = 0..n
%o A397345 {upto(n) = a(n); Vec(GF)}
%o A397345 upto(20)
%o A397345 (PARI) \\ by recurrence (slower)
%o A397345 \\ print terms a(n) for n = 0..N
%o A397345 N = 20; A = vector(N+1);
%o A397345 {a(n) = A[n+1] = if(n<=1, 1, 5*n*A[n] + n*sum(k=1, n-2, (5*(k+1)^2-1)/(k+1) * a(k+1) * A[n-k]) )}
%o A397345 for(n=0, N, print1(a(n), ", "))
%Y A397345 Cf. A397242, A397346, A397348, A397245.
%K A397345 nonn,new
%O A397345 0,3
%A A397345 _Paul D. Hanna_, Jun 28 2026
