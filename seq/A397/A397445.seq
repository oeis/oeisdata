%T A397445 292718885826099937280,0,0,279549743774208227086317226131456,
%U A397445 3675745848073184804005233540559011840,0,0,7627800343162470610551615645522436123639409213964288,9835850520212342615759816040579413208770643952444693807104
%N A397445 a(n) is the permanent of the n X n Krawtchouk matrix.
%C A397445 The n X n Krawtchouk matrix M(n) is defined by M(i,j,n) = C(n-1,i-1)*hypergeom([1-i, 1-j], [1-n], 2), with 1 <= i,j <= n.
%H A397445 Wikipedia, <a href="https://en.wikipedia.org/wiki/Krawtchouk_matrices">Krawtchouk matrices</a>
%H A397445 Wolfram Function Repository, <a href="https://resources.wolframcloud.com/FunctionRepository/resources/KrawtchoukMatrix/">KrawtchoukMatrix</a>, 2023.
%F A397445 det(M(n)) = A057077(n)*A006125(n).
%F A397445 Tr(M(n)) = A077957(n-1), where Tr denotes the trace.
%F A397445 Conjecture: a(n) = 0 iff n is congruent to {2, 3} mod 4 (cf. A042964).
%e A397445 a(1) = 1:
%e A397445   [1]
%e A397445 a(2) = 0:
%e A397445   [1,  1]
%e A397445   [1, -1]
%e A397445 a(3) = 0:
%e A397445   [1,  1,  1]
%e A397445   [2,  0, -2]
%e A397445   [1, -1,  1]
%e A397445 a(4) = 24:
%e A397445   [1,  1,  1,  1]
%e A397445   [3,  1, -1, -3]
%e A397445   [3, -1, -1,  3]
%e A397445   [1, -1,  1, -1]
%e A397445  ...
%t A397445 a[n_]:=Permanent[ResourceFunction["KrawtchoukMatrix"][n]]; Join[{1},Array[a,17]]
%t A397445 (* Alternative: *)
%t A397445 M[i_,j_,n_]:=Binomial[n-1,i-1]Hypergeometric2F1[1-i,1-j,1-n,2]; a[n_]:=Permanent[Table[M[i,j,n],{i,n},{j,n}]]; Join[{1},Array[a,17]]
%Y A397445 Cf. A006125, A042964, A057077, A077957.
%K A397445 sign,changed
%O A397445 0,5
