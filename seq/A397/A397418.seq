%I A397418 #5 Jul 11 2026 20:36:44
%S A397418 1,4,8,16,32,36,9,27,72,64,100,25,125,200,108,81,144,128,196,49,343,
%T A397418 392,216,225,243,288,256,324,400,432,441,576,484,121,968,500,512,648,
%U A397418 675,625,800,676,169,1352,784,864,729,900,972,1000,1024,1152,1089,1125,1225
%N A397418 Lexicographically earliest infinite sequence of distinct positive powerful numbers such that gcd(a(n), a(n-1)) > 1 for n >= 2.
%C A397418 Version of A064413 confined to powerful numbers (in A001694).
%C A397418 Let a(s(j)) = p^m be the j-th proper prime power in this sequence. Then for j = 4..549 (the latter the limit of data), a(s(j)-1) = 4*p^m, and a(s(j)+1) = 8*p^m.
%H A397418 Michael De Vlieger, <a href="/A397418/b397418.txt">Table of n, a(n) for n = 1..16384</a>
%e A397418 Table of n, a(n) for n = 1..20:
%e A397418    n   a(n)  Prime power factors
%e A397418   --------------------------------
%e A397418    1     1
%e A397418    2     4   2^2
%e A397418    3     8   2^3
%e A397418    4    16   2^4
%e A397418    5    32   2^5
%e A397418    6    36   2^2   3^2
%e A397418    7     9         3^2
%e A397418    8    27         3^3
%e A397418    9    72   2^3   3^2
%e A397418   10    64   2^6
%e A397418   11   100   2^2         5^2
%e A397418   12    25               5^2
%e A397418   13   125               5^3
%e A397418   14   200   2^3         5^2
%e A397418   15   108   2^2   3^3
%e A397418   16    81         3^4
%e A397418   17   144   2^4   3^2
%e A397418   18   128   2^7
%e A397418   19   196   2^2               7^2
%e A397418   20    49                     7^2
%t A397418 nn = 120; hit[_] = False; j = 2; u = 1;
%t A397418   s = Union@ Flatten@ Table[a^2*b^3, {b, Surd[#, 3]}, {a, Sqrt[#/b^3] } ] &[nn*2^4];
%t A397418   {s[[1]]}~Join~Reap[Do[
%t A397418     k = u; While[Or[hit[s[[k]]], CoprimeQ[j, s[[k]] ] ], k++];
%t A397418     Set[{hit[s[[k]] ], j}, {True, s[[k]] } ]; Sow[s[[k]] ];
%t A397418       If[k == u, While[hit[s[[u]] ], u++] ], {n, 2, nn}] ][[-1, 1]]
%Y A397418 Cf. A001694, A064413, A100113 (squarefree version).
%K A397418 nonn,new
%O A397418 1,2
%A A397418 _Michael De Vlieger_, Jun 28 2026
