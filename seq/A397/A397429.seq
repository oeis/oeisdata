%I A397429 #14 Jul 07 2026 21:36:07
%S A397429 11,23,37,43,47,67,71,83,131,151,163,167,173,199,223,263,269,277,283,
%T A397429 307,331,349,359,383,431,463,479,521,571,599,601,619,631,643,653,661,
%U A397429 683,691,701,727,739,823,827,839,911,1033,1049,1087,1091,1093,1109,1117
%N A397429 Primes in A161601 whose binary reversal is prime.
%H A397429 Vincenzo Librandi, <a href="/A397429/b397429.txt">Table of n, a(n) for n = 1..8237</a>
%e A397429 The pairs (A161601(k), A161603(k)) for k=1..5 are (11,13), (19,25), (23,29), (35,49), (37,41), so this sequence begins with 11,23,37.
%e A397429 For (37,41), we have (37 base 2) = 100101 and (41 base 2) = 10101, which is the reverse of 100101, as in A161601(5) and A161603(5).
%t A397429 p[f_] := Module[{n = 1, c = 0}, Reap[While[c < f, With[{d = IntegerDigits[n, 2]}, With[{r = Reverse[d]}, If[d =!= r && n < FromDigits[r, 2],
%t A397429 Sow[{n, FromDigits[r, 2]}]; c++]]]; n += 2]][[2, 1]]];
%t A397429 u = Select[p[300], PrimeQ[#[[1]]] && PrimeQ[#[[2]]] &];
%t A397429 Map[First, u]
%t A397429 (* _Peter J. C. Moses_, Jun 24 2026 *)
