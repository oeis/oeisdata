%F A397180 a(n) = 1 + max_{k=1..n} A394611(k). - _Michael S. Branicky_, Jul 01 2026
%o A397180 (Python)
%o A397180 from collections import Counter
%o A397180 from itertools import count, islice
%o A397180 def A397180_gen(): # generator of terms
%o A397180     alst, an, c, m = [], 0, Counter(), -1
%o A397180     for n in count(1):
%o A397180         an = c[an]
%o A397180         c.update(an+ai for ai in alst)
%o A397180         alst.append(an)
%o A397180         m = max(m, an)
%o A397180         yield m+1
%o A397180 print(list(islice(A397180_gen(), 88))) # _Michael S. Branicky_, Jul 01 2026
