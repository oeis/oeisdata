%I A397596 #14 Jul 12 2026 03:58:00
%S A397596 1,1,20,845,68389,9154109,1838562068,518917632012,196310716302359,
%T A397596 96026927549638901,59038615622436497740,44589921541345552880058,
%U A397596 40599524405166841363600140,43869059964546537412305665364,55508839204493285017736609125988,81315065452180268862344515609173700
%N A397596 G.f. A(x) such that the sum of the first n coefficients in A(x/n)^n equals n^(n-1) for n >= 1.
%C A397596 Submitted at the suggestion of _Vaclav Kotesovec_.
%H A397596 Paul D. Hanna, <a href="/A397596/b397596.txt">Table of n, a(n) for n = 0..225</a>
%F A397596 G.f. A(x) = Sum_{n>=0} a(n)*x^n has the following properties.
%F A397596 (1) n^(n-1) = Sum_{k=0..n-1} [x^k] A(x/n)^n for n >= 1.
%F A397596 (2) (n^2)^(n-1) = [x^(n-1)] A(x)^n / (1 - n*x) for n >= 1.
%F A397596 (3) (n^2)^(n-1) = [x^(n-1)] B'(x) / (1 - n*B(x)) for n >= 1 where B(x) = x*A(B(x)) and B(x) = Series_Reversion(x/A(x)).
%F A397596 (4) [x^(n-1)] B'(x)/(1 - B(x)) = Sum_{k=0..n-1} [x^k] A(x)^n for n >= 1 where B(x) = x*A(B(x)).
%F A397596 a(n) ~ exp(2) * n^(2*n-1). - _Vaclav Kotesovec_, Jul 11 2026
%e A397596 G.f.: A(x) = 1 + x + 20*x^2 + 845*x^3 + 68389*x^4 + 9154109*x^5 + 1838562068*x^6 + 518917632012*x^7 + ...
%e A397596 where n^(n-1) = Sum_{k=0..n-1} [x^k] A(x/n)^n for n >= 1, as illustrated below.
%e A397596 The table of coefficients of x^k in A(x)^n begins
%e A397596   n = 1: [1, 1,  20,  845,  68389,  9154109, ...];
%e A397596   n = 2: [1, 2,  41, 1730, 138868, 18478796, ...];
%e A397596   n = 3: [1, 3,  63, 2656, 211497, 27977796, ...];
%e A397596   n = 4: [1, 4,  86, 3624, 286337, 37654924, ...];
%e A397596   n = 5: [1, 5, 110, 4635, 363450, 47514076, ...];
%e A397596   n = 6: [1, 6, 135, 5690, 442899, 57559230, ...]; ...
%e A397596 The sums of the first n coefficients in A(x/n)^n are
%e A397596   n = 1: 1^0 = 1;
%e A397596   n = 2: 2^1 = 1 + 2/2;
%e A397596   n = 3: 3^2 = 1 + 3/3 + 63/3^2;
%e A397596   n = 4: 4^3 = 1 + 4/4 + 86/4^2 + 3624/4^3;
%e A397596   n = 5: 5^4 = 1 + 5/5 + 110/5^2 + 4635/5^3 + 363450/5^4;
%e A397596   n = 6: 6^5 = 1 + 6/6 + 135/6^2 + 5690/6^3 + 442899/6^4 + 57559230/6^5;
%e A397596   etc.
%e A397596 RELATED SERIES.
%e A397596 Let B(x) = Series_Reversion(x/A(x)) then
%e A397596 B(x) = x + x^2 + 21*x^3 + 906*x^4 + 72690*x^5 + 9593205*x^6 + 1905437513*x^7 + 533749944368*x^8 + ...
%e A397596 where B(x) = x*A(B(x)) and
%e A397596 B'(x)/(1 - B(x)) = 1 + 3*x + 67*x^2 + 3715*x^3 + 368201*x^4 + 58007961*x^5 + 13406388745*x^6 + ...
%e A397596 the coefficients of which are partial sums of [x^k] A(x)^n:
%e A397596 1 = 1, 3 = (1 + 2), 67 = (1 + 3 + 63), 3715 = (1 + 4 + 86 + 3624), ...
%e A397596 The table of coefficients in B'(x)/(1 - n*B(x)) begins
%e A397596   n = 1: [1, 3,  67, 3715, 368201, ...];
%e A397596   n = 2: [1, 4,  73, 3820, 373216, ...];
%e A397596   n = 3: [1, 5,  81, 3945, 378561, ...];
%e A397596   n = 4: [1, 6,  91, 4096, 384326, ...];
%e A397596   n = 5: [1, 7, 103, 4279, 390625, ...]; ...
%e A397596 in which the main diagonal equals
%e A397596 [1, 4, 81, 4096, 390625, ..., (n^2)^(n-1), ...].
%o A397596 (PARI) \\ by definition
%o A397596 {a(n) = my(A=[1], m, V); for(i=1, n, A = concat(A, 0); m=#A; V=Vec( subst(Ser(A)^m, x, x/m) );
%o A397596 A[m] = (m^(m-1) - sum(k=1, #V, V[k]) )*m^(m-2) ); GF=Ser(A); polcoef(GF, n)}
%o A397596 {upto(n) = a(n); Vec(GF)}
%o A397596 upto(20)
%o A397596 (PARI) \\ from (n^2)^(n-1) = [x^(n-1)] A(x)^n / (1 - n*x)
%o A397596 {a(n) = my(A=[1], m, V); for(i=1, n, A = concat(A, 0); m=#A;
%o A397596 A[m] = ((m^2)^(m-1) - polcoef(Ser(A)^m/(1-m*x), m-1))/m ); GF=Ser(A); polcoef(GF, n)}
%o A397596 {upto(n) = a(n); Vec(GF)}
%o A397596 upto(20)
%Y A397596 Cf. A397590, A397592, A397593, A397594, A397595.
%K A397596 nonn,new
%O A397596 0,3
%A A397596 _Paul D. Hanna_, Jul 11 2026
