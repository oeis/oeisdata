%S A397932 12,20,28,44,52,68,76,90,92,116,124,126,148,164,172,188,198,212,234,
%T A397932 236,244,268,284,292,306,315,316,332,342,356,388,404,412,414,428,436,
%U A397932 452,495,508,522,524,548,556,558,585,596,604,628,652,666,668,692,693,716
%N A397932 Numbers k that are neither squarefree nor powerful such that rad(k)*omega(k) = k, where rad = A007947 and omega = A001221.
%C A397932 Composite terms in A397221.
%C A397932 Intersection of A332785 and A397221.
%C A397932 The smallest term in A361098 is a(3189) = 50050 = 2 * 5^2 * 7 * 11 * 13. This is to say that k = 50050 is such that k/rad(k) > A053669(k), k/rad(k) >= A119288(k), and k = rad(k) * omega(k) are all true.
%H A397932 Michael De Vlieger, <a href="/A397932/b397932.txt">Table of n, a(n) for n = 1..10000</a>
%e A397932 Table of n, a(n) for select n:
%e A397932      n      a(n) = k                            rad(k) * omega(k)
%e A397932   ---------------------------------------------------------------
%e A397932       1       12 = 2^2 * 3                           6 * 3
%e A397932       2       20 = 2^2 * 5                          10 * 3
%e A397932       3       28 = 2^2 * 7                          14 * 3
%e A397932       4       44 = 2^2 * 11                         22 * 3
%e A397932       8       90 = 2 * 3^2 * 5                      30 * 4
%e A397932      26      315 = 3^2 * 5 * 7                     105 * 4
%e A397932      38      495 = 3^2 * 5 * 11                    165 * 4
%e A397932      64      840 = 2^3 * 3 * 5 * 7                 210 * 6
%e A397932     774    11550 = 2 * 3 * 5^2 * 7 * 11           2310 * 6
%e A397932   11078   180180 = 2^2 * 3^2 * 5 * 7 * 11 * 13   30030 * 8
%t A397932 rad[x_] := Times @@ FactorInteger[x][[All, 1]]; s = Select[Range[10^3], Not @* SquareFreeQ]; Select[s, # == rad[#]*PrimeNu[#] &]
%Y A397932 Cf. A001221, A002808, A007947, A332785, A397221, A397933, A397934.
%K A397932 nonn,new
%O A397932 1,1
