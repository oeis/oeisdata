%N A397947 G.f. A(x) satisfies A(x) = 1 + x * A(x^3/(1 - x)^3) / (1 - x)^4.
%F A397947 a(0) = 1; a(n) = Sum_{k=0..floor((n-1)/3)} binomial(n+2,3*k+3) * a(k).
%F A397947 E.g.f.: 1 + d^2/dx^2 ( exp(x) * Sum_{k>=0} a(k) * x^(3*k+3) / (3*k+3)! ).
%o A397947 (PARI) a_vector(n) = my(v=vector(n+1)); v[1]=1; for(i=1, n, v[i+1]=sum(j=0, (i-1)\3, binomial(i+2, 3*j+3)*v[j+1])); v;
