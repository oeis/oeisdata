%T A397504 167,43,17,4561,947,5003,337,3067,7159,1787,15889,2837,347,1087,5443,
%U A397504 3217,12049,1091,1723,2393,2287,3697,1669,1087,6967,1423,11321,9613,8923,4591,9337,23879,26497,7507,3181
%N A397504 a(n) is the first prime p such that the concatenations, both in forward and reverse orders, of the last digits of n consecutive primes starting with p are primes (not necessarily distinct).
%H A397504 Robert Israel, <a href="/A397504/b397504.txt">Table of n, a(n) for n = 1..500</a>
%e A397504 a(5) = 73 because the 5 consecutive primes starting with 73 are 73, 79, 83, 89, 97, and both 39397 (the concatenation in forward order) and 79393 (the concatenation in reverse order) are primes, and 73 is the first prime that works.
%p A397504 P:= select(isprime, [2, seq(i, i=3..10^7, 2)]):
%p A397504 rcat:= proc(L) local i, nL;
%p A397504   nL:= nops(L);
%p A397504   add(L[i]*10^(i-1), i=1..nL)
%p A397504 end proc:
%p A397504 lcat:= proc(L) local i, nL;
%p A397504   nL:= nops(L);
%p A397504   add(L[i]*10^(nL-i), i=1..nL)
%p A397504 end proc:
%p A397504 f:= proc(n) local i,L, v,w;
%p A397504   for i from 1 do
%p A397504     L:= P[i..i+n-1] mod 10;
%p A397504     v:= rcat(L);
%p A397504     if isprime(v) then
%p A397504       w:= lcat(L);
%p A397504       if isprime(w) then
%p A397504         return P[i]
%p A397504       fi
%p A397504     fi
%p A397504   od
%p A397504 end proc:
%p A397504 map(f, [$1..100]);
%t A397504 a[n_]:=Module[{p=0},Until[PrimeQ[IntegerReverse[FromDigits[Last/@IntegerDigits/@Prime[Range[p,p+n-1]]]]]&&PrimeQ[FromDigits[Last/@IntegerDigits/@Prime[Range[p,p+n-1]]]],p++];Prime[p]];Array[a,54] (* _James C. McMahon_, Jul 06 2026 *)
