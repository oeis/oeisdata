%F A397575 Equals 132*zeta(2)^2 - 264*zeta(3)*zeta(2) + 180*zeta(4)*zeta(2) - 96*zeta(5)*zeta(2) + 40*zeta(6)*zeta(2) - 12*zeta(7)*zeta(2) + 2*zeta(8)*zeta(2) - 6006*zeta(2) + 132*zeta(3)^2 + 62*zeta(4)^2 + 20*zeta(5)^2 + 6*zeta(6)^2 + 2*zeta(7)^2 + zeta(8)^2 - 4290*zeta(3) - 180*zeta(3)*zeta(4) + 2970*zeta(4) + 96*zeta(3)*zeta(5) - 68*zeta(4)*zeta(5) - 1650*zeta(5) - 40*zeta(3)*zeta(6) + 30*zeta(4)*zeta(6) - 20*zeta(5)*zeta(6) + 750*zeta(6) + 12*zeta(3)*zeta(7) - 10*zeta(4)*zeta(7) + 8*zeta(5)*zeta(7) - 6*zeta(6)*zeta(7) - 270*zeta(7) - 2*zeta(3)*zeta(8) + 2*zeta(4)*zeta(8) - 2*zeta(5)*zeta(8) + 2*zeta(6)*zeta(8) - 2*zeta(7)*zeta(8) + 70*zeta(8) - 10*zeta(9) + 12870.
