%N A397521 Expansion of ordinary generating function A(x) satisfying (A(x)^2-A(x^2))/2 = x/(1-x)^2.
%C A397521 This sequence was inspired by the analysis of A397174 and is a variant of A397525.
%F A397521 Sum_{k=0..n} a(k)*a(n-k) = 2*n + [n even] a(n/2).
%p A397521 a:= proc(n) option remember; `if`(n=0, 1, n+`if`(n::even, (t->
%p A397521       t*(1-t)/2)(a(n/2)), 0)-add(a(k)*a(n-k), k=1..(n-1)/2))
%p A397521     end:
%p A397521 seq(a(n), n=0..55);  # _Alois P. Heinz_, Jun 30 2026
%o A397521 (PARI)
%o A397521 h(v) = (Ser(v)^2-subst(Ser(v), x, x^2))/2
%o A397521 ListA(max_n) = {my(v=[1]); while(#v<max_n, v=concat(v, #v-polcoeff(Vec(h(concat(v, y)))[#v], 0))); vector(#v, k, v[k])}
%Y A397521 Cf. A394611, A397173, A397525.
%K A397521 sign,new
%O A397521 0,3
