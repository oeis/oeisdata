%S A397463 7,17,37,89,149,229,331,449,691,907,1171,1531,1777,2029,2521,3163,
%T A397463 3607,4111,4783,5189,5791,6569,7411,8669,9811,10427,11047,11677,12329,
%U A397463 14449,16649,17971,19051,20771,22501,23741,25609,27239,28909,31013,32401,34631,36871,38039
%N A397463 Smallest prime greater than or equal to (prime(n)^2 + prime(n+1)^2)/2.
%H A397463 Paolo Xausa, <a href="/A397463/b397463.txt">Table of n, a(n) for n = 1..10000</a>
%F A397463 a(n) = A007918(A075892(n)). - _Alois P. Heinz_, Jun 26 2026
%e A397463 a(1) = 7 since 2^2 + 3^2 = 13 and the smallest prime >= 13/2 is 7.
%e A397463 a(2) = 17 since 3^2 + 5^2 = 34 and the smallest prime >= 34/2 is 17.
%t A397463 A397463[n_] := NextPrime[Mean[Prime[{n, n+1}]^2] - 1]; Array[A397463, 50] (* _Paolo Xausa_, Jul 04 2026 *)
%t A397463 (* Alternative: *)
%t A397463 NextPrime[Map[Mean, Partition[Prime[Range[51]]^2, 2, 1]] - 1] (* _Paolo Xausa_, Jul 04 2026 *)
%Y A397463 Cf. A000040, A062772, A075892, A007918, A093343 (subsequence).
