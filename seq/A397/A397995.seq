%N A397995 E.g.f. A(x) satisfies A(-log(1-4*x)/4) = 5*A(x) - 4*x.
%F A397995 a(1) = 1; a(n+1) = Sum_{k=1..n} 4^(n-k) * |Stirling1(n+1,k)| * a(k).
%o A397995 (PARI) a_vector(n) = my(v=vector(n)); v[1]=1; for(i=1, n-1, v[i+1]=sum(j=1, i, 4^(i-j)*abs(stirling(i+1, j, 1))*v[j])); v;
