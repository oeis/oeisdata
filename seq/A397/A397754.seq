%S A397754 212,214,216,218,312,315,318,321,324,327,412,414,416,418,424,428,432,
%T A397754 436,515,525,535,545,612,614,615,616,618,621,624,627,636,642,648,654,
%U A397754 714,721,728,735,742,749,756,763,812,814,816,818,824,828,832,836,848,856,864,872,912,915,918,921,924
%N A397754 Numbers that don't contain digit 0 but have a divisor that does.
%H A397754 Robert Israel, <a href="/A397754/b397754.txt">Table of n, a(n) for n = 1..10000</a>
%e A397754 a(5) = 312 is a term because 312 has no 0 but its divisor 312/3 = 104 does.
%p A397754 filter:= proc(n) not member(0, convert(n,base,10)) and ormap(t -> member(0,convert(t,base,10)), NumberTheory:-Divisors(n)) end proc:
%p A397754 select(filter, [$1..1000]);
%t A397754 A397754Q[k_] := FreeQ[IntegerDigits[k], 0] && MemberQ[IntegerDigits[Divisors[k]], 0, {2}];
%t A397754 Select[Range[1000], A397754Q] (* _Paolo Xausa_, Jul 09 2026 *)
%o A397754 (Python)
%o A397754 from sympy import divisors
%o A397754 def ok(k): return "0" not in str(k) and any("0" in str(d) for d in divisors(k, generator=True))
%o A397754 print([k for k in range(925) if ok(k)]) # _Michael S. Branicky_, Jul 08 2026
%o A397754 (PARI) first(nn)= my(r=List()); for(n=2, oo, if(Set(digits(n))[1], foreach(Vecrev(divisors(n)), d, if(Set(digits(d))[1], , listput(~r, n); break(2-(#r<nn)))))); Vec(r); \\ _Ruud H.G. van Tol_, Jul 09 2026
