%I A397979 #10 Jul 24 2026 00:57:26
%S A397979 0,2,6,12,21,33,47,63,82,104,128,154,183,215,249,285,324,366,410,456,
%T A397979 505,557,611,667,726,788,852,918,987,1059,1133,1209,1288,1370,1454,
%U A397979 1540,1629,1721,1815,1911,2010,2112,2216,2322,2431,2543,2657,2773,2892,3014
%N A397979 Upper (1/2,1) midsequence of triangular numbers (A000217) and squares (A000290); see Comments.
%C A397979 Suppose that s = (s(n)) and t = (t(n)) are sequences of numbers and h > 0 and k > 0. The lower (h, k)-midsequence of s and t is floor(h*s + k*t); the upper (h, k)-midsequence of s and t is ceiling(h*s + k*t). See A397972 for a guide to related sequences.
%H A397979 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (3,-4,4,-3,1).
%F A397979 a(n) = 3*a(n-1) - 4*a(n-2) + 4*a(n-3) - 3*a(n-4) + a(n-5), with (a(0),...,a(4)) = (0,2,6,12,21).
%F A397979 G.f.: -x*(2 + 2*x^2 + x^3)/((-1 + x)^3*(1 + x^2))).
%F A397979 E.g.f.: (exp(x)*(1 + 6*x + 5*x^2) - cos(x) + sin(x))/4. - _Stefano Spezia_, Jul 21 2026
%t A397979 z = 60;
%t A397979 f[n_] := (n^2 + n)/2; g[n_] := n^2; r = 1/2; s = 1;
%t A397979 u[n_] := Floor[r*f[n] + s*g[n]]; v[n_] := Ceiling[r*f[n] + s*g[n]]
%t A397979 Table[v[n], {n, 0, z}]
%Y A397979 Cf. A000217, A000290, A397978.
%K A397979 nonn,easy,new
%O A397979 0,2
%A A397979 _Clark Kimberling_, Jul 21 2026
