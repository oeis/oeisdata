%T A397064 88074,176148,352296,704548,1409096,2818192,5636296,11272592,22545184,
%U A397064 45090195,90180390,180360780,360721214,721442428,1442884856,2885769020,5771538040,11543076080
%N A397064 G.f. A(x) satisfies (1-2*x)*A(x) + A(x^3) = x.
%F A397064 G.f.: Sum_{j>=0} (-1)^j*x^(3^j) / Product_{k=0..j} (1 - 2*x^(3^k)).
%F A397064 a(1) = 1; for n >= 2, a(n) = 2*a(n-1) - a(n/3) if 3|n, and a(n) = 2*a(n-1) otherwise.
%F A397064 a(n) = 2^(n-1) - Sum_{k=1..floor(n/3)} 2^(n-3*k) * a(k).
%t A397064 a[1]=1;a[n_]:=a[n]=If[Divisible[n,3],2*a[n-1]-a[n/3],2*a[n-1]];Array[a, 35] (* _Shenghui Yang_, Jul 18 2026 *)
%o A397064 (Ruby)
%o A397064 def A397064(n)
%o A397064   a = [0]
%o A397064   (1..n).each{|i|
%o A397064   a << (1..i / 3).inject(2 ** (i - 1)){|s, k| s - 2 ** (i - 3 * k) * a[k]}}
%o A397064   a[1..-1]
%o A397064 end
%o A397064 p A397064(40)
%Y A397064 Cf. A045690, A397213, A397274.
%K A397064 nonn,new
%O A397064 1,2
