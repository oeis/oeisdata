%I A397500 #6 Jul 20 2026 19:39:18
%S A397500 1,2,4,8,3,16,6,9,32,12,18,64,24,5,27,36,128,48,10,54,72,15,81,256,96,
%T A397500 20,108,25,144,30,162,512,192,40,216,45,243,7,50,288,60,324,1024,75,
%U A397500 384,80,432,90,486,14,100,576,120,125,648,135,2048,729,21,150,768
%N A397500 Distinct numbers in the order they appear in A397499.
%C A397500 Permutation of natural numbers.
%H A397500 Michael De Vlieger, <a href="/A397500/b397500.txt">Table of n, a(n) for n = 1..10000</a>
%H A397500 Michael De Vlieger, <a href="/A397500/a397500.png">Log log scatterplot of a(n)</a>, n = 1..1471539.
%H A397500 <a href="/index/Per#IntegerPermutation">Index entries for sequences that are permutations of the natural numbers</a>
%e A397500 Table of n, i, s(i), a(n) = t(i) and exponents of 2, 3, and 5 that produce s(i) and a(i):
%e A397500                    Exp. of   a(n) Exp. of
%e A397500    n     i    s(i)  2.3.5    t(i)  2.3.5
%e A397500   --------------------------------------
%e A397500    1     1      1   0          1   0
%e A397500    2     3      4   2          2   1
%e A397500    3     5      8   3          4   2
%e A397500    4     7     16   4          8   3
%e A397500    5     8     18   1.2        3   0.1
%e A397500    6    11     32   5         16   4
%e A397500    7    12     36   2.2        6   1.1
%e A397500    8    14     54   1.3        9   0.2
%e A397500    9    16     64   6         32   5
%e A397500   10    17     72   3.2       12   2.1
%e A397500   11    20    108   2.3       18   1.2
%e A397500   12    22    128   7         64   6
%e A397500   13    23    144   4.2       24   3.1
%e A397500   14    24    150   1.1.2      5   0.0.1
%e A397500 .
%e A397500 a(1) = s(1) = t(1) = 1 since 1 = 1/rad(1) and 1 is not already in the sequence.
%e A397500 t(2) is not in the sequence because s(2) = 2, and 2/rad(2) = 1 = a(1).
%e A397500 a(2) = t(3) = s(3)/rad(s(3)) = 4/2 = 2, not already in the sequence.
%e A397500 t(4) is not in the sequence since s(4) = 6; 6/rad(6) = 1 = a(1).
%e A397500 a(3) = t(5) = s(5)/rad(s(5)) = 8/2 = 4, not already in the sequence.
%e A397500 t(6) is not in the sequence since s(6) = 12; 12/rad(12) = 2 = a(2).
%e A397500 a(4) = t(7) = s(7)/rad(s(7)) = 16/2 = 8, not already in the sequence.
%e A397500 a(5) = t(8) = s(8)/rad(s(8)) = 18/6 = 3, not already in the sequence, etc.
%t A397500 (* First, load the Mathematica function f055932 from links at A397499, then: *)
%t A397500 g[x_] := Times @@ Flatten@ MapIndexed[Prime[#2]^#1 &, x]; DeleteDuplicates@ Map[g, SortBy[Join @@ f055932[6, 1], g] - 1 /. -1 -> 0]
%Y A397500 Cf. A003557, A007947, A055932, A397499.
%K A397500 nonn,easy,look,new
%O A397500 1,2
%A A397500 _Michael De Vlieger_, Jul 14 2026
