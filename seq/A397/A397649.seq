%I A397649 #10 Jul 04 2026 09:57:13
%S A397649 1,3,22,132,839,5252,33017,207328,1302298,8179522,51375340,322685207,
%T A397649 2026768043,12730013649,79956492736,502202176025,3154303281733,
%U A397649 19811999328290,124438039885484,781588244168457,4909111265382886,30833848379235585,193665646281067686
%N A397649 Number of ways to tile a 3 X n strip with squares, dominoes, and crosses.
%C A397649 a(n) starts with 1, 3, 22, 132 which is almost the same as the initial values of 1, 3, 22, 131 for A033506; this is because A033506 counts the tilings of a 3 X n strip with just squares and dominoes and so not until n=3 do we see a difference (and only a difference of 1, because there is just one way to tile a 3 X 3 strip with squares, dominoes, and one cross).
%H A397649 <a href="/index/Rec#order_07">Index entries for linear recurrences with constant coefficients</a>, signature (4,14,4,-11,-8,1,1).
%F A397649 G.f.: (1 - x - 4*x^2 - 2*x^3 + 2*x^4 + x^5)/(1 - 4*x - 14*x^2 - 4*x^3 + 11*x^4 + 8*x^5 - x^6 - x^7).
%F A397649 a(n) = 4*a(n-1) + 14*a(n-2) + 4*a(n-3) - 11*a(n-4) - 8*a(n-5) + a(n-6) + a(n-7).
%e A397649 Here is one of the ways to tile a 3 X 10 strip:
%e A397649    ___________________
%e A397649   |_| |___|_| |_|_| |_|
%e A397649   |_   _|___|_| |_   _|
%e A397649   |_|_|___|_|_|_|_|_|_|.
%t A397649 LinearRecurrence[{4, 14, 4, -11, -8, 1, 1}, {1, 3, 22, 132, 839, 5252, 33017}, 30]
%Y A397649 Cf. A033506.
%K A397649 nonn,easy
%O A397649 0,2
