%U A397859 841084460666198,11117910554505105,152939719801413630,2185334293804000497,32379961336405070248
%N A397859 G.f. A(x) satisfies A(x) = 1 + x * (1+x) * A(x * (1+x)^2).
%F A397859 a(0) = 1; a(n) = Sum_{k=0..n-1} binomial(2*k+1,n-k-1) * a(k).
%t A397859 nmax = 25; a[n_] := a[n] = If[n == 0, 1, Sum[Binomial[2*k+1, n-k-1]*a[k], {k, 0, n-1}]]; Table[a[n], {n, 0, nmax}] (* _Vaclav Kotesovec_, Jul 13 2026 *)
%o A397859 (PARI) a_vector(n, s=2, t=1) = my(v=vector(n+1)); v[1]=1; for(i=1, n, v[i+1]=sum(k=0, i-1, binomial(s*k+t, i-k-1)*v[k+1])); v;
