%S A397432 35,39,69,75,87,95,111,133,135,141,147,155,159,171,175,183,187,207,
%T A397432 215,259,261,265,267,279,285,287,291,299,301,303,309,315,319,327,333,
%U A397432 335,339,343,351,363,371,375,391,399,411,423,447,519,525,527,529,531,537
%N A397432 Composites in A161601 whose binary reversal is composite.
%t A397432 p[f_] := Module[{n = 1, c = 0}, Reap[While[c < f, With[{d = IntegerDigits[n, 2]}, With[{r = Reverse[d]}, If[d =!= r && n < FromDigits[r, 2],
%t A397432 Sow[{n, FromDigits[r, 2]}]; c++]]]; n += 2]][[2, 1]]];
%t A397432 u = Select[p[300], !PrimeQ[#[[1]]] && !PrimeQ[#[[2]]] &];
%t A397432 Map[First, u]
%t A397432 (* _Peter J. C. Moses_, Jun 24 2026 *)
