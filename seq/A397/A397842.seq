%N A397842 Numbers k such that sigma(k) = psi(k) + omega(k)^7.
%e A397842 508 is a term since sigma(508) = 896 = 768 + 2^7 = psi(508) + omega(508)^7.
%o A397842 (PARI) isok(k) = {my(f = factor(k)); sigma(f) == prod(i=1, #f~, (f[i, 1]+1) * f[i, 1]^(f[i, 2]-1)) + omega(f)^7; } \\ _Amiram Eldar_, Jul 12 2026
%o A397842 (Python)
%o A397842 from math import prod
%o A397842 from sympy import factorint
%o A397842 def ok(n):
%o A397842     f = factorint(n)
%o A397842     sigma = prod((p**(e+1)-1)//(p-1) for p, e in f.items())
%o A397842     omega = len(f)
%o A397842     psi = prod((p+1)*p**(e-1) for p, e in f.items())
%o A397842     return sigma == psi + omega**7
%o A397842 print([k for k in range(33000) if ok(k)]) # _Michael S. Branicky_, Jul 16 2026
%Y A397842 Cf. A000203 (sigma), A001615 (psi), A001221 (omega), A390251, A390252, A390253.
