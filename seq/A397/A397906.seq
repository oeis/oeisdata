%I A397906 #13 Jul 20 2026 23:42:32
%S A397906 1,2,3,6,21,140,1683,35642,1339169,90158472,10963693807,2424821184086,
%T A397906 981520167227325,731358701194891556,1008526116992564568715,
%U A397906 2586314036542072366240754,12388723098047717714269291865,111288239782787515933227386861248,1881497497414384096201171281066797095
%N A397906 Row sums of triangle A152795.
%H A397906 Paul D. Hanna, <a href="/A397906/b397906.txt">Table of n, a(n) for n = 0..80</a>
%F A397906 a(n) = Sum_{k=0..n} A152795(n,k) for n >= 0.
%F A397906 Equals column 0 of the square of A152795 as a triangular matrix.
%e A397906 Triangle A152795 begins:
%e A397906   1;
%e A397906   1,   1;
%e A397906   1,   1,   1;
%e A397906   1,   3,   1,   1;
%e A397906   1,  11,   7,   1,  1;
%e A397906   1,  59,  63,  15,  1, 1;
%e A397906   1, 507, 847, 295, 31, 1, 1;
%e A397906   ...
%e A397906 the row sums of which form this sequence.
%e A397906 Triangular matrix T = A152795 may be generated by
%e A397906   ShiftUp(T) = T + (T - I)*D*(T - I),
%e A397906 where D = diagonal matrix of powers of 2, I = identity matrix, and ShiftUp(T) = T shifted 1 row up and 1 column left.
%o A397906 (PARI) \\ Generate A152795 Using Matrix Products
%o A397906 {A152795(n, k) = my(M=matrix(2, 2, r, c, if(r>=c, 1)), D, L, S); for(i=2, n,
%o A397906 D = matrix(#M, #M, r, c, if(r==c, 2^(r-1))); \\ D = Diagonal of powers of 2
%o A397906 L = M - M^0; \\ L = M without diagonal of 1's
%o A397906 S = M + L*D*L; \\ S = New matrix, shifted up 1 row and 1 column
%o A397906 M = matrix(#M+1, #M+1, r, c, if(c==1, 1, if(r==1, 0, S[r-1, c-1])) ));
%o A397906 TM = M; M[n+1, k+1]}
%o A397906 \\ Print up to n terms from column 2 of triangle A152795
%o A397906 {upto(n) = A152795(n, n); for(r=0, n, print1( sum(c=0,n,TM[r+1, c+1]), ", "))}
%o A397906 upto(20)
%Y A397906 Cf. A152795, A152796, A152797, A397907.
%K A397906 nonn,new
%O A397906 0,2
%A A397906 _Paul D. Hanna_, Jul 14 2026
