%F A397324 a(n) ~ c * d^n * n! / n, where d = 7.6740613887763091793948695205480360967079681319856915919... and c = 0.3777190228013660867332019485572802011183627312634054244... - _Vaclav Kotesovec_, Jun 26 2026
%p A397324 a := n -> local j; add(Stirling1(n, j)*binomial(n + j, n)*n^j, j = 0..n):
%p A397324 seq(a(n), n = 0..18);
%t A397324 A397324[n_] := If[n == 0, 1, Sum[StirlingS1[n, j]*Binomial[n + j, n]*n^j, {j, n}]];
