%I A397346 #10 Jun 28 2026 01:05:03
%S A397346 1,1,4,66,2248,121690,9370716,966649250,128531346448,21422115304146,
%T A397346 4378265000276660,1077682603965623810,314642031460100660184,
%U A397346 107552396319722414482058,42560722449344419779467596,19307270813913777096663297090,9954384356588211802988067127328,5788726491461269558331566961458594
%N A397346 O.g.f. satisfies A(x) = exp( x + Sum_{n>=2} (2*n^2-1) * a(n)*x^n / (2*n^2) ).
%C A397346 Conjecture: a(n) == [4,2,0,2] repeating (mod 8) for n >= 2.
%C A397346 The limit lim_{n->oo} a(n)/(2^n * n!^2) appears to be finite and nonzero. At n = 1000, a(1000)/(2^1000 * 1000!^2) = 0.382102660872332...
%H A397346 Paul D. Hanna, <a href="/A397346/b397346.txt">Table of n, a(n) for n = 0..520</a>
%F A397346 G.f. A(x) = Sum_{n>=0} a(n)*x^n satisfies the following formulas.
%F A397346 (1) A(x) = exp( A(x) - 1 - Sum_{n>=2} a(n)*x^n / (2*n^2) ).
%F A397346 (2) A(x) = B(x*A(x)^q) where B(x) = A(x/B(x)^q) satisfies (q*n)*[x^n] B(x)^(q*n) = (q*n-1)*[x^n] B(x)^(q*n+1) for n > 1, where q = sqrt(2).
%F A397346 (3) A'(x) = A(x) * (1 + Sum_{n>=1} (2*(n+1)^2-1)/(2*(n+1)) * a(n+1) * x^n ).
%F A397346 (4) A(x) = 1+x + 2*x*(A(x)-1)*(A'(x) + x*A''(x))/A(x) + 2*x^2*A'(x)^2/A(x)^2.
%F A397346 (5) a(n) = 2*n^2/(2*n^2-1) * [x^n] log(A(x)) for n > 1.
%F A397346 (6) a(n) = n*A397347(n)/(n^2-1) for n > 1, where A397347 is the logarithmic derivative of this sequence.
%F A397346 (7) a(n) = 2*n*a(n-1) + n*Sum_{k=1..n-2} (2*(k+1)^2-1)/(k+1) * a(k+1)*a(n-k-1) for n > 1, with a(0) = a(1) = 1.
%e A397346 G.f.: A(x) = 1 + x + 4*x^2 + 66*x^3 + 2248*x^4 + 121690*x^5 + 9370716*x^6 + 966649250*x^7 + 128531346448*x^8 + ...
%e A397346 where
%e A397346 A(x) = exp( x + 7*4*x^2/(2*2^2) + 17*66*x^3/(2*3^2) + 31*2248*x^4/(2*4^2) + 49*121690*x^5/(2*5^2) + 71*9370716*x^6/(2*6^2) + ... + (2*n^2-1)*a(n)*x^n/(2*n^2) + ... ).
%e A397346 RELATED SERIES.
%e A397346 The logarithm of the g.f. A(x) begins
%e A397346 log(A(x)) = x + 7*x^2/2 + 187*x^3/3 + 8711*x^4/4 + 596281*x^5/5 + 55443403*x^6/6 + 6697498375*x^7/7 + ... + A397347(n)*x^n/n + ...
%e A397346 where A397347(n) = (2*n^2-1)*a(n)/(2*n) for n > 1.
%e A397346 The terms a(n) are divisible by n for n > 0:
%e A397346 a(n)/n = [1, 2, 22, 562, 24338, 1561786, 138092750, ...].
%o A397346 (PARI) \\ by a(n) = 2*n^2/(2*n^2-1) * [x^n] log(A)  for n > 1:
%o A397346 {a(n) = my(V=[1, 1], A, m); for(i=2, n, V=concat(V, 0); A = Ser(V); m = #V-1;
%o A397346 V[#V] = (2*m^2-1)*polcoef(A, m) - 2*m^2*polcoef(log(A), m) ); GF=Ser(V); V[n+1]}
%o A397346 \\ returns a vector of terms a(k) for k = 0..n
%o A397346 {upto(n) = a(n); Vec(GF)}
%o A397346 upto(20)
%o A397346 (PARI) \\ by recurrence (slower)
%o A397346 \\ print terms a(n) for n = 0..N
%o A397346 N = 20; A = vector(N+1);
%o A397346 {a(n) = A[n+1] = if(n<=1, 1, 2*n*A[n] + n*sum(k=1, n-2, (2*(k+1)^2-1)/(k+1) * a(k+1) * A[n-k]) )}
%o A397346 for(n=0, N, print1(a(n), ", "))
%Y A397346 Cf. A397242, A397245, A397347, A397348.
%K A397346 nonn
%O A397346 0,3
%A A397346 _Paul D. Hanna_, Jun 26 2026
