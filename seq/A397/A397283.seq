%U A397283 39422023280640000,45407768445591552000,646324747492206182400,3487970512389242880000,2758527695206021939200000
%N A397283 Expansion of e.g.f. (1/x) * Series_Reversion( x + log(1-x^4) ).
%F A397283 E.g.f. A(x) satisfies A(x) = 1 - log(1 - (x * A(x))^4)/x.
%F A397283 a(n) = (1/(n+1)) * Sum_{k=ceiling(n/4)..floor(n/3)} (4*k)!/k! * |Stirling1(k,4*k-n)|.
%F A397283 a(n) ~ 2*n^(n-1) / (sqrt(4 + 6*sqrt(2) + 6*sqrt(-2 + 4*sqrt(2))) * exp(n) * (sqrt(5/2 + 2*sqrt(2)) - 1 - 1/sqrt(2) + log(-64 - 46*sqrt(2) + 20*sqrt(5 + 4*sqrt(2)) + 14*sqrt(10 + 8*sqrt(2))))^(n + 1/2)). - _Vaclav Kotesovec_, Jun 20 2026
%t A397283 Table[1/(n+1) * Sum[(4*k)!/k! * Abs[StirlingS1[k,4*k-n]], {k,Ceiling[n/4],Floor[n/3]}], {n,0,25}] (* _Vaclav Kotesovec_, Jun 20 2026 *)
%o A397283 (PARI) my(N=30, x='x+O('x^N)); Vec(serlaplace(serreverse(x+log(1-x^4))/x))
%Y A397283 Cf. A213641, A397282.
%K A397283 nonn,new
%O A397283 0,4
