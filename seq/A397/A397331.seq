%I A397331 #12 Jun 23 2026 05:46:46
%S A397331 1,0,1,1,3,1,8,19,9,1,81,175,97,18,1,1024,2101,1275,305,30,1,15625,
%T A397331 31031,19981,5590,740,45,1,279936,543607,365001,113701,18200,1526,63,
%U A397331 1,5764801,11012415,7628545,2571114,470631,48678,2814,84,1
%N A397331 Triangle read by rows: T(n, k) = P(n, k, -1) where P(n, k, x) = (1/k!) * Sum_{j=0..k}((-1)^(k - j) * binomial(k, j) * (n + x + j)^n).
%C A397331 For comments and a table of the polynomials see A397333, which is the main entry for this family of triangles.
%F A397331 T(n, k) = T(n - 1, k - 1) + (n + 2*k - 1) * T(n - 1, k) + (n + k - 1) * (k + 1) * T(n - 1, k + 1) and T(n, n) = 1.
%F A397331 T(n, k) = [x^k] b(n, n) where b(n, k) = (k - 1)*b(n-1, k) + x*b(n-1, k+1) if n > 0 and b(0, k) = 1.
%e A397331 Triangle starts:
%e A397331   [0]       1;
%e A397331   [1]       0,        1;
%e A397331   [2]       1,        3,       1;
%e A397331   [3]       8,       19,       9,       1;
%e A397331   [4]      81,      175,      97,      18,      1;
%e A397331   [5]    1024,     2101,    1275,     305,     30,     1;
%e A397331   [6]   15625,    31031,   19981,    5590,    740,    45,    1;
%e A397331   [7]  279936,   543607,  365001,  113701,  18200,  1526,   63,  1;
%e A397331   [8] 5764801, 11012415, 7628545, 2571114, 470631, 48678, 2814, 84, 1;
%p A397331 T := proc(n, k) option remember; if n = k then return 1 fi; if k < 0 or k > n then return 0 fi; T(n - 1, k - 1) + (n + 2*k - 1) * T(n - 1, k) + (n + k - 1) * (k + 1) * T(n - 1, k + 1) end:
%p A397331 # Alternative:
%p A397331 P := (n, k, x) -> local j; add((-1)^(k - j) * binomial(k, j) * (n + x + j)^n , j = 0..k) / k!: T := (n, k) -> P(n, k, -1): seq(seq(T(n, k), k = 0..n), n = 0..9);
%t A397331 b[a_, 0, k_] := 1
%t A397331 b[a_, n_, k_] := b[a, n, k] = (k + a) b[a, n - 1, k] + x b[a, n - 1, k + 1];
%t A397331 TRow[a_, n_] := CoefficientList[b[a, n, n], x]
%t A397331 Table[TRow[-1, n], {n, 0, 8}] // Flatten
%o A397331 (SageMath)
%o A397331 R.<z> = ZZ[]
%o A397331 @cached_function
%o A397331 def b(a, n, k):
%o A397331     if n == 0: return R(1)
%o A397331     return (k + a)*b(a, n-1, k) + z*b(a, n-1, k+1)
%o A397331 def T_row(a, n) -> list[int]: return list(b(a, n, n))
%o A397331 for n in range(9): print(T_row(-1, n))
%Y A397331 Cf. A065440 (column 0), A045943 (subdiagonal), A397330 (row sums), A397333 (p(x=1)), A397331 (p(x=-1)), A397329 (p(x=1/2)), A397048 (p(x=0)).
%K A397331 nonn,tabl,new
