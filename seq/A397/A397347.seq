%S A397347 1,7,187,8711,596281,55443403,6697498375,1020217562431,
%T A397347 191608920220417,43563736752752767,11805523070714333555,
%U A397347 3762594292877037061367,1394044521528709756940521,594330088489059576206136787,288965486514909530546727346447,158959075194268007228965696939519,98238093693328015739921004022400257
%N A397347 L.g.f. Sum_{n>=1} a(n)*x^n/n = log(1+x + Sum_{n>=2} 2*n/(2*n^2-1) * a(n)*x^n ).
%C A397347 Conjecture: a(n) == [1,3,3,3] (mod 4) for n >= 1.
%H A397347 Paul D. Hanna, <a href="/A397347/b397347.txt">Table of n, a(n) for n = 1..400</a>
%F A397347 L.g.f. L(x) = Sum_{n>=1} a(n)*x^n/n satisfies the following formulas.
%F A397347 (1) L(x) = log(1+x + Sum_{n>=2} 2*n/(2*n^2-1) * a(n)*x^n ).
%F A397347 (2) L(x) equals the logarithm of the g.f. of A397346.
%F A397347 (3) a(n) = (2*n^2-1)/(2*n) * A397346(n) for n > 1 with a(1) = 1.
%e A397347 L.g.f.: L(x) = x + 7*x^2/2 + 187*x^3/3 + 8711*x^4/4 + 596281*x^5/5 + 55443403*x^6/6 + 6697498375*x^7/7 + 1020217562431*x^8/8 + ...
%e A397347 where exponentiation yields the g.f. of A397346
%e A397347 exp(L(x)) = 1 + x + 4*x^2 + 66*x^3 + 2248*x^4 + 121690*x^5 + 9370716*x^6 + 966649250*x^7 + ... + 2*n/(2*n^2-1) * a(n)*x^n + ...
%o A397347 (PARI) {a(n) = my(L=[0, 1], A, m); for(i=2, n, L=concat(L, 0); A = exp(Ser(L)); m = #L-1;
%o A397347 L[#L] = (2*m^2-1)*polcoef(A, m) - 2*m^2*polcoef(log(A), m) ); GF=Ser(L); L[n+1]}
%o A397347 \\ returns a vector of terms a(k) for k = 1..n
%o A397347 {upto(n) = a(n); Vec(GF')}
%o A397347 upto(25)
%Y A397347 Cf. A397346, A396846, A397349.
%K A397347 nonn
%O A397347 1,2
