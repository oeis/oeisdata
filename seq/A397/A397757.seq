%S A397757 6,9,14,17,21,24,29,32,36,40,44,47,51,55,59,62,66,70,74,77,81,85,89,
%T A397757 92,96,100,104,107,111,115,119,122,126,130,134,137,141,145,149,152,
%U A397757 156,160,164,167,171,175,179,182,186,190,194,197,201,205,209,212,216,220,224,227
%N A397757 Maximum length of a snake polyomino in a 6 X n rectangle.
%C A397757 For n > 6, there always exist snakes in this family that are generated by the concatenation of 6 X 4 tiles of area 15 plus other tiles at the extremities.
%H A397757 Andrew Howroyd, <a href="/A397757/b397757.txt">Table of n, a(n) for n = 1..10000</a>
%H A397757 Alexandre Blondin Massé and Alain Goupil, <a href="https://arxiv.org/abs/2606.13155">Snake Polyominoes of Maximal Area in a Rectangle</a>, arXiv:2606.13155 [cs.DM], 2026.
%H A397757 Alexandre Blondin Massé and Alain Goupil, <a href="https://gascom2026.dista.uninsubria.it/accepted-papers">Thin snake-like polyominoes of maximal length</a>, EPTCS 445: GASCom 2026 (2026), pp. 29-37.
%H A397757 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (1,0,0,1,-1).
%F A397757 Conjecture: a(n) = 2 + 15*n/4 + (n mod 4)/4 for n > 6.
%F A397757 From _Andrew Howroyd_, Jul 13 2026: (Start)
%F A397757 The above formula is correct. It was confirmed via the transfer-matrix method.
%F A397757 a(n) = a(n-4) + 15 for n >= 11.
%F A397757 G.f.: x*(6 + 3*x + 5*x^2 + 3*x^3 - 2*x^4 + x^9 - x^10)/((1 - x)^2*(1 + x)*(1 + x^2)). (End)
%F A397757 E.g.f.: 5*(2 + 3*x)*sinh(x)/4 - sin(x)/4 + 3*(3 + 5*x)*cosh(x)/4 - cos(x)/4 - x^2*(360 + x^4)/720 - 2. - _Stefano Spezia_, Jul 15 2026
%e A397757 For n=6, the maximum length of a snake polyomino in a 6 X 6 rectangle is 24 = 15/24*6*6 + 1 + (6 mod 4)/4.
%e A397757 For n=7, the maximum length of a snake polyomino in a 6 X 7 rectangle is 29 = 15/24*6*7 + 2 + (7 mod 4)/4.
%p A397757 exact6 := proc(n) if n in {2, 6} then 15/4*n + 1 + 1/4*modp(n, 4); else 15/4*n + 2 + 1/4*modp(n, 4); end if; end proc;
%t A397757 A397757[n_] := (8 + 15*n + Mod[n, 4])/4 - Boole[n == 2 || n == 6]; Array[A397757, 100] (* _Paolo Xausa_, Jul 21 2026 *)
%t A397757 (* Alternative: *)
%t A397757 LinearRecurrence[{1, 0, 0, 1, -1}, {6, 9, 14, 17, 21, 24, 29, 32, 36, 40, 44}, 100] (* _Paolo Xausa_, Jul 21 2026 *)
