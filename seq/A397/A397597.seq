%I A397597 #9 Jul 16 2026 00:46:57
%S A397597 1,1,2,5,24,313,13394,2226675,1693625476,6793024920197,
%T A397597 161377440068823558,25204121915499676541959,
%U A397597 28539366512411687944532113160,257063817780444483794734441749649161,20081983771581527729880421322314599177437962,14713549101030860437867649367707840835728169295172363
%N A397597 a(n) = Sum_{k=0..n-1} A009963(n-1,k) * a(k) for n > 0, with a(0) = 1, where A009963(n,k) = F(n)/(F(k)*F(n-k)) and F(n) = Product_{k=0..n} k! is the superfactorial of n (A000178).
%C A397597 Also A009963(n,k) = Product_{j=1..k} (n+1-j)! / j!.
%H A397597 Paul D. Hanna, <a href="/A397597/b397597.txt">Table of n, a(n) for n = 0..50</a>
%F A397597 a(n) = Sum_{k=0..n-1} a(k) * Product_{j=1..k} (n-j)!/j! for n > 0, with a(0) = 1.
%e A397597 The terms may be computed from triangle A009963 as follows.
%e A397597 Starting with a(0) = 1,
%e A397597   a(1) = 1*(1) = 1;
%e A397597   a(2) = 1*(1) + 1*(1) = 2;
%e A397597   a(3) = 1*(1) + 2*(1) + 1*(2) = 5;
%e A397597   a(4) = 1*(1) + 6*(1) + 6*(2) + 1*(5) = 24;
%e A397597   a(5) = 1*(1) + 24*(1) + 72*(2) + 24*(5) + 1*(24) = 313;
%e A397597   etc.
%e A397597 where triangle A009963(n, k) = F(n)/(F(k)*F(n-k)) begins
%e A397597   1;
%e A397597   1,   1;
%e A397597   1,   2,    1;
%e A397597   1,   6,    6,    1;
%e A397597   1,  24,   72,   24,   1;
%e A397597   1, 120, 1440, 1440, 120, 1;
%e A397597   ...
%e A397597 here, F(n) = Product_{k=0..n} k! is the superfactorial of n:
%e A397597 A000178 = [1, 1, 2, 12, 288, 34560, 24883200, ...].
%o A397597 (PARI) \\ by definition (slow)
%o A397597 {F(n) = prod(k=1, n, k!)} \\ superfactorial of n
%o A397597 {A009963(n, k) = F(n)/(F(k)*F(n-k))}
%o A397597 {a(n) = if(n==0,1, sum(k=0,n-1, A009963(n-1,k)*a(k)))}
%o A397597 for(n=0,20,print1(a(n),", "))
%o A397597 (PARI) \\ explicit recurrence using vector (fast)
%o A397597 N = 20; \\ N = number of terms to print
%o A397597 {a(n) = if(n==0,A=vector(N+1);A[1]=1, A[n+1] = sum(k=0,n-1, A[k+1] * prod(j=1,k, (n-j)!/j! ) ) )}
%o A397597 for(n=0,N,print1(a(n),", "))
%Y A397597 Cf. A009963, A000178, A397589 (variant), A000110 (Bell numbers).
%K A397597 nonn,new
%O A397597 0,3
%A A397597 _Paul D. Hanna_, Jul 13 2026
