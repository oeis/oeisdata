%N A397224 Number of ordered pairs (i,j) such that i*j=n and |i-j| is a perfect square.
%C A397224 a(n) is odd if and only if n is square. - _Chai Wah Wu_, Jun 19 2026
%e A397224 a(36) = 5. Pairs here are (18, 2), (2, 18), (6, 6), (12, 3), (3, 12).
%o A397224 (Python)
%o A397224 from itertools import takewhile
%o A397224 from sympy import divisors
%o A397224 from sympy.ntheory.primetest import is_square
%o A397224 def A397224(n): return (sum(1 for d in takewhile(lambda d:d**2<n, divisors(n)) if is_square(n//d-d))<<1)+is_square(n) # _Chai Wah Wu_, Jun 19 2026
