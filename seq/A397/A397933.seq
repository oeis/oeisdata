%I A397933 #7 Jul 22 2026 22:41:42
%S A397933 18,24,40,45,56,63,88,99,104,117,136,152,153,171,184,207,232,248,261,
%T A397933 279,296,328,333,344,369,376,387,423,424,472,477,488,531,536,549,568,
%U A397933 584,603,632,639,657,664,711,712,747,776,801,808,824,856,872,873,904,909
%N A397933 Numbers k that are neither squarefree nor powerful such that rad(k)*bigomega(k) = k, where rad = A007947 and bigomega = A001222.
%C A397933 A396594 is the union of this sequence and A175787 (the primes and 4).
%C A397933 Intersection of A332785 and A396594.
%C A397933 A397658 \ {2, 4} is a proper subset.
%H A397933 Michael De Vlieger, <a href="/A397933/b397933.txt">Table of n, a(n) for n = 1..10000</a>
%e A397933 Table of n, a(n) for select n:
%e A397933      n     a(n) = k                          rad(k) * bigomega(k)
%e A397933   ---------------------------------------------------------------
%e A397933      1       18 = 2 * 3^2                         6 * 3
%e A397933      2       24 = 2^3 * 3                         6 * 4
%e A397933      3       40 = 2^3 * 5                        10 * 4
%e A397933      4       45 = 3^2 * 5                        15 * 3
%e A397933      5       56 = 2^3 * 7                        14 * 4
%e A397933      6       63 = 3^2 * 7                        21 * 3
%e A397933     61     1050 = 2 * 3 * 5^2 * 7               210 * 5
%e A397933     71     1260 = 2^2 * 3^2 * 5 * 7             210 * 6
%e A397933    770    18480 = 2^4 * 3 * 5 * 7 * 11         2310 * 8
%e A397933   7528   210210 = 2 * 3 * 5 * 7^2 * 11 * 13   30030 * 7
%t A397933 rad[x_] := Times @@ FactorInteger[x][[All, 1]]; s = Select[Range[10^3], Not @* PrimePowerQ]; Select[s, # == rad[#]*PrimeOmega[#] &]
%Y A397933 Cf. A001222, A007947, A175787, A332785, A396594, A397658, A397932, A397934.
%K A397933 nonn,new
%O A397933 1,1
%A A397933 _Michael De Vlieger_, _James C. McMahon_, and _Vincenzo Manto_, Jul 16 2026
