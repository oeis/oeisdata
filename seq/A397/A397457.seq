%S A397457 1,3,14,176,3190,197064,5803182,476737560,19555012620,2033995195440,
%T A397457 464996881825905,27985898092370400,7154846849480939700,
%U A397457 999252888102876459864,79655506851519021246120,12941231844900315279655152,4130428218282524393306784090
%N A397457 a(n) = Product_{k=1..n} (prime(n) + 1/k).
%C A397457 This sequence shows a way to characterize prime numbers without using them as divisor. prime(n) is the smallest integer > 1 such that the product Product_{k=1..prime(n-1)} (prime(n) + 1/k) gives us an integer result. If we use the Product_{k=1..n} instead like in the definition of this sequence, we will get an integer result for the first prime that is no factor in n! already.
%F A397457 a(n) = prime(n)^n*Gamma(n + 1 + 1/prime(n))/(Gamma(1 + 1/prime(n))*n!), for n > 0.
%F A397457 a(n) ~ prime(n)^n*exp(H_n/prime(n)), where H_n is the n-th harmonic number.
%F A397457 a(n) = prime(n)^n*binomial(n + 1/prime(n), n), for n > 0.
%F A397457 a(n)*n! mod prime(n) = 1.
%F A397457 a(n)*n! = Sum_{m=0..n} Stirling1(n+1, n-m+1)*(-prime(n))^m.
%F A397457 log(a(n)) = n*log(prime(n)) + Sum_{k=1..n} ((-1)^k/(k*prime(n)^k))*Sum_{m=1..n} (1/m^k).
%F A397457 a(n)*n!-1 == prime(n)*n*(n+1)/2 (mod prime(n)^2).
%p A397457 a:= n-> mul(ithprime(n)+1/k, k=1..n):
%p A397457 seq(a(n), n=0..17);  # _Alois P. Heinz_, Jun 26 2026
%t A397457 a[n_] := With[{p = Prime[n]}, Pochhammer[1 + 1/p, n] * p^n / n!]; a[0] = 1; Array[a, 17, 0] (* _Amiram Eldar_, Jun 26 2026 *)
%o A397457 (PARI) a(n) = {my(p = if(n>0, prime(n), 1)); prod(k=1, n, k*p+1)/n!}
%o A397457 (Python)
%o A397457 from fractions import Fraction
%o A397457 from sympy import prime, binomial
%o A397457 def A397457(n): return int((p:=prime(n))**n*binomial(n+Fraction(1,p),n)) if n else 1 # _Chai Wah Wu_, Jun 27 2026
%Y A397457 Cf. A000040 (primes), A048994 (Stirling1), A062457.
