%I A397589 #12 Jul 16 2026 00:46:48
%S A397589 1,1,2,7,89,5594,2086845,5999277166,162209867361537,
%T A397589 47225351952328420610,164578486556188142664328341,
%U A397589 7970352146856493573883027287528342,6087775211847302535380674794014999738485305,80601590299179955387690999136973644595591120823945786
%N A397589 a(n) = Sum_{k=0..n-1} A396840(n-1,k) * a(k) for n > 0, with a(0) = 1, where A396840(n,k) = H(n)/(H(k)*H(n-k)) and H(n) = Product_{k=0..n} k^k is the hyperfactorial of n (A002109).
%C A397589 Also A396840(n,k) = Product_{j=1..k} (n+1-j)^(n+1-j) / j^j.
%H A397589 Paul D. Hanna, <a href="/A397589/b397589.txt">Table of n, a(n) for n = 0..45</a>
%F A397589 a(n) = Sum_{k=0..n-1} a(k) * Product_{j=1..k} (n-j)^(n-j)/j^j for n > 0, with a(0) = 1.
%e A397589 The terms may be computed from triangle A396840 as follows.
%e A397589 Starting with a(0) = 1,
%e A397589   a(1) = 1*(1) = 1;
%e A397589   a(2) = 1*(1) + 1*(1) = 2;
%e A397589   a(3) = 1*(1) + 4*(1) + 1*(2) = 7;
%e A397589   a(4) = 1*(1) + 27*(1) + 27*(2) + 1*(7) = 89;
%e A397589   a(5) = 1*(1) + 256*(1) + 1728*(2) + 256*(7) + 1*(89) = 5594;
%e A397589   etc.
%e A397589 where triangle A396840(n, k) = H(n)/(H(k)*H(n-k)) begins
%e A397589   1;
%e A397589   1, 1;
%e A397589   1, 4, 1;
%e A397589   1, 27, 27, 1;
%e A397589   1, 256, 1728, 256, 1;
%e A397589   1, 3125, 200000, 200000, 3125, 1;
%e A397589   ...
%e A397589 and H(n) = Product_{k=0..n} k^k is the hyperfactorial of n:
%e A397589 A002109 = [1, 1, 4, 108, 27648, 86400000, ...].
%o A397589 (PARI) \\ by definition (slow)
%o A397589 {H(n) = prod(k=1, n, k^k)} \\ hyperfactorial of n
%o A397589 {A396840(n, k) = H(n)/(H(k)*H(n-k))}
%o A397589 {a(n) = if(n==0,1, sum(k=0,n-1, A396840(n-1,k)*a(k)))}
%o A397589 for(n=0,20,print1(a(n),", "))
%o A397589 (PARI) \\ explicit recurrence using vector (fast)
%o A397589 N = 20; \\ N = number of terms to print
%o A397589 {a(n) = if(n==0,A=vector(N+1);A[1]=1, A[n+1] = sum(k=0,n-1, A[k+1] * prod(j=1,k, (n-j)^(n-j)/j^j ) ) )}
%o A397589 for(n=0,20,print1(a(n),", "))
%Y A397589 Cf. A396840, A002109, A397597 (variant), A000110 (Bell numbers).
%K A397589 nonn,new
%O A397589 0,3
%A A397589 _Paul D. Hanna_, Jul 13 2026
