%H A397181 Michael S. Branicky, <a href="/A397181/b397181.txt">Table of n, a(n) for n = 1..20000</a>
%o A397181 (Python)
%o A397181 from collections import Counter
%o A397181 from itertools import count, islice
%o A397181 def A397181_gen(): # generator of terms
%o A397181     alst, an, c = [], 0, Counter()
%o A397181     yield 0
%o A397181     for n in count(1):
%o A397181         an = c[an]
%o A397181         c.update(an+ai for ai in alst)
%o A397181         if n >= 2: yield 1 + max(c.keys())
%o A397181         alst.append(an)
%o A397181 print(list(islice(A397181_gen(), 68))) # _Michael S. Branicky_, Jul 02 2026
