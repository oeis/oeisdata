%I A397305 #21 Jun 28 2026 00:13:06
%S A397305 8,12,14,16,20,22,24,26,28,30,32,36,38,40,42,44,46,48,50,52,54,56,58,
%T A397305 60,62,64,68,70,72,74,76,78,80,82,84,86,88,90,92,94,96,98,100,102,104,
%U A397305 106,108,110,112,114,116,118,120,122,124,126,127,128,132,134,136,138,140,142,144,146,148,149
%N A397305 Positive numbers m such that m - 2^k is composite for all k > 0 with 2^k < m.
%C A397305 Inspired by A039669 where "prime" is replaced here by "composite".
%C A397305 Subsequence of even terms correspond to {m = 2*s : 2*s <> 2^r+2} = A299174 \ {A052548 \ 3}.
%C A397305 Subsequence of odd terms are de Polignac numbers: A006285 \ {1}.
%e A397305 30 is a term as 30-2, 30-4, 30-8, 30-16, i.e., 28, 26, 22 and 14 are all composites.
%e A397305 127 is a term (least odd term) as 127-2, 127-4, 127-8, 127-16, 127-32, 127-64, i.e., 125, 123, 119, 111, 95 and 63 are all composites.
%e A397305 34 is not a term as 34-32 = 2 is prime.
%p A397305 with(numtheory):
%p A397305 Suite1 := proc(N)
%p A397305 local n,k,m,L,test;
%p A397305     L := [];
%p A397305     for n from 4 to N do
%p A397305         test := true;
%p A397305         k := 1;
%p A397305         while 2^k < n do
%p A397305             m := n - 2^k;
%p A397305             if isprime(m) then
%p A397305                 test := false;
%p A397305                 break;
%p A397305             end if;
%p A397305             k := k+1;
%p A397305         od;
%p A397305         if test then
%p A397305             L := [op(L), n];
%p A397305         end if;
%p A397305     od;
%p A397305     return L;
%p A397305 end proc:
%p A397305 Suite1(150);
%o A397305 (PARI) isok(m) =  if (m>2, for (k=1, logint(m,2), my(c); if (isprime(c=m-2^k) || (c==1), return(0))); 1); \\ _Michel Marcus_, Jun 22 2026
%Y A397305 Cf. A006285, A039669, A052548.
%K A397305 nonn
%O A397305 1,1
%A A397305 _Bernard Schott_, Jun 20 2026
