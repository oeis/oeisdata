%N A397178 Irregular triangle read by rows: T(n,k) (n >= 1, k >= 0) = number of times k appears in the first n terms of A394611.
%C A397178 In row n, k ranges from 0 to max{A394611(i): 0 <= i <= n}.
%C A397178 The "length" L(n) of row n is defined to be 1 + max{A394611(i): 0 <= i <= n}.
%C A397178 Row n is an inventory of the first n terms of A394611, that is, the number of 0's, 1's, ..., m's in A394611(1)..A394611(n) where m = max_{k=1..n} A394611(k). The sum of row n is n. - _Michael S. Branicky_, Jul 01 2026
%H A397178 N. J. A. Sloane, <a href="/A397178/b397178.txt">Table of n, a(n) for n = 1..3743</a> (The first 100 rows, flattened)
%F A397178 From _Michael S. Branicky_, Jul 01 2026: (Start)
%F A397178 T(n, k) = #{ h in 1..n | A394611(h) = k}.
%F A397178 Sum_k T(n, k) = n. (End)
%e A397178 The first 12 rows are:
%e A397178   n L(n) row n
%e A397178   1, 1, [1]
%e A397178   2, 1, [2]
%e A397178   3, 2, [2, 1]
%e A397178   4, 3, [2, 1, 1]
%e A397178   5, 3, [2, 1, 2]
%e A397178   6, 5, [2, 1, 2, 0, 1]
%e A397178   7, 5, [2, 1, 2, 1, 1]
%e A397178   8, 5, [2, 1, 2, 1, 2]
%e A397178   9, 7, [2, 1, 2, 1, 2, 0, 1]
%e A397178   10, 7, [2, 1, 2, 1, 2, 0, 2]
%e A397178   11, 9, [2, 1, 2, 1, 2, 0, 2, 0, 1]
%e A397178   12, 9, [2, 1, 2, 1, 2, 0, 2, 1, 1]
%e A397178 ...
%o A397178 (Python)
%o A397178 from collections import Counter
%o A397178 from itertools import count, islice
%o A397178 def A397178_gen(): # generator of terms
%o A397178     alst, an, c, b, m = [], 0, Counter(), Counter(), -1
%o A397178     for n in count(1):
%o A397178         an = c[an]
%o A397178         c.update(an+ai for ai in alst)
%o A397178         alst.append(an)
%o A397178         b[an] += 1
%o A397178         m = max(m, an)
%o A397178         yield from (b[i] for i in range(m+1))
%o A397178 print(list(islice(A397178_gen(), 114))) # _Michael S. Branicky_, Jul 01 2026
