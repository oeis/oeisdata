%F A397285 a(n) ~ exp(1/2 + exp(-1)) * 2^(n-1) * n^(n-1). - _Vaclav Kotesovec_, Jul 02 2026
%p A397285 P := (x, n, k) -> x * (n - k + x)^(n - k - 1) * binomial(n, k):
%p A397285 seq(add(2^n * P(1/2, n, k), k = 0..n), n = 0..18);
%t A397285 A397285[n_] := Sum[2^k*(2*(n - k) + 1)^(n - k - 1)*Binomial[n, k], {k, 0, n}];
