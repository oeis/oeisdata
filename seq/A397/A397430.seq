%I A397430 #12 Jul 01 2026 17:07:29
%S A397430 19,79,103,137,139,149,157,179,191,239,271,281,293,311,317,347,367,
%T A397430 379,439,523,541,547,557,563,569,587,607,613,647,659,719,733,743,751,
%U A397430 787,811,859,863,887,919,991,1031,1039,1051,1061,1063,1069,1097,1103,1123
%N A397430 Primes in A161601 whose binary reversal is composite.
%e A397430 19 = (10011)_2 has reversal (11011)_2, which is 25, a composite, so 19 is in the sequence.
%t A397430 p[f_] := Module[{n = 1, c = 0}, Reap[While[c < f, With[{d = IntegerDigits[n, 2]}, With[{r = Reverse[d]}, If[d =!= r && n < FromDigits[r, 2],
%t A397430 Sow[{n, FromDigits[r, 2]}]; c++]]]; n += 2]][[2, 1]]];
%t A397430 u = Select[p[300], PrimeQ[#[[1]]] && !PrimeQ[#[[2]]] &];
%t A397430 Map[First, u]
%t A397430 (* _Peter J. C. Moses_, Jun 24 2026 *)
