%N A397999 E.g.f. A(x) satisfies A'(x) = 1 + A(-log(1-2*x)/2), with A(0) = 0.
%F A397999 a(1) = 1; a(n+1) = Sum_{k=1..n} 2^(n-k) * |Stirling1(n,k)| * a(k).
%o A397999 (PARI) a_vector(n) = my(v=vector(n)); v[1]=1; for(i=1, n-1, v[i+1]=sum(j=1, i, 2^(i-j)*abs(stirling(i, j, 1))*v[j])); v;
