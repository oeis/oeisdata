%I A397580 #11 Jul 05 2026 03:28:30
%S A397580 0,2,21,228,2805,39330,623385,11055240,217237545,4689345150,
%T A397580 110367613125,2813814441900,77270219351325,2274248091965850,
%U A397580 71429313459128625,2384782564350186000,84344886515269004625,3150403792223415477750,123926562918547083820125,5121078407394641183992500
%N A397580 a(n) = n*A122649(n) = n*((2*n - 1)!! - (2*n - 2)!!).
%C A397580 This sequence gives the number of rooted binary non-plane leaf-labeled general galled trees with n leaves and exactly 1 gall.
%C A397580 This is column g=1 of the array \tilde{e}_{n,g} in Table 2 of Agranat-Tamir, Fuchs, Gittenberger, Rosenberg, and Seetharaman.
%C A397580 For n >= 2, the terms also count tree-child, reticulation-visible, and orchard phylogenetic networks with n leaves and exactly one reticulation node; this is column k=1 in the corresponding tables of Batle (2026).
%H A397580 Lily Agranat-Tamir, Michael Fuchs, Bernhard Gittenberger, Noah A. Rosenberg, and Karthik V. Seetharaman, <a href="https://arxiv.org/abs/2601.08062">Combinatorial comparison of general galled trees, time-consistent galled trees, and simplex time-consistent galled trees</a>, arXiv:2601.08062 [math.CO], 2026. See Table 2 and Eq. (24).
%H A397580 Josep Batle, <a href="https://arxiv.org/abs/2606.24325">Exact Enumeration of Phylogenetic Networks: The Tree-Child, Reticulation-Visible and Orchard Hierarchy</a>, arXiv:2606.24325 [math.CO], 2026. See Table 2, column k=1, for reticulation-visible networks; see Tables 4 and 5, column/row k=1, for orchard networks.
%H A397580 Louxin Zhang, <a href="https://doi.org/10.1186/s12859-019-3209-3">Generating normal networks via leaf insertion and nearest neighbor interchange</a>, BMC Bioinformatics 20, 642 (2019). See Theorem 4.
%F A397580 a(n) = A396954(n) + 2*A035101(n).
%F A397580 E.g.f.: x*((1 - 2*x)^(-3/2) - 1/(1 - 2*x)).
%F A397580 Limit_{n->oo} a(n) / (n^(n+1)*(2/e)^n) = sqrt(2).
%F A397580 For n >=1, a(n) = A001879(n-1) - A002866(n) = (2*n)!/(2^n*(n-1)!) - 2^(n-1)*n!.
%F A397580 a(1) = 0, and for n >= 2: a(n) = n*(2*n - 1)*a(n-1)/(n - 1) + n*2^(n-2)*(n-2)!.
%e A397580 a(4) = 4*(7!! - 6!!) = 4*(105 - 48) = 228.
%p A397580 a := n -> (2*n)!/(2^n*(n-1)!) - 2^(n-1)*n!: seq(a(n), n=1..20);
%t A397580 a[n_]:=n*((2*n - 1)!! - (2*n - 2)!!); Array[a,20] (* _Stefano Spezia_, Jul 02 2026 *)
%o A397580 (Python)
%o A397580 from math import factorial, comb
%o A397580 def A397580(n: int) -> int:
%o A397580     fact = factorial(n)
%o A397580     comb2 = comb(2 * n, n)
%o A397580     numerator = fact * (n * comb2 - (1 << (2 * n - 1)))
%o A397580     return numerator // (1 << n)
%o A397580 A = [A397580(i) for i in range(1, 21)]; print(A)  # _Peter Luschny_, Jul 02 2026
%Y A397580 Cf. A001879, A002866, A035101, A122649, A396954.
%K A397580 nonn,easy,new
%O A397580 1,2
