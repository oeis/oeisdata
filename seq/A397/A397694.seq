%S A397694 3,1,2,3,1,2,3,1,2,3,13,11,12,13,11,12,13,11,12,13,23,21,22,23,21,22,
%T A397694 23,21,22,23,33,31,32,33,31,32,33,31,32,33,13,11,12,13,11,12,13,11,12,
%U A397694 13,23,21,22,23,21,22,23,21,22,23,33,31,32,33,31,32,33,31
%N A397694 Residues of decimal digits mod 3, with 0 represented by 3.
%C A397694 If n = d_1 d_2 ... d_m, then the i-th digit of a(n) is d_i mod 3 + 3*[d_i mod 3 = 0], where [.] is the Iverson bracket. Alternatively, the i-th digit of a(n) is k in 1..3 such that k == d_i (mod 3).
%H A397694 Michael S. Branicky, <a href="/A397694/b397694.txt">Table of n, a(n) for n = 0..10000</a>
%e A397694 a(57) = 21 since 5 mod 3 = 2 and 7 mod 3 = 1.
%e A397694 a(68) = 32 since 6 mod 3 = 0 (which is encoded as 3) and 8 mod 3 = 2.
%t A397694 A397694[n_] := FromDigits[Mod[IntegerDigits[n], 3] /. 0 -> 3];
%t A397694 Array[A397694, 100, 0] (* _Paolo Xausa_, Jul 05 2026 *)
%o A397694 (Python)
%o A397694 def a(n): return int("".join(map(str, [(r:=di%3)+3*int(r==0) for di in list(map(int, str(n)))])))
%o A397694 print([a(n) for n in range(68)])
%Y A397694 Cf. A007932, A010882, A397643, A397644.
%K A397694 nonn,base,easy,new
%O A397694 0,1
