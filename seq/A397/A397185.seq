%T A397185 166027,332053,664107,1328197,2656395,5312789,10625579,21251141,
%U A397185 42502283,85004565,170009131,340018245,680036491,1360072981,2720145963,5440291909,10880583819
%N A397185 a(n) is the smallest positive integer m such that every even integer from 2 to 2n can be expressed as a sum of two (not necessarily distinct) 1-bit positions in the binary expansion of m.
%C A397185 Let P(m) be the set of 1-based positions of the 1-bits of m (the least significant bit is position 1).
%C A397185 For a given m, let S(m) = {p+q | p,q in P(m)}. Then a(n) is the smallest m such that S(m) contains all even numbers 2, 4, 6, ..., 2n.
%C A397185 Equivalently, a(n) is the first integer that achieves a new maximum for the largest even number up to which the pairwise sums cover the even range without gaps.
%F A397185 Conjecture: a(2k) = 2*a(2k-1) + 1.
%F A397185 a(n) <= 2*a(n) + 1. - _Sean A. Irvine_, Jun 23 2026
%e A397185 a(1) = 1: binary 1 -> positions {1} -> sums give {2} -> covers up to 2.
%e A397185 a(2) = 3: binary 11 -> positions {1,2} -> sums give {2,4} -> covers up to 4.
%e A397185 a(3) = 5: binary 101 -> positions {1,3} -> sums give {2,4,6} -> covers up to 6.
%e A397185 a(4) = 11: binary 1011 -> positions {1,2,4} -> sums give {2,4,6,8} -> covers up to 8.
%o A397185 (Python)
%o A397185 def pos(n):
%o A397185     return [i+1 for i,b in enumerate(bin(n)[:1:-1]) if b=='1']
%o A397185 seq = []
%o A397185 best = 0
%o A397185 n = 1
%o A397185 while len(seq) < 20:
%o A397185     p = pos(n)
%o A397185     s = {x+y for x in p for y in p}
%o A397185     evens = sorted([x for x in s if x%2==0])
%o A397185     if evens and evens == list(range(2, evens[-1]+1, 2)):
%o A397185         if len(evens) > best:
%o A397185             best = len(evens)
%o A397185             seq.append(n)
%o A397185     n += 1
%o A397185 print(seq)
%o A397185 (PARI) isok(k, n) = my(b=Vecrev(binary(k)), vb=Vec(select(x->(x==1), b, 1)), s=setbinop((x,y)->x+y, vb)); for(i=1, n, if (!#select(x->(x==2*i), s), return(0))); 1;
%o A397185 a(n) = my(k=1); while (!isok(k, n), k++); k; \\ _Michel Marcus_, Jun 18 2026
