%S A397335 1,2,3,5,8,13,20,29,45,66,104,144,227,320,442,591,932,1226,1951,2583,
%T A397335 3426,4571,7232,9175,12504,16667,21536,26922,42450,52077,82408,102888,
%U A397335 131365,172066,218360,260458,410442,541369,687174,823233,1295715,1565213,2472613,3047124,3676597,4762059
%N A397335 Number of distinct final products of the prefix-constrained binary words counted by A394165.
%C A397335 For a binary word x = (x_1,...,x_n), define its final product as Product_{1 <= j <= n, x_j = 1} (j+1), with the empty product equal to 1.
%C A397335 This sequence counts the distinct final products obtained from the binary words counted by A394165.
%C A397335 Different admissible binary words may have the same final product.
%F A397335 a(n) = #{ Product_{1 <= j <= n, x_j = 1} (j+1) : x in {0,1}^n and Product_{1 <= j <= k, x_j = 1} (j+1) <= 2^k for every 1 <= k <= n }, where the empty product is 1.
%e A397335 a(0) = 1, since the empty word gives the product 1.
%e A397335 For n = 2, the admissible words counted by A394165 are 00, 01, and 10. Their final products are 1, 3, and 2, so a(2) = 3.
%e A397335 For n = 3, the admissible words counted by A394165 are 000, 001, 010, 100, and 101. Their final products are 1, 4, 3, 2, and 8, so a(3) = 5.
%o A397335 (Python)
%o A397335 def a(n):
%o A397335     states = {1}
%o A397335     for k in range(1, n+1):
%o A397335         new_states = set(states)
%o A397335         limit = 2**k
%o A397335         for P in states:
%o A397335             Q = P*(k+1)
%o A397335             if Q <= limit:
%o A397335                 new_states.add(Q)
%o A397335         states = new_states
%o A397335     return len(states)
%o A397335 print([a(n) for n in range(46)])
%Y A397335 Cf. A394165.
%K A397335 nonn,base,new
%O A397335 0,2
