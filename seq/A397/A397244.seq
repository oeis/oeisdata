%I A397244 #11 Jun 25 2026 00:49:00
%S A397244 1,1,6,235,17010,1912023,302087720,63489224916,17121352485210,
%T A397244 5769538089705343,2378893623541440198,1179401111585644767939,
%U A397244 692730236386965337967224,475932665746640718360267300,378268991157868874683460109072,344453600355815042560632934067544,356320971787250737582071143571260010
%N A397244 G.f. A(x) satisfies (2*n) * [x^n] A(x)^(2*n) = (2*n-1) * [x^n] A(x)^(2*n+1) for n > 1.
%C A397244 Conjecture: for n > 0, a(n) is odd iff n = 2*A003714(k) + 1 for some k >= 0, where A003714 lists the Fibbinary numbers.
%C A397244 The limit lim_{n->oo} a(n)/(4^n * n!^2) appears to be finite and nonzero. At n = 900, a(900)/900!^2 = 0.2186063410009...
%H A397244 Paul D. Hanna, <a href="/A397244/b397244.txt">Table of n, a(n) for n = 0..400</a>
%F A397244 G.f. A(x) = Sum_{n>=0} a(n)*x^n satisfies the following formulas.
%F A397244 (1) (2*n) * [x^n] A(x)^(2*n) = (2*n-1) * [x^n] A(x)^(2*n+1) for n > 1.
%F A397244 (2) [x^n] A(x)^(2*n) = A396846(n) for n >= 1, where A396846 forms the logarithmic derivative of A397245.
%F A397244 (3) [x^n] A(x)^(n+1) = (n+1) * A397245(n) for n >= 0, where Sum_{n>=0} A397245(n)*x^n = exp(x + Sum_{n>=2} (4*n^2-1) * A397245(n)*x^n / (4*n^2) ).
%F A397244 (4) A(x) = F(x*A(x)^2) where F(x) = A(x/F(x)^2) is the g.f. of A397245.
%e A397244 G.f.: A(x) = 1 + x + 6*x^2 + 235*x^3 + 17010*x^4 + 1912023*x^5 + 302087720*x^6 + 63489224916*x^7 + 17121352485210*x^8 + ...
%e A397244 The table of coefficients of x^k in A(x)^n begins
%e A397244   n = 1: [1,  1,   6,   235,   17010,   1912023, ...];
%e A397244   n = 2: [1,  2,  13,   482,   34526,   3860886, ...];
%e A397244   n = 3: [1,  3,  21,   742,   52566,   5847402, ...];
%e A397244   n = 4: [1,  4, (30), 1016,   71149,   7872408, ...];
%e A397244   n = 5: [1,  5, (40), 1305,   90295,   9936766, ...];
%e A397244   n = 6: [1,  6,  51, (1610), 110025,  12041364, ...];
%e A397244   n = 7: [1,  7,  63, (1932), 130361,  14187117, ...];
%e A397244   n = 8: [1,  8,  76,  2272, (151326), 16374968, ...];
%e A397244   n = 9: [1,  9,  90,  2631, (172944), 18605889, ...];
%e A397244   n =10: [1, 10, 105,  3010,  195240, (20880882), ...];
%e A397244   n =11: [1, 11, 121,  3410,  218240, (23200980), ...];
%e A397244   ...
%e A397244 from which we may illustrate the definition
%e A397244   (2*n)*[x^n] A(x)^(2*n) = (2*n-1)*[x^n] A(x)^(2*n+1)
%e A397244 by
%e A397244   n = 2: 4*[x^2] A(x)^4 = 4*30 = 3*40 = 3*[x^2] A(x)^5;
%e A397244   n = 3: 6*[x^3] A(x)^6 = 6*1610 = 5*1932 = 5*[x^3] A(x)^7;
%e A397244   n = 4: 8*[x^4] A(x)^8 = 8*151326 = 7*172944 = 7*[x^4] A(x)^9;
%e A397244   n = 5: 10*[x^5] A(x)^10 = 10*20880882 = 9*23200980 = 9*[x^5] A(x)^11;
%e A397244   etc.
%e A397244 Also, we obtain A397245 from a semi-diagonal
%e A397244 A397245 = [1/1, 3/3, 40/5, 1932/7, 172944/9, 23200980/11, ...]
%e A397244   = [1, 1, 8, 276, 19216, 2109180, 327968280, ...].
%e A397244 Further, we obtain A396846 from half a semi-diagonal
%e A397244 A396846 = (1/2)*[2, 30, 1610, 151326, 20880882, ...]
%e A397244    = [1, 15, 805, 75663, 10440441, ...]
%e A397244 which forms the logarithmic derivative of A397245.
%o A397244 (PARI) \\ returns vector of terms a(k) for k = 0..n
%o A397244 {a(n) = my(A=[1, 1], m); for(i=1, n-1, A=concat(A, 0); m=#A-1;
%o A397244 A[#A] = (2*m-1)*polcoef(Ser(A)^(2*m+1), m) - 2*m*polcoef(Ser(A)^(2*m), m) ); GF=Ser(A); A}
%Y A397244 Cf. A397241, A397245, A396846.
%K A397244 nonn,new
%O A397244 0,3
%A A397244 _Paul D. Hanna_, Jun 24 2026
