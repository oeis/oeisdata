%I A397127 #7 Jul 01 2026 22:23:47
%S A397127 12,18,175,140,24,45,20,28,63,36,40,75,48,44,99,54,50,135,72,52,117,
%T A397127 60,80,147,84,68,153,90,100,171,228,56,189,96,76,475,120,108,245,280,
%U A397127 88,275,150,126,539,132,144,325,260,92,207,156,104,225,180,98,315,240
%N A397127 Lexicographically earliest sequence of distinct numbers k that are neither squarefree nor prime powers (k in A126706), such that for any prime p, any run of consecutive multiples of p has length exactly 2.
%C A397127 This variant of A280864 eliminates the occasion of powers of primes occupying the first and last terms of a block.
%C A397127 The first block of this sequence, {12, 18}, a duplex block, is analogous to block 2 of A280864, {2, 4}, in having 2 terms with the same squarefree kernel. There are 57 duplexes for n <= 2^15. Apart from {12, 18}, the duplexes {j,k} are such that j | k, k > j, rad(k) | j, with j even and k = 2*j.
%C A397127 Conjecture: There are no more duplex blocks {j,k} such that rad(j) = rad(k) but neither j nor k divides the other, apart from j = 12 and k = 18.
%C A397127 Conjecture: permutation of A126706.
%H A397127 Michael De Vlieger, <a href="/A397127/b397127.txt">Table of n, a(n) for n = 1..16384</a>
%e A397127 Table of the first 16 terms:
%e A397127    n   a(n)  Prime power factors
%e A397127   ------------------------------------
%e A397127    1    12 = 2^2   3
%e A397127    2    18 = 2     3^2
%e A397127    3   175 =             5^2   7
%e A397127    4   140 = 2^2         5     7
%e A397127    5    24 = 2^3   3
%e A397127    6    45 =       3^2   5
%e A397127    7    20 = 2^2         5
%e A397127    8    28 = 2^2               7
%e A397127    9    63 =       3^2         7
%e A397127   10    36 = 2^2   3^2
%e A397127   11    40 = 2^3         5
%e A397127   12    75 =       3     5^2
%e A397127   13    48 = 2^4   3
%e A397127   14    44 = 2^2                   11
%e A397127   15    99 = 3^2                   11
%e A397127   16    54 = 2     3^3
%t A397127 Block[{c, k, m, r, s, w, nn, rad},
%t A397127   nn = 120; c[_] := False; r = s = 1;
%t A397127   rad[n_] := rad[n] = Times @@ FactorInteger[n][[All, 1]];
%t A397127   Reap[Do[w = GCD[r, s]; m = r/w; k = m;
%t A397127     While[Or[c[k], SquareFreeQ[k], PrimePowerQ[k], ! CoprimeQ[w, k] ],
%t A397127       k += m]; Sow[k]; Set[{c[k], s, r}, {True, r, rad[k] } ],
%t A397127     {i, nn} ] ][[-1, 1]] ]
%Y A397127 Cf. A052486, A126706, A131605, A280864, A286708, A303606, A332785, A338444 (squarefree variant), A383394, A386762, A397126 (powerful variant), A397128 (variant in A332785).
