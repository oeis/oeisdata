%S A397323 1,2,4,6,3,9,12,8,10,14,16,18,15,21,24,27,30,33,22,20,26,28,32,34,36,
%T A397323 38,40,5,35,42,39,45,48,44,54,60,46,50,52,56,7,70,58,62,64,66,68,80,
