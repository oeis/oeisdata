%S A397213 1,2,4,7,14,28,56,110,220,440,880,1756,3512,7024,14048,28089,56178,
%T A397213 112356,224712,449410,898820,1797640,3595280,7190532,14381064,
%U A397213 28762128,57524256,115048456,230096912,460193824,920387648,1840775186,3681550372,7363100744,14726201488
%N A397213 G.f. A(x) satisfies (1-2*x)*A(x) + A(x^4) = x.
%F A397213 G.f.: Sum_{j>=0} (-1)^j*x^(4^j) / Product_{k=0..j} (1 - 2*x^(4^k)).
%F A397213 a(1) = 1; for n >= 2, a(n) = 2*a(n-1) - a(n/4) if 4|n, and a(n) = 2*a(n-1) otherwise.
%F A397213 a(n) = 2^(n-1) - Sum_{k=1..floor(n/4)} 2^(n-4*k) * a(k).
%o A397213 (Ruby)
%o A397213 def A397213(n)
%o A397213   a = [0]
%o A397213   (1..n).each{|i|
%o A397213   a << (1..i / 4).inject(2 ** (i - 1)){|s, k| s - 2 ** (i - 4 * k) * a[k]}}
%o A397213   a[1..-1]
%o A397213 end
%o A397213 p A397213(40)
%Y A397213 Cf. A045690, A397064, A398036.
%K A397213 nonn,new
%O A397213 1,2
%A A397213 _Seiichi Manyama_, Jul 17 2026
