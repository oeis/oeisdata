%N A397862 G.f. A(x) satisfies A(x) = 1 + x * (1+x) * A(x * (1+x)^3).
%F A397862 a(0) = 1; a(n) = Sum_{k=0..n-1} binomial(3*k+1,n-k-1) * a(k).
%o A397862 (PARI) a_vector(n, s=3, t=1) = my(v=vector(n+1)); v[1]=1; for(i=1, n, v[i+1]=sum(k=0, i-1, binomial(s*k+t, i-k-1)*v[k+1])); v;
