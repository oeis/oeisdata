%S A397695 3,1,2,3,1,2,3,1,2,3,13,11,12,13,11,12,13,11,12,13,23,12,22,23,12,22,
%T A397695 23,12,22,23,33,13,23,33,13,23,33,13,23,33,13,11,12,13,11,12,13,11,12,
%U A397695 13,23,12,22,23,12,22,23,12,22,23,33,13,23,33,13,23,33,13
%N A397695 Residue class of the decimal digits of n taken mod 3, with 0 represented by 3, and in nondecreasing order.
%C A397695 Also, a(n) is the digits of A397694(n) sorted in nondecreasing order.
%H A397695 Michael S. Branicky, <a href="/A397695/b397695.txt">Table of n, a(n) for n = 0..10000</a>
%e A397695 a(57) = 12 since 5 mod 3 = 2 and 7 mod 3 = 1, and 21 sorted in nondecreasing order is 12.
%e A397695 a(68) = 23 since 6 mod 3 = 0 (which is encoded as 3) and 8 mod 3 = 2, and 32 sorted in nondecreasing order is 23.
%t A397695 A397695[n_] := FromDigits[Sort[Mod[IntegerDigits[n], 3] /. 0 -> 3]];
%t A397695 Array[A397695, 100, 0] (* _Paolo Xausa_, Jul 05 2026 *)
%o A397695 (Python)
%o A397695 def a(n): return int("".join(sorted(map(str, [(r:=di%3)+3*int(r==0) for di in list(map(int, str(n)))]))))
%o A397695 print([a(n) for n in range(68)])
%Y A397695 Cf. A007932, A010882, A397643, A397644, A397694.
%K A397695 nonn,base,easy
%O A397695 0,1
