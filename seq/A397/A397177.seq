%N A397177 a(n) = n - A394611(n).
%H A397177 N. J. A. Sloane, <a href="/A397177/b397177.txt">Table of n, a(n) for n = 1..10000</a>
%o A397177 (Python)
%o A397177 from collections import Counter
%o A397177 from itertools import count, islice
%o A397177 def A397177_gen(): # generator of terms
%o A397177     alst, an, c = [], 0, Counter()
%o A397177     for n in count(1):
%o A397177         an = c[an]
%o A397177         yield n - an
%o A397177         c.update(an+ai for ai in alst)
%o A397177         alst.append(an)
%o A397177 print(list(islice(A397177_gen(), 91))) # _Michael S. Branicky_, Jul 01 2026
