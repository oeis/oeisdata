%N A397370 Numbers k such that the last d digits of k^k are equal to the reverse of k, where d is the number of digits of k, and k is not a palindrome.
%o A397370 (Python)
%o A397370 def ok(k):
%o A397370     s = str(k)
%o A397370     rev = s[::-1]
%o A397370     if s == rev:
%o A397370         return False
%o A397370     return str(pow(k, k, 10**len(s))).zfill(len(s)) == rev
%o A397370 print([k for k in range(10**6) if ok(k)])
