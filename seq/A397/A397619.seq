%S A397619 1,1,2,2,8,4,40,40,56,88,1288,1040,18200,17600,158194,173100,2218366,
%T A397619 817516,45303282,4998932,51800326,59441320,3931035158,1206962488,
%U A397619 57085150898,25000385878,1011984855438,696555511396
%N A397619 Number of permutations p of [n] such that p(i)*p(i+1) + 1 is prime for all 1 <= i <= n-1.
%C A397619 Since reversals are counted separately, a(n) is even for n>=2. No two odd numbers can be adjacent, as odd * odd + 1 is even and greater than 2. Therefore for odd n the permutation alternates parity. Conjecture: a(n)>0 for all n. Verified up to n = 27. For n>=2, a(n) > 0 implies a prime == 1 mod n, not exceeding n^2 - n + 1.
%e A397619 For n = 5, a(5) = 4. The valid permutations are (5,2,1,4,3) and (5,2,3,4,1) plus their reversals. For the permutation (5,2,1,4,3), the adjacent products plus one are 11,3,5, and 13, all prime.
%t A397619 fp[s_]:=Module[{ps={}},Do[AppendTo[ps,s[[i]]*s[[i+1]]+1],{i,Length[s]-1}];ps];a[n_]:=Length[Select[Permutations[Range[n],{n}],AllTrue[fp[#],PrimeQ]&]];Array[a,10,0] (* _James C. McMahon_, Jul 08 2026 *)
%o A397619 (Java)
%o A397619 public class Main {
%o A397619     static int n; static boolean[] used;
%o A397619     static boolean p(int m) {
%o A397619         for (int i = 2; i * i <= m; i++) if (m % i == 0) return false;
%o A397619         return m > 1;
%o A397619     }
%o A397619     static long dfs(int last, int depth) {
%o A397619         if (depth == n) return 1;
%o A397619         long c = 0;
%o A397619         for (int v = 1; v <= n; v++)
%o A397619             if (!used[v] && p(last * v + 1)) {
%o A397619                 used[v] = true; c += dfs(v, depth + 1); used[v] = false;
%o A397619             }
%o A397619         return c;
%o A397619     }
%o A397619     public static void main(String[] args) {
%o A397619         for (n = 1; n <= 20; n++) {
%o A397619             long t = 0; used = new boolean[n + 1];
%o A397619             for (int s = 1; s <= n; s++) { used[s] = true; t += dfs(s, 1); used[s] = false; }
%o A397619             System.out.println(n + ", " + t);
%o A397619         }
%o A397619     }
%o A397619 }
