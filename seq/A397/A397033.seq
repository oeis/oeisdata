%o A397033 (SageMath)
%o A397033 def search_primes(start, count):
%o A397033     for n in range(start, start + count):
%o A397033         if not is_prime(n):
%o A397033             continue
%o A397033         try:
%o A397033             E = EllipticCurve([0, 0, 0, 0, n^3])
%o A397033             pts = E.integral_points()
%o A397033             if len(pts) > 1:
%o A397033                 print(n)
%o A397033         except Exception:
%o A397033             continue
%o A397033 search_primes(2, 500)
