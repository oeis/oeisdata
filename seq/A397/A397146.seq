%N A397146 G.f. A(x), with A(0) = 0, satisfies A(x-x^2) = x + A(x)^4.
%F A397146 a(1) = 1; a(n) = Sum_{i, j, k, l>=1 and i+j+k+l=n} a(i)*a(j)*a(k)*a(l) + Sum_{r=1..floor(n/2)} (-1)^(r+1) * binomial(n-r,r) * a(n-r).
%o A397146 (PARI) my(A=x, N=30, g=serreverse(x-x^2+x*O(x^N))); for(k=1, N, A=g+subst(A, x, g)^4); Vec(A)
