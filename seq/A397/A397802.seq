%N A397802 Expansion of e.g.f. sinh( 1 / (2 - exp(x)) - 1 ).
%F A397802 a(n) = Sum_{k=0..n} Stirling2(n,k) * A088313(k).
%t A397802 nmax = 22; CoefficientList[Series[Sinh[1/(2 - Exp[x]) - 1], {x, 0, nmax}], x] Range[0, nmax]!
%t A397802 (* Alternative: *)
%t A397802 Table[Sum[Sum[StirlingS2[n, k] Binomial[k - 1, 2 j - 2] k!/(2 j - 1)!, {j, 1, Floor[(k + 1)/2]}], {k, 0, n}], {n, 0, 22}]
