%N A397993 E.g.f. A(x) satisfies A(-log(1-2*x)/2) = 3*A(x) - 2*x.
%F A397993 a(1) = 1; a(n+1) = Sum_{k=1..n} 2^(n-k) * |Stirling1(n+1,k)| * a(k).
%o A397993 (PARI) a_vector(n) = my(v=vector(n)); v[1]=1; for(i=1, n-1, v[i+1]=sum(j=1, i, 2^(i-j)*abs(stirling(i+1, j, 1))*v[j])); v;
