%I A397954 #9 Jul 22 2026 01:07:53
%S A397954 0,1,2,3,4,6,8,10,12,14,18,24,27,33,42,48,51,57,72,96,108,132,168,192,
%T A397954 204,228,290,385,435,530,675,770,915,1542,1740,2700,3660,10801
%N A397954 Polydivisible numbers in base 4.
%C A397954 For the definition of polydivisible number in base b, see A397953.
%H A397954 Wikipedia, <a href="https://en.wikipedia.org/wiki/Polydivisible_number">Polydivisible number</a>.
%F A397954 a(A271374(4)) = A109032(4).
%e A397954 10801 is a term because 10801_10 = 2220301_4 and all of the following conditions are true:
%e A397954   2_4       =     2_10 is divisible by 1;
%e A397954   22_4      =    10_10 is divisible by 2;
%e A397954   222_4     =    42_10 is divisible by 3;
%e A397954   2220_4    =   168_10 is divisible by 4;
%e A397954   22203_4   =   675_10 is divisible by 5;
%e A397954   222030_4  =  2700_10 is divisible by 6;
%e A397954   2220301_4 = 10801_10 is divisible by 7.
%t A397954 (* polyDivQ is defined at A397953 *)
%t A397954 Select[Range[0, 10801], polyDivQ[#, 4] &] (* Gives the full sequence *)
%t A397954 (* Alternative: *)
%t A397954 (* polyDivFullList is defined at A144688 *)
%t A397954 polyDivFullList[4]
%o A397954 (Python) # uses polydiv in A397953
%o A397954 print([an for an in polydiv(base=4)]) # _Michael S. Branicky_, Jul 16 2026
%Y A397954 Cf. polydivisible numbers in other bases b: A397953 (b = 3), A397955 (b = 5), A397956 (b = 6), A397957 (b = 7), A397958 (b = 8), A397959 (b = 9), A144688 (b = 10).
%Y A397954 Cf. A109032, A271373, A271374.
