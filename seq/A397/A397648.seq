%U A397648 -13829025,28247522,-57825709,119142873,-247239353,514867189,-1068516402,2191165223,-4401702967
%N A397648 Inverse binomial transform of Kolakoski sequence A000002.
%C A397648 [Before taking the transform, relabel A000002 so the subscripts start at 0 instead of 1.]
%C A397648 The sequence is generated by forward differences of increasing order evaluated at the initial index. This can also be expressed as the inverse binomial transform of the input sequence (where the sign factor (-1)^(n-k) is used), but in an online (streaming) fashion, that is provided by Python's Iterator interface with no reference to difference tables.
%e A397648 The streaming algorithm of forward differences:
%e A397648 .
%e A397648 | A000002 |  computation                                    | a(n) is first column |
%e A397648 | ------- | ----------------------------------------------- | -------------------- |
%e A397648 | a0 = 1  | [a0]                                            | [ 1]                 |
%e A397648 | a1 = 2  | [a1 - a0,  a1]                                  | [ 1,  2]             |
%e A397648 | a2 = 2  | [a2 - 2*a1 + a_0,  a2 - a1,  a2]                | [-1,  0, 2]          |
%e A397648 | a3 = 1  | [a3 - 3*a2 + 3*a1 - a0,  a3 - a2,  a_3]         | [ 0, -1, 1]          |
%e A397648 | a4 = 1  | [a4 - 4*a3 + 6*a2 - 4*a1 + a0, a4 - 3*a3 + ...] | [ 2,  2, 1, 0, 1]    |
%e A397648 | a5 = 2  | [a5 - 5*a4 + 10*a3 - 10*a2 + 5*a1 - a0, ...]    | [-4, -2, 0, 1, 1, 2] |
%p A397648 # Using _R. J. Mathar_'s function A000002.
%p A397648 inverse_binomial_transform := (sq, dim) -> local n, k;
%p A397648 seq(add((-1)^(n - k) * binomial(n, k) * sq(k), k = 0..n), n = 0..dim):
%p A397648 inverse_binomial_transform(n -> A000002(n + 1), 35);
%o A397648 (Python) # Using _David Eppstein_'s Kolakoski function from A000002.
%o A397648 from typing import Iterator
%o A397648 def inverse_binomial_transform(seq: Iterator, dim: int) -> list[int]:
%o A397648     c = []; t = []
%o A397648     for _ in range(dim):
%o A397648         try: r = next(seq)
%o A397648         except StopIteration: break
%o A397648         u = [0] * len(c) + [r]
%o A397648         for i in range(len(c) - 1, -1, -1):
%o A397648             u[i] = u[i + 1] - c[i]
%o A397648         c = u; t.append(u[0])
%o A397648     return t
%o A397648 A397648 = inverse_binomial_transform(Kolakoski(), 36); print(A397648)
%Y A397648 Cf. A000002, A054355.
%K A397648 sign,new
%O A397648 0,5
