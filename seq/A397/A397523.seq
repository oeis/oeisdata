%S A397523 1,1,10,316,20440,2227456,366526720,84831556096,26270863897600,
%T A397523 10488938037348736,5246408901744398080,3213188283847685925376,
%U A397523 2365135920868524271068160,2060116269344776730429526016,2095851099524675313845290147840,2462634430282108430354900640710656
%N A397523 Row 9 of A365673.
%C A397523 This a weighted generalized Catalan sequence (A365673) with the 9-gonal numbers as weights.
%C A397523 In general, if s > 2 is the number of sides of the polygon, then a(n) ~ 2^(3*n + 1 + 4/(s-2)) * (s-2)^n * n^(2*n - 1/2 + 2/(s-2)) / (Gamma(2/(s-2)) * exp(2*n) * Pi^(2*n + (6-s)/(2*(s-2)))).
%F A397523 a(n) ~ 2^(3*n + 11/7) * 7^n * n^(2*n - 3/14) / (Gamma(2/7) * exp(2*n) * Pi^(2*n - 3/14)).
%t A397523 pn[n_,k_]:=pn[n, k] = Which[k==0, 1, k==n, pn[n, k-1], True, PolygonalNumber[9, n-k+1]*pn[n, k-1] + pn[n-1, k]]; Table[pn[n, n], {n, 0, 20}]
%Y A397523 Cf. A001106, A365673, A366150, A397522.
%K A397523 nonn,new
%O A397523 0,3
