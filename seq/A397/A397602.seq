%N A397602 Row sums of A397603.
%F A397602 a(n) ~ 2^(n-2) * 5^(n+4) / (27*Pi*n^3). - _Vaclav Kotesovec_, Jul 21 2026
%p A397602 seq(add(A397603(n, k), k = 0..n), n = 0..25);
%t A397602 T[n_, k_] := T[n, k] = If[n == k, -3^(2*n+3) * Hypergeometric2F1[3/2, n+2, 2, 4]^2, T[n, k+1] + T[n-1, k]]; Table[Sum[T[n, k], {k, 0, n}], {n, 0, 25}] (* _Vaclav Kotesovec_, Jul 21 2026 *)
