%T A397088 684529750280576,76524539192084096,9440085602432363520,
%U A397088 1273845857661955460096,186655067329617703720960,29514780183694348261738496,5009445771827759781276491776,908381310192753648470120243200
%N A397088 E.g.f. A(x) satisfies A'(x) = exp( A(x)*A'(x)^4 ), with A(0)=0.
%F A397088 For k >= 0, e.g.f. A(x) satisfies A'(x) = exp( A(x)*A'(x)^k ), with A(0)=0.
%F A397088 Let R(x) = Series_Reversion( (1-(1-k*(k+1)*x) * exp(-(k+1)*x))/(k+1)^2 ).
%F A397088 A(x) = R(x) * exp(-k*R(x)).
%F A397088 For k > 0, with V(x) = LambertW(e^(1/k) * (1-(k+1)^2*x)/k), we have R(x) = (1-k*V(x))/(k*(k+1)) and A(x) = (1-k*V(x))/(k*(k+1)) * exp((k*V(x)-1)/(k+1)).
%o A397088 (PARI) my(k=4, N=20, x='x+O('x^N), R=serreverse((1-(1-k*(k+1)*x)*exp(-(k+1)*x))/(k+1)^2)); Vec(serlaplace(R*exp(-k*R)))
%Y A397088 Cf. A104150, A214654, A392206, A392208.
%Y A397088 Cf. A376174.
%K A397088 nonn,new
%O A397088 1,3
