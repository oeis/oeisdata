%T A397959 44,46,48,50,52,54,56,58,60,62,64,66,68,70,72,74,76,78,80,90,93,96,
%U A397959 108,111,114,126,129,132,144,147,150,162,165,168,180,183,186,198,201
%N A397959 Polydivisible numbers in base 9.
%C A397959 For the definition of polydivisible number in base b, see A397953.
%H A397959 Michael S. Branicky, <a href="/A397959/b397959.txt">Table of n, a(n) for n = 1..8381</a> (full sequence)
%H A397959 Wikipedia, <a href="https://en.wikipedia.org/wiki/Polydivisible_number">Polydivisible number</a>.
%F A397959 a(A271374(9)) = A109032(9).
%e A397959 989072 is a term because 989072_10 = 1766668_9 and all of the following conditions are true:
%e A397959   1_9       =      1_10 is divisible by 1;
%e A397959   17_9      =     16_10 is divisible by 2;
%e A397959   176_9     =    150_10 is divisible by 3;
%e A397959   1766_9    =   1356_10 is divisible by 4;
%e A397959   17666_9   =  12210_10 is divisible by 5;
%e A397959   176666_9  = 109896_10 is divisible by 6;
%e A397959   1766668_9 = 989072_10 is divisible by 7.
%t A397959 (* polyDivQ is defined at A397953 *)
%t A397959 Select[Range[0, 234], polyDivQ[#, 9] &]
%t A397959 (* Alternative: *)
%t A397959 (* polyDivFullList is defined at A144688 *)
%t A397959 polyDivFullList[9][[;; 70]]
%o A397959 (Python) # uses polydiv in A397953
%o A397959 print([an for an in polydiv(base=9)]) # _Michael S. Branicky_, Jul 16 2026
