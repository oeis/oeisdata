%S A397125 1,94,97,7,133,32,1,49,139,1,68,91,1,28,79,13,23,192,1,94,49,326,1,
%T A397125 203,28,13,44,1,7,97,1,1,129,32,19,32,32,23,28,7,28,68,7,1,97,19,7,19,
%U A397125 1,133,31,49,28,28,32,7,91,79,19,32,13,13,68,23,32,23,7,1
%N A397125 a(n) = smallest happy number h such that n*h is happy.
%C A397125 No term is divisible by 10.
%H A397125 Xander Lee Luo, <a href="/A397125/b397125.txt">Table of n, a(n) for n = 1..10000</a>
%F A397125 a(n) = 1 iff n is happy.
%F A397125 a(a(n)) = 1 for all n.
%F A397125 a(n) = a(10^k*n) for all n, k.
%F A397125 a(n) >= A360942(n), with equality iff A360942(n) is happy. - _Michael S. Branicky_, Jun 16 2026
%e A397125 a(2) = 94 since 2*94 = 188, both 94 and 188 are happy and there is no smaller happy number h such that 2*h is happy.
%o A397125 (Python)
%o A397125 from itertools import count
%o A397125 def ssd(n): # sum of squared digits
%o A397125     return sum(int(d)**2 for d in str(n))
%o A397125 def is_happy(n):
%o A397125     while n not in [1, 4]: n = ssd(n) # iterate until fixed point or in cycle
%o A397125     return n==1
%o A397125 def a(n):
%o A397125     return next(h for h in count(1) if is_happy(h) and is_happy(h*n))
%o A397125 print([a(n) for n in range(1, 69)]) # _Michael S. Branicky_, Jun 16 2026
%Y A397125 Cf. A007770, A360942.
%K A397125 nonn,base,new
%O A397125 1,2
%A A397125 _Xander Lee Luo_, Jun 16 2026
