%I A397247 #6 Jun 19 2026 16:15:36
%S A397247 49,100,169,361,400,900,1225,1444,1600,1681,2500,3249,3600,4225,4900,
%T A397247 6400,8100,9025,10000,12100,14400,15625,16900,19600,22500,25600,28900,
%U A397247 32400,36100,40000,42025,44100,48400,49729,52900,57600,62500,64009,67600,72900,78400,81225,84100,90000
%N A397247 Squares that are the concatenation of two squares.
%C A397247 The first 16 terms were computed by my son, Martin Spezia, after my suggestion.
%C A397247 Leading zero digits are allowed only for the second square, e.g., 64009 is split into 64 and 009.
%C A397247 The sequence has infinitely many terms since A017270 \ {0} is a subsequence.
%e A397247 64009 = 253^2 is a term since it splits in 64 = 8^2 and 009 = 9 = 3^2.
%t A397247 Select[Range[300]^2, Function[s, With[{digits = IntegerDigits[s], len = IntegerLength[s]}, AnyTrue[Range[len - 1], Function[k, IntegerQ[Sqrt[Sum[digits[[i]]*10^(k - i), {i, 1, k}]]] && IntegerQ[Sqrt[Sum[digits[[i]]*10^(len - i), {i, k + 1, len}]]]]]]]]
%Y A397247 Cf. A000290, A017270, A102766, A238237, A350918, A387866, A387911.
%Y A397247 Supersequence of A039686 and A147608.
%Y A397247 The square roots give A397248.
%K A397247 nonn,base,easy
%O A397247 1,1
%A A397247 _Stefano Spezia_, Jun 19 2026
