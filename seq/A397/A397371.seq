%S A397371 0,2,4,6,12,15,18,21,24,36,40,44,48,52,56,60,80,85,90,95,100,105,110,
%T A397371 115,120,150,156,162,168,174,180,186,192,198,204,210,252,259,266,273,
%U A397371 280,287,294,301,308,315,322,329,336,392,400,408,416,424,432,440,448
%N A397371 a(n) = n times the square root of the smallest square number greater than n.
%F A397371 a(n) = n + n*floor(sqrt(n)). - _Chai Wah Wu_, Jun 22 2026
%e A397371 When n=4, the next square is 9 (4 does not count since the next one must be greater and not equal.) The square root of 9 is 3, so we multiply n, which is 4, by 3 to get 12; therefore when n=4 the sequence outputs 12.
%t A397371 Table[n + n * Floor@ Sqrt[n], {n, 0, 57}] (* _Michael De Vlieger_, Jun 22 2026 *)
%o A397371 (Python)
%o A397371 from math import isqrt
%o A397371 def A397371(n): return n*(isqrt(n)+1) # _Chai Wah Wu_, Jun 22 2026
