%I A397348 #10 Jun 29 2026 00:56:34
%S A397348 1,1,6,153,7932,650010,75564108,11747407371,2351292937656,
%T A397348 589428265833072,181088207311771020,66975651456303119178,
%U A397348 29372914884127577906088,15078354622965006123873642,8959192413093624570222525864,6101628779654763527891648460735,4722320380467342560271915126682992,4121928205466667088439970659718890328
%N A397348 O.g.f. satisfies A(x) = exp( x + Sum_{n>=2} (3*n^2 - 1) * a(n)*x^n / (3*n^2) ).
%C A397348 Conjecture: a(n) is odd iff n+1 is a power of 2.
%C A397348 The limit lim_{n->oo} a(n)/(3^n * n!^2) appears to be finite and nonzero. At n = 800, a(800)/(3^800 * 800!^2) = 0.2787968231045730...
%H A397348 Paul D. Hanna, <a href="/A397348/b397348.txt">Table of n, a(n) for n = 0..400</a>
%F A397348 G.f. A(x) = Sum_{n>=0} a(n)*x^n satisfies the following formulas.
%F A397348 (1) A(x) = exp( A(x) - 1 - Sum_{n>=2} a(n)*x^n / (3*n^2) ).
%F A397348 (2) A(x) = B(x*A(x)^q) where B(x) = A(x/B(x)^q) satisfies (q*n)*[x^n] B(x)^(q*n) = (q*n-1)*[x^n] B(x)^(q*n+1) for n > 1, where q = sqrt(3).
%F A397348 (3) A'(x) = A(x) * (1 + Sum_{n>=1} (3*(n+1)^2 - 1)/(3*(n+1)) * a(n+1) * x^n ).
%F A397348 (4) A(x) = 1+x + 3*x*(A(x)-1)*(A'(x) + x*A''(x))/A(x) + 3*x^2*A'(x)^2/A(x)^2.
%F A397348 (5) a(n) = 3*n^2/(3*n^2 - 1) * [x^n] log(A(x)) for n > 1.
%F A397348 (6) a(n) = n*A397349(n)/(n^2-1) for n > 1, where A397349 is the logarithmic derivative of this sequence.
%F A397348 (7) a(n) = 3*n*a(n-1) + n*Sum_{k=1..n-2} (3*(k+1)^2-1)/(k+1) * a(k+1)*a(n-k-1) for n > 1, with a(0) = a(1) = 1.
%e A397348 G.f.: A(x) = 1 + x + 6*x^2 + 153*x^3 + 7932*x^4 + 650010*x^5 + 75564108*x^6 + 11747407371*x^7 + 2351292937656*x^8 + ...
%e A397348 where
%e A397348 A(x) = exp( x + 11*6*x^2/(3*2^2) + 26*153*x^3/(3*3^2) + 47*7932*x^4/(3*4^2) + 74*650010*x^5/(3*5^2) + 107*75564108*x^6/(3*6^2) + ... + (3*n^2-1)*a(n)*x^n/(3*n^2) + ... ).
%e A397348 RELATED SERIES.
%e A397348 The logarithm of the g.f. A(x) begins
%e A397348 log(A(x)) = x + 11*x^2/2 + 442*x^3/3 + 31067*x^4/4 + 3206716*x^5/5 + 449186642*x^6/6 + 81672451246*x^7/7 + ... + A397349(n)*x^n/n + ...
%e A397348 where A397349(n) = (3*n^2-1)*a(n)/(3*n) for n > 1.
%e A397348 The terms a(n) are divisible by n for n > 0:
%e A397348 a(n)/n = [1, 3, 51, 1983, 130002, 12594018, 1678201053, ...].
%o A397348 (PARI) \\ by a(n) = 3*n^2/(3*n^2-1) * [x^n] log(A)  for n > 1:
%o A397348 {a(n) = my(V=[1, 1], A, m); for(i=2, n, V=concat(V, 0); A = Ser(V); m = #V-1;
%o A397348 V[#V] = (3*m^2-1)*polcoef(A, m) - 3*m^2*polcoef(log(A), m) ); GF=Ser(V); V[n+1]}
%o A397348 \\ returns a vector of terms a(k) for k = 0..n
%o A397348 {upto(n) = a(n); Vec(GF)}
%o A397348 upto(20)
%o A397348 (PARI) \\ by recurrence (slower)
%o A397348 \\ print terms a(n) for n = 0..N
%o A397348 N = 20; A = vector(N+1);
%o A397348 {a(n) = A[n+1] = if(n<=1, 1, 3*n*A[n] + n*sum(k=1, n-2, (3*(k+1)^2-1)/(k+1) * a(k+1) * A[n-k]) )}
%o A397348 for(n=0, N, print1(a(n), ", "))
%Y A397348 Cf. A397242, A397245, A397347, A397349, A397345.
%K A397348 nonn
%O A397348 0,3
