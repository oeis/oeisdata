%I A397367 #5 Jul 01 2026 23:00:50
%S A397367 2,4,3,9,5,25,7,49,8,16,11,121,13,169,17,289,19,361,23,529,27,81,29,
%T A397367 841,31,961,32,64,37,1369,41,1681,43,1849,47,2209,53,2809,59,3481,61,
%U A397367 3721,67,4489,71,5041,73,5329,79,6241,83,6889,89,7921,97,9409,101,10201
%N A397367 Lexicographically earliest sequence of distinct prime powers p^m, m >= 1, such that for any prime p, any run of consecutive multiples of p has length exactly 2.
%C A397367 Variant of A280864 confined to A246655.
%C A397367 Permutation of A246655.
%C A397367 We may partition A280864 into blocks according to a(n-1) coprime to a(n). In A280864, the blocks have variable lengths, but in this sequence, all the blocks are duplexes (a(n), a(n+1)) such that a(n) | a(n+1) and rad(a(n+1)) | a(n) but a(n+1) > a(n).
%C A397367 a(n) is a perfect square (in A000290) for even n.
%H A397367 Michael De Vlieger, <a href="/A397367/b397367.txt">Table of n, a(n) for n = 1..16384</a>
%e A397367 Table of n, a(n) for n = 1..16:
%e A397367    n    a(n)  2^m 3^m 5^m 7^m 11^m 13^m 17^m
%e A397367   ------------------------------------------
%e A397367    1     2 =  2
%e A397367    2     4 =  2^2
%e A397367    3     3 =      3
%e A397367    4     9 =      3^2
%e A397367    5     5 =          5
%e A397367    6    25 =          5^2
%e A397367    7     7 =              7
%e A397367    8    49 =              7^2
%e A397367    9     8 =  2^3
%e A397367   10    16 =  2^4
%e A397367   11    11 =                  11
%e A397367   12   121 =                  11^2
%e A397367   13    13 =                       13
%e A397367   14   169 =                       13^2
%e A397367   15    17 =                            17
%e A397367   16   289 =                            17^2
%t A397367 Block[{s, t, c, f, i, j, k, m, u, nn},
%t A397367   nn = 2^8; c[_] := False; i = u = 1; j = 1;
%t A397367   s = Union[#, {1}~Join~Union@ Flatten@
%t A397367     Table[Array[p^# &, Floor@Log[p, #] - 1, 2],
%t A397367     {p, Prime@ Range@ PrimePi@ Sqrt[#] } ] &[#[[-1]] ] ] &[
%t A397367     Prime@ Range[2*nn] ]; m = Length[s]; c[s[[i]] ] = True;
%t A397367   Reap[Do[Set[{i, k}, {u, s[[i]] } ];
%t A397367     If[CoprimeQ[j, k],
%t A397367       While[Set[k, s[[i]]]; Or[c[k], ! CoprimeQ[j, k] ], i++];
%t A397367         If[i == u, While[c[s[[u]] ], u++] ],
%t A397367       k = #1^(#2 + 1) & @@ FactorInteger[j][[1]] ];
%t A397367     Set[{c[k], j}, {True, k}]; Sow[k], {n, nn}] ][[-1, 1]] ]
%Y A397367 Cf. A000290, A007947, A246655, A280864, A338444 (squarefree variant), A397368 (proper prime power variant).
%K A397367 nonn,easy,new
%O A397367 1,1
%A A397367 _Michael De Vlieger_, Jun 26 2026
