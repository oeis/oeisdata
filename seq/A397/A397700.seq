%I A397700 #14 Jul 09 2026 07:55:38
%S A397700 1547,2737,39997,52633,65773,93023,449497,510229,1392047,2532851,
%T A397700 3705407,7336477,7511687,13927283,17631503,20115649,28288763,32524379,
%U A397700 63198001,69647257,102195757,105310367,148857227,212094721,228844547,239795459,251192339,261279971,280113373,378693181,396657071
%N A397700 Numbers p*q*r where p, q and r are distinct primes with p^2 + r^2 = 2*q^2.
%C A397700 Terms of A255356 with three prime factors.
%C A397700 If q is in A307894, there are distinct primes p,r so p*q*r is a term.
%H A397700 Robert Israel, <a href="/A397700/b397700.txt">Table of n, a(n) for n = 1..781</a>
%e A397700 a(3) = 39997 is a term because 39997 = 23*37*47 where 23, 37 and 47 are distinct primes with 23^2 + 47^2 = 2 * 37^2 = 2738.
%p A397700 M:= 10^9:
%p A397700 R:= NULL:
%p A397700 p:= 5:
%p A397700 while p^3 < M do
%p A397700   p:= nextprime(p);
%p A397700   S:= [isolve(p^2 + r^2 = 2*q^2)];
%p A397700   for i from 0 do
%p A397700     Ss:= expand(eval(S,_Z1=i));
%p A397700     Spq:= map(s -> [subs(s,q),subs(s,r)], Ss);
%p A397700     Spq:= select(s -> s[1]>p and s[2]>p, Spq);
%p A397700     Mpq:= map(s -> p*s[1]*s[2], Spq);
%p A397700     if i > 0 and min(Mpq) > M then break fi;
%p A397700     Spq:= select(s -> p*s[1]*s[2] <= M and isprime(s[1]) and isprime(s[2]), Spq);
%p A397700     R:= R, op(map(s -> p*s[1]*s[2], Spq));
%p A397700 od od:
%p A397700 sort([R]);
%Y A397700 Cf. A255356, A307894.
%Y A397700 Subsequence of A007304.
%K A397700 nonn,new
%O A397700 1,1
%A A397700 _Robert Israel_, Jul 05 2026
