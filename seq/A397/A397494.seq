%I A397494 #6 Jul 14 2026 22:44:08
%S A397494 1,4,9,8,27,16,81,32,225,64,25,36,125,72,625,108,1225,128,49,100,343,
%T A397494 144,2401,200,441,256,243,196,675,392,729,400,1089,500,121,216,1331,
%U A397494 288,3025,324,3125,432,4225,484,169,512,1521,784,1125,676,1323,800,2187,968
%N A397494 a(1) = 1, a(2) = 4, a(3) = 9; for n > 2, a(n) is the smallest powerful k not already used that shares a factor with a(n-2), but none with a(n-1).
%C A397494 This sequence is a variant of the Yellowstone sequence, confined to powerful numbers.
%C A397494 Prime squares (in A001248) seem to assume the role of primes in the Yellowstone sequence.
%C A397494 For a(n) = p^2 for prime p > 3, we observe the following for primes that do not exceed prime(938) (for n <= 2^15):
%C A397494 1.) a(n-2) = 9*p^2 except for p in {7, 13} where a(n-2) = 25*p^2.
%C A397494 2.) a(n+2) = q^2*p^2, prime q < p, except for p in {3, 5, 7, 11, 17, 19, 23, 31, 37, 47}, where a(n+2) = p^3.
%C A397494 3.) a(n-1) and a(n+1) are even.
%C A397494 In scatterplot, there exists trajectories associated with q^2*p^2 for q in {3, 5, 7, ...} similar to those observed in the Yellowstone sequence.
%C A397494 Selcoe's theorem in A098550 applies to this sequence and is a consequence of greedy solutions to a(n) reliant upon the squarefree kernel, in this case, of a powerful number.
%H A397494 Michael De Vlieger, <a href="/A397494/b397494.txt">Table of n, a(n) for n = 1..16384</a>
%e A397494 Table of n, a(n) for n = 1..21:
%e A397494    n    a(n)  Prime power factors
%e A397494   ----------------------------------
%e A397494    1      1
%e A397494    2      4   2^2
%e A397494    3      9         3^2
%e A397494    4      8   2^3
%e A397494    5     27         3^3
%e A397494    6     16   2^4
%e A397494    7     81         3^4
%e A397494    8     32   2^5
%e A397494    9    225         3^2   5^2
%e A397494   10     64   2^6
%e A397494   11     25               5^2
%e A397494   12     36   2^2   3^2
%e A397494   13    125               5^3
%e A397494   14     72   2^3   3^2
%e A397494   15    625               5^4
%e A397494   16    108   2^2   3^3
%e A397494   17   1225               5^2   7^2
%e A397494   18    128   2^7
%e A397494   19     49                     7^2
%e A397494   20    100   2^2         5^2
%e A397494   21    343                     7^3
%t A397494 nn = 60; hit[_] = False;
%t A397494   s = Union@ Flatten@ Table[a^2*b^3, {b, Surd[#, 3]}, {a, Sqrt[#/b^3] } ] &[nn*2^14];
%t A397494   Set[{i, j, u}, {4, 9, 3}]; Map[Set[hit[#], True] &, {1, 4, 9}];
%t A397494   {s[[1]], s[[2]], s[[4]]}~Join~Reap[Do[k = u;
%t A397494      While[Or[hit[#], CoprimeQ[#, i], ! CoprimeQ[#, j] ] &[s[[k]] ], k++];
%t A397494      Set[{hit[s[[k]] ], i, j}, {True, j, s[[k]] } ]; Sow[s[[k]] ];
%t A397494      If[k == u, While[hit[s[[u]] ], u++] ], {n, 4, nn}] ][[-1, 1]]
%Y A397494 Cf. A001248, A001694, A098550.
%K A397494 nonn,new
