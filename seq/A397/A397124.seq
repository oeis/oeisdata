%e A397124    9           1          (0,0,1, 0)         4
%e A397124   10           1          (0,0,0, 1)         8
%e A397124   11           2          (0,0,0, 2)        16
%e A397124   12           7          (0,1,2, 4)        42
%e A397124   13           1          (0,0,0, 1)         8
%e A397124   14           4          (0,0,3, 1)        20
%e A397124   15           3          (0,0,2, 1)        16
%e A397124   16           1          (0,0,1, 0)         4
%e A397124   17           1          (0,0,0, 1)         8
