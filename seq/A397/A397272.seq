%I A397272 #19 Jul 11 2026 23:38:56
%S A397272 7,11,23,26,28,38,44,63,84,91,92,95,99,104,110,112,140,152,175,176,
%T A397272 189,207,234,247,252,275,286,304,315,329,336,342,343,364,368,380,396,
%U A397272 407,416,440,448,455,465,476,539,559,560,567,575
%N A397272 Integers k such that both Mordell equations y^2 = x^3 + k^3 and y^2 = x^3 - k^3 have nonzero integer solutions.
%C A397272 Intersection of A228948 and A356720.
%C A397272 k has a set of general solutions for any integers (a,b,c): k=a^4 (b^4-12 c^4)(3 b^4-4 c^4);
%C A397272 y^2==x^3+k^3 has a solution: {x,y} = {a^4 (-3 b^8+48 b^6 c^2-152 b^4 c^4+192 b^2 c^6-48 c^8),12 a^6 (3 b^11 c-30 b^9 c^3+136 b^7 c^5-272 b^5 c^7+240 b^3 c^9-96 b c^11)};
%C A397272 y^2==x^3-k^3 has a solution: {x,y} = {a^4 (3 b^8+48 b^6 c^2+152 b^4 c^4+192 b^2 c^6+48 c^8),12 a^6 (3 b^11 c+30 b^9 c^3+136 b^7 c^5+272 b^5 c^7+240 b^3 c^9+96 b c^11)}.
%H A397272 Zhining Yang, <a href="/A397272/b397272.txt">Table of n, a(n) for n = 1..1202</a>
%H A397272 XiaoYang Zhang, <a href="https://www.zhihu.com/question/2044768904506036330">How many prime numbers P are currently known to satisfy the equation y^2 = x^3 +- P^2?</a> (in Chinese).
%e A397272 Integer 11 is in the sequence because both Mordell equations y^2 = x^3 + 11^3 and y^2 = x^3 - 11^3 have integer solutions as {{37,228}} and {{443,9324}}.
%o A397272 (SageMath)
%o A397272 def f(start):
%o A397272     for k in range(start, start + 201):
%o A397272         try:
%o A397272             E1 = EllipticCurve([0,0,0,0,-k^3])
%o A397272             E2 = EllipticCurve([0,0,0,0, k^3])
%o A397272             pts1 = E1.integral_points()
%o A397272             pts2 = E2.integral_points()
%o A397272             if any(pt[0] != k for pt in pts1) and any(pt[0] != -k for pt in pts2):
%o A397272                 print(k)
%o A397272         except:
%o A397272             pass
%o A397272 f(1)
%Y A397272 Cf. A081120, A081119, A228948, A356720, A396853, A396946.
%K A397272 nonn,new
%O A397272 1,1
