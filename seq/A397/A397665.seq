%I A397665 #20 Jul 21 2026 04:19:12
%S A397665 1,5,171,8,0,8864,1567580,3762938,46478818,564426414,14923058975,0,
%T A397665 1649631772087,35745880200118,147951368773034,5000564987675006,
%U A397665 20880784275792583,126382307372799276,0,15560236416416655175,137876550371745394142,0,33109718275005955612566
%N A397665 Least integer equal to the sum of the n-th powers of the tens' complements of its digits or 0 if no such number exists.
%C A397665 In other words, least shy n k-digit number, whatever k is.
%C A397665 For any n (exponent) the relation holds: k - log(k) <= n + 1, for k>0. This helps to limit the range of search.
%C A397665 No values for n equal to 4, 11, 18, 21, 24, 25, ...
%e A397665 a(0) = 1 -> (10 - 1)^0 = 9^0 = 1;
%e A397665 a(1) = 5 -> (10 - 5)^1 = 5^1 = 5;
%e A397665 a(2) = 171 -> (10 - 1)^2 + (10 - 7)^2 + (10 - 1)^2 = 9^2 + 3^2 + 9^2 = 81 + 9 + 81 = 171; etc.
%t A397665 bnd[pw_] := Block[{mx=pw}, While[IntervalIntersection[Interval[{10^(mx-1), 10^mx - 1}], Interval[{2^pw + (mx-1), (mx-1) 10^pw + 9^pw}]] =!= Interval[], mx++]; mx]; cnt[u_, t_] := Block[{v = 0 Range[10]}, Do[If[e == 0, v[[10]]++, v[[e]]++], {e, u}]; v[[t]]++; v];
%t A397665 search[nd_, pw_] := Block[{p, s, b, t, r=Infinity}, Do[If[IntegerQ[r], Break[]]; b = (10-fi)^pw; Do[p = IntegerPartitions[sm, {nd-1}, Range[0, 9]]; s = Select[p, DigitCount[b + Total[(10 - #)^pw]] == cnt[#, fi] &]; If[s != {}, t = Min[Table[b + Total[(10 - e)^pw], {e, s}]]; r = Min[r, t]], {sm, 0, 9 (nd - 1)}], {fi, 9}];r];
%t A397665 a[0]=1; a[n_] := Block[{nd = 1, r = Infinity, mxd = bnd[n]}, While[r == Infinity && nd <= mxd, r = Min[search[nd, n], r]; nd++];If[IntegerQ[r], r, 0]];
%t A397665 a /@ Range[0, 8] (* _Giovanni Resta_, Jul 20 2026 *)
