%U A397658 4563753952908150,11068016086592845380,554015694112230760410,38455207003084252781400,2228479245828732448682130,165024752572685608173460890
%N A397658 Numbers k*P(j) such that bigomega(k) = k - j, where P = A002110 and bigomega = A001222.
%C A397658 Intersection of A060735 and A396594.
%C A397658 Numbers k in A060735 such that rad(k)*bigomega(k) = k, where rad = A007947 and bigomega = A001222.
%C A397658 Apart from 2 and 4, this sequence is a subset of A332785 (neither squarefree nor powerful).
%H A397658 Michael De Vlieger, <a href="/A397658/b397658.txt">Table of n, a(n) for n = 1..352</a>
%e A397658 Let T(j,k) = P(j)*k with k = 1..prime(j+1)-1. Then T(j,k) is a term iff bigomega(T(j,k)) = k.
%e A397658 Table of n, (j,k), a(n) for n = 1..12:
%e A397658                                             row a(n) of A067255
%e A397658                                             exponents of primes:
%e A397658                                                     1 1 1 1 2 2
%e A397658    n    (j, k)           a(n)               2 3 5 7 1 3 7 9 3 9
%e A397658   -------------------------------------------------------------
%e A397658    1    (1, 1)             2 =  1 * P(1)    1
%e A397658    2    (1, 2)             4 =  2 * P(1)    2
%e A397658    3    (2, 3)            18 =  3 * P(2)    1,2
%e A397658    4    (2, 4)            24 =  4 * P(2)    3,1
%e A397658    5    (4, 5)          1050 =  5 * P(4)    1,1,2,1
%e A397658    6    (4, 6)          1260 =  6 * P(4)    2,2,1,1
%e A397658    7    (5, 8)         18480 =  8 * P(5)    4,1,1,1,1
%e A397658    8    (6, 7)        210210 =  7 * P(6)    1,1,1,2,1,1
%e A397658    9    (7, 9)       4594590 =  9 * P(7)    1,3,1,1,1,1,1
%e A397658   10    (8,10)      96996900 = 10 * P(8)    2,1,2,1,1,1,1,1
%e A397658   11    (9,12)    2677114440 = 12 * P(9)    3,2,1,1,1,1,1,1,1
%e A397658   12   (10,11)   71166625530 = 11 * P(10)   1,1,1,1,2,1,1,1,1,1
%e A397658   ...
%t A397658 Union@ Flatten@ Table[Product[Prime[i], {i, n}]*Select[Range[Prime[n + 1] - 1], PrimeOmega[#] == # - n &], {n, 0, 20}]
%Y A397658 Cf. A001222, A002110, A007947, A060735, A332785, A396594.
%K A397658 nonn,easy,new
%O A397658 1,1
