%I A397167 #50 Jun 24 2026 15:42:55
%S A397167 0,0,1,0,1,2,0,3,0,3,4,0,5,0,1,5,6,0,1,7,1,8,1,2,8,9,1,2,10,2,11,2,3,
%T A397167 11,12,2,3,4,13,3,4,14,4,15,4,5,15,16,4,5,6,17,5,6,18,6,19,6,7,19,20,
%U A397167 6,7,8,21,7,8,9,22,8,9,23,9,24,9,10,24,25,9,10,11,26
%N A397167 Consider the square spiral with cells labeled counterclockwise starting at 0, as in A304586 and A307282; sequence gives irregular triangle read by rows, where row n lists the neighbors of cell n that already exist when cell n is being filled in.
%H A397167 Paolo Xausa, <a href="/A397167/b397167.txt">Table of n, a(n) for n = 1..10100</a> (rows 1..2600 of triangle, flattened).
%e A397167  The spiral begins:
%e A397167  .
%e A397167   ..16--15--14--13--12
%e A397167   ...|...............|
%e A397167   ..17...4---3---2..11
%e A397167   ...|...|.......|...|
%e A397167   ..18...5...0---1..10
%e A397167   ...|...|...........|
%e A397167   ..19...6---7---8---9
%e A397167   ...|...................|
%e A397167   ..20--21--22--23--24--25
%e A397167   .
%e A397167 The irregular triangle, with rows labeled 1, 2, 3, ..., begins as follows:
%e A397167   0,
%e A397167   0, 1,
%e A397167   0, 1, 2, [when filling in cell 3, its existing neighbors are cells 0,1,2]
%e A397167   0, 3, [when filling in cell 4, its existing neighbors are cells 0,3]
%e A397167   0, 3, 4, [when filling in cell 5, its existing neighbors are 0,3,4]
%e A397167   0, 5,
%e A397167   0, 1, 5, 6,
%e A397167   0, 1, 7,
%e A397167   1, 8,
%e A397167   1, 2, 8, 9,
%e A397167   1, 2, 10,
%e A397167   2, 11,
%e A397167   2, 3, 11, 12,
%e A397167   2, 3, 4, 13,
%e A397167   3, 4, 14,
%e A397167   4, 15,
%e A397167   4, 5, 15, 16,
%e A397167   4, 5, 6, 17,
%e A397167   5, 6, 18,
%e A397167   6, 19,
%e A397167   6, 7, 19, 20,
%e A397167   6, 7, 8, 21,
%e A397167   7, 8, 9, 22,
%e A397167   8, 9, 23,
%e A397167   9, 24,
%e A397167   ,
%e A397167 Note that the last entry in row n is always n-1.
%t A397167 A397167list[hs_] := Module[{s, x, y, c = 0, l = 0, nxt, fs},
%t A397167   If[hs == 0, Return[{{0}}]];
%t A397167   s = CenterArray[0, {fs = 2*hs + 1, fs}, -1]; x = y = hs + 1;
%t A397167   nxt[ix_, iy_, len_] := Do[x += ix; y += iy; Sow[Sort[Select[Flatten[s[[Max[1, x-1] ;; Min[fs, x+1], Max[1, y-1] ;; Min[fs, y+1]]]], # >= 0 &]]]; s[[x, y]] = ++c, len];
%t A397167   Reap[Do[nxt[1, 0, ++l]; nxt[0, -1, l]; nxt[-1, 0, ++l]; nxt[0, 1, l], hs]; nxt[1, 0, l]][[2, 1]]
%t A397167 ]; (* Considers a spiral with side 2*hs + 1 *)
%t A397167 A397167list[3] (* _Paolo Xausa_, Jun 22 2026 *)
%Y A397167 Cf. A304586, A307282, A278354 (row lengths, shifted by one), A394513 (row sums).
