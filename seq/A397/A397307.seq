%S A397307 0,0,0,1,1,1,2,0,2,1,2,0,2,0,3,0,1,1,3,0,4,0,2,0,2,0,3,0,1,0,2,0,3,1,
%T A397307 3,0,2,0,4,0,1,0,2,0,5,0,2,0,3,0,3,0,1,0,3,0,2,0,1,0,3,0,4,0,1,1,2,0,
%U A397307 5,0,2,0,2,0,6,0,3,0,2,0,3,0,3,0,2,0,4,0,1,0
%N A397307 Number of primes of the form n - 2^k, where k >= 1.
%C A397307 Equivalently, number of representations of n of the form n = p+2^k, with k > 0 and p prime.
%C A397307 Inspired by the condition k > 0 of Erdős conjecture in A039669.
%C A397307 This sequence differs from A109925, where k >= 0.
%C A397307 a(n) <= A109925(n) with equality iff (for n >= 3, n-1 is composite) or iff (n is in A079696 Union {1, 2}).
%C A397307 a(n) = 0 iff n is in A397305 Union {1, 2, 3}.
%C A397307 a(n) = 1 iff n is in A397306.
%F A397307 a(n) = A109925(n) - A010051(n-1) for n >= 2.
%e A397307 a(5) = 1 since 5-2=3, 5-4=1 and only 3 is prime.
%e A397307 a(11) = 2 since 11-2=9, 11-4=7, 11-8= 3 and we get 2 primes (3 and 7).
%e A397307 a(12) = 0 since 12-2=10, 12-4=8, 12-8=4 and 4, 8, 10 are not primes.
%e A397307 a(75) = 6 since 75-2=73, 75-4=71, 75-8=67, 75-16=59, 75-32=43, 75-64=11 and 11, 43, 59, 67, 71, 73 are 6 prime numbers, also A039669(6) = 75.
%t A397307 a[n_]:=Sum[Boole[PrimeQ[n-2^k]],{k,Floor[Log2[n]]}]; Array[a,90] (* _Stefano Spezia_, Jul 06 2026 *)
%o A397307 (PARI) a(n) = sum(k=1, logint(n, 2), isprime(n-2^k)); \\ _Michel Marcus_, Jul 06 2026
%Y A397307 Cf. A010051, A039669, A079696, A109925.
%Y A397307 Cf. A397305, A397306.
%K A397307 nonn,easy,new
%O A397307 1,7
%A A397307 _Bernard Schott_, Jul 06 2026
