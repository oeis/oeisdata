%T A397276 11,29,7,11,37,2,3,5,7,11,19,19,29,53,2,5,5,7,7,13,13,19,43,67,2,5,5,
%U A397276 7,19,19,13,41,23,43,41,2,5,7,23,11,13,19,19,37,37,127,79
%N A397276 Triangle read by rows: T(n,k) is the smallest prime p such that p^k in base n contains exactly k distinct digits, for 1 <= k <= n (n >= 2), and T(1,1) = 2.
%C A397276 Prime-only variant of the triangle A247045, with row n corresponding to base n.
%e A397276 The values for T(n,k) are as follows (n refers to row n and its corresponding base):
%e A397276   2;
%e A397276   3, 2; (base 2)
%e A397276   2, 3, 7; (base 3)
%e A397276   2, 2, 3, 5; (base 4)
%e A397276   2, 3, 3, 7, 17; (base 5)
%e A397276   2, 3, 5, 7, 7, 23; (base 6)
%e A397276   2, 3, 5, 11, 5, 17, 41; (base 7)
%e A397276   2, 5, 5, 11, 29, 7, 11, 37; (base 8)
%e A397276   2, 3, 5, 7, 11, 19, 19, 29, 53; (base 9)
%e A397276   2, 5, 5, 7, 7, 13, 13, 19, 43, 67; (base 10)
%e A397276 T(10,10) = 67 because 67^10 is 1822837804551761449, which is the smallest prime p such that p^10 contains exactly 10 distinct digits (0 through 9).
%t A397276 T[1, 1] = 2;
%t A397276 T[n_, k_] := Module[{p = 2}, While[Length[Union[IntegerDigits[p^k, n]]] != k, p = NextPrime[p]]; p];
%t A397276 Table[T[n, k], {n, 1, 12}, {k, 1, n}] // Flatten
%o A397276 (Python)
%o A397276 from sympy import nextprime
%o A397276 def T(n, k):
%o A397276     if n == 1:
%o A397276         return 2
%o A397276     p = 2
%o A397276     while True:
%o A397276         v, d = p**k, set()
%o A397276         while v > 0:
%o A397276             d.add(v % n)
%o A397276             v //= n
%o A397276         if len(d) == k:
%o A397276             return p
%o A397276         p = nextprime(p)
%o A397276 print([T(n, k) for n in range(1, 13) for k in range(1, n + 1)])
%o A397276 (PARI) T(n, k) = if ((n==1) && (k==1), 1, my(m=2); while(#Set(digits(m^k, n)) != k, m=nextprime(m+1)); m);
%o A397276 row(n) = if (n==1, [2], vector(n, k, T(n, k))); \\ _Michel Marcus_, Jun 20 2026
