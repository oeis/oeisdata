%U A397073 391713739171393,2357137939171373,23571379391713739,137937179917373911,7391713939713793717,71379391713739171393,137939171373917139397,7939171373917139397137
%N A397073 a(n) is the first concatenation of final digits of n consecutive primes that is prime.
%C A397073 a(n) is the concatenation of the final digits of n consecutive primes starting at A397072(n).
%H A397073 Robert Israel, <a href="/A397073/b397073.txt">Table of n, a(n) for n = 1..997</a>
%e A397073 a(5) = 17137 because the 5 consecutive primes starting with 31 are 31, 37, 41, 43 and 47, the concatenation of their last digits is 17137, which is prime, and no prime less than 31 works.
%p A397073 P:= select(isprime, [2, seq(i, i=3..10^6, 2)]):
%p A397073 lcat:= proc(L) local i, t;
%p A397073   add((L[i] mod 10)*10^(nops(L)-i), i=1..nops(L))
%p A397073 end proc:
%p A397073 f:= proc(n) local i, j, v;
%p A397073   for i from 1 do
%p A397073     v:= lcat(P[i..i+n-1]);
%p A397073     if isprime(v) then return v fi
%p A397073   od
%p A397073 end proc:
%p A397073 map(f, [$1..100]);
%t A397073 a[n_]:=Module[{p=0},Until[PrimeQ[FromDigits[Last/@IntegerDigits/@Prime[Range[p,p+n-1]]]],p++];FromDigits[Last/@IntegerDigits/@Prime[Range[p,p+n-1]]]];Array[a,22] (* _James C. McMahon_, Jul 05 2026 *)
