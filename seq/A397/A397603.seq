%S A397603 1,1,0,2,1,1,5,3,2,1,20,15,12,10,9,102,82,67,55,45,36,612,510,428,361,
%T A397603 306,261,225,3999,3387,2877,2449,2088,1782,1521,1296,27680,23681,
%U A397603 20294,17417,14968,12880,11098,9577,8281,199700,172020,148339,128045,110628,95660,82780,71682,62105,53824
%N A397603 Triangle read by rows: T(n, k) = T(n, k+1) + T(n-1, k) with initial values T(n, n) = A005043(n)^2.
%e A397603 Triangle starts:
%e A397603   [0]      1;
%e A397603   [1]      1,     0;
%e A397603   [2]      2,     1,     1;
%e A397603   [3]      5,     3,     2,     1;
%e A397603   [4]     20,    15,    12,    10,     9;
%e A397603   [5]    102,    82,    67,    55,    45,    36;
%e A397603   [6]    612,   510,   428,   361,   306,   261,   225;
%e A397603   [7]   3999,  3387,  2877,  2449,  2088,  1782,  1521, 1296;
%e A397603   [8]  27680, 23681, 20294, 17417, 14968, 12880, 11098, 9577, 8281;
%p A397603 T := proc(n, k) option remember; if n = k then simplify(hypergeom([-n,1/2], [2], 4))^2 else T(n, k+1) + T(n-1, k) fi end: seq(lprint([n], seq(T(n, k), k = 0..n)), n = 0..9);
%o A397603 (Python)
%o A397603 def row_gen():
%o A397603     a, b, n, m = 1, 0, 0, 1
%o A397603     row = []
%o A397603     while True:
%o A397603         row.append(m * m)
%o A397603         for k in range(n, 0, -1):
%o A397603             row[k - 1] += row[k]
%o A397603         yield row[:]
%o A397603         m = n * (2*b + 3*a) // (n + 2)
%o A397603         a, b = (a, b) if n == 0 else (b, m)
%o A397603         n += 1
%o A397603 A397603_row = row_gen()
%o A397603 for _ in range(9): print(next(A397603_row))
%Y A397603 Cf. A005043, A397419 (column 0), A397602 (row sums).
%K A397603 nonn,tabl,new
%O A397603 0,4
