%I A397266 #14 Jun 29 2026 23:29:47
%S A397266 0,1,1,1,6,6,8,13,17,17,28,28,34,43,49,49,68,68,76,89,99,99,124,124,
%T A397266 136,153,165,165,198,198,212,233,249,249,288,288,306,331,349,349,396,
%U A397266 396,416,445,467,467,520,520,544,577,601,601,662,662,688,725,753,753,820,820,850
%N A397266 Lower (1,1) midsequence of (floor[n/2]^2) and (ceiling[n/3]^2); see Comments.
%C A397266 Suppose that s = (s(n)) and t = (t(n)) are sequences of numbers and h > 0 and k > 0. The lower (h, k)-midsequence of s and t is floor(h*s + k*t); the upper (h, k)-midsequence of s and t is ceiling(h*s + k*t).
%H A397266 Index entries for linear recurrences with constant coefficients, signature (-1,0,2,3,1,-1,-3,-2,0,1,1).
%F A397266 a(n) = - a(n-1) + 2 a(n-3) + 3 a(n-4) +  a(n-5) - a(n-6) - 3 a(n-7) - 2 a(n-8) + a(n-10) + a(n-11), with (a(0),...,a(11)) = (0, 1, 1, 1, 6, 6, 8, 13, 17, 17, 28).
%t A397266 z = 60;
%t A397266 f[n_] := Floor[n/2]^2; g[n_] := Ceiling[n/3]^2;
%t A397266 r = 1; s = 1;
%t A397266 u[n_] := Floor[r*f[n] + s*g[n]]; v[n_] := Ceiling[r*f[n] + s*g[n]]
%t A397266 Table[u[n], {n, 0, z}]
%t A397266 (* Alternative: *)
%t A397266 LinearRecurrence[{-1, 0, 2, 3, 1, -1, -3, -2, 0, 1, 1}, {0, 1, 1, 1, 6, 6, 8, 13, 17, 17, 28}, 30]
%Y A397266 Cf. A389123, A397110, A397267.
%K A397266 nonn,easy,new
%O A397266 0,5
%A A397266 _Clark Kimberling_, Jun 21 2026
