%S A397792 1,6,16,63,206,735,2517,8786,30396,105597,366136,1270653,4407861,
%T A397792 15293766,53059244,184088347,638679318,2215865819,7687801737,
%U A397792 26672380130,92538181016,321055664409,1113883127024,3864550223769,13407822958537,46517630728134,161390104432872
%N A397792 Number of ways to tile a 2 X n strip with alternate corners missing, using squares, dominoes, and Z-shaped tetrominoes.
%C A397792 Compare to A397583 which counts these tilings for a 2 X n strip with only one missing corner, and with T-shaped tetrominoes instead of Z-shaped tetrominoes.
%H A397792 <a href="/index/Rec#order_06">Index entries for linear recurrences with constant coefficients</a>, signature (2,6,-2,-4,0,1).
%F A397792 a(n) = 2*a(n-1) + 6*a(n-2) - 2*a(n-3) - 4*a(n-4) + a(n-6).
%F A397792 G.f.: x^2*(-1 - 4*x + 2*x^2 + 3*x^3 - x^5)/((-1 - x + x^2)*(1 - 3*x - 2*x^2 + x^3 + x^4)).
%e A397792 Here is one of the a(6)=206 ways to tile this 2 X 6 strip (with alternate missing corners) using squares, dominoes, and Z-shaped tetrominoes:
%e A397792    _________
%e A397792   |_  |_| |_|_
%e A397792     |___|_|___|.
%t A397792 LinearRecurrence[{2, 6, -2, -4, 0, 1}, {1, 6, 16, 63, 206, 735}, 30];
%Y A397792 Cf. A397583.
%K A397792 nonn,easy,new
%O A397792 2,2
