%N A397640 Least k such that {1^n, 2^n, ..., k^n} contains numbers with every digit from 1 through 9.
%C A397640 Due to the relationship with A137214, it appears a(n) <= 2 starting at a(169); a(n) = 1 for all zeroless pandigital (A050289) and pandigital (A171102) numbers n. - _Michael S. Branicky_, Jul 03 2026
%H A397640 Michael S. Branicky, <a href="/A397640/b397640.txt">Table of n, a(n) for n = 1..10000</a> (terms 1..3000 from Vincenzo Librandi)
%F A397640 From _Michael S. Branicky_, Jul 03 2026: (Start)
%F A397640 a(n) <= A395429(n).
%F A397640 a(n) <= A020666(n).
%F A397640 a(n) = 1 for all n in A050289 or A171102.
%F A397640 a(n) <= 2 for all n where A137214(n) = 10. (End)
%t A397640 digits[n_]:=IntegerDigits[n]; isok[k_,n_]:=Module[{s={1},i=2},While[i<=k,s=Union[s,DeleteCases[digits[i^n],0]]; i++;]; Sort[s]==Range[9]]; a[n_]:=Module[{k=1},While[!isok[k,n],k++]; k]; Table[a[n],{n,1,100}] (* _Vincenzo Librandi_, Jul 03 2026 *)
%o A397640 (PARI) isok(k, n) = my(d=[1]); for (i=2, k, d = concat(d, digits(i^n))); Set(select(x->x>0, d)) == Set([1..9]);
%o A397640 a(n) = my(k=1); while (!isok(k, n), k++); k; \\ _Michel Marcus_, Jul 03 2026
%o A397640 (Magma) N:=100; function IsOk(k,n) S:={1}; for i in [2..k] do m:=i^n; while m gt 0 do
%o A397640 Include(~S,m mod 10); m div:=10; end while; end for; Exclude(~S,0); return S eq {1..9};
%o A397640 end function; function a(n) k:=1; while not IsOk(k,n) do k+:=1; end while;
%o A397640 return k; end function; [a(n): n in [1..N]]; // _Vincenzo Librandi_, Jul 03 2026
%o A397640 (Python)
%o A397640 from gmpy2 import digits, mpz
%o A397640 from itertools import count
%o A397640 def a(n): s, D = {"1"}, set("123456789"); return next(k for k in count(2) if (s:=s|set(digits(mpz(k)**mpz(n))))>=D)
%o A397640 print([a(n) for n in range(1, 88)]) # _Michael S. Branicky_, Jul 03 2026
%Y A397640 Cf. A020666, A050289, A137214, A171102, A395429.
%K A397640 nonn,base,new
