%I A397973 #7 Jul 20 2026 01:15:49
%S A397973 0,2,5,9,16,24,33,45,58,72,89,107,126,148,171,195,222,250,279,311,344,
%T A397973 378,415,453,492,534,577,621,668,716,765,817,870,924,981,1039,1098,
%U A397973 1160,1223,1287,1354,1422,1491,1563,1636,1710,1787,1865,1944,2026,2109
%N A397973 Upper (1,1/3) midsequence of midsequence of triangular numbers (A000217) and squares (A000290); see Comments.
%C A397973 Suppose that s = (s(n)) and t = (t(n)) are sequences of numbers and h > 0 and k > 0. The lower (h, k)-midsequence of s and t is floor(h*s + k*t); the upper (h, k)-midsequence of s and t is ceiling(h*s + k*t). See A397972 for a guide to related sequences.
%H A397973 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (2,-1,1,-2,1).
%F A397973 a(n) = 2*a(n-1) - a(n-2) + a(n-3) - 2*a(n-4) + a(n-5), with (a(0),...,a(4)) = (0, 2, 5, 9, 16).
%F A397973 G.f.: x*(-2 - x - x^2 - x^3)/((-1 + x)^3 (1 + x + x^2)).
%F A397973 E.g.f.: (exp(x)*(8 + 24*x + 15*x^2) - 8*exp(-x/2)*cos(sqrt(3)*x/2))/18. - _Stefano Spezia_, Jul 18 2026
%t A397973 z = 60;
%t A397973 f[n_] := (n^2 + n)/2; g[n_] := n^2; r = 1; s = 1/3;
%t A397973 u[n_] := Floor[r*f[n] + s*g[n]]; v[n_] := Ceiling[r*f[n] + s*g[n]]
%t A397973 Table[v[n], {n, 0, z}]
%Y A397973 Cf. A000217, A000290, A397972.
%K A397973 nonn,easy,new
%O A397973 0,2
%A A397973 _Clark Kimberling_, Jul 18 2026
