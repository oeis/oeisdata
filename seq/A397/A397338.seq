%I A397338 #19 Jul 02 2026 17:08:18
%S A397338 3,307,431,857,1109,1583,3967,5519,7451,8423,12739,13337,13921,16087,
%T A397338 23059,25873,60793,63997,171671,253433,340127,457553,580201,977791,
%U A397338 1267663,1329217,2059711,2607469,3032279,6253549,11761777,34929547,45740213,51656281,213350989,227710961,316867699,1033090529,11342219743
%N A397338 In the prime race that counts the 40 mod 100 residues 10k + {1,3,7,9} (k = 0...9), primes at which one of the residues leads for the first time.
%C A397338 This is a finite sequence with 40 terms, but only the first 39 terms are currently known, with the "missing" residue being 41.
%C A397338 In June 2026 Benjamin Chaffin proved that a(40) > 10^19.
%H A397338 G. L. Honaker, Jr., <a href="https://t5k.org/curios/page.php?curio_id=48895">Prime Curio for 41</a>.
%e A397338 a(2) = 307, because at 307 three primes with mod 100 residue of 7 have appeared so far (7, 107, and 307), all other residues have appeared < 3 times, and this is the first time residue 7 is in the lead.
%o A397338 (PARI)
%o A397338 {
%o A397338 agen(last) =
%o A397338  h = matrix(2, 100);
%o A397338  for (i = 1, 100, h[1, i] = i);
%o A397338  seen = vector(100);
%o A397338  forprime (i = 3, last,
%o A397338   k = i % 100;
%o A397338   h[2, k]++;
%o A397338   s = vecsort(h, 2);
%o A397338   index = s[1, 100];
%o A397338   if (seen[index] == 0 && s[2, 100] != s[2, 99],
%o A397338     seen[index] = 1;
%o A397338     printf("%2d at %9d  count = %d\n", index, i, s[2, 100]);
%o A397338    );
%o A397338  );
%o A397338 }
%o A397338 agen(10^8) /* _Mike Keith_, Jun 21 2026 */
%Y A397338 Cf. A000040.
%K A397338 nonn,fini
%O A397338 1,1
%A A397338 _G. L. Honaker, Jr._, Jun 21 2026
%E A397338 a(1)-a(39) from _Mike Keith_, Jun 21 2026
