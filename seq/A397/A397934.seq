%I A397934 #9 Jul 22 2026 22:44:23
%S A397934 48,50,54,60,75,80,84,96,98,112,120,132,135,140,147,150,156,160,162,
%T A397934 168,175,176,180,189,192,204,208,220,224,228,240,242,245,250,252,260,
%U A397934 264,270,272,275,276,280,294,297,300,304,308,312,320,325,336,338,340,348
%N A397934 Numbers that are neither squarefree, powerful, nor in either A396594 or A397221.
%C A397934 Numbers k such that all of the following are false:
%C A397934   rad(k) = k, where rad = A007947,
%C A397934   rad(k)^2 | k,
%C A397934   k = rad(k)*omega(k), where omega = A001221,
%C A397934   k = rad(k)*bigomega(k), where bigomega = A001222.
%C A397934 This sequence is A332785 \ (A397932 U A397933).
%C A397934 Smallest k such that omega(k) = j for j > 2 is 2*A002110(j).
%C A397934 Smallest k such that omega(k) = j for j > 1 and omega(k/rad(k)) = omega(k)-1 is A061742(j)/prime(j).
%H A397934 Michael De Vlieger, <a href="/A397934/b397934.txt">Table of n, a(n) for n = 1..10000</a>
%H A397934 Michael De Vlieger, <a href="/A397934/a397934.png">List of k = A322785(i)</a>, i = 1..1296, showing k in A397932 in cyan, k in A397933 in magenta, and k in this sequence in blue.
%H A397934 Michael De Vlieger, <a href="/A397934/a397934_1.png">Plot a(n) at (x,y) = (floor(n/1024),-(n mod 1024))</a>, n = 1..2^20, showing numbers in A397932 in cyan, those in A397933 in cyan, and numbers in this sequence in blue.
%e A397934 Let R = A332785, S = A397932, and T = A397933.
%e A397934 Table of n, R(n) for n - 1..24:
%e A397934    i         R(n)
%e A397934 ---------------------------------
%e A397934    1     S    12 = 2^2 *  3
%e A397934    2     T    18 = 2   *  3^2
%e A397934    3     S    20 = 2^2 *  5
%e A397934    4     T    24 = 2^3 *  3
%e A397934    5     S    28 = 2^2 *  7
%e A397934    6     T    40 = 2^3 *  5
%e A397934    7     S    44 = 2^2 * 11
%e A397934    8     T    45 = 3^2 *  5
%e A397934    9   a(1)   48 = 2^4 *  3
%e A397934   10   a(2)   50 = 2   *  5^2
%e A397934   11     S    52 = 2^2 * 13
%e A397934   12   a(3)   54 = 2   *  3^3
%e A397934   13     T    56 = 2^3 *  7
%e A397934   14   a(4)   60 = 2^2 *  3   * 5
%e A397934   15     T    63 = 3^2 *  7
%e A397934   16     S    68 = 2^2 * 17
%e A397934   17   a(5)   75 = 3   *  5^2
%e A397934   18     S    76 = 2^2 * 19
%e A397934   19   a(6)   80 = 2^4 *  5
%e A397934   20   a(7)   84 = 2^2 *  3   * 7
%t A397934 rad[x_] := Times @@ FactorInteger[x][[All, 1]]; s = Select[Range[360], Nor[SquareFreeQ[#], Divisible[#, rad[#]^2]] &]; Select[s, FreeQ[rad[#]*{PrimeNu[#], PrimeOmega[#]}, #] &]
%Y A397934 Cf. A001221, A001222, A001694, A005117, A332785, A396594, A397221, A397932, A397933.
