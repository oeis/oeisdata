%S A397349 1,11,442,31067,3206716,449186642,81672451246,18712372962179,
%T A397349 5283023715985312,1804845799540651166,734702600823688761892,
%U A397349 351659064307194057708998,195631985621033156376411868,125215379678237086255252921004,91388839944162458173310468056342,75458744412884411327678310461788643
%N A397349 L.g.f. Sum_{n>=1} a(n)*x^n/n = log(1+x + Sum_{n>=2} 3*n/(3*n^2 - 1) * a(n)*x^n ).
%C A397349 Conjecture: a(n) is odd iff n is a power of 2.
%C A397349 Conjecture: a(n) = [1,2] repeating (mod 3) for n >= 1.
%H A397349 Paul D. Hanna, <a href="/A397349/b397349.txt">Table of n, a(n) for n = 1..400</a>
%F A397349 L.g.f. L(x) = Sum_{n>=1} a(n)*x^n/n satisfies the following formulas.
%F A397349 (1) L(x) = log(1+x + Sum_{n>=2} 3*n/(3*n^2 - 1) * a(n)*x^n ).
%F A397349 (2) L(x) equals the logarithm of the g.f. of A397348.
%F A397349 (3) a(n) = (3*n^2 - 1)/(3*n) * A397348(n) for n > 1 with a(1) = 1.
%e A397349 L.g.f.: L(x) = x + 11*x^2/2 + 442*x^3/3 + 31067*x^4/4 + 3206716*x^5/5 + 449186642*x^6/6 + 81672451246*x^7/7 + 18712372962179*x^8/8 + ...
%e A397349 where exponentiation yields the g.f. of A397348
%e A397349 exp(L(x)) = 1 + x + 6*x^2 + 153*x^3 + 7932*x^4 + 650010*x^5 + 75564108*x^6 + 11747407371*x^7 + ... + 3*n/(3*n^2-1) * a(n)*x^n + ...
%o A397349 (PARI) {a(n) = my(L=[0, 1], A, m); for(i=2, n, L=concat(L, 0); A = exp(Ser(L)); m = #L-1;
%o A397349 L[#L] = (3*m^2-1)*polcoef(A, m) - 3*m^2*polcoef(log(A), m) ); GF=Ser(L); L[n+1]}
%o A397349 \\ returns a vector of terms a(k) for k = 1..n
%o A397349 {upto(n) = a(n); Vec(GF')}
%o A397349 upto(25)
%Y A397349 Cf. A397346, A396846, A397348.
%K A397349 nonn
%O A397349 1,2
%A A397349 _Paul D. Hanna_, Jun 27 2026
