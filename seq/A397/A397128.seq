%I A397128 #10 Jul 01 2026 22:45:44
%S A397128 12,18,175,140,24,45,20,28,63,48,40,75,54,44,99,60,50,117,156,56,147,
%T A397128 90,80,153,204,52,325,120,84,245,135,96,68,425,150,126,539,88,76,171,
%U A397128 132,176,189,168,92,207,162,98,315,180,104,351,192,112,525,240,116,261
%N A397128 Lexicographically earliest sequence of distinct numbers k that are neither squarefree nor powerful (k in A332785), such that for any prime p, any run of consecutive multiples of p has length exactly 2.
%C A397128 Like A280864, this sequence can be partitioned into blocks on the occasion of coprime a(j) and a(j+1).
%C A397128 This sequence eliminates the confinement of a certain class of number (wherein the class is related to prime power decomposition) to the first or last terms in a block. In s = A280864, for instance, prime powers may only occur at the beginning or end of a block, that is, such that s(n) is coprime to at least one of s(n-1) or s(n+1).
%C A397128 This said, this sequence preserves the following qualities pertinent to A280864:
%C A397128 A.) Terms a(j) that are coprime to a neighbor (at the beginning or end of a block) are such that rad(a(j)) divides the other neighbor (where rad = A007947),
%C A397128 B.) Terms a(n) that are noncoprime to both neighbors (i.e., in the middle of a block) are such that rad(a(j)) divides neither neighbor.
%C A397128 Duplex blocks {k,m} have rad(k) = rad(m), and apart from the first, {12,18}, k | m. Are there any other duplex blocks such that rad(k) = rad(m) yet k does not divide m?
%C A397128 Agrees with A397127 through a(9); S20260622(10) = 36, which is forbidden in this sequence.
%C A397128 Conjecture: permutation of A332785.
%H A397128 Michael De Vlieger, <a href="/A397128/b397128.txt">Table of n, a(n) for n = 1..16384</a>
%e A397128 Table of the first 16 terms:
%e A397128    n   a(n)  Prime power factors
%e A397128   ------------------------------
%e A397128    1    12 = 2^2   3
%e A397128    2    18 = 2     3^2
%e A397128    3   175 =             5^2   7
%e A397128    4   140 = 2^2         5     7
%e A397128    5    24 = 2^3   3
%e A397128    6    45 =       3^2   5
%e A397128    7    20 = 2^2         5
%e A397128    8    28 = 2^2               7
%e A397128    9    63 =       3^2         7
%e A397128   10    48 = 2^4   3
%e A397128   11    40 = 2^3         5
%e A397128   12    75 =       3     5^2
%t A397128 Block[{c, k, m, r, s, w, nn, rad},
%t A397128   nn = 2^15; c[_] := False; r = s = 1;
%t A397128   rad[n_] := rad[n] = Times @@ FactorInteger[n][[All, 1]];
%t A397128   Reap[Do[w = GCD[r, s]; m = r/w; k = m;
%t A397128     While[Or[c[k], SquareFreeQ[k],
%t A397128       Divisible[k, rad[k]^2], ! CoprimeQ[w, k] ], k += m];
%t A397128     Sow[k]; Set[{c[k], s, r}, {True, r, rad[k] } ],
%t A397128     {i, nn} ] ][[-1, 1]] ]
%Y A397128 Cf. A007947, A280864, A332785, A338444 (squarefree version), A397126 (powerful version), A397127 (confined to A126706, superset of A332785), A397368 (proper prime power version).
%K A397128 nonn,new
%O A397128 1,1
%A A397128 _Michael De Vlieger_, Jun 21 2026
