%N A397956 Polydivisible numbers in base 6.
%C A397956 For the definition of polydivisible number in base b, see A397953.
%H A397956 Michael S. Branicky, <a href="/A397956/b397956.txt">Table of n, a(n) for n = 1..324</a> (full sequence)
%H A397956 Wikipedia, <a href="https://en.wikipedia.org/wiki/Polydivisible_number">Polydivisible number</a>.
%F A397956 a(A271374(6)) = A109032(6).
%e A397956 960120 is a term because 960120_10 = 32325000_6 and all of the following conditions are true:
%e A397956   3_6        =      3_10 is divisible by 1;
%e A397956   32_6       =     20_10 is divisible by 2;
%e A397956   323_6      =    123_10 is divisible by 3;
%e A397956   3232_6     =    740_10 is divisible by 4;
%e A397956   32325_6    =   4445_10 is divisible by 5;
%e A397956   323250_6   =  26670_10 is divisible by 6;
%e A397956   3232500_6  = 160020_10 is divisible by 7;
%e A397956   32325000_6 = 960120_10 is divisible by 8.
%t A397956 (* polyDivQ is defined at A397953 *)
%t A397956 Select[Range[0, 648], polyDivQ[#, 6] &]
%t A397956 (* Alternative: *)
%t A397956 (* polyDivFullList is defined at A144688 *)
%t A397956 polyDivFullList[6][[;; 70]]
%o A397956 (Python) # uses polydiv in A397953
%o A397956 print([an for an in polydiv(base=6)]) # _Michael S. Branicky_, Jul 16 2026
