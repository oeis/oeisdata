%I A397051 #12 Jun 24 2026 00:36:34
%S A397051 4,5,63,443,2725,20243,167982,1496045
%N A397051 a(n) is the number of n-digit terms in A397050.
%F A397051 Conjecture: lim_{n->oo} a(n+1)/a(n) = 10.
%t A397051 nmax=4; a={2}; For[k=3, k<=10^nmax-1, k++, If[AllTrue[a, Mod[DigitSum[k],#]!=0 &] && PrimeQ[k], AppendTo[a,k]]]; Table[Length[Select[a, IntegerLength[#]==i &]], {i, nmax}]
%Y A397051 Cf. A397050.
%K A397051 nonn,base,hard,more,new
%O A397051 1,1
%A A397051 _Stefano Spezia_, Jun 14 2026
