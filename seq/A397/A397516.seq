%S A397516 0,1,12,170,2575,40425,648907,10575377,174252924,2895217379,
%T A397516 48419310224,814028835840,13744828002374,232922192929973,
%U A397516 3959291207865012,67479499735126731,1152719661778233935,19731056022350430390,338337704093271741475,5810843901021199507951
%N A397516 a(n) = Sum_{k=0..n} binomial(5*n+2*k-3,k-1).
%H A397516 Robert Israel, <a href="/A397516/a397516.txt">Recurrence of order 13 for n >= 1</a>
%F A397516 G.f.: x*g^4/((1-7*x*g^6) * (1-x*g^5)) where g = 1+x*g^7 is the g.f. of A002296.
%F A397516 G.f.: (-1+g)/((7-6*g) * (1-g+g^2)) where g = 1+x*g^7 is the g.f. of A002296.
%F A397516 Here and below, binomial(N,k) = 0 for k<0.
%F A397516 a(n) = Sum_{k=0..n} (-1)^k * binomial(7*n+k-1,n-k-1).
%F A397516 a(n) = Sum_{k=0..floor(n/2)} (-1)^k * binomial(7*n-k-2,n-2*k-1).
%F A397516 This is the special case l=5, m=2, c=0, r=0, s=-1 of the following family. For integers l, m, c in Z, and for any constants r and s, define a_{l,m,c,r,s}(n) = Sum_{k=0..n} (r*binomial(l*n+m*k-m-1+c,k) - s*binomial(l*n+m*k-m-1+c,k-1)). A_{l,m,c,r,s}(x) = Sum_{n>=0} a_{l,m,c,r,s}(n)*x^n = t^c*(r+s-s*t)/((l+m-(l+m-1)*t)*(1-t+t^m)), where t = t(x) satisfies t = 1 + x*t^(l+m), equivalently y = x*(1+y)^(l+m) with y=t-1.
%F A397516 D-finite with recurrence of order 13 for n >= 1 (see link). - _Robert Israel_, Jun 29 2026
%o A397516 (PARI) C(n, k) = if(k>=0, binomial(n, k));
%o A397516 a(n) = sum(k=0, n, (-1)^k*C(7*n+k-1, n-k-1));
%Y A397516 Cf. A397514, A397515.
%Y A397516 Cf. A002296.
%K A397516 nonn
%O A397516 0,3
