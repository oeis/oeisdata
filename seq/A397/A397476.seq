%U A397476 78417843498225,87452703108225,95599408475025,124581426176025,137515844691225,145372334132025,170251217361225,187928318603025
%N A397476 Odd primitive exponential abundant numbers that are not primitives exponential unitary abundant.
%C A397476 The odd terms in A391086.
%C A397476 The powerful terms in A397475.
%C A397476 Any term in A397475 is of the form k*m where k is a term of this sequence and m is an odd squarefree number coprime to k. Therefore, A397475 can be generated from this sequence by multiplying terms with coprime odd squarefree numbers, and the asymptotic density of A397475 can be evaluated from the terms in this sequence (see the Comments section of A397475).
%H A397476 Amiram Eldar, <a href="/A397476/b397476.txt">Table of n, a(n) for n = 1..2334</a> (terms below 10^18)
%o A397476 (PARI) fun1(p, e) = sumdiv(e, d, p^d);
%o A397476 fun2(p, e) = sumdiv(e, d, if(gcd(d, e/d) == 1, p^d));
%o A397476 is1(k) = {my(f = factor(k)); prod(i = 1, #f~, fun1(f[i, 1], f[i, 2])) > 2*k && prod(i = 1, #f~, fun2(f[i, 1], f[i, 2])) <= 2*k;}
%o A397476 list(lim) = {my(s = List(), m); forstep(j = 1, sqrtnint(lim, 3), 2, forstep(i = 1, sqrtint(lim\j^3), 2, m = i^2*j^3; if(is1(m), listput(s, m)))); Set(s);}
%o A397476 list(10^13)
%Y A397476 Intersection of A005408 and A391086.
%Y A397476 Intersection of A001694 and A397475.
%Y A397476 Subsequence of A321147.
