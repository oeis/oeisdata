%T A397958 44,46,48,50,52,54,56,58,60,62,66,69,81,84,87,96,99,102,114,117,129,
%U A397958 132,135,144,147,150,162,165,177,180,183,192,195,198,210,213,225,228,231
%N A397958 Polydivisible numbers in base 8.
%C A397958 For the definition of polydivisible number in base b, see A397953.
%H A397958 Michael S. Branicky, <a href="/A397958/b397958.txt">Table of n, a(n) for n = 1..2569</a> (full sequence)
%H A397958 Wikipedia, <a href="https://en.wikipedia.org/wiki/Polydivisible_number">Polydivisible number</a>.
%F A397958 a(A271374(8)) = A109032(8).
%e A397958 997780 is a term because 997780_10 = 3634624_8 and all of the following conditions are true:
%e A397958   3_8       =      2_10 is divisible by 1;
%e A397958   36_8      =     30_10 is divisible by 2;
%e A397958   363_8     =    243_10 is divisible by 3;
%e A397958   3634_8    =   1948_10 is divisible by 4;
%e A397958   36346_8   =  15590_10 is divisible by 5;
%e A397958   363462_8  = 124722_10 is divisible by 6;
%e A397958   3634624_8 = 997780_10 is divisible by 7.
%t A397958 (* polyDivQ is defined at A397953 *)
%t A397958 Select[Range[0, 261], polyDivQ[#, 8] &]
%t A397958 (* Alternative: *)
%t A397958 (* polyDivFullList is defined at A144688 *)
%t A397958 polyDivFullList[8][[;; 70]]
%o A397958 (Python) # uses polydiv in A397953
%o A397958 print([an for an in polydiv(base=8)]) # _Michael S. Branicky_, Jul 16 2026
