%S A397737 3,15,78,435,2658,18102,138780,1198971,11600730,124489794,1466798916,
%T A397737 18807464910,260499759828,3874067519820,61547871299640,
%U A397737 1040102328321675,18626778871389450,352351829564950410
%N A397737 Number of assembly trees for the wheel graph W_n.
%C A397737 For n >= 4, the wheel graph W_n has n vertices and is the join of a cycle C_{n-1} and a singleton.
%C A397737 The sequence is extended to a(3) using the formula.
%H A397737 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/AssemblyNumber.html">Assembly Number</a>.
%H A397737 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/WheelGraph.html">Wheel Graph</a>.
%F A397737 a(n) = binomial(2*n-4,n-2)*(1/2 + hypergeom([1,3,3-n],[5-2*n],1)).
%F A397737 With m = n - 1, a(n) = binomial(2*m-2,m-1)/2 + m*Sum_{b=2..m} b!*binomial(2*m-b,m-b)/(2*m-b).
%t A397737 Table[Binomial[2 n - 4, n - 2] (1/2 + HypergeometricPFQ[{1, 3, 3 - n}, {5 - 2 n}, 1]), {n, 3, 20}]
%K A397737 nonn
%O A397737 3,1
%A A397737 _Eric W. Weisstein_, Jul 08 2026
