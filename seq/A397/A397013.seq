%S A397013 1,12,118,1152,11772,128160,1494576,18679680,249815520,3566142720,
%T A397013 54187574400,873962127360,14920424467200,268923168460800,
%U A397013 5104647388108800,101811581061120000,2129097359866982400,46590736318156800000,1064901291126220800000,25379394670728806400000
%N A397013 Expansion of the exponential generating function (1 - 23*x - (30 - 6*x)*log(1-x)) / (1 - x)^5.
%H A397013 Paolo Xausa, <a href="/A397013/b397013.txt">Table of n, a(n) for n = 0..445</a>
%F A397013 a(n) = (n + 3)! * ((n + 5) * H(n + 3) - 3*n - 9), where H(n) is the n-th harmonic number.
%F A397013 a(n) = A396981(n, 12).
%p A397013 prec := 20: egf := (1 - 23*z - (30 - 6*z)*log(1-z)) /(1 - z)^5:
%p A397013 ser := series(egf, z, prec+1): seq(n!*coeff(ser, z, n), n = 0..19);
%p A397013 # Alternative:
%p A397013 a := n -> (n + 3)! * ((n + 5) * harmonic(n + 3) - 3*n - 9):
%t A397013 A397013[n_] := (n + 3)!*((n + 5)*HarmonicNumber[n + 3] - 3*n - 9);
%t A397013 Array[A397013, 20, 0] (* _Paolo Xausa_, Jun 14 2026 *)
