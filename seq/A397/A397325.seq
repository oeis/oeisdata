%N A397325 a(n) = Sum_{j=0..n} Stirling2(n, j) * binomial(n + j, n) * n^j.
%H A397325 Paolo Xausa, <a href="/A397325/b397325.txt">Table of n, a(n) for n = 0..300</a>
%F A397325 a(n) ~ c * (exp(r)*(1+r)*(1+r+r^2)/r)^n * n! / n, where r = 0.8515520703139071853654902522988609567588695428976770746616... is the root of the equation -LambertW(-exp(-1/r)/r) = (1+r)/(r*(1+r+r^2)) and c = 0.1973021460997488159826564238622677637154746792372892471686... - _Vaclav Kotesovec_, Jun 24 2026
%p A397325 a := n -> local j; add(Stirling2(n, j)*binomial(n + j, n)*n^j, j = 0..n):
%p A397325 seq(a(n), n = 0..18);
%t A397325 A397325[n_] := If[n == 0, 1, Sum[StirlingS2[n, j]*Binomial[n + j, n]*n^j, {j, n}]];
