%I A397741 #7 Jul 12 2026 13:31:09
%S A397741 0,1,2,5,9,13,19,26,32,40,50,60,72,84,98,113,129,145,163,182,201,222,
%T A397741 244,267,291,316,342,369,397,426,456,487,519,552,586,621,657,694,732,
%U A397741 771,810,851,892,935,979,1024,1070,1117,1165,1213,1263,1314,1366,1419
%N A397741 a(n) is the number of distinct values in the addition triangle with base (a(0), ..., a(n-1)).
%C A397741 An addition triangle has any set of positive numbers as base; other rows are formed by adding pairs of adjacent numbers.
%C A397741 By convention, a(0) = 0 as the corresponding addition triangle is empty.
%H A397741 Rémy Sigrist, <a href="/A397741/b397741.txt">Table of n, a(n) for n = 0..5000</a>
%F A397741 a(n) <= A000217(n).
%e A397741 a(0) = 0 as the empty triangle has no value.
%e A397741 a(1) = 1 as there are one distinct values in the triangle 1.
%e A397741                                                            1
%e A397741 a(2) = 2 as there are two distinct values in the triangle 0 1.
%e A397741                                                              4
%e A397741                                                             1 3
%e A397741 a(3) = 5 as there are five distinct values in the triangle 0 1 2.
%o A397741 (PARI) { s = []; d = []; for (n = 1, 54, v = #s; print1 (v", "); t = vector(n); t[1] = v; for (k = 2, n, t[k] = t[k-1]+d[k-1];); d = t; s = setunion(s, Set(d));); }
%o A397741 (Python)
%o A397741 from itertools import islice
%o A397741 def agen(): # generator of terms
%o A397741     an, ends, s = 0, [], set()
%o A397741     n = 0
%o A397741     while True:
%o A397741         yield an
%o A397741         newends = [an]
%o A397741         for r in range(len(ends)):
%o A397741             newends.append(newends[-1]+ends[r])
%o A397741         ends = newends
%o A397741         s.update(ends)
%o A397741         an = len(s)
%o A397741 print(list(islice(agen(), 54))) # _Michael S. Branicky_, Jul 10 2026
%Y A397741 Cf. A000217.
%K A397741 nonn,new
%O A397741 0,3
%A A397741 _Rémy Sigrist_, Jul 08 2026
