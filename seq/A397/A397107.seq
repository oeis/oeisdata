%S A397107 0,2,3,9,12,22,27,41,48,66,75,97,108,134,147,177,192,226,243,281,300,
%T A397107 342,363,409,432,482,507,561,588,646,675,737,768,834,867,937,972,1046,
%U A397107 1083,1161,1200,1282,1323,1409,1452,1542,1587,1681,1728,1826,1875,1977,2028,2134,2187,2297,2352,2466,2523,2641,2700
%N A397107 Lower (1,2) midsequence of (floor[n/2]^2) and (ceiling[n/2]^2); see Comments.
%C A397107 Suppose that s = (s(n)) and t = (t(n)) are sequences of numbers and h > 0 and k > 0. The lower (h, k)-midsequence of s and t is floor(h*s + k*t); the upper (h, k)-midsequence of s and t is ceiling(h*s + k*t). The upper (1,2) midsequence of (floor[n/2]^2) and (ceiling[n/2]^2) is identical to this lower sequence.
%H A397107 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (1,2,-2,-1,1).
%F A397107 a(n) = a(n-1) + 2*a(n-2) - 2*a(n-3) - a(n-4) + a(n-5), with (a(0),...,a(4)) = (0, 2, 3, 9, 12).
%F A397107 G.f.: -x*(2 + x)*(1 + x^2)/((-1 + x)^3*(1 + x)^2).
%F A397107 a(n)-a(n-1) = A066070(n-1), n>=2 . - _R. J. Mathar_, Jun 30 2026
%t A397107 z = 60;
%t A397107 f[n_] := Floor[n/2]^2; g[n_] := Ceiling[n/2]^2;
%t A397107 r = 1; s = 2; u[n_] := Floor[r*f[n] + s*g[n]];
%t A397107 Table[u[n], {n, 0, z}]
%t A397107 (* Alternative: *)
%t A397107 LinearRecurrence[{1, 2, -2, -1, 1}, {0, 2, 3, 9, 12}, 61]
%Y A397107 Cf. A389123, A396811, A396834, A397108, A397109.
%K A397107 nonn,easy,changed
%O A397107 0,2
%A A397107 _Clark Kimberling_, Jun 19 2026
