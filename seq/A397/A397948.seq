%N A397948 G.f. A(x) satisfies A(x) = 1 + x * A(x^4/(1 - x)^4) / (1 - x)^3.
%F A397948 a(0) = 1; a(n) = Sum_{k=0..floor((n-1)/4)} binomial(n+1,4*k+2) * a(k).
%F A397948 E.g.f.: 1 + d/dx ( exp(x) * Sum_{k>=0} a(k) * x^(4*k+2) / (4*k+2)! ).
%o A397948 (PARI) a_vector(n) = my(v=vector(n+1)); v[1]=1; for(i=1, n, v[i+1]=sum(j=0, (i-1)\4, binomial(i+1, 4*j+2)*v[j+1])); v;
