%S A397591 1,1,4,28,281,3658,58257,1093228,23558599,572266776,15452506280,
%T A397591 458821151228,14851492994252,520354780202214,19618194420629803,
%U A397591 791884055353155776,34073795479759377099,1556996042454725399980,75302117386217875215016,3843109109512227994295960,206418937612873398754242802
%N A397591 G.f. A(x) satisfies [x^(n-1)] (1 - A(x))^n / (1 - n*x) = 0 for n > 1.
%C A397591 Essentially the same as column 0 in triangle A397590 (apart from signs and offset by 1).
%C A397591 Conjecture: for n > 3, a(n) is odd iff n is of the form 2^k-1 or 2^k+1 (k > 1).
%H A397591 Paul D. Hanna, <a href="/A397591/b397591.txt">Table of n, a(n) for n = 1..400</a>
%F A397591 G.f. A(x) = Sum_{n>=1} a(n)*x^n has the following properties.
%F A397591 (1) [x^(n-1)] (1 - A(x))^n / (1 - n*x) = 0 for n > 1.
%F A397591 (2) Sum_{k=0..n-1} [x^k] (1 - A(x/n))^n = 0 for n > 1.
%F A397591 (3) Sum_{k=0..n-1} n^(n-k) * [x^k] (1 - A(x))^n = 0 for n > 1.
%F A397591 (4) Sum_{k=0..n-1} n^(n-k) * Sum_{j=0..n} (-1)^j * binomial(n,j) * [x^k] A(x)^j = 0 for n > 1.
%F A397591 (5) 1/(1 - A(x)) equals the g.f. of A320415.
%F A397591 (6) a(n) = -A397590(n,0) for n >= 1.
%F A397591 a(n) ~ (exp(1) - 1) * exp(exp(-1) - 1) * n^(n-1). - _Vaclav Kotesovec_, Jul 11 2026
%e A397591 G.f.: A(x) = x + x^2 + 4*x^3 + 28*x^4 + 281*x^5 + 3658*x^6 + 58257*x^7 + 1093228*x^8 + 23558599*x^9 + 572266776*x^10 + ...
%e A397591 The table of coefficients of x^k in (1 - A(x))^n begins
%e A397591   n = 1: [1, -1, -1,  -4, -28,  -281,  -3658, ...];
%e A397591   n = 2: [1, -2, -1,  -6, -47,  -498,  -6682, ...];
%e A397591   n = 3: [1, -3,  0,  -7, -60,  -666,  -9181, ...];
%e A397591   n = 4: [1, -4,  2,  -8, -69,  -796, -11242, ...];
%e A397591   n = 5: [1, -5,  5, -10, -75,  -896, -12935, ...];
%e A397591   n = 6: [1, -6,  9, -14, -78,  -972, -14317, ...];
%e A397591   n = 7: [1, -7, 14, -21, -77, -1029, -15435, ...];
%e A397591   ...
%e A397591 from which we may illustrate that the sum of the first n coefficients in (1 - A(x/n))^n equals 0 for n > 1 by:
%e A397591   n = 1: 1 = 1;
%e A397591   n = 2: 0 = 1 - 2/2;
%e A397591   n = 3: 0 = 1 - 3/3 + 0/3^2;
%e A397591   n = 4: 0 = 1 - 4/4 + 2/4^2 - 8/4^3;
%e A397591   n = 5: 0 = 1 - 5/5 + 5/5^2 - 10/5^3 - 75/5^4;
%e A397591   n = 6: 0 = 1 - 6/6 + 9/6^2 - 14/6^3 - 78/6^4 - 972/6^5;
%e A397591   etc.
%e A397591 RELATED SERIES.
%e A397591 Given g.f. A(x), then 1/(1 - A(x)) is the g.f. of A320415
%e A397591 1/(1 - A(x)) = 1 + x + 2*x^2 + 7*x^3 + 41*x^4 + 365*x^5 + 4429*x^6 + 67631*x^7 + 1235436*x^8 + ... + A320415(n)*x^n + ...
%o A397591 (PARI) {a(n) = my(A=[0,1]); for(i=2, n, A=concat(A, 0); m=#A; A[m] = Vec( (1-Ser(A))^m / (1 - m*x +x^2*O(x^m)) )[m]/m ); GF=Ser(A); A[n+1]}
%o A397591 {upto(n) = a(n); Vec(GF)}
%o A397591 upto(25)
%Y A397591 Cf. A320415, A397590, A397592, A397593, A397594, A397595.
%K A397591 nonn,new
