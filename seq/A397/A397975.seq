%I A397975 #4 Jul 21 2026 01:01:20
%S A397975 0,2,6,12,21,32,45,61,79,99,122,147,174,204,236,270,307,346,387,431,
%T A397975 477,525,576,629,684,742,802,864,929,996,1065,1137,1211,1287,1366,
%U A397975 1447,1530,1616,1704,1794,1887,1982,2079,2179,2281,2385,2492,2601,2712,2826
%N A397975 Upper (1,2/3) midsequence triangular numbers (A000217) and squares (A000290); see Comments.
%C A397975 Suppose that s = (s(n)) and t = (t(n)) are sequences of numbers and h > 0 and k > 0. The lower (h, k)-midsequence of s and t is floor(h*s + k*t); the upper (h, k)-midsequence of s and t is ceiling(h*s + k*t). See A397972 for a guide to related sequences.
%H A397975 Index entries for linear recurrences with constant coefficients, signature (2,-1,1,-2,1).
%F A397975 a(n) = 2 a(n-1) - a(n-2) + a(n-3) - 2 a(n-4) + a(n-5), with (a(0),...,a(4)) = (0, 2, 6, 12, 21).
%F A397975 G.f.: (x (-2 - 2 x - 2 x^2 - x^3))/((-1 + x)^3 (1 + x + x^2)).
%t A397975 z = 60;
%t A397975 f[n_] := (n^2 + n)/2; g[n_] := n^2; r = 1; s = 2/3;
%t A397975 u[n_] := Floor[r*f[n] + s*g[n]]; v[n_] := Ceiling[r*f[n] + s*g[n]]
%t A397975 Table[v[n], {n, 0, z}]
%Y A397975 Cf. A000217, A000290, A397972, A397975.
%K A397975 nonn,easy,new
%O A397975 0,2
%A A397975 _Clark Kimberling_, Jul 20 2026
