%U A397039 3649123,5681949,8801537,13563507,20802968,31756865,48267241,73046879,110102202,165300167,247242133,368453334
%N A397039 Convolution of A000005 and A000219.
%H A397039 Vaclav Kotesovec, <a href="/A397039/b397039.txt">Table of n, a(n) for n = 0..10000</a>
%F A397039 G.f.: Sum_{j>=1} (x^j/(1-x^j)) / Product_{k>=1} (1-x^k)^k.
%F A397039 a(n) ~ A000219(n) * 3*n^(1/3) * (log(3*n^(1/3)/(2*r)) + gamma) / (2*r), where r = 3*zeta(3)^(1/3)/2^(2/3) and gamma is the Euler-Mascheroni constant A001620.
%F A397039 a(n) ~ exp(1/12 + 3*zeta(3)^(1/3)*n^(2/3)/2^(2/3)) * (log(n^(1/3)/(2*zeta(3))^(1/3)) + gamma) / (A * 2^(23/36) * sqrt(3*Pi) * zeta(3)^(5/36) * n^(13/36)), where A is the Glaisher-Kinkelin constant (A074962).
%t A397039 nmax = 40; CoefficientList[Series[Sum[x^j/(1-x^j),{j,1,nmax}] / Product[(1-x^k)^k, {k,1,nmax}], {x, 0, nmax}], x]
