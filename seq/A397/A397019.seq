%I A397019 #26 Jun 19 2026 17:31:41
%S A397019 1,7,93,1973,47161,1204744,31711028,852689953
%N A397019 Number of free polyominoes with 4n cells that can be tiled by n copies of the I-tetromino (the 1 X 4 bar); equivalently, the number of n-fold multiples of the I-tetromino, counted up to rotation and reflection.
%C A397019 In the divisibility language of Polyomino Number Theory (Cibulis, Liu, and Wainwright), a polyomino that can be assembled from n copies of a polyomino P is an n-fold multiple of P. This sequence counts the distinct free n-fold multiples of the I-tetromino. The pieces may be placed in any of their orientations; copies must meet edge to edge and may not overlap.
%H A397019 A. Cibulis, A. Liu, and B. Wainwright, <a href="http://www.paulsalomon.com/uploads/2/8/3/3/28331113/polyomino_number_theory_(i).pdf">Polyomino Number Theory I</a>, Crux Mathematicorum 28(3) (2002), 147-150.
%H A397019 Solomon W. Golomb, <a href="https://www.jstor.org/stable/2320673">Normed Division Domains</a>, The American Mathematical Monthly, Vol. 88, No. 9 (Nov., 1981), pp. 680-686.
%H A397019 Haoyang Xu, <a href="/A397019/a397019_2.png">Illustration of a(1) and a(2)</a>
%e A397019 a(1) = 1 (the bar itself).
%e A397019 a(2) = 7: two 1 X 4 bars joined edge to edge form 7 distinct free octominoes (the 2 X 4 rectangle, the 1 X 8 bar, and five offset arrangements).
%o A397019 (Python)
%o A397019 def _norm(s):
%o A397019     mx = min(x for x, y in s); my = min(y for x, y in s)
%o A397019     return frozenset((x - mx, y - my) for x, y in s)
%o A397019 def _orients(s):
%o A397019     out = set(); c = _norm(s)
%o A397019     for _ in range(4):
%o A397019         out.add(c)
%o A397019         out.add(_norm(frozenset((-x, y) for x, y in c)))
%o A397019         c = _norm(frozenset((-y, x) for x, y in c))
%o A397019     return out
%o A397019 def _canon(s):
%o A397019     return min(tuple(sorted(o)) for o in _orients(s))
%o A397019 def a(n, piece=frozenset({(0,0),(1,0),(2,0),(3,0)})):
%o A397019     states = {frozenset(_canon(list(_orients(piece))[0]))}
%o A397019     O = list(_orients(piece))
%o A397019     for _ in range(n - 1):
%o A397019         nxt = set()
%o A397019         for st in states:
%o A397019             xs = [x for x, y in st]; ys = [y for x, y in st]
%o A397019             for o in O:
%o A397019                 ox = [p[0] for p in o]; oy = [p[1] for p in o]
%o A397019                 for dx in range(min(xs)-max(ox)-1, max(xs)-min(ox)+2):
%o A397019                     for dy in range(min(ys)-max(oy)-1, max(ys)-min(oy)+2):
%o A397019                         t = frozenset((p[0]+dx, p[1]+dy) for p in o)
%o A397019                         if t & st: continue
%o A397019                         if any((x+1,y) in st or (x-1,y) in st or (x,y+1) in st or (x,y-1) in st for x,y in t):
%o A397019                             nxt.add(st | t)
%o A397019         states = {frozenset(k) for k in {_canon(s) for s in nxt}}
%o A397019     return len(states)
%o A397019 print([a(n) for n in range(1, 6)])  # 1, 7, 93, 1973, 47161
%o A397019 # larger terms by the parallel hash-sharded on-disk method. _Haoyang Xu_
%Y A397019 Cf. A390620 (O-column, free polynars), A000105 (free polyominoes); A397020 (T), A397021 (L), A397022 (S), A397023 (A390620 - A000105).
