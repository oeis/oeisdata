%I A397102 #12 Jun 18 2026 08:19:58
%S A397102 34,117,164,187,188,193,195,211,216,233,249,250,254,276,303,316,330,
%T A397102 396,401,417,446,453,461,474,492,506,518,528,547,554,567,571,574,586,
%U A397102 590,603,635,671,684,734,744,769,777,802,832,839,841,886,937,945,954,987,1010
%N A397102 Which blocks in A280864 have length 4 and whose first and last terms are primes.
%C A397102 Theorem: The beginning and end primes are consecutive primes. This follows from the fact that if p<q are primes, the first time p divides a term of A280864 is less than the first time q divides a term. It is also easy to give a direct proof. - _N. J. A. Sloane_, Jun 17 2026
%C A397102 It follows that these blocks have the form {prime(i), 2*prime(i), 2*prime(i+1), prime(i+1)}.
%C A397102 Proper subset of A396305.
%C A397102 Let T(n,k) be the k-th term of the n-th block of A280864, with k = 1..A283832(n).
%C A397102 Both T(a(n),2) and T(a(n),3) are in A100484 and thus also in A006881 for n <= 2856 (i.e., within the first 2^20 terms of A280864).
%H A397102 Michael De Vlieger, <a href="/A397102/b397102.txt">Table of n, a(n) for n = 1..2856</a>
%F A397102 T(a(n),1) = A396301(a(n)).
%F A397102 T(a(n),4) = T(a(n), A283832(a(n))) = A396300(a(n)).
%e A397102 Table of blocks a(n) for n = 1..5:
%e A397102 n\k       1      2      3      4    pi(T(n,1)) [pi = A000720]
%e A397102 ----------------------------------------------
%e A397102  34:    137    274    278    139        30
%e A397102 117:    659   1318   1322    661       120
%e A397102 164:   1019   2038   2042   1021       171
%e A397102 187:   1229   2458   2462   1231       201
%e A397102 188:   1237   2474   2498   1249       203
%t A397102 Block[{c, j, k, m, q, r, s, t, w, nn, rad},
%t A397102   nn = 2^14; c[_] := False; q = 0; r = 1; s = 1; t = {};
%t A397102   rad[n_] := rad[n] = Times @@ FactorInteger[n][[All, 1]];
%t A397102   Monitor[Reap[
%t A397102     Do[w = GCD[r, s]; m = r/w; k = m;
%t A397102     While[Or[c[k], ! CoprimeQ[w, k] ], k += m]; c[k] = True; s = r;
%t A397102     r = rad[k];
%t A397102     If[CoprimeQ[s, r],
%t A397102       If[Length[t] == 4,
%t A397102         If[AllTrue[{First[t], Last[t]}, PrimeQ], Sow[q] ] ];
%t A397102         q++; t = {k}, AppendTo[t, k] ], {i, nn}] ][[-1, 1]], i] ]
%Y A397102 Cf. A006881, A100484, A280864, A283832, A396300, A396301, A396305, A396306, A396307.
%K A397102 nonn,new
%O A397102 1,1
%A A397102 _Michael De Vlieger_ and _N. J. A. Sloane_, Jun 16 2026
