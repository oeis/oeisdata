%I A397269 #17 Jul 06 2026 03:10:29
%S A397269 0,0,0,4,5,20,23,56,62,120,130,220,235,364,385,560,588,816,852,1140,
%T A397269 1185,1540,1595,2024,2090,2600,2678,3276,3367,4060,4165,4960,5080,
%U A397269 5984,6120,7140,7293,8436,8607,9880,10070,11480,11690,13244,13475,15180,15433,17296,17572,19600,19900,22100,22425,24804,25155
%N A397269 a(n) = n*(8*n^2-9*n-2-(9*n-6)*(-1)^n)/48.
%C A397269 Sum of the areas of all composite rectangles formed by taking each of the distinct nonsquare L X W integer-sided rectangles with semiperimeter n = L + W, and gluing W X W squares to their widths (see example).
%H A397269 <a href="/index/Rec#order_07">Index entries for linear recurrences with constant coefficients</a>, signature (1,3,-3,-3,3,1,-1).
%F A397269 G.f.: x^3*(4+x+3*x^2)/((-1+x)^4*(1+x)^3).
%F A397269 a(n) = a(n-1) + 3*a(n-2) - 3*a(n-3) - 3*a(n-4) + 3*a(n-5) + a(n-6) - a(n-7).
%F A397269 a(n) = t*(t+1)*(3*n+2*t+1)/6, where t = floor((n-1)/2).
%F A397269 a(n) = Sum_{k=1..floor((n-1)/2)} k * (n+k).
%F A397269 E.g.f.: x*(x*(3 + 4*x)*cosh(x) - (3 - 12*x - 4*x^2)*sinh(x))/24. - _Stefano Spezia_, Jun 20 2026
%F A397269 a(2*n) = n*(n-1)*(8*n-1)/6, a(2*n+1) = 2*n*(n+1)*(2*n+1)/3. - _Wesley Ivan Hurt_, Jun 24 2026
%F A397269 Sum_{n>=3} 1/a(n) = (621/14 + 24*sqrt((2+sqrt(2))/(2-sqrt(2)))*Pi - 234*log(2) - 24*sqrt(2)*log(2) + 48*sqrt(2)*log(2-sqrt(2)))/7. - _Amiram Eldar_, Jul 06 2026
%e A397269 For n = 8, the L X W rectangles with semiperimeter 8, including the squares on their widths are:
%e A397269 .
%e A397269      1             2               3
%e A397269      _            ___            _____
%e A397269   1 |_| 1     2  |   |  2       |     |
%e A397269     | |          |___|        3 |     | 3
%e A397269     | |          |   |          |_____|
%e A397269     | |          |   |          |     |
%e A397269   7 | | 7     6  |   |  6       |     |
%e A397269     | |          |   |        5 |     | 5
%e A397269     | |          |   |          |     |
%e A397269     |_|          |___|          |_____|
%e A397269   1 |_| 1     2  |   |  2       |     |
%e A397269                  |___|        3 |     | 3
%e A397269      1                          |_____|
%e A397269                    2
%e A397269                                    3
%e A397269 .
%e A397269 The sum of the composite areas = 9 + 20 + 33 = 62.
%t A397269 Table[n*(8*n^2 - 9*n - 2 - (9*n - 6)*(-1)^n)/48, {n, 0, 100}]
%t A397269 (* Alternative: *)
%t A397269 CoefficientList[Series[x^3 (4 + x + 3 x^2)/((x - 1)^4*(x + 1)^3), {x, 0, 100}], x]
%o A397269 (Magma) [n*(8*n^2-9*n-2-(9*n-6)*(-1)^n)/48 : n in [0..100]];
%o A397269 (Python)
%o A397269 def A397269(n): return (t:=n-1>>1)*(t+1)*(3*n+(n-1&-2)+1)//6 # _Chai Wah Wu_, Jun 20 2026
