%e A397825           41--26--33--37
%e A397825          /              \
%e A397825        22   15--17---8   21
%e A397825       /    /          \    \
%e A397825     35   19    4---3   13   16
%e A397825    /    /    /      \    \    \
%e A397825  43   12    5    1---2   11   27   .
%e A397825    \    \    \          /    /    .
%e A397825     47   23   6---7---9    14   55
%e A397825       \    \              /    /
%e A397825        18   25--29--10--31   51
%e A397825          \                  /
%e A397825           49--24--53--39--20
%e A397825 .
%e A397825 a(11) = 8 as when a(11) is placed its existing adjacent terms are 3 and 13, and 8 is the smallest unused number that is coprime to both 3 and 13.
%Y A397825 Cf. A397826 (start with 2), A257339, A397323.
