%N A397035 G.f. A(x) satisfies A(x) = 1 + x * A(x^2/(1 - x)^2) / (1 - x)^4.
%F A397035 a(0) = 1; a(n) = Sum_{k=0..floor((n-1)/2)} binomial(n+2,2*k+3) * a(k).
%F A397035 E.g.f.: 1 + d^2/dx^2 ( exp(x) * Sum_{k>=0} a(k) * x^(2*k+3) / (2*k+3)! ).
%o A397035 (PARI) a_vector(n) = my(v=vector(n+1)); v[1]=1; for(i=1, n, v[i+1]=sum(j=0, (i-1)\2, binomial(i+2, 2*j+3)*v[j+1])); v;
