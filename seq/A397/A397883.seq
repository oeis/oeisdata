%U A397883 17320990732469270,358734286891982762,7770884280257420122,175771546368675713974,4144992837500245164510,101753134757610207411234
%N A397883 a(n) = r(2,n,2) where r(m,n,k) is the number of possible outcomes in a race with n participants that contains exactly k ties of size at least m.
%H A397883 Wenxiang Zhu, <a href="/A397883/b397883.txt">Table of n, a(n) for n = 1..200</a>
%H A397883 Yu Chen and Wenxiang Zhu, <a href="https://arxiv.org/abs/2607.02085">A Snail Race Problem</a>, arXiv:2607.02085 [math.CO], 2026.
%F A397883 r(m,n,k) = Sum_{i=1..m-1} binomial(n,i)*r(m,n-i,k) + Sum_{i=m..n} binomial(n,i)*r(m,n-i,k-1); r(m,0,0) = 1, r(m,0, k) = 0 for k >= 1.
%e A397883 For a race of n=4 participants with exactly 2 ties of size at least 2, there are 6 possible outcomes.
%o A397883 (PARI) r(m, n, k) = if (n==0, return(k==0)); sum(i=1, m-1, binomial(n,i)*r(m,n-i,k)) + sum(i=m, n, binomial(n,i)*r(m,n-i,k-1));
%o A397883 a(n) = r(2, n, 2); \\ _Michel Marcus_, Jul 19 2026
