%I A397848 #28 Jul 21 2026 19:50:08
%S A397848 101,151,211,223,227,229,233,353,383,433,443,449,499,557,599,661,677,
%T A397848 773,881,883,887,929,997,2111,2221,3833,4111,4441,4447,5557,6661,7477,
%U A397848 7877,8887,8999,10111,11119,11411,22229,23333,33343,38333,44449,59999,71777,79999,88883,99929,99991
%N A397848 Near-repdigit primes such that no rearrangement of their digits (without leading zeros) results in any other prime number.
%C A397848 For any prime p in this sequence, every valid permutation of its decimal digits forms a composite number, except for the original identity permutation that yields p itself.
%C A397848 Permutations that result in numbers with leading zeros (which would reduce the digit length) are excluded from the evaluation.
%H A397848 Michael S. Branicky, <a href="/A397848/b397848.txt">Table of n, a(n) for n = 1..6331</a>
%o A397848 (Python)
%o A397848 from gmpy2 import is_prime
%o A397848 from itertools import count, islice
%o A397848 def agen(): # generator of terms
%o A397848     for d in count(3):
%o A397848         cands = set()
%o A397848         for end in "1379":
%o A397848             for c in "24568":
%o A397848                 if is_prime(t:=int(c*(d-1) + end)): # no other permutation can be prime
%o A397848                     cands.add(t)
%o A397848             for diff in set("0123456789") - {end}:
%o A397848                 P = [t for i in range(d) if (s:=end*i+diff+end*(d-1-i))[0]!="0" and is_prime(t:=int(s))]
%o A397848                 if len(P) == 1: # only one prime with that multiset of digits
%o A397848                     cands.add(P[0])
%o A397848         yield from sorted(cands)
%o A397848 print(list(islice(agen(), 49))) # _Michael S. Branicky_, Jul 13 2026
%Y A397848 Intersection of A246044 and A164937.
%Y A397848 Cf. A039986.
%K A397848 nonn,base,new
%O A397848 1,1
