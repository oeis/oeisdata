%T A397515 147661274552,2108130616423,30208089841385,434212103802781,
%U A397515 6258103225469234,90405023993903151,1308659739222398445,18977644553820387729,275647023671860226406,4009472365451217844895
%N A397515 a(n) = Sum_{k=0..n} binomial(4*n+2*k-3,k-1).
%F A397515 G.f.: x*g^3/((1-6*x*g^5) * (1-x*g^4)) where g = 1+x*g^6 is the g.f. of A002295.
%F A397515 G.f.: (-1+g)/((6-5*g) * (1-g+g^2)) where g = 1+x*g^6 is the g.f. of A002295.
%F A397515 Here and below, binomial(N,k) = 0 for k<0.
%F A397515 a(n) = Sum_{k=0..n} (-1)^k * binomial(6*n+k-1,n-k-1).
%F A397515 a(n) = Sum_{k=0..floor(n/2)} (-1)^k * binomial(6*n-k-2,n-2*k-1).
%F A397515 This is the special case l=4, m=2, c=0, r=0, s=-1 of the following family. For integers l, m, c in Z, and for any constants r and s, define a_{l,m,c,r,s}(n) = Sum_{k=0..n} (r*binomial(l*n+m*k-m-1+c,k) - s*binomial(l*n+m*k-m-1+c,k-1)). A_{l,m,c,r,s}(x) = Sum_{n>=0} a_{l,m,c,r,s}(n)*x^n = t^c*(r+s-s*t)/((l+m-(l+m-1)*t)*(1-t+t^m)), where t = t(x) satisfies t = 1 + x*t^(l+m), equivalently y = x*(1+y)^(l+m) with y=t-1.
%o A397515 (PARI) C(n, k) = if(k>=0, binomial(n, k));
%o A397515 a(n) = sum(k=0, n, (-1)^k*C(6*n+k-1, n-k-1));
%Y A397515 Cf. A397514, A397516.
%Y A397515 Cf. A002295.
%K A397515 nonn
%O A397515 0,3
