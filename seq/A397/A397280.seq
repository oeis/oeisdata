%U A397280 988680805739827200,24134163146418124800,1794899599558281216000,54820156712956553318400,4142185546786169186304000
%N A397280 Expansion of e.g.f. (1/x) * Series_Reversion( x + 1 - exp(x^3) ).
%F A397280 E.g.f. A(x) satisfies A(x) = 1 + (exp((x * A(x))^3) - 1)/x.
%F A397280 a(n) = (1/(n+1)) * Sum_{k=ceiling(n/3)..floor(n/2)} (3*k)!/k! * Stirling2(k,3*k-n).
%F A397280 a(n) ~ sqrt((3*w^2*(1+w) - 1)/(3*w*(2 + 3*w^3))) * n^(n-1) / (exp(n) * (1+w - 1/(3*w^2))^(n+1)), where w = (2*LambertW(1/(2*sqrt(3)))/3)^(1/3). - _Vaclav Kotesovec_, Jun 20 2026
%t A397280 Table[1/(n+1) * Sum[(3*k)!/k! * StirlingS2[k,3*k-n], {k,Ceiling[n/3],Floor[n/2]}], {n,0,20}] (* _Vaclav Kotesovec_, Jun 20 2026 *)
%o A397280 (PARI) my(N=30, x='x+O('x^N)); Vec(serlaplace(serreverse(x+1-exp(x^3))/x))
%Y A397280 Cf. A392788, A397281.
%K A397280 nonn,new
%O A397280 0,3
