%I A397329 #11 Jun 23 2026 05:46:42
%S A397329 1,3,1,25,12,1,343,193,27,1,6561,4040,730,48,1,161051,105121,22230,
%T A397329 1970,75,1,4826809,3281908,772891,82880,4355,108,1,170859375,
%U A397329 119739649,30506721,3742291,242725,8435,147,1,6975757441,5003902800,1353936340,183694560,13860966,602448,14868,192,1
%N A397329 Triangle read by rows: T(n, k) = 2^(n - k) * P(n, k, 1/2) where P(n, k, x) = (1/k!) * Sum_{j=0..k}((-1)^(k - j) * binomial(k, j) * (n + x + j)^n).
%C A397329 For comments and a table of the polynomials see A397333, which is the main entry for this family of triangles.
%F A397329 T(n, k) = 2^(n - k) * t(n, k) where t(n, k) = t(n - 1, k - 1) + (n + 2*k + 1/2) * t(n - 1, k) + (n + k + 1/2) * (k + 1) * t(n - 1, k + 1) for 0 <= k < n, and t(n, n) = 1.
%F A397329 T(n, k) = 2^(n - k) * [x^k] b(n, n) where b(n, k) = (k + 1/2)*b(n-1, k) + x*b(n-1, k+1) if n > 0 and b(0, k) = 1.
%e A397329 Triangle starts:
%e A397329   [0]         1;
%e A397329   [1]         3,         1;
%e A397329   [2]        25,        12,        1;
%e A397329   [3]       343,       193,       27,       1;
%e A397329   [4]      6561,      4040,      730,      48,      1;
%e A397329   [5]    161051,    105121,    22230,    1970,     75,    1;
%e A397329   [6]   4826809,   3281908,   772891,   82880,   4355,  108,   1;
%e A397329   [7] 170859375, 119739649, 30506721, 3742291, 242725, 8435, 147, 1;
%p A397329 t := proc(n, k) option remember; if n = k then return 1 fi; if k < 0 or k > n then return 0 fi; t(n-1, k-1) + (n + 2*k + 1/2) * t(n - 1, k) + (n + k + 1/2) * (k + 1) * t(n-1, k+1) end: T := (n, k) -> 2^(n - k) * t(n, k):
%p A397329 # Alternative:
%p A397329 P := (n, k, x) -> local j; add((-1)^(k - j) * binomial(k, j) * (n + x + j)^n , j = 0..k) / k!: T := (n, k) -> 2^(n-k) * P(n, k, 1/2): seq(seq(T(n, k), k = 0..n), n = 0..9);
%o A397329 (SageMath)
%o A397329 R.<z> = ZZ[]
%o A397329 @cached_function
%o A397329 def b(a, n, k):
%o A397329     if n == 0: return R(1)
%o A397329     return (k + a)*b(a, n-1, k) + z*b(a, n-1, k+1)
%o A397329 def T_row(a, n) -> list[int]: return [2^(n - k) * c for k, c in enumerate(b(a, n, n))]
%o A397329 for n in range(8): print(T_row(1/2, n))
%Y A397329 Cf. A085527 (column 1), A033428 (subdiagonal), A397328 (row sums), A397333 (p(x=1)), A397331 (p(x=-1)), A397048 (p(x=0)).
%K A397329 nonn,tabl,new
%O A397329 0,2
