%I A397473 #25 Jul 03 2026 19:21:12
%S A397473 1,1,2,5,10,21,45,91,184,367,743,1469,2919,5752,11341,22372,44038,
%T A397473 86707,170716,336259,662596,1307341,2580497,5099031,10083099,19957264,
%U A397473 39530663,78364912,155462423,308618564,613040951,1218442899,2422956925,4820482880,9594448516,19103632348
%N A397473 Number of sets of nonempty compositions with total sum n such that no compositions in the set share a part.
%H A397473 Alois P. Heinz, <a href="/A397473/b397473.txt">Table of n, a(n) for n = 0..64</a>
%H A397473 John Tyler Rascoe, <a href="/A397473/a397473.py.txt">Python code</a>.
%e A397473 The set {(1,3,1), (4,2)} has total sum 11 and no compositions in the set have common elements so it is counted under a(11) = 1469.
%e A397473 a(5) = 21: {(1),(4)}, {(1),(2,2)}, {(1,1),(3)}, {(2),(3)}, {(1,1,1),(2)}, and the 16 sets with a single composition of 5: {(1,1,1,1,1)}, {(1,1,1,2)}, {(1,1,2,1)}, {(1,2,1,1)}, {(2,1,1,1)}, {(1,2,2)}, {(2,1,2)}, {(2,2,1)}, {(1,1,3)}, {(1,3,1)}, {(3,1,1)}, {(2,3)}, {(3,2)}, {(1,4)}, {(4,1)}, {(5)}.
%p A397473 g:= proc(n, s, ss, p) `if`(n=0, 1/p!,
%p A397473      `if`(s={}, 0, g(n, {}, s union ss, p+1))+
%p A397473         b(n, map(h-> select(x-> x<=n, h), [s, ss])[], p))
%p A397473     end:
%p A397473 b:= proc(n, s, ss, p) option remember; add(
%p A397473      `if`(j in ss, 0, g(n-j, s union {j}, ss, p)), j=1..n)
%p A397473     end:
%p A397473 a:= proc(n) option remember; g(n, {}$2, 1) end:
%p A397473 seq(a(n), n=0..30);  # _Alois P. Heinz_, Jun 30 2026
%o A397473 (Python) # see links
%Y A397473 Cf. A011782, A098407, A336127, A358904, A396494.
%K A397473 nonn,new
%O A397473 0,3
%A A397473 _John Tyler Rascoe_, Jun 26 2026
%E A397473 a(14)-a(35) from _Alois P. Heinz_, Jun 27 2026
