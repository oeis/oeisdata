%F A397686 L.g.f.: -log(Product_{k>=1} (1 - x^k)^(A359037(k)/k)).
%F A397686 Dirichlet g.f.: zeta(s)^4 * Product_{primes p} (1 + 5*p^(-s)).
%p A397686 seq(mul((m[2]+1)*(m[2]+2)*(2*m[2]+1)/2, m in ifactors(n)[2]), n=1..120);
