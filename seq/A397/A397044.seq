%T A397044 16,2,1,37,2,1,10,104,8,25,8,5,4,5,2,1,2,1,16,32,10,10,8,8,10,5,4,4,2,
%U A397044 1,1,17,2,1,17,5,4,65,2,1,8,5,4,5,2,1,2,1,40,2,1,16,50,17,16,200,10,10
%N A397044 a(n) is the first term k of A397042 such that k + n is also in A397042.
%C A397044 a(n) is the least k such that both k and k + n can be written as products of numbers of the form x^2 + 1.
%H A397044 Robert Israel, <a href="/A397044/b397044.txt">Table of n, a(n) for n = 1..10000</a>
%e A397044 a(8) = 2 because 2 = (1^2+1) and 2 + 8 = (1^2 + 1) * (2^2 + 1) are both products of numbers of the form x^2 + 1.
%p A397044 filter:= proc(n) option remember; local F;
%p A397044   if issqr(n-1) then return true fi;
%p A397044   ormap(t -> issqr(t-1) and filter(n/t), NumberTheory:-Divisors(n) minus {1,n});
%p A397044 end proc:
%p A397044 f:= proc(n) local k;
%p A397044 for k from 1 do if filter(k) and filter(k+n) then return k fi od
%p A397044 end proc:
%p A397044 map(f, [$1..100]);
%Y A397044 Cf. A002522, A397042.
%K A397044 nonn
%O A397044 1,2
