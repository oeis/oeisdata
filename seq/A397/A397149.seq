%N A397149 G.f. A(x), with A(0) = 0, satisfies A(x-x^3) = x + A(x)^4.
%F A397149 a(1) = 1; a(n) = Sum_{i, j, k, l>=1 and i+j+k+l=n} a(i)*a(j)*a(k)*a(l) + Sum_{r=1..floor(n/3)} (-1)^(r+1) * binomial(n-2*r,r) * a(n-2*r).
%o A397149 (PARI) my(A=x, N=40, g=serreverse(x-x^3+x*O(x^N))); for(k=1, N, A=g+subst(A, x, g)^4); Vec(A)
