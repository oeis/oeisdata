%I A397485 #12 Jun 28 2026 23:51:14
%S A397485 33,39,24,40,34,38,16,48,35,37,8,56,25,47,17,55,9,63,41,31,49,23,57,
%T A397485 15,27,45,19,53,11,61,43,29,51,21,59,13,26,46,18,54,10,62,42,30,58,14,
%U A397485 115,113,106,122,116,112,98,66,117,119,90,74,107,121,99,65,91,73,123
%N A397485 Octal encoding of the combinations of positions of the main beam and the two wings used to represent the 92 numbers of the Chappe telegraph code.
%C A397485 The position of the main beam is encoded by the most significant bit of the 7-bit word. 0 for vertical, 1 for horizontal. The angles of the wings are encoded similar to A397484, but using the next 3 bits from the front for the lower/right wing and the rear 3 bits for the upper/left wing, starting with 0 for downward and then CCW up to 7.
%C A397485 .
%C A397485    6 543 210 bit positions
%C A397485    |  |   |
%C A397485    |  |   upper (main beam vertical) or left (main beam horizontal) wing
%C A397485    |  lower (main beam vertical) or right (main beam horizontal) wing
%C A397485    main beam
%C A397485 .
%C A397485 Encoding of wing angles:
%C A397485        4
%C A397485     5  |  3
%C A397485      \   /
%C A397485   6_      _ 2
%C A397485      /   \
%C A397485     7  |  1
%C A397485        0
%D A397485 See A397484 for more information.
%H A397485 Hugo Pfoertner, <a href="/A397485/b397485.txt">Table of n, a(n) for n = 1..92</a>
%e A397485 a(20) = 31: 31 = 037_8 -> main beam vertical, lower wing in position 3, upper wing in position 7. (A397484(2)=148).
%e A397485   /|
%e A397485    |
%e A397485    |/
%o A397485 (PARI) \\ Convert from x = A397484(n)
%o A397485 a(x) = my(d=digits(x)); fromdigits([(d[1]-1)/2, d[2]-1, d[3]-1], 8)
%Y A397485 Cf. A397484.
%K A397485 nonn,base,fini,full,new
%O A397485 1,1
%A A397485 _Hugo Pfoertner_, Jun 28 2026
