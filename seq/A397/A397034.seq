%I A397034 #6 Jul 01 2026 18:48:23
%S A397034 0,0,1,2,3,5,7,10,14,18,22,27,33,39,46,53,61,69,78,88,98,109,121,133,
%T A397034 145,158,172,187,202,217,234,251,268,286,305,325,345,365,387,409,431,
%U A397034 455,478,503,528,554,580,607,635,664,693,722,753,784,816,848,881
%N A397034 a(n) = floor(A(n)), where A(n) is the area enclosed between the line y = x and the curve y = exp(x*log(n+1)/n) - 1 for 0 <= x <= n (the constant log(n+1)/n makes the curve pass through (n,n)).
%C A397034 The curve y = exp(c*x) - 1 with c = log(n+1)/n passes through the origin and through (n,n), where it meets the line y = x; on 0 <= x <= n the line lies above the convex curve, and A(n) is the area of the region between them.
%C A397034 A(n) = n^2/2 - n^2/log(n+1) + n is asymptotic to n^2/2, but the n^2/log(n+1) correction term is large at small n (e.g. a(10) = 18, far from 10^2/2 = 50), so the sequence is not a floor-of-polynomial sequence.
%C A397034 a(n) is strictly increasing for n >= 2.
%F A397034 a(n) = floor(n^2/2 - n^2/log(n+1) + n).
%F A397034 a(n) = floor(Integral_{x=0..n} (x - (exp(x*log(n+1)/n) - 1)) dx).
%e A397034 n=3: c = log(4)/3, A(3) = 9/2 - 9/log(4) + 3 = 1.00787..., so a(3) = 1.
%e A397034 n=10: A(10) = 50 - 100/log(11) + 10 = 18.2967..., so a(10) = 18.
%t A397034 a[n_] := Floor[n^2/2 - n^2/Log[n + 1] + n]; Array[a, 57]
%o A397034 (Python)
%o A397034 from mpmath import mp, mpf, log, floor
%o A397034 mp.dps = 50
%o A397034 def a(n):
%o A397034     return int(floor(mpf(n)**2/2 - mpf(n)**2/log(n+1) + n))
%o A397034 print([a(n) for n in range(1, 58)])
%Y A397034 Cf. A007590.
