%I A397582 #21 Jul 12 2026 03:56:57
%S A397582 1,2,7,24,83,288,999,3466,12025,41720,144745,502184,1742297,6044794,
%T A397582 20972047,72761248,252440747,875827896,3038631887,10542349458,
%U A397582 36576043505,126898369648,440266214609,1527476990160,5299488986545,18386256355698
%N A397582 Number of ways to tile a 2 X n strip with squares, dominoes, and T-shaped tetrominoes.
%C A397582 Compare to A030186 which counts tilings with just squares and dominoes, and to A000213 which counts tilings with just squares and T-shaped tetrominoes, and to A387619 which counts tilings with squares, dominoes, and (bent and straight) trominoes, and to A397583 which uses squares, dominoes, and T-shaped tetrominoes but the strip is missing one corner.
%H A397582 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (3,2,-1,-1).
%F A397582 G.f.: (1 - x - x^2)/(1 - 3*x - 2*x^2 + x^3 + x^4).
%F A397582 a(n) = 3*a(n-1) + 2*a(n-2) - a(n-3) - a(n-4).
%F A397582 a(n) = b(n+1) - b(n) - b(n-1) for b(n) = A397583(n).
%F A397582 a(n) = a(n-2) + 2*b(n) for b(n) = A397583(n).
%F A397582 a(n) = A030186(n) + 2*Sum_{i=1..n-2} A397583(i)*A033505(n-2-i).
%F A397582 a(2*n) = a(n)^2 + a(n-1)^2 + 2*b(n)^2 + 4*b(n)*b(n-1) for b(n) = A397583(n).
%e A397582 Here is one of the a(6)=999 ways to tile this 2 X 6 strip with squares, dominoes, and T-shaped tetrominoes:
%e A397582  ___________
%e A397582 |_   _| |_|_|
%e A397582 |_|_|_|_|___|.
%t A397582 LinearRecurrence[{3, 2, -1, -1}, {1, 2, 7, 24}, 20]
%Y A397582 Cf. A000213, A030186, A387619, A397583.
%K A397582 nonn,easy,new
%O A397582 0,2
%A A397582 _Greg Dresden_ and Yutang (Daniel) Bai, Jul 01 2026
