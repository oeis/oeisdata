%N A397860 G.f. A(x) satisfies A(x) = 1 + x * (1+x)^3 * A(x * (1+x)^2).
%F A397860 a(0) = 1; a(n) = Sum_{k=0..n-1} binomial(2*k+3,n-k-1) * a(k).
%o A397860 (PARI) a_vector(n, s=2, t=3) = my(v=vector(n+1)); v[1]=1; for(i=1, n, v[i+1]=sum(k=0, i-1, binomial(s*k+t, i-k-1)*v[k+1])); v;
