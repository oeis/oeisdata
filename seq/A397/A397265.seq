%S A397265 0,1,7,45,311,2383,20301,191369,1982971,22436211,275469833,3649696141,
%T A397265 51918805719,789481862471,12781506673141,219532566547473,
%U A397265 3987537447519731,76374382747183579,1538488737341228001,32517284049719360021,719560660404897360463,16637683826845139530671
%N A397265 a(n) = r(2,n,1) where r(m,n,k) is the number of possible outcomes in a race with n participants that contains exactly k ties of size at least m.
%H A397265 Wenxiang Zhu, <a href="/A397265/b397265.txt">Table of n, a(n) for n = 1..200</a>
%H A397265 Yu Chen and Wenxiang Zhu, <a href="https://arxiv.org/abs/2607.02085">A Snail Race Problem</a>, arXiv:2607.02085 [math.CO], 2026.
%F A397265 r(m,n,k) = Sum_{i=1..m-1} binomial(n,i)*r(m,n-i,k) + Sum_{i=m..n} binomial(n,i)*r(m,n-i,k-1); r(m,0,0) = 1, r(m,0, k) = 0 for k >= 1.
%F A397265 It appears that a(n) = A007808(n) - n!.
%e A397265 For a race of n = 3 participants (A, B, C) with exactly 1 tie of size at least 1, there are 7 possible outcomes: (A = B = C = 1st), (A = B = 1st, C = 2nd), (A = C = 1st, B = 2nd), (B = C = 1st, A = 2nd), (C = 1st, A = B = 2nd), (B = 1st, A = C = 2nd), and (A = 1st, B = C = 2nd).
%o A397265 (PARI) r(m, n, k) = if (n==0, return(k==0)); sum(i=1, m-1, binomial(n,i)*r(m,n-i,k)) + sum(i=m, n, binomial(n,i)*r(m,n-i,k-1));
%o A397265 a(n) = r(2, n, 1); \\ _Michel Marcus_, Jul 19 2026
%Y A397265 Cf. A007808, A397883.
