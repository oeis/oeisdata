%N A397080 Expansion of g.f. (Sum_{j>=1} x^j/(1-x^j))^2 * Product_{k>=1} ((1+x^k)/(1-x^k))^k.
%C A397080 Convolution of A397040 and A397039.
%F A397080 a(n) ~ exp(1/12 + 3*(7*zeta(3))^(1/3)*n^(2/3)/2^(4/3)) * (3*gamma + log(2*n/(7*zeta(3))))^2 / (A * 2^(1/9) * 3^(5/2) * sqrt(Pi) * (7*zeta(3))^(17/36) * n^(1/36)), where A is the Glaisher-Kinkelin constant A074962 and gamma is the Euler-Mascheroni constant A001620.
%t A397080 nmax = 40; CoefficientList[Series[Sum[x^j/(1-x^j), {j, 1, nmax}]^2 * Product[((1+x^k)/(1-x^k))^k, {k, 1, nmax}], {x, 0, nmax}], x]
