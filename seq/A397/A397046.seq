%I A397046 #14 Jun 24 2026 00:28:36
%S A397046 2,3,5,7,10,29,38,47,49,56,58,65,67,74,76,83,85,89,92,94,98,100,119,
%T A397046 128,137,139,146,148,155,157,164,166,173,175,179,182,184,188,191,193,
%U A397046 197,199,209,218,227,229,236,238,245,247,254,256,263,265,269,272,274,278
%N A397046 Numbers k with digital sum not divisible by any smaller term of the sequence, with a(1) = 2.
%C A397046 Equivalently, apply the same sieve as Eratosthenes, but cross off every number whose digital sum is divisible by k.
%C A397046 If we replace the digital sum with the digital root in the definition, we get 2, 3, 5, 7 followed by A017173 \ {1}.
%H A397046 Stefano Spezia, <a href="/A397046/b397046.txt">Table of n, a(n) for n = 1..10000</a>
%H A397046 <a href="/index/Si#sieve">Index entries for sequences generated by sieves</a>.
%e A397046 2 is the first term;
%e A397046 3 is a term since digsum(3) = 3 is not divisible by 2;
%e A397046 4 is not a term since digsum(4) = 4 is a multiple of 2;
%e A397046 5 is a term since digsum(5) = 5 is not divisible by any smaller terms of the sequence: 2, 3;
%e A397046 6 is not a term since digsum(6) = 6 is a multiple of 2;
%e A397046 7 is a term since digsum(7) = 7 is not divisible by any smaller terms of the sequence: 2, 3, 5;
%e A397046 8 and 9 are not terms since their digital sum is divisible respectively by 2 and 3;
%e A397046 10 is a term since digsum(10) = 1 which is lower than any other term of the sequence;
%e A397046 ...
%t A397046 kmax=300; a={2}; For[k=3,k<=kmax, k++, If[AllTrue[a,Mod[DigitSum[k],#]!=0 &], AppendTo[a,k]]]; a
%o A397046 (Python)
%o A397046 def aupto(limit):
%o A397046     a = [2]
%o A397046     for n in range(3, limit+1):
%o A397046         ds = sum(map(int, str(n)))
%o A397046         if all(ds%ai for ai in a):
%o A397046             a.append(n)
%o A397046     return a
%o A397046 print(aupto(280)) # _Michael S. Branicky_, Jun 19 2026
%Y A397046 Cf. A007953, A017173, A397047, A397050.
%Y A397046 A011557 \ {1} is a subsequence.
%K A397046 nonn,base,new
%O A397046 1,1
%A A397046 _Stefano Spezia_, Jun 14 2026
