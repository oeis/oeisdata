%S A397103 1,2,4,2,18,12,4,12,24,26,18,42,10,2,16,18,34,20,4,12,46,26,16,6,36,
%T A397103 26,16,6,16,90,18,42,30,6,162,132,58,24,142,48,22,56,16,36,10,2,12,24,
%U A397103 100,20,4,12,180,36,60,12,130,26,54,210,42,150,30,6,82,68,136,92,60,12,106
%N A397103 Smallest integer k>0 such that k*5^n + 1 is a prime.
%C A397103 Obviously for n>0, a(n) must be even.
%H A397103 Robert G. Wilson v, <a href="/A397103/b397103.txt">Table of n, a(n) for n = 0..6500</a>
%F A397103 If 5|a(n) then a(n+1) = a(n)/5.
%e A397103 a(0) = 1*5^0+1 = 2 which is prime;
%e A397103 a(1) = 2*5^1+1 = 11 which is prime;
%e A397103 a(2) = 4*5^2+1 = 101 which is prime;
%e A397103 a(3) = 2*5^3+1 = 251 which is prime; etc.
%t A397103 a[n_] := Block[{k = 2}, While[ !PrimeQ[ k*5^n +1], k+=2]; k]; a[0] = 1; Array[a, 71, 0]
%Y A397103 Cf. A035050, A239676, A295640, A225911, A121172.
%K A397103 nonn,new
%O A397103 0,2
%A A397103 _Robert G. Wilson v_, Jun 16 2026
