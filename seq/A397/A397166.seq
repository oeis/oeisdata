%I A397166 #14 Jun 17 2026 15:46:01
%S A397166 2,4,7,11,14,22,24,28,31,39,49,55,63,66,70,87,91,95,104,121,128,132,
%T A397166 136,140,145,149,162,166,186,198,212,256,259,261,263,276,287,291,301,
%U A397166 312,320,331,335,351,355,359,368,376,380,400,415,421,428,444,448,454,458,466,487,501,505,531,535,550,556,560,566,578,606,629
%N A397166 a(n) = smallest k such that prime(n) divides A280864(k).
%H A397166 Michael De Vlieger, <a href="/A397166/b397166.txt">Table of n, a(n) for n = 1..43598</a> (* full dataset of terms that result from 2^20 terms of A280864 *)
%e A397166 Consider p = prime(6) = 13. A280864(22) = 26, A280864(23) = 13, so a(6) = 22, whereas A280742(6) = 23.
%t A397166 Block[{c, k, m, p, r, s, w, nn, facs, rad},
%t A397166   nn = 640; c[_] := False; p[_] := 0; r = s = 1;
%t A397166   facs[n_] := facs[n] = FactorInteger[n][[All, 1]];
%t A397166   rad[n_] := Times @@ facs[n];
%t A397166   Monitor[Do[w = GCD[r, s]; m = r/w; k = m;
%t A397166   While[Or[c[k], ! CoprimeQ[w, k] ], k += m]; c[k] = True;
%t A397166   Map[If[p[#] == 0, Set[p[#], i]] &, facs[k]];
%t A397166     s = r; r = rad[k], {i, nn}], i]; k = 2;
%t A397166   Reap[While[p[k] > 0, Sow[p[k]]; k = NextPrime[k] ] ][[-1, 1]] ] (* _Michael De Vlieger_, Jun 17 2026 *)
%Y A397166 Cf. A280864, A280741, A280745, A372058, A372059, A280742.
%K A397166 nonn,new
%O A397166 1,1
