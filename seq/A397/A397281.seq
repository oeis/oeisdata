%U A397281 28158588057600000,45370421265641472000,646301432181294489600,2667271568297656320000,2753239782691250012160000
%N A397281 Expansion of e.g.f. (1/x) * Series_Reversion( x + 1 - exp(x^4) ).
%F A397281 E.g.f. A(x) satisfies A(x) = 1 + (exp((x * A(x))^4) - 1)/x.
%F A397281 a(n) = (1/(n+1)) * Sum_{k=ceiling(n/4)..floor(n/3)} (4*k)!/k! * Stirling2(k,4*k-n).
%F A397281 a(n) ~ sqrt((4*w^3*(1+w) - 1)/(3 + 4*w^4)) * n^(n-1) / (2*w*exp(n) * (1 - 1/(4*w^3) + w)^(n+1)), where w = (3*LambertW(1/(3*2^(2/3))))^(1/4)/sqrt(2). - _Vaclav Kotesovec_, Jun 20 2026
%t A397281 Table[1/(n+1) * Sum[(4*k)!/k! * StirlingS2[k,4*k-n], {k,Ceiling[n/4],Floor[n/3]}], {n,0,25}] (* _Vaclav Kotesovec_, Jun 20 2026 *)
%o A397281 (PARI) my(N=30, x='x+O('x^N)); Vec(serlaplace(serreverse(x+1-exp(x^4))/x))
%Y A397281 Cf. A392788, A397280.
%K A397281 nonn
%O A397281 0,4
%A A397281 _Seiichi Manyama_, Jun 20 2026
