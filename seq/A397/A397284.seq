%N A397284 Triangle read by rows: T(n, k) = 2^n * P_{n, k}(1/2) where P_{n, k}(x) = x * (n - k + x)^(n - k - 1) * binomial(n, k).
%F A397284 P_{n, k}(1) = A088956(n, k).
%F A397284 P_{n, k}(-1) = A215534(n, k).
%F A397284 P_{n, k}(0) = A023531(n, k).
%F A397284 See also a comment of _Werner Schulte_ in A397048.
%e A397284 Triangle starts:
%e A397284   [0]        1;
%e A397284   [1]        1,       2;
%e A397284   [2]        5,       4,       4;
%e A397284   [3]       49,      30,      12,      8;
%e A397284   [4]      729,     392,     120,     32,    16;
%e A397284   [5]    14641,    7290,    1960,    400,    80,   32;
%e A397284   [6]   371293,  175692,   43740,   7840,  1200,  192,  64;
%e A397284   [7] 11390625, 5198102, 1229844, 204120, 27440, 3360, 448, 128;
%e A397284 .
%e A397284 The triangle of polynomials (n, k) -> P(x) = x * (n - k + x)^(n-k-1) * binomial(n, k) starts:
%e A397284   1;
%e A397284   x          , 1;
%e A397284   x*(2 + x)  , 2*x          , 1;
%e A397284   x*(3 + x)^2, 3*x*(2 + x)  , 3*x          ,  1;
%e A397284   x*(4 + x)^3, 4*x*(3 + x)^2, 6*x*(2 + x)  ,  4*x         , 1;
%e A397284   x*(5 + x)^4, 5*x*(4 + x)^3, 10*x*(3 + x)^2, 10*x*(2 + x), 5*x,  1;
%e A397284   ...
%p A397284 P := (x, n, k) -> x * (n - k + x)^(n - k - 1) * binomial(n, k):
%p A397284 T := (n, k) -> 2^n * P(1/2, n, k);
%p A397284 seq(seq(T(n, k), k = 0..n), n = 0..8);
%Y A397284 Cf. A052750 (column 0), A397285 (row sums), A397286, A088956, A023531, A215534, A397048.
%K A397284 nonn,tabl,new
