%I A397164 #12 Jun 17 2026 15:46:31
%S A397164 137,659,1019,1229,1237,1291,1303,1451,1493,1693,1871,1877,1931,2137,
%T A397164 2383,2549,2711,3407,3467,3617,3917,4007,4091,4253,4483,4649,4799,
%U A397164 4933,5167,5279,5441,5479,5521,5653,5689,5857,6263,6689,6863,7583,7687,8011,8111,8443,8849,8969,9007,9547,10159,10271,10391,10889,11239
%N A397164 In A280864, these are the primes that begin a block of length 4 that both begins and ends with a prime.
%H A397164 Michael De Vlieger, <a href="/A397164/b397164.txt">Table of n, a(n) for n = 1..2856</a>
%t A397164 Block[{c, j, k, m, q, r, s, t, w, nn, rad},
%t A397164   nn = 24000; c[_] := False; q = 0; r = s = 1; t = {};
%t A397164   rad[n_] := rad[n] = Times @@ FactorInteger[n][[All, 1]];
%t A397164   Monitor[Reap[Do[w = GCD[r, s]; m = r/w; k = m;
%t A397164     While[Or[c[k], ! CoprimeQ[w, k]], k += m];
%t A397164       c[k] = True; s = r; r = rad[k];
%t A397164     If[CoprimeQ[s, r],
%t A397164       If[Length[t] == 4,
%t A397164         If[AllTrue[{First[t], Last[t]}, PrimeQ], Sow[First[t] ] ] ];
%t A397164       q++; t = {k}, AppendTo[t, k]], {i, nn}] ][[-1, 1]], i] ] (* _Michael De Vlieger_, Jun 17 2026 *)
%Y A397164 Cf. A280774, A280864, A283832, A396300, A396301, A397102, A397165.
%K A397164 nonn
%O A397164 1,1
%A A397164 _N. J. A. Sloane_, Jun 17 2026
