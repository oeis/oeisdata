%S A397209 1,3,7,21,37,50,52,78,96,115,129,144,167,174,222,237,252,268,271,280,
%T A397209 273,354,421,420,419,466,463,505,528,546,615,545,663,620,636,656,640,
%U A397209 659,747,752,738,741,892,879,889,916,938,949,915,1039,1063,1087,1076,1044
%N A397209 a(n) is the smallest index k such that A397208(k) = n, or -1 if no such k exists.
%C A397209 It is conjectured that every nonnegative integer occurs in A397208.
%e A397209 a(0) = 1, since A397208(1) = 0.
%e A397209 a(1) = 3, since A397208(3) = 1 and this is the first occurrence of 1.
%e A397209 a(2) = 7, since A397208(7) = 2 and no earlier index has value 2.
%p A397209 A397209List := proc(N)
%p A397209     local a, i, k, n, v;
%p A397209     a := Array(0 .. N, 'fill' = -1);
%p A397209     i := 0;
%p A397209     k := 1;
%p A397209     while i <= N do
%p A397209         v := A397208(k);
%p A397209         if v <= N and v >= 0 and a[v] = -1 then
%p A397209             a[v] := k;
%p A397209             i := i + 1
%p A397209         end if;
%p A397209         k := k + 1;
%p A397209     end do;
%p A397209     [seq(a[n], n = 0 .. N)]
%p A397209 end proc:
%p A397209 A397209List(53);
