%I A397901 #8 Jul 20 2026 22:52:42
%S A397901 6,31,100,228,488,868,1498,2362,3529,5154,7433,9783,13481,17449,22548,
%T A397901 28312,36147,43800,54589,65924,78821,93297,112051,129180,153372,
%U A397901 177489,204659,233369,268782,302098,346890,389771,438360,490006,552692,608979,682376,754474,831840
%N A397901 Number of distinct products z*w, where z and w range over the nonzero Gaussian integers a+b*i with 0 <= a, b <= n and i the imaginary unit.
%C A397901 Restricting z and w to the positive real integers gives A027424(n).
%H A397901 Frédéric D. W. Heidenthal-König, <a href="https://doi.org/10.5281/zenodo.20465011">Euclidean Decomposition in Plane Arithmetic</a>, Zenodo, 2026.
%F A397901 a(n) = #{(a*c-b*d, a*d+b*c): 0 <= a, b, c, d <= n,  a+b > 0,  c+d > 0}.
%o A397901 (Python)
%o A397901 def a(n):
%o A397901     factors = []
%o A397901     for x in range(n + 1):
%o A397901         for y in range(n + 1):
%o A397901             if x != 0 or y != 0:
%o A397901                 factors.append((x, y))
%o A397901     products = set()
%o A397901     for a, b in factors:
%o A397901         for c, d in factors:
%o A397901             real_part = a * c - b * d
%o A397901             imaginary_part = a * d + b * c
%o A397901             products.add((real_part, imaginary_part))
%o A397901     return len(products)
%o A397901 print([a(n) for n in range(1, 40)])
%Y A397901 Cf. A027424.
%K A397901 nonn,new
%O A397901 1,1
%A A397901 _Frédéric D. W. Heidenthal-König_, Jul 14 2026
