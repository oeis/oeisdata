%T A397834 87600,186196,394108,831101,1746892,3661031,7652344,15956936,33201944,
%U A397834 68947596,142918554,295757337,611105328,1260898647,2598199062,5347277764,10992515464,22573447784,46308912184
%N A397834 Number of binary words of length n containing the consecutive word ababab.
%H A397834 Wikipedia, <a href="https://en.wikipedia.org/wiki/Autocorrelation_%28words%29">Autocorrelation (words)</a>
%H A397834 <a href="/index/Rec#order_07">Index entries for linear recurrences with constant coefficients</a>, signature (4,-5,4,-5,4,-5,2).
%F A397834 G.f.: x^6/((1-2*x) * (x^6 + (1-2*x) * (1+x^2+x^4))). Equivalently, 1/(1-2*x) - (1+x^2+x^4)/(x^6 + (1-2*x) * (1+x^2+x^4)).
%F A397834 a(n) = 4*a(n-1) - 5*a(n-2) + 4*a(n-3) - 5*a(n-4) + 4*a(n-5) - 5*a(n-6) + 2*a(n-7).
%e A397834 a(7) = 4: the words are aababab, abababa, abababb, bababab.
%o A397834 (PARI) my(N=40, x='x+O('x^N)); concat([0, 0, 0, 0, 0, 0], Vec(x^6/((1-2*x)*(x^6+(1-2*x)*(1+x^2+x^4)))))
%Y A397834 Cf. A256813, A397833.
%K A397834 nonn,easy,new
%O A397834 0,8
