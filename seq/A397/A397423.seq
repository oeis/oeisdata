%N A397423 a(n) = Sum_{j=0..n} abs(Stirling1(n, j)) * binomial(n + j, n) * n^j.
%F A397423 a(n) ~ c * (exp(r)*(1+r)*(1+2*r)/r)^n * n! / n, where r = 0.82506987245889649414011656390500836009994111212734792413605... is the root of the equation -(1+r)*(LambertW(-1, -r*exp(-r)) + r) = r^2 and c = 0.18810075704917016248053554671907469507232504783794203152534...
%p A397423 A397421 := (n, k) -> (-1)^(n-k)*Stirling1(n, k)*binomial(n + k, n)*n^k:
%p A397423 A397423 := n -> local j; add(A397421(n, j), j = 0..n):
%p A397423 seq(A397423(n), n = 0..16);  # _Peter Luschny_, Jun 24 2026
%t A397423 Join[{1}, Table[Sum[Abs[StirlingS1[n, j]]*Binomial[n + j, n]*n^j, {j, 0, n}], {n, 1, 20}]]
