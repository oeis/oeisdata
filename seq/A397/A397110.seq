%S A397110 0,1,2,2,6,6,11,14,21,21,33,33,44,49,62,62,82,82,99,106,125,125,153,
%T A397110 153,176,185,210,210,246,246,275,286,317,317,361,361,396,409,446,446,
%U A397110 498,498,539,554,597,597,657,657,704,721,770,770,838,838,891,910,965,965,1041,1041,1100
%N A397110 Upper (1,1/2) midsequence of (floor[n/2]^2) and (ceiling[n/3]^2); see Comments.
%C A397110 Suppose that s = (s(n)) and t = (t(n)) are sequences of numbers and h > 0 and k > 0. The lower (h, k)-midsequence of s and t is floor(h*s + k*t); the upper (h, k)-midsequence of s and t is ceiling(h*s + k*t).
%H A397110 <a href="/index/Rec#order_11">Index entries for linear recurrences with constant coefficients</a>, signature (0,1,1,0,-1,1,0,-1,-1,0,1).
%F A397110 a(n) = a(n-2) + a(n-3) - a(n-5) + a(n-6) - a(n-8) - a(n-9) + a(n-11), with (a(0),...,a(11)) = (0, 1, 2, 2, 6, 6, 11, 14, 21, 21, 33)
%F A397110 G.f. -x*(x^2+1)*(x^7+x^6+3*x^5+2*x^4+x^3+2*x+1) / ( (x^2-x+1)*(1+x)^2*(1+x+x^2)^2*(x-1)^3 ). - _R. J. Mathar_, Jun 30 2026
%F A397110 (-4*n+13)*a(n) +(-7*n+39)*a(n-1) +8*a(n-2) +26*a(n-3) +29*a(n-4) +14*a(n-5) +(4*n+7)*a(n-6) +(7*n-4)*a(n-7) +66*n-467 =0. - _R. J. Mathar_, Jun 30 2026
%t A397110 z = 60;
%t A397110 f[n_] := Floor[n/2]^2; g[n_] := Ceiling[n/3]^2;
%t A397110 r = 1; s = 1/2;
%t A397110 v[n_] := Ceiling[r*f[n] + s*g[n]]
%t A397110 Table[v[n], {n, 0, z}]
%t A397110 (* Alternative: *)
%t A397110 LinearRecurrence[{0, 1, 1, 0, -1, 1, 0, -1, -1, 0, 1}, {0, 1, 2, 2, 6, 6, 11, 14, 21, 21, 33}, 30]
%Y A397110 Cf. A389123, A397107, A397108, A397111.
%K A397110 nonn,easy,changed
