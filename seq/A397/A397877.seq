%I A397877 #13 Jul 20 2026 18:17:44
%S A397877 2,3,2,2,2,2,3,2,3,3,2,2,2,3,2,2,2,3,2,2,2,2,2,2,3,3,3,2,2,2,2,2,3,3,
%T A397877 2,2,2,2,3,2,2,2,3,2,3
%N A397877 Length of the repeating part of row n of A281001.
%C A397877 Row n of A281001 is the trajectory of n under the map k -> A039951(k) (the smallest Wieferich prime to base k), which is eventually periodic; a(n) is the length of that period.
%C A397877 a(47) is unknown, since there is no known Wieferich prime in base 47 (A039951(47) > 1.4*10^14; cf. Fischer link).
%C A397877 a(n) != 1 for all n, since A039951(k) != k for all k.
%C A397877 This sequence extends A269111 (which covers prime bases) to all bases n >= 2.
%H A397877 Richard Fischer, <a href="http://www.fermatquotient.com/FermatQuotienten/FermQ_Sort.txt">Thema: Fermatquotient B^(P-1) == 1 (mod P^2)</a>.
%F A397877 a(prime(n)) = A269111(n).
%e A397877 The trajectory of 2 is 2, 1093, 2, 1093, ..., entering a repeating cycle of length 2, so a(2) = 2.
%e A397877 The trajectory of 3 is 3, 11, 71, 3, 11, 71, ..., entering a repeating cycle of length 3, so a(3) = 3.
%o A397877 (PARI)
%o A397877 a039951(n) = forprime(p=1, , if(Mod(n, p^2)^(p-1)==1, return(p)));
%o A397877 trajectory(n, terms) = my(v=[n]); while(#v < terms, v=concat(v, a039951(v[#v]))); v;
%o A397877 a(n) = my(len=2, t=trajectory(n, len), k=#t); while(1, while(k > 1, k--; if(t[k]==t[#t], return(#t-k))); len++; t=trajectory(n, len); k=#t);
%o A397877 (Python)
%o A397877 from sympy import nextprime
%o A397877 def a039951(n):
%o A397877     p = 2
%o A397877     while pow(n, p-1, p*p) != 1: p = nextprime(p)
%o A397877     return p
%o A397877 def a(n):
%o A397877     seen = {}; x = n; i = 0
%o A397877     while x not in seen:
%o A397877         seen[x] = i; x = a039951(x); i += 1
%o A397877     return i - seen[x]
%Y A397877 Cf. A039951, A244550, A252801, A252802, A252812, A268479, A269111, A281001, A288097.
%K A397877 nonn,hard,more,new
%O A397877 2,1
