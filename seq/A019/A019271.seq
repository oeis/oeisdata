%I A019271 #17 May 17 2026 12:44:13
%S A019271 0,2,4,5,7,10,11,13,15,17,19,20,22,24,26,28,29,30,32,33,36,37,39,40,
%T A019271 43,44,46,48,49,52,53,55,57,60,61,62,64,65,66,67,68,70,71,72,73,74,76,
%U A019271 77,79,80,81,82,85,86,87,89,90,91,92,94,95,96,98,99,100,103,104,105,106,107
%N A019271 A self-descriptive sequence: positions of consonants in "zero, two, four, ...".
%H A019271 Sean A. Irvine, <a href="https://github.com/archmageirvine/joeis/blob/master/src/irvine/oeis/a019/A019271.java">Java program</a> (github)
%o A019271 (Python)
%o A019271 from itertools import islice
%o A019271 from num2words import num2words
%o A019271 def n2w(n): return "".join(c for c in num2words(n).replace(" and", "") if c.isalpha())
%o A019271 def agen():
%o A019271     k, s = 0, "zero"
%o A019271     while True:
%o A019271         t = ""
%o A019271         for c in s:
%o A019271             if c not in "aeiou":
%o A019271                 yield k
%o A019271                 if k: t += n2w(k)
%o A019271             k += 1
%o A019271         s = t
%o A019271 print(list(islice(agen(), 70))) # _Michael S. Branicky_, May 17 2026
%K A019271 word,nonn
%O A019271 0,2
