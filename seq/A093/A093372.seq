%T A093372 64079,64681,65471,67861,68251,72831,78089,90061,96049,97921,109871,
%U A093372 118441,139359,146611,157079,163081,168299,186961,196559,197209,219781
%N A093372 Composite k such that Fibonacci(k) == Legendre(k,5) == 1 (mod k).
%H A093372 Amiram Eldar, <a href="/A093372/b093372.txt">Table of n, a(n) for n = 1..300</a>
%t A093372 Select[ Range[ 2, 100000 ], ! PrimeQ[ # ] && Mod[ Fibonacci[ # ] - JacobiSymbol[ #, 5 ], # ] == 0 && JacobiSymbol[ #, 5 ] == 1 & ]
%o A093372 (Python)
%o A093372 from itertools import islice
%o A093372 from sympy import nextprime
%o A093372 from sympy.functions.combinatorial.numbers import legendre_symbol
%o A093372 from oeis_sequences.OEISsequences import fibonacci_mod
%o A093372 def A093372_gen(): # generator of terms
%o A093372     p, q = 4, 5
%o A093372     while True:
%o A093372         for m in range(p,q):
%o A093372             if fibonacci_mod(m,m) == 1 and legendre_symbol(m,5) == 1:
%o A093372                 yield m
%o A093372         p, q = q+1, nextprime(q)
%o A093372 A093372_list = list(islice(A093372_gen(),30)) # _Chai Wah Wu_, Jul 13 2026
%Y A093372 Cf. A049062, A090820, A094063.
