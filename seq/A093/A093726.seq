%S A093726 1,1,4,3,11,97,280,101,2337,2251,19516,14101,163009,16245,30256,
%T A093726 245929,11371969,32865601,94983348,22875581,19349753,2292794785,
%U A093726 6626299912,2393795271,2635503517,159951677089,462268926316,11517086141,3861059617665,247970431013
%N A093726 Given the infinite continued fraction (1+i)+1/((1+i)+1/((1+i)+...)), where i is the square root of (-1), this is the numerator of the imaginary part of the convergents.
%F A093726 Conjecture: a(n)/A093727(n) = A317974(n+1)/A138573(n). - _Zhuorui He_, Jun 16 2026
%e A093726 From _Zhuorui He_, Jun 16 2026: (Start)
%e A093726 (1+i) = 1+i, so A093725(1)=1, a(1)=1 and A093727(1)=1.
%e A093726 (1+i)+1/(1+i) = (3+i)/2, so A093725(2)=3, a(2)=1 and A093727(2)=2.
%e A093726 (1+i)+1/((1+i)+1/(1+i)) = (8+4*i)/5, so A093725(3)=8, a(3)=4 and A093727(3)=5.
%e A093726 (1+i)+1/((1+i)+1/((1+i)+1/(1+i))) = (6+3*i)/4, so A093725(4)=6, a(4)=3 and A093727(4)=4.
%e A093726 (1+i)+1/((1+i)+1/((1+i)+1/((1+i)+1/(1+i)))) = (23+11*i)/15, so A093725(5)=23, a(5)=11 and A093727(5)=15. (End)
%t A093726 Table[ Im[ Numerator[ FromContinuedFraction[ Table[1 + I, {n}]]]], {n, 30}]
%Y A093726 Cf. A091806, A091807, A091808, A091809, A093725, A093727, A317974, A138573.
%K A093726 frac,nonn
%O A093726 1,3
