%T A093043 4117971,13325450,43123017,139547457,451587592,1461364025,4729080015,
%U A093043 15303613546,49523551333,160261550085,518617316448,1678280815525,5431030925499,17575185066730,56874493910481
%N A093043 a(n) = Jacobsthal(n)*Fibonacci(n-1).
%C A093043 Form a graph from a triangle and its midpoint triangle. a(n) counts walks of length n between two vertices of the original triangle.
%H A093043 Paolo Xausa, <a href="/A093043/b093043.txt">Table of n, a(n) for n = 0..1000</a>
%H A093043 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (1,7,2,-4).
%F A093043 G.f.: x^2*(1+2*x)/((1+x-x^2)*(1-2*x-4*x^2)).
%F A093043 a(n) = A001045(n)*A000045(n-1).
%F A093043 a(n) = (2^n/3-(-1)^n/3)*(((1+sqrt(5))/2)^(n-1)/sqrt(5)-((1-sqrt(5))/2)^(n-1)/sqrt(5)).
%F A093043 a(n) = a(n-1) + 7*a(n-2) + 2*a(n-3) - 4*a(n-4). - _Wesley Ivan Hurt_, Jun 05 2026
%t A093043 A093043[n_] := Round[2^n/3]*Fibonacci[n-1]; Array[A093043, 30, 0] (* _Paolo Xausa_, Jun 06 2026 *)
%t A093043 (* Alternative: *)
%t A093043 LinearRecurrence[{1, 7, 2, -4}, {0, 0, 1, 3}, 30] (* _Paolo Xausa_, Jun 06 2026 *)
