%I A181687 #13 Mar 06 2026 04:14:28
%S A181687 1,2,3,6,8,12,15,21,24,25,30,33,39,42,45,50,51,57,66,69,75,78,81,87,
%T A181687 90,93,96,102,111,114,120,123,128,129,138,141,150,159,162,168,174,177,
%U A181687 180,183,186,189,200,201,213,219,222,225,237,240,246,249,258,264,267,282,291,300
%N A181687 Numbers k such that the number of odd divisors of (2k)^2 is an odd divisor of (2k)^2, and the number of even divisors of (2k)^2 is an even divisor of (2k)^2.
%H A181687 Amiram Eldar, <a href="/A181687/b181687.txt">Table of n, a(n) for n = 1..10000</a>
%F A181687 A016742(a(n)) = A181795(n).
%p A181687 for j from 1 to 300 do
%p A181687    y:=(2*j)^2:evdiv:=0:oddiv:=0:
%p A181687    for k in divisors(y) do
%p A181687       if(k mod 2=0)then evdiv:=evdiv+1:else oddiv:=oddiv+1:fi:
%p A181687    od:
%p A181687    if(type(y/evdiv,integer) and type(y/oddiv,integer))then
%p A181687       print(j);
%p A181687    fi;
%p A181687 od:
%t A181687 q[k_] := Module[{kk = 4*k^2, v = IntegerExponent[k, 2], m, e, no, ne}, m = k/2^v; e = If[m == 1, 0, FactorInteger[m][[;; , 2]]]; no = Times @@ (2*e + 1); ne = (2*v + 2)*no; OddQ[no] && Divisible[kk , no] && EvenQ[ne] && Divisible[kk , ne]]; Select[Range[300], q] (* _Amiram Eldar_, Mar 06 2026 *)
%o A181687 (PARI) isok(k) = {my(kk = 4*k^2, v = valuation(k, 2), m = k >> v, e = factor(m)[, 2], no, ne); no = vecprod(apply(x -> 2*x+1, e)); ne = (2*v+2)*no; (no % 2) && !(kk % no) && !(ne % 2) && !(kk % ne);} \\ _Amiram Eldar_, Mar 06 2026
%Y A181687 Cf. A016742, A181795.
%K A181687 easy,nonn
%O A181687 1,2
%A A181687 _Nathaniel Johnston_, Nov 17 2010
