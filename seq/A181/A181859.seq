%I A181859 #33 May 06 2026 04:37:11
%S A181859 1,1,1,1,4,1,9,1,32,9,25,1,12,1,49,5,128,1,81,1,100,21,121,1,144,25,
%T A181859 169,27,98,1,5,1,512,11,289,7,108,1,361,13,80,1,147,1,242,3,529,1,64,
%U A181859 49,625,17,338,1,729,55,56,57
%N A181859 a(n) = gcd(n^2, n!) / gcd(n^2, n!/floor(n/2)!^2).
%F A181859 a(n) = A170826(n) / A181861(n).
%F A181859 From _Peter Luschny_, May 06 2026: (Start)
%F A181859 a(p) = 1 <=> p is prime.
%F A181859 a(2^k) = 2^(2*k-1) for k >= 3.  (End)
%p A181859 A181859 := n -> igcd(n^2,n!)/igcd(n^2,n!/iquo(n,2)!^2);
%t A181859 a[n_] := GCD[n^2, n!]/GCD[n^2, n!/Quotient[n, 2]!^2];
%t A181859 Table[a[n], {n, 0, 57}] (* _Jean-François Alcover_, Jun 18 2019 *)
%o A181859 (PARI) a(n)=if(isprime(n), n, if(n==4, 8, n^2))/gcd(n^2,n!/(n\2)!^2) \\ _Charles R Greathouse IV_, Feb 01 2013
%o A181859 (Python)
%o A181859 from math import prod
%o A181859 from sympy import factorint
%o A181859 from sympy.ntheory.factor_ import digits
%o A181859 def A181859(n):
%o A181859     def s(n,p): return sum(digits(n,p)[1:])
%o A181859     return prod(p**(min(e<<1,(n-s(n,p))//(p-1))-min(e<<1,((n-(n&-2))+(s(n>>1,p)<<1)-s(n,p))//(p-1))) for p,e, in factorint(n).items()) if n else 1 # _Chai Wah Wu_, May 05 2026
%o A181859 (SageMath)
%o A181859 def a(n):
%o A181859     if n < 2: return 1
%o A181859     def legendre_vp(num, p):
%o A181859         count = 0
%o A181859         while num >= p:
%o A181859             num //= p
%o A181859             count += num
%o A181859         return count
%o A181859     ans = 1
%o A181859     for p, k in factor(n):
%o A181859         vp_n = legendre_vp(n, p)
%o A181859         vp_m = legendre_vp(n // 2, p)
%o A181859         e1 = min(2 * k, vp_n)
%o A181859         e2 = min(2 * k, vp_n - 2 * vp_m)
%o A181859         ans *= p ** (e1 - e2)
%o A181859     return ans
%o A181859 L = [a(n) for n in range(58)]; print(L)  # _Peter Luschny_, May 06 2026
%Y A181859 Cf. A170826, A181860, A181861, A056040, A000290.
%K A181859 nonn,changed
%O A181859 0,5
