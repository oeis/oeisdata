%N A140228 Binomial transform of [1, 5, 10, 10, 5, 1, 1, -1, 1, -1, 1, ...].
%H A140228 Zhuorui He, <a href="/A140228/b140228.txt">Table of n, a(n) for n = 0..1000</a>
%H A140228 <a href="/index/Rec#order_06">Index entries for linear recurrences with constant coefficients</a>, signature (6,-15,20,-15,6,-1).
%F A140228 A007318 * [1, 5, 10, 10, 5, 1, 1, -1, 1, -1, 1, ...]
%F A140228 From _Emeric Deutsch_, Jun 03 2008: (Start)
%F A140228 a(n) = n*(274 + 85*n^2 + n^4)/60 for n >= 1. [corrected by _Zhuorui He_, Mar 01 2026]
%F A140228 G.f.: (1+x^6)/(1-x)^6. (End)
%F A140228 E.g.f.: 1 + exp(x)*x*(360 + 270*x + 110*x^2 + 10*x^3 + x^4)/60. - _Stefano Spezia_, Mar 02 2026
%e A140228 a(4) = 56 = (1, 3, 3, 1) dot (1, 5, 10, 10) = (1 + 15 + 30 + 10).
%p A140228 1, seq((1/60)*n*(274+85*n^2+n^4),n=1..30); # _Emeric Deutsch_, Jun 03 2008
%t A140228 A140228[n_] := If[n == 0, 1, n*(274 + 85*n^2 + n^4)/60]; Array[A140228, 50, 0] (* or *)
%t A140228 LinearRecurrence[{6, -15, 20, -15, 6, -1}, {1, 6, 21, 56, 126, 252, 463}, 50] (* _Paolo Xausa_, Apr 03 2026 *)
