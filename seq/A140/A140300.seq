%S A140300 1,1024,1048576,1073741824,1099511627776,1125899906842624,
%T A140300 1152921504606846976,1180591620717411303424,1208925819614629174706176,
%U A140300 1237940039285380274899124224,1267650600228229401496703205376,1298074214633706907132624082305024
%N A140300 a(n) = 1024^n.
%C A140300 First bisection of A009976.
%C A140300 From _Ed Pegg Jr_, Apr 23 2026: (Start)
%C A140300 1024^3 bytes is a gibibyte within IEC binary prefixes.
%C A140300 For exponents 1 to 10: kibi, mebi, gibi, tebi, pebi, exbi, zebi, yobi, robi, quebi.
%C A140300 Corresponding to: kilo, mega, giga, tera, peta, exa, zetta, yotta, ronna, quetta. (End)
%H A140300 Vincenzo Librandi, <a href="/A140300/b140300.txt">Table of n, a(n) for n = 0..300</a>
%H A140300 Wikipedia, <a href="http://en.wikipedia.org/wiki/Binary_prefix">Binary prefix</a>.
%H A140300 <a href="/index/Rec#order_01">Index entries for linear recurrences with constant coefficients</a>, signature (1024).
%F A140300 a(n) = 2^(10*n).
%F A140300 G.f.: 1/(1-1024*x). - _L. Edson Jeffery_, Jul 03 2012
%F A140300 a(m*n) = a(n)^m; a(n+m) = a(n)*a(m). - _Bruno Berselli_, Mar 30 2017
%F A140300 From _Elmo R. Oliveira_, Aug 30 2024: (Start)
%F A140300 E.g.f.: exp(1024*x).
%F A140300 a(n) = 1024*a(n-1) for n > 0.
%F A140300 a(n) = A009976(n)^2. (End)
%t A140300 1024^Range[0,10] (* _Ed Pegg Jr_, Apr 23 2026 *)
%o A140300 (Magma) [1024^n: n in [0..15]] ; // _Vincenzo Librandi_, Aug 09 2011
%o A140300 (PARI) A140300(n)=1<<(10*n) \\ _M. F. Hasler_, Apr 23 2026
