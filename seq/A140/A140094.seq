%I A140094 #17 Jun 08 2026 00:58:50
%S A140094 1,1,4,25,199,1855,19387,221407,2717782,35455981,487672243,7029980797,
%T A140094 105732907498,1653377947393,26805765569863,449568735630517,
%U A140094 7785116448484318,138980739891821269,2554369130466577138,48277900432914176227,937357175357395653301,18679170546731484738259,381722027611740836329630
%N A140094 G.f. satisfies: A(x) = x/(1 - A(A(A(x)))).
%H A140094 Paul D. Hanna, <a href="/A140094/b140094.txt">Table of n, a(n), n = 1..100.</a>
%F A140094 G.f. A(x) = Sum_{n>=1} a(n)*x^n satisfies the following formulas.
%F A140094 (1) A(x) = Series_Reversion(x - x*A(A(x))).
%F A140094 (2) A(x) = x + Sum_{n=1} d^(n-1)/dx^(n-1) x^n * A(A(x))^n / n!.
%F A140094 (3) A(x) = x*exp( Sum_{n=1} d^(n-1)/dx^(n-1) x^(n-1) * A(A(x))^n / n! ).
%F A140094 (4) A^n(x) = A^(n-1) / (1 - A^(n+2)(x)).
%F A140094 (5) A^n(x) = 1 - A^(n-3)(x) / A^(n-2)(x).
%F A140094 (6) A(x) = 1 - A^(-2)(x) / A^(-1)(x) where -A^(-1)(-x) = x - x*A^2(-x) is the g.f. of A396102. - _Paul D. Hanna_, Jun 07 2026
%e A140094 G.f.: A(x) = x + x^2 + 4*x^3 + 25*x^4 + 199*x^5 + 1855*x^6 + 19387*x^7 + 221407*x^8 + 2717782*x^9 + 35455981*x^10 + ...
%e A140094 Iterations of A(x) are related as follows.
%e A140094 A^2(x) = 1 - A^(-1)(x) / x;
%e A140094 A^3(x) = 1 - x / A(x);
%e A140094 A^4(x) = 1 - A(x) / A^2(x);
%e A140094 A^5(x) = 1 - A^2(x) / A^3(x);
%e A140094 A^6(x) = 1 - A^3(x) / A^4(x); ...
%e A140094 where the iterations of A(x) begin:
%e A140094 A^2(x) = x + 2*x^2 + 10*x^3 +  71*x^4 +  616*x^5 +  6119*x^6 + ...;
%e A140094 A^3(x) = x + 3*x^2 + 18*x^3 + 144*x^4 + 1365*x^5 + 14544*x^6 + ...;
%e A140094 A^4(x) = x + 4*x^2 + 28*x^3 + 250*x^4 + 2584*x^5 + 29584*x^6 + ...;
%e A140094 A^5(x) = x + 5*x^2 + 40*x^3 + 395*x^4 + 4435*x^5 + 54515*x^6 + ...;
%e A140094 A^6(x) = x + 6*x^2 + 54*x^3 + 585*x^4 + 7104*x^5 + 93555*x^6 + ...;
%e A140094 ...
%e A140094 Iterations of A(x) are also related by continued fractions
%e A140094 A(x) = x/(1 - A^2(x)/(1 - A^4(x)/(1 - A^6(x)/(1 - ...)))), and
%e A140094 A^2(x) = A(x)/(1 - A^3(x)/(1 - A^5(x)/(1 - A^7(x)/(1 - ...)))).
%e A140094 Also, A(x) is the unique solution to variable A in the infinite system of simultaneous equations starting with:
%e A140094   A = x + A*C;
%e A140094   B = A + B*D;
%e A140094   C = B + C*E;
%e A140094   D = C + D*F; ...
%e A140094   resulting in B = A^2(x), C = A^3(x), D = A^4(x), etc.
%e A140094 The series reversion of A(x) begins
%e A140094 A^(-1)(x) = x - x^2 - 2*x^3 - 10*x^4 - 71*x^5 - 616*x^6 - 6119*x^7 - 67210*x^8 - 799307*x^9 + ... + (-1)^(n-1)*A396102(n)*x^n + ... also,
%e A140094 A^(-2)(x) = x - 2*x^2 - 2*x^3 - 11*x^4 - 80*x^5 - 701*x^6 - 6998*x^7 - 77075*x^8 - 918059*x^9 + ...
%e A140094 where A(x) = 1 - A^(-2)(x)/A^(-1)(x).
%o A140094 (PARI) {a(n) = my(A); if(n<0, 0, n++; A=x+O(x^2); for(i=2, n, A=x/(1 - subst(A, x, subst(A, x, A)))); polcoef(GF=A, n))}
%o A140094 {upto(n) = a(n); Vec(GF)}
%o A140094 upto(30)
%Y A140094 Cf. A396102, A140095, A088714.
%Y A140094 Cf. A088717, A091713, A120971, A139702.
