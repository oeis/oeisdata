%I A140801 #16 Apr 03 2026 07:33:28
%S A140801 360,1080,1800,2520,3240,3960,4680,5400,6120,6840,7560,8280,9000,9720,
%T A140801 10440,11160,11880,12600,13320,14040,14760,15480,16200,16920,17640,
%U A140801 18360,19080,19800,20520,21240,21960,22680,23400,24120,24840,25560,26280,27000,27720,28440,29160
%N A140801 a(0)=360, a(n) = a(n-1) + 720 for n>=1.
%H A140801 Tanya Khovanova, <a href="https://www.tanyakhovanova.com/RecursiveSequences/RecursiveSequences.html">Recursive Sequences</a>.
%H A140801 <a href="/index/Rec#order_02">Index entries for linear recurrences with constant coefficients</a>, signature (2,-1).
%F A140801 a(n) = 360 + 720*n.
%F A140801 From _Elmo R. Oliveira_, Apr 02 2026: (Start)
%F A140801 G.f.: 360*(x + 1)/(x - 1)^2.
%F A140801 E.g.f.: 360*(2*x + 1)*exp(x).
%F A140801 a(n) = 360*A005408(n).
%F A140801 a(n) = 2*a(n-1) - a(n-2). (End)
%t A140801 NestList[720+#&,360,40] (* or *) 720*Range[0,40]+360 (* _Harvey P. Dale_, Jan 24 2017 *)
%Y A140801 Cf. A005408, A069476 (same sequence, starting with 1800).
%K A140801 nonn,easy,less
%O A140801 0,1
