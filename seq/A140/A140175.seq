%I A140175 #17 Jun 28 2026 01:07:29
%S A140175 4621,34361,2881861,63882851
%N A140175 Numbers m such that m = prime((d_1*d_2*...*d_k)*(d_1+d_2+...+d_k)) where d_1d_2...d_k is the decimal expansion of m.
%C A140175 Similarly to A110069, the sequence is finite with all terms < 10^146. There are no other terms below 10^11, the sequence is likely complete. - _Max Alekseyev_, Jun 27 2026
%e A140175 63882851 = prime((6*3*8*8*2*8*5*1)*(6+3+8+8+2+8+5+1)).
%t A140175 fQ[n_] := Block[{id = IntegerDigits@ n}, n == Prime[Plus @@ id Times @@ id]]; k = 1; lst = {}; While[ k < 10^8, If[ fQ@n, AppendTo[lst, k]; Print@ n]; k++ ]; lst (* _Robert G. Wilson v_, Jan 09 2009 *)
%Y A140175 Cf. A097223, A110069, A164322.
%K A140175 base,fini,nonn,more,changed
