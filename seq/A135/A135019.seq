%N A135019 a(n) = -a(n-1) + 2*a(n-2) - a(n-3), with a(0) = 0, a(1) = 1, a(2) = -3.
%C A135019 Sequence is identical to its signed second differences less first 3 terms. - _R. J. Mathar_, May 17 2009
%H A135019 G. C. Greubel, <a href="/A135019/b135019.txt">Table of n, a(n) for n = 0..1000</a>
%H A135019 <a href="/index/Rec#order_03">Index entries for linear recurrences with constant coefficients</a>, signature (-1,2,-1).
%F A135019 From _R. J. Mathar_, May 17 2009: (Start)
%F A135019 a(n)*(-1)^(n+1) = A002478(n-1) + 2*A002478(n-2).
%F A135019 G.f.: x*(1 - 2*x)/(1 + x - 2*x^2 + x^3). (End)
%t A135019 LinearRecurrence[{-1, 2, -1}, {0, 1, -3}, 35] (* _Paolo Xausa_, Jun 03 2026 *)
%o A135019 (PARI) a(n)=([0,1,0; 0,0,1; -1,2,-1]^n*[0;1;-3])[1,1] \\ _Charles R Greathouse IV_, Jun 03 2026
