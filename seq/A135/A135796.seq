%T A135796 2080,2952,2968,3240,3280,4040,4352,4872,4992,5000,5368,6120,6960,
%U A135796 7008,7280,7320,8320,8840,9720,10240,10360,10368,11000,11032,13080,13560,13968,14208
%N A135796 Numbers of the form 4*x*y*(x^2+y^2) (where x,y are positive integers).
%C A135796 Squares of these numbers are of the form N^4-M^2 (where N belongs to A135786 and M to A135797) Proof uses: (4x^3y+4xy^3)^2=(x^2-y^2)^4+(x^4+6x^2y^2+y^4)^2.
%C A135796 Refers to A057102, which had an incorrect description and has been replaced by A256418. As a result the present sequence should be re-checked. - _N. J. A. Sloane_, Apr 06 2015
%C A135796 From _Žiga Pirc_, Jun 27 2026: (Start)
%C A135796 Alternatively, 2xy, where x+y and |x-y| are perfect squares.
%C A135796 A number can be written in the form (x^4-y^4)/2, where n and p are nonnegative integers congruent modulo 2 with y < x if and only if it's in this sequence. (End)
%H A135796 Žiga Pirc, <a href="/A135796/b135796.txt">Table of n, a(n) for n = 1..10000</a>
%t A135796 a = {}; Do[Do[w = 4x^3y + 4x y^3; If[w < 10000, AppendTo[a, w]], {x, y, 1000}], {y, 1, 1000}]; Union[a]
%Y A135796 Cf. A000404, A050803, A057102, A135784, A060803, A135786, A135787, A135789, A135790, A135791, A135792, A135793, A135795, A135796, A135797.
%K A135796 nonn
%O A135796 1,1
