%S A376690 1,2,2,2,4,4,2,6,6,2,4,12,6,6,4,8,18,6,12,12,8,16,6,12,18,12,18,6,24,
%T A376690 16,14,18,12,24,36,24,36,12,18,30,6,26,28,36,24,30,18,72,30,18,42,30,
%U A376690 24,36,60,12,52,26,30,72,48,60,36,54,90,18,12,30,36,84,60
%N A376690 First differences of A055932.
%C A376690 First difference of numbers k with a primorial kernel, i.e., rad(k) = P(i), where rad = A007947 and primorial P = A002110.
%H A376690 Michael De Vlieger, <a href="/A376690/b376690.txt">Table of n, a(n) for n = 1..10000</a>
%H A376690 Michael De Vlieger, <a href="/A376690/a376690.png">Log log scatterplot of a(n)</a>, n = 1..74468.
%H A376690 Michael De Vlieger, <a href="/A376690/a376690.txt">Efficient Mathematica constructor program for A055932</a>
%t A376690 (* Load function f in the linked constructor a-file *)
%t A376690 Differences@ Union@ Flatten@ f[8]
%o A376690 (Python)
%o A376690 from functools import lru_cache
%o A376690 from itertools import count
%o A376690 from sympy import prime, integer_log, primorial
%o A376690 from oeis_sequences.OEISsequences import bisection
%o A376690 def A376690(n):
%o A376690     @lru_cache(maxsize=None)
%o A376690     def g(x, m): return sum(g(x//(prime(m)**i), m-1) for i in range(1,integer_log(x, prime(m))[0]+1)) if m-1 else x.bit_length()-1
%o A376690     def f(x):
%o A376690         c = n-1+x
%o A376690         for k in count(1):
%o A376690             if primorial(k)>x:
%o A376690                 break
%o A376690             c -= g(x,k)
%o A376690         return c
%o A376690     return -(m:=bisection(f,n,n))+bisection(lambda x:f(x)+1,m,m) # _Chai Wah Wu_, Mar 18 2026
%Y A376690 Cf. A002110, A007947, A055932, A178799.
%K A376690 nonn,easy,changed
%O A376690 1,2
