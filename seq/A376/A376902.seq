%I A376902 #31 Apr 14 2026 01:00:14
%S A376902 21,187,5810,17883,3188109,37880357,831883422714
%N A376902 Numbers k such that the concatenation of their prime factors with multiplicity, in some order, yields the k-th prime number.
%C A376902 This sequence allows the concatenation to be any permutation of the prime factors provided the digits of each prime factor are retained in their natural order.
%C A376902 So far, only k=187 factors concatenate in ascending order.
%C A376902 Next term, if it exists, is a(8) > 8.32 * 10^11.
%e A376902 21 = 3*7 is a term since prime(21) = 73.
%e A376902 187 = 11*17 is a term since prime(187) = 1117.
%e A376902 5810 = 2*5*7*83 is a term since prime(5810) = 57283.
%e A376902 17883 = 3*3*1987 is a term since prime(17883) = 198733.
%e A376902 3188109 = 3*53*20051 is a term since prime(3188109) = 53320051.
%e A376902 37880357 = 19*31*73*881 is a term since prime(37880357) = 733188119.
%e A376902 831883422714 = 2*3*29*47947*99713 is a term since prime(831883422714) = 24794732999713.
%e A376902 In prime(1075454 = 2*17*47*673) = 16737247 we can remove the factors in decreasing order as substrings to get the empty string, but '673' occurs "within" the '17', so this is not a valid solution. - _M. F. Hasler_, Apr 10 2026
%o A376902 (Python)
%o A376902 from sympy import factorint, prime
%o A376902 def is_A376902(k):
%o A376902     s = str(prime(k)); f = factorint(k)
%o A376902     for p,e in reversed(f.items()):
%o A376902         if (c := s.count(str(p))) < e: return False
%o A376902         if c==e: s = s.replace(str(p),' '); f[p]=0
%o A376902     assert not any(f.values()) # to my surprise, always true!?
%o A376902     return not s.strip()
%o A376902 def A376902_gen(): # takes ~25 sec on my laptop for a(5)
%o A376902     for k in range(1,1<<53):
%o A376902         if is_A376902(k): yield k # _M. F. Hasler_, Apr 10 2026
