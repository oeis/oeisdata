%S A188426 1,3,8,17,31,50,77,112,157,211,276,355,448,554,676,815,973,1149,1344,
%T A188426 1561,1801,2064,2351,2663,3003,3371,3766,4190,4647,5135,5657,6212,
%U A188426 6802,7430,8094,8797,9539,10322,11147,12014,12925,13881,14883,15933,17031,18178,19375,20624,21925,23281,24690
%N A188426 Position of 3^n in A051037 (5-smooth numbers).
%H A188426 Zak Seidov, <a href="/A188426/b188426.txt">Table of n, a(n) for n = 0..150</a>
%F A188426 A051037(a(n)) = 3^n.
%F A188426 a(n) ~ c * n^3, where c = log(3)^2/(6*log(2)*log(5)) = 0.180317536836709... - _Vaclav Kotesovec_ and _Amiram Eldar_, Sep 22 2024
%o A188426 (Python)
%o A188426 def A188426(n):
%o A188426     c, m = 0, 3**n
%o A188426     i, i5 = 0, 1
%o A188426     while i5<=m:
%o A188426         j, j3 = 0, 1
%o A188426         y = m//i5
%o A188426         z = y
%o A188426         while j3 <= y:
%o A188426             c += z.bit_length()
%o A188426             j += 1
%o A188426             j3 *= 3
%o A188426             z //= 3
%o A188426         i += 1
%o A188426         i5 *= 5
%o A188426     return c # _Chai Wah Wu_, Mar 12 2026
%Y A188426 Cf. A051037, A188425, A188427 (powers of 2 and 5).
%K A188426 nonn,changed
%O A188426 0,2
