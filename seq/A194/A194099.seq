%I A194099 #74 Apr 06 2026 22:47:17
%S A194099 3,5,7,11,17,19,29,31,41,49,71,161,251,449,769,881,1079,1429,3431,
%T A194099 4159,4801,6049,8749,19601,24751,246401,388961,1267111
%N A194099 Numbers m >= 2, such that, if a prime p divides m^2 - 1, then every prime q < p divides m^2 - 1 as well.
%C A194099 No more terms <= 10^8.
%C A194099 No more terms <= 2 * 10^38. - _Charles R Greathouse IV_, Aug 22 2011
%C A194099 All terms are odd. - _Kausthub Gudipati_, Aug 22 2011
%H A194099 Florian Luca and Filip Najman, <a href="https://web.math.pmf.unizg.hr/~fnajman/FLFNMC.pdf">On the largest prime factor of x^2 - 1</a>, Math. Comp. 80 (2011), 429-435.
%F A194099 A055932 INTERSECT A005563. - _R. J. Mathar_, Aug 16 2011
%F A194099 a(n) = 2 * A141399(n) + 1. - _Thomas Ordowski_, Mar 29 2026
%e A194099 881^2-1 = 776160 = 2^5 * 3^2 * 5 * 7^2 * 11 (all primes <= 11 appear), so 881 is a term.
%t A194099 Select[Range[1, 10^4], First@ # == 1 && If[Length@ # > 1, Union@ Differences@ # == {1}, True] &@ PrimePi@ Map[First, FactorInteger[#^2 - 1]] &] (* _Michael De Vlieger_, Jul 02 2016 *)
%o A194099 (PARI) isok(n) = my(f = factor(n^2-1)); #f~ == primepi(f[#f~,1]); \\ _Michel Marcus_, Jul 02 2016
%o A194099 (Python)
%o A194099 from sympy import prime, primefactors
%o A194099 def is_ok(m):
%o A194099     pf = primefactors(m*m - 1)
%o A194099     return prime(len(pf)) == pf[-1]
%o A194099 print([ m for m in range(3, 1270000, 2) if is_ok(m)])
%o A194099 # _Ken Clements_, Jan 01 2026
%o A194099 (Python)
%o A194099 from itertools import islice
%o A194099 from heapq import heappop, heappush
%o A194099 from sympy import integer_nthroot, nextprime
%o A194099 def A194099_gen(): # generator of terms
%o A194099     h, hset = [(1,(1,))], {1}
%o A194099     while True:
%o A194099         m, ps = heappop(h)
%o A194099         a, b = integer_nthroot(m+1,2)
%o A194099         if b:
%o A194099             yield a
%o A194099         for p in ps:
%o A194099             mp = m*p
%o A194099             if mp not in hset:
%o A194099                 heappush(h,(mp,ps))
%o A194099                 hset.add(mp)
%o A194099         q = nextprime(max(ps,default=1))
%o A194099         mp = m*q
%o A194099         if mp not in hset:
%o A194099             heappush(h,(mp,(ps+(q,))))
%o A194099             hset.add(mp)
%o A194099 A194099_list = list(islice(A194099_gen(),28)) # _Chai Wah Wu_, Apr 04 2026
%Y A194099 Cf. A005563, A055932, A141399, A391602.
%K A194099 nonn,more,changed
%O A194099 1,1
