%N A241235 a(n) = number of times n appears in A006949.
%C A241235 Is this (with an exception at n=1) the same as A135560? - _R. J. Mathar_, Apr 26 2014
%C A241235 The Bodini-Genitrini-Nurligareev paper shows this sequence to be A135560 beginning with a(1) = 3 instead of A135560(1) = 2. - _Michael De Vlieger_, Mar 28 2026
%H A241235 Reinhard Zumkeller, <a href="/A241235/b241235.txt">Table of n, a(n) for n = 1..10000</a>
%H A241235 Olivier Bodini, Antoine Genitrini, and Khaydar Nurligareev, <a href="https://www.researchgate.net/profile/Antoine-Genitrini/publication/403039039">Growing binary trees</a>, ResearchGate (2026). See pp. 5 (Prop. 3.2), 11 (Appendix A).
%t A241235 MapAt[# + 1 &, Table[t = IntegerExponent[n, 2]; t + Boole[n == 2^t] + 1, {n, 120}], 1] (* _Michael De Vlieger_, Mar 28 2026 *)
%o A241235 (Haskell)
%o A241235 a241235 n = a241235_list !! (n-1)
%o A241235 a241235_list = map length $ group a006949_list
%Y A241235 Cf. A051135, A135560.
%K A241235 nonn,changed
%O A241235 1,1
