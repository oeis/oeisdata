%I A160774 #9 May 21 2026 06:50:01
%S A160774 23,27,28,33,37,38,44,45,49,54,55,59,64,65,69,83,87,88,93,97,98,
%T A160774 120015,120016,120070,121004,121005,121009,122004,122005,122009,
%U A160774 124001,124002,124006,124010,125001,125002,125006,125010,126004,126005,126009,129001,129002,129006,129010
%N A160774 Numbers that have a "y" in the middle of their names in American English.
%H A160774 Michael S. Branicky, <a href="/A160774/b160774.txt">Table of n, a(n) for n = 1..10000</a>
%e A160774 In the spelling of the name of each term, with spaces and hyphens omitted, each name has an odd number of letters, and the middle letter is "y"; e.g.,
%e A160774   23 = twentYthree,
%e A160774   27 = twentYseven,
%e A160774   28 = twentYeight,
%e A160774   etc.
%o A160774 (Python)
%o A160774 from num2words import num2words
%o A160774 def n2w(n): return "".join(c for c in num2words(n).replace(" and", "") if c.isalpha())
%o A160774 def ok(n): return len(w:=n2w(n))&1 and w[len(w)>>1] == "y"
%o A160774 print([k for k in range(13*10**4) if ok(k)]) # _Michael S. Branicky_, May 20 2026
%Y A160774 Cf. A160658, A160659, A160660, A160661, A160662.
%K A160774 nonn,word,changed
%O A160774 1,1
%A A160774 _Claudio Meller_, May 26 2009
%E A160774 Name clarified and a(22) onward from _Michael S. Branicky_, May 20 2026
