%N A160949 a(n) = n - digital sum(n+1).
%H A160949 Paolo Xausa, <a href="/A160949/b160949.txt">Table of n, a(n) for n = 1..10000</a>
%F A160949 a(n) = n - A007953(n+1). - _R. J. Mathar_, Mar 04 2026
%e A160949 a(8) = 8 - ds(9) = 8 - 9 = -1.
%e A160949 a(15) = 15 - ds(16) = 15 - (1 + 6) = 15 - 7 = 8.
%e A160949 a(26) = 26 - ds(27) = 26 - (2 + 7) = 26 - 9 = 17.
%t A160949 Table[n-Total[IntegerDigits[n+1]],{n,80}] (* _Harvey P. Dale_, May 19 2018 *)
