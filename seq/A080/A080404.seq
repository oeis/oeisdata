%S A080404 2,2,6,2,6,2,6,6,30,2,6,6,6,30,2,6,30,6,6,30,2,6,30,6,30,6,210,6,30,2,
%T A080404 30,6,30,6,30,6,210,6,30,30,6,2,30,6,30,210,6,30,30,6,30,210,6,30,30,
%U A080404 6,2,210,30,6,30,210,6,30,30,6,210,30,6,30,210,6,30,210,30,6,2,210,30,30,6
%N A080404 a(n)=A007947[A055932(n)]; the sequence consists of primorial numbers;.
%H A080404 Michael De Vlieger, <a href="/A080404/b080404.txt">Table of n, a(n) for n = 1..10000</a>
%t A080404 With[{P = FoldList[Times, Prime@ Range@ Max@ #]}, Map[P[[#]] &, #]] &@ Map[PrimeNu@ # &, Select[Range[10^4], Last[#] == Length[#] &@ PrimePi@ FactorInteger[#][[All, 1]] &]] (* _Michael De Vlieger_, Feb 06 2020 *)
%o A080404 (Python)
%o A080404 from math import prod
%o A080404 from itertools import count
%o A080404 from functools import lru_cache
%o A080404 from sympy import prime, integer_log, primorial, primefactors
%o A080404 from oeis_sequences.OEISsequences import bisection
%o A080404 def A080404(n):
%o A080404     @lru_cache(maxsize=None)
%o A080404     def g(x, m): return sum(g(x//(prime(m)**i), m-1) for i in range(1,integer_log(x, prime(m))[0]+1)) if m-1 else x.bit_length()-1
%o A080404     def f(x):
%o A080404         c = n+x
%o A080404         for k in count(1):
%o A080404             if primorial(k)>x:
%o A080404                 break
%o A080404             c -= g(x,k)
%o A080404         return c
%o A080404     return prod(primefactors(bisection(f,n+1,n+1))) # _Chai Wah Wu_, Mar 18 2026
%Y A080404 Cf. A007947, A002110, A055932.
%K A080404 nonn
%O A080404 1,1
%A A080404 _Labos Elemer_, Mar 19 2003
