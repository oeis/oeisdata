%T A098718 16495,24756,36766,54084,78858,114018,163558,232965,329478,462996,
%U A098718 646551,897699,1239395,1702142,2325845,3162865,4281304,5769761,7742941,10348857,13778106,18275141
%N A098718 Position of n! in A025487.
%H A098718 Chai Wah Wu, <a href="/A098718/b098718.txt">Table of n, a(n) for n = 1..83</a>
%F A098718 A025487(a(n)) = n!. - _Amiram Eldar_, Jun 20 2019
%e A098718 A025487(34) = 720 = 6! so a(6) = 34. - _David A. Corneth_, Sep 19 2019
%o A098718 (Python)
%o A098718 from itertools import count
%o A098718 from functools import lru_cache
%o A098718 from math import factorial
%o A098718 from sympy import prime, integer_log, primorial
%o A098718 def A098718(n):
%o A098718     @lru_cache(maxsize=None)
%o A098718     def g(x, m, j): return sum(g(x//(prime(m)**i), m-1, i) for i in range(j,integer_log(x, prime(m))[0]+1)) if m-1 else max(0,x.bit_length()-j)
%o A098718     c, f = 1, factorial(n)
%o A098718     for k in count(1):
%o A098718         if primorial(k)>f:
%o A098718             break
%o A098718         c += g(f,k,1)
%o A098718     return c # _Chai Wah Wu_, Mar 23 2026
%Y A098718 Cf. A000142, A025487, A098719.
%K A098718 nonn
