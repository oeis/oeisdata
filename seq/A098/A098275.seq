%N A098275 Coefficients in a simultaneous approximation to Li(2,-1) and Li(3,-1).
%C A098275 Conjecture: a(n) is divisible by n+1. - _F. Chapoton_, Jan 28 2026
%C A098275 Conjecture: The g.f. has a fourth root with integer coefficients 1, 2, 60, 2892... - _F. Chapoton_, Apr 23 2026
%H A098275 Vaclav Kotesovec, <a href="/A098275/b098275.txt">Table of n, a(n) for n = 0..200</a>
%H A098275 Wadim Zudilin, <a href="https://arxiv.org/abs/math/0409023">Approximations to -, di and trilogarithms</a>, arXiv:math/0409023 [math.CA], 2004-2005.
%F A098275 a(n) = Sum_{i=0..n} Sum_{j=0..n} C(n, i)^2*C(n, j)^2*C(n+i, n)*C(i+j, i).
%F A098275 From _Vaclav Kotesovec_, Apr 24 2026: (Start)
%F A098275 a(n) ~ sqrt(29/48 + sqrt(25669/31)*cosh(arccosh(1477873*sqrt(31/25669)/51338)/3)/24) * (34 + 2*sqrt(3401/3)*cosh(arccosh(229071*sqrt(3/3401)/6802)/3))^n / (Pi^2 * n^2).
%F A098275 Recurrence: n^4*(1457*n^2 - 4277*n + 3168)*a(n) = (148614*n^6 - 733482*n^5 + 1428905*n^4 - 1414974*n^3 + 765991*n^2 - 218022*n + 25752)*a(n-1) - (97619*n^6 - 677035*n^5 + 1911447*n^4 - 2792475*n^3 + 2209368*n^2 - 893316*n + 146160)*a(n-2) + 3*(n-2)^2*(3*n - 7)*(3*n - 5)*(1457*n^2 - 1363*n + 348)*a(n-3). (End)
%t A098275 Table[Sum[Binomial[n, i]^2 * Binomial[n, j]^2 * Binomial[n+i, n] * Binomial[i+j, i], {i,0,n}, {j,0,n}], {n,0,20}] (* _Vaclav Kotesovec_, Apr 24 2026 *)
%o A098275 (PARI) a(n) = sum(i=0,n,sum(j=0,n,binomial(n,i)^2*binomial(n,j)^2*binomial(n+i,n)*binomial(i+j,i)))
