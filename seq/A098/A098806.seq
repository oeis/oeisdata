%I A098806 #12 Mar 17 2026 09:57:44
%S A098806 5,7,11,11,13,17,17,23,23,29,31,37,37,43,41,43,47,53,53,59,67,67,71,
%T A098806 71,79,89,83,89,101,97,101,101,109,107,131,113,127,131,127,131,137,
%U A098806 137,179,149,157,157,193,191,167,179,179,181,193,193,191,193,197,211,227,211
%N A098806 Smallest prime p such that p - A098807(n) and p + A098807(n) are both prime.
%C A098806 a(n) is the smallest prime p such that p - k and p + k are both prime, where k is the n-th number for which such a p exists. - _Robert Israel_, Mar 16 2026
%H A098806 Robert Israel, <a href="/A098806/b098806.txt">Table of n, a(n) for n = 1..10000</a>
%e A098806 a(4) = 11 because A098807(4) = 8, and 11, 11 - 8 = 3 and 11 + 8 = 19 are all prime. - _Robert Israel_, Mar 16 2026
%p A098806 g:= proc(n) local p;
%p A098806     if n mod 3 <> 0 then
%p A098806        if isprime(2*n+3) and isprime(4*n+3) then return 2*n+3 else return NULL fi
%p A098806     fi;
%p A098806     p:= prevprime(2*n);
%p A098806     do
%p A098806       p:= nextprime(p);
%p A098806       if isprime(p-2*n) and isprime(2*n+p) then return p fi;
%p A098806     od;
%p A098806 end proc:
%p A098806 map(g, [$1..100]);
%o A098806 (PARI) upto(n) = for(p=1,n, for(x=1,n, y=x-p; z=x+p; if(isprime(y) & isprime(z) & isprime(x), print1(x","); break)));
%o A098806 upto(211)
%Y A098806 Cf. A098807.
%K A098806 easy,nonn,changed
%O A098806 1,1
