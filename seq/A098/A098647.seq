%I A098647 #16 Jun 25 2026 09:16:41
%S A098647 1,12,224,4608,96256,2015232,42205184,883949568,18513657856,
%T A098647 387755016192,8121246285824,170093589823488,3562486393470976,
%U A098647 74613683694600192,1562729279488262144,32730226951263879168,685510772943084322816,14357524025753135480832,300707887149717854879744
%N A098647 Trace sequence associated to the 4 X 4 Krawtchouk matrix and its transpose.
%C A098647 Let A=[1,1,1,1;3,1,-1,-3;3,-1,-1,3;1,-1,1,-1], the 4 X 4 Krawtchouk matrix. Then a(n)=trace((A*A')^n)/4.
%C A098647 Twelfth binomial transform of ((4*sqrt(5))^n +(-4*sqrt(5))^n)/2, with g.f. 1/(1-80*x^2).
%H A098647 Vincenzo Librandi, <a href="/A098647/b098647.txt">Table of n, a(n) for n = 0..300</a>
%H A098647 Wikipedia, <a href="https://en.wikipedia.org/wiki/Krawtchouk_matrices">Krawtchouk matrices</a>.
%H A098647 <a href="/index/Rec#order_02">Index entries for linear recurrences with constant coefficients</a>, signature (24,-64).
%F A098647 G.f.: (1 - 12*x)/(1 - 24*x + 64*x^2).
%F A098647 a(n) = ((12+4*sqrt(5))^n+(12-4*sqrt(5))^n)/2.
%F A098647 a(n) = 2^(n-1)*((sqrt(5)-1)^(2*n)+(sqrt(5)+1)^(2*n)).
%F A098647 a(n) = 4^n*A098648(n). - _R. J. Mathar_, Nov 11 2013
%F A098647 E.g.f.: exp(12*x)*cosh(4*sqrt(5)*x). - _Stefano Spezia_, Jun 25 2026
%Y A098647 Cf. A098646, A098648.
%K A098647 easy,nonn
%O A098647 0,2
%A A098647 _Paul Barry_, Sep 18 2004
