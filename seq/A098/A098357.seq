%U A098357 2,1,2,1,1,1,2,2,3,2,2,2,2,1,1,1,2,2,2,2,2,2,2,3,3,3,3,3,3,3,3,2,2,2,2,3,3
%N A098357 a(n) = A061017(n) - pi(n+1).
%C A098357 a(n) >= 0 for all n >= 1.
%C A098357 The old entry with this sequence number was a duplicate of A058071.
%o A098357 (Python)
%o A098357 from math import isqrt
%o A098357 from sympy import primepi
%o A098357 from oeis_sequences.OEISsequences import bisection, bsearch
%o A098357 def A098357(n):
%o A098357     def g(x): return x-(s:=isqrt(x))**2+(sum(x//k for k in range(1,s+1))<<1)
%o A098357     def f(x): return n+bsearch(g,x)
%o A098357     return bisection(f,n,n)-n-primepi(n+1)+1 # _Chai Wah Wu_, Mar 01 2026
%Y A098357 A companion to A052511. Cf. A061017, A006218, A088526.
%K A098357 nonn
%O A098357 1,38
