%I A098210 #19 Jul 09 2026 11:14:06
%S A098210 0,15,1155,111555,11115555,1111155555,111111555555,11111115555555,
%T A098210 1111111155555555,111111111555555555,11111111115555555555,
%U A098210 1111111111155555555555,111111111111555555555555,11111111111115555555555555,1111111111111155555555555555,111111111111111555555555555555
%N A098210 a(n) = -1 + A093137(n)^2.
%H A098210 Vincenzo Librandi, <a href="/A098210/b098210.txt">Table of n, a(n) for n = 0..100</a>
%H A098210 <a href="/index/Rec#order_03">Index entries for linear recurrences with constant coefficients</a>, signature (111,-1110,1000).
%F A098210 a(n) = (1/9)*(10^n - 1)*(5 + 10^n). - _Vincenzo Librandi_, Jun 02 2013
%F A098210 From _Elmo R. Oliveira_, Jul 09 2026: (Start)
%F A098210 a(n) = 15*A099638(n).
%F A098210 a(n) = 111*a(n-1) - 1110*a(n-2) + 1000*a(n-3).
%F A098210 G.f.: 15*x*(1 - 34*x)/((1 - x)*(1 - 10*x)*(1 - 100*x)).
%F A098210 E.g.f.: exp(x)*(-5 + 4*exp(9*x) + exp(99*x))/9. (End)
%e A098210 Like other -1 + square of near-repdigits give special digit patterns: a(8) = (33333334)^2 - 1 = 1111111155555555.
%t A098210 Table[(1/9) (10^n - 1) (5 + 10^n), {n, 0, 25}] (* _Vincenzo Librandi_, Jun 02 2013 *)
%o A098210 (Magma) [(1/9)*(10^n-1)*(5+10^n): n in [0..15]]; // _Vincenzo Librandi_, Jun 02 2013
%Y A098210 Cf. A093137, A099638.
