%I A185242 #33 Apr 27 2026 01:23:40
%S A185242 3,165,145,385,455,85,78,66,58,154,182,34,2,15,825,725,1925,2275,425,
%T A185242 390,330,290,770,910,170,156,132,116,308,364,68,4,30,225,12375,10875,
%U A185242 28875,25375,67375,79625,14875,13650,2550,2340,1980,1740,4620,4060,10780,12740,2380,2184,408,152,92,380,230
%N A185242 Successive integers produced by Conway's PRIMEGAME, starting with 3 rather than 2.
%C A185242 2 is nevertheless reached fairly soon (at the 12th iteration), and after that the sequence proceeds exactly the same as A007542.
%H A185242 The OEIS Wiki, <a href="https://oeis.org/wiki/Conway&#39;s_PRIMEGAME">Conway's PRIMEGAME</a>
%F A185242 a(n+12) = A007542(n) for n >= 0. - _Charles R Greathouse IV_, Jan 24 2012
%F A185242 a(n+1) = A203907(a(n)), a(0) = 3. - _Reinhard Zumkeller_, Jan 25 2012
%e A185242 After 3, we have 3 * 55 = 165 because none of the other fractions give an integer. Then we can use 29/33, and thus 165 * 29/33 = 145, and so on and so forth.
%t A185242 (* First run the program for A203907 to define conwayProc *) NestList[conwayProc, 3, 50]
%o A185242 (Haskell)
%o A185242 a185242 n = a185242_list !! (n-1)
%o A185242 a185242_list = iterate a203907 3
%o A185242 -- _Reinhard Zumkeller_, Jan 25 2012
%o A185242 (Python) A185242_first = lambda N: [(N:=A203907(N) if i else 3) for i in range(N)] # _M. F. Hasler_, Apr 26 2026
%Y A185242 Cf. A007542 (trajectory of 2), A203907 (PRIMEGAME successor function), A273091 (trajectory of 6), A273099 (trajectory of 12).
%K A185242 nonn,changed
%O A185242 0,1
%A A185242 _Alonso del Arte_, Jan 24 2012
%E A185242 More terms from _M. F. Hasler_, Apr 26 2026
