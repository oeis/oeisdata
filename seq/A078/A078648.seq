%I A078648 #16 Jul 10 2026 10:24:21
%S A078648 5,18,24,36,48,60,78,84,90,114,144,120,168,180,234,246,288,240,210,
%T A078648 324,300,360,474,330,528,576,390,462,480,420,570,510,672,792,756,876,
%U A078648 714,798,690,1038,630,1008,930,780,960,870,924,900,1134,1434,840,990,1302
%N A078648 Smallest integer that can be written in exactly n ways as the sum of two primes that are not congruent modulo 3.
%H A078648 Robert Israel, <a href="/A078648/b078648.txt">Table of n, a(n) for n = 1..5000</a> (first 321 terms from R. J. Mathar)
%F A078648 a(n) >= A023036(n). - _R. J. Mathar_, Jul 10 2026
%e A078648 18 is the first integer that can be written in exactly two ways as the sum of two incongruent primes modulo 3: 18 = 5 + 13 = 7 + 11 (order of addition is ignored, 5 <> 13 mod 3 and 7 <> 11 mod 3). Hence a(2) = 18.
%p A078648 A078684 := proc(n)
%p A078648     local a,p,q,N,i ;
%p A078648     for a from 5 do
%p A078648         N := 0 ;
%p A078648         for i from 1 do
%p A078648             p := ithprime(i) ;
%p A078648             q := a-p ;
%p A078648             if q < p then
%p A078648                 break ;
%p A078648             end if;
%p A078648             if isprime(q) and modp(p,3) <> modp(q,3) then
%p A078648                 N := N+1 ;
%p A078648             end if;
%p A078648         end do:
%p A078648         if N = n then
%p A078648             return a ;
%p A078648         end if;
%p A078648     end do:
%p A078648 end proc:
%p A078648 seq(A078684(n),n=1..60) ; # _R. J. Mathar_, Jul 10 2026
%p A078648 # Alternative:
%p A078648 N:= 2000: # for terms before the first term > N
%p A078648 V:= Vector(N):
%p A078648 P1:= select(isprime,[seq(i,i=1..N,6)]):
%p A078648 P2:= select(isprime,[2,seq(i,i=5..N,6)]):
%p A078648 for p in P1 while p+3 <= N do V[p+3]:= V[p+3]+1 od:
%p A078648 for p in P2 while p+3 <= N do V[p+3]:= V[p+3]+1 od:
%p A078648 for p in P1 do
%p A078648   for q in P2 while p + q <= N do V[p+q]:= V[p+q]+1 od
%p A078648 od:
%p A078648 mV:= max(V):
%p A078648 R:= Vector(mV): count:= 0:
%p A078648 for i from 1 to N while count < mV do
%p A078648   if V[i] > 0 and R[V[i]] = 0 then R[V[i]]:= i; count:= count+1 fi
%p A078648 od:
%p A078648 if not member(0,R,'m') then m:= mV+1 fi;
%p A078648 convert(R[1..m-1],list); # _Robert Israel_, Jul 10 2026
%t A078648 f[n_] := Module[{a, d, i}, a = {}; u = Floor[n/2]; For[i = 1, i <= u, i++, If[PrimeQ[i] && PrimeQ[n - i] && Mod[i, 3] != Mod[n - i, 3], a = Append[a, {n, i, n - i}]]]; a]; a = Table[0, {55}]; Do[l = Length[ f[n]]; If[l < 56 && a[[l]] == 0, a[[l]] = n], {n, 1, 2500}]; a
%Y A078648 Cf. A074169. Large overlap with A055065.
