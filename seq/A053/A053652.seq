%I A053652 #13 Jun 12 2026 15:29:53
%S A053652 53,233,347,431,743,1237,1249,1327,1367,1429,1471,1571,1583,1637,1723,
%T A053652 1741,2137,2371,2713,2731,3167,3217,3271,3581,3617,3671,3761,3851,
%U A053652 3863,3877,4129,4219,5171,5381,5399,5477,5657,5711,5813,5939,6173,6317,6577,6833,7151
%N A053652 Primes for which some rearrangement of the digits (leading zeros not allowed) is the product of two consecutive primes.
%C A053652 Primes from A053736 sorted in numerical order.
%D A053652 C. A. Pickover, "Vampire numbers," chapter 30 of Keys to Infinity. NY: Wiley, 1995. Pages 227-231
%H A053652 Michael S. Branicky, <a href="/A053652/b053652.txt">Table of n, a(n) for n = 1..10000</a>
%e A053652 a(3)=347, a(5)=743. These terms are derived from 19*23=437. By arranging digits of 437, two primes are formed: 347 and 743.
%o A053652 (Python)
%o A053652 from itertools import islice
%o A053652 from sympy import isprime, nextprime
%o A053652 from sympy.utilities.iterables import multiset_permutations
%o A053652 def agen(): # generator of terms
%o A053652     p, q, terms, digits = 2, 3, set(), 1
%o A053652     while True:
%o A053652         s = sorted(str(p*q))
%o A053652         if len(s) > digits:
%o A053652             yield from sorted(terms)
%o A053652             terms, digits = set(), len(s)
%o A053652         for w in multiset_permutations(s):
%o A053652             if w[0] != '0' and isprime(t:=int("".join(w))):
%o A053652                 terms.add(t)
%o A053652         p, q = q, nextprime(q)
%o A053652 print(list(islice(agen(), 45))) # _Michael S. Branicky_, Jun 12 2026
%Y A053652 Cf. A053736, A053653, A014575.
