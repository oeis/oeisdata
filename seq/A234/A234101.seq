%I A234101 #9 May 28 2026 00:45:08
%S A234101 97,127,199,227,241,277,307,313,331,379,397,457,467,547,617,619,647,
%T A234101 709,727,739,757,773,797,829,883,977,1033,1069,1117,1123,1171,1193,
%U A234101 1277,1297,1303,1319,1423,1447,1459,1483,1609,1621,1667,1697,1699,1747,1753
%N A234101 Primes of the form (p*q*r - 1)/2, where p, q, r are distinct primes.
%H A234101 Chris R. Rehmann, <a href="/A234101/b234101.txt">Table of n, a(n) for n = 1..10000</a>
%e A234101 (See A234100.)
%t A234101 t = Select[Range[1, 10000, 2], Map[Last, FactorInteger[#]] == Table[1, {3}] &]; Take[(t - 1)/2, 120] (* A234099 *)
%t A234101 v = Flatten[Position[PrimeQ[(t - 1)/2], True]] ; w = Table[t[[v[[n]]]], {n, 1, Length[v]}]  (* A234100 *)
%t A234101 (w - 1)/2 (* A234101 *)    (* _Peter J. C. Moses_, Dec 23 2013 *)
%o A234101 (MATLAB)
%o A234101 a = []; N = 1753; p = primes(N);
%o A234101 for k = 1:length(p)
%o A234101     f = factor(2*p(k)+1); u = unique(f);
%o A234101     if isequal(f,u) && length(u)==3
%o A234101         a(end+1) = p(k);
%o A234101     end
%o A234101 end
%o A234101 disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, May 24 2026
%Y A234101 Cf. A234099, A234100, A234093, A234102.
%K A234101 nonn,easy,changed
%O A234101 1,1
%A A234101 _Clark Kimberling_, Dec 27 2013
