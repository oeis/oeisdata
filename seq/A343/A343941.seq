%t A343941 sats[y_]:=Sum[(-1)^(i-Length[y])*y[[i]],{i,Length[y]}];
%t A343941 Table[Length[Select[IntegerPartitions[n],UnsameQ@@#&&sats[#]==4&]],{n,0,30,2}]
%o A343941 (PARI) my(N=70, q='q+O('q^N)); concat([0, 0], Vec(sum(j=1, 4, (-1)^(j-1)*q^(j*(j-1)/2+2)/prod(k=1, 4-j, 1-q^k)))) \\ _Seiichi Manyama_, May 16 2026
