%I A075077 #12 Jun 01 2026 05:05:31
%S A075077 1,3,5,4,2,8,6,9,7,11,10,12,13,14,16,17,15,19,20,18,22,23,21,25,24,26,
%T A075077 28,27,29,31,32,30,34,35,33,37,38,36,40,41,39,43,42,44,46,45,47,48,50,
%U A075077 49,51,53,52,54,56,55,57,58,59,60,61,62,63,65,64,66,67,68,70,71,69,73
%N A075077 a(1) = 1 and then the smallest number not occurring earlier such that a(n) + a(n+1) gives a different composite number (not obtained earlier).
%C A075077 Conjecture: for n > 6, n - 2 <= a(n) <= n + 1. - _Robert Israel_, Jun 01 2026
%H A075077 Robert Israel, <a href="/A075077/b075077.txt">Table of n, a(n) for n = 1..10000</a>
%e A075077 19 (not 18) follows 15 though 15+18 = 33 is also composite but 33 is already obtained as 16 +17.
%p A075077 N:= 200: R:= 1: r:= 1: Cands:= [$2..N]: Comps:= remove(isprime,[$4..2*N]): nC:= nops(Cands):
%p A075077 do
%p A075077   found:= false;
%p A075077   for i from 1 to nC do
%p A075077     if r + Cands[i] > Comps[-1] then break fi;
%p A075077     v:= ListTools:-BinarySearch(Comps,r+Cands[i]);
%p A075077     if v > 0 then found:= true; break fi;
%p A075077   od;
%p A075077   if not found then break fi;
%p A075077   R:= R, Cands[i]; r:= Cands[i]; Cands:= subsop(i=NULL,Cands); nC:= nC-1;
%p A075077   Comps:= subsop(v=NULL, Comps);
%p A075077 od:
%p A075077 R; # _Robert Israel_, Jun 01 2026
%Y A075077 Cf. A075078.
%K A075077 nonn
%O A075077 1,2
%A A075077 _Amarnath Murthy_, Sep 09 2002
%E A075077 More terms from _Sascha Kurz_, Feb 01 2003
