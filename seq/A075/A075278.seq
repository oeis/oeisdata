%I A075278 #12 Apr 21 2026 15:21:14
%S A075278 6,9,15,21,39,69,93,111,129,309,381,393,453,489,501,687,723,771,879,
%T A075278 933,939,1011,1167,1299,1527,1563,1569,1839,1941,1983,2157,2217,2229,
%U A075278 2271,2391,2463,2661,2811,2859,2913,3039,3099,3189,3453,3459,3651,3849
%N A075278 Interprimes which are of the form s*prime, s=3.
%C A075278 Interprimes which are of the form s*prime are in A075277-A075296 (s = 2-21). Case s = 1 is impossible.
%H A075278 Robert Israel, <a href="/A075278/b075278.txt">Table of n, a(n) for n = 1..10000</a>
%e A075278 39 is an interprime and 39/3 = 13 is prime.
%p A075278 R:= NULL: count:= 0:
%p A075278 p:= 1:
%p A075278 while count < 50 do
%p A075278   p:= nextprime(p);
%p A075278   if nextprime(3*p) + prevprime(3*p) = 6*p then
%p A075278     R:= R,3*p; count:= count+1
%p A075278   fi
%p A075278 od:
%p A075278 R; # _Robert Israel_, Apr 21 2026
%t A075278 s=3; Select[Table[(Prime[n+1]+Prime[n])/2, {n, 2, 1000}], PrimeQ[ #/s]&]
%Y A075278 Cf. A075277-A075296.
%K A075278 easy,nonn,changed
%O A075278 1,1
%A A075278 _Zak Seidov_, Sep 12 2002
