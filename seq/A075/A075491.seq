%U A075491 3,3,7,4,11,8,11,-1,6,-3,8,7,6,7,10,7,14,-2,4,6,9,0,9,10,11,8,15,-3,6,5,8,9,10,3,14,11,12,-8,0,-5,2,-3,-2,3,6,-3,8,-6
%N A075491 Sum of digits of n minus number of divisors of n.
%H A075491 Amiram Eldar, <a href="/A075491/b075491.txt">Table of n, a(n) for n = 1..10000</a>
%F A075491 a(n) = A007953(n) - A000005(n).
%e A075491 a(n) < 0 for n = 10, 20, 30, ... (A075492).
%e A075491 a(n) = 0 for n in A057531 which includes primes like 2, 11, 101.
%e A075491 a(n) > 0 for n in A075493 which includes the majority of primes and others.
%t A075491 sud[x_] := Apply[Plus, IntegerDigits[x]]; Table[sud[w]-DivisorSigma[0, w], {w, 1, 128}]
%t A075491 a[n_] := Total[IntegerDigits[n]]-DivisorSigma[0,n]; Array[a,130] (* _Harvey P. Dale_, Aug 10 2011 *)
%o A075491 (PARI) a(n) = sumdigits(n) - numdiv(n); \\ _Amiram Eldar_, Mar 09 2026
%Y A075491 Cf. A000005, A007953, A057531, A075492, A075493.
%K A075491 base,easy,sign,changed
%O A075491 1,5
%A A075491 _Labos Elemer_, Sep 26 2002
