%N A075647 List of groups in A075643.
%e A075647 Triangle begins:
%e A075647   2;
%e A075647   1,8;
%e A075647   3,4,9;
%e A075647   5,6,12,32;
%e A075647   7,10,15,16,30;
%e A075647   11,14,18,20,25,24;
%e A075647   ...
%p A075647 mex2 := proc(s)
%p A075647     local n ;
%p A075647     for n from 1 do
%p A075647         if not member(n,s) then
%p A075647             return n;
%p A075647         end if;
%p A075647     end do:
%p A075647 end proc:
%p A075647 part := proc(n,hav,ex)
%p A075647     local L,f,a,hav2,Lsub ;
%p A075647     if nops(hav) = n then
%p A075647         if modp(add(a,a=hav),n+1)=0 and nops(convert(hav,set)) = n then
%p A075647             return(hav);
%p A075647         else
%p A075647             return([]) ;
%p A075647         end if;
%p A075647     end if;
%p A075647     f := 1+nops(hav) ;
%p A075647     for a from f by f do
%p A075647         if not member(a,ex) and not member(a,hav) then
%p A075647             hav2 := [op(hav),a] ;
%p A075647             Lsub := procname(n,hav2,ex) ;
%p A075647             if nops(Lsub) > 0 then
%p A075647                 return Lsub ;
%p A075647             end if;
%p A075647         end if;
%p A075647     end do:
%p A075647 end proc:
%p A075647 A075647row := proc(n)
%p A075647     option remember ;
%p A075647     local ex,r,at0 ;
%p A075647     if n = 1 then
%p A075647         [2] ;
%p A075647     else
%p A075647         ex := {} ;
%p A075647         for r from 1 to n-1 do
%p A075647             ex := ex union convert(procname(r),set) ;
%p A075647         end do:
%p A075647         at0 := mex2(ex) ;
%p A075647         return part(n,[at0],ex) ;
%p A075647     end if;
%p A075647 end proc:
%p A075647 for n from 1 to 12 do
%p A075647     A075647row(n) ;
%p A075647     print(%) ;
%p A075647 end do: # _R. J. Mathar_, Jul 17 2026
%o A075647 (PARI) used = vector(50000); A = vector(70); A[1] = 2; B = A; C = A; D = A; D[1] = 1; print(2); used[2] = 1; x = vector(70, i, i); for (n = 2, 70, s = 0; for (j = 1, n - 1, while (used[x[j]], x[j] += j); print1(x[j], " "); used[x[j]] = 1; s += x[j]; x[j] += j); while (used[x[n]], x[n] += n); i = x[n] + n*((s + x[n])%(n + 1)); while(used[i], i += n*(n + 1)); print(i); used[i] = 1; s += i; A[n] = x[1] - 1; B[n] = i; C[n] = s; D[n] = s/(n + 1)); \\ _David Wasserman_, Jan 22 2005
