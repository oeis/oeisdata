%S A355403 1,2,3,6,6,12,15,30,30,60,60,84,105,210,210,420,420,420,420,840,840,
%T A355403 1260,1260,2310,2310,4620,4620,5460,5460,9240,9240,13860,13860,16380,
%U A355403 16380,30030,30030,60060,60060,60060,60060,120120,120120,180180,180180,180180,180180
%N A355403 Maximal LCM of seven positive integers with sum n.
%H A355403 Robert Israel, <a href="/A355403/b355403.txt">Table of n, a(n) for n = 7..200</a>
%H A355403 <a href="/index/Lc#lcm">Index entries for sequences related to lcm's</a>
%p A355403 L:= proc(m,n) option remember; local k;
%p A355403   if m = n then return {1} fi;
%p A355403   if m = 1 then return {n} fi;
%p A355403   `union`(seq(map(t -> ilcm(t,k), procname(m-1, n-k)), k=1..n-m+1))
%p A355403 end proc:
%p A355403 seq(max(L(7,i)),i=7..60); # _Robert Israel_, Jul 17 2026
%Y A355403 Cf. A009641, A355368, A355402.
%Y A355403 Maximal LCM of k positive integers with sum n for k = 2..7: A129647 (k=2), A129648 (k=3), A129649 (k=4), A129650 (k=5), A355367 (k=6), this sequence (k=7).
