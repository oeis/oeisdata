%S A131553 1,2,2,6,8,120,12,5040,384,12960,640,39916800,1152,6227020800,80640,
%T A131553 5443200,10321920,355687428096000,290304,121645100408832000,38707200,
%U A131553 384758035200,6812467200,25852016738884976640000,139345920,699459327350784000000,3643696742400
%N A131553 a(n) = Product_{k=1..n, gcd(k,n)=1} (1+k).
%H A131553 Alois P. Heinz, <a href="/A131553/b131553.txt">Table of n, a(n) for n = 0..456</a>
%e A131553 The positive integers that are <= 9 and are coprime to 9 are 1,2,4,5,7,8.
%e A131553 So a(9) = (1+1)(1+2)(1+4)(1+5)(1+7)(1+8) = 2*3*5*6*8*9 = 12960.
%p A131553 a:=proc(n) local p,k: p:=1: for k to n do if gcd(k,n)=1 then p:=p*(1+k) else end if end do: p end proc: seq(a(n),n=0..22); # _Emeric Deutsch_, Sep 05 2007
%p A131553 # Alternative:
%p A131553 for n from 0 to 25 do pr:=1: for k to n do if gcd(k,n)=1 then pr:=pr*(1+k) else end if end do: a[n]:=pr end do: seq(a[n],n=0..25); # _Emeric Deutsch_, Aug 28 2007
%p A131553 # Alternative:
%p A131553 a:= n-> mul(`if`(igcd(k,n)=1, 1+k, 1), k=1..n):
%p A131553 seq(a(n), n=0..26);  # _Alois P. Heinz_, May 17 2026
%t A131553 Table[Times @@ (1 + Select[Range[n], GCD[ #, n] == 1 &]), {n, 1, 40}] (* _Stefan Steinerberger_, Sep 14 2007 *)
%o A131553 (PARI) rr(n) = pp=1;for(i=1,n,if(gcd(i,n)==1,pp=pp*(1+i)));return(pp); for(j=1,60,print1(rr(j),",")) \\ _Matthew Conroy_, Sep 05 2007
