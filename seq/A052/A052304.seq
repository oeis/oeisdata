%S A052304 1,1,2,1,2,2,3,2,1,3,4,3,2,4,4,3,2,4,6,4,4,1,4,3,5,6,4,4,2,6,3,5,8,6,
%T A052304 5,2,6,8,4,6,4,8,4,9,6,5,3,8,8,4,6,6,10,1,4,9,8,6,3,8,12,5,7,6,10,2,6,
%U A052304 12,8,8,6,8,9,4,10,12,4,5,9,7,8,12,2
%N A052304 Number of squares dividing A025487(n).
%C A052304 Number of 2-generated Abelian groups of order A025487(n), if n > 1. - _Álvar Ibeas_, Dec 22 2014
%H A052304 Álvar Ibeas, <a href="/A052304/b052304.txt">Table of n, a(n) for n = 1..10000</a>
%F A052304 a(n) = A046951(A025487(n)).
%o A052304 (Python)
%o A052304 from math import prod
%o A052304 from itertools import count
%o A052304 from functools import lru_cache
%o A052304 from sympy import prime, integer_log, factorint
%o A052304 from oeis_sequences.OEISsequences import bisection
%o A052304 def A052304(n):
%o A052304     @lru_cache(maxsize=None)
%o A052304     def g(x, m, j): return sum(g(x//(prime(m)**i), m-1, i) for i in range(j,integer_log(x, prime(m))[0]+1)) if m-1 else max(0,x.bit_length()-j)
%o A052304     def f(x):
%o A052304         c, p = n-1+x, 1
%o A052304         for k in count(1):
%o A052304             p *= prime(k)
%o A052304             if p>x:
%o A052304                 break
%o A052304             c -= g(x,k,1)
%o A052304         return c
%o A052304     return prod((e>>1)+1 for e in factorint(bisection(f,n,n)).values()) # _Chai Wah Wu_, Apr 08 2026
%Y A052304 Cf. A046951, A025487.
%K A052304 nonn,changed
%O A052304 1,3
%A A052304 _Christian G. Bower_, Nov 15 1999
