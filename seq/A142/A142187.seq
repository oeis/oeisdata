%I A142187 #16 Jun 28 2026 14:32:40
%S A142187 11,131,211,251,331,491,571,691,811,971,1051,1091,1171,1291,1451,1531,
%T A142187 1571,1811,1931,2011,2131,2251,2371,2411,2531,2731,2851,2971,3011,
%U A142187 3251,3331,3371,3491,3571,3691,3851,3931,4051,4091,4211,4451,4651,4691,4931,5011
%N A142187 Primes congruent to 11 mod 40.
%C A142187 Also primes of the form x^2 + 10*y^2 (see Uspensky and Heaslet). - _Stefano Spezia_, Jun 28 2026
%D A142187 J. V. Uspensky and M. A. Heaslet, Elementary Number Theory, McGraw-Hill, NY, 1939, Exercise n. 2 at p. 346.
%H A142187 Vincenzo Librandi, <a href="/A142187/b142187.txt">Table of n, a(n) for n = 1..1000</a>
%F A142187 a(n) ~ 16n log n. - _Charles R Greathouse IV_, Jul 03 2016
%t A142187 Select[Prime[Range[2000]],MemberQ[{11},Mod[#,40]]&] (* _Vincenzo Librandi_, Aug 20 2012 *)
%t A142187 (* Alternative: *)
%t A142187 Select[Range[11,5500,40],PrimeQ] (* _Harvey P. Dale_, Sep 13 2021 *)
%o A142187 (Magma) [p: p in PrimesUpTo(7000) | p mod 40 eq 11]; // _Vincenzo Librandi_, Aug 20 2012
%o A142187 (PARI) is(n)=isprime(n) && n%40==11 \\ _Charles R Greathouse IV_, Jul 03 2016
%Y A142187 Cf. A000040.
%K A142187 nonn,easy,changed
%O A142187 1,1
%A A142187 _N. J. A. Sloane_, Jul 11 2008
