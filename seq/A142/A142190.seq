%U A142190 3019,3259,3299,3499,3539,3659,3739,3779,4019,4099,4139,4219,4259,4339,5059,5099
%N A142190 Primes congruent to 19 mod 40.
%C A142190 Also primes of the form x^2 + 10*y^2 (see Uspensky and Heaslet). - _Stefano Spezia_, Jun 28 2026
%D A142190 J. V. Uspensky and M. A. Heaslet, Elementary Number Theory, McGraw-Hill, NY, 1939, Exercise n. 2 at p. 346.
%H A142190 Vincenzo Librandi, <a href="/A142190/b142190.txt">Table of n, a(n) for n = 1..1000</a>
%F A142190 a(n) ~ 16n log n. - _Charles R Greathouse IV_, Jul 02 2016
%t A142190 Select[Prime[Range[2000]],MemberQ[{19},Mod[#,40]]&] (* _Vincenzo Librandi_, Aug 22 2012 *)
%o A142190 (Magma) [p: p in PrimesUpTo(6000) | p mod 40 eq 19 ]; // _Vincenzo Librandi_, Aug 22 2012
%o A142190 (PARI) is(n)=isprime(n) && n%40==19 \\ _Charles R Greathouse IV_, Jul 02 2016
%Y A142190 Cf. A000040.
