%N A392566 Expansion of e.g.f. (1/x) * Series_Reversion( x*exp(-x*(3+x)) ).
%F A392566 E.g.f. A(x) satisfies A(x) = exp(3*x*A(x) + (x*A(x))^2).
%F A392566 a(n) = n! * Sum_{k=0..floor(n/2)} (n+1)^(n-k-1) * 3^(n-2*k) * binomial(n-k,k)/(n-k)!.
%o A392566 (PARI) my(N=20, x='x+O('x^N)); Vec(serlaplace(serreverse(x*exp(-x*(3+x)))/x))
