%I A392195 #14 Mar 16 2026 21:33:54
%S A392195 1,2,6,9,150,225,250,625,7350,11025,12250,14406,21609,30625,33614,
%T A392195 117649,107611350,161417025,179352250,210918246,265734150,316377369,
%U A392195 398601225,442890250,448380625,492142574,1107225625,1286153286,1722499009,1929229929,4715895382,18186318150
%N A392195 Positive integers with canonical prime factorization Product_{i=1..m} p_i^(p_i - p_{i-1}), where p_0 = 1.
%C A392195 If k = Product_{i=1..m} p_i^e_i is in the sequence, then p_i = 1 + Sum_{j<=i} e_j. Thus the primes in the factorization are obtained as cumulative sums of the exponents plus 1.
%C A392195 The only prime term is 2, the only squarefree terms are 1, 2 and 6.
%H A392195 Felix Huber, <a href="/A392195/b392195.txt">Table of n, a(n) for n = 1..10000</a>
%F A392195 A001222(a(n)) = A006530(a(n)) - 1.
%e A392195 150 = 2^1*3^1*5^2 is a term since 2 - 1 = 1 (exponent of 2), 3 - 2 = 1 (exponent of 3), and 5 - 3 = 2 (exponent of 5).
%e A392195 21609 = 3^2*7^4 is a term since 3 - 1 = 2 (exponent of 3), and 7 - 3 = 4 (exponent of 7).
%p A392195 A392195 := proc(N)
%p A392195     local c, i, f, m, t;
%p A392195     m := evalf(ln(N));
%p A392195     t := table();
%p A392195     c := 0;
%p A392195     f := proc(l, v, k)
%p A392195         local i, p, w;
%p A392195         c := c + 1;
%p A392195         t[c] := v;
%p A392195         i := k;
%p A392195         do
%p A392195             p := ithprime(i);
%p A392195             if (p - l)*evalf(ln(p)) > m then
%p A392195                 break
%p A392195             end if;
%p A392195             w := v*p^(p - l);
%p A392195             if w <= N then
%p A392195                 f(p, w, i + 1)
%p A392195             end if;
%p A392195             i := i + 1;
%p A392195         end do
%p A392195     end proc;
%p A392195     f(1, 1, 1);
%p A392195     sort([seq(t[i], i = 1 .. c)]);
%p A392195 end proc:
%p A392195 A392195(18186318150);
%Y A392195 Cf. A001222, A006530, A390784, A392819.
%K A392195 nonn
%O A392195 1,2
%A A392195 _Felix Huber_, Mar 11 2026
