%S A392706 1,2,1,3,2,1,1,4,3,2,2,1,0,1,1,5,4,3,3,2,1,2,2,1,-1,1,0,1,1,1,1,6,5,4,
%T A392706 4,3,2,3,3,2,0,2,1,2,2,2,2,1,-2,0,-1,1,1,0,0,1,1,1,1,1,0,1,1,7,6,5,5,
%U A392706 4,3,4,4,3,1,3,2,3,3,3,3,2,-1,1,0,2,2,1
%N A392706 Least even-indexed part in row n of A391983 (the 0-based partial alternating sums of the n-th composition in standard order).
%C A392706 The k-th composition in standard order (graded reverse-lexicographic, A066099) is obtained by taking the set of positions of 1's in the reversed binary expansion of k, prepending 0, taking first differences, and reversing again. This gives a bijective correspondence between nonnegative integers and integer compositions.
%C A392706 The k-based partial alternating sums of a finite sequence q are given by pas(q,k)_j = (-1)^j * k + Sum_{i=1..j} (-1)^(i+j) * q_i. This is a signed version of the partial sums transformation, inverse to the "first sums" transformation. For example, the k-based partial alternating sums of q = (a,b,c,d,e) are:
%C A392706   pas(q,k)_0 =  k
%C A392706   pas(q,k)_1 = -k + a
%C A392706   pas(q,k)_2 =  k - a + b
%C A392706   pas(q,k)_3 = -k + a - b + c
%C A392706   pas(q,k)_4 =  k - a + b - c + d
%C A392706   pas(q,k)_5 = -k + a - b + c - d + e
%e A392706 The 92nd standard composition is (2,1,1,3), with 0-based partial alternating sums (0,2,-1,2,1), with even-indexed parts (2,2), with minimum 2, so a(92) = 2.
%t A392706 stc[n_]:=Differences[Prepend[Join @@ Position[Reverse[IntegerDigits[n,2]],1],0]]//Reverse;
%t A392706 pas[y_,k_]:=Table[(-1)^j*k+Sum[(-1)^(i+j)*y[[i]],{i,j}],{j,0,Length[y]}];
%t A392706 gex[c_]:=c[[Select[Range[Length[c]],EvenQ]]];
%t A392706 Table[Min@@gex[pas[stc[n],0]],{n,100}]
%Y A392706 This is the least even-indexed part in row n of A391983.
%Y A392706 For odd instead of even we have A392705.
%Y A392706 Including odd indices gives A392713.
%Y A392706 A011782 counts compositions.
%Y A392706 A066099 lists standard compositions, sums A070939, first sums A390432.
%Y A392706 A116406 counts compositions with alternating sum >= 0.
%Y A392706 A390673 ranks compositions with distinct first sums, count A390567.
%Y A392706 A390676 ranks compositions that are first sums, union of A390568.
%Y A392706 A392369 adds up odd-indexed parts (even A392370), non-reverse A209281 (even A346633).
%Y A392706 Cf. A000120, A065120, A124754, A124767, A316524, A344616, A344618, A344619, A346697, A390745, A391642, A391984.
