%t A392409 Block[{c, m, q, r, t, w, x, y}, m = 15; x = y = 0; c[_] := 0; q[_] := 0; t[_, _] = 0; r = 1; Monitor[Do[w = PrimeOmega[i]; q[w]++; If[SquareFreeQ[i], c[w]++]; If[IntegerQ[#], Set[t[w, #], c[w] ]; If[# > y, y = #]; If[w > x, x = w]] &[Log2[q[w] ] ], {i, 2^m}], i]; Flatten@ TakeWhile[Table[t[k, n - k + 1], {n, 0, y}, {k, n + 1}], First[#] > 0 &] ]
