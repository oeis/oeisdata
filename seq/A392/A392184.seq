%I A392184 #43 Mar 27 2026 21:16:57
%S A392184 1,2,4,29,10,2309,28,1138829,20,130,2308,239378649509,68,
%T A392184 461282657605769,570569,2728,208,3338236629672919864889,154,
%U A392184 11465419967969569966774409,3568,570568,200560490129,447252622660353534197972753024069,713,77140,304250263527208,644
%N A392184 a(n) is the least k for which omega(k)*omega(k + 1)*omega(k + 2) = n where omega = A001221, or -1 if no such k exists.
%H A392184 Sean A. Irvine, <a href="/A392184/b392184.txt">Table of n, a(n) for n = 0..43</a>
%H A392184 Brian Hayes, <a href="http://bit-player.org/2021/does-having-prime-neighbors-make-you-more-composite">Does having prime neighbors make you more composite?</a>, Bit-Player Article, Nov 04 2021.
%F A392184 From _Vaclav Kotesovec_, Jan 03 2026: (Start)
%F A392184 For p>2 prime, A002110(p) - 1 <= a(p) <= A075590(p) - 1.
%F A392184 Conjecture: a(p) = A075590(p) - 1. (End)
%e A392184         k  |    omega(k)*omega(k + 1)*omega(k + 2)  =      n
%e A392184   -----------------------------------------------------------
%e A392184         1  |       0     *      1     *     1       =      0
%e A392184         2  |       1     *      1     *     1       =      1
%e A392184         4  |       1     *      1     *     2       =      2
%e A392184        29  |       1     *      3     *     1       =      3
%e A392184        10  |       2     *      1     *     2       =      4
%e A392184      2309  |       1     *      5     *     1       =      5
%e A392184        28  |       2     *      1     *     3       =      6
%e A392184   1138829  |       1     *      7     *     1       =      7
%e A392184        20  |       2     *      2     *     2       =      8
%e A392184       130  |       3     *      1     *     3       =      9
%e A392184      2308  |       2     *      1     *     5       =      10
%o A392184 (Magma) [Min([k: k in [1..10000] | #PrimeDivisors(k)*#PrimeDivisors(k+1)*#PrimeDivisors(k+2) eq n]): n in [0..6]];
%o A392184 (PARI) isok(k,n) = omega(k)*omega(k+1)*omega(k+2) == n;
%o A392184 a(n) = my(k=1); while (! isok(k,n), k++); k; \\ _Michel Marcus_, Feb 26 2026
%Y A392184 Cf. A001221, A002110, A075590, A391216, A006549, A088071, A173037, A264734, A329364, A392232, A393108.
%K A392184 nonn,more
%O A392184 0,2
