%I A392527 #16 Apr 03 2026 19:07:40
%S A392527 1,1,3,13,73,498,3907,33965,319829,3214318,34123464,379794279,
%T A392527 4407033157,53087576412,661669675996,8510226472146,112710197647111,
%U A392527 1534423574143335,21441405546634806,307151551000185660,4505958548392846572,67633496431516286779,1037840871755749982990
%N A392527 G.f.: A(x) = 1 + x*F(x)*G(x)^2 where F(x) = A(x/F(x)) and G(x) = A(x*G(x)).
%H A392527 Paul D. Hanna, <a href="/A392527/b392527.txt">Table of n, a(n) for n = 0..400</a>
%F A392527 G.f. A(x) = Sum_{n>=0} a(n)*x^n, along with F(x) = A(x/F(x)) and G(x) = A(x*G(x)), satisfy the following formulas.
%F A392527 (1) A(x) = 1 + x*F(x)*G(x)^2 by definition.
%F A392527 (2) A(x) = 1 + Series_Reversion(x/A(x))^2 / Series_Reversion(x*A(x)).
%F A392527 (3) A(x/A(x)) = 1 + x*A(x) * F(x/A(x)) since G(x/A(x)) = A(x).
%F A392527 (4) A(x*A(x)) = 1 + x*A(x)^2 * G(x*A(x))^2 since F(x*A(x)) = A(x).
%F A392527 (5) A(x/F(x)^2) = 1 + x*F( x/F(x)^2 ) since F(x) = G(x/F(x)^2).
%F A392527 (6) A(x*G(x)^2) = 1 + x*G(x)^3 * G( x*G(x)^2 )^2 since G(x) = F(x*G(x)^2).
%e A392527 G.f.: A(x) = 1 + x + 3*x^2 + 13*x^3 + 73*x^4 + 498*x^5 + 3907*x^6 + 33965*x^7 + 319829*x^8 + 3214318*x^9 + 34123464*x^10 + ...
%e A392527 RELATED SERIES.
%e A392527 Let F(x) = A(x/F(x)), which begins
%e A392527 F(x) = 1 + x + 2*x^2 + 6*x^3 + 28*x^4 + 177*x^5 + 1310*x^6 + 10759*x^7 + 96108*x^8 + 919641*x^9 + 9317490*x^10 + ...
%e A392527 and let G(x) = A(x*G(x)), which begins
%e A392527 G(x) = 1 + x + 4*x^2 + 23*x^3 + 162*x^4 + 1309*x^5 + 11692*x^6 + 112821*x^7 + 1158770*x^8 + 12541046*x^9 + 141998762*x^10 + ...
%e A392527 then A(x) = 1 + x*F(x)*G(x)^2.
%o A392527 (PARI) {a(n) = my(A=1); for(k=1, n, A = truncate(A) +O(x^k); A = 1 + serreverse(x/A)^2/serreverse(x*A)); polcoef(GF=A, n)}
%o A392527 {upto(n) = a(n); Vec(GF)}
%o A392527 \\ List the terms
%o A392527 upto(30)
%o A392527 \\ DEMONSTRATION OF FORMULAS.
%o A392527 \\ Obtain F(x) = A(x/F(x)) and G(x) = A(x*G(x))
%o A392527 A = GF
%o A392527 F = x/serreverse(x*GF)
%o A392527 G = (1/x)*serreverse(x/GF)
%o A392527 \\ the following statements return a '1' if true
%o A392527 A - x*F*G^2
%o A392527 subst(A,x,x/A) - x*A*subst(F,x,x/A)
%o A392527 subst(A,x,x*A) - x*A^2*subst(G,x,x*A)^2
%o A392527 subst(A,x,x/F^2) - x*subst(F,x,x/F^2)
%o A392527 subst(A,x,x*G^2) - x*G^3*subst(G,x,x*G^2)^2
%Y A392527 Cf. A184509.
%K A392527 nonn,new
%O A392527 0,3
%A A392527 _Paul D. Hanna_, Apr 01 2026
