%I A392712 #10 Mar 30 2026 09:51:22
%S A392712 0,1,2,4,6,8,16,26,32,40,64,106,128,256,288,426,512,648,1024,1706,
%T A392712 2048,2176,4096,6826,8192,10376,16384,16896,18464,27306,32768,65536,
%U A392712 109226,131072,133120,166024,262144,436906,524288,557184,1048576,1056768,1181728
%N A392712 Numbers k such that the trimmed partial alternating sums of the k-th composition in standard order are all equal.
%C A392712 The k-th composition in standard order (graded reverse-lexicographic, A066099) is obtained by taking the set of positions of 1's in the reversed binary expansion of k, prepending 0, taking first differences, and reversing again. This gives a bijective correspondence between nonnegative integers and integer compositions.
%C A392712 The partial alternating sums of a finite sequence q are given by pas(q)_j = Sum_{i=1..j} (-1)^(i+j) * q_i. For example, partial alternating sums of q = (a,b,c,d,e) are:
%C A392712   pas(q)_0 =  0
%C A392712   pas(q)_1 =  a
%C A392712   pas(q)_2 = -a + b
%C A392712   pas(q)_3 =  a - b + c
%C A392712   pas(q)_4 = -a + b - c + d
%C A392712   pas(q)_5 =  a - b + c - d + e
%C A392712 These are trimmed by removing the zeroth line.
%e A392712 The 288th composition in standard order is (3,6), with partial alternating sums (0,3,3), trimmed (3,3), so 288 is in the sequence.
%e A392712 The terms together with their standard compositions begin:
%e A392712      0: ()
%e A392712      1: (1)
%e A392712      2: (2)
%e A392712      4: (3)
%e A392712      6: (1,2)
%e A392712      8: (4)
%e A392712     16: (5)
%e A392712     26: (1,2,2)
%e A392712     32: (6)
%e A392712     40: (2,4)
%e A392712     64: (7)
%e A392712    106: (1,2,2,2)
%e A392712    128: (8)
%e A392712    256: (9)
%e A392712    288: (3,6)
%e A392712    426: (1,2,2,2,2)
%e A392712    512: (10)
%e A392712    648: (2,4,4)
%e A392712   1024: (11)
%e A392712   1706: (1,2,2,2,2,2)
%t A392712 stc[n_]:=Differences[Prepend[Join @@ Position[Reverse[IntegerDigits[n,2]],1],0]]//Reverse;
%t A392712 pas[y_,k_]:=Table[(-1)^j*k+Sum[(-1)^(i+j)*y[[i]],{i,j}],{j,0,Length[y]}];
%t A392712 Select[Range[0,1000],SameQ@@Rest[pas[stc[#],0]]&]
%Y A392712 These compositions are counted by A001227, nonprime case A069283.
%Y A392712 For run lengths instead of partial alternating sums we have A353744, count A329738.
%Y A392712 For run-sums instead of partial alternating sums we have A353848, count A353851.
%Y A392712 For first differences instead of partial alternating sums we have A389731.
%Y A392712 For first sums instead of partial alternating sums we have A390674, count A342527.
%Y A392712 Positions of constant rows in A391983, non-singleton case A391981 or A392374.
%Y A392712 The version for prime indices is A392700, including primes A392371, see A325230.
%Y A392712 For distinct non-trimmed we have A392708, count A392703.
%Y A392712 For distinct instead of equal we have A392709, count A392702.
%Y A392712 A003242 counts anti-run compositions, ranks A333489.
%Y A392712 A005811 counts runs in binary expansion.
%Y A392712 A011782 counts compositions.
%Y A392712 A066099 lists all compositions in standard order.
%Y A392712 A097805 counts compositions by alternating sum.
%Y A392712 A304442 counts partitions with all equal run-sums, ranks A353833.
%Y A392712 A390432 lists first sums of standard compositions, row ranks A390568.
