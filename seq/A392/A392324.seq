%I A392324 #36 May 09 2026 11:13:48
%S A392324 1,4,11,30,57,104,167,258,373,524,707,934,1201,1520,1887,2314,2797,
%T A392324 3348,3963,4654,5417,6264,7191,8210,9317,10524,11827,13238,14753,
%U A392324 16384,18127,19994,21981,24100,26347,28734,31257,33928,36743,39714,42837,46124,49571,53190
%N A392324 Minimal value of p(1) + Sum_{i=2...n} p(i-1)*p(i), as p ranges over all permutations of odd numbers {1,3,...,2*n-1}.
%C A392324 The question originated from generalization of the first puzzle 'Low Budget' in the book Mathematical Puzzles and Curiosities.
%D A392324 I. David, T. Khovanova, and Y. Shpilman, Mathematical Puzzles and Curiosities, World Scientific, 2026, p.2.
%H A392324 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (3,-2,-2,3,-1).
%F A392324 a(n) = (2*n^3 - 6*n^2 + 19*n - 21 + 3*(-1)^n)/3 for n > 1.
%F A392324 G.f.: x*(4*x^5-6*x^4+7*x^3+x^2+x+1)/((x+1)*(x-1)^4).
%e A392324 For n=4, the permutation that realizes the minimum value is 5,3,1,7. So a(4) = 5 + 5*3 + 3*1 + 1*7 = 30. Thus, a(4) = 30.
%t A392324 a[1]=1;a[n_]:=(2*n^3 - 6*n^2 + 19*n - 21 + 3*(-1)^n)/3 ;Array[a,44]
%t A392324 (* Alternative: *)
%t A392324 {1}~Join~LinearRecurrence[{3,-2,-2,3,-1},{4,11,30,57,104},43]
%t A392324 (* Alternative: *)
%t A392324 Rest[CoefficientList[Series[x*(4*x^5-6*x^4+7*x^3+x^2+x+1)/((x+1)*(x-1)^4),{x,0,44}],x]] (* _James C. McMahon_, May 08 2026 *)
