%I A392265 #25 Mar 28 2026 21:13:51
%S A392265 1,2,1,2,3,1,2,4,1,4,3,2,3,6,1,1,2,5,6,2,1,3,4,8,4,2,4,4,1,2,6,1,1,9,
%T A392265 2,2,2,1,1,4,5,10,4,7,3,8,6,3,1,7,2,3,12,1,7,3,4,2,5,1,2,5,6,1,2,1,4,
%U A392265 12,7,10,1,4,12,3,8,1,2,4,7,2,8,3,1,4,6,15
%N A392265 Number of divisors d | A286708(n) such that d is also in A286708.
%C A392265 A286708 = A001694 \ A246547 \ {1}, i.e., powerful numbers that are not powers of primes.
%C A392265 Intersection of A286708 and row A286708(n) of A027750.
%C A392265 Let f(k) = A005361(k) - A046660(k) - 1; f(k) > 0 for k in A286708.
%H A392265 Michael De Vlieger, <a href="/A392265/b392265.txt">Table of n, a(n) for n = 1..10000</a>
%H A392265 <a href="/index/Pow#powerful">Index entries for sequences related to powerful numbers</a>.
%F A392265 a(n) = A005361(A286708(n)) - A046660(A286708(n)) - 1.
%F A392265 a(n) = A000005(A003557(n)) - A001222(A286708(n)) + A001221(A286708(n)) - 1.
%e A392265 Let s = A286708.
%e A392265 Let P = A005361(s(n)) be the product of prime power factor exponents of s(n).
%e A392265 Let S = A046660(A003557(s(n))) be the sum of one less than each prime power factor exponent of s(n).
%e A392265 Table of n, a(n), s(n), P, and S for select n:
%e A392265  n  a(n)  s(n)                      P(n)        S(n)        Divisors in A286708
%e A392265 -------------------------------------------------------------------------------
%e A392265  1    1     36 = 2^2 * 3^2          4 = 2*2     2 = 2+2-2   {36}
%e A392265  2    2     72 = 2^3 * 3^2          6 = 3*2     3 = 3+2-2   {36, 72}
%e A392265  3    1    100 = 2^2 * 5^2          4 = 2*5     2 = 2+5-2   {100}
%e A392265  4    2    108 = 2^2 * 3^3          6 = 2*3     3 = 2+3-2   {36, 108}
%e A392265  5    3    144 = 2^4 * 3^2          8 = 4*2     4 = 4+2-2   {36, 72, 144}
%e A392265  8    4    216 = 2^3 * 3^3          9 = 3*3     4 = 3+3-2   {36, 72, 108, 216}
%e A392265 14    6    432 = 2^4 * 3^3         12 = 4*3     5 = 4+3-2   etc.
%e A392265 18    5    576 = 2^6 * 3^2         12 = 6*2     6 = 6+2-2
%e A392265 24    8    864 = 2^5 * 3^3         15 = 5*3     6 = 5+3-2
%e A392265 34    9   1296 = 2^4 * 3^4         16 = 4*4     6 = 4+4-2
%e A392265 42   10   1728 = 2^6 * 3^3         18 = 6*3     7 = 6+3-2
%e A392265 44    7   1800 = 2^3 * 3^2 * 5^2   12 = 3*2*2   4 = 3+2+2-3
%t A392265 nn = 2^13; f[x_] := Times @@ # - Total[# - 1] - 1 &[FactorInteger[x][[;; , -1]] ];
%t A392265 s = Rest@ Select[Union@ Flatten@ Table[a^2*b^3, {b, Surd[nn, 3]}, {a, Sqrt[nn/b^3] } ], Not @* PrimePowerQ]; Map[f, s]
%Y A392265 Cf. A001221, A001222, A001694, A003557, A005361, A007947, A027750, A046660, A246547, A286708.
%K A392265 nonn,easy
%O A392265 1,2
%A A392265 _Michael De Vlieger_, Mar 19 2026
