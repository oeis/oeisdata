%o A392495 (Python) # Function 'is_rigid' is defined in A392499 (see also links).
%o A392495 def A392495_list(upto: int) -> list[int]:
%o A392495     return [n for n in range(45, upto+1, 3) if 3 == is_rigid(n)]
