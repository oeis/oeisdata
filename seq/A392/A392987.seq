%N A392987 The number of 2-dense numbers <= n where the 2-dense numbers are A174973.
%C A392987 First differs from A225559 at a(78).
%H A392987 Antti Karttunen, <a href="/A392987/b392987.txt">Table of n, a(n) for n = 1..10000</a>
%F A392987 A174973(a(n)) = n.
%t A392987 Accumulate[Array[Boole[Max[Rest[#]/Most[#]] <= 2] & [Divisors[#]] &, 100]] (* _Paolo Xausa_, Mar 13 2026 *)
%o A392987 (PARI)
%o A392987 up_to = 10000;
%o A392987 A365429(n) = { my(d=divisors(n)); for(i=2, #d, if(d[i]>2*d[i-1], return(0))); (1); };
%o A392987 A392987_list(up_to) = { my(v=vector(up_to), s=0); for(i=1,up_to,s+=A365429(i); v[i] = s); (v); };
%o A392987 v392987 = A392987_list(up_to);
%o A392987 A392987(n) = v392987[n]; \\ _Antti Karttunen_, Mar 05 2026
%Y A392987 Partial sums of A365429.
%Y A392987 Cf. A174973, A225559.
%K A392987 nonn
%O A392987 1,2
%A A392987 _Omar E. Pol_, Mar 05 2026
