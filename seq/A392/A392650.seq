%N A392650 Sum-irreducible numbers. A number k > 0 is sum-irreducible if no subset of its nontrivial divisors {1 < d < k : d | k} can sum to k.
%C A392650 The first term that is not in A263837 is 20, the first 2-rigid number (A392496).
%H A392650 Robert Israel, <a href="/A392650/b392650.txt">Table of n, a(n) for n = 1..10000</a>
%H A392650 Peter Luschny, <a href="https://github.com/PeterLuschny/Gists/blob/main/ComposableRigidSparse.ipynb">Composable, rigid, and sparse numbers</a>. A Python notebook.
%e A392650 351351 is sum-irreducible.
%p A392650 filter:= proc(n) local D,S,d;
%p A392650   D:= NumberTheory:-Divisors(n) minus {1,n};
%p A392650   S:= {0};
%p A392650   for d in D do
%p A392650     S:= S union select(`<=`,S +~ d, n);
%p A392650     if member(n,S) then return false fi;
%p A392650   od;
%p A392650   true
%p A392650 end proc:
%p A392650 select(filter, [$1..100]); # _Robert Israel_, Mar 03 2026
%t A392650 q[k_]:=!ContainsAny[Total/@Subsets[Rest[Drop[Divisors[k],-1]]],{k}];{1}~Join~Select[Range[2,99],q] (* _James C. McMahon_, Mar 03 2026 *)
%o A392650 (Python)  # See also links.
%o A392650 from sympy import divisors
%o A392650 from functools import cache
%o A392650 # The function 'subset_sum_exists' is defined in A392652.
%o A392650 @cache
%o A392650 def is_sum_irreducible(n: int) -> bool:
%o A392650     if n < 12: return True
%o A392650     divs = divisors(n)[1:-1]
%o A392650     return not subset_sum_exists(divs, n)
%o A392650 def A392650_list(upto: int) -> list[int]:
%o A392650     return [n for n in range(1, upto + 1) if is_sum_irreducible(n)]
%o A392650 print(A392650_list(100))
%o A392650 (PARI) lista(len)= my(a=List([1]), k=1); while(#a<len, my(b=1, d=Vecrev(divisors(k++)[2..-2]));  for(i=1, 2^#d-1, if(k==d*Vecrev(binary(i), #d)~, b=0; break)); b && listput(~a, k));  Vec(a); \\ _Ruud H.G. van Tol_, Mar 04 2026
