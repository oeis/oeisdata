%S A392922 15,51,85,91,255,435,451,561,595,679,703,771,1105,1261,1285,1351,1387,
%T A392922 1695,1729,1891,2047,2091,2431,2465,2509,2701,2821,3277,3367,3655,
%U A392922 3855,4369,4795,5083,5151,5383,5551,6601,6643,6735,7051,7471,7735,8119,8245,8481,8695,8827,8911,8995,9061,9605,9997
%N A392922 Odd composite k such that the odd part of psi(k) divides k-1, where psi = A002322 and odd part = A000265.
%C A392922 Odd composite squarefree k such that odd(p-1) divides k-1 for every prime factor p of k.
%C A392922 Odd composite k such that A393131((k-1)/2), the index of witnesses for Solovay-Strassen primality test of k as a subgroup of (Z/kZ)*, is a power of 2. In other words, odd composite k such that the inequality odd(A329726((k-1)/2)) <= odd(EulerPhi(k)) becomes an equality.
%H A392922 Jianing Song, <a href="/A392922/b392922.txt">Table of n, a(n) for n = 1..10000</a>
%F A392922 255 is a term since psi(255) = 16, and odd(16) = 1 divides 255-1.
%F A392922 435 is a term since psi(435) = 28, and odd(28) = 7 divides 435-1.
%t A392922 q[k_] := OddQ[k] && CompositeQ[k] && Divisible[k-1, (# / 2^IntegerExponent[#, 2])& @ CarmichaelLambda[k]]; Select[Range[10^4], q] (* _Amiram Eldar_, Mar 30 2026 *)
%o A392922 (PARI) odd(n) = n >> valuation(n, 2)
%o A392922 isA392922(n) = (n>1 && n%2==1 && !isprime(n) && (n-1) % odd(lcm(znstar(n)[2])) == 0)
%Y A392922 Cf. A329726, A393131, A392921, A000265, A002322, A339879.
%Y A392922 A002997 (and also A033181) are subsequences.
%K A392922 nonn,new
%O A392922 1,1
