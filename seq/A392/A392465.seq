%I A392465 #29 Mar 29 2026 17:29:48
%S A392465 1,2,1,1,8,10,19,23,19,28,29,46,55,62,64,100,77,109,109,119,127,181,
%T A392465 143,136,172,140,199,172,236,244,253,251,226,262,266,253,325,362,307,
%U A392465 334,341,343,388,401,361,451,434,469,451,467,433,550,518,514,487,506
%N A392465 Sum of decimal digits of A101686.
%C A392465 Let s_b(n) denote the sum of digits of a positive integer n when written in integer base b. It follows from Theorem 1.1 in Cilleruelo link that for any base b>=2, s_b(A101686(n)) > 2*log(n)/(30*log(b)) holds on a set of positive integers n of asymptotic density 1.
%H A392465 Shreyansh Jaiswal, <a href="/A392465/b392465.txt">Table of n, a(n) for n = 0..1000</a>
%H A392465 Javier Cilleruelo, Florian Luca, Juanjo Rué, and Ana Zumalacárregui, <a href="https://doi.org/10.2478/s11533-012-0080-0">On the sum of digits of some sequences of integers</a>, Open Mathematics, Vol. 11, No. 1 (2013), pp. 188-195.
%F A392465 a(n) = A007953(A101686(n)).
%e A392465 a(5) = 10 because A101686(5) = 44200, and 4 + 4 + 2 = 10.
%t A392465 a[n_] := DigitSum[Abs[Pochhammer[1 + I, n]]^2]; Array[a, 56, 0] (* _Amiram Eldar_, Mar 24 2026 *)
%o A392465 (Python)
%o A392465 from math import prod
%o A392465 def A007953(n): return sum(int(d) for d in str(n)) # from A007953
%o A392465 def A101686(n): return prod(i**2+1 for i in range(1, n+1)) # from A101686
%o A392465 def a(n): return A007953(A101686(n))
%Y A392465 Cf. A007953, A101686.
%K A392465 nonn,base
%O A392465 0,2
%A A392465 _Shreyansh Jaiswal_, Mar 24 2026
