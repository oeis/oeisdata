%S A392362 62,127,146,154,189,191,195,199,203,211,215,220,229,235,245,252,254,
%T A392362 255,260,268,269,274,275,277,281,282,283,284,286,287,297,299,300
%N A392362 Primitive solutions k to the Diophantine equation k^7 = Sum_{i = 1..9} y_i^7 with y_i > 0.
%H A392362 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/DiophantineEquation7thPowers.html">Diophantine Equation--7th Powers</a>.
%H A392362 Zhining Yang, <a href="/A392362/a392362.txt">All solutions of Diophantine Equation k^7 = y1^7 + y2^7 + ... + y9^7 with k <= 300</a>.
%e A392362 62^7 = 59^7 + 50^7 + 41^7 + 33^7 + 27^7 + 22^7 + 20^7 + 14^7 + 6^7.
%e A392362 127^7 = 121^7 + 103^7 + 76^7 + 75^7 + 54^7 + 49^7 + 38^7 + 28^7 + 3^7.
%t A392362 For[k=10,k<=200,k++,s=Select[IntegerPartitions[k^7,{9},Range[k-1]^7]^(1/7),DuplicateFreeQ@#&&GCD@@#==1&];If[s!={},Print[{k,s}]]]
%Y A392362 Cf. A381026, A380716.
