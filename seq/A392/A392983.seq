%S A392983 1,0,1,2,8,24,160,384,3456,16896,129024,589824,7741440,33914880,
%T A392983 513146880,3397386240,30576476160,271790899200,5218385264640,
%U A392983 33267206062080,704482010726400,6011579824865280,78901985201356800,845378412871680000,21326079428709580800
%N A392983 a(n) is the absolute value of the determinant of the symmetric n X n matrix M defined by M[i,j] = gcd(i,j) for 0 <= i,j <= n-1.
%C A392983 Definition gcd(0,0) = 0 is adopted; see Knuth (1997), Eq. 1, p. 333.
%D A392983 D. E. Knuth, The Art of Computer Programming Third Edition. Vol. 2, Seminumerical Algorithms. Chapter 4.5.2 The Greatest Common Divisor, Page 333. Addison-Wesley, Reading, MA, 1997.
%H A392983 R. J. Cintra, <a href="/A392983/b392983.txt">Table of n, a(n) for n = 0..100</a>
%H A392983 R. J. Cintra, <a href="https://hal.science/hal-05671935">A note on the determinant of a certain GCD matrix</a>, 2026.
%H A392983 Henry J. Stephen Smith, <a href="https://scispace.com/pdf/on-the-value-of-a-certain-arithmetical-determinant-3ptu9ad1z7.pdf">On the value of a certain arithmetical determinant</a>, Proc. London Math. Soc., Vol. 7 (1875-1876), 208-212.
%F A392983 a(n) = A001088(n-1)*A002088(n-1), for n>=1.
%e A392983                | 0 1 2 |
%e A392983 a(3) = abs(det | 1 1 1 |) = 2.
%e A392983                | 2 1 2 |
%p A392983 a:= n-> abs(LinearAlgebra[Determinant](Matrix(n, (i, j)-> igcd(i-1, j-1)))):
%p A392983 seq(a(n), n=0..24);  # _Alois P. Heinz_, Jun 07 2026
%t A392983 a[n_] := Abs[With[{e = EulerPhi[Range[n-1]]}, -(Plus @@ e) * Times @@ e]]; a[0] = 1; Array[a, 25, 0] (* _Amiram Eldar_, Jun 07 2026 *)
%t A392983 (* Alternative: *)
%t A392983 a[n_] := Abs[Det[Table[GCD[i, j], {i, 0, n-1}, {j, 0, n-1}]]]; a[0] = 1; Array[a, 25, 0] (* _Amiram Eldar_, Jun 07 2026 *)
%o A392983 (Julia) using Primes; function a(n)
%o A392983   (n==0 || n==1) && return 1-n; n = BigInt(n); t = totient.(1:n-1); return sum(t)*prod(t); end
%o A392983 (Julia) using LinearAlgebra; function a(n) n==0 && return 1; return -LinearAlgebra.det_bareiss([gcd(BigInt(i), j) for i in 0:n-1, j in 0:n-1]) end
%o A392983 (PARI) a(n) = if (n, my(v=vector(n-1, k, eulerphi(k))); vecprod(v)*vecsum(v), 1); \\ _Michel Marcus_, Jun 07 2026
%Y A392983 Cf. A001088, A002088.
%K A392983 nonn,easy,new
%O A392983 0,4
%A A392983 _R. J. Cintra_, Jun 06 2026
