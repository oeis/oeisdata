%I A392857 #35 Mar 29 2026 17:01:28
%S A392857 1,0,1,0,2,1,0,12,6,1,0,122,60,12,1,0,1740,850,180,20,1,0,31922,15540,
%T A392857 3390,420,30,1,0,715932,347774,77280,10150,840,42,1,0,18978122,
%U A392857 9205308,2071496,282240,25340,1512,56,1,0,580513260,281274858,63878220,8926008,844200,55692,2520,72,1
%N A392857 T(n, k) is the number of partitions of [n] into a set of k connected series-parallel posets.
%C A392857 As a counterpart to the Stirling triangles (for A058349's structure instead of sets or cycles), this triangle is of binomial type.
%H A392857 Andrei Z. Broder, <a href="https://doi.org/10.1016/0012-365X(84)90161-4">The r-Stirling numbers</a>, Discrete Mathematics, Vol. 49, Iss. 3 (1984), pp. 241-259.
%H A392857 Natalia L. Skirrow, <a href="/wiki/User:Natalia_L._Skirrow/A058349">A058349</a> (derivation of this sequence's formula for each column follows the same route).
%H A392857 Wikipedia, <a href="https://en.wikipedia.org/wiki/Binomial_type">Binomial type</a>.
%F A392857 E.g.f.: exp(y*f(x)), where f(x), the compositional inverse of x + 2*(1 - cosh(x)), is the e.g.f. of A058349.
%F A392857 T(n, k) = Sum_{j=0..n-k} (2*j)!/j! * C(n+j-1, k-1) * Stirling2(-j; n-k, j), where Stirling2(r; n, k) is an r-subset number, and Stirling2(-j; n-k, j) = |A199916(n-k,j)|.
%F A392857 T(n, 1) = A058349(n,k).
%F A392857 Sum_{k=1..n} T(n, k) = A048172(n).
%F A392857 Sum_{k=2..n} T(n, k) = A048174(n) for n >= 2.
%e A392857 Triangle begins:
%e A392857   n\k| 0      1      2     3     4   5  6 7
%e A392857   ---+-------------------------------------
%e A392857    0 | 1
%e A392857    1 | 0      1
%e A392857    2 | 0      2      1
%e A392857    3 | 0     12      6     1
%e A392857    4 | 0    122     60    12     1
%e A392857    5 | 0   1740    850   180    20   1
%e A392857    6 | 0  31922  15540  3390   420  30  1
%e A392857    7 | 0 715932 347774 77280 10150 840 42 1
%o A392857 (Python)
%o A392857 from math import comb, factorial as fact
%o A392857 C=lambda n,k: int(k>=0) and comb(n,k) if n>=0 else (-1)**(-n-k)*C(~k,~n) if k<0 else (-1)**k*C(k+~n,k)
%o A392857 rsubset=lambda r, n, k: k>=r and sum((-1)**(k-r-i)*comb(k-r, i)*(i+r)**(n-r) for i in range(k-r+1))//fact(k-r)
%o A392857 T=lambda n, k: sum(fact(2*j)//fact(j)*C(n+j-1, k-1)*rsubset(-j, n-k, j) for j in range(n-k+1))
%o A392857 (Python)
%o A392857 N = 7; weights = [A058349(n) for n in range(N+1)]
%o A392857 WeightedSetPartitionTransform(weights, N) # function defined in A394559
%o A392857 # _Peter Luschny_, Mar 29 2026
%Y A392857 Cf. A048172, A058349 (formerly A048173), A048174, A199916.
%K A392857 nonn,tabl,new
%O A392857 0,5
