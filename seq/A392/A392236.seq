%T A392236 330,331,336,337,390,391,392,393,2238,2239,2268,2269,2282,2283,2288,
%U A392236 2289,2364,2365,2394,2395,2406,2407,2408,2409,2454,2455,2456,2457,2468,2469,2498,2499
%N A392236 Positions of zeros in A309983.
%H A392236 Paolo Xausa, <a href="/A392236/b392236.txt">Table of n, a(n) for n = 1..10000</a>
%F A392236 a(2*k) = 2*A392980(k), for k >= 1.
%F A392236 a(2*k+1) = 2*A392980(k) + 1, for k >= 1.
%t A392236 A392236Q[k_] := Total[#*Range[Length[#], 1, -1]] == 0 & [2*Most[IntegerDigits[k, 2]] - 1];
%t A392236 Select[Range[2500], A392236Q]
%o A392236 (Python)
%o A392236 from itertools import count, islice
%o A392236 def A392236_gen(): # generator of terms
%o A392236     yield 1
%o A392236     for n in count(2):
%o A392236         if not (m:=n.bit_length()+1)&2 and (sum(i if j == '1' else 0 for i, j in enumerate(bin(n)[:1:-1],1))<<2)==m*(m-1):
%o A392236             yield n<<1
%o A392236             yield (n<<1)|1
%o A392236 A392236_list = list(islice(A392236_gen(),40)) # _Chai Wah Wu_, Mar 07 2026
%Y A392236 Cf. A309983, A392980.
