%U A392492 59796271,143950087,215345231,249369101,5054221,175062593,4646101,538122367,423938387,1075895291,1109440441
%N A392492 a(n) is the smallest p-composable number where p = prime(n).
%C A392492 For the definition of a p-composable number see A392440.
%H A392492 Peter Luschny, <a href="https://github.com/PeterLuschny/Gists/blob/main/ComposableRigidSparse.ipynb">Composable, rigid, and sparse numbers</a>. A Python notebook.
%e A392492 12 is 2-composable as it can be written as the sum of a subset of the divisors of 12 that are > 1 and < 12, namely as 2 + 4 + 6, and {2, 4} is a subset drawn from divisors strictly smaller than 12/2.
%e A392492 .
%e A392492 In the table the minimal p-composable n is given and the lex-earliest witness is shown in form: (lex-earliest witness of n/p) + (p-1)*(n/p).
%e A392492       n = smallest
%e A392492   p  |p-composable| n / p  | lexicographically-earliest sum witness
%e A392492   --------------------------------------------------------------------
%e A392492   2  |     12     |     6  |  2 +   4 +    6;
%e A392492   3  |    135     |    45  |  3 +  15 +   27 +    90;
%e A392492   5  |   1645     |   329  |  5 +   7 +   35 +    47 +   235 +    1316;
%e A392492   7  |  14651     |  2093  |  7 +  23 +  299 +   637 +  1127 +   12558;
%e A392492   11 |   8041     |   731  | 11 +  17 +   43 +   187 +   473 +    7310;
%e A392492   13 | 175253     | 13481  | 17 +  61 +  221 +  2873 + 10309 +  161772;
%e A392492   17 | 115957     |  6821  | 17 +  19 +  323 +   359 +  6103 +  109136;
%o A392492 (Python) # Function 'is_composable' is defined in A392440.
%o A392492 # Implement function 'smallest_prime_divisor' A020639, trial division is sufficient.
%o A392492 from sympy import sieve
%o A392492 def first_p_composable(p: int, limit: int = 10**12) -> int | None:
%o A392492     if p == 2: return 12
%o A392492     for n in range(p*p, limit + 1, 2 * p):
%o A392492         if smallest_prime_divisor(n) != p: continue
%o A392492         if is_composable(n): return n
%o A392492     return None
%o A392492 def A392492_list(upto: int) -> list[int | None]:
%o A392492     return [first_p_composable(p) for p in sieve.primerange(2, upto + 1)]
%o A392492 print(A392492_list(113))
%Y A392492 Cf. A392440, A392438 (p=2), A392437 (p=3), A020639.
%K A392492 nonn,new
%O A392492 1,1
