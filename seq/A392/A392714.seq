%S A392714 1,2,90,586656,1915103977500,7886133184567796056800,
%T A392714 85873408332103907284746052081828368,
%U A392714 4594491123326092088701002220876785865521537220214784,2059560342372549855311520646192231857828658156995213197895311773186910208
%N A392714 a(n) is the positive integer such that Sum_{sigma in S_{2n}} sign(sigma) * w_{sigma(1)}*D^n o w_{sigma(2)}*D^n o ... o w_{sigma(2n)}*D^n = a(n) * Wronskian(w_1,...,w_{2n}) * D^n, where D = d/dx and w_1,...,w_{2n} are smooth functions on the real line.
%C A392714 The case n=1 recovers the Lie bracket of two vector fields, giving a(1)=1.
%C A392714 Only "late-growing" permutations contribute to the sum; the number of contributing permutations in S_{2n} equals A147681(2n).
%C A392714 For prime p, p^(p-1) divides a(p) (proved). Conjecture: the p-adic valuation of a(p) equals exactly p-1 for every prime p.
%C A392714 Among the contributing permutations, the counts of even and odd permutations differ by exactly 1 for n <= 6; conjectured to hold for all n.
%H A392714 Sean A. Irvine, <a href="/A392714/b392714.txt">Table of n, a(n) for n = 1..13</a>
%H A392714 A. V. Kiselev, <a href="https://doi.org/10.1088/1742-6596/3152/1/012044">Wronskians as n-ary brackets in finite-dimensional analogues of sl(2)</a>, J. Phys.: Conf. Ser. 3152 (2025), 012044.
%H A392714 K. C. Shah and A. V. Kiselev, <a href="https://arxiv.org/abs/2605.11137">The alternating compositions of weighted differential operators yield the weights' Wronskian with which constant?</a>, arXiv:2605.11137 [math.CO], 2026.
%F A392714 a(n) * Product_{k=0..2n-1} k! = Sum_{sigma in Phi_n} sign(sigma) * Product_{k=1..2n-1} E_k!/(E_k - n)!, where E_k = Sum_{j=0..k-1} (sigma(2n-j) - 1) - (k-1)*n and Phi_n is the set of permutations of {1,...,2n} with sigma(1)=1 and E_k >= n for all k. See Shah-Kiselev link, Claim 4.1.
%e A392714 For n = 2, the three contributing permutations of {1,2,3,4} are (1,2,3,4), (1,2,4,3), (1,3,2,4), giving a(2) = (3!*3!*2! - 3!*2!*2! - 3!*2!*2!)/(3!*2!*1!) = 2.
%o A392714 (Python)
%o A392714 from math import prod, factorial
%o A392714 from functools import lru_cache
%o A392714 def a(n):
%o A392714     N = 2*n
%o A392714     @lru_cache(maxsize=None)
%o A392714     def b(avail, s, d):
%o A392714         if d == N-1: return 1
%o A392714         t = 0
%o A392714         for i, e in enumerate(avail):
%o A392714             ns = s + e - n - 1
%o A392714             if ns < 0: continue
%o A392714             sgn = -1 if (len(avail)-1-i) & 1 else 1
%o A392714             t += sgn*prod(range(ns+1, ns+n+1))*b(avail[:i]+avail[i+1:], ns, d+1)
%o A392714         return t
%o A392714     return abs(b(tuple(range(2, N+1)), 0, 0))//prod(factorial(k) for k in range(N))
%o A392714 print([a(n) for n in range(1, 8)])
%Y A392714 Cf. A147681.
%K A392714 nonn,hard,new
