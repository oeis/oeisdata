%N A392106 Concatenation of binary words using letters 1 and 2, in numerical order.
%F A392106 a(n) = 1 + A076478(n).
%e A392106 The first seven words are 1,2,11,12,21,22,111.
%t A392106 d[n_] := 1 + Rest@IntegerDigits[n + 1, 2] + 1; -1 + Flatten[Array[d, 50]]
%o A392106 (Python)
%o A392106 from oeis_sequences.OEISsequences import bisection, bsearch
%o A392106 def A392106(n):
%o A392106     def g(x): return x+(x-1<<x+1)+2
%o A392106     def f(x): return n+1+bsearch(g,x)
%o A392106     a = bisection(f,n+1,n+1)-n
%o A392106     q, r = divmod(n-(a-2<<a)-2,a)
%o A392106     return 1+int(format(q,'0'+str(a)+'b')[r]) # _Chai Wah Wu_, Mar 03 2026
%Y A392106 Cf. A007931, A076478, A392107.
