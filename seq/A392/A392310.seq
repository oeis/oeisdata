%U A392310 9,8,8,1,4,0,3,0,2,2,3,5,7,7,6,9,5,0,6
%N A392310 Decimal expansion of the continued fraction [sigma*(1), sigma*(2), sigma*(3), sigma*(4), ...], where sigma*(k) is the sum of antidivisors of k.
%C A392310 0.432262081510854951985079559730... = [0, 0, 2, 3, 5, 4, 10, 8, 8, 14, 12, 13, 19, 16, 18, ...]
%p A392310 with(numtheory): A:=proc(w) local j,k; k:=0; j:=w; while j mod 2<>1 do k:=k+1; j:=j/2; od;
%p A392310 sigma(2*w+1)+sigma(2*w-1)+sigma(w/2^k)*2^(k+1)-6*w-2; end:
%p A392310 P:=proc(q) local a,n; a:=A(q+1); for n from q by -1 to 3 do a:=1/a+A(n); od;
%p A392310 print(evalf(1/a,100)); end: P(10^3);
