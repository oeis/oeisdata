%T A392326 983,1019,1049,1097,1259,1307,1559,1583,1637,2111,2267,2411,2477,2531,
%U A392326 2543,2609,2621,2687,2699,2753,2777,2789,2843,2909,2963,3119,3491,4889,5087
%N A392326 Low points occurring in A392975.
%C A392326 Low points are those elements of A392975 that occur after a series of increasing terms.
%H A392326 James C. McMahon, <a href="/A392326/b392326.txt">Table of n, a(n) for n = 1..1000</a>
%e A392326 A392975 begins: 0, 1, 2, 3, 6, 9, 7, 14, 21, 28, 13, 26... The first term that is lower than the previous term is 7. A392975 then increases to 14, 21, 28. The next term that is lower than its predecessor is 13.
%e A392326 Let s = A392975.
%e A392326 Table of n, a(n) for n = 1..12:
%e A392326    n           a(n)              Series of increasing terms before a(n) in s
%e A392326 ----------------------------------------------------------------------------
%e A392326    1    s(7) =   7 = prime(4)    {0, 1, 2, 3, 6, 9, 7}
%e A392326    2   s(11) =  13 = prime(6)    {14, 21, 28, 13}
%e A392326    3   s(15) =  17 = prime(7)    {26, 39, 52, 17}
%e A392326    4   s(18) =  19 = prime(8)    {34, 51, 19}
%e A392326    5   s(21) =  23 = prime(9)    {38, 57, 23}
%e A392326    6   s(25) =  29 = prime(10)   {46, 69, 92, 29}
%e A392326    7   s(33) =  59 = prime(17)   {58, 87, 116, 145, 174, 203, 232, 59}
%e A392326    8   s(45) = 107 = prime(28)   {118, 177, ..., 708, 107}
%e A392326    9   s(57) = 137 = prime(33)   {214, 321, ..., 1284, 137}
%e A392326   10   s(68) = 173 = prime(40)   {274, 411, ..., 1507, 173}
%e A392326   11   s(83) = 257 = prime(55)   {346, 519, ..., 2595, 257}
%e A392326   12   s(98) = 293 = prime(62)   {514, 771, ..., 3855, 293}
%t A392326 a392326 = Block[{a, c, f, g, j, k, s, nn}, nn = 1000; c[_] := True; f[x_] := f[x] = FactorInteger[x][[-1, 1]]; a = Range[0, 2]; Map[Set[c[#], True] &, a]; j = Last[a]; s = Total[a]; g = 0; Until[c[g], g++]; Reap[Do[Set[{k, g}, {#*Ceiling[g/#], #} &[f[s] ] ]; While[Nand[c[k], f[k] == g], k += g]; If[j > k, Sow[k]]; s += k; Set[{c[k], j}, {False, k}], {n, Length[a], nn}] ][[-1, 1]] ]
%Y A392326 Cf. A006530, A392975.
