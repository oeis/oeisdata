%S A392024 2,6,9,10,14,20,22,26,28,30,32,34,38,42,44,45,46,48,50,52,54,58,62,63,
%T A392024 66,68,70,74,75,76,78,82,86,92,94,98,99,102,106,110,112,114,116,117,
%U A392024 118,122,124,130,134,138,142,144,146,147,148,153,154,158,162,164,166
%N A392024 Positive integers k such that gcd(k, tau(k)) is prime.
%C A392024 2 is the only prime in the sequence since for any odd prime k, tau(k) = 2 and gcd(k, 2) = 1, which is not prime, and gcd(2, 2) = 2, which is prime.
%C A392024 k is a term if A009191(k) is prime.
%e A392024 For k = 6: tau(6) = 4 and gcd(6, 4) = 2, which is prime, so 6 is a term.
%e A392024 For k = 8: tau(8) = 4 and gcd(8, 4) = 4, which is not prime, so 8 is not a term.
%t A392024 q[k_] := PrimeQ[GCD[k, DivisorSigma[0, k]]]; Select[Range[166], q] (* _Amiram Eldar_, Mar 24 2026 *)
%o A392024 (Python)
%o A392024 from sympy import divisor_count, gcd, isprime
%o A392024 def ok(k): return isprime(gcd(k, divisor_count(k)))
%o A392024 print([k for k in range(1, 200) if ok(k)])
%o A392024 (PARI) isok(k) = isprime(gcd(k, numdiv(k))); \\ _Michel Marcus_, Mar 24 2026
%Y A392024 Cf. A000005, A009191, A033950, A392199.
%Y A392024 A036878 is a subsequence.
