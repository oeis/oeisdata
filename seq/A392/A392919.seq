%N A392919 Number of partitions p of n such that (maximal multiplicity of the parts of p) <= (minimal part of p).
%F A392919 G.f.: Sum_{j>=1} q^j*(1-q^(j^2))/(1-q^j) * Product_{k>=j+1} (1-q^((j+1)*k))/(1-q^k).
%e A392919 a(8) counts these 9 partitions: 8, 71, 62, 53, 521, 44, 431, 422, 332.
%o A392919 (PARI) my(N=60, q='q+O('q^N)); Vec(sum(j=1, N, q^j*(1-q^j^2)/(1-q^j)*prod(k=j+1, N, (1-q^((j+1)*k))/(1-q^k))))
