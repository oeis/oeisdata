%U A392513 6,8,5,4,3,8,6,5,4,2,8,3,0,9,1,6,2,3,4,3,6,8,4,3,2,0,1,0,7,2,5,2,4,6,5,9,1
%N A392513 Decimal expansion of the average Euclidean distance between two randomly picked points, one of which is located in a unit cube and the other in an adjacent unit cube, both axis-parallel, with the two cubes sharing one common edge.
%H A392513 Lee David Chung Lin, <a href="https://math.stackexchange.com/questions/2793350/mean-distance-between-2-points-in-adjacent-voxels-cubes">Mean distance between 2 points in adjacent voxels (cubes)</a>, Mathematics Stack Exchange, 2018.
%F A392513 From _Amiram Eldar_, Mar 21 2026: (Start)
%F A392513 Equals (-1798 + 1156*sqrt(2) - 36*sqrt(3) + 30*sqrt(5) + 162*sqrt(6) + 84*Pi + 84*arccos(4/5) - 336*arccos(sqrt(2/5)) - 2016*log(phi) + 252*log(2+sqrt(3)) + 1470*log((sqrt(6)-1)/sqrt(5)) - 2688*arcsec(5) + 2688*arctan(3) + 1428*log(1+sqrt(2)) - 63*log(2+sqrt(5)) - 336*log(sqrt(2) + sqrt(3)) + 1344*log(2) + (735*log(5))/2)/630, where phi is the golden ratio (A001622).
%F A392513 Equals 5*A073012 - A392512 - A392514/3. (End)
%e A392513 1.531847122327893544737888637719784...
%t A392513 e[a_, b_, c_] := Module[{r = Sqrt[a^2 + b^2 + c^2], r1 = Sqrt[b^2 + c^2], r2 = Sqrt[c^2 + a^2], r3 = Sqrt[a^2 + b^2]},
%t A392513   2*r/15 - (7/45)*((r - r1)*(r1/a)^2 + (r - r2)*(r2/b)^2 + (r - r3)*(r3/c)^2) + (8/(315*(a*b*c)^2))*(a^7 + b^7 + c^7 -
%t A392513   r1^7 - r2^7 - r3^7 + r^7) + (1/(15*a*(b*c)^2))*(b^6*ArcSinh[a/b] +
%t A392513   c^6*ArcSinh[a/c] - r1^2*(r1^4 - 8*(b*c)^2)*ArcSinh[a/r1]) + (1/(15*b*(c*a)^2))*(c^6*ArcSinh[b/c] +
%t A392513   a^6*ArcSinh[b/a] - r2^2*(r2^4 - 8*(c*a)^2)*ArcSinh[b/r2]) + (1/(15*c*(a*b)^2))*(a^6*ArcSinh[c/a] +
%t A392513   b^6*ArcSinh[c/b] - r3^2*(r3^4 - 8*(a*b)^2)*ArcSinh[c/r3]) - (4/(15*a*b*c))*(a^4*ArcSin[b*c/(r2*r3)] +
%t A392513   b^4*ArcSin[c*a/(r3*r1)] + c^4*ArcSin[a*b/(r1*r2)])];
%t A392513 RealDigits[4*(e[1, 1, 1/2] - e[1, 1/2, 1/2]) + e[1/2, 1/2, 1/2], 10, 120][[1]] (* _Amiram Eldar_, Jan 20 2026 *)
%o A392513 (PARI) my(phi = quadgen(5)); (-1798 + 1156*sqrt(2) - 36*sqrt(3) + 30*sqrt(5) + 162*sqrt(6) + 84*Pi + 84*acos(4/5) - 336*acos(sqrt(2/5)) - 2016*log(phi) + 252*log(2+sqrt(3)) + 1470*log((sqrt(6)-1)/sqrt(5)) - 2688*acos(1/5) + 2688*atan(3) + 1428*log(1+sqrt(2)) - 63*log(2+sqrt(5)) - 336*log(sqrt(2) + sqrt(3)) + 1344*log(2) + (735*log(5))/2)/630 \\ _Amiram Eldar_, Mar 21 2026
