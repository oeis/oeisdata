%N A392460 Number of transitive relations on an n-set with exactly seven ordered pairs.
%C A392460 a(n) is odd if and only if n = 8*k + 7 for some nonnegative integer k.
%H A392460 Paolo Xausa, <a href="/A392460/b392460.txt">Table of n, a(n) for n = 0..10000</a>
%H A392460 <a href="/index/Rec#order_15">Index entries for linear recurrences with constant coefficients</a>, signature (15,-105,455,-1365,3003,-5005,6435,-6435,5005,-3003,1365,-455,105,-15,1).
%F A392460 a(n) = 6*C(n,3) + 644*C(n,4) + 18550*C(n,5) + 237210*C(n,6) + 1748587*C(n,7) + 8279224*C(n,8) + 26645976*C(n,9) + 59729040*C(n,10) + 92862000*C(n,11) + 96465600*C(n,12) + 60540480*C(n,13) + 17297280*C(n,14).
%e A392460 a(2) = 0 as there are no transitive relations on a 2-set with exactly seven ordered pairs.
%t A392460 A392460[n_] := Total[{6, 644, 18550, 237210, 1748587, 8279224, 26645976, 59729040, 92862000, 96465600, 60540480, 17297280}*Binomial[n, Range[3, 14]]];
%t A392460 Array[A392460, 25, 0] (* or *)
%t A392460 LinearRecurrence[{15, -105, 455, -1365, 3003, -5005, 6435, -6435, 5005, -3003, 1365, -455, 105, -15, 1}, {0, 0, 0, 6, 668, 21830, 358290, 3821357, 29994016, 186452712, 963208980, 4276890420, 16732331484, 58779532526, 188192800406}, 25] (* _Paolo Xausa_, Mar 24 2026 *)
