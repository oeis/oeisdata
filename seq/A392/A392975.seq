%S A392975 0,1,2,3,6,9,7,14,21,28,13,26,39,52,17,34,51,19,38,57,23,46,69,92,29,
%T A392975 58,87,116,145,174,203,232,59,118,177,236,295,354,413,472,531,590,649,
%U A392975 708,107,214,321,428,535,642,749,856,963,1070,1177,1284,137,274
%N A392975 A Sisyphus sequence: a(0) = 0, a(1) = 1, a(2) = 2; for n > 2, a(n) is the smallest unused positive integer having the same greatest prime factor as the sum of the previous terms.
%C A392975 Low points (A392326) occur at: 7, 13, 17, 19, 23, 29, 59, 107, 137, 173, 257, 293, 467, 503...
%C A392975 Through n = 200000, low points are prime. Are all low points prime?
%C A392975 Beginning at n = 3 and through at least n = 200000, the common greatest prime factors repeat in runs of 3+. For example, the factor 587 repeats 27 times. Common greatest prime factors begin: 3, 3, 3, 7, 7, 7, 7, 13, 13, 13, 13...
%H A392975 Michael De Vlieger, <a href="/A392975/b392975.txt">Table of n, a(n) for n = 0..10000</a>
%H A392975 Michael De Vlieger, <a href="/A392975/a392975.png">Log log scatterplot of a(n)</a> for n = 1..2^20.
%H A392975 James C. McMahon, <a href="/A392975/a392975.pdf">Plot of a(n)</a> for n = 1..300.
%e A392975 For n = 3, the greatest prime factor of the sum of the previous terms (3) is 3. The next unused integer with the same greatest prime factor is 3.
%e A392975 For n = 4, the greatest prime factor of the sum of the previous terms (6) is 3. The next unused integer with the same greatest prime factor is 6.
%e A392975 For n = 6, the greatest prime factor of the sum of the previous terms (21) is 7. The next unused integer with the same greatest prime factor is 7.
%t A392975 s={0,1,2};Do[i=1;Until[!MemberQ[s,i]&&FactorInteger[Total[s]][[-1,1]]==FactorInteger[i][[-1,1]],i++];AppendTo[s,i],{j,55}];s
%t A392975 (* Alternative: *)
%t A392975 Block[{a, c, f, g, k, s, u, nn}, nn = 120; c[_] := True; f[x_] := f[x] = FactorInteger[x][[-1, 1]]; a = Range[0, 2]; Map[Set[c[#], True] &, a]; s = Total[a]; g = 0; Until[c[g], g++]; a~Join~Reap[Do[Set[{k, g}, {#*Ceiling[g/#], #} &[f[s] ] ]; While[Nand[c[k], f[k] == g], k += g]; Sow[k]; s += k; Set[c[k], False], {n, Length[a], nn}] ][[-1, 1]] ] (* _Michael De Vlieger_, Mar 29 2026 *)
%o A392975 (Python)
%o A392975 from sympy import factorint
%o A392975 from itertools import count, islice
%o A392975 def agen(): # generator of terms
%o A392975     aset, s = {0, 1, 2}, 3
%o A392975     yield from sorted(aset)
%o A392975     while True:
%o A392975         p = max(factorint(s))
%o A392975         an = next(k for k in count(p, p) if k not in aset)
%o A392975         yield an
%o A392975         aset.add(an)
%o A392975         s += an
%o A392975 print(list(islice(agen(), 58))) # _Michael S. Branicky_, Mar 29 2026
%Y A392975 Cf. A006530; other variants using Gpf(n): A364246, A364280, A374404, A376865, A377193, A378233, A379044. Low points: A392326.
