%N A392386 Numbers k such that omega(2*k) = omega(k + 2), where omega = A001221.
%H A392386 Robert Israel, <a href="/A392386/b392386.txt">Table of n, a(n) for n = 1..10000</a>
%e A392386 10 is a term because omega(20) = omega(12).
%p A392386 filter:= proc(k) NumberTheory:-Omega(2*k,distinct) = NumberTheory:-Omega(k+2,distinct) end proc:
%p A392386 select(filter, [$1..1000]); # _Robert Israel_, May 14 2026
%t A392386 Select[Range[200], PrimeNu[2*#] == PrimeNu[# + 2] &] (* _Amiram Eldar_, Jan 09 2026 *)
%o A392386 (Magma) [k: k in [1..170] | #PrimeDivisors(2*k) eq #PrimeDivisors(k + 2)];
