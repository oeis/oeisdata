%S A392497 20,45,175,1001,1573,4199,5491,12673,20677,26071,47027,65231,72283,
%T A392497 107113,146969,190747,212341,290177,347261,367993,478661,583573,
%U A392497 716539,871933,1009091,1050703,1201289,1247941,1564259,1879981,2279269,2494633,2608891,3127361,3352351
%N A392497 a(n) is the smallest p-rigid number where p = prime(n).
%C A392497 For the definition of a p-rigid number see A392499.
%H A392497 Peter Luschny, <a href="https://github.com/PeterLuschny/Gists/blob/main/ComposableRigidSparse.ipynb">Composable, rigid, and sparse numbers</a>. A Python notebook.
%o A392497 (Python) # Function 'is_rigid' is defined in A392499 (see also links).
%o A392497 from sympy import isprime as is_prime
%o A392497 def first_p_rigid(p: int, limit: int = 10**12) -> int | None:
%o A392497     if not is_prime(p): return None
%o A392497     step = p if p == 2 else 2 * p
%o A392497     for n in range(p*p, limit + 1, step):
%o A392497         if p != is_rigid(n): continue
%o A392497         return n
%o A392497     return None
%o A392497 def A392497_list(upto: int) -> list[int]:
%o A392497     return [c for n in range(2, upto) if (c := first_p_rigid(n)) is not None]
%o A392497 print(A392497_list(150))
%Y A392497 Cf. A392499, A392496 (p=2), A392495 (p=3).
%K A392497 nonn,new
%O A392497 1,1
%A A392497 _Peter Luschny_, Jan 16 2026
