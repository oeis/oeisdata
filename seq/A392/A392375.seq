%N A392375 Numbers k such that k is coprime to each of its digits and to the sum of its digits.
%H A392375 Vincenzo Manto, <a href="/A392375/b392375.txt">Table of n, a(n) for n = 1..9999</a>
%t A392375 q[k_] := With[{d = IntegerDigits[k]}, AllTrue[d, CoprimeQ[k, #] &] && CoprimeQ[Total[d], k]]; Select[Range[270], q] (* _Amiram Eldar_, Apr 13 2026 *)
%o A392375 (Python)
%o A392375 from math import gcd
%o A392375 def ok(n):
%o A392375     digs = list(map(int, str(n)))
%o A392375     return all(gcd(n, d) == 1 for d in digs) and gcd(n, sum(digs)) == 1
%o A392375 print([k for k in range(333) if ok(k)]) # _Michael S. Branicky_, Apr 08 2026
%o A392375 (PARI) select( {is_A392375(n)=!foreach(Set(concat(digits(n),sumdigits(n))),d,gcd(n,d)>1&&return)}, [1..333]) \\ _M. F. Hasler_, Apr 09 2026
%Y A392375 Intersection of A061116 and A339076.
