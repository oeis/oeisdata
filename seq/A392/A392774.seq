%I A392774 #97 Mar 10 2026 23:48:12
%S A392774 14,15,33,35,46,51,55,54,56,62,69,77,66,70,87,95,94,115,119,102,110,
%T A392774 114,135,118,145,123,143,132,140,138,154,165,141,155,161,142,159,187,
%U A392774 158,177,203,209,166,205,221,174,184,190,182,195,186,231,204,220,224,213,235,253
%N A392774 Irregular triangle read by rows; integers with identical (tau, sigma) values occurring at least twice, rows ordered by their smallest term.
%C A392774 A positive integer does not appear if its (tau, sigma) pair is unique.
%H A392774 Felix Huber, <a href="/A392774/b392774.txt">Rows 1 to 2662, flattened</a>
%e A392774 14 and 15 are in a row since tau(14) = tau(15) = 4 and sigma(14) = sigma(15) = 24.
%e A392774 46, 51 and 55 are in a row since tau(46) = tau(51) = tau(55) = 4 and sigma(46) = sigma(51) = sigma(55) = 72.
%e A392774 16 is not in the sequence because its (tau, sigma) pair (5, 31) is unique.
%e A392774 The triangle begins:
%e A392774    14   15
%e A392774    33   35
%e A392774    46   51   55
%e A392774    54   56
%e A392774    62   69   77
%e A392774    66   70
%e A392774    87   95
%e A392774    94  115  119
%e A392774   102  110
%e A392774   114  135
%e A392774   118  145
%e A392774   123  143
%e A392774   132  140
%e A392774   138  154  165
%e A392774   141  155  161
%e A392774   142  159  187
%e A392774   158  177  203  209
%e A392774   166  205  221
%e A392774   174  184  190
%e A392774   182  195
%e A392774   186  231
%e A392774   204  220  224
%e A392774   213  235  253
%p A392774 with(NumberTheory):
%p A392774 L := proc(N) # All rows with smallest number <= N
%p A392774     local t, k, d, i, m;
%p A392774     m := max(seq(sigma(k), k = 1 .. N)) - 1;
%p A392774     t := table();
%p A392774     for k to m do
%p A392774         d := [tau(k), sigma(k)];
%p A392774         if assigned(t[d]) then
%p A392774             t[d] := [op(t[d]), k]
%p A392774         else
%p A392774             t[d] := [k]
%p A392774         end if
%p A392774     end do;
%p A392774     sort([seq(`if`(nops(t[op(i)]) > 1 and t[op(i)][1] <= N, t[op(i)], NULL), i in indices(t))], (x, y) -> x[1] < y[1]);
%p A392774 end proc:
%p A392774 T := proc(N) local l, w, i, j; l := L(N); w := 0; for i in l do for j to nops(i) do w := max(w, length(convert(i[j], string))); end do; end do; w := w + 2; for i in l do for j to nops(i) do printf(cat("%", w, "d"), i[j]); end do; printf("\n"); end do; end proc:
%p A392774 A392774 := proc(N) local i; seq(op(i), i in L(N)) end proc:
%p A392774 A392774(213); L(213); T(213);
