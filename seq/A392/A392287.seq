%S A392287 1,2,4,8,16,32,64,128,255,510,1020,2039,4076,8147,16285,32561,65110,
%T A392287 130203,260389,520753,1041477,2082910,4165757,8331421,16662721,
%U A392287 33325268,66650300
%N A392287 Number of distinct descendants of [1] in the n-th degree, where a list L has two children: L with a 1 appended; L + (L reversed).
%C A392287 The sequence starts like the powers of 2 and then duplicate descendants start to appear at n=8: [4,5,4,4,5,4] is both [1,1,1,3,4,3]+[3,4,3,1,1,1] and [1,3,2,2,2,3]+[3,2,2,2,3,1] but is only counted once; in imaged terms, a child can have several parents.
%e A392287 n=
%e A392287   0     1      2       3      ...
%e A392287                +---[1,1,1,1]
%e A392287                |
%e A392287         +---[1,1,1]
%e A392287         |      |
%e A392287         |      +----[2,2,2]
%e A392287         |
%e A392287   +---[1,1]
%e A392287   |     |
%e A392287   |     |      +----[2,2,1]
%e A392287   |     |      |
%e A392287   |     +----[2,2]
%e A392287   |            |
%e A392287   |            +-----[4,4]
%e A392287   |
%e A392287  [1]                          ...
%e A392287   |
%e A392287   |            +----[2,1,1]
%e A392287   |            |
%e A392287   |     +----[2,1]
%e A392287   |     |      |
%e A392287   |     |      +-----[3,3]
%e A392287   |     |
%e A392287   +----[2]
%e A392287         |
%e A392287         |      +-----[4,1]
%e A392287         |      |
%e A392287         +-----[4]
%e A392287                |
%e A392287                +------[8]
%e A392287 a(n)=
%e A392287   1     2      4       8    ...
%p A392287 b:= proc(n) option remember; `if`(n=0, {[1]}, map(l->
%p A392287       [[l[], 1], l+ListTools[Reverse](l)][], b(n-1)))
%p A392287     end:
%p A392287 a:= n-> nops(b(n)):
%p A392287 seq(a(n), n=0..20);  # _Alois P. Heinz_, Mar 04 2026
%o A392287 (Python)
%o A392287 from itertools import islice
%o A392287 def agen(): # generator of terms
%o A392287     reach = {(1,)}
%o A392287     while True:
%o A392287         yield len(reach)
%o A392287         out = set()
%o A392287         for L in reach:
%o A392287             out.add(L+(1,))
%o A392287             out.add(tuple(t+r for t, r in zip(L, L[::-1])))
%o A392287         reach = out
%o A392287 print(list(islice(agen(), 22))) # _Michael S. Branicky_, Mar 18 2026
