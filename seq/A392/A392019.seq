%I A392019 #24 May 22 2026 00:22:13
%S A392019 0,0,0,0,0,0,0,0,0,7,0,0,0,0,0,11,0,13,0,0,8,13,0,17,12,13,13,5,17,7,
%T A392019 19,9,12,11,11,7,11,17,15,14,17,17,19,13,13,19,23,17,17,7,7,8,15,7,8,
%U A392019 8,9,11,18,12,14,19,16,11,12,12,13,15,19,17,20,13,19
%N A392019 If binomial(n,k) = u*v where the only primes dividing u are <= k and the only primes dividing v are > k, then a(n) is the least k such that u > n^2, or 0 if such a k doesn't exist.
%H A392019 Thomas Bloom, <a href="https://www.erdosproblems.com/684">Problem #684</a>, Erdős Problems.
%H A392019 Paul Erdős, <a href="https://users.renyi.hu/~p_erdos/1979-23.pdf">Some unconventional problems in number theory</a>, Acta Math. Acad. Sci. Hungar. (1979), 71-80.
%e A392019 a(10)=7 because binomial(10,7) = 120 and 120 = 2^3*3*5 > 100 = 10^2.
%e A392019 a(21)=8 because binomial(21,8) = 203490 = 630*323 and 630 = 2*3^2*5*7 > 441 = 21^2.
%t A392019 u[n_,k_]:=Times@@Power@@@Select[FactorInteger[Binomial[n,k]],#[[1]]<=k&];
%t A392019 a[n_]:=Append[Select[u[n,#]&/@Range[n],#>n^2&->"Index",1],0][[1]];
%o A392019 (PARI)
%o A392019 a(n)={my(uv,f,u);for(k=0,n,uv=binomial(n,k);
%o A392019   f=factor(uv);u=1;for(i=1,matsize(f)[1],if(f[i,1]<=k,u*=f[i,1]^f[i,2];););
%o A392019   if(u>n^2,return(k);););return(0);};
%Y A392019 Cf. A007318.
%K A392019 nonn
%O A392019 1,10
%A A392019 _Elijah Beregovsky_, Dec 27 2025
%E A392019 a(7) corrected by _Tomás Oliveira e Silva_, Apr 29 2026
