%N A392128 E.g.f. A(x) satisfies A(x) = (1 + 5*x*A(x)^3)^(1/5).
%H A392128 Vincenzo Librandi, <a href="/A392128/b392128.txt">Table of n, a(n) for n = 0..350</a>
%F A392128 a(n) = 5^n * n! * binomial((3*n+1)/5,n)/(3*n+1).
%F A392128 a(5*n+3) = 0.
%t A392128 a[n_]:=If[n==0,1,Product[(3* n+1-5 *k),{k,0,n-1}]/(3 *n+1)]; Table[a[n],{n,0,25}] (* _Vincenzo Librandi_, Mar 26 2026 *)
%o A392128 (PARI) a(n) = 5^n*n!*binomial((3*n+1)/5, n)/(3*n+1);
%o A392128 (Magma) [n eq 0 select 1 else (5^n*&*[((3*n+1)/5-k): k in [0..n-1] ])/(3*n+1): n in [0..23]]; // _Vincenzo Librandi_, Mar 26 2026
