%T A392779 30540,51442,85836,142809,237876,396590,660032,1093409,1800392,
%U A392779 2944809,4782820,7709207,12322508,19517477,30622829
%N A392779 Number of distinct coefficients in the expansion of x_1(x_1 + x_2)...(x_1 + x_2 + ... + x_n).
%e A392779 x_1(x_1 + x_2)(x_1 + x_2 + x_3) = x_1^3 + 2*x_1^2x_2 + x_1x_2^2 + x_1^2x_3 + x_1x_2x_3, so the distinct coefficients are 1 and 2. Therefore, a(3) = 2.
%o A392779 (Python)
%o A392779 from math import prod
%o A392779 from sympy import symbols, Poly
%o A392779 def A392779(n):
%o A392779     if n == 0: return 1
%o A392779     s = symbols('x_0:'+str(n))
%o A392779     return len(set(Poly(prod(sum(s[j] for j in range(i)) for i in range(1,n+1))).coeffs())) # _Chai Wah Wu_, Mar 30 2026
