%S A392378 1,1,0,1,1,0,1,2,1,0,1,3,3,3,0,1,4,6,8,15,0,1,5,10,16,37,101,0,1,6,15,
%T A392378 28,69,238,841,0,1,7,21,45,115,423,1923,8267,0,1,8,28,68,180,672,3310,
%U A392378 18508,93259,0,1,9,36,98,270,1006,5084,31152,205565,1184693,0
%N A392378 Square array A(n,k), n >= 0, k >= 0, read by antidiagonals downwards, where column k is the expansion of B(x)^k, where B(x) is the g.f. of A242003.
%H A392378 Seiichi Manyama, <a href="/A392378/b392378.txt">Antidiagonals n = 0..139, flattened</a>
%F A392378 A(n,0) = 0^n.
%F A392378 A(0,1) = A(1,1) = 1;   A(n,1) =         Sum_{j=1..n-1} A(j,1) * A(n-j,j).
%F A392378 For k > 1, A(0,k) = 1; A(n,k) = (1/n) * Sum_{j=1..n} ((k+1)*j-n) * A(j,1) * A(n-j,k).
%e A392378 Square array begins:
%e A392378   1,   1,    1,    1,    1,    1,     1, ...
%e A392378   0,   1,    2,    3,    4,    5,     6, ...
%e A392378   0,   1,    3,    6,   10,   15,    21, ...
%e A392378   0,   3,    8,   16,   28,   45,    68, ...
%e A392378   0,  15,   37,   69,  115,  180,   270, ...
%e A392378   0, 101,  238,  423,  672, 1006,  1452, ...
%e A392378   0, 841, 1923, 3310, 5084, 7350, 10242, ...
%o A392378 (PARI) a(n, k, m=1) = if(n*k<=1, k^n, if(k==1, m*sum(j=1, n-1, a(j, 1)*a(n-j, j)), sum(j=1, n, ((k+1)*j-n)*a(j, 1)*a(n-j, k))/n));
%Y A392378 Columns k=0..1 give A000007, A242003.
%Y A392378 Cf. A392379, A394047, A394901.
%K A392378 nonn,tabl
%O A392378 0,8
%A A392378 _Seiichi Manyama_, Apr 06 2026
