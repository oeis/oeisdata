%I A392653 #22 Mar 06 2026 06:46:35
%S A392653 945,1575,1890,2205,2835,3150,3465,4095,4410,4725,5355,5670,5775,5985,
%T A392653 6435,6615,6825,6930,7245,7425,7875,8085,8190,8415,8505,8925,9135,
%U A392653 9450,9555,9765,10395,10710,11025,11550,11655,11970,12285,12705,12870,12915,13230,13545
%N A392653 Numbers k for which there exists a subset of its odd nontrivial divisors that sum to k.
%C A392653 Subsequence of the semiperfect numbers A005835.
%H A392653 Robert Israel, <a href="/A392653/b392653.txt">Table of n, a(n) for n = 1..2700</a>
%H A392653 Peter Luschny, <a href="https://github.com/PeterLuschny/Gists/blob/main/ComposableRigidSparse.ipynb">Composable, rigid, and sparse numbers</a>. A Python notebook.
%e A392653 Let n = 5391411025 and D = {d | n, d < n, d % 2 = 1} and E = {14300825, 2042975, 142025, 805, 95, 25}. Then E is subset of D and sum(D \ E) = n. Note that 3 does not divide n.
%p A392653 filter:= proc(n) local D,S,d;
%p A392653   D:= select(type,NumberTheory:-Divisors(n) minus {1,n},odd);
%p A392653   S:= {0};
%p A392653   for d in D do
%p A392653     S:= S union select(`<=`,S +~ d, n);
%p A392653     if member(n,S) then return true fi;
%p A392653   od;
%p A392653   false
%p A392653 end proc:
%p A392653 select(filter, [$1..20000]); # _Robert Israel_, Mar 03 2026
%o A392653 (Python)  # The function 'subset_sum_exists' is defined in A392652.
%o A392653 from sympy import proper_divisors
%o A392653 def isA392653(n):
%o A392653     nums = [d for d in proper_divisors(n) if d % 2 == 1 and d > 1]
%o A392653     return subset_sum_exists(nums, n)
%o A392653 print([n for n in range(13546) if isA392653(n)])
%Y A392653 Cf. A392652 (even divisors), A005835.
%K A392653 nonn
%O A392653 1,1
%A A392653 _Peter Luschny_, Jan 24 2026
