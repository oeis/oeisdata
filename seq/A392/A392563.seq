%I A392563 #32 Mar 12 2026 15:54:43
%S A392563 1,4,44,88,299,898,776,1106,5008,4994,6325,5654,5104,6776,8888,8998,
%T A392563 9494,8585,10706,43444,11009,12625,26666,44554,50504,31211,53332,
%U A392563 66556,54443,54344,39998,11110,28888,67777,55556,32221,33332,91108,55564,89908,108088,106706,107062,89888,71110,66662
%N A392563 a(n) is the least number that can be written in exactly n ways as p + r, where p is a prime and r is an anagram of p.
%C A392563 Leading zeros are not allowed.
%H A392563 Robert Israel, <a href="/A392563/b392563.txt">Table of n, a(n) for n = 0..559</a>
%F A392563 A393958(a(n)) = n.
%e A392563 a(5) = 898 because 898 = 179 + 719 = 269 + 629 = 359 + 539 = 449 + 449 = 719 + 179 can be written in exactly 5 ways as the sum of a prime and an anagram of that prime, and 898 is the least number that works.
%p A392563 g:= proc(n) local d,F,i;
%p A392563   F:= convert(n,base,10); d:= nops(F);
%p A392563   map(t -> n + add(t[i]*10^(i-1),i=1..d), select( t -> t[-1] <> 0, combinat:-permute(F)))
%p A392563 end proc:
%p A392563 N:= 1000000: V:= Vector(N):
%p A392563 for p in select(isprime,[2,seq(i,i=3..N,2)]) do
%p A392563   v:= select(`<=`,g(p),N);
%p A392563   V[v]:= V[v]+~ 1
%p A392563 od:
%p A392563 R:= Array(0..max(V)):
%p A392563 for i from 1 to N do
%p A392563 if R[V[i]] = 0 then R[V[i]]:= i fi
%p A392563 od:
%p A392563 if not member(0,R,'k0') then k0:= max(V)+1 fi;
%p A392563 convert(R[0..k0-1],list);
%Y A392563 Cf. A393958.
%K A392563 nonn,base,look
%O A392563 0,2
%A A392563 _Robert Israel_, Mar 04 2026
