%N A392103 E.g.f. A(x) satisfies A(x) = (1 + 5*x*A(x)^2)^(1/5).
%H A392103 Vincenzo Librandi, <a href="/A392103/b392103.txt">Table of n, a(n) for n = 0..350</a>
%F A392103 a(n) = 5^n * n! * binomial((2*n+1)/5,n)/(2*n+1).
%F A392103 a(5*n+2) = 0.
%t A392103 a[n_]:=If[n==0,1,Product[(2*n+1-5*k),{k,0,n-1}]/(2*n+1)]; Table[a[n],{n,0,20}] (* _Vincenzo Librandi_, Mar 26 2026 *)
%o A392103 (PARI) a(n) = 5^n*n!*binomial((2*n+1)/5, n)/(2*n+1);
%o A392103 (Magma) [n eq 0 select 1 else (5^n/(2*n+1))*&*[((2*n+1)/5-k): k in [0..n-1]]: n in [0..25]]; // _Vincenzo Librandi_, Mar 26 2026
