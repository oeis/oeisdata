%N A392980 Positions of zeros in A393336.
%C A392980 The number of bits in each term is 0 or -1 (mod 4). - _Ruud H.G. van Tol_, Feb 28 2026
%H A392980 Paolo Xausa, <a href="/A392980/b392980.txt">Table of n, a(n) for n = 1..10000</a>
%F A392980 a(n) = A392236(2*n)/2.
%t A392980 A392980Q[k_] := Total[#*Range[Length[#], 1, -1]] == 0 & [2*IntegerDigits[k, 2] - 1];
%t A392980 Select[Range[2500], A392980Q]
%o A392980 (PARI) lista(len) = len<1 && return([]); my(r=List(), b); for(i=1, oo, #(b=binary(i))%4%3 && (i+=2^(#b-1)-1) && next; if(!(2*b*-[-#b..-1]~ - binomial(#b+1, 2)), listput(~r, i); #r<len||break)); Vec(r); \\ _Ruud H.G. van Tol_, Mar 02 2026
%o A392980 (Python)
%o A392980 from itertools import count, islice
%o A392980 def A392980_gen(startvalue=1): # generator of terms >= startvalue
%o A392980     return filter(lambda n: not (m:=n.bit_length()+1)&2 and (sum(i if j == '1' else 0 for i, j in enumerate(bin(n)[:1:-1],1))<<2)==m*(m-1), count(max(startvalue,1)))
%o A392980 A392980_list = list(islice(A392980_gen(),40)) # _Chai Wah Wu_, Mar 07 2026
