%I A392961 #63 Apr 17 2026 17:36:10
%S A392961 11,12,15,22,24,33,36,44,48,55,66,77,88,99,110,120,125,150,210,220,
%T A392961 240,250,312,315,330,360,375,416,420,440,480,510,520,525,550,612,624,
%U A392961 630,660,714,728,735,770,816,832,840,880,918,936,945,990,1010,1020,1040,1050,1100,1111,1122,1125,1144
%N A392961 Numbers k that are the concatenation of two divisors of k.
%C A392961 In contrast to A249766, leading zeros are not allowed.
%C A392961 Numbers of the form a*10^m + a*b where m >= 1, 10^(m-1) <= a*b < 10^m and b divides 10^m.
%H A392961 Robert Israel, <a href="/A392961/b392961.txt">Table of n, a(n) for n = 1..10000</a>
%e A392961 a(5) = 24 is a term because 24 is the concatenation of 2 and 4, which are both divisors of 24.
%p A392961 N:= 10^4: # for terms <= N
%p A392961 R:= {}:
%p A392961 for a from 1 to floor(sqrt(N)) do
%p A392961   for m from 1 to 1+ilog10(N) do
%p A392961     for b in NumberTheory:-Divisors(10^m) do
%p A392961       if a*b >= 10^(m-1) and a*b < 10^m and a*(10^m+b) <= N then
%p A392961          R:= R union {a*(10^m+b)}
%p A392961       fi
%p A392961 od od od:
%p A392961 sort(convert(R,list));
%Y A392961 Cf. A249766, A395128, A395129.
%K A392961 nonn,base,new
%O A392961 1,1
%A A392961 _Robert Israel_, Apr 09 2026
