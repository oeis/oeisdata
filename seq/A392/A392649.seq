%I A392649 #22 Mar 03 2026 04:11:51
%S A392649 12,18,30,40,42,56,60,66,78,90,100,102,114,138,140,150,174,176,186,
%T A392649 196,208,210,220,222,246,258,260,282,294,308,318,330,340,354,364,366,
%U A392649 380,390,402,426,438,450,460,462,474,476,490,498,510,532,534,544,546,550,570
%N A392649 Numbers that can be written as the sum of a subset of their sum-irreducible nontrivial divisors.
%C A392649 A number k is sum-irreducible (A392650) if no subset of its nontrivial divisors {1 < d < k : d | k} sums to k. If a subset of k's sum-irreducible divisors sums to k, k is called solid.
%C A392649 All solid numbers are semiperfect (A005835), but not all semiperfect numbers are solid. For example, 24 is semiperfect (12 + 8 + 4 = 24) but not solid since 12 is not sum-irreducible.
%H A392649 Peter Luschny, <a href="https://github.com/PeterLuschny/Gists/blob/main/ComposableRigidSparse.ipynb">Composable, rigid, and sparse numbers</a>. A Python notebook.
%e A392649     n -> witness
%e A392649    -----------------
%e A392649    12 =  6 +  4 + 2;
%e A392649    18 =  9 +  6 + 3;
%e A392649    30 = 15 + 10 + 5;
%e A392649    40 = 20 + 10 + 8 + 2;
%e A392649    42 = 21 + 14 + 7;
%e A392649    56 = 28 + 14 + 8 + 4 + 2;
%e A392649    60 = 20 + 15 + 10 + 6 + 5 + 4;
%e A392649    66 = 33 + 22 + 11;
%e A392649    78 = 39 + 26 + 13;
%e A392649    90 = 45 + 15 + 10 + 9 + 6 + 5;
%e A392649   100 = 50 + 25 + 20 + 5;
%o A392649 (Python)  # See also links.
%o A392649 from sympy import divisors
%o A392649 # The function 'is_sum_irreducible' is defined in A392650.
%o A392649 # The function 'subset_sum_exists' is defined in A392652.
%o A392649 def is_solid(n: int) -> bool:
%o A392649     if n < 12: return False
%o A392649     divs = divisors(n)[1:-1]
%o A392649     irr_divs = [d for d in divs if is_sum_irreducible(d)]
%o A392649     return subset_sum_exists(irr_divs, n)
%o A392649 def A392649_list(upto: int) -> list[int]:
%o A392649     return [n for n in range(2, upto + 1) if is_solid(n)]
%o A392649 print(A392649_list(570))
%Y A392649 Cf. A138636 (a subsequence).
%Y A392649 Cf. A392650 (sum-irreducible), A392440 (composable), A005835 (semiperfect), A392652, A392651 (odd terms).
%K A392649 nonn,new
%O A392649 1,1
