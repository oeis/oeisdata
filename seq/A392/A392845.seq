%S A392845 3,6,7,12,14,23,24,28,31,46,47,48,56,62,89,92,94,96,112,124,127,167,
%T A392845 178,184,188,192,223,224,233,248,254,263,334,356,359,368,376,383,384,
%U A392845 431,439,446,448,466,479,496,503,508,526,668,712,718,719,736,752,766,768
%N A392845 Numbers k for which the period length of the binary expansion of 1/k is a prime number.
%C A392845 Numbers of the form d*2^m, where d > 1 is one of the divisors of the Mersenne numbers (A001348) and m >= 0.
%H A392845 Arkadiusz Wesolowski, <a href="/A392845/b392845.txt">Table of n, a(n) for n = 1..10000</a>
%H A392845 W. S. Bennett, <a href="https://doi.org/10.1109/PROC.1973.9126">Quotient generation with conventional binary multipliers</a>, Proceedings of IEEE, 61(5), pp. 664-665.
%H A392845 <a href="/index/1#1overn">Index entries for sequences related to decimal expansion of 1/n</a>
%e A392845 1/14 in binary notation is 0.0001001001... repeating 001 ad infinity. Since the length of the repeated string is 3 (a prime number), 14 is in the sequence.
%o A392845 (Magma) MO:=func<k | Modorder(2, k)>; lst:=[]; for k in [3..768] do if IsOdd(k) then if IsPrime(MO(k)) then Append(~lst, k); end if; else if not IsPower(k) then v:=Truncate(k/2^Valuation(k, 2)); if IsPrime(MO(v)) then Append(~lst, k); end if; end if; end if; end for; lst;
%o A392845 (PARI) isok(k) = {if(k>2 && !ispower(k), my(v=k/2^valuation(k, 2), S=Set(factor(v)[, 1]), o=znorder(Mod(2, S[1]))); if(isprime(o) && bigomega(v)==#S && #select(x->o==znorder(Mod(2, x)), S)==#S, 1, 0))};
%o A392845 (Python)
%o A392845 from itertools import count, islice
%o A392845 from sympy import isprime, n_order
%o A392845 def A392845_gen(startvalue=3): # generator of terms >= startvalue
%o A392845     return filter(lambda k:(m:=k>>(~k & k-1).bit_length())>1 and isprime(n_order(2,m)),count(max(startvalue,3)))
%o A392845 A392845_list = list(islice(A392845_gen(),40)) # _Chai Wah Wu_, Mar 05 2026
%Y A392845 Cf. A001348, A007733.
%Y A392845 Supersequence of A122094 and of A335431.
