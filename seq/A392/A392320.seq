%S A392320 0,73,166,207,213,216,595,986,1069,1075,1117,1118,1135,1369,1383,1397,
%T A392320 1422,3986,4040,4041,4042,4043,4075,4083,4476,4501,8497,31301,31304,
%U A392320 56570,60320,62888,63025,63573,63600
%N A392320 Indices of nonzero entries in the continued hyperbolic-tangent expansion of Pi.
%C A392320 Pi = 3 + tanh(x(0) + tanh(x(1) + tanh(x(2) + tanh(x(3) + ...)))). The set {x(k)} is sparse, so k is in this sequence only when x(k) is nonzero.
%H A392320 Patrick J. Millican, <a href="https://github.com/pjm07/contfunc">contfunc GitHub repository</a>.
%H A392320 A. Rényi, <a href="https://doi.org/10.1007/BF02020331">Representations for real numbers and their ergodic properties</a>, Acta Mathematica Academiae Scientiarum Hungaricae 8, 477-493 (1957).
%t A392320 ContTanh[n_, mx_] := Block[{k = 0, x = n, lmt = mx + 1, s, lst = {}}, While[k < lmt, s = Floor[x]; x = ArcTanh[x - s]; If[s > 0, AppendTo[lst, k] ]; k++]; lst]; ContTanh[Pi, 100000]
%Y A392320 Cf. A000796.
%K A392320 nonn,more,new
%O A392320 1,2
%A A392320 _Patrick J. Millican_, Mar 31 2026
