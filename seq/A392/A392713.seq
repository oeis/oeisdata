%S A392713 1,2,0,3,-1,1,0,4,-2,0,-1,1,0,0,0,5,-3,-1,-2,1,0,-1,-1,1,-1,1,0,0,-1,
%T A392713 0,0,6,-4,-2,-3,0,-1,-2,-2,2,0,0,0,-1,-2,-1,-1,1,-2,0,-1,1,0,0,0,0,-2,
%U A392713 0,-1,0,0,0,0,7,-5,-3,-4,-1,-2,-3,-3,1,0,-1,-1,-2
%N A392713 Least part ofter the leading zero in row n of A391983 (the 0-based partial alternating sums of the n-th composition in standard order).
%C A392713 The k-th composition in standard order (graded reverse-lexicographic, A066099) is obtained by taking the set of positions of 1's in the reversed binary expansion of k, prepending 0, taking first differences, and reversing again. This gives a bijective correspondence between nonnegative integers and integer compositions.
%C A392713 The k-based partial alternating sums of a finite sequence q are given by pas(q,k)_j = (-1)^j * k + Sum_{i=1..j} (-1)^(i+j) * q_i. This is a signed version of the partial sums transformation, inverse to the "first sums" transformation. For example, the k-based partial alternating sums of q = (a,b,c,d,e) are:
%C A392713   pas(q,k)_0 =  k
%C A392713   pas(q,k)_1 = -k + a
%C A392713   pas(q,k)_2 =  k - a + b
%C A392713   pas(q,k)_3 = -k + a - b + c
%C A392713   pas(q,k)_4 =  k - a + b - c + d
%C A392713   pas(q,k)_5 = -k + a - b + c - d + e
%e A392713 The 9th composition in standard order is (3,1), with 0-based partial alternating sums (0,3,-2), so a(9) = -2.
%t A392713 stc[n_]:=Differences[Prepend[Join @@ Position[Reverse[IntegerDigits[n,2]],1],0]]//Reverse;
%t A392713 pas[y_,k_]:=Table[(-1)^j*k+Sum[(-1)^(i+j)*y[[i]],{i,j}],{j,0,Length[y]}];
%t A392713 Table[Min@@Rest[pas[stc[n],0]],{n,100}]
%Y A392713 Without taking alternating sums we have A333768, maximum A333766.
%Y A392713 For run lengths we have A357138, for maximum A357137.
%Y A392713 For first instead of minimal we have A357180, last A357181.
%Y A392713 Row minima of A391983, non-singleton case A391981 or A392374.
%Y A392713 The odd-indexed case is A392705 (negated), even A392706.
%Y A392713 For maximum instead of minimum we have A394091.
%Y A392713 Including the leading zero gives A394092 (negated).
%Y A392713 For prime indices we have A394094, maximum A394093.
%Y A392713 A003242 counts anti-run compositions, ranks A333489.
%Y A392713 A011782 counts compositions.
%Y A392713 A051904 gives least prime exponent.
%Y A392713 A055396 gives least prime index.
%Y A392713 A066099 lists all compositions in standard order.
%Y A392713 A097805 counts compositions by alternating sum.
%Y A392713 A390432 lists first sums of standard compositions, row ranks A390568.
