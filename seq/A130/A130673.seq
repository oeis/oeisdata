%S A130673 2,3,6,9,13,17,21,25,29,34,39,43,48,53,58,63,68,74,79,84,90,95,101,
%T A130673 106,112,118,123,129,135,141,147,152,158,164,170,176,183,189,195,201,
%U A130673 207,213,220,226,232,239,245,251,258,264,271,277,284,290,297,303,310
%N A130673 Smallest m > 1 such that log m + psi(n/m) is negative, where psi(x) is the digamma function.
%C A130673 Related to D. H. Lehmer's generalized Euler constants, E(r,m) = lim_{n->oo} (H_{r,m}(n) - log n / m); E(r,m) = -1/m * (log m + psi(r/m)).
%D A130673 Stefan Kraemer, Eulers constant and related numbers, preprint, 2005.
%H A130673 Stefan Kraemer, <a href="http://www.math.uni-goettingen.de/skraemer/gamma.html">Euler's Constant 0.577... Its Mathematics and History</a>
%H A130673 D. H. Lehmer, <a href="http://matwbn.icm.edu.pl/ksiazki/aa/aa27/aa27121.pdf">Euler constants for arithmetic progressions</a>, Acta Arith. 27 (1975) 125-142.
%t A130673 a[n_]:=Module[{m=2},While[Log[m]+PolyGamma[n/m]>=0, m++]; m]; Array[a,57] (* _Stefano Spezia_, Jul 22 2026 *)
%K A130673 nonn,changed
%O A130673 1,1
%A A130673 _Stefan Krämer_, Jun 28 2007
%E A130673 Edited and more terms from _Sean A. Irvine_, Jul 20 2026
