%T A130873 30962,43202,83537,83602,84146,85922,98162,112082,130337,130402,
%U A130873 130946,132722,144962,158882,213842,279857,279922,280466,282242,294482,308402
%N A130873 Sums of two distinct prime 4th powers.
%C A130873 This is to 4th powers as A120398 is to cubes.
%C A130873 The first term that occurs in more than one way is a(1223) = 3262811042 = 7^4 + 239^4 = 157^4 + 227^4. - _Robert Israel_, Mar 12 2026
%H A130873 Robert Israel, <a href="/A130873/b130873.txt">Table of n, a(n) for n = 1..10000</a>
%p A130873 N:= 10^8: # for terms <= N
%p A130873 P:= select(isprime,[2,seq(i,i=3..floor(N^(1/4)))]): nP:= nops(P):
%p A130873 S:= select(`<=`,{seq(seq(P[i]^4 + P[j]^4,i=1..j-1),j=1..nP)},N):
%p A130873 sort(convert(S,list)); # _Robert Israel_, Mar 12 2026
%t A130873 Select[Sort[ Flatten[Table[Prime[n]^4 + Prime[k]^4, {n, 15}, {k, n - 1}]]], # <= Prime[15^4] &]
%t A130873 Total/@Subsets[Prime[Range[10]]^4,{2}]//Union (* _Harvey P. Dale_, Oct 20 2024 *)
%Y A130873 Cf. A030514, A120398.
%K A130873 easy,nonn
%O A130873 1,1
