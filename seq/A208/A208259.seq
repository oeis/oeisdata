%o A208259 (Python)
%o A208259 from itertools import count, islice, product
%o A208259 def agen(): # generator of terms
%o A208259     yield 1
%o A208259     yield from (int("1"+"".join(m)+"1") for d in count(0) for m in product("0123456789", repeat=d))
%o A208259 print(list(islice(agen(), 46))) # _Michael S. Branicky_, Jun 13 2026
