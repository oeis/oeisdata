%N A056201 Characteristic cube divisor (A056191) of central binomial coefficient (A001405).
%F A056201 a(n) = A056059(n)^3 = g^3 and binomial(n, floor(n/2)) = a(n)^3 * L^2 * A056060(n), where L = A056056(n)/A056059(n).
%e A056201 n=14, binomial(14,8) = 3432 = 2*2*2*3*11*13 so g(3432)=2, thus a(14)=8.
%o A056201 (Python)
%o A056201 from math import prod
%o A056201 from sympy import primerange
%o A056201 from sympy.ntheory.factor_ import digits
%o A056201 def A056201(n):
%o A056201     def s(n,p): return sum(digits(n,p)[1:])
%o A056201     m = n>>1
%o A056201     return prod(p if (e:=(s(m,p)+s(n-m,p)-s(n,p))//(p-1))&1 and e>1 else 1 for p in primerange(n+1))**3 # _Chai Wah Wu_, May 05 2026
%Y A056201 Cf. A056056-A056060, A056202.
%Y A056201 Equals A056059^3.
%K A056201 nonn,changed
%O A056201 1,14
%A A056201 _Labos Elemer_, Aug 02 2000
