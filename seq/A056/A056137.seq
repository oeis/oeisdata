%F A056137 a(n) = A046079(n) - A056138(n) = A046081(n) - A046080(n) - A056138(n).
%o A056137 (PARI) a(n) = my(r=n^2); sumdiv(r, d, my(t=r/d-d); t>0 && t%2 == 0 && t^2<4*r) \\ _Andrew Howroyd_, Jul 10 2026
