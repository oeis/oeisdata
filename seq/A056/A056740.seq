%I A056740 #27 Jul 09 2026 00:36:29
%S A056740 135,1423249,31491395,55519333,1065373685,3559609381
%N A056740 Odd numbers k such that 2^k mod k = 2^(k+2) mod (k-2) is also an odd number.
%C A056740 Also, odd numbers k such that 2^(k-1)*(2+3k) mod k*(k-2) is odd and smaller than k-2. - _Max Alekseyev_, Jul 07 2026
%H A056740 Joe K. Crump, <a href="http://web.archive.org/web/20070614175509/http://www.immortaltheory.com/NumberTheory/2nmodn.htm">2^n mod n</a>
%e A056740 135 is a term because 2^135 mod 135 = 53 and 2^137 mod 133 = 53.
%o A056740 (PARI) isok(n) = {va = Mod(2,n)^n; (lift(va) % 2) && (lift(va) == lift(Mod(2, n-2)^(n+2)));} \\ _Michel Marcus_, Sep 02 2013
%o A056740 (Python)
%o A056740 from itertools import count, islice
%o A056740 def A056740_gen(startvalue=1): # generator of terms >= startvalue
%o A056740     for k in count((m:=max(startvalue,1))+(m&1^1),2):
%o A056740         a = pow(2,k,k)
%o A056740         if a&1 and pow(2,k+2,k-2)==a:
%o A056740             yield k
%o A056740 A056740_list = list(islice(A056740_gen(),3)) # _Chai Wah Wu_, Jul 09 2026
%Y A056740 Cf. A015911.
%K A056740 nonn,more,changed
