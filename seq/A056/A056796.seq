%N A056796 Minimal number of steps to get from 0 to n when there are 3 kinds of step: add 1, multiply by 2, multiply by 3.
%D A056796 Proposed by _Mark Sapir_, Math. Dept., Vanderbilt University, August 2000.
%H A056796 Robert Israel, <a href="/A056796/b056796.txt">Table of n, a(n) for n = 0..10000</a>
%H A056796 <a href="/index/Com#complexity">Index to sequences related to the complexity of n</a>
%p A056796 g:= proc(a,b) option remember; local r;
%p A056796    if a = b then return 0 fi;
%p A056796    if a = 0 then return 1 + procname(1,b) fi;
%p A056796    r:= 1 + procname(a+1,b);
%p A056796    if 2*a <= b then r:= min(r, 1+procname(2*a,b)) fi;
%p A056796    if 3*a <= b then r:= min(r, 1+procname(3*a,b)) fi;
%p A056796    r
%p A056796 end proc:
%p A056796 seq(g(0,n),n=0..100); # _Robert Israel_, Mar 06 2026
%Y A056796 Cf. A056792, A056817.
%K A056796 nonn,changed
%O A056796 0,3
%A A056796 _David W. Wilson_, Sep 07 2000
