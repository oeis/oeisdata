%S A056471 1,1,2,2,5,5,15,15,52,52,203,203,876,876,4111,4111,20648,20648,109299,
%T A056471 109299,601492,601492,3403127,3403127,19628064,19628064,114700315,
%U A056471 114700315,676207628,676207628,4010090463,4010090463,23874362200,23874362200,142508723651,142508723651
%N A056471 Number of palindromic structures using a maximum of six different symbols.
%C A056471 Permuting the symbols will not change the structure.
%D A056471 M. R. Nester, Mathematical investigations of some plant interaction designs, PhD Thesis, University of Queensland, Brisbane, Australia, 1999. [See A056391 for pdf file of Chap. 2]
%H A056471 Paolo Xausa, <a href="/A056471/b056471.txt">Table of n, a(n) for n = 1..1000</a>
%H A056471 <a href="/index/Rec#order_09">Index entries for linear recurrences with constant coefficients</a>, signature (1,15,-15,-80,80,180,-180,-144,144).
%F A056471 a(n) = Sum_{k=1..6} A008277(floor((n+1)/2), k), where A008277 are the Stirling numbers of the second kind.
%F A056471 G.f.: -x*(91*x^8-135*x^6+68*x^4-14*x^2+1) / ((x-1)*(2*x-1)*(2*x+1)*(2*x^2-1)*(3*x^2-1)*(6*x^2-1)). - _Colin Barker_, Dec 05 2012
%t A056471 A056471[n_] := Sum[StirlingS2[Quotient[n+1, 2], k], {k, 6}];
%t A056471 Array[A056471, 40] (* _Paolo Xausa_, May 20 2026 *)
%t A056471 (* Alternative: *)
%t A056471 LinearRecurrence[{1, 15, -15, -80, 80, 180, -180, -144, 144}, {1, 1, 2, 2, 5, 5, 15, 15, 52}, 40] (* _Paolo Xausa_, May 20 2026 *)
