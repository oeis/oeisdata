%I A104283 #6 May 21 2026 17:56:09
%S A104283 49135832685980009261,205379216000226981238328250047,
%T A104283 456533474552493039512000531441,21466892197000224809122999682352637,
%U A104283 2171763921952000221880412242576822665187
%N A104283 Primes which are the concatenation of five consecutive cubes.
%H A104283 Robert Israel, <a href="/A104283/b104283.txt">Table of n, a(n) for n = 1..10000</a>
%e A104283 The first term is 49135832685980009261 which is a prime and is the concatenation of 4913,5832,6859,8000 and 9261 which are five consecutive cubes.
%p A104283 R:= NULL: count:= 0:
%p A104283 fcat:= proc(x) local s,i;
%p A104283    s:= x^3;
%p A104283    for i from 1 to 4 do
%p A104283      s:= 10^(1+ilog10((x+i)^3))*s + (x+i)^3
%p A104283    od;
%p A104283  end proc:
%p A104283 for x from 1 by 2 while count < 30 do
%p A104283   v:= fcat(x);
%p A104283   if isprime(v) then R:= R,v; count:= count+1; fi
%p A104283 od:
%p A104283 R; # _Robert Israel_, May 21 2026
%K A104283 base,nonn,changed
%O A104283 1,1
