%I A084818 #17 May 12 2026 05:31:17
%S A084818 1,10,32,102,328,1060,3434,11130,36083,116981,379259,1229586,3986416,
%T A084818 12924279
%N A084818 Least integers that satisfy Sum_{n>=1} 1/a(n)^z = 0, where a(1)=1, a(n+1)>a(n) and z=I/log(3).
%C A084818 Sequence satisfies Sum_{n>=1} 1/a(n)^z = 0 by requiring that the modulus of the successive partial sums are monotonically decreasing in magnitude for the given z.
%o A084818 (PARI) my(z=I/log(3), S=0, w=1, a=0; for(n=1,100,b=a+1; while(abs(S+exp(-z*log(b)))>w,b++); S=S+exp(-z*log(b)); w=abs(S); a=b; print1(b,","))
%Y A084818 Cf. A084812, A084813, A084814, A084815, A084816, A084817.
%K A084818 nonn,more,changed
%O A084818 1,2
%A A084818 _Paul D. Hanna_, Jun 04 2003
%E A084818 a(9)-a(14) from _Sean A. Irvine_, May 12 2026
