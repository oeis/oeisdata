%T A084216 5,7,1,2,7,3,2,2,1,6,1,3,3,14,1,2,1,3,5,2,1,3,1,10,1,19,2,2,1,3,2,2,3,
%U A084216 6,1,2,5,22,1,2,1,3,1,11,1,6,5,2,11,23,1
%N A084216 a(n) = smallest integer d such that a quadratic representation 2n+1 = x^2 + d*y^2 exists (x,y positive integers).
%H A084216 Michael De Vlieger, <a href="/A084216/b084216.txt">Table of n, a(n) for n = 1..10000</a>
%e A084216 a(7)=6 because d=6 is the smallest d giving integer solutions x=2, y=1 in (2*7+1) = x^2+d*y^2 = 3^2 + 6*1^2 = 15.
%t A084216 Table[d = 1; While[! Resolve[Exists[{x, y}, And[2*n + 1 == x^2 + d*y^2, x > 0, y > 0]], Integers], d++]; d, {n, 120}] (* _Michael De Vlieger_, Mar 19 2026 *)
