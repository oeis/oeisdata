%I A084123 #31 Jul 03 2026 09:07:59
%S A084123 2,6,55,444,848,122555221,161131161,5729689869275,7587952597857,
%T A084123 35757255275753,182196497222794691281
%N A084123 Palindromic numbers which are equal to a number k multiplied by the k-th prime.
%C A084123 a(12) > 4.3*10^26. - _Giovanni Resta_, Jun 28 2013
%C A084123 a(7) = 161131161 is also palindromic in base 16 = 99AAA99. - _Patrick De Geest_, Jun 29 2026
%e A084123 The palindrome 161131161 is a term since 4119*prime(4119) = 4119*39119 = 161131161.
%t A084123 palQ[n_]:=FromDigits[Reverse[IntegerDigits[n]]]==n; t={}; Do[If[palQ[x=n*Prime[n]],AppendTo[t,x]],{n,15*10^5}]; t (* _Jayanta Basu_, May 11 2013 *)
%Y A084123 Cf. A084121, A084122.
%Y A084123 Intersection of A002113 and A033286.
%K A084123 base,nonn,more
%O A084123 1,1
