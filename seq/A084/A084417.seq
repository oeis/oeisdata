%N A084417 Triangle read by rows: T(n,k) = Sum_{i=1..k} (n+1-i)! * Stirling2(n,n+1-i), n>=1, 1<=k<=n.
%C A084417 Interpolates between A000670 and factorials.
%F A084417 T(n, k) = Sum_{i=1..k} (n+1-i)! * Stirling2(n, n+1-i), n>=1, 1<=k<=n.
%F A084417 abs(Sum_{k=1..n} (-1)^k*T(n,k)) = A089677(n). - _Alois P. Heinz_, Apr 12 2026
