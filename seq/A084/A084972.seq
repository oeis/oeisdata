%N A084972 When A058033 first reaches n.
%t A084972 Primorial[n_] := Product[Prime[i], {i, 1, n}]; f[n_] := Block[{k = 2, p = 1}, While[q = Floor[ Log[2, Primorial[k]]]; q - p != n, k++; p = q]; k - 1]; Table[ f[n], {n, 1, 17}]
