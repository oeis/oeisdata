%I A084814 #16 May 12 2026 05:31:34
%S A084814 1,4,8,17,37,82,185,419,952,2166,4932,11234,25593,58307,132837,302638,
%T A084814 689491,1570849,3578825,8153546,18576017
%N A084814 Least integers that satisfy Sum_{n>=1} 1/a(n)^z = 0, where a(1)=1, a(n+1) > a(n) and z = i*Pi/2.
%C A084814 Sequence satisfies Sum_{n>=1} 1/a(n)^z = 0 by requiring that the modulus of the successive partial sums are monotonically decreasing in magnitude for the given z.
%o A084814 (PARI) my(z = I*Pi/2, S=0, w=1, a=0); for(n=1,100,b=a+1; while(abs(S+exp(-z*log(b)))>w,b++); S=S+exp(-z*log(b)); w=abs(S); a=b; print1(b,","))
%Y A084814 Cf. A084812, A084813, A084815, A084816, A084817, A084818.
%K A084814 nonn,more,changed
%O A084814 1,2
%A A084814 _Paul D. Hanna_, Jun 04 2003
%E A084814 a(14)-a(21) from _Sean A. Irvine_, May 11 2026
