%T A084430 117281,421973,127447,233759,240967,249131,158329,168599,180001,
%U A084430 192611,1106489,1121671,2138249,2156251,1175767,1196837,2219527,2243893,1270001,3297911,2327681
%N A084430 Smallest prime with "n^3" as central digit(s).
%H A084430 Robert Israel, <a href="/A084430/b084430.txt">Table of n, a(n) for n = 0..10000</a>
%F A084430 a(n) = A084413(n^3). - _Sean A. Irvine_, Apr 14 2026
%p A084430 f:= proc(n) local k,r,p,d;
%p A084430       for k from 1 do
%p A084430         d:= 1+ilog10(k);
%p A084430         r:= tcat(k,n)*10^d;
%p A084430         p:= nextprime(r);
%p A084430         if p - r < 10^d then return p fi
%p A084430       od
%p A084430 end proc:
%p A084430 f(0):= 101:
%p A084430 map(f, [$0..100]); # _Robert Israel_, Apr 17 2026
%o A084430 (PARI) a(n) = {n = n^3; for (i = 1, 9, forstep (j=1, 9, 2, v = j + 10*n + i*10^(1+length(Str(n))); if (isprime(v), return (v)); ); ); } \\ _Michel Marcus_, Oct 05 2013
