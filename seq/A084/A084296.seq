%N A084296 Triangle read by rows: T(n,k) = omega(prime(n)#+k) where prime(n)# is the n-th primorial (A002110) and omega is the number of distinct prime factors (A001221), 0 <= k < n.
%F A084296 T(n,k) = A001221(A002110(n)+k).
%F A084296 T(n,0) = n.
%e A084296 Triangle begins:
%e A084296   1;
%e A084296   2, 1;
%e A084296   3, 1, 1;
%e A084296   4, 1, 2, 2;
%e A084296   5, 1, 2, 2, 3;
%e A084296   6, 2, 2, 3, 2, 2;
%e A084296   7, 3, 2, 3, 3, 2, 4;
%e A084296   ...
%t A084296 lf[x_] := Length[FactorInteger[x]]; q[x_] := Apply[Times, Table[Prime[w], {w, 1, x}]]; Flatten[Table[Table[lf[q[n]+j], {j, 0, n-1}], {n, 1, 20}], 1]
%Y A084296 Cf. A001221, A002110, A068069, A045983.
%K A084296 nonn,tabl
%O A084296 1,2
