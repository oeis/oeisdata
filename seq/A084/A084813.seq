%I A084813 #12 May 12 2026 05:31:39
%S A084813 1,9,26,84,272,887,2895,9454,30874,100834,329323,1075573,3512840,
%T A084813 11472997,37471011,122380987
%N A084813 Least integers that satisfy Sum_{n>=1} 1/a(n)^z = 0, where a(1)=1, a(n+1)>a(n) and z=I.
%C A084813 Sequence satisfies Sum_{n>=1} 1/a(n)^z = 0 by requiring that the modulus of the successive partial sums are monotonically decreasing in magnitude for the given z.
%F A084813 Limit a(n+1)/a(n) --> 3.266017... - _Paul D. Hanna_, Jun 16 2003
%o A084813 (PARI) z=I; S=0; w=1; a=0; for(n=1,100,b=a+1; while(abs(S+exp(-z*log(b)))>w,b++); S=S+exp(-z*log(b)); w=abs(S); a=b; print1(b,","))
%Y A084813 Cf. A084812, A084814-A084818.
%K A084813 nonn,more,changed
%O A084813 1,2
%A A084813 _Paul D. Hanna_, Jun 04 2003
%E A084813 More terms from _Paul D. Hanna_, Jun 16 2003
