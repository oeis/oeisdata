%F A008639 G.f.: 1/Product_{k=1..10} (1 - x^k). - _David Neil McGrath_, Apr 29 2015
%F A008639 a(n) = a(n-10) + A008638(n). - _Vladimír Modrák_, Sep 29 2020
%F A008639 a(n) = floor((10*n^9 +2475*n^8 +260700*n^7 +15246000*n^6 +541340184*n^5 +11985724800*n^4 +163531843200*n^3 +1309872384000*n^2 +5575652433792*n)/13168189440000 - (n mod 2)*(n^4+110*n^3+4180*n^2+63525*n)/1474560 - ((n mod 3)*(n^2+55*n) + ((2*n^2+2*n) mod 3)*7*n)/8748 + ((n^2+3*n+2) mod 4)*n/1024 + (((n+4) mod 5)-(n mod 5))*n/1250 + 1). - _Hoang Xuan Thanh_, Apr 06 2026
%t A008639 CoefficientList[ Series[ 1/ Product[ 1 - x^n, {n, 1, 10} ], {x, 0, 60} ], x ]
