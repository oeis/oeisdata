%N A293210 a(n) = [x^n] (1/(1 - x)^n)*Sum_{k>=1} prime(k)*x^k.
%H A293210 Alois P. Heinz, <a href="/A293210/b293210.txt">Table of n, a(n) for n = 0..1663</a>
%F A293210 a(n) = A254858(n,n).
%p A293210 b:= proc(n, k) option remember; `if`(n=0, 0,
%p A293210      `if`(k=0, ithprime(n), b(n-1, k)+b(n, k-1)))
%p A293210     end:
%p A293210 a:= n-> b(n$2):
%p A293210 seq(a(n), n=0..28);  # _Alois P. Heinz_, Mar 20 2026
%t A293210 Table[SeriesCoefficient[1/(1 - x)^n Sum[Prime[k] x^k, {k, 1, n}], {x, 0, n}], {n, 0, 28}]
