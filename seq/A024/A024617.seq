%I A024617 #9 May 28 2026 13:58:32
%S A024617 1,2,4,6,9,12,16,20,25,31,37,43,50,58,65,73,82,92,102,111,122,132,144,
%T A024617 155,167,181,194,207,222,237,252,267,283,297,314,333,349,367,385,404,
%U A024617 422,444,466,483,505,524,546,568,591,615,637,662,684,706,733,759,784
%N A024617 Position of n^2 + n + 1 in A024614.
%H A024617 Robert Israel, <a href="/A024617/b024617.txt">Table of n, a(n) for n = 1..2500</a>
%p A024617 M:= 100: # for a(1) .. a(M)
%p A024617 N:= M^2 + M + 1: S:= {}:
%p A024617 for x from 1 to M do
%p A024617   ym:= floor((sqrt(4*N-3*x^2)-x)/2);
%p A024617   S:= S union {seq(x^2+x*y+y^2,y=1..ym)};
%p A024617 od:
%p A024617 S:= sort(convert(S,list)):
%p A024617 f:= n -> ListTools:-BinarySearch(S,n^2+n+1):
%p A024617 map(f, [$1..M]); # _Robert Israel_, May 28 2026
%K A024617 nonn,changed
%O A024617 1,2
