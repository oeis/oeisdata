%N A024293 Expansion of e.g.f. log(1 + sin(x)^2)/2 (even-indexed coefficients).
%F A024293 A(0,k) = 1 and A(n,k) = -(k*(k+1) * A(n-1,k+2) + k^2 * A(n-1,k)) for n > 0. a(0) = 0 and a(n) = A(n-1,2). - _Seiichi Manyama_, Apr 15 2026
%e A024293 log(1 + sin(x)^2)/2 = x^2/2! - 10*x^4/4! + 256*x^6/6! - 13840*x^8/8! + 1282816*x^10/10! - ...
%t A024293 With[{nn=30},Take[CoefficientList[Series[Log[1+Sin[x]^2]/2,{x,0,nn}],x] Range[0,nn]!,{1,-1,2}]] (* _Harvey P. Dale_, May 21 2014 *)
