%I A024377 #10 Jun 25 2026 00:50:18
%S A024377 2,3,5,7,16,20,35,43,53,65,86,106,137,153,196,220,246,270,329,353,412,
%T A024377 454,521,559,642,686,732,780,869,917,1032,1080,1199,1263,1388,1456,
%U A024377 1597,1673,1735,1823,1974,2062,2227,2301,2476,2572,2761,2863,3062,3166,3365,3475,3591
%N A024377 a(n) = s(1)t(n) + s(2)t(n-1) + ... + s(k)t(n+1-k), where k = [ (n+1)/2 ], s = A023532, t = (primes).
%H A024377 Robert Israel, <a href="/A024377/b024377.txt">Table of n, a(n) for n = 1..10000</a>
%p A024377 N:= 100: # for a(1) .. a(N)
%p A024377 P:= [seq(ithprime(i),i=1..10000)]:
%p A024377 S:= ListTools:-PartialSums(P):
%p A024377 g:= proc(n) local m; S[n] - S[floor(n/2)] - add(ithprime(n+1-m*(m+3)/2),
%p A024377   m = 1 .. floor((sqrt(9+4*(n+1))-3)/2))
%p A024377 end proc:
%p A024377 g(1):= 2:
%p A024377 map(g, [$1..N]); # _Robert Israel_, Jun 24 2026
%Y A024377 Cf. A000040, A023532.
%K A024377 nonn
%O A024377 1,1
%A A024377 _Clark Kimberling_
