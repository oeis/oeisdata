%F A024142 G.f.: (1-4*x+14*x^2+11*x^3)/((1-12*x)*(1-x)^3). - _Vincenzo Librandi_, Oct 06 2014
%F A024142 From _Elmo R. Oliveira_, Jul 10 2026: (Start)
%F A024142 E.g.f.: exp(12*x) - x*(1 + x)*exp(x).
%F A024142 a(n) = A001021(n) - A000290(n).
%F A024142 a(n) = 15*a(n-1) - 39*a(n-2) + 37*a(n-3) - 12*a(n-4). (End)
%t A024142 Table[12^n - n^2, {n, 0, 25}] (* _Vincenzo Librandi_, Oct 06 2014 *)
