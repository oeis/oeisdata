%I A180747 #22 Jul 12 2026 03:59:30
%S A180747 1,1,2,9,68,715,9527,152789,2856984,60962112,1461364051,38885737209,
%T A180747 1137587558289,36299474019445,1254966476969859,46739853740801293,
%U A180747 1865947811034153032,79499993864122690971,3600874278814894340648,172792068400002430587990,8757341486276956735567441
%N A180747 G.f.: A(x) = x/Series_Reversion(x*G(x)) where G(x) = Sum_{n>=0} (n+1)^(n-1)*x^n.
%C A180747 Equals the main diagonal of triangle A397590. - _Paul D. Hanna_, Jul 09 2026
%H A180747 Paul D. Hanna, <a href="/A180747/b180747.txt">Table of n, a(n) for n = 0..300</a>
%F A180747 G.f. satisfies: [x^n] A(x)^(n+1) = (n+1)^n for n>=0.
%F A180747 G.f. satisfies: A(x) = G(x/A(x)) where A(x*G(x)) = G(x) = Sum_{n>=0} (n+1)^(n-1)*x^n.
%F A180747 a(n) ~ exp(1-exp(-1)) * n^(n-1). - _Vaclav Kotesovec_, Jul 09 2026
%e A180747 G.f.: A(x) = 1 + x + 2*x^2 + 9*x^3 + 68*x^4 + 715*x^5 + ...
%e A180747 G.f. satisfies A(x) = G(x/A(x)) where G(x) begins:
%e A180747 G(x) = 1 + x + 3*x^2 + 4^2*x^3 + 5^3*x^4 + 6^4*x^5 + ...
%e A180747 so that:
%e A180747 A(x) = 1 + x/A(x) + 3*x^2/A(x)^2 + 4^2*x^3/A(x)^3 + 5^3*x^4/A(x)^4 + ...
%e A180747 The table of coefficients of x^k in A(x)^n begins:
%e A180747   A^1: [1, 1,  2,   9,   68,   715,   9527, ...];
%e A180747   A^2: [1,(2), 5,  22,  158,  1602,  20837, ...];
%e A180747   A^3: [1, 3, (9), 40,  276,  2700,  34250, ...];
%e A180747   A^4: [1, 4, 14, (64), 429,  4056,  50146, ...];
%e A180747   A^5: [1, 5, 20,  95, (625), 5726,  68975, ...];
%e A180747   A^6: [1, 6, 27, 134,  873, (7776), 91268, ...];
%e A180747   A^7: [1, 7, 35, 182, 1183, 10283,(117649), ...]; ...
%e A180747 where the coefficient of x^n in A(x)^(n+1) equals (n+1)^n.
%o A180747 (PARI) {a(n) = my(D = sum(m=0,n+1, (m+1)^(m-1)*x^m) +x*O(x^n)); polcoef(GF = x/serreverse(x*D), n)}
%o A180747 {upto(n) = a(n); Vec(GF)}
%o A180747 upto(25) \\ program revised by _Paul D. Hanna_, Jul 09 2026
