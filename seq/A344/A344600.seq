%N A344600 a(n) = Sum_{k=1..n} phi(k) * (floor(n/k)^4 - floor((n-1)/k)^4).
%F A344600 Sum_{k=1..n} a(k) = A344523(n).
%F A344600 G.f.: Sum_{k >= 1} phi(k) * x^k * (1 + 11*x^k + 11*x^(2*k) + x^(3*k))/(1 - x^k)^4.
%t A344600 a[n_] := Sum[EulerPhi[k] * First @ Differences @ (Quotient[{n - 1, n}, k]^4), {k, 1, n}]; Array[a, 40] (* _Amiram Eldar_, May 24 2021 *)
%o A344600 (PARI) a(n) = sum(k=1, n, eulerphi(k)*((n\k)^4-((n-1)\k)^4));
%o A344600 (PARI) my(N=40, x='x+O('x^N)); Vec(sum(k=1, N, eulerphi(k)*x^k*(1+11*x^k+11*x^(2*k)+x^(3*k))/(1-x^k)^4))
%o A344600 (Python)
%o A344600 # uses Python function from A002088
%o A344600 def A344600(n):
%o A344600     c, j, v, j2, v2 = 0, 1, 0, 1, 0
%o A344600     while j <= n:
%o A344600         k = n//j
%o A344600         m = n//k
%o A344600         c += k**4*(-v+(v:=A002088(m)))
%o A344600         j = m+1
%o A344600     while j2 <= (n2:=n-1):
%o A344600         k2 = n2//j2
%o A344600         m2 = n2//k2
%o A344600         c -= k2**4*(-v2+(v2:=A002088(m2)))
%o A344600         j2 = m2+1
%o A344600     return c # _Chai Wah Wu_, May 15 2026
%Y A344600 Cf. A344523, A344598, A344599.
%K A344600 nonn
%O A344600 1,2
%A A344600 _Seiichi Manyama_, May 24 2021
