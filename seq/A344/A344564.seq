%T A344564 22364160,58490880,150405120,381026304,952565760,2353397760,
%U A344564 5752750080,13927710720,33426505728,79586918400,188114534400,441660211200,1030540492800,2390853943296
%N A344564 a(n) = [x^n] -3/(2*x - 1)^5.
%H A344564 Paolo Xausa, <a href="/A344564/b344564.txt">Table of n, a(n) for n = 0..1000</a>
%H A344564 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (10,-40,80,-80,32).
%F A344564 a(n) = 2*(n + 4)*a(n - 1) / n for n >= 2.
%F A344564 a(n) = 2^(n - 3)*(n + 1)*(n + 2)*(n + 3)*(n + 4).
%F A344564 a(n) = n! * [x^n] (2*x^4 + 16*x^3 + 36*x^2 + 24*x + 3)*exp(2*x).
%F A344564 a(n) ~ 2^(n - 3) * n^4.
%F A344564 From _Amiram Eldar_, Jul 07 2026: (Start)
%F A344564 Sum_{n>=0} 1/a(n) = 20/9 - 8*log(2)/3.
%F A344564 Sum_{n>=0} (-1)^n/a(n) = 72*log(3/2) - 260/9. (End)
%p A344564 a := n -> 2^(n - 3)*(n + 1)*(n + 2)*(n + 3)*(n + 4): seq(a(n), n = 0..25);
%t A344564 A344564[n_] := 2^(n - 3)*(n + 1)*(n + 2)*(n + 3)*(n + 4);
