%I A344990 #42 Mar 02 2026 22:35:43
%S A344990 2,5,7,11,23,37,47,61,67,79,83,167,223,227,359,439,443,503,509,521,
%T A344990 727,839,997,1019,1087,1091,1223,1367,1523,1847,2027,2207,2399,2741,
%U A344990 3023,3251,3719,3967,4093,4099,4759,5039,5623,5927,6553,6563,6569,7919,8179
%N A344990 Primes of the form m^k +- k, with m,k > 1.
%H A344990 Robert Israel, <a href="/A344990/b344990.txt">Table of n, a(n) for n = 1..10000</a>
%e A344990     2 =  2^2 - 2,
%e A344990     5 =  2^3 - 3,
%e A344990     7 =  3^2 - 2,
%e A344990    11 =  3^2 + 2,
%e A344990    23 =  5^2 - 2,
%e A344990    37 =  2^5 + 5,
%e A344990    47 =  7^2 - 2,
%e A344990    61 =  4^3 - 3,
%e A344990    67 =  4^3 + 3,
%e A344990    79 =  9^2 - 2,
%e A344990    83 =  9^2 + 2,
%e A344990   167 = 13^2 - 2,
%e A344990   223 = 15^2 - 2,
%e A344990   227 = 15^2 + 2,
%e A344990   359 = 19^2 - 2,
%e A344990   439 = 21^2 - 2,
%e A344990   443 = 21^2 + 2,
%e A344990   503 =  2^9 - 9,
%e A344990   509 =  8^3 - 3,
%e A344990   521 =  2^9 + 9,
%e A344990   ...
%p A344990 N:= 10000: # for terms <= N
%p A344990 S:= {2}:
%p A344990 for m from 2 while m^2-2 <= N do
%p A344990   for k from 3-(m mod 2) by 2 do
%p A344990     v:= m^k-k;
%p A344990     if v > N then break fi;
%p A344990     if isprime(v) then S:= S union {v} fi;
%p A344990     v:= m^k + k;
%p A344990     if v <= N and isprime(v) then S:= S union {v} fi;
%p A344990 od od:
%p A344990 sort(convert(S,list)); # _Robert Israel_, Mar 02 2026
%Y A344990 Union of A099227 and A099228.
%K A344990 nonn
%O A344990 1,1
%A A344990 _Luke Voyles_, Jun 05 2021
