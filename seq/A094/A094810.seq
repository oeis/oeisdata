%S A094810 3,5,11,23,53,307,769,5039,13049,603667,1578823,10810469,427860443429,
%T A094810 16944504081930151,31525215457325198354227,
%U A094810 33014537901332492765899179111315710183929325703531042557,929153004165028209140476861623544319436354594054815247101152031731
%N A094810 Primes of the form F(k)*F(k+1) + F(k+2) where F(x) = Fibonacci(x).
%C A094810 Excluding the term a(4)=23, primes p such that p(n) is not a sum of two squares but p(n+1) is a sum of two squares.
%H A094810 Harvey P. Dale, <a href="/A094810/b094810.txt">Table of n, a(n) for n = 1..23</a>
%F A094810 A000040 INTERSECT A305412. - _R. J. Mathar_, Nov 14 2019
%e A094810 5 is in the sequence because F(2)*F(3)+F(4) = 1*2+3=5.
%e A094810 11 is in because F(3)*F(4)+F(5) = 2*3+5 = 11.
%e A094810 23 is in because F(4)*F(5)+F(6) = 3*5+8 = 23.
%t A094810 Select[#[[1]]#[[2]]+#[[3]]&/@Partition[Fibonacci[Range[60]],3,1],PrimeQ] (* _Harvey P. Dale_, Mar 03 2026 *)
%o A094810 (PARI) lista(nn) = {for (n=1, nn, if (isprime(p=fibonacci(n)*fibonacci(n+1) +fibonacci(n+2)), print1(p, ", ")););} \\ _Michel Marcus_, Jun 03 2013
%Y A094810 Cf. A000040, A305412.
%K A094810 nonn,changed
%O A094810 1,1
