%T A094402 51983,53663,65471,78089,79547,82983,86063,94667,104663,109871,121103,
%U A094402 139359,142883,157079,168299,195227,196559,200147,233519
%N A094402 Numbers k that divide both Fibonacci(k+1) and Lucas(k) + 1.
%C A094402 Numbers k that divide both Fibonacci(k)-1 and Fibonacci(k-1)+1. - _Chai Wah Wu_, Jul 17 2026
%H A094402 Chai Wah Wu, <a href="/A094402/b094402.txt">Table of n, a(n) for n = 1..4823</a> (terms 1..1000 from Giovanni Resta)
%t A094402 Select[Range[10^5],Divisible[Fibonacci[#+1],#]&&Divisible[LucasL[#]+1,#]&] (* _Giorgos Kalogeropoulos_, Aug 20 2021 *)
%o A094402 (PARI) is(n)=(Mod([0,1;1,1],n)^(n+1)*[0;1])[1,1]==0 && (Mod([0,1;1,1],n)^n*[2;1])[1,1]==-1 \\ _Charles R Greathouse IV_, Nov 04 2016
%o A094402 (Python)
%o A094402 from itertools import count, islice
%o A094402 def A094402_gen(startvalue=1): # generator of terms >= startvalue
%o A094402     def f(n,m): # returns true if fibonacci(n+1) == lucas(n)+1 == 0 mod m
%o A094402         a, b, c, d, a2, b2, c2, d2 = 1, 1, 1, 0, 1, 0, 0, 1
%o A094402         for x in bin(n)[2:]:
%o A094402             e, f = b2*c2%m, k if (k:=a2+d2)<m else k-m
%o A094402             a2, b2, c2, d2 = (a2*a2+e)%m, b2*f%m, c2*f%m, (d2*d2+e)%m
%o A094402             if x=='1':
%o A094402                 a2, b2, c2, d2 = (a2*a+b2*c)%m, (a2*b+b2*d)%m, (c2*a+d2*c)%m, (c2*b+d2*d)%m
%o A094402         return (d2+1)%m==0==(c2-1)%m
%o A094402     return (k for k in count(max(startvalue,1)) if f(k,k))
%o A094402 A094402_list = list(islice(A094402_gen(),30)) # _Chai Wah Wu_, Jul 17 2026
%Y A094402 Cf. A069107, A094398, A094400.
