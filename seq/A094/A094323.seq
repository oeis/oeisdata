%U A094323 4525917,5629848,6939380,8481980,10287459,12388068,14818594,17616456,20821801,24477600,28629744
%N A094323 a(n) = n*(n+1)*(2*n+1)*(3*n+1)*(4*n+1)/30.
%H A094323 <a href="/index/Rec#order_06">Index entries for linear recurrences with constant coefficients</a>, signature (6,-15,20,-15,6,-1).
%F A094323 From _Amiram Eldar_, Mar 08 2022: (Start)
%F A094323 Sum_{n>=1} 1/a(n) = 300 + (135*sqrt(3)/2 - 160)*Pi - 1200*log(2) + 1215*log(3)/2.
%F A094323 Sum_{n>=1} (-1)^(n+1)/a(n) = (60 + 160*sqrt(2) - 135*sqrt(3))*Pi + (160*sqrt(2) - 380)*log(2) - 320*sqrt(2)*log(2-sqrt(2)) - 300. (End)
%F A094323 From _Elmo R. Oliveira_, May 25 2026: (Start)
%F A094323 G.f.: x*(4 + 39*x + 46*x^2 + 7*x^3)/(1 - x)^6.
%F A094323 E.g.f.: x*(120 + 825*x + 935*x^2 + 290*x^3 + 24*x^4)*exp(x)/30.
%F A094323 a(n) = 6*a(n-1) - 15*a(n-2) + 20*a(n-3) - 15*a(n-4) + 6*a(n-5) - a(n-6).
%F A094323 a(n) = A011197(n)/5. (End)
%e A094323 a(4) = 4*5*9*13*17/30 = 1326.
%t A094323 a[n_] := n*(n+1)*(2*n+1)*(3*n+1)*(4*n+1)/30; Array[a, 30, 0] (* _Amiram Eldar_, Mar 08 2022 *)
%o A094323 (PARI) a(n) = n*(n+1)*(2*n+1)*(3*n+1)*(4*n+1)/30; \\ _Michel Marcus_, Aug 15 2013
