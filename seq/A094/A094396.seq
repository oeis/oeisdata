%N A094396 Numbers k such that k divides the (k-1)st Lucas number.
%H A094396 Chai Wah Wu, <a href="/A094396/b094396.txt">Table of n, a(n) for n = 1..287</a>
%t A094396 Do[If[Mod[Fibonacci[n-2] + Fibonacci[n], n] == 0, Print[n]], {n, 100000}] (* _Ryan Propper_, Jun 21 2005 *)
%o A094396 (PARI) is(n)=(Mod([0,1;1,1],n)^(n-1)*[0;1])[1,1]==0 \\ _Charles R Greathouse IV_, Nov 04 2016
%o A094396 (Python)
%o A094396 from itertools import count, islice
%o A094396 from oeis_sequences.OEISsequences import lucas_mod
%o A094396 def A094396_gen(startvalue=1): # generator of terms >= startvalue
%o A094396     return filter(lambda k: not lucas_mod(k-1,k),count(max(startvalue,1)))
%o A094396 A094396_list = list(islice(A094396_gen(),10)) # _Chai Wah Wu_, Jul 15 2026
