%I A094466 #13 Mar 30 2026 23:58:29
%S A094466 1,3,-1,5,3,19,3,7,3,11,-1,23,5,19,6,23,7,47,-1,6,14,6,7,15,11,43,46,
%T A094466 10,20,6,11,33,23,45,22,6,15,14,38,51,15,14,21,10,41,12,19,27,23,69,
%U A094466 -1,22,24,22,15,14,15,14,21,26,23,55,15,14,30,20,23,87,15,14,31,26,27,139,15,14,35
%N A094466 a(n) is the smallest positive integer k with property that phi(n+k)=sigma(k), or -1 if there is no such k.
%C A094466 From _Robert Israel_, Mar 29 2026: (Start)
%C A094466 If n is odd and k is an odd prime with phi(n+k) = sigma(k), then k <= n-2.
%C A094466 If k is composite and phi(n+k) = sigma(k), then k <= (n-3)^2. (End)
%H A094466 Robert Israel, <a href="/A094466/b094466.txt">Table of n, a(n) for n = 1..10000</a>
%F A094466 Least solution to Min{x; phi[x+n]=sigma[x]}.
%e A094466 n=6:a[6]=19 because sigma[19]=20=phi[19+6]=phi[25]=20.
%e A094466 n=16:a[16]=23 because sigma[23]=24=phi[23+16]=phi[39]=24
%p A094466 f:= proc(n) local km, k; uses NumberTheory;
%p A094466   km:= max(2,(n-3)^2);
%p A094466   for k from 1 to km do
%p A094466       if phi(n+k) = sigma(k) then return k fi;
%p A094466   od;
%p A094466   if n::odd then return -1 fi;
%p A094466   k:= km;
%p A094466   do
%p A094466     k:= nextprime(k);
%p A094466     if phi(n+k) = k+1 then return k fi
%p A094466   od;
%p A094466 end proc:
%p A094466 map(f, [$1..100]); # _Robert Israel_, Mar 29 2026
%Y A094466 Cf. A000010, A000203, A007015, A007365, A393634.
%K A094466 sign
