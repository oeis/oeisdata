%T A094400 701569,809999,850541,881011,1274897,1365407,1383249,1464449,1504097,
%U A094400 1653751,1922817,2106017,2276351,2385811,2474047,2556553,2628879,2697899,2804543,3017729,3352049
%N A094400 Odd n dividing Fibonacci(n)-1 but neither Fibonacci(n-1) nor Fibonacci(n+1).
%H A094400 Giovanni Resta, <a href="/A094400/b094400.txt">Table of n, a(n) for n = 1..559</a> (terms < 4*10^9)
%t A094400 Select[Range[50000], OddQ[ # ] && Mod[Fibonacci[ # ] - 1, # ] == 0 && ! Mod[Fibonacci[ # - 1], # ] == 0 && ! Mod[Fibonacci[ # + 1], # ] == 0 &]
%o A094400 (Python)
%o A094400 from itertools import count, islice
%o A094400 def A094400_gen(): # generator of terms
%o A094400     def fib_mod(n,m): # fibonacci(n) mod m
%o A094400         a, b, c, d, a2, b2, c2, d2 = 1, 1, 1, 0, 1, 0, 0, 1
%o A094400         for x in bin(n)[2:]:
%o A094400             e, f = b2*c2%m, a2+d2
%o A094400             a2, b2, c2, d2 = (pow(a2,2,m)+e)%m, b2*f%m, c2*f%m, (pow(d2,2,m)+e)%m
%o A094400             if x=='1':
%o A094400                 a2, b2, c2, d2 = (a2*a+b2*c)%m, (a2*b+b2*d)%m, (c2*a+d2*c)%m, (c2*b+d2*d)%m
%o A094400         return c2
%o A094400     for m in count(1,2):
%o A094400         if fib_mod(m,m)==1 and fib_mod(m-1,m)!=0 and fib_mod(m+1,m)!=0:
%o A094400             yield m
%o A094400 A094400_list = list(islice(A094400_gen(),20)) # _Chai Wah Wu_, Jul 01 2026
