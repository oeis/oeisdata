%I A094822 #20 Mar 04 2026 22:02:05
%S A094822 1,4,19,118,1021,12088,183727,3389242,73156249,1804349548,50009179819,
%T A094822 1537920654526,51952155415381,1911990785926432,76137201611236999,
%U A094822 3261400435090171522,149530099101901409713,7305923490645888605908,378947686822932957638851
%N A094822 Expansion of e.g.f.: exp(3*x)/(1-3*x)^(1/3).
%C A094822 Sum_{k = 0..n} A046716(n,k)*x^k give A000522(n), A081367(n) for x = 1, 2 respectively.
%H A094822 G. C. Greubel, <a href="/A094822/b094822.txt">Table of n, a(n) for n = 0..375</a>
%F A094822 a(n) = Sum_{k = 0..n} A046716(n, k)*3^k.
%F A094822 a(n) ~ Gamma(2/3)*3^(n+1/2)*n^(n-1/6)/(sqrt(2*Pi)*exp(n-1)). - _Vaclav Kotesovec_, Jun 15 2013
%F A094822 Conjecture: D-finite with recurrence: a(n) -(3*n+1)*a(n-1) +9*(n-1)*a(n-2) = 0. - _R. J. Mathar_, Nov 14 2019
%t A094822 With[{nn=25},CoefficientList[Series[Exp[3x]/Surd[1-3x,3],{x,0,nn}],x] Range[0,nn]!] (* _Harvey P. Dale_, Jul 28 2018 *)
%o A094822 (Magma)
%o A094822 R<x>:=PowerSeriesRing(Rationals(), 40);
%o A094822 Coefficients(R!(Laplace( Exp(3*x)/(1-3*x)^(1/3) ))); // _G. C. Greubel_, Mar 03 2026
%o A094822 (SageMath)
%o A094822 def A094822_list(prec):
%o A094822     P.<x>= PowerSeriesRing(QQ, prec)
%o A094822     return P( exp(3*x)/(1-3*x)^(1/3) ).egf_to_ogf().list()
%o A094822 print(A094822_list(41)) # _G. C. Greubel_, Mar 03 2026
%Y A094822 Cf. A000522, A046716, A081367.
%K A094822 nonn
%O A094822 0,2
