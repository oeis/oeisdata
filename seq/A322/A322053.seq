%I A322053 #34 Jun 02 2026 11:37:27
%S A322053 0,1,19,280,3691,45739,544870,6315481,71743159,802527760,8868438271,
%T A322053 97038694279,1053164192950,11351825985061,121644911602099,
%U A322053 1296970638284440,13767539948978851,145580595285369619,1534133217109136230,16117424311550552641,168864017757937199839
%N A322053 Number of decimal strings of length n that contain a specific string xx (where x is a single digit).
%C A322053 See A322054 for the number that do not contain the specified string.
%H A322053 Vincenzo Librandi, <a href="/A322053/b322053.txt">Table of n, a(n) for n = 1..1000</a>
%H A322053 <a href="/index/Rec#order_03">Index entries for linear recurrences with constant coefficients</a>, signature (19,-81,-90).
%F A322053 G.f.: x^2/((1-10*x)*(1-9*x-9*x^2)).
%F A322053 a(n) = 10^n - A322054(n). - _R. J. Mathar_, May 28 2026
%F A322053 E.g.f.: exp(10*x) - exp(9*x/2)*(39*cosh(3*sqrt(13)*x/2) + 11*sqrt(13)*sinh(3*sqrt(13)*x/2))/39. - _Stefano Spezia_, Jun 02 2026
%e A322053 Suppose the desired string is 00. At length 2 that is the only possibility. At length 3 there are 19 strings that contain it: 000, 00d, and d00, where d is any nonzero digit.
%t A322053 Rest[CoefficientList[Series[x^2/((1-10*x)*(1-9*x-9*x^2)),{x,0,25}],x]] (* _Vincenzo Librandi_, Mar 16 2026 *)
%o A322053 (Magma) R<x>:=PowerSeriesRing(Rationals(), 25); [0] cat Coefficients(R! x^2/((1-10*x)*(1-9*x-9*x^2))); // _Vincenzo Librandi_, Mar 16 2026
%o A322053 (Python)
%o A322053 n, a0, a1, a2 = 2, 1, 0, 0
%o A322053 print(str(a1)+", "+str(a0), end = ", ")
%o A322053 while n < 21:
%o A322053     n, a0, a1, a2 = n+1, 19*a0-81*a1-90*a2, a0, a1
%o A322053     print(a0, end = ", ") # _A.H.M. Smeets_, May 28 2026
%o A322053 (PARI) concat([0], Vec(x^2/((1-10*x)*(1-9*x-9*x^2)) + O(x^22))) \\ _A.H.M. Smeets_, May 29 2026
%Y A322053 Cf. A322052, A004189, A322054.
