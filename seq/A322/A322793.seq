%I A322793 #22 Apr 07 2026 00:19:36
%S A322793 4,8,16,32,36,64,128,216,256,512,900,1024,1296,2048,4096,7776,8192,
%T A322793 16384,27000,32768,44100,46656,65536,131072,262144,279936,524288,
%U A322793 810000,1048576,1679616,2097152,4194304,5336100,8388608,9261000,10077696,16777216,24300000,33554432
%N A322793 Proper powers of primorial numbers.
%C A322793 A primorial number is a product of the first n primes, for some n.
%C A322793 Also Heinz numbers of non-strict uniform integer partitions whose union is an initial interval of positive integers. An integer partition is uniform if all parts appear with the same multiplicity. The Heinz number of an integer partition (y_1, ..., y_k) is prime(y_1) * ... * prime(y_k).
%H A322793 Michael De Vlieger, <a href="/A322793/b322793.txt">Table of n, a(n) for n = 1..8255</a>
%F A322793 Sum_{n>=1} 1/a(n) = Sum_{k>=1} 1/(A002110(k)*(A002110(k)-1)) = 0.53450573145072369022... . - _Amiram Eldar_, Mar 10 2024
%e A322793 The sequence of all non-strict uniform integer partitions whose Heinz numbers belong to the sequence begins: (11), (111), (1111), (11111), (2211), (111111), (1111111), (222111), (11111111), (111111111), (332211), (1111111111), (22221111).
%t A322793 unintpropQ[n_]:=And[SameQ@@Last/@FactorInteger[n],FactorInteger[n][[1,2]]>1,Length[FactorInteger[n]]==PrimePi[FactorInteger[n][[-1,1]]]];
%t A322793 Select[Range[10000],unintpropQ]
%t A322793 (* Alternative: *)
%t A322793 nn = 2^26; k = 1; P = 2; Union@ Reap[While[j = 2; While[P^j < nn, Sow[P^j]; j++]; j > 2, k++; P *= Prime[k]]][[-1, 1]] (* _Michael De Vlieger_, Oct 04 2023 *)
%o A322793 (Python)
%o A322793 from itertools import count
%o A322793 from functools import lru_cache
%o A322793 from sympy import integer_log
%o A322793 from oeis_sequences.OEISsequences import bisection
%o A322793 def A322793(n):
%o A322793     @lru_cache(maxsize=None)
%o A322793     def primorial(x): return 2 if x==1 else primorial(x-1)*prime(x)
%o A322793     def f(x):
%o A322793         c = n+x
%o A322793         for k in count(1):
%o A322793             if primorial(k)>x:
%o A322793                 break
%o A322793             c -= integer_log(x,primorial(k))[0]-1
%o A322793         return c
%o A322793     return bisection(f,n,n) # _Chai Wah Wu_, Apr 04 2026
%o A322793 (Python)
%o A322793 from itertools import islice
%o A322793 from math import prod
%o A322793 from heapq import heappop, heappush
%o A322793 from sympy import nextprime
%o A322793 def A322793_gen(): # generator of terms if the first n terms are desired.
%o A322793     h, hset = [(4,(2,),2)], {4}
%o A322793     while True:
%o A322793         m, ps, e = heappop(h)
%o A322793         yield m
%o A322793         for p in ps:
%o A322793             mp = m*prod(ps)
%o A322793             if mp not in hset:
%o A322793                 heappush(h,(mp,ps,e+1))
%o A322793                 hset.add(mp)
%o A322793         q = nextprime(max(ps,default=1))
%o A322793         mp = m*q**e
%o A322793         if mp not in hset:
%o A322793             heappush(h,(mp,(ps+(q,)),e))
%o A322793             hset.add(mp)
%o A322793 A322793_list = list(islice(A322793_gen(),40)) # _Chai Wah Wu_, Apr 04 2026
%Y A322793 Cf. A000961, A001597, A001694, A002110, A025487, A047966, A055932, A056239, A072774, A072777, A100778, A112798, A304250, A322792.
