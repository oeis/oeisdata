%F A009927 From _Jianing Song_, May 22 2026: (Start)
%F A009927 a(n) = a(n-2) + 2*a(n-3) + a(n-4) + 2*a(n-5) - 2*a(n-7) - a(n-8) - 2*a(n-9) + a(n-10) + a(n-12) for n >= 15.
%F A009927 a(n) = (187*n^2 + c1*n + c0)/12 for n >= 3, where c1 = [-72,-86,-100,-54,-104,-118,-36,-86,-136,-54,-68,-118] and c0 = [-216,139,196,-81,40,43,36,175,-56,-117,292,79] for n == 0..11 (mod 12). (End)
%o A009927 (PARI) a(n) = if(n<=2, [1,12,50][n+1], my(c1=[-72,-86,-100,-54,-104,-118,-36,-86,-136,-54,-68,-118], c0 = [-216,139,196,-81,40,43,36,175,-56,-117,292,79]); (187*n^2 + c1[n%12+1]*n + c0[n%12+1])/12) \\ _Jianing Song_, May 22 2026
