%N A027182 a(n) = self-convolution of row n of array T given by A027170.
%C A027182 Let g(x) = Sum_(k=0..n) A027170(n,k)*x^k be the generating function of row n, then a(n) = [x^n] g(x)^2. - _R. J. Mathar_, May 06 2026
%F A027182 Conjecture: D-finite with recurrence 2*(n+2)*a(n) +(-17*n-23)*a(n-1) +(47*n+36)*a(n-2) +2*(-22*n-17)*a(n-3) +4*(-n+20)*a(n-4) +8*(2*n-9)*a(n-5) +24*(12*n-47)=0. - _R. J. Mathar_, May 06 2026
%e A027182 a(2) = 5*5+10*10+5*5=120. a(3) = 7*7+19*19+19*19+7*7=820. - _R. J. Mathar_, May 06 2026
%p A027182 A027182 := proc(n)
%p A027182     local x,k ;
%p A027182     add(A027170(n,k)*x^k,k=0..n) ;
%p A027182     %^2 ;
%p A027182     coeff(%,x^n) ;
%p A027182 end proc:
%p A027182 seq(A027182(n),n=1..40) ;
