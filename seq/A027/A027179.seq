%N A027179 a(n) = T(n,0) + T(n,1) + ... + T(n,[ n/2 ]), T given by A027170.
%F A027179 Conjecture: D-finite with recurrence -(n+2)*(3*n-20)*a(n) -(n+1)*(3*n-11)*a(n-1) +(33*n^2-180*n-100)*a(n-2) +(15*n^2-56*n+1)*a(n-3) +2*(-51*n^2+313*n-208)*a(n-4) -12*(n-1)*(n-4)*a(n-5) +8*(9*n-11)*(n-5)*a(n-6) +4*(-24*n^2+196*n-365)=0. - _R. J. Mathar_, May 06 2026
%F A027179 For odd n, a(n) = A027178(n)/2. For even n, a(n) = (A027178(n)+A027177(n))/2. - _R. J. Mathar_, May 06 2026
%p A027179 A027179 := proc(n)
%p A027179     add(A027170(n,k),k=0..floor(n/2)) ;
%p A027179 end proc:
%p A027179 seq(A027179(n),n=0..50) ; # _R. J. Mathar_, May 06 2026
