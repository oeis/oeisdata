%I A027696 #50 Apr 16 2026 00:53:10
%S A027696 3,4,6,8,10,11,14,17,30,41,43,50,60,88,145,276,322,374,823,1152
%N A027696 Numbers k >= 2 such that for some m >= 2, the sum of the first m k-gonal numbers is again a k-gonal number, excluding the parametric solution m = (k^2-4*k-2)/3 when k==2 (mod 3).
%C A027696 The parametric solution: if k==2 (mod 3) and k >= 5, the sum of the first (k^2-4*k-2)/3 k-gonal numbers is the ((k^3-6*k^2+3*k+19)/9)-th k-gonal number A057145(k,(k^3-6*k^2+3*k+19)/9) = A344410((k-2)/3).
%C A027696 2378, 2386, and 31265 are also terms. See link "Cannon Ball Numbers". - _Pontus von Brömssen_, Jan 08 2025
%C A027696 Number k is a term iff the elliptic curve (3*k-6)*y^2 - (3*k-12)*y = (k-2)*x^3 + 3*x^2 - (k-5)*x has an integral point with x >= 2 different from (k^2-4*k-2)/3. The listed values may be incomplete. For example, I was not able to verify that k = 273 is not a term. - _Max Alekseyev_, Feb 27 2025
%C A027696 This sequence includes 4980, 9325, 9525, 16420, 19605, 31368, 83135, 125070, 210903, 223613, and 191070870. - _Ian Olivant_, Apr 06 2026; updated by _Max Alekseyev_, Apr 15 2026
%H A027696 Brady Haran and Matt Parker, <a href="https://www.numberphile.com/cannon-ball-numbers">Cannon Ball Numbers</a>, Numberphile (2019).
%o A027696 (Python)
%o A027696 import numpy as np
%o A027696 from collections import Counter
%o A027696 def g(k, m):
%o A027696     return (k-4+np.sqrt((4*m*(k-2)*(m+1)*(k*m-k-2*m+5))/3+(k-4)*(k-4)))/(2*(k-2))
%o A027696 eligible_k_values = []
%o A027696 for k in range(3,1000000):
%o A027696     m_limit_calc = (3*2**53)/(k-2)
%o A027696     if m_limit_calc < 0:
%o A027696         continue
%o A027696     m_upper_bound = int(m_limit_calc**(1/3))
%o A027696     for m in range(2, m_upper_bound):
%o A027696         g_k_m_val = g(k,m)
%o A027696         if np.iscomplex(g_k_m_val):
%o A027696             continue
%o A027696         if float(g_k_m_val).is_integer() and (k-2)*g_k_m_val*g_k_m_val < 2**53:
%o A027696             eligible_k_values.append(k)
%o A027696 k_counts = Counter(eligible_k_values)
%o A027696 printed_k = set()
%o A027696 for k_val in eligible_k_values:
%o A027696     if k_counts[k_val] > 1 and (k_val + 1) % 3 == 0:
%o A027696         if k_val not in printed_k:
%o A027696             printed_k.add(k_val)
%o A027696     if (k_val + 1) % 3 != 0:
%o A027696         if k_val not in printed_k:
%o A027696             printed_k.add(k_val)
%o A027696 sorted_list = sorted(printed_k)
%o A027696 print(sorted_list) # _Ian Olivant_, Apr 06 2026
%Y A027696 Cf. A027669, A057145, A344410, A373711.
%K A027696 nonn,more
%O A027696 1,1
%A A027696 Masanobu Kaneko (mkaneko(AT)math.kyushu-u.ac.jp)
