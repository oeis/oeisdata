%N A014579 Inverse of 570th cyclotomic polynomial.
%C A014579 Periodic with period length 570. - _Ray Chandler_, Apr 06 2017
%H A014579 Ray Chandler, <a href="/A014579/b014579.txt">Table of n, a(n) for n = 0..1000</a>
%H A014579 <a href="/index/Per#periodic">Index entries for periodic sequences</a>.
%H A014579 <a href="/index/Rec#order_144">Index entries for linear recurrences with constant coefficients</a>, order 144.
%H A014579 <a href="/index/Pol#poly_cyclo_inv">Index to sequences related to inverse of cyclotomic polynomials</a>
%p A014579 with(numtheory,cyclotomic); c := n->series(1/cyclotomic(n,x),x,80);
%t A014579 CoefficientList[Series[1/Cyclotomic[570,x],{x,0,120}],x,120] (* _Harvey P. Dale_, Jan 10 2023 *)
%o A014579 (PARI) Vec(1/polcyclo(570)+O(x^99)) \\ _Charles R Greathouse IV_, May 31 2026
