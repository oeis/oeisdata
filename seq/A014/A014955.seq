%N A014955 Inverse of 946th cyclotomic polynomial.
%C A014955 Periodic with period length 946. - _Ray Chandler_, Apr 07 2017
%H A014955 Ray Chandler, <a href="/A014955/b014955.txt">Table of n, a(n) for n = 0..1000</a>
%H A014955 <a href="/index/Per#periodic">Index entries for periodic sequences</a>, period 946.
%H A014955 <a href="/index/Rec#order_420">Index entries for linear recurrences with constant coefficients</a>, order 420.
%H A014955 <a href="/index/Pol#poly_cyclo_inv">Index to sequences related to inverse of cyclotomic polynomials</a>
%p A014955 with(numtheory,cyclotomic); c := n->series(1/cyclotomic(n,x),x,80);
%t A014955 CoefficientList[Series[1/Cyclotomic[946,x],{x,0,120}],x,120] (* _Harvey P. Dale_, May 02 2026 *)
%o A014955 (PARI) first(n)=Vec(1/polcyclo(946)+O(x^(n+1))) \\ _Charles R Greathouse IV_, Jun 01 2026
%K A014955 sign,easy,changed
%O A014955 0,1
%A A014955 _Simon Plouffe_
