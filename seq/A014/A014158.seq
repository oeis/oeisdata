%S A014158 13,20,25,32,39,40,51,58,59,62,76,77,81,84,88,89,95,96,98,102,103,104,
%T A014158 111,115,116,123,124,151,160,165,166,168,175,176,186,193,202,205,209,
%U A014158 213,214,215,221,228,229,241,242,263,268,270,273,287,289,291,293,306,310,312
%N A014158 Numbers that are not the sum of 2 nonnegative cubes and a triangular number.
%H A014158 Robert Israel, <a href="/A014158/b014158.txt">Table of n, a(n) for n = 1..10000</a>
%p A014158 N:= 500: # for terms <= N
%p A014158 cm:= floor(surd(N,3)): CC:= select(`<=`,{seq(seq(i^3 + j^3, j=i..cm),i=0..cm)},N):
%p A014158 tm:= floor((sqrt(1+8*N)-1)/2): T:= {seq(i*(i+1)/2,i=0..tm)}:
%p A014158 sort(convert(select(`<=`,{seq(seq(cc+t,t=T),cc=CC)},N),list)); # _Robert Israel_, Apr 17 2026
%Y A014158 Cf. A014157 (complement).
%K A014158 nonn
%O A014158 1,1
%A A014158 _N. J. A. Sloane_
