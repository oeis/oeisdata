%N A014155 Sum of a nonnegative cube and a triangular number.
%H A014155 Robert Israel, <a href="/A014155/b014155.txt">Table of n, a(n) for n = 1..10000</a>
%p A014155 N:= 200: # for terms <= N
%p A014155 nC:= floor(surd(N,3)): C:= {seq(i^3,i=0..nC)}:
%p A014155 nT:= floor((sqrt(1+8*N)-1)/2): T:= {seq(i*(i+1)/2,i=0..nT)}:
%p A014155 sort(convert(select(`<=`,{seq(seq(c+t,c=C),t=T)},N),list)); # _Robert Israel_, Apr 17 2026
