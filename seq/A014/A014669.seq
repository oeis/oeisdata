%p A014669 with(numtheory,cyclotomic); c := n->series(1/cyclotomic(n,x),x,80);
%t A014669 CoefficientList[Series[1/Cyclotomic[660,x],{x,0,120}],x] (* _Harvey P. Dale_, Jul 22 2022 *)
