%S A112250 5,7,8,10,11,13,14,17,18,19,21,22,23,25,26,27,29,30,31,32,33,34,36,37,
%T A112250 38,39,41,42,43,44,46,47,48,49,51,52,53,54,56,57,58,59,61,62,63,64,65,
%U A112250 67,68,69,70,71,73,74,75,76,77,79,80,81,82,83,85,86,87,88,89,91,92,93
%N A112250 Numbers m such that m mod floor(log_2(m)) > 0.
%C A112250 The asymptotic density of this sequence is 1 (Cooper and Kennedy, 1989). - _Amiram Eldar_, Jul 10 2020
%H A112250 Robert Israel, <a href="/A112250/b112250.txt">Table of n, a(n) for n = 1..10000</a>
%H A112250 Curtis N. Cooper and Robert E. Kennedy, <a href="https://www.jstor.org/stable/2323194">Chebyshev's inequality and natural density</a>, Amer. Math. Monthly, Vol. 96, No. 2 (1989), pp. 118-124.
%F A112250 A112248(a(n)) > 0.
%p A112250 seq(op(select(t -> t mod d > 0, [$2^d .. 2^(d+1)-1])),d=1..6); # _Robert Israel_, Aug 27 2020
%o A112250 (Python)
%o A112250 def A112250(n):
%o A112250     def f(x):
%o A112250         c, l, a = n+1, x.bit_length(), 2
%o A112250         for i in range(1,l-1):
%o A112250             c -= (a-1)//i
%o A112250             a <<= 1
%o A112250             c += (a-1)//i
%o A112250         if l>1:
%o A112250             c += x//(l-1)-(a-1)//(l-1)
%o A112250         return c
%o A112250     m, k = n, f(n)
%o A112250     while m != k: m, k = k, f(k)
%o A112250     return m # _Chai Wah Wu_, Jul 02 2026
%Y A112250 Complement of A112249.
%Y A112250 A112251 is a subsequence.
%Y A112250 Cf. A000523, A112248.
%K A112250 nonn
%O A112250 1,1
%A A112250 _Reinhard Zumkeller_, Aug 30 2005
%E A112250 Name changed by _Robert Israel_, Aug 27 2020
