%I A112992 #29 Jul 18 2026 04:45:59
%S A112992 1,2,4,8,16,25,32,45,55,64,91,95,99,125,128,135,143,153,155,161,175,
%T A112992 187,225,235,245,247,256,261,273,275,279,285,289,297,319,329,333,335,
%U A112992 355,363,369,387,391,403,407,413,423,425,429,435,437,441,459,473,477,481,483,493
%N A112992 Numbers k such that ceiling(2^(2^k mod k)/3) is odd.
%C A112992 Conjecture: the odd values of ceiling(2^(2^k mod k)/3) are Jacobsthal numbers (and the even values are 1 plus a Jacobsthal number).
%C A112992 Numbers k such that 2^k mod k is 0 or an odd number. Includes A000079 (corresponding to 2^k mod k = 0) but no other even numbers. - _Robert Israel_, Jul 15 2026
%H A112992 Robert Israel, <a href="/A112992/b112992.txt">Table of n, a(n) for n = 1..10000</a>
%p A112992 filter:= proc(k) local m;
%p A112992   m:= 2^k mod k;
%p A112992   m = 0 or m::odd;
%p A112992 end proc:
%p A112992 select(filter, [$1..1000]); # _Robert Israel_, Jul 15 2026
%t A112992 Select[Range[493], OddQ[Ceiling[2^PowerMod[2, #, #]/3]]&] (* _James C. McMahon_, Jun 14 2024 *)
%o A112992 (PARI) isok(k) = (ceil(2^lift(Mod(2, k)^k)/3) % 2) == 1; \\ _Michel Marcus_, Jun 14 2024
%o A112992 (Python)
%o A112992 from itertools import count, islice
%o A112992 def A112992_gen(startvalue=1): # generator of terms >= startvalue
%o A112992     return filter(lambda k: (m:=pow(2,k,k))==0 or m&1, count(max(startvalue,1)))
%o A112992 A112992_list = list(islice(A112992_gen(),30)) # _Chai Wah Wu_, Jul 17 2026
%Y A112992 Cf. A000079, A005578, A001045.
%K A112992 easy,nonn,changed
%O A112992 1,2
%A A112992 _Paul Barry_, Oct 08 2005
