%U A112755 3,3,5,3,3,3,3,3,3,3,3,3,3,3,3,3,3,5,3,3,3,3,3,3,3,3,3,3,3,3,3,3,3,3,5,3,3
%N A112755 Smallest prime factor of n-th number of the form 3^i*5^j.
%H A112755 Amiram Eldar, <a href="/A112755/b112755.txt">Table of n, a(n) for n = 1..10000</a>
%F A112755 a(n) = A020639(A003593(n));
%F A112755 a(n) <= A112756(n) <= 5.
%t A112755 s = {}; m = 12; Do[n = 5^k; While[n <= 5^m, AppendTo[s, n]; n *= 3], {k, 0, m}]; FactorInteger[#][[1, 1]] & /@ Union[s] (* _Amiram Eldar_, Feb 07 2020 *)
%o A112755 (Python)
%o A112755 from sympy import integer_log
%o A112755 from oeis_sequences.OEISsequences import bisection
%o A112755 def A112755(n):
%o A112755     if n == 1: return 1
%o A112755     def f(x): return n+x-sum(integer_log(x//5**i,3)[0]+1 for i in range(integer_log(x,5)[0]+1))
%o A112755     return 3+(bool(bisection(f,n,n)%3)<<1) # _Chai Wah Wu_, Mar 13 2026
%Y A112755 Cf. A003593, A020639, A086410, A112756, A112763.
%K A112755 nonn,changed
%O A112755 1,2
%A A112755 _Reinhard Zumkeller_, Sep 18 2005
