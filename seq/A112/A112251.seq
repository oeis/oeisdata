%I A112251 #16 Jul 03 2026 21:40:36
%S A112251 5,7,10,13,17,21,25,29,36,41,46,51,56,61,67,73,79,85,91,97,103,109,
%T A112251 115,121,127,134,141,148,155,162,169,176,183,190,197,204,211,218,225,
%U A112251 232,239,246,253,257,265,273,281,289,297,305,313,321,329,337,345,353,361
%N A112251 Numbers m such that m mod floor(log_2(m)) = 1.
%C A112251 A112248(a(n)) = 1; subsequence of A112250.
%H A112251 Alois P. Heinz, <a href="/A112251/b112251.txt">Table of n, a(n) for n = 1..20000</a>
%p A112251 q:= m-> is(m mod ilog2(m)=1):
%p A112251 select(q, [$2..361])[];  # _Alois P. Heinz_, Jul 03 2026
%o A112251 (Python)
%o A112251 from oeis_sequences.OEISsequences import bisection
%o A112251 def A112251(n):
%o A112251     def f(x):
%o A112251         c, l, a = n+2+x, x.bit_length(), 2
%o A112251         for i in range(1,l-1):
%o A112251             c += (a-2)//i
%o A112251             a <<= 1
%o A112251             c -= (a-2)//i
%o A112251         if l>1:
%o A112251             c -= (x-1)//(l-1)-(a-2)//(l-1)
%o A112251         return c
%o A112251     return bisection(f,n,n) # _Chai Wah Wu_, Jul 02 2026
%Y A112251 Cf. A000523, A112248, A112250.
%K A112251 nonn,changed
%O A112251 1,1
