%F A206608 a(n) = Fibonacci(n+5) + Fibonacci(n-6). - _Greg Dresden_ and Gavron Campbell, Mar 03 2022
%F A206608 From _Elmo R. Oliveira_, Mar 31 2026: (Start)
%F A206608 G.f.: -(16*x - 3)/(x^2 + x - 1).
%F A206608 a(n) = a(n-1) + a(n-2) for n > 2.
%F A206608 a(n) = 13*Fibonacci(n) - 3*Fibonacci(n-1). (End)
%p A206608 a:= n-> (<<0|1>, <1|1>>^n.<<-3, 13>>)[1, 1]:
%p A206608 seq(a(n), n=1..36);  # _Alois P. Heinz_, Mar 31 2026
