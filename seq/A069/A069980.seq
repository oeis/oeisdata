%S A069980 0,0,54,711,4077,15606,46629,117621,262125,531423,0,36,684,4059,15588,
%T A069980 46629,117612,262107,531423,999963,54,693,4059,15579,46620,117621,
%U A069980 262098,531396,999963,1771524,711,4050,15588,46602,117612,262098
%N A069980 (Sum of digits of n)^6 - (sum of digits of n^6).
%C A069980 a(n) = 0 iff n is 0 or a power of ten.
%H A069980 Robert Israel, <a href="/A069980/b069980.txt">Table of n, a(n) for n = 0..10000</a>
%p A069980 f:= n -> convert(convert(n,base,10),`+`)^6 - convert(convert(n^6,base,10),`+`):
%p A069980 map(f, [$0..100]); # _Robert Israel_, May 12 2026
%t A069980 f[n_] := Plus @@ IntegerDigits[n]^6 - Plus @@ (IntegerDigits[n^6]); Table[ f[n], {n, 0, 100}]
%K A069980 base,easy,nonn,look,changed
%O A069980 0,3
%A A069980 _N. J. A. Sloane_ and _Robert G. Wilson v_, May 04 2002
