%T A090540 77777733337711311773333777777,3777777333377113117733337777773,
%U A090540 33377777733337711311773333777777333,333333337777773333771131177333377777733333333,9933333333777777333377113117733337777773333333399,33333993333333377777733337711311773333777777333333339933333
%N A090540 Beginning with 3, least prime obtained by sandwiching the previous term between strings of identical digits.
%C A090540 Questions: (1) Is this sequence infinite? (2) If so, are the digits equally distributed? - _Stefan Steinerberger_, Nov 08 2005
%C A090540 a(21) has 1051 digits. - _Michael S. Branicky_, Jun 13 2026
%H A090540 Michael S. Branicky, <a href="/A090540/b090540.txt">Table of n, a(n) for n = 1..20</a>
%o A090540 (Python)
%o A090540 from itertools import count, islice
%o A090540 from sympy import isprime
%o A090540 def agen(): # generator of terms
%o A090540     an = 3
%o A090540     while True:
%o A090540         yield an
%o A090540         s = str(an)
%o A090540         an = next(t for k in count(1) for sk in [d*k for d in "1379"] if isprime(t:=int(sk + s + sk)))
%o A090540 print(list(islice(agen(), 11))) # _Michael S. Branicky_, Jun 13 2026
%K A090540 base,nonn
%O A090540 1,1
%A A090540 _Amarnath Murthy_, Dec 09 2003
%E A090540 a(6)-a(8) from _Jim Nastos_, Jan 30 2004
%E A090540 a(9)-a(11) from _Stefan Steinerberger_, Nov 08 2005
