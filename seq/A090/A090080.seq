%I A090080 #13 Jun 06 2026 16:56:17
%S A090080 2,1,5,1,5,5,5,5,5,5,1,21,21,21,5,21,5,5,5,5,21,5,21,21,5,21,5,21,21,
%T A090080 5,1,5,21,21,85,21,21,21,21,85,21,85,5,5,21,5,21,5,5,21,21,5,5,5,5,5,
%U A090080 21,5,85,21,21,85,21,21,21,21,85,85,85,85,21,21,21,85,21,5,21,21,21
%N A090080 In binary expansion of n-th prime: reduce contiguous blocks of 0's to 0 and contiguous blocks of 1's to 1.
%H A090080 Robert Israel, <a href="/A090080/b090080.txt">Table of n, a(n) for n = 1..10000</a>
%F A090080 a(n) = A090079(A000040(n)).
%e A090080 A000040(25)=97 -> '1100001' -> [11][0000][1] -> [1][0][1] ->
%e A090080 '101' -> 5=a(25).
%p A090080 f:= proc(n) local L,k;
%p A090080   L:= convert(n,base,2);
%p A090080   k:= 1+numboccur(1, L[1..-2]-L[2..-1]);
%p A090080   (4^k-1)/3
%p A090080 end proc:
%p A090080 f(2):= 2:
%p A090080 map(f @ ithprime, [$1..100]); # _Robert Israel_, Jun 05 2026
%t A090080 A090080[n_] := FromDigits[DeleteAdjacentDuplicates[IntegerDigits[Prime[n], 2]], 2];
%t A090080 Array[A090080, 100] (* _Paolo Xausa_, Jun 06 2026 *)
%Y A090080 Cf. A000040, A004676, A090079.
%K A090080 nonn,base,changed
%O A090080 1,1
%A A090080 _Reinhard Zumkeller_, Nov 20 2003
