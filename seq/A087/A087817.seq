%N A087817 a(n) = a(a(a(n-1)))+a(n-a(n-1)) with a(1)=a(2)=1.
%H A087817 Michel Marcus, <a href="/A087817/b087817.txt">Table of n, a(n) for n = 1..1000</a>
%F A087817 Conjecture: a(n) is asymptotic to n^c with c=0.677.... - _Benoit Cloitre_, Jun 05 2004
%t A087817 a[1] = a[2] = 1; a[n_Integer?Positive] :=a[n] = a[a[a[n - 1]]] + a[n - a[n - 1]]; Table[a[n], {n, 1, 100}]
%o A087817 (PARI) lista(nn) = {va = vector(nn); va[1] = 1; va[2] = 1; for (n=3, nn, va[n] = va[va[va[n-1]]]+va[n-va[n-1]];); va;} \\ _Michel Marcus_, Aug 06 2017
