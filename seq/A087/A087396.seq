%I A087396 #11 Apr 23 2026 00:25:26
%S A087396 22,44,66,88,1010,222,1001,1144,333,1100,22,444,1001,2002,555,2112,
%T A087396 1122,666,1881,1100,777,44,1771,888,1100,1144,999,2772,2233,3300,4433,
%U A087396 2112,66,1122,1155,1188,111,3344,3003,2200,2255,2772,3311,88,4455,4554,1551
%N A087396 Smallest nontrivial multiple of n with each digit occurring with the same frequency >1. By nontrivial we mean a(n) is not a concatenation of n with itself.
%H A087396 Robert Israel, <a href="/A087396/b087396.txt">Table of n, a(n) for n = 1..10000</a>
%e A087396 a(12) = 2112 and not 1212 ( trivial).
%p A087396 f:= proc(n) local m,L,Ln,S,k;
%p A087396     Ln:= convert(n,base,10);
%p A087396     for m from 2*n by n do
%p A087396       L:= convert(m,base,10);
%p A087396       S:= convert(map(rhs,Statistics:-Tally(L,output=list)),set);
%p A087396       if nops(S) > 1 or S[1] = 1 then next fi;
%p A087396       k:= nops(L)/nops(Ln);
%p A087396       if not(k::posint and k > 1 and L = map(op,[Ln$k])) then return m fi;
%p A087396     od
%p A087396 end proc:
%p A087396 map(f, [$1..100]); # _Robert Israel_, Apr 22 2026
%K A087396 base,nonn,look,changed
%O A087396 1,1
%A A087396 _Amarnath Murthy_, Sep 10 2003
%E A087396 More terms from _David Wasserman_, May 31 2005
