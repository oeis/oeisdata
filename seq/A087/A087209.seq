%I A087209 #18 May 02 2026 20:50:04
%S A087209 3,29,45,76,162,192,397,405,612,650,1025,1098,1275,1856,2064,2160,
%T A087209 2187,2880,3420,4864,5499,6831,6875,8775,9072,10368,12288,12348,15000,
%U A087209 21096,21141,25408,25920,26811,29079,30600,30758,32805,33957,36875,39168
%N A087209 Numbers k such that k^2 = x^3 + y^4 with positive integers x, y.
%C A087209 There are an infinite number of solutions. Parametrizations are given at the Alpern link.
%H A087209 Robert Israel, <a href="/A087209/b087209.txt">Table of n, a(n) for n = 1..380</a>
%H A087209 Dario Alpern, <a href="https://www.alpertron.com.ar/SUMPOWER.HTM#4_3_2">Sum of powers</a>
%e A087209 3 is a term because 3^2 = 2^3 + 1^4.
%e A087209 45 is a term because 45^2 = 9^3 + 6^4 = 729 + 1296 = 2025.
%p A087209 N:= 10^10: # for terms <= sqrt(N)
%p A087209 Res:= NULL:
%p A087209 for x from 1 while x^3 < N do
%p A087209   for y from 1 do
%p A087209     w:= x^3 + y^4;
%p A087209   if w > N then break fi;
%p A087209   if issqr(w) then Res:= Res, sqrt(w) fi
%p A087209 od od:
%p A087209 sort(convert({Res},list)); # _Robert Israel_, Apr 30 2026
%Y A087209 Cf. A087210, solutions with gcd(n, x, y) = 1.
%K A087209 nonn,changed
%O A087209 1,1
%A A087209 _Hugo Pfoertner_, Aug 26 2003
