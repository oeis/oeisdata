%U A087288 33554434,67108864,134217730,268435456,536870914,1073741824,2147483650,4294967296,8589934594,17179869184
%N A087288 a(n) = 2*a(n-1) + a(n-2) - 2*a(n-3), with initial terms 4, 4, 10.
%H A087288 Indranil Ghosh, <a href="/A087288/b087288.txt">Table of n, a(n) for n = 0..3314</a>
%H A087288 <a href="/index/Rec#order_03">Index entries for linear recurrences with constant coefficients</a>, signature (2,1,-2).
%F A087288 G.f.: 2*(2-2*x-x^2)/(1-2*x-x^2+2*x^3).
%F A087288 a(n) = 2^(n+1) + 1 + (-1)^n.
%F A087288 a(n) = (A000051(n) - A014551(n))/2.
%F A087288 From _Elmo R. Oliveira_, Jun 13 2026: (Start)
%F A087288 a(n) = 2*A052531(n).
%F A087288 E.g.f.: 2*(exp(2*x) + cosh(x)). (End)
%t A087288 CoefficientList[Series[(4 - 4x - 2x^2)/(1 - 2x - x^2 + 2x^3), {x, 0, 30}], x]
%t A087288 (* Alternative: *)
%t A087288 LinearRecurrence[{2, 1, -2}, {4, 4, 10}, 40] (* _Robert C. Lyons_, Jun 28 2026 *)
%o A087288 (PARI) a(n)=2<<n+1+(-1)^n \\ _Charles R Greathouse IV_, Aug 20 2013
