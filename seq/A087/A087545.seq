%I A087545 #10 May 08 2026 11:02:17
%S A087545 0,1,10,111,1212,13230,14442,276724,2911664,31883886,34795550,
%T A087545 6667943601,670273915104,67694185870506,683644597856108,
%U A087545 75133878372661410,758175229705175184,83330910807783659415,840890860374888345996,924221771182672005411,176511263155756035140700,177435484926938707146111
%N A087545 a(0) = 0, a(1) = 1, a(n) = smallest multiple of n beginning with the sum of two previous terms.
%H A087545 Robert Israel, <a href="/A087545/b087545.txt">Table of n, a(n) for n = 0..427</a>
%e A087545 a(3) = 10, a(4) = 111, a(5) = 1212 is the smallest prime beginning with 10+111 = 121.
%p A087545 f:= proc(x,n) local y,d;
%p A087545   y:= x;
%p A087545   for d from 0 do
%p A087545     if -y mod n < 10^d then return y + (-y mod n) fi;
%p A087545     y:= 10*y
%p A087545   od;
%p A087545 end proc:
%p A087545 R:= 0,1: L:= 0,1:
%p A087545 for n from 2 to 20 do
%p A087545   v:= f(L[1]+L[2],n);
%p A087545   R:= R,v;
%p A087545   L:= L[2],v;
%p A087545 od:
%p A087545 R; # _Robert Israel_, May 07 2026
%Y A087545 Cf. A087546.
%K A087545 base,nonn,changed
