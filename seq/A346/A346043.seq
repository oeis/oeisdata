%S A346043 1,2,6,17,67,166,676,1373,4475,10446,30036,51032,196386,315302,737515,
%T A346043 1654229,4227565,6301902,17975187,26010425,70085244,133337963,
%U A346043 250039913,346136188,1096793068,1711865265,3030290770,5257516008,11602637216,15293266726,41896261337
%N A346043 a(n) is the position of A138534(n) in A025487.
%H A346043 Chai Wah Wu, <a href="/A346043/b346043.txt">Table of n, a(n) for n = 0..36</a>
%F A346043 A025487(a(n)) = A138534(n).
%e A346043 A138534(2) = A025487(6) = 12, so a(2) = 6.
%t A346043 lps = Cases[Import["https://oeis.org/A025487/b025487.txt", "Table"], {_, _}][[;; , 2]]; s = {}; Do[p = Position[lps, Product[Prime[k]^Floor[n/k], {k, 1, n}]]; If[p == {}, Break[]]; AppendTo[s, p[[1, 1]]], {n, 0, 20}]; s
%o A346043 (PARI) f(m) = my(c=1, p, q=2, v=vector(logint(m, 2), i, 2^i), w); while(#v, c+=#v; p=q; q=nextprime(q+1); w=List([]); for(i=1, #v, for(j=1, min(valuation(v[i], p), logint(m\v[i], q)), listput(w, v[i]*q^j))); v=w); c;
%o A346043 a(n) = f(prod(k=1, n, prime(k)^(n\k))); \\ _Jinyuan Wang_, Jul 08 2021
%o A346043 (Python)
%o A346043 from math import prod
%o A346043 from itertools import count
%o A346043 from functools import lru_cache
%o A346043 from sympy import prime, integer_log, primorial
%o A346043 def A346043(n):
%o A346043     @lru_cache(maxsize=None)
%o A346043     def g(x, m, j): return sum(g(x//(prime(m)**i), m-1, i) for i in range(j,integer_log(x, prime(m))[0]+1)) if m-1 else max(0,x.bit_length()-j)
%o A346043     c, f = 1, prod(prime(k)**(n//k) for k in range(1,n+1))
%o A346043     for k in count(1):
%o A346043         if primorial(k)>f:
%o A346043             break
%o A346043         c += g(f,k,1)
%o A346043     return c # _Chai Wah Wu_, Mar 23 2026
%Y A346043 Cf. A025487, A138534.
