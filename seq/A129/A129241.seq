%I A129241 #12 Mar 08 2026 16:21:26
%S A129241 104161,169313,449381,751753,857321,915029,937789,976501,981049,
%T A129241 986581,1138901,1159889,1219469,1370921,1488749,1881949,1903289,
%U A129241 1980073,2246129,2329949,2356609,2422093,2514389,2602429,2752921,2857369
%N A129241 Balanced primes q such that p = (r+q+s-1)/2 is a balanced prime, where r, q, s are consecutive primes.
%C A129241 The primes p arising here are in A129242.
%C A129241 Subsequence of A129190, where q need not be balanced.
%H A129241 Robert Israel, <a href="/A129241/b129241.txt">Table of n, a(n) for n = 1..1000</a>
%F A129241 a(n) = (2*A129242(n) + 1)/3. - _Robert Israel_, Mar 08 2026
%e A129241 104149, 104161, 104173 are consecutive primes and 104161 = A006562(446) is a balanced prime (distance 12). (104149+104161+104173-1)/2 = 156241 = A006562(629) is a balanced prime, it has distance 12 to the preceding prime 156229 and to the next prime 156253. Hence 104161 is a term.
%p A129241 R:= NULL: count:= 0:
%p A129241 q:= 3: s:= 5:
%p A129241 while count < 100 do
%p A129241   r:= q; q:= s; s:= nextprime(s);
%p A129241   if r + s = 2*q then
%p A129241      p:= (3*q-1)/2;
%p A129241      if isprime(p) and prevprime(p) + nextprime(p) = 2*p then
%p A129241        count:= count+1; R:= R,q;
%p A129241      fi
%p A129241   fi
%p A129241 od:
%p A129241 R; # _Robert Israel_, Mar 08 2026
%o A129241 (Magma) [ q: q in PrimesInInterval(3, 2900000) | r+s eq 2*q and IsPrime(p) and PreviousPrime(p)+NextPrime(p) eq 2*p where p is (r+q+s-1) div 2 where r is PreviousPrime(q) where s is NextPrime(q) ];
%Y A129241 Cf. A006562 (balanced primes), A129190, A129242.
%K A129241 nonn
%O A129241 1,1
%A A129241 _Klaus Brockhaus_, Apr 05 2007
