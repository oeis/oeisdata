%I A039363 #18 Apr 04 2026 15:49:23
%S A039363 63,88,144,169,225,250,306,331,387,412,468,493,549,568,569,570,571,
%T A039363 572,573,575,576,585,594,603,612,621,639,655,711,745,754,763,772,781,
%U A039363 790,793,794,795,796,797,798,800,808,817,873,898,954,979,1035,1060,1116,1141
%N A039363 Numbers whose base-9 representation has the same nonzero number of 0's and 7's.
%H A039363 Chris R. Rehmann, <a href="/A039363/b039363.txt">Table of n, a(n) for n = 1..10000</a>
%t A039363 Select[Range[1100],DigitCount[#,9,0]==DigitCount[#,9,7]>0&] (* _Harvey P. Dale_, Feb 12 2016 *)
%o A039363 (MATLAB)
%o A039363 a = NaN(52,1); k = 0; j = 1;
%o A039363 while any(isnan(a))
%o A039363     d = dec2base(k,9)-'0';
%o A039363     n1 = sum(d==0); n2 = sum(d==7);
%o A039363     if n1==n2 && n1 > 0
%o A039363         a(j) = k; j = j+1;
%o A039363     end
%o A039363     k = k+1;
%o A039363 end
%o A039363 disp(regexprep(num2str(a'), ' +', ', ')) % _Chris R. Rehmann_, Apr 04 2026
%Y A039363 Cf. A007095, A039083.
%Y A039363 Cf. A039357, A039358, A039359, A039360, A039361, A039362, A039364.
%Y A039363 Cf. A039370, A039376, A039381, A039385, A039388, A039390.
%K A039363 nonn,base,easy
%O A039363 1,1
%A A039363 _Olivier Gérard_
