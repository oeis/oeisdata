%T A039378 301,310,319,327,336,345,351,352,353,356,357,358,359,372,381,390,399,
%U A039378 436,444,517,525,598,606,679,687,760,768,841,849,922,930,976,985,994,1008
%N A039378 Numbers whose base-9 representation has the same nonzero number of 3's and 4's.
%H A039378 Chris R. Rehmann, <a href="/A039378/b039378.txt">Table of n, a(n) for n = 1..10000</a>
%t A039378 Select[Range[1000],DigitCount[#,9,3]==DigitCount[#,9,4]>0&] (* _Harvey P. Dale_, Apr 17 2022 *)
%o A039378 (MATLAB) x = 0:1008; d = dec2base(x,9)-'0'; s1 = sum(d==3,2); s2 = sum(d==4,2); a = x(s1==s2 & s1>0); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Apr 10 2026
%Y A039378 Cf. A007095, A039097.
