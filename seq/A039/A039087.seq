%N A039087 Numbers whose base-9 representation has the same number of 1's and 5's.
%H A039087 Chris R. Rehmann, <a href="/A039087/b039087.txt">Table of n, a(n) for n = 1..10000</a>
%t A039087 Select[Range[0, 25427], DigitCount[#, 9, 1]==DigitCount[#, 9, 5]&] (* _Chris R. Rehmann_, Mar 06 2026 *)
%o A039087 (MATLAB) x = 0:25427; d = dec2base(x,9)-'0'; a = x(sum(d==1,2)==sum(d==5,2)); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Mar 06 2026
