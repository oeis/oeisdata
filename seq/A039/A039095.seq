%N A039095 Numbers whose base-9 representation has the same number of 2's and 7's.
%H A039095 Chris R. Rehmann, <a href="/A039095/b039095.txt">Table of n, a(n) for n = 1..10000</a>
%t A039095 Select[Range[0,200],DigitCount[#,9,2]==DigitCount[#,9,7]&] (* _Harvey P. Dale_, Oct 15 2022 *)
%o A039095 (MATLAB) x = 0:25112; d = dec2base(x,9)-'0'; a = x(sum(d==2,2)==sum(d==7,2)); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Mar 16 2026
