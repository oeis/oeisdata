%T A039389 477,478,479,480,481,483,484,539,563,620,644,653,662,671,680,689,693,
%U A039389 694,695,696,697,699,700,707,716,782,806,863,887,944,968,1025,1049
%N A039389 Numbers whose base-9 representation has the same nonzero number of 5's and 8's.
%H A039389 Chris R. Rehmann, <a href="/A039389/b039389.txt">Table of n, a(n) for n = 1..10000</a>
%t A039389 Select[Range[1100],DigitCount[#,9,5]==DigitCount[#,9,8]>0&] (* _Harvey P. Dale_, May 17 2017 *)
%o A039389 (MATLAB) x = 0:1049; d = dec2base(x,9)-'0'; s1 = sum(d==5,2); s2 = sum(d==8,2); a = x(s1==s2 & s1>0); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Apr 14 2026
