%I A039079 #18 Mar 04 2026 21:54:22
%S A039079 1,2,4,5,6,7,8,10,11,13,14,15,16,17,19,20,22,23,24,25,26,27,37,38,40,
%T A039079 41,42,43,44,46,47,49,50,51,52,53,55,56,58,59,60,61,62,64,65,67,68,69,
%U A039079 70,71,73,74,76,77,78,79,80,84,91,92,94,95,96,97,98,100,101,103,104
%N A039079 Numbers whose base-9 representation has the same number of 0's and 3's.
%H A039079 Chris R. Rehmann, <a href="/A039079/b039079.txt">Table of n, a(n) for n = 1..10000</a>
%t A039079 Select[Range[200],DigitCount[#,9,0]==DigitCount[#,9,3]&] (* _Harvey P. Dale_, Sep 18 2016 *)
%o A039079 (MATLAB)
%o A039079 a = NaN(10000,1); k = 0; j = 1;
%o A039079 while any(isnan(a))
%o A039079     d = dec2base(k,9)-'0';
%o A039079     if sum(d==0)==sum(d==3)
%o A039079         a(j) = k; j = j+1;
%o A039079     end
%o A039079     k = k+1;
%o A039079 end
%o A039079 disp(regexprep(num2str(a'), ' +', ', ')) % _Chris R. Rehmann_, Mar 01 2026
%Y A039079 Cf. A007095, A039359.
%Y A039079 Cf. A039077, A039078, A039080, A039081, A039082, A039083, A031492.
%Y A039079 Cf. A039085, A039091.
%K A039079 nonn,base,easy
%O A039079 1,2
%A A039079 _Olivier Gérard_
