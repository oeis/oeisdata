%I A039081 #17 Mar 05 2026 16:00:57
%S A039081 1,2,3,4,6,7,8,10,11,12,13,15,16,17,19,20,21,22,24,25,26,28,29,30,31,
%T A039081 33,34,35,37,38,39,40,42,43,44,45,55,56,57,58,60,61,62,64,65,66,67,69,
%U A039081 70,71,73,74,75,76,78,79,80,86,91,92,93,94,96,97,98,100,101,102,103
%N A039081 Numbers whose base-9 representation has the same number of 0's and 5's.
%H A039081 Daniel Starodubtsev, <a href="/A039081/b039081.txt">Table of n, a(n) for n = 1..10000</a>
%t A039081 Select[Range[103], DigitCount[#, 9, 0]==DigitCount[#, 9, 5]&] (* _Chris R. Rehmann_, Mar 04 2026 *)
%o A039081 (MATLAB)
%o A039081 a = NaN(10000,1); k = 0; j = 1;
%o A039081 while any(isnan(a))
%o A039081     d = dec2base(k,9)-'0';
%o A039081     if sum(d==0)==sum(d==5)
%o A039081         a(j) = k; j = j+1;
%o A039081     end
%o A039081     k = k+1;
%o A039081 end
%o A039081 disp(regexprep(num2str(a'), ' +', ', ')) % _Chris R. Rehmann_, Mar 04 2026
%Y A039081 Cf. A007095, A039361.
%Y A039081 Cf. A039077, A039078, A039079, A039080, A039082, A039083, A031492.
%Y A039081 Cf. A039087, A039093, A039098, A039102.
%K A039081 nonn,base,easy
%O A039081 1,2
%A A039081 _Olivier Gérard_
