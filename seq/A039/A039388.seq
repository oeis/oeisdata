%S A039388 52,68,133,149,214,230,295,311,376,392,412,421,430,439,448,466,468,
%T A039388 469,470,471,472,474,476,484,538,554,572,581,590,599,608,612,613,614,
%U A039388 615,616,618,620,626,644,700,716,781,797,862,878,943,959,1024,1040
%N A039388 Numbers whose base-9 representation has the same nonzero number of 5's and 7's.
%H A039388 Chris R. Rehmann, <a href="/A039388/b039388.txt">Table of n, a(n) for n = 1..10000</a>
%t A039388 Select[Range[1100],DigitCount[#,9,5]==DigitCount[#,9,7]>0&] (* _Harvey P. Dale_, Oct 09 2011 *)
%o A039388 (MATLAB) x = 0:1040; d = dec2base(x,9)-'0'; s1 = sum(d==5,2); s2 = sum(d==7,2); a = x(s1==s2 & s1>0); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Apr 14 2026
