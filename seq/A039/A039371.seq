%T A039371 260,316,341,397,422,478,503,559,584,640,649,657,659,660,661,662,663,
%U A039371 664,667,676,685,694,703,712,737,755,764,773,782,791,800,801,803,804,805
%N A039371 Numbers whose base-9 representation has the same nonzero number of 1's and 8's.
%H A039371 Chris R. Rehmann, <a href="/A039371/b039371.txt">Table of n, a(n) for n = 1..10000</a>
%t A039371 Select[Range[805], DigitCount[#, 9, 1]==DigitCount[#, 9, 8]>0&] (* _Chris R. Rehmann_, Apr 06 2026 *)
%o A039371 (MATLAB) x = 0:805; d = dec2base(x,9)-'0'; s1 = sum(d==1,2); s2 = sum(d==8,2); a = x(s1==s2 & s1>0); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Apr 06 2026
