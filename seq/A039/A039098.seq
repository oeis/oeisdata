%N A039098 Numbers whose base-9 representation has the same number of 3's and 5's.
%H A039098 Chris R. Rehmann, <a href="/A039098/b039098.txt">Table of n, a(n) for n = 1..10000</a>
%t A039098 Select[Range[0,150],DigitCount[#,9,3]==DigitCount[#,9,5]&] (* _Harvey P. Dale_, Sep 30 2019 *)
%o A039098 (MATLAB) x = 0:24108; d = dec2base(x,9)-'0'; a = x(sum(d==3,2)==sum(d==5,2)); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Mar 17 2026
