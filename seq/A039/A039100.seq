%T A039100 40,41,42,44,45,46,47,49,50,51,53,54,55,56,58,59,60,62,66,72,73,74,76,
%U A039100 77,78,80,81,82,83,85,86,87,89,90,91,92,94,95,96,98,99,100,101,103
%N A039100 Numbers whose base-9 representation has the same number of 3's and 7's.
%H A039100 Chris R. Rehmann, <a href="/A039100/b039100.txt">Table of n, a(n) for n = 1..10000</a>
%t A039100 Select[Range[0,200],DigitCount[#,9,3]==DigitCount[#,9,7]&] (* _Harvey P. Dale_, Dec 05 2012 *)
%o A039100 (MATLAB) x = 0:24929; d = dec2base(x,9)-'0'; a = x(sum(d==3,2)==sum(d==7,2)); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Mar 19 2026
