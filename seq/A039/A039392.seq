%S A039392 71,79,152,160,233,241,314,322,395,403,476,484,557,565,575,584,593,
%T A039392 602,611,620,629,639,640,641,642,643,644,645,655,664,673,682,691,700,
%U A039392 709,711,712,713,714,715,716,717,800,808,881,889,962,970,1043,1051
%N A039392 Numbers whose base-9 representation has the same nonzero number of 7's and 8's.
%H A039392 Chris R. Rehmann, <a href="/A039392/b039392.txt">Table of n, a(n) for n = 1..10000</a>
%t A039392 b9Q[n_]:=Module[{idn9=IntegerDigits[n,9]},Count[idn9,7]==Count[idn9,8]!=0]
%t A039392 Select[Range[1100],b9Q]  (* _Harvey P. Dale_, Feb 14 2011 *)
%o A039392 (MATLAB) x = 0:1051; d = dec2base(x,9)-'0'; s1 = sum(d==7,2); s2 = sum(d==8,2); a = x(s1==s2 & s1>0); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Apr 14 2026
