%S A039380 33,57,114,138,195,219,249,258,267,285,294,297,298,299,301,302,304,
%T A039380 305,312,321,357,381,438,462,489,498,507,513,514,515,517,518,520,521,
%U A039380 525,534,552,561,600,624,681,705,762,786,843,867,924,948,978,987,996,1014
%N A039380 Numbers whose base-9 representation has the same nonzero number of 3's and 6's.
%H A039380 Chris R. Rehmann, <a href="/A039380/b039380.txt">Table of n, a(n) for n = 1..10000</a>
%t A039380 Select[Range[1014], DigitCount[#, 9, 3]==DigitCount[#, 9, 6]>0&] (* _Chris R. Rehmann_, Apr 12 2026 *)
%o A039380 (MATLAB) x = 0:1014; d = dec2base(x,9)-'0'; s1 = sum(d==3,2); s2 = sum(d==6,2); a = x(s1==s2 & s1>0); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Apr 12 2026
%Y A039380 Cf. A007095, A039099.
