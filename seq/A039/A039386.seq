%T A039386 398,399,401,402,403,449,481,530,562,611,643,652,661,670,679,684,685,
%U A039386 686,687,689,690,691,697,706,715,773,805,854,886,935,967,1016,1048
%N A039386 Numbers whose base-9 representation has the same nonzero number of 4's and 8's.
%H A039386 Chris R. Rehmann, <a href="/A039386/b039386.txt">Table of n, a(n) for n = 1..10000</a>
%t A039386 Select[Range[1250],DigitCount[#,9,4]==DigitCount[#,9,8]>0&] (* _Harvey P. Dale_, Jan 18 2024 *)
%o A039386 (MATLAB) x = 0:1048; d = dec2base(x,9)-'0'; s1 = sum(d==4,2); s2 = sum(d==8,2); a = x(s1==s2 & s1>0); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Apr 13 2026
