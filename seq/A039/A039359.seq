%I A039359 #18 Apr 04 2026 09:08:50
%S A039359 27,84,108,165,189,244,245,247,248,249,250,251,252,261,279,288,297,
%T A039359 306,315,327,351,408,432,489,513,570,594,651,675,741,750,757,758,760,
%U A039359 761,762,763,764,768,777,786,795,804,813,837,894,918,973,974,976,977,978
%N A039359 Numbers whose base-9 representation has the same nonzero number of 0's and 3's.
%H A039359 Chris R. Rehmann, <a href="/A039359/b039359.txt">Table of n, a(n) for n = 1..10000</a>
%t A039359 Select[Range[1000],DigitCount[#,9,0]==DigitCount[#,9,3]>0&] (* _Harvey P. Dale_, Sep 23 2018 *)
%o A039359 (MATLAB)
%o A039359 a = NaN(52,1); k = 0; j = 1;
%o A039359 while any(isnan(a))
%o A039359     d = dec2base(k,9)-'0';
%o A039359     n1 = sum(d==0); n2 = sum(d==3);
%o A039359     if n1==n2 && n1 > 0
%o A039359         a(j) = k; j = j+1;
%o A039359     end
%o A039359     k = k+1;
%o A039359 end
%o A039359 disp(regexprep(num2str(a'), ' +', ', ')) % _Chris R. Rehmann_, Apr 03 2026
%Y A039359 Cf. A007095, A039079.
%Y A039359 Cf. A039357, A039358, A039360, A039361, A039362, A039363, A039364.
%Y A039359 Cf. A039366, A039372.
%K A039359 nonn,base,easy
%O A039359 1,1
%A A039359 _Olivier Gérard_
