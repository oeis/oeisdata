%T A039109 31,32,35,36,37,38,39,40,41,44,45,46,47,48,49,50,53,61,69,72,73,74,75,
%U A039109 76,77,80,81,82,83,84,85,86,89,90,91,92,93,94,95,98,99,100,101,102
%N A039109 Numbers whose base-9 representation has the same number of 6's and 7's.
%H A039109 Chris R. Rehmann, <a href="/A039109/b039109.txt">Table of n, a(n) for n = 1..10000</a>
%p A039109 q:= n-> (l-> numboccur(l,6)=numboccur(l,7))(convert(n, base, 9)):
%p A039109 select(q, [$0..102])[];  # _Alois P. Heinz_, Mar 25 2026
%t A039109 Select[Range[0,120],DigitCount[#,9,6]==DigitCount[#,9,7]&] (* _Harvey P. Dale_, Jul 10 2019 *)
%o A039109 (MATLAB) x = 0:21515; d = dec2base(x,9)-'0'; a = x(sum(d==6,2)==sum(d==7,2)); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Mar 25 2026
