%T A039085 49,50,51,52,53,54,56,58,59,60,61,62,63,65,67,68,69,70,71,72,74,76,77,
%U A039085 78,79,80,84,102,108,110,112,113,114,115,116,120,129,138,147,156,162
%N A039085 Numbers whose base-9 representation has the same number of 1's and 3's.
%H A039085 Chris R. Rehmann, <a href="/A039085/b039085.txt">Table of n, a(n) for n = 1..10000</a>
%t A039085 Select[Range[0,200],DigitCount[#,9,1]==DigitCount[#,9,3]&] (* _Harvey P. Dale_, Aug 08 2023 *)
%o A039085 (MATLAB) x = 0:29211; d = dec2base(x,9)-'0'; a = x(sum(d==1,2)==sum(d==3,2));
%o A039085 disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Mar 06 2026
