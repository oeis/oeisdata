%N A039094 Numbers whose base-9 representation has the same number of 2's and 6's.
%H A039094 Chris R. Rehmann, <a href="/A039094/b039094.txt">Table of n, a(n) for n = 1..10000</a>
%t A039094 Select[Range[0,120],DigitCount[#,9,2]==DigitCount[#,9,6]&] (* _Harvey P. Dale_, May 03 2018 *)
%o A039094 (MATLAB) x = 0:25426; d = dec2base(x,9)-'0'; a = x(sum(d==2,2)==sum(d==6,2)); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Mar 16 2026
