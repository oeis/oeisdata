%U A039366 433,498,514,579,595,660,676,732,750,756,758,760,761,762,763,764,768,777
%N A039366 Numbers whose base-9 representation has the same nonzero number of 1's and 3's.
%H A039366 Chris R. Rehmann, <a href="/A039366/b039366.txt">Table of n, a(n) for n = 1..10000</a>
%t A039366 Select[Range[800],DigitCount[#,9,1]==DigitCount[#,9,3]>0&] (* _Harvey P. Dale_, Aug 03 2017 *)
%o A039366 (MATLAB) x = 0:777; d = dec2base(x,9)-'0'; s1 = sum(d==1,2); s2 = sum(d==3,2); a = x(s1==s2 & s1>0);  disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Apr 04 2026
