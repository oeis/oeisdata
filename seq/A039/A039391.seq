%I A039391 #17 Apr 15 2026 00:59:24
%S A039391 62,78,143,159,224,240,305,321,386,402,467,483,494,503,512,521,530,
%T A039391 539,557,558,559,560,561,562,563,565,629,645,654,663,672,681,690,699,
%U A039391 702,703,704,705,706,707,709,717,791,807,872,888,953,969,1034,1050
%N A039391 Numbers whose base-9 representation has the same nonzero number of 6's and 8's.
%H A039391 Chris R. Rehmann, <a href="/A039391/b039391.txt">Table of n, a(n) for n = 1..10000</a>
%t A039391 Select[Range[1100],DigitCount[#,9,6]==DigitCount[#,9,8]>0&] (* _Harvey P. Dale_, Mar 29 2015 *)
%o A039391 (MATLAB) x = 0:1050; d = dec2base(x,9)-'0'; s1 = sum(d==6,2); s2 = sum(d==8,2); a = x(s1==s2 & s1>0); disp(regexprep(num2str(a), ' +', ', '))  % _Chris R. Rehmann_, Apr 14 2026
%Y A039391 Cf. A007095, A039110.
%Y A039391 Cf. A039390.
