%T A039110 31,32,34,36,37,38,39,40,41,43,45,46,47,48,49,50,52,62,63,64,65,66,67,
%U A039110 68,70,78,81,82,83,84,85,86,88,90,91,92,93,94,95,97,99,100,101,102
%N A039110 Numbers whose base-9 representation has the same number of 6's and 8's.
%H A039110 Chris R. Rehmann, <a href="/A039110/b039110.txt">Table of n, a(n) for n = 1..10000</a>
%p A039110 q:= n-> (l-> numboccur(l,6)=numboccur(l,8))(convert(n, base, 9)):
%p A039110 select(q, [$0..102])[];  # _Alois P. Heinz_, Mar 25 2026
%t A039110 Select[Range[0,150],DigitCount[#,9,6]==DigitCount[#,9,8]&] (* _Harvey P. Dale_, Sep 01 2025 *)
%o A039110 (MATLAB) x = 0:21515; d = dec2base(x,9)-'0'; a = x(sum(d==6,2)==sum(d==8,2)); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Mar 25 2026
