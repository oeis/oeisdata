%N A039084 Numbers whose base-9 representation has the same number of 1's and 2's.
%H A039084 Chris R. Rehmann, <a href="/A039084/b039084.txt">Table of n, a(n) for n = 1..10000</a>
%t A039084 Select[Range[0,170],DigitCount[#,9,1]==DigitCount[#,9,2]&]  (* _Harvey P. Dale_, Mar 23 2011 *)
%o A039084 (MATLAB) x = 0:29211; d = dec2base(x,9)-'0'; a = x(sum(d==1,2)==sum(d==2,2));
%o A039084 disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Mar 05 2026
