%I A039357 #20 Apr 03 2026 19:06:05
%S A039357 9,83,84,85,86,87,88,89,99,108,117,126,135,144,153,163,171,244,252,
%T A039357 325,333,406,414,487,495,568,576,649,657,730,738,749,750,751,752,753,
%U A039357 754,755,758,759,760,761,762,763,764,767,768,769,770,771,772,773,776,777
%N A039357 Numbers whose base-9 representation has the same nonzero number of 0's and 1's.
%H A039357 Chris R. Rehmann, <a href="/A039357/b039357.txt">Table of n, a(n) for n = 1..10000</a>
%t A039357 Select[Range[800],DigitCount[#,9,0]==DigitCount[#,9,1]>0&] (* _Harvey P. Dale_, Mar 10 2016 *)
%o A039357 (MATLAB)
%o A039357 a = NaN(54,1); k = 0; j = 1;
%o A039357 while any(isnan(a))
%o A039357     d = dec2base(k,9)-'0';
%o A039357     n1 = sum(d==0); n2 = sum(d==1);
%o A039357     if n1==n2 && n1 > 0
%o A039357         a(j) = k; j = j+1;
%o A039357     end
%o A039357     k = k+1;
%o A039357 end
%o A039357 disp(regexprep(num2str(a'), ' +', ', ')) % _Chris R. Rehmann_, Apr 02 2026
%Y A039357 Cf. A007095, A039077.
%Y A039357 Cf. A039358, A039359, A039360, A039361, A039362, A039363, A039364.
%K A039357 nonn,base,easy,changed
%O A039357 1,1
%A A039357 _Olivier Gérard_
