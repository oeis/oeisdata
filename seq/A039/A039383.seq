%U A039383 472,481,527,535,608,616,689,697,770,778,851,859,932,940,1013,1021,1058,1067
%N A039383 Numbers whose base-9 representation has the same nonzero number of 4's and 5's.
%H A039383 Chris R. Rehmann, <a href="/A039383/b039383.txt">Table of n, a(n) for n = 1..10000</a>
%t A039383 Select[Range[1100],DigitCount[#,9,4]==DigitCount[#,9,5]>0&] (* _Harvey P. Dale_, Jul 06 2011 *)
%o A039383 (MATLAB) x = 0:1067; d = dec2base(x,9)-'0'; s1 = sum(d==4,2); s2 = sum(d==5,2); a = x(s1==s2 & s1>0); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Apr 12 2026
