%T A039372 237,245,254,261,262,265,266,267,268,269,281,290,299,308,317,345,353,
%U A039372 426,434,507,515,588,596,669,677,750,758,831,839,894,903,918,919,922,923
%N A039372 Numbers whose base-9 representation has the same nonzero number of 2's and 3's.
%H A039372 Chris R. Rehmann, <a href="/A039372/b039372.txt">Table of n, a(n) for n = 1..10000</a>
%t A039372 Select[Range[1000],DigitCount[#,9,2]==DigitCount[#,9,3]>0&] (* _Harvey P. Dale_, Sep 24 2015 *)
%o A039372 (MATLAB) x = 0:923; d = dec2base(x,9)-'0'; s1 = sum(d==2,2); s2 = sum(d==3,2); a = x(s1==s2 & s1>0); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Apr 06 2026
