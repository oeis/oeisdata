%T A039374 239,266,290,347,371,407,416,423,424,426,427,429,430,431,434,443,461,
%U A039374 470,479,509,533,590,614,671,695,752,776,833,857,896,905,923,932,936,937
%N A039374 Numbers whose base-9 representation has the same nonzero number of 2's and 5's.
%H A039374 Chris R. Rehmann, <a href="/A039374/b039374.txt">Table of n, a(n) for n = 1..10000</a>
%t A039374 Select[Range[1000],DigitCount[#,9,2]==DigitCount[#,9,5]>0&] (* _Harvey P. Dale_, Dec 16 2019 *)
%o A039374 (MATLAB) x = 0:937; d = dec2base(x,9)-'0'; s1 = sum(d==2,2); s2 = sum(d==5,2); a = x(s1==s2 & s1>0); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Apr 08 2026
