%N A039103 Numbers whose base-9 representation has the same number of 4's and 6's.
%H A039103 Chris R. Rehmann, <a href="/A039103/b039103.txt">Table of n, a(n) for n = 1..10000</a>
%t A039103 Select[Range[0,110],DigitCount[#,9,4]==DigitCount[#,9,6]&] (* _Harvey P. Dale_, Apr 27 2018 *)
%o A039103 (MATLAB) x = 0:21580; d = dec2base(x,9)-'0'; a = x(sum(d==4,2)==sum(d==6,2)); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Mar 23 2026
