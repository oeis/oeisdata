%I A039360 #19 Apr 04 2026 09:08:53
%S A039360 36,85,117,166,198,247,279,325,326,327,329,330,331,332,333,342,351,
%T A039360 369,378,387,396,409,441,490,522,571,603,652,684,742,751,760,766,767,
%U A039360 768,770,771,772,773,778,787,796,805,814,846,895,927,976,1008,1054,1055,1056
%N A039360 Numbers whose base-9 representation has the same nonzero number of 0's and 4's.
%H A039360 Chris R. Rehmann, <a href="/A039360/b039360.txt">Table of n, a(n) for n = 1..10000</a>
%t A039360 Select[Range[1100],DigitCount[#,9,0]==DigitCount[#,9,4]>0&] (* _Harvey P. Dale_, May 22 2018 *)
%o A039360 (MATLAB)
%o A039360 a = NaN(52,1); k = 0; j = 1;
%o A039360 while any(isnan(a))
%o A039360     d = dec2base(k,9)-'0';
%o A039360     n1 = sum(d==0); n2 = sum(d==4);
%o A039360     if n1==n2 && n1 > 0
%o A039360         a(j) = k; j = j+1;
%o A039360     end
%o A039360     k = k+1;
%o A039360 end
%o A039360 disp(regexprep(num2str(a'), ' +', ', ')) % _Chris R. Rehmann_, Apr 03 2026
%Y A039360 Cf. A007095, A039080.
%Y A039360 Cf. A039357, A039358, A039359, A039361, A039362, A039363, A039364.
%Y A039360 Cf. A039367, A039373, A039378.
%K A039360 nonn,base,easy
%O A039360 1,1
%A A039360 _Olivier Gérard_
