%N A039107 Numbers whose base-9 representation has the same number of 5's and 7's.
%H A039107 Chris R. Rehmann, <a href="/A039107/b039107.txt">Table of n, a(n) for n = 1..10000</a>
%t A039107 Select[Range[0,120],DigitCount[#,9,5]==DigitCount[#,9,7]&] (* _Harvey P. Dale_, Apr 07 2013 *)
%o A039107 (MATLAB) x = 0:21523; d = dec2base(x,9)-'0'; a = x(sum(d==5,2)==sum(d==7,2)); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Mar 25 2026
