%N A039108 Numbers whose base-9 representation has the same number of 5's and 8's.
%H A039108 Chris R. Rehmann, <a href="/A039108/b039108.txt">Table of n, a(n) for n = 1..10000</a>
%t A039108 Select[Range[0,150],DigitCount[#,9,5]==DigitCount[#,9,8]&] (* _Harvey P. Dale_, Aug 28 2020 *)
%o A039108 (MATLAB) x = 0:21523; d = dec2base(x,9)-'0'; a = x(sum(d==5,2)==sum(d==8,2)); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Mar 25 2026
