%N A039102 Numbers whose base-9 representation has the same number of 4's and 5's.
%H A039102 Chris R. Rehmann, <a href="/A039102/b039102.txt">Table of n, a(n) for n = 1..10000</a>
%t A039102 Select[Range[0,110],DigitCount[#,9,4]==DigitCount[#,9,5]&] (* _Harvey P. Dale_, Jul 21 2013 *)
%o A039102 (MATLAB) x = 0:21643; d = dec2base(x,9)-'0'; a = x(sum(d==4,2)==sum(d==5,2)); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Mar 19 2026
