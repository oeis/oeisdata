%N A039092 Numbers whose base-9 representation has the same number of 2's and 4's.
%H A039092 Chris R. Rehmann, <a href="/A039092/b039092.txt">Table of n, a(n) for n = 1..10000</a>
%t A039092 Select[Range[125],DigitCount[#,9,2]==DigitCount[#,9,4]&]  (* _Harvey P. Dale_, Jan 23 2011 *)
%o A039092 (MATLAB) x = 0:25426; d = dec2base(x,9)-'0'; a = x(sum(d==2,2)==sum(d==4,2)); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Mar 16 2026
