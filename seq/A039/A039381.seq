%U A039381 600,602,606,615,624,642,682,714,763,795,844,876,925,957,979,988,997,1015,1024,1033,1035,1036,1037,1039,1040,1041,1043,1051
%N A039381 Numbers whose base-9 representation has the same nonzero number of 3's and 7's.
%H A039381 Chris R. Rehmann, <a href="/A039381/b039381.txt">Table of n, a(n) for n = 1..10000</a>
%t A039381 okQ[n_]:=Module[{dc3=DigitCount[n,9,3]},dc3>0&&dc3==DigitCount[n,9,7]]
%t A039381 Select[Range[2000],okQ] (* _Harvey P. Dale_, Nov 26 2010 *)
%o A039381 (MATLAB) x = 0:1051; d = dec2base(x,9)-'0'; s1 = sum(d==3,2); s2 = sum(d==7,2); a = x(s1==s2 & s1>0); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Apr 12 2026
