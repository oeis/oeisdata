%S A039385 43,67,124,148,205,229,286,310,331,340,349,358,376,385,387,388,389,
%T A039385 390,392,393,395,403,448,472,529,553,571,580,589,598,603,604,605,606,
%U A039385 608,609,611,616,625,643,691,715,772,796,853,877,934,958,1015,1039
%N A039385 Numbers whose base-9 representation has the same nonzero number of 4's and 7's.
%H A039385 Chris R. Rehmann, <a href="/A039385/b039385.txt">Table of n, a(n) for n = 1..10000</a>
%t A039385 Select[Range[0, 1039], DigitCount[#, 9, 4] == DigitCount[#, 9, 7] > 0 &] (* _Chris R. Rehmann_, Apr 13 2026 *)
%o A039385 (MATLAB) x = 0:1039; d = dec2base(x,9)-'0'; s1 = sum(d==4,2); s2 = sum(d==7,2); a = x(s1==s2 & s1>0); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Apr 13 2026
%Y A039385 Cf. A007095, A039104.
