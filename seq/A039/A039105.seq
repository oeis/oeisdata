%N A039105 Numbers whose base-9 representation has the same number of 4's and 8's.
%H A039105 Chris R. Rehmann, <a href="/A039105/b039105.txt">Table of n, a(n) for n = 1..10000</a>
%t A039105 Select[Range[0,120],DigitCount[#,9,4]==DigitCount[#,9,8]&] (* _Harvey P. Dale_, Aug 02 2020 *)
%o A039105 (MATLAB) x = 0:21579; d = dec2base(x,9)-'0'; a = x(sum(d==4,2)==sum(d==8,2)); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Mar 24 2026
