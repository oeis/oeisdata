%U A039367 442,499,523,580,604,661,685,733,751,760,765,767,768,770,771,772,773,778
%N A039367 Numbers whose base-9 representation has the same nonzero number of 1's and 4's.
%H A039367 Chris R. Rehmann, <a href="/A039367/b039367.txt">Table of n, a(n) for n = 1..10000</a>
%t A039367 Select[Range[1000],DigitCount[#,9,1]==DigitCount[#,9,4]>0&] (* _Harvey P. Dale_, Aug 16 2012 *)
%o A039367 (MATLAB) x = 0:778; d = dec2base(x,9)-'0'; s1 = sum(d==1,2); s2 = sum(d==4,2); a = x(s1==s2 & s1>0); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Apr 05 2026
