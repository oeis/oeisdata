%T A039384 383,385,386,393,402,447,463,490,499,508,517,522,523,524,525,527,529,
%U A039384 530,535,553,562,609,625,690,706,771,787,852,868,933,949,1014,1030,1059,1068
%N A039384 Numbers whose base-9 representation has the same nonzero number of 4's and 6's.
%H A039384 Chris R. Rehmann, <a href="/A039384/b039384.txt">Table of n, a(n) for n = 1..10000</a>
%t A039384 Select[Range[0, 1068], DigitCount[#, 9, 4] == DigitCount[#, 9, 6] > 0 &] (* _Chris R. Rehmann_, Apr 12 2026 *)
%o A039384 (MATLAB) x = 0:1068; d = dec2base(x,9)-'0'; s1 = sum(d==4,2); s2 = sum(d==6,2); a = x(s1==s2 & s1>0); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Apr 12 2026
%Y A039384 Cf. A007095, A039103.
