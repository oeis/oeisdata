%I A039080 #17 Mar 04 2026 21:53:58
%S A039080 1,2,3,5,6,7,8,10,11,12,14,15,16,17,19,20,21,23,24,25,26,28,29,30,32,
%T A039080 33,34,35,36,46,47,48,50,51,52,53,55,56,57,59,60,61,62,64,65,66,68,69,
%U A039080 70,71,73,74,75,77,78,79,80,85,91,92,93,95,96,97,98,100,101,102,104
%N A039080 Numbers whose base-9 representation has the same number of 0's and 4's.
%H A039080 Chris R. Rehmann, <a href="/A039080/b039080.txt">Table of n, a(n) for n = 1..10000</a>
%t A039080 Select[Range[150],DigitCount[#,9,0]==DigitCount[#,9,4]&] (* _Harvey P. Dale_, Sep 05 2013 *)
%o A039080 (MATLAB)
%o A039080 a = NaN(10000,1); k = 0; j = 1;
%o A039080 while any(isnan(a))
%o A039080     d = dec2base(k,9)-'0';
%o A039080     if sum(d==0)==sum(d==4)
%o A039080         a(j) = k; j = j+1;
%o A039080     end
%o A039080     k = k+1;
%o A039080 end
%o A039080 disp(regexprep(num2str(a'), ' +', ', ')) % _Chris R. Rehmann_, Mar 01 2026
%Y A039080 Cf. A007095, A039360.
%Y A039080 Cf. A039077, A039078, A039079, A039081, A039082, A039083, A031492.
%Y A039080 Cf. A039086, A039092, A039097.
%K A039080 nonn,base,easy
%O A039080 1,2
%A A039080 _Olivier Gérard_
