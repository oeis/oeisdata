%I A039358 #18 Apr 04 2026 09:54:04
%S A039358 18,83,99,163,165,166,167,168,169,170,171,189,198,207,216,225,234,245,
%T A039358 261,326,342,407,423,488,504,569,585,650,666,740,748,750,751,752,753,
%U A039358 754,755,758,767,776,785,794,803,812,828,892,894,895,896,897,898,899,900
%N A039358 Numbers whose base-9 representation has the same nonzero number of 0's and 2's.
%H A039358 Chris R. Rehmann, <a href="/A039358/b039358.txt">Table of n, a(n) for n = 1..10000</a>
%t A039358 Select[Range[1000],DigitCount[#,9,0]==DigitCount[#,9,2]>0&] (* _Harvey P. Dale_, Jan 03 2024 *)
%o A039358 (MATLAB)
%o A039358 a = NaN(53,1); k = 0; j = 1;
%o A039358 while any(isnan(a))
%o A039358     d = dec2base(k,9)-'0';
%o A039358     n1 = sum(d==0); n2 = sum(d==2);
%o A039358     if n1==n2 && n1 > 0
%o A039358         a(j) = k; j = j+1;
%o A039358     end
%o A039358     k = k+1;
%o A039358 end
%o A039358 disp(regexprep(num2str(a'), ' +', ', ')) % _Chris R. Rehmann_, Apr 03 2026
%Y A039358 Cf. A007095, A039078.
%Y A039358 Cf. A039357, A039359, A039360, A039361, A039362, A039363, A039364.
%Y A039358 Cf. A039365.
%K A039358 nonn,base,easy,changed
%O A039358 1,1
%A A039358 _Olivier Gérard_
