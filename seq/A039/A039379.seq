%T A039379 302,311,320,356,372,408,417,426,432,433,434,436,438,439,440,444,462,
%U A039379 471,480,518,534,599,615,680,696,761,777,842,858,923,939,977,986,995,1013
%N A039379 Numbers whose base-9 representation has the same nonzero number of 3's and 5's.
%H A039379 Chris R. Rehmann, <a href="/A039379/b039379.txt">Table of n, a(n) for n = 1..10000</a>
%t A039379 Select[Range[1000],DigitCount[#,9,3]==DigitCount[#,9,5]>0&] (* _Harvey P. Dale_, Jan 10 2021 *)
%o A039379 (MATLAB) x = 0:1013; d = dec2base(x,9)-'0'; s1 = sum(d==3,2); s2 = sum(d==5,2); a = x(s1==s2 & s1>0); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Apr 12 2026
