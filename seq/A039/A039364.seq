%I A039364 #18 Apr 05 2026 13:17:54
%S A039364 72,89,153,170,234,251,315,332,396,413,477,494,558,575,639,649,650,
%T A039364 651,652,653,654,655,657,666,675,684,693,702,711,746,755,764,773,782,
%U A039364 791,800,802,803,804,805,806,807,808,818,882,899,963,980,1044,1061,1125,1142
%N A039364 Numbers whose base-9 representation has the same nonzero number of 0's and 8's.
%H A039364 Chris R. Rehmann, <a href="/A039364/b039364.txt">Table of n, a(n) for n = 1..10000</a>
%t A039364 Select[Range[1200],DigitCount[#,9,0]==DigitCount[#,9,8]>0&] (* _Harvey P. Dale_, Sep 20 2023 *)
%o A039364 (MATLAB)
%o A039364 a = NaN(52,1); k = 0; j = 1;
%o A039364 while any(isnan(a))
%o A039364     d = dec2base(k,9)-'0';
%o A039364     n1 = sum(d==0); n2 = sum(d==8);
%o A039364     if n1==n2 && n1 > 0
%o A039364         a(j) = k; j = j+1;
%o A039364     end
%o A039364     k = k+1;
%o A039364 end
%o A039364 disp(regexprep(num2str(a'), ' +', ', ')) % _Chris R. Rehmann_, Apr 04 2026
%Y A039364 Cf. A007095, A031492.
%Y A039364 Cf. A039357, A039358, A039359, A039360, A039361, A039362, A039363.
%Y A039364 Cf. A039371, A039377, A039382, A039386, A039389, A039391, A039392.
%K A039364 nonn,base,easy,changed
%O A039364 1,1
%A A039364 _Olivier Gérard_
