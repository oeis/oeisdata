%N A039096 Numbers whose base-9 representation has the same number of 2's and 8's.
%H A039096 Chris R. Rehmann, <a href="/A039096/b039096.txt">Table of n, a(n) for n = 1..10000</a>
%t A039096 Select[Range[0,200],DigitCount[#,9,2]==DigitCount[#,9,8]&] (* _Harvey P. Dale_, Feb 02 2015 *)
%o A039096 (MATLAB) x = 0:24928; d = dec2base(x,9)-'0'; a = x(sum(d==2,2)==sum(d==8,2)); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Mar 16 2026
