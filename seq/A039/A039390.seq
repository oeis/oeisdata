%T A039390 538,549,550,551,552,553,554,557,565,573,582,591,600,609,618,621,622,
%U A039390 623,624,625,626,629,645,709,717,790,798,871,879,952,960,1033,1041
%N A039390 Numbers whose base-9 representation has the same nonzero number of 6's and 7's.
%H A039390 Chris R. Rehmann, <a href="/A039390/b039390.txt">Table of n, a(n) for n = 1..10000</a>
%t A039390 Select[Range[1100],DigitCount[#,9,6]==DigitCount[#,9,7]>0&] (* _Harvey P. Dale_, Feb 23 2015 *)
%o A039390 (MATLAB) x = 0:1041; d = dec2base(x,9)-'0'; s1 = sum(d==6,2); s2 = sum(d==7,2); a = x(s1==s2 & s1>0); disp(regexprep(num2str(a), ' +', ', '))  % _Chris R. Rehmann_, Apr 14 2026
%Y A039390 Cf. A007095, A039109.
