%N A039086 Numbers whose base-9 representation has the same number of 1's and 4's.
%H A039086 Chris R. Rehmann, <a href="/A039086/b039086.txt">Table of n, a(n) for n = 1..10000</a>
%t A039086 Select[Range[0,200],DigitCount[#,9,1]==DigitCount[#,9,4]&] (* _Harvey P. Dale_, Dec 26 2014 *)
%o A039086 (MATLAB) x = 0:25427; d = dec2base(x,9)-'0'; a = x(sum(d==1,2)==sum(d==4,2)); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Mar 06 2026
