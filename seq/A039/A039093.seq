%N A039093 Numbers whose base-9 representation has the same number of 2's and 5's.
%H A039093 Chris R. Rehmann, <a href="/A039093/b039093.txt">Table of n, a(n) for n = 1..10000</a>
%t A039093 Select[Range[0,120],DigitCount[#,9,2]==DigitCount[#,9,5]&] (* _Harvey P. Dale_, Apr 24 2012 *)
%o A039093 (MATLAB) x = 0:25426; d = dec2base(x,9)-'0'; a = x(sum(d==2,2)==sum(d==5,2)); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Mar 16 2026
