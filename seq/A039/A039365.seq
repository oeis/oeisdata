%U A039365 424,497,505,578,586,659,667,731,747,750,751,752,753,754,755,758,767,776
%N A039365 Numbers whose base-9 representation has the same nonzero number of 1's and 2's.
%H A039365 Chris R. Rehmann, <a href="/A039365/b039365.txt">Table of n, a(n) for n = 1..10000</a>
%t A039365 Select[Range[1000],DigitCount[#,9,1]==DigitCount[#,9,2]>0&] (* _Harvey P. Dale_, Jun 08 2022 *)
%o A039365 (MATLAB) x = 0:776; d = dec2base(x,9)-'0'; s1 = sum(d==1,2); s2 = sum(d==2,2); a = x(s1==s2 & s1>0); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Apr 04 2026
