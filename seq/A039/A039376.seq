%U A039376 593,596,605,614,623,641,673,713,754,794,835,875,898,907,925,934,943,952
%N A039376 Numbers whose base-9 representation has the same nonzero number of 2's and 7's.
%H A039376 Chris R. Rehmann, <a href="/A039376/b039376.txt">Table of n, a(n) for n = 1..10000</a>
%t A039376 Select[Range[1000],DigitCount[#,9,2]==DigitCount[#,9,7]>0&] (* _Harvey P. Dale_, Apr 04 2020 *)
%o A039376 (MATLAB) x = 0:952; d = dec2base(x,9)-'0'; s1 = sum(d==2,2); s2 = sum(d==7,2); a = x(s1==s2 & s1>0); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Apr 10 2026
