%T A039375 240,267,299,348,380,429,461,488,497,504,505,507,508,509,511,512,515,
%U A039375 524,533,551,560,591,623,672,704,753,785,834,866,897,906,924,933,942,945
%N A039375 Numbers whose base-9 representation has the same nonzero number of 2's and 6's.
%H A039375 Chris R. Rehmann, <a href="/A039375/b039375.txt">Table of n, a(n) for n = 1..10000</a>
%t A039375 Select[Range[1000],DigitCount[#,9,2]==DigitCount[#,9,6]>0&] (* _Harvey P. Dale_, Jun 30 2015 *)
%o A039375 (MATLAB) x = 0:945; d = dec2base(x,9)-'0'; s1 = sum(d==2,2); s2 = sum(d==6,2); a = x(s1==s2 & s1>0); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Apr 08 2026
