%I A039082 #19 Mar 05 2026 16:01:02
%S A039082 1,2,3,4,5,7,8,10,11,12,13,14,16,17,19,20,21,22,23,25,26,28,29,30,31,
%T A039082 32,34,35,37,38,39,40,41,43,44,46,47,48,49,50,52,53,54,64,65,66,67,68,
%U A039082 70,71,73,74,75,76,77,79,80,87,91,92,93,94,95,97,98,100,101,102,103
%N A039082 Numbers whose base-9 representation has the same number of 0's and 6's.
%H A039082 Chris R. Rehmann, <a href="/A039082/b039082.txt">Table of n, a(n) for n = 1..10000</a>
%t A039082 Select[Range[200],DigitCount[#,9,0]==DigitCount[#,9,6]&] (* _Harvey P. Dale_, Oct 20 2014 *)
%o A039082 (MATLAB)
%o A039082 a = NaN(10000,1); k = 0; j = 1;
%o A039082 while any(isnan(a))
%o A039082     d = dec2base(k,9)-'0';
%o A039082     if sum(d==0)==sum(d==6)
%o A039082         a(j) = k; j = j+1;
%o A039082     end
%o A039082     k = k+1;
%o A039082 end
%o A039082 disp(regexprep(num2str(a'), ' +', ', ')) % _Chris R. Rehmann_, Mar 04 2026
%Y A039082 Cf. A007095, A039362.
%Y A039082 Cf. A039077, A039078, A039079, A039080, A039081, A039083, A031492.
%Y A039082 Cf. A039088, A039094, A039099, A039103, A039106.
%K A039082 nonn,base,easy,changed
%O A039082 1,2
%A A039082 _Olivier Gérard_
