%I A039361 #16 Apr 04 2026 16:32:48
%S A039361 45,86,126,167,207,248,288,329,369,406,407,408,409,411,412,413,414,
%T A039361 423,432,441,459,468,477,491,531,572,612,653,693,743,752,761,770,775,
%U A039361 776,777,778,780,781,782,788,797,806,815,855,896,936,977,1017,1058,1098,1135
%N A039361 Numbers whose base-9 representation has the same nonzero number of 0's and 5's.
%H A039361 Chris R. Rehmann, <a href="/A039361/b039361.txt">Table of n, a(n) for n = 1..10000</a>
%t A039361 Select[Range[1135], DigitCount[#, 9, 0]==DigitCount[#, 9, 5]>0&] (* _Chris R. Rehmann_, Apr 04 2026 *)
%o A039361 (MATLAB)
%o A039361 a = NaN(52,1); k = 0; j = 1;
%o A039361 while any(isnan(a))
%o A039361     d = dec2base(k,9)-'0';
%o A039361     n1 = sum(d==0); n2 = sum(d==5);
%o A039361     if n1==n2 && n1 > 0
%o A039361         a(j) = k; j = j+1;
%o A039361     end
%o A039361     k = k+1;
%o A039361 end
%o A039361 disp(regexprep(num2str(a'), ' +', ', ')) % _Chris R. Rehmann_, Apr 04 2026
%Y A039361 Cf. A007095, A039081.
%Y A039361 Cf. A039357, A039358, A039359, A039360, A039362, A039363, A039364.
%Y A039361 Cf. A039368, A039374, A039379, A039383.
%K A039361 nonn,base,easy
%O A039361 1,1
%A A039361 _Olivier Gérard_
