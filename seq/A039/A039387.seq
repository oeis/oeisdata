%S A039387 51,59,132,140,213,221,294,302,375,383,411,420,429,438,447,459,460,
%T A039387 461,462,463,466,467,474,483,491,500,509,518,527,531,532,533,534,535,
%U A039387 538,539,554,563,618,626,699,707,780,788,861,869,942,950,1023,1031
%N A039387 Numbers whose base-9 representation has the same nonzero number of 5's and 6's.
%H A039387 Chris R. Rehmann, <a href="/A039387/b039387.txt">Table of n, a(n) for n = 1..10000</a>
%t A039387 Select[Range[1200],DigitCount[#,9,5]==DigitCount[#,9,6]>0&] (* _Harvey P. Dale_, Nov 17 2018 *)
%o A039387 (MATLAB) x = 0:1031; d = dec2base(x,9)-'0'; s1 = sum(d==5,2); s2 = sum(d==6,2); a = x(s1==s2 & s1>0); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Apr 13 2026
%Y A039387 Cf. A007095, A039106.
