%N A039099 Numbers whose base-9 representation has the same number of 3's and 6's.
%H A039099 Chris R. Rehmann, <a href="/A039099/b039099.txt">Table of n, a(n) for n = 1..10000</a>
%t A039099 Select[Range[0,150],DigitCount[#,9,3]==DigitCount[#,9,6]&] (* _Harvey P. Dale_, Oct 13 2025 *)
%o A039099 (MATLAB) x = 0:24502; d = dec2base(x,9)-'0'; a = x(sum(d==3,2)==sum(d==6,2)); disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Mar 17 2026
