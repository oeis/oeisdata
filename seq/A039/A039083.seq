%I A039083 #19 Mar 05 2026 16:01:07
%S A039083 1,2,3,4,5,6,8,10,11,12,13,14,15,17,19,20,21,22,23,24,26,28,29,30,31,
%T A039083 32,33,35,37,38,39,40,41,42,44,46,47,48,49,50,51,53,55,56,57,58,59,60,
%U A039083 62,63,73,74,75,76,77,78,80,88,91,92,93,94,95,96,98,100,101,102,103
%N A039083 Numbers whose base-9 representation has the same number of 0's and 7's.
%H A039083 Chris R. Rehmann, <a href="/A039083/b039083.txt">Table of n, a(n) for n = 1..10000</a>
%t A039083 Select[Range[120],DigitCount[#,9,0]==DigitCount[#,9,7]&] (* _Harvey P. Dale_, Mar 06 2018 *)
%o A039083 (MATLAB)
%o A039083 a = NaN(10000,1); k = 0; j = 1;
%o A039083 while any(isnan(a))
%o A039083     d = dec2base(k,9)-'0';
%o A039083     if sum(d==0)==sum(d==7)
%o A039083         a(j) = k; j = j+1;
%o A039083     end
%o A039083     k = k+1;
%o A039083 end
%o A039083 disp(regexprep(num2str(a'), ' +', ', ')) % _Chris R. Rehmann_, Mar 04 2026
%Y A039083 Cf. A007095, A039363.
%Y A039083 Cf. A039077, A039078, A039079, A039080, A039081, A039082, A031492.
%Y A039083 Cf. A039089, A039095, A039100, A039104, A039107, A039109.
%K A039083 nonn,base,easy
%O A039083 1,2
%A A039083 _Olivier Gérard_
