%I A039362 #19 Apr 04 2026 15:49:19
%S A039362 54,87,135,168,216,249,297,330,378,411,459,487,488,489,490,491,493,
%T A039362 494,495,504,513,522,531,549,558,573,621,654,702,744,753,762,771,780,
%U A039362 784,785,786,787,788,790,791,798,807,816,864,897,945,978,1026,1059,1107,1140
%N A039362 Numbers whose base-9 representation has the same nonzero number of 0's and 6's.
%H A039362 Chris R. Rehmann, <a href="/A039362/b039362.txt">Table of n, a(n) for n = 1..10000</a>
%t A039362 Select[Range[1100],DigitCount[#,9,0]==DigitCount[#,9,6]>0&] (* _Harvey P. Dale_, Aug 18 2011 *)
%o A039362 (MATLAB)
%o A039362 a = NaN(52,1); k = 0; j = 1;
%o A039362 while any(isnan(a))
%o A039362     d = dec2base(k,9)-'0';
%o A039362     n1 = sum(d==0); n2 = sum(d==6);
%o A039362     if n1==n2 && n1 > 0
%o A039362         a(j) = k; j = j+1;
%o A039362     end
%o A039362     k = k+1;
%o A039362 end
%o A039362 disp(regexprep(num2str(a'), ' +', ', ')) % _Chris R. Rehmann_, Apr 04 2026
%Y A039362 Cf. A007095, A039082.
%Y A039362 Cf. A039357, A039358, A039359, A039360, A039361, A039363, A039364.
%Y A039362 Cf. A039369, A039375, A039380, A039384, A039387.
%K A039362 nonn,base,easy,changed
%O A039362 1,1
