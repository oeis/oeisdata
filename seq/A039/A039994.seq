%U A039994 5,2,4,4,5,5,5,3,3,5,2,1,3,3,5,3,3,3,1,4,3,3,4,4,3,2,1,4,3,3,6,3,4,3,4,3,4
%N A039994 Number of primes embedded in decimal expansion of prime(n) as subsequences.
%H A039994 Michael S. Branicky, <a href="/A039994/b039994.txt">Table of n, a(n) for n = 1..10000</a>
%F A039994 a(n) = A039995(prime(n)) = A039995(A000040(n)).
%e A039994 a(9) = 3 since prime(9) = 23 and "23" has three prime subsequences, 2, 3 and 23.
%e A039994 a(26) = 2 since prime(26) = 101 and "101" has two prime subsequences, 101 and 11.
%p A039994 f:= proc(n) local d,L,S;
%p A039994   L:= convert(n,base,10); d:= nops(L);
%p A039994   S:= convert(map(t -> L[t],combinat[powerset]([$1..d])),set);
%p A039994   nops(select(isprime,map(proc(t) local i; add(t[i]*10^(i-1),i=1..nops(t)) end proc, S)))
%p A039994 end proc:
%p A039994 map(f @ ithprime, [$1..100]); # _Robert Israel_, Jul 01 2026
%t A039994 A039994[n_] := Count[Union[Map[FromDigits, Subsets[IntegerDigits[Prime[n]]]]], _?PrimeQ];
%t A039994 Array[A039994, 100] (* _Paolo Xausa_, Jul 02 2026 *)
%o A039994 (Python)
%o A039994 from sympy import isprime, prime
%o A039994 from itertools import chain, combinations as combs
%o A039994 def powerset(s): # nonempty subsets of s
%o A039994     return chain.from_iterable(combs(s, r) for r in range(1, len(s)+1))
%o A039994 def a(n):
%o A039994     ss = set(int("".join(s)) for s in powerset(str(prime(n))))
%o A039994     return sum(1 for k in ss if isprime(k))
%o A039994 print([a(n) for n in range(1, 106)]) # _Michael S. Branicky_, Jun 29 2026
%Y A039994 Cf. A000040, A039995.
%Y A039994 Different from A039996.
%K A039994 nonn,base
%O A039994 1,6
%A A039994 _David W. Wilson_
%E A039994 Definition and example clarified by _N. J. A. Sloane_, Jun 03 2024
