%I A055065 #16 Jul 10 2026 10:24:33
%S A055065 8,16,24,36,48,60,78,84,90,114,144,120,168,180,234,246,288,240,210,
%T A055065 324,300,360,474,330,528,576,390,462,480,420,570,510,672,792,756,876,
%U A055065 714,798,690,1038,630,1008,930,780,960,870,924,900,1134,1434,840,990
%N A055065 Smallest even number that is the sum of distinct primes in exactly n ways.
%C A055065 Proposed by G. L. Honaker, Jr.
%C A055065 Essentially a greedy inverse of A061357: a(n)/2 is the index of the first appearance of n in A061357. - _R. J. Mathar_, Jul 10 2026
%H A055065 R. J. Mathar, <a href="/A055065/b055065.txt">Table of n, a(n) for n = 1..382</a>
%F A055065 a(n) >= A087747(n). - _R. J. Mathar_, Jul 10 2026
%e A055065 16 is the sum of distinct primes in exactly 2 ways (3 + 13 and 5 + 11), and is the smallest such number, so a(2) = 16.
%p A055065 A055065 := proc(n)
%p A055065     local a,p,q,N,i ;
%p A055065     for a from 2 by 2 do
%p A055065         N := 0 ;
%p A055065         for i from 1 do
%p A055065             p := ithprime(i) ;
%p A055065             q := a-p ;
%p A055065             if q < p then
%p A055065                 break ;
%p A055065             end if;
%p A055065             if isprime(q) and p <> q then
%p A055065                 N := N+1 ;
%p A055065             end if;
%p A055065         end do:
%p A055065         if N = n then
%p A055065             return a ;
%p A055065         end if;
%p A055065     end do:
%p A055065 end proc:
%p A055065 seq(A055065(n),n=1..60) ; # _R. J. Mathar_, Jul 10 2026
%Y A055065 Cf. A001172.
%K A055065 nonn,changed
%O A055065 1,1
