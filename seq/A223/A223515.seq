%N A223515 Triangle T(n,k) represents the coefficients of (x^13*d/dx)^n, where n=1,2,3,...; generalization of Stirling numbers of second kind A008277, Lah-numbers A008297.
%e A223515 Triangle begins:
%e A223515              1;
%e A223515             13,           1;
%e A223515            325,          39,          1;
%e A223515          12025,        1807,         78,         1;
%e A223515         589225,      102375,       5785,       130,       1;
%e A223515       35942725,     6936475,     466830,     14105,     195,     1
%e A223515     2623818925,   549241875,   41948725,   1538810,   29120,   273,   1;
%e A223515   223024608625, 49858620175, 4198780950, 177364005, 4130490, 53690, 364, 1;
%p A223515 b[0]:=f(x):
%p A223515 for j from 1 to 10 do
%p A223515 b[j]:=simplify(x^13*diff(b[j-1],x$1));
%p A223515 end do;
%p A223515 # Recurrence
%p A223515 a := proc(j,n,N) option remember;
%p A223515    if j < 0 or j > n then 0 elif n = 0 then 1
%p A223515    else a(j-1,n-1,N)+((N-1)*(n-1)+j)*a(j,n-1,N);
%p A223515    end if; end proc:
%p A223515 for n from 0 to 8 do print(seq(a(j,n,13),j=1..n)): end: # _Brendan McKay_, Mar 03 2026
