%U A223516 33810,294,1,384402775680,79123806720,6148457280,240056880,5174400,62328,392,1
%N A223516 Triangle T(n,k) represents the coefficients of (x^14*d/dx)^n, where n=1,2,3,...; generalization of Stirling numbers of second kind A008277, Lah-numbers A008297.
%e A223516 1;
%e A223516 14,1;
%e A223516 378,42,1;
%e A223516 15120,2100,84,1;
%e A223516 801360,128520,6720,140,1;
%e A223516 52889760,9412200,585480,16380,210,1;
%e A223516 4178291040,805865760,56836080,1928640,33810,294,1;
%e A223516 384402775680,79123806720,6148457280,240056880,5174400,62328,392,1;
%p A223516 b[0]:=f(x):
%p A223516 for j from 1 to 10 do
%p A223516 b[j]:=simplify(x^14*diff(b[j-1],x$1));
%p A223516 end do;
%p A223516 # Recurrence
%p A223516 a := proc(j,n,N) option remember;
%p A223516    if j < 0 or j > n then 0 elif n = 0 then 1
%p A223516    else a(j-1,n-1,N)+((N-1)*(n-1)+j)*a(j,n-1,N);
%p A223516    end if; end proc:
%p A223516 for n from 0 to 8 do print(seq(a(j,n,14),j=1..n)): end: # _Brendan McKay_, Mar 03 2026
