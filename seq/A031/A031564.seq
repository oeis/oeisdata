%U A031564 9876,9897,9903,9921,9942,9957,9969,9993,10014,10029,10041,10077,10101,10113,10119
%N A031564 Numbers k such that the continued fraction for sqrt(k) has even period and if the last term of the periodic part is deleted the central term is 66.
%H A031564 Harvey P. Dale, <a href="/A031564/b031564.txt">Table of n, a(n) for n = 1..3313</a> (* All terms up to one million. *) (* _Harvey P. Dale_, Jun 20 2026 *)
%t A031564 cf66Q[n_]:=With[{s=Sqrt[n]},{cf=If[IntegerQ[s],{1},ContinuedFraction[s][[2]]]},{len=Length[cf]},EvenQ[len]&&cf[[len/2]]==66]; Select[Range[10200],cf66Q] (* _Harvey P. Dale_, Jun 20 2026 *)
%K A031564 nonn
%O A031564 1,1
%A A031564 _David W. Wilson_
