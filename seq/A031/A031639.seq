%U A031639 412789,414074,417941,420529,479593,487933,548441,554377,560345,566345,629810
%N A031639 Numbers k such that the continued fraction for sqrt(k) has odd period and if the last term of the periodic part is deleted the two central terms are both 51.
%t A031639 cf51Q[n_]:=With[{s=Sqrt[n]},{cf=If[IntegerQ[s],{1,2},ContinuedFraction[s[[2]]]]},{len=Length[cf]},OddQ[len]&&cf[[(len-1)/2]]==cf[[(len-1)/2+1]]==51]; Select[Range[630000],cf51Q] (* _Harvey P. Dale_, May 16 2026 *)
%K A031639 nonn
%O A031639 1,1
%A A031639 _David W. Wilson_
