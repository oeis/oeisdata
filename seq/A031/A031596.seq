%N A031596 Numbers k such that the continued fraction for sqrt(k) has even period and if the last term of the periodic part is deleted the central term is 98.
%t A031596 cf98Q[n_]:=With[{s=Sqrt[n]},{cf=If[IntegerQ[s],{1},ContinuedFraction[s][[2]]]},{len=Length[cf]},EvenQ[len]&&cf[[len/2]]==98]; Select[Range[22000],cf98Q] (* _Harvey P. Dale_, Apr 19 2026 *)
