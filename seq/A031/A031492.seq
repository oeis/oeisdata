%I A031492 #18 Mar 06 2026 16:33:14
%S A031492 1,2,3,4,5,6,7,10,11,12,13,14,15,16,19,20,21,22,23,24,25,28,29,30,31,
%T A031492 32,33,34,37,38,39,40,41,42,43,46,47,48,49,50,51,52,55,56,57,58,59,60,
%U A031492 61,64,65,66,67,68,69,70,72,89,91,92,93,94,95,96,97,100
%N A031492 Numbers whose base-9 representation has the same number of 0's as 8's.
%H A031492 Chris R. Rehmann, <a href="/A031492/b031492.txt">Table of n, a(n) for n = 1..10000</a>
%t A031492 Select[Range@100,(s=#;Differences[Count[IntegerDigits[s,9],#]&/@{0,8}]=={0})&] (* _Giorgos Kalogeropoulos_, Jul 04 2021 *)
%t A031492 Select[Range[100],DigitCount[#,9,0]==DigitCount[#,9,8]&] (* _Harvey P. Dale_, Mar 09 2023 *)
%o A031492 (MATLAB)
%o A031492 a = NaN(10000,1); k = 0; j = 1;
%o A031492 while any(isnan(a))
%o A031492     d = dec2base(k,9)-'0';
%o A031492     if sum(d==0)==sum(d==8)
%o A031492         a(j) = k; j = j+1;
%o A031492     end
%o A031492     k = k+1;
%o A031492 end
%o A031492 disp(regexprep(num2str(a'), ' +', ', ')) % _Chris R. Rehmann_, Mar 05 2026
%Y A031492 Cf. A007095, A039364.
%Y A031492 Cf. A039077, A039078, A039079, A039080, A039081, A039082, A039083.
%Y A031492 Cf. A039090, A039096, A039101, A039105, A039108, A039110, A039111.
%K A031492 nonn,base,changed
%O A031492 1,2
%A A031492 _Clark Kimberling_
