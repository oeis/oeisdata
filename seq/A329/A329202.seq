%N A329202 a(n) = floor(2*log_2(n)) = floor(log_2(n^2)).
%C A329202 For n >= 1, a(n+1) is the tree-depth of the n-ladder graph. - _Eric W. Weisstein_, Jul 01 2026
%H A329202 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/LadderGraph.html">Ladder Graph</a>.
%H A329202 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/Tree-Depth.html">Tree-Depth</a>.
%t A329202 Table[Floor[2 Log2[n]], {n, 20}] (* _Eric W. Weisstein_, Jul 01 2026 *)
%t A329202 (* Alternative: *)
%t A329202 Floor[2 Log2[Range[20]]] (* _Eric W. Weisstein_, Jul 01 2026 *)
%o A329202 (PARI) a(n)=logint(n^2,2)
%Y A329202 Cf. A017912, A328911 (has this as row lengths).
%K A329202 nonn,easy
%O A329202 1,2
