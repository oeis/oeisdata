%S A329072 0,1,6,7,19,25,26,44,63,69,70,85,129,146,148,154,155,231,275,294,300,
%T A329072 301,344,377,462,489,506,525,531,532,575,670,721,806,833,850,869,875,
%U A329072 876,891,1064,1156,1159,1210,1295,1339,1358,1364,1365,1469,1503,1561,1734
%N A329072 Numbers that are sums of one or more consecutive octahedral numbers (A005900).
%C A329072 The first term that is a sum of consecutive octahedral numbers in more than one way is a(18) = 231 = A005900(7) = 85 + 146 = A005900(5) + A005900(6). Are there any terms that are a sum of consecutive octahedral numbers in three ways? - _Robert Israel_, Jul 20 2026
%H A329072 Robert Israel, <a href="/A329072/b329072.txt">Table of n, a(n) for n = 1..10000</a>
%H A329072 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/OctahedralNumber.html">Octahedral Number</a>
%p A329072 N:= 10^4: # for terms <= N
%p A329072 Oct:= [seq(n*(2*n^2+1)/3,n=0..floor(fsolve(x*(2*x^2+1)/3=N)))]:
%p A329072 S:= ListTools:-PartialSums(Oct):
%p A329072 select(t -> t <= N, sort(convert({0,seq(seq(S[j]-S[i],i=1..j-1),j=1..nops(S))},list))); # _Robert Israel_, Jul 20 2026
%Y A329072 Cf. A005900, A006325, A217843, A322468, A322479, A329597, A329599.
