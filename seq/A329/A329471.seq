%I A329471 #19 Jul 24 2026 01:03:59
%S A329471 1,3,12,147,21612,467078547,218162369067631212,
%T A329471 47594819277201331861096436836588947,
%U A329471 2265266822029455509816214491130485582138030749246532017266850242568812
%N A329471 a(n) = a(n-1)^2 + 3 for n >= 2 , where a(0) = 1, a(1) = 3.
%C A329471 (a(n)) is a strong divisibility sequence.
%C A329471 For k >= 1, the sequences {a(n+k) - a(k) : n >= 1} and {a(n+k) + a(k): n >= 1} are also strong divisibility sequences. - _Peter Bala_, Jul 16 2026
%D A329471 L. E. Dickson, History of the Theory of Numbers, Vol. 1, Chelsea, New York, 1952, p. 403.
%H A329471 Peter Bala, <a href="/A000058/a000058_1.pdf">Sylvester's theorem and strong divisibility sequences</a>, 2026.
%F A329471 a(n) = p(n,0), where p(n,x) is the polynomial defined in A329433.
%t A329471 f[x_] := x^2 + 3; u[0, x_] := 1;
%t A329471 u[1, x_] := f[x]; u[n_, x_] := f[u[n - 1, x]]
%t A329471 Table [u[n, x] /. x -> 0, {n, 0, 10}]
%Y A329471 Cf. A003095, A072191, A329433.
%K A329471 nonn,easy,changed
%O A329471 0,2
%A A329471 _Clark Kimberling_, Dec 31 2019
