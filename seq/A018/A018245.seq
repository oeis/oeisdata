%N A018245 A self-generating sequence: there are a(n) (k+1)'s between successive k's, where k=4.
%p A018245 f:= proc(n, k) floor(n*(k+sqrt(k^2+4*k))/2)-floor((n-1)*(k+sqrt(k^2+4*k))/2) end:
%p A018245 seq(f(n,4), n=1..105);
%Y A018245 Cf. A001468, A007538.
%K A018245 nonn,changed
%O A018245 1,1
%A A018245 _Jonas Wallgren_
