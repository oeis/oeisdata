%U A117976 44739243,134217729,402653187,402653187,1207959561,3623878683,3623878683,7650410553,22951231659,22951231659
%N A117976 Legendre-binomial transform of 2^n for p=3.
%F A117976 a(3n) = a(3n+1)/a(1) = a(3n+2)/a(2).
%F A117976 a(9n) = a(9n+3)/a(3) = a(9n+6)/a(6).
%F A117976 a(27n) = a(27n+9)/a(9) = a(27n+18)/a(18).
%F A117976 a(3^k*n) = a(3^k*n+3^(k-1))/a(3^(k-1)) = a(3^k*n+2*3^(k-1))/a(2*3^(k-1)), k>0.
%F A117976 a(n) = Sum{k=0..n} L(C(n,k)/3)*2^k, where L(j/p) is the Legendre symbol of j and p.
%t A117976 a[n_]:=Sum[JacobiSymbol[Binomial[n,k],3]*2^k,{k,0,n}]; Array[a,36,0] (* _Stefano Spezia_, Jul 22 2026 *)
%Y A117976 Cf. A117611, A117977, A117980, A117981.
%K A117976 easy,nonn,changed
%O A117976 0,2
