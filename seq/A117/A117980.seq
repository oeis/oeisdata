%N A117980 Legendre-binomial transform of (-1)^n for p=3.
%H A117980 Antti Karttunen, <a href="/A117980/b117980.txt">Table of n, a(n) for n = 0..59049</a>
%F A117980 a(n) = a(3n) = a(3n+2)/3; a(3n+2) = 0.
%F A117980 a(n) = Sum_{k=0..n} L(C(n,k)/3)*(-1)^k, where L(j/p) is the Legendre symbol of j and p.
%t A117980 a[n_]:=Sum[JacobiSymbol[Binomial[n,k],3]*(-1)^k,{k,0,n}]; Array[a,99,0] (* _Stefano Spezia_, Jul 22 2026 *)
%o A117980 (PARI) A117980(n) = sum(k=0,n,kronecker(binomial(n,k),3)*((-1)^k)); \\ _Antti Karttunen_, Sep 20 2019
%Y A117980 Cf. A117611, A117976, A117977.
%K A117980 easy,nonn,changed
%O A117980 0,3
%A A117980 _Paul Barry_, Apr 06 2006
