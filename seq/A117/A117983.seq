%N A117983 A modified Legendre-binomial transform of 3^n for p=3.
%C A117983 Divisors of a(9) = 3^9-1 are a(0), a(1), a(2), a(3), a(6), a(7), a(8), and a(9).
%F A117983 a(3n) = a(3n+1)/2 = a(3n+2)/13.
%F A117983 a(3^k*n) = a(3^k*n+3^(k-1))/a(3^(k-1)) = a(3^k*n+2*3^(k-1))/a(2*3^(k-1)), k>0.
%F A117983 a(n) = Sum_{k=0..n} (-1)^(n-k)*L(C(n,k)/3)*3^k, where L(j/p) is the Legendre symbol of j and p.
%t A117983 a[n_]:=Sum[(-1)^(n-k)JacobiSymbol[Binomial[n,k],3]*3^k,{k,0,n}]; Array[a,29,0] (* _Stefano Spezia_, Jul 22 2026 *)
%Y A117983 Cf. A117977, A117981, A117984.
%K A117983 easy,nonn,changed
