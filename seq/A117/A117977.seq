%U A117977 10847222596,43388890384,75930558172,272342767321,1089371069284,1906399371247,7625597484988,30502389939952
%N A117977 Legendre-binomial transform of 3^n for p=3.
%F A117977 a(3n) = a(3n+1)/a(1) = a(3n+2)/a(2).
%F A117977 a(9n) = a(9n+3)/a(3) = a(9n+6)/a(6).
%F A117977 a(27n) = a(27n+9)/a(9) = a(27n+18)/a(18).
%F A117977 a(3^k*n) = a(3^k*n+3^(k-1))/a(3^(k-1)) = a(3^k*n+2*3^(k-1))/a(2*3^(k-1)), k>0.
%F A117977 a(n) = Sum_{k=0..n} L(C(n,k)/3)*3^k, where L(j/p) is the Legendre symbol of j and p.
%t A117977 a[n_]:=Sum[JacobiSymbol[Binomial[n,k],3]*3^k,{k,0,n}]; Array[a,29,0] (* _Stefano Spezia_, Jul 22 2026 *)
%Y A117977 Cf. A117611, A117976, A117980, A117983.
%K A117977 easy,nonn,changed
