%U A117667 406615755353655135,17216961135462248176,775537745518440716417,37031913482632035365106,1868507452568073945283759
%N A117667 a(n) = n^n - n^(n-1) - n^(n-2) - n^(n-3) - ... - n^3 - n^2 - n.
%H A117667 Alois P. Heinz, <a href="/A117667/b117667.txt">Table of n, a(n) for n = 0..386</a> (terms n = 1..100 from Christian N. K. Anderson)
%F A117667 a(n) = A000312(n) - A023037(n) + 1 for n>=1. - _Michel Marcus_, Apr 14 2015
%F A117667 a(n) = A191690(n) + 1 for n>=1. - _Robert G. Wilson v_, Apr 16 2015
%e A117667 a(3) = 3^3-3^2-3 = 27-9-3 = 15.
%p A117667 a:=n->n^n-sum(n^j,j=1..n-1): seq(a(n),n=0..19); # _Emeric Deutsch_, Apr 16 2006
%t A117667 s[n_] := Sum[n^i, {i, 1, n - 1}]; Table[n^n - s[n], {n, 17}] (* _Carlos Eduardo Olivieri_, Apr 14 2015 *)
%t A117667 (* Alternative: *)
%t A117667 f[n_] := ((n - 2) n^n + n)/(n - 1); f[1] = 1; Array[f, 18] (* _Robert G. Wilson v_, Apr 15 2015 *)
%o A117667 (PARI) a(n)= if(1==n, 1, (n^n*(n-2)+n)/(n-1)); \\ _Ruud H.G. van Tol_, Apr 28 2026
%Y A117667 Cf. A000312 (n^n), A023037 (1+n+n^2+...n^(n-1)), A001923, A031972, A191690, A341331 (n^n-(n-1)^n-...).
