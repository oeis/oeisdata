%N A117611 Legendre-binomial transform of 10^n for p=3.
%F A117611 a(n) = Sum_{k=0..n} L(C(n,k)/3)*10^k, where L(j/p) is the Legendre symbol of j and p.
%t A117611 a[n_]:=Sum[JacobiSymbol[Binomial[n,k],3]*10^k,{k,0,n}]; Array[a,21,0] (* _Stefano Spezia_, Jul 22 2026 *)
