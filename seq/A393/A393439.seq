%T A393439 26,29,27,30,28,34,33,31,45,35,38,43,48,39,40,46,36,62,44,37,49,42,41,
%U A393439 52,53,50,47,51,58,54,55,65,66,77,56,59,67,60,76,69,57,78
%N A393439 Index of 2*n in A390314, or -1 if 2*n does not appear.
%H A393439 Chai Wah Wu, <a href="/A393439/b393439.txt">Table of n, a(n) for n = 1..10000</a>
%o A393439 (Python)
%o A393439 from itertools import count
%o A393439 from math import gcd
%o A393439 from sympy import primefactors
%o A393439 def A393439(n):
%o A393439     c, aset, a, b, s, p = set(), {1}, 1, 2, 1, n<<1
%o A393439     for a in count(2):
%o A393439         for k in count(b,2):
%o A393439             if k not in aset:
%o A393439                 m = s+k
%o A393439                 if gcd(m,k) == 1 and all(m%p for p in c):
%o A393439                     if k == p:
%o A393439                         return a
%o A393439                     a = k
%o A393439                     aset.add(a)
%o A393439                     s += a
%o A393439                     c |= set(primefactors(a))
%o A393439                     while b in aset:
%o A393439                         b += 2
%o A393439                     break # _Chai Wah Wu_, Mar 10 2026
