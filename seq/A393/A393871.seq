%N A393871 O.g.f. A(x) satisfies: [x^n] exp( n^7*x - n*A(x) ) = 0 for n >= 1.
%H A393871 Paul D. Hanna, <a href="/A393871/b393871.txt">Table of n, a(n) for n = 1..201</a>
%e A393871 O.g.f.: A(x) = x + 3969*x^2 + 570074232*x^3 + 739996964038962*x^4 + 4789222982357994715500*x^5 + 110008722838279295800818830376*x^6 + ...
%e A393871 ILLUSTRATION OF DEFINITION.
%e A393871 The table of coefficients of x^k/k! in exp( n^7*x - n*A(x) ) begins
%e A393871   n = 1: [1,     0,      -7938,     -3420445392, ...];
%e A393871   n = 2: [1,   126,          0,     -6844891536, ...];
%e A393871   n = 3: [1,  2184,    4746042,               0, ...];
%e A393871   n = 4: [1, 16380,  268272648,   4379583997152, 0, ...];
%e A393871   n = 5: [1, 78120, 6102694710, 476719207352640, 37147770116934096060, 0, ...]; ...
%e A393871 in which a diagonal, the coefficient of x^n in row n, is all zeros.
%e A393871 RELATED SERIES.
%e A393871 exp(A(x)) = 1 + x + 7939*x^2/2! + 3420469207*x^3/3! + 17759941007799817*x^4/4! + 574706846954145155463361*x^5/5! + 79206283894033577300908004448571*x^6/6! + ...
%e A393871 where [x^n] exp(n^7*x) / exp(A(x))^n = 0 for n >= 1.
%o A393871 (PARI) {a(n,p=7,q=1) = my(A=[0], m); for(i=1, n+1, m=#A; A=concat(A, 0); A[m+1] = Vec( exp(m^p*x - m^q*Ser(A)) )[m+1]/(m^q) ); polcoef( Ser(A), n)}
%o A393871 for(n=1, 15, print1(a(n,7,1), ", "))
%Y A393871 Below, sequences with the parameters (p,q) indicated have an o.g.f. F(x) satisfying [x^n] exp( n^p*x - n^q*F(x) ) = 0 for n >= 1.
