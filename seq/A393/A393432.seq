%S A393432 0,0,0,0,0,7,14,36,57,115,143,302,314,540,670,1031,1047,1789,1682,
%T A393432 2827,2916,3852,3835,6580,5635,7834,8426,11657,10192,16206,13496,
%U A393432 20291,19526,23767,23379,36653,28154,37769,39030,52630
%N A393432 a(n) is the number of three-element sets of distinct integer-sided trapezoids whose base angles are 60 degrees of total area n^2 but which cannot fill an equilateral triangular grid of side n units.
%C A393432 These sets consist of distinct integer-sided trapezoids formed within the equilateral triangular grid of side n units such that the total area is n^2.
%C A393432 A trapezoid whose base angles are 60 degrees with larger base b and legs s is denoted by {b X s} here.
%H A393432 Janaka Rodrigo, <a href="/A393432/a393432.txt">Python code for 3-trapezoid sets of total area n^2</a>
%e A393432 Sequence has seven sets for n = 6:
%e A393432  {(2 X 1), (4 X 2), (5 X 3)},
%e A393432  {(3 X 1), (4 X 1), (5 X 4)},
%e A393432  {(3 X 1), (6 X 1), (6 X 2)},
%e A393432  {(4 X 1), (5 X 1), (6 X 2)},
%e A393432  {(3 X 2), (4 X 2), (5 X 2)},
%e A393432  {(5 X 1), (6 X 1), (5 X 2)},
%e A393432  {(5 X 1), (4 X 2), (4 X 3)}.
%e A393432 Therefore a(6) = 7.
%Y A393432 Cf. A130518, A390522, A389392, A389518, A390523, A391498, A391499, A393545.
%K A393432 nonn,more,new
