%S A393128 1,4,9,21,52,134,356,956,2588,7021,19069,51818,140837,382814,1040575,
%T A393128 2828552,7688777,20900235,56812699,154432898,419792107,1141113222,
%U A393128 3101867298,8431749474,22919871337,62302669726,169356214937,460357921555,1251382572703,3401610507781,9246536030745
%N A393128 Positive integers not of the form floor(k + log(k) + log(Pi)).
%C A393128 It was conjectured that for every prime p there is exactly one integer k such that p = k + floor(log(Pi*k)), but this is not true for the primes in this sequence, the first of which are 19069, 140837, 56812699, ...
%C A393128 (This sequence lists all positive integers that do not occur as values of the function on the right hand side.)
%H A393128 Sebastian Martin Ruiz, <a href="https://groups.io/g/primenumberstheory/message/203">Pi Conjecture</a>, PrimeNumbersTheory on Groups.io, March 14, 2026.
%F A393128 a(n+1) / a(n) -> e = 2.718281828...
%o A393128 (PARI)
%o A393128 A393128_first(N)=vector(N, n, if(n>1, N=N*exp(1)\/1-n; n=N+log(N*Pi)\1; until(n+1<n=N+++log(N*Pi)\1,);n-1, N=1))
%Y A393128 Cf. A053510 (log Pi).
%K A393128 nonn,new
%O A393128 1,2
%A A393128 _M. F. Hasler_, Mar 17 2026
