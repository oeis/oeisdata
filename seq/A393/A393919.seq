%I A393919 #9 Mar 25 2026 16:59:08
%S A393919 12,18,36,48,56,60,75,80,84,90,98,120,126,132,150,156,192,198,204,228,
%T A393919 234,252,276,280,300,306,342,348,351,360,372,396,414,420,444,448,450,
%U A393919 468,484,492,516,522,525,528,558,564,594,612,616,624,630,636,660,666,684
%N A393919 Nonsquarefree k such that rad(Sum({m <= k : rad(m) = rad(k)})) = rad(k), where rad = A007947.
%C A393919 Numbers k in A013929 such that rad(A391625(k)) = rad(k).
%C A393919 Proper subset of A126706.
%C A393919 Most terms are in A332785 (neither squarefree nor powerful).
%C A393919 In the first 1339477 terms of the sequence there are only a few powerful terms, for example, a(3) = 36 (in A303606), a(152) = 1800 (Achilles A052486), and a(1094) = 13689 = 3^4*13^2 (in A386762). There are Achilles numbers in this sequence as large as 2^3 * 709^2 * 1543^2.
%C A393919 No intersection with A383394 (perfect powers of Achilles numbers) in the first 300000 terms of that sequence.
%H A393919 Michael De Vlieger, <a href="/A393919/b393919.txt">Table of n, a(n) for n = 1..10000</a>
%H A393919 Michael De Vlieger, <a href="/A393919/a393919.txt">On the intersection of this sequence with certain subsets of powerful numbers</a>.
%e A393919 Table of n, a(n) for select n:
%e A393919      n      a(n)
%e A393919 ----------------------------------------------------------------------------
%e A393919      1        12 = rad(18), where 18 = sum of {6, 12}
%e A393919      2        18 = rad(36), where 36 = sum of {6, 12, 18}
%e A393919      3        36 = rad(96), where 96 = sum of {6, 12, 18, 24, 36}
%e A393919      4        48 = rad(144), where 144 = sum of {6, 12, 18, 24, 36, 48}
%e A393919      5        56 = rad(98), where 98 = sum of {14, 28, 56}
%e A393919      6        60 = rad(90), where 90 = sum of {30, 60}
%e A393919     39       484 = rad(1408); 1408 = sum of {22, 44, 88, 176, 242, 352, 484}
%e A393919    152      1800 = rad(18000), with 1800 = 2^3 * 3^2 * 5^2
%e A393919    594      7396 = rad(22016), with 7396 = 2^2 * 43^2
%e A393919   1094     13689 = rad(41067), with 13689 = 3^4 * 13^2
%e A393919   3472     43681 = rad(75449); 75449 = sum of {209, 2299, 3971, 25289, 43681}
%e A393919 149082   1865956 = rad(5595136), with 1865956 = 2^2 * 683^2
%t A393919 rad[x_] := Times @@ FactorInteger[x][[All, 1]]; t = Select[Range[700], Not @* SquareFreeQ]; s[x_] := Module[{r}, r = rad[x]; Total@ Select[Range[x], rad[#] == r &]]; Select[t, rad[#] == rad[s[#] ] &]
%Y A393919 Cf. A007947, A008479, A013929, A126706, A332785, A369609, A381498, A391625.
%K A393919 nonn
%O A393919 1,1
%A A393919 _Michael De Vlieger_, Mar 11 2026
