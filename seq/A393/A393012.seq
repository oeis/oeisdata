%N A393012 List giving least 5-rough number (A007310) of each prime signature.
%C A393012 Sequences of the form "List giving least p-rough number of each prime signature." for prime p can help in a search for numbers k <= U such that sigma(k) >= b*k where U is some chosen upper bound and b is some chosen constant. If such sequence is S(p, U) then we can find the largest ratio sigma(k)/k for k in S(p, U) and use that to decide to continue searching.
%C A393012 b = 2 describes nonabundant numbers (A023196). p = 2 describes A025487. p = 3 describes A147516. This sequence has p = 5.
%H A393012 Michael De Vlieger, <a href="/A393012/b393012.txt">Table of n, a(n) for n = 1..10000</a>
%H A393012 Michael De Vlieger, <a href="/A393012/a393012.txt">Mathematica algorithm that generates least prime(k)-rough numbers less than a limit</a>.
%F A393012 Sum_{n>=1} 1/a(n) = Product_{n>=3} 1/(1 - 3/A070826(n)) = 1.290389472537278155572... . - _Amiram Eldar_, Feb 13 2026
%e A393012 175 is in the sequence as it is a product of consecutive primes starting at 5 and for any two distinct prime powers p^ep and q^eq where p < q we have ep >= eq.
%o A393012 (PARI) is(n) = {if(n == 1, return(1)); e = valuation(n, 5); if(e == 0, return(0)); n\=5^e; if(n==1, return(1)); forprime(p = 7, oo, v = valuation(n, p); if(v > e, return(0)); if(v == 0, return(0)); n\=p^v; if(n==1, return(1)); e = v)}
%o A393012 (Python)
%o A393012 from itertools import count
%o A393012 from functools import lru_cache
%o A393012 from sympy import prime, integer_log
%o A393012 from oeis_sequences.OEISsequences import bisection
%o A393012 def A393012(n):
%o A393012     @lru_cache(maxsize=None)
%o A393012     def g(x, m, j): return sum(g(x//(prime(m)**i), m-1, i) for i in range(j,integer_log(x, prime(m))[0]+1)) if m>3 else max(0,integer_log(x,5)[0]+1-j)
%o A393012     def f(x):
%o A393012         c, p = n-1+x, 1
%o A393012         for k in count(3):
%o A393012             p *= prime(k)
%o A393012             if p>x:
%o A393012                 break
%o A393012             c -= g(x,k,1)
%o A393012         return c
%o A393012     return bisection(f,n,n) # _Chai Wah Wu_, Mar 31 2026
%o A393012 (Python)
%o A393012 from itertools import islice
%o A393012 from heapq import heappop, heappush
%o A393012 from sympy import factorint, prevprime, nextprime
%o A393012 def A393012_gen(): # generator of terms if the first n terms are desired.
%o A393012     h, hset = [1], {1}
%o A393012     while True:
%o A393012         yield (m:=heappop(h))
%o A393012         ps = factorint(m)
%o A393012         for p in ps:
%o A393012             if p == 5 or ps[prevprime(p)]>ps[p]:
%o A393012                 mp = m*p
%o A393012                 if mp not in hset:
%o A393012                     heappush(h,mp)
%o A393012                     hset.add(mp)
%o A393012         mp = m*nextprime(max(ps.keys(),default=3))
%o A393012         if mp not in hset:
%o A393012             heappush(h,mp)
%o A393012             hset.add(mp)
%o A393012 A393012_list = list(islice(A393012_gen(),40)) # _Chai Wah Wu_, Mar 31 2026
%Y A393012 Cf. A007310, A023196, A025487, A070826, A147516.
