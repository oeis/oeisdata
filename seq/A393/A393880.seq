%S A393880 1,1,0,1,4,6,8,29,83,153,324,977,2526,5460,13384,37119,93684,222500,
%T A393880 572112,1528656,3876494,9693846,25313424,66666142,171067694,439585892,
%U A393880 1154259084,3029642100,7861383156,20495276076,53976637896,141874500780,371329102669,975970513553,2576858116940
%N A393880 G.f. satisfies Sum_{n>=0} (-1)^n * A(x)^(n^2) = 1 - x - x^2.
%C A393880 Special value: A(t) = exp(-Pi) where t = (sqrt(3 - 2*s) - 1)/2 with s = (Pi/2)^(1/4)/Gamma(3/4) giving t = 0.041489086613886974002...
%C A393880 Special value: A(t) = -exp(-Pi) where t = (sqrt(3 - 2*s) - 1)/2 with s = Pi^(1/4)/Gamma(3/4) giving t = -0.0452664578092506790757...
%C A393880 Conjecture: a(n)^(1/n) tends to 1+sqrt(3). - _Vaclav Kotesovec_, Apr 17 2026
%H A393880 Paul D. Hanna, <a href="/A393880/b393880.txt">Table of n, a(n) for n = 1..1000</a>
%H A393880 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/RamanujanThetaFunctions.html">Ramanujan Theta Functions.</a>
%F A393880 G.f. A(x) = Sum_{n>=0} a(n)*x^n satisfies the following formulas.
%F A393880 (1) 1-x-x^2 = Sum_{n>=0} (-1)^n * A(x)^(n^2).
%F A393880 (2) 1-x-x^2 = Sum_{n>=0} (-1)^n * A(x)^n * Product_{k=1..n} (1 + A(x)^(4*k-3)) / (1 + A(x)^(4*k-1)) due to a q-series identity.
%F A393880 (3) 1-x-x^2 = 1/(1 + A/(1 + (A^3-A)/(1 + A^5/(1 + (A^7-A^3)/(1 + A^9/(1 + (A^11-A^5)/(1 + A^13/(1 + (A^15-A^7)/(1 + ...))))))))) where A = A(x), a continued fraction due to an identity of a partial elliptic theta function.
%F A393880 (4) Sum_{n>=0} (-1)^n * A(x)^(2*n+1)/(1 + A(x)^(2*n+1)) = (x + x^2)*(1 - x - x^2).
%F A393880 (5) Sum_{n>=1} (-1)^n * n * A(x)^n/(1 + A(x)^n) = -(x + x^2)*(1 - x - x^2) * (1 - 2*(x + x^2)*(1 - x - x^2)).
%F A393880 (6) Product_{n>=1} (1 - A(x)^(2*n))*(1 - A(x)^(2*n-1))^2 = 1 - 2*x - 2*x^2, by the Jacobi triple product identity.
%e A393880 G.f.: A(x) = x + x^2 + x^4 + 4*x^5 + 6*x^6 + 8*x^7 + 29*x^8 + 83*x^9 + 153*x^10 + 324*x^11 + 977*x^12 + ...
%o A393880 (PARI) {a(n) = my(A=[0,1]); for(i=1,n, A = concat(A,0);
%o A393880 A[#A] = polcoef( -(1-x-x^2) - sum(m=1,sqrtint(#A), (-1)^(m-1) * Ser(A)^(m^2) ), #A-1) ); polcoef(GF=Ser(A),n)}
%o A393880 {upto(n) = a(n); Vec(GF)}
%o A393880 upto(30)
%o A393880 \\ Verify formulas
%o A393880 A = GF
%o A393880 sum(n=0,#A, (-1)^n * A^(n^2) )
%o A393880 sum(n=0,#A, (-1)^n * A^n * prod(k=1,n, (1 + A^(4*k-3)) / (1 + A^(4*k-1)) ))
%Y A393880 Cf. A393879.
%K A393880 nonn,new
%O A393880 1,5
%A A393880 _Paul D. Hanna_, Apr 09 2026
