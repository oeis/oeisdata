%I A393258 #12 Mar 24 2026 00:17:00
%S A393258 1,2,3,4,5,6,7,9,8,11,10,13,12,15,14,18,16,21,20,19,25,17,23,22,28,27,
%T A393258 26,32,24,30,29,38,37,34,43,31,41,33,40,50,39,49,36,47,45,55,42,53,44,
%U A393258 52,64,51,62,35,48,60,58,72,54,70,56,67,82,65,80,46,61,78,63,76,91,57,74,71,89,73,69,85,86,104
%N A393258 a(n) is the position of A003961(A025487(n)) in A147516.
%C A393258 This is a permutation of the positive integers.
%H A393258 <a href="/index/Per#IntegerPermutation">Index entries for sequences that are permutations of the natural numbers</a>.
%e A393258 a(11) = 10 as A025487(11) = 36 = 2^2 * 3^2. When replacing each prime factor in the prime factorization with the next larger prime we get 3^3 * 5^2 = 225 = A147516(10).
%o A393258 (Python)
%o A393258 from functools import lru_cache
%o A393258 from itertools import count
%o A393258 from sympy import prime, integer_log, primorial, nextprime, factorint
%o A393258 from oeis_sequences.OEISsequences import bisection
%o A393258 def A393258(n):
%o A393258     @lru_cache(maxsize=None)
%o A393258     def g(x, m, j): return sum(g(x//(prime(m)**i), m-1, i) for i in range(j,integer_log(x, prime(m))[0]+1)) if m-1 else max(0,x.bit_length()-j)
%o A393258     @lru_cache(maxsize=None)
%o A393258     def h(x, m, j): return sum(h(x//(prime(m)**i), m-1, i) for i in range(j,integer_log(x, prime(m))[0]+1)) if m>2 else max(0,integer_log(x,3)[0]+1-j)
%o A393258     def f(x):
%o A393258         c = n-1+x
%o A393258         for k in count(1):
%o A393258             if primorial(k)>x:
%o A393258                 break
%o A393258             c -= g(x,k,1)
%o A393258         return c
%o A393258     m, c = prod(nextprime(p)**e for p,e in factorint(bisection(f,n,n)).items()), 1
%o A393258     for k in count(2):
%o A393258         if primorial(k)>(m<<1):
%o A393258             break
%o A393258         c += h(m,k,1)
%o A393258     return c # _Chai Wah Wu_, Mar 23 2026
%Y A393258 Cf. A003961, A025487, A147516.
%K A393258 nonn
%O A393258 1,2
%A A393258 _David A. Corneth_, Feb 07 2026
