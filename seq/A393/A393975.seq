%I A393975 #25 Mar 19 2026 17:26:25
%S A393975 211,233,277,383,409,443,463,479,499,521,541,563,607,613,631,653,673,
%T A393975 677,743,761,787,809,811,827,829,839,853,877,883,887,919,929,937,947,
%U A393975 983,1009,1019,1031,1033,1039,1049,1051,1061,1063,1069,1093,1097,1103,1117,1123,1151,1171,1213,1231,1237
%N A393975 Primes that can be written as p + r where p is a prime and r is an anagram of p.
%C A393975 Leading zeros are not allowed.
%C A393975 We expect that most large primes are terms.
%C A393975 If p and q are the greatest prime < 10^d and least prime > 10^d respectively, any prime between 10^d + p and 10^d + q cannot be a term.  Thus we expect there to be arbitrarily large primes not in the sequence.
%C A393975 From _David A. Corneth_, Mar 16 2026: (Start)
%C A393975 As r is an anagram of p we have p == r (mod 9) and so p+r == 2*p (mod 9). This lets us find p (mod 9) for a particular prime if that prime can be written as such p+r.
%C A393975 Let digsum be the sum of digits (cf. A007953). Then digsum(p)+digsum(r) = 2*digsum(p) >= digsum(p+r) which further restricts the possible digsum of p. (End)
%H A393975 Robert Israel, <a href="/A393975/b393975.txt">Table of n, a(n) for n = 1..10000</a>
%e A393975 a(5) = 409 is a term because 409 is a prime and 409 = 281 + 128 where 281 is prime and 128 is an anagram of 281.
%p A393975 g:= proc(n) local d, L, i;
%p A393975   L:= convert(n, base, 10); d:= nops(L);
%p A393975   select(isprime, convert(map(t -> n + add(t[i]*10^(i-1), i=1..d), select( t -> t[-1] <> 0, combinat:-permute(L))),set))
%p A393975 end proc:
%p A393975 select(`<=`,`union`(op(map(g, {seq(ithprime(i),i=1..1000)}))), ithprime(1000));
%t A393975 g[n_]:=Select[n+FromDigits/@Reverse/@Select[Permutations[Reverse@IntegerDigits[n]],Last[#]!=0&],PrimeQ]; Select[Union@@(g/@Prime[Range[1000]]),#<=Prime[500]&] (* _Vincenzo Librandi_, Mar 13 2026 *)
%o A393975 (Magma) g:=function(n) L:=Reverse(IntegerToSequence(n)); d:=#L; S:={}; for p in SymmetricGroup(d) do t:=[L[i^p]:i in [1..d]]; if t[d] ne 0 then m:=n+&+[t[i]*10^(i-1):i in [1..d]]; if IsPrime(m) then Include(~S,m); end if; end if; end for; return S; end function; U:=&join[g(NthPrime(i)):i in [1..500]]; {x:x in U | x le NthPrime(500)}; // _Vincenzo Librandi_, Mar 13 2026
%Y A393975 Cf. A007953, A046810, A179239, A392836, A393958.
%K A393975 nonn,base,new
%O A393975 1,1
%A A393975 _Robert Israel_, Mar 05 2026
