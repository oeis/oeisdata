%I A393440 #13 Mar 10 2026 19:26:57
%S A393440 3,4,5,9,12,14,15,19,23,30,34,43,46,62,42,51,77,59,78,63,70,84,87,92,
%T A393440 104,98,108,107,140,103,134,125,137,126,153,151,165,182,164,180,184,
%U A393440 233,190,205,211,198,218,222,226,228,231,253,249,259,250,263,275,278,294,282,332,284
%N A393440 Index of 2*prime(n) in A390314, or -1 if 2*prime(n) does not appear.
%H A393440 Chai Wah Wu, <a href="/A393440/b393440.txt">Table of n, a(n) for n = 1..10000</a>
%o A393440 (Python)
%o A393440 from math import gcd
%o A393440 from itertools import count
%o A393440 from sympy import prime, primefactors
%o A393440 def A393440(n):
%o A393440     c, aset, a, b, s, p = set(), {1}, 1, 2, 1, prime(n)<<1
%o A393440     for a in count(2):
%o A393440         for k in count(b,2):
%o A393440             if k not in aset:
%o A393440                 m = s+k
%o A393440                 if gcd(m,k) == 1 and all(m%p for p in c):
%o A393440                     if k == p:
%o A393440                         return a
%o A393440                     a = k
%o A393440                     aset.add(a)
%o A393440                     s += a
%o A393440                     c |= set(primefactors(a))
%o A393440                     while b in aset:
%o A393440                         b += 2
%o A393440                     break # _Chai Wah Wu_, Mar 10 2026
%Y A393440 Cf. A390314, A393439.
%K A393440 nonn
%O A393440 1,1
