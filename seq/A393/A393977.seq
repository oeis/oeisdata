%S A393977 1,1,12,360,23920,3038275,661613616,227993931326,117074972668864,
%T A393977 85514867404374267,85632409776358310300,114090874349629345407646,
%U A393977 197297302443962466857375808,433713210324225209948611599324,1190651062684690034955587638650576
%N A393977 G.f. A(x) satisfies A(x) = 1 - E^3(log(1 - x*A(x))), where E is the Euler operator x*d/dx.
%F A393977 G.f.: 1 + E^2(B(x)), where B(x) is the g.f. of A393475.
%F A393977 a(n) = n^2 * A393475(n) for n > 0.
%F A393977 a(0) = 1; a(n) = n^3 * a(n-1) + Sum_{k=1..n-1} (n/k)^2 * a(k) * a(n-1-k).
%e A393977      -E(log(1 - x*A(x))) =     x +  3*x^2 +  40*x^3 +  1495*x^4 + ...
%e A393977    -E^2(log(1 - x*A(x))) =     x +  6*x^2 + 120*x^3 +  5980*x^4 + ...
%e A393977 1 - E^3(log(1 - x*A(x))) = 1 + x + 12*x^2 + 360*x^3 + 23920*x^4 + ...
%o A393977 (PARI) E(f) = x*deriv(f);
%o A393977 my(A=1, N=20); for(k=1, N, A=1-E(E(E(log(1-x*A))))+x*O(x^N)); Vec(A)
%Y A393977 Cf. A003319, A393959, A394821.
%Y A393977 Cf. A393475.
