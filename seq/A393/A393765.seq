%S A393765 6,64,5292,1072352,385322400,211762028976,163677620352176,
%T A393765 168566053117057280,222690093537453283872,366839454924410928031360,
%U A393765 737047142820591826780788352,1774249919609139600797173509120,5042273999764573347948713660863744,16707837561420261525962058483694662400,63863968134053858316341183877764827956480
%N A393765 O.g.f. A(x) satisfies: [x^n] exp( n^2*(n+5)*x - n*A(x) ) = 0 for n >= 1.
%H A393765 Paul D. Hanna, <a href="/A393765/b393765.txt">Table of n, a(n) for n = 1..301</a>
%F A393765 a(n) ~ sqrt(1-w) * 3^(3*n + 2/3) * n^(2*n - 3/2) / (sqrt(2*Pi) * exp(2*n) * (3-w)^(2*n-1) * w^(n + 5/3)), where w = -A226750 = -LambertW(-3*exp(-3)). - _Vaclav Kotesovec_, Mar 02 2026
%e A393765 O.g.f.: A(x) = 6*x + 64*x^2 + 5292*x^3 + 1072352*x^4 + 385322400*x^5 + 211762028976*x^6 + 163677620352176*x^7 + 168566053117057280*x^8 + ...
%e A393765 ILLUSTRATION OF DEFINITION.
%e A393765 The table of coefficients of x^k/k! in exp( n^2*(n+5)*x - n*A(x) ) begin
%e A393765   n = 1: [1,   0,  -128,   -31752,  -25687296, ...];
%e A393765   n = 2: [1,  16,     0,   -71696,  -55668224, ...];
%e A393765   n = 3: [1,  54,  2532,        0,  -95557680, ...];
%e A393765   n = 4: [1, 120, 13888,  1416672,          0, ...];
%e A393765   n = 5: [1, 220, 47760, 10066840, 1889541760, 0, ...];
%e A393765   ...
%e A393765 in which a diagonal, the coefficient of x^n in row n, equals all zeros.
%e A393765 RELATED SERIES.
%e A393765 exp(A(x)) = 1 + 6*x + 164*x^2/2! + 34272*x^3/3! + 26576592*x^4/4! + 47064613536*x^5/5! + 154208308022976*x^6/6! + ...
%e A393765 where [x^n] exp(n^2*(n+5)*x) / exp(A(x))^n = 0 for n >= 1.
%o A393765 (PARI) {a(n,k=5) = my(A=[0], m); for(i=1, n+1, m=#A; A=concat(A, 0); A[m+1] = Vec( exp(m^2*(m+k)*x - m*Ser(A)) )[m+1]/m ); polcoef( Ser(A), n)}
%o A393765 for(n=1, 15, print1(a(n,5), ", "))
%Y A393765 Cf. A393760, A317347, A393761, A393762, A393763, A393764, A393766, A393767.
%K A393765 nonn
%O A393765 1,1
