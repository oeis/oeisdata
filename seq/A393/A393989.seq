%T A393989 0,1,1,2,0,0,3,0,1,2,1,2,1,1,1,1,1,1,3,1,2,3,0,1,3,1,1,3,2,3,2,2,2,3,
%U A393989 1,0,6,1,1,4,2,4,1,4,3,3,3,1,6,1,2,6,2,3
%N A393989 Expansion of g.f.: Product_{k>=1} (1 + x^(k*(k+5)/2)).
%C A393989 In general, if b > 0, b is odd and g.f. is Product_{k>=1} (1 + x^(k*(k+b)/2)), then a(n) ~ exp(3*Pi^(1/3) * ((sqrt(2)-1)*Zeta(3/2))^(2/3) * n^(1/3) / 2^(4/3)) * ((sqrt(2)-1)*Zeta(3/2))^(1/3) / (2^(b/2 + 7/6) * sqrt(3) * Pi^(1/3) * n^(5/6)).
%C A393989 a(n) is the number of partitions of n into distinct parts of the form k*(k+5)/2.
%H A393989 Vaclav Kotesovec, <a href="/A393989/b393989.txt">Table of n, a(n) for n = 0..10000</a>
%F A393989 a(n) ~ exp(3*Pi^(1/3) * ((sqrt(2)-1)*Zeta(3/2))^(2/3) * n^(1/3) / 2^(4/3)) * ((sqrt(2)-1)*Zeta(3/2))^(1/3) / (2^(11/3) * sqrt(3) * Pi^(1/3) * n^(5/6)).
%t A393989 nmax = 200; CoefficientList[Series[Product[1 + x^(k*(k+5)/2), {k, 1, Floor[Sqrt[25+8*nmax]/2]}], {x, 0, nmax}], x]
%Y A393989 Cf. A024940, A393987, A393988.
%K A393989 nonn,new
%O A393989 0,26
