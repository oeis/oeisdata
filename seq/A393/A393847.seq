%N A393847 O.g.f. A(x) satisfies: [x^n] exp( n^7 * x ) / A(x) = 0 for n>0.
%H A393847 Paul D. Hanna, <a href="/A393847/b393847.txt">Table of n, a(n) for n = 0..100</a>
%e A393847 O.g.f.: A(x) = 1 + x + 8065*x^2 + 1723380877*x^3 + 2972352315820441*x^4 + 24013530904194819396970*x^5 + 661513372249008158305805082187*x^6 + ...
%e A393847 ILLUSTRATION OF DEFINITION.
%e A393847 The table of coefficients of x^k/k! in exp(n^7*x)/A(x) begins
%e A393847   n = 1: [1,     0,     -16129,    -10340236874, ...];
%e A393847   n = 2: [1,   127,          0,    -10344333640, ...];
%e A393847   n = 3: [1,  2186,    4762467,               0, ...];
%e A393847   n = 4: [1, 16383,  268386560,   4386108292792, 0, ...];
%e A393847   n = 5: [1, 78124, 6103343247, 476804727467762, 37175837330786900381, 0, ...];
%e A393847   ...
%e A393847 in which a diagonal, the coefficient of x^n in row n, is all zeros.
%o A393847 (PARI) {a(n,k=7) = my(A=[1]); for(i=1, n, A=concat(A, 0); m=#A; A[m] = Vec( exp(x*(m-1)^k +x*O(x^m)) / Ser(A) )[m] ); A[n+1]}
%o A393847 for(n=0, 15, print1( a(n,7), ", "))
%Y A393847 Sequences below with the given parameter p have an o.g.f. F(x) satisfying [x^n] exp( n^p*x ) / F(x) = 0 for n >= 1.
%Y A393847 Cf. A304322 (p=2), A304323 (p=3), A304324 (p=4), A304325 (p=5).
%Y A393847 Cf. A393846 (p=6), A393848 (p=8), A393849 (p=9).
%K A393847 nonn
%O A393847 0,3
