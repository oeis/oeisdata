%U A393661 39129469389,123587135991,389357591445,1223861324751,3838949625501,12018945830247,37563128351973,117208257639615,365181390669933
%N A393661 A sequence appearing in the 3-Bratteli diagram, a(n)=3^(n-3)*(16*n-17), n>=3.
%C A393661 a(n) denotes the total number of descents of all paths starting from a vertex on the 2(n+1)-th floor in the 3-Bratteli diagram and ending at all vertices on the first floor.
%H A393661 Tamilselvi Annamalai, <a href="/A393661/b393661.txt">Table of n, a(n) for n = 1..100</a>
%H A393661 Wikipedia, <a href="https://en.wikipedia.org/wiki/Bratteli_diagram">Bratteli diagram</a>.
%H A393661 <a href="/index/Rec#order_02">Index entries for linear recurrences with constant coefficients</a>, signature (6,-9).
%F A393661 a(n) = 3^(n-3)*(16*n-17).
%F A393661 G.f: x^3*(31-45*x)/(1-3*x)^2.
%F A393661 E.g.f.: (34 + 6*x - 135*x^2 + exp(3*x)*(96*x - 34))/54. - _Stefano Spezia_, Feb 25 2026
%p A393661 a(n):= 3^(n - 3)*(16*n - 17);
%p A393661 num_list := [seq(eval(a(n), n = i), i = 3 .. 100)];
%t A393661 LinearRecurrence[{6, -9}, {31, 141}, 26] (* _Hugo Pfoertner_, Feb 24 2026 *)
