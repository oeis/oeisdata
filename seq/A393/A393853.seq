%U A393853 26201243804894888012465274226741248,22037908435373887477062906608302823424000,28578363358880431076573073973885461018380795904,54795450390474606316958220236698406535473510158958592
%N A393853 O.g.f. A(x) satisfies: [x^n] exp( n^5*x - n^3*A(x) ) = 0 for n >= 1.
%H A393853 Paul D. Hanna, <a href="/A393853/b393853.txt">Table of n, a(n) for n = 1..201</a>
%e A393853 O.g.f.: A(x) = x + 36*x^2 + 54432*x^3 + 484157952*x^4 + 14341070088000*x^5 + 1069388709947831808*x^6 + ...
%e A393853 ILLUSTRATION OF DEFINITION.
%e A393853 The table of coefficients of x^k/k! in exp( n^5*x - n^3*A(x) ) begins
%e A393853   n = 1: [1,    0,     -72,     -326592, ...];
%e A393853   n = 2: [1,   24,       0,    -2640384, ...];
%e A393853   n = 3: [1,  216,   44712,           0, ...];
%e A393853   n = 4: [1,  960,  916992,   850563072, 0, ...];
%e A393853   n = 5: [1, 3000, 8991000, 26878176000, 78571881144000, 0, ...]; ...
%e A393853 in which a diagonal, the coefficient of x^n in row n, is all zeros.
%e A393853 RELATED SERIES.
%e A393853 exp(A(x)) = 1 + x + 73*x^2/2! + 326809*x^3/3! + 11621113201*x^4/4! + 1720986748004881*x^5/5! + 769970210524619827321*x^6/6! + ...
%e A393853 where [x^n] exp(n^5*x) / exp(A(x))^(n^3) = 0 for n >= 1.
%o A393853 (PARI) {a(n,p=5,q=3) = my(A=[0], m); for(i=1, n+1, m=#A; A=concat(A, 0); A[m+1] = Vec( exp(m^p*x - m^q*Ser(A)) )[m+1]/(m^q) ); polcoef( Ser(A), n)}
%o A393853 for(n=1, 15, print1(a(n,5,3), ", "))
%Y A393853 Below, sequences with the parameters (p,q) indicated have an o.g.f. F(x) satisfying [x^n] exp( n^p*x - n^q*F(x) ) = 0 for n >= 1.
%Y A393853 Cf. A319944 (5,1), A393852 (5,2), A393854 (5,4).
%Y A393853 Cf. A319943 (4,3), A393863 (6,3), A393873 (7,3), A393883 (8,3).
