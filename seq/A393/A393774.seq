%N A393774 Expansion of 1/(1 - q^2 - q^3/(1 - q^4 - q^5/(1 - q^6 - q^7/(1 - q^8 - q^9/(1 - ... ))))), a continued fraction.
%H A393774 Vincenzo Librandi, <a href="/A393774/b393774.txt">Table of n, a(n) for n = 0..300</a>
%e A393774 G.f.: 1 + q^2 + q^3 + q^4 + 2*q^5 + 2*q^6 + 4*q^7 + 5*q^8 + 7*q^9 + 11*q^10 + ...
%t A393774 lista[nn_Integer?NonNegative]:=Module[{q,R},R=1;Do[R=1-q^(2 k+2)-q^(2 k+3)/R,{k,nn,0,-1}]; CoefficientList[Normal@Series[1/R,{q,0,nn}],q]]
%t A393774 lista[46] (* _Vincenzo Librandi_, Mar 02 2026 *)
%o A393774 (PARI)
%o A393774 lista(nn) = {
%o A393774   my(q='q+O('q^(nn+1)), R=1);
%o A393774   forstep(k=nn, 0, -1, R = 1 - q^(2*k+2) - q^(2*k+3)/R);
%o A393774   Vec(1/R, -nn-1);
%o A393774 };
%o A393774 (Magma) R<q> := PowerSeriesRing(Rationals(), 1000); lista := function(nn) Rser := R!1;for k in [nn..0 by -1] do Rser := 1 - q^(2*k+2) - q^(2*k+3)/Rser; end for; return Coefficients(1/Rser + O(q^(nn+1))); end function; v := lista(48); v; // _Vincenzo Librandi_, Mar 02 2026
