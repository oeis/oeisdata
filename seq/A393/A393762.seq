%S A393762 3,25,1692,289538,90173820,43882422792,30567719526512,
%T A393762 28785942694230992,35194116545752650480,54193646720531146409200,
%U A393762 102636316720344537986517376,234531656808960184131334782144,636449723900330778403724706336064,2023890035106228182972962107059653888,7456012944848541106071311366067334364160
%N A393762 O.g.f. A(x) satisfies: [x^n] exp( n^2*(n+2)*x - n*A(x) ) = 0 for n >= 1.
%H A393762 Paul D. Hanna, <a href="/A393762/b393762.txt">Table of n, a(n) for n = 1..301</a>
%F A393762 a(n) ~ sqrt(1-w) * 3^(3*n - 1/3) * n^(2*n - 3/2) / (sqrt(2*Pi) * exp(2*n) * (3-w)^(2*n-1) * w^(n + 2/3)), where w = -A226750 = -LambertW(-3*exp(-3)). - _Vaclav Kotesovec_, Mar 02 2026
%e A393762 O.g.f.: A(x) = 3*x + 25*x^2 + 1692*x^3 + 289538*x^4 + 90173820*x^5 + 43882422792*x^6 + 30567719526512*x^7 + 28785942694230992*x^8 + ...
%e A393762 ILLUSTRATION OF DEFINITION.
%e A393762 The table of coefficients of x^k/k! in exp( n^2*(n+2)*x - n*A(x) ) begin
%e A393762   n = 1: [1,   0,   -50,  -10152,  -6941412, ...];
%e A393762   n = 2: [1,  10,     0,  -22304, -14729984, ...];
%e A393762   n = 3: [1,  36,  1146,       0, -24651684, ...];
%e A393762   n = 4: [1,  84,  6856,  501696,         0, ...];
%e A393762   n = 5: [1, 160, 25350, 3925240, 549916540, 0, ...];
%e A393762   ...
%e A393762 in which a diagonal, the coefficient of x^n in row n, equals all zeros.
%e A393762 RELATED SERIES.
%e A393762 exp(A(x)) = 1 + 3*x + 59*x^2/2! + 10629*x^3/3! + 7081017*x^4/4! + 10931208003*x^5/5! + 31797400078659*x^6/6! + ...
%e A393762 where [x^n] exp(n^2*(n+2)*x) / exp(A(x))^n = 0 for n >= 1.
%o A393762 (PARI) {a(n,k=2) = my(A=[0], m); for(i=1, n+1, m=#A; A=concat(A, 0); A[m+1] = Vec( exp(m^2*(m+k)*x - m*Ser(A)) )[m+1]/m ); polcoef( Ser(A), n)}
%o A393762 for(n=1, 15, print1(a(n,2), ", "))
%Y A393762 Cf. A393760, A317347, A393761, A393763, A393764, A393765, A393766, A393767.
