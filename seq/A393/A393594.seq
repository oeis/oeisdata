%T A393594 1930,4288,4819,1764,196,1,0,15,3990,5835,8727,98724,155043,83355,
%U A393594 273825,372281,183904,164508,189360,99044,22428,1764,1,0,31,29633,58909,117079,2096755,4441117,3049235,13012776,21536368,13032432,18031054,24678532,15511076,9099889,8253323,5219505,1757169,287496,17424
%N A393594 Triangle read by rows: T(n, k) is the number of 4-dimensional balanced ballot paths of 4n steps and symmetric height exactly k.
%C A393594 For point x = (x_1,x_2,x_3,x_4) in the 4-dimensional lattice, we define the semisymmetric height of x as h_4'(x) := 3x_1 + x_2 - x_3 - 3x_4. The 4-dimensional balanced ballot path (multidimensional Dyck path) is a sequence of 4*n steps with initial point (0,0,0,0) and ending at (n,n,n,n) satisfying that each step is a standard unit vector and each point of the path satisfies x_1 >= x_2 >= x_3 >= x_4. T(n,k) is the number of 4-dimensional balanced ballot paths of 4*n steps such that the largest semisymmetric height reached by any point in the path is equal to k, i.e., for at least one intermediate point h_4'(x) = k, but for no intermediate points h_4'(x) > k. In this context, 1 <= k <= 4n.
%C A393594 It is important to note that, here, the semisymmetric height of a point in the 4-dimensional lattice is defined differently from the height defined in the comments of sequence A387987.
%e A393594 Triangle begins:
%e A393594   1;
%e A393594   1, 0, 1, 8, 4;
%e A393594   1, 0, 3, 69, 48, 30, 151, 135, 25;
%e A393594   1, 0, 7, 533, 553, 583, 4299, 5051, 1930, 4288, 4819, 1764, 196;
%e A393594   ...
%o A393594 (Python)
%o A393594 from functools import lru_cache
%o A393594 @lru_cache(None)
%o A393594 def ht(t):
%o A393594     return 3 * t[0] + t[1] - t[2] - 3*t[3]
%o A393594 def f(t, bd):
%o A393594     count = 0
%o A393594     if t == (0, 0, 0, 0):
%o A393594         return 1
%o A393594     if t[0] > 0 and t[0] - 1 >= t[1]:
%o A393594         count += f((t[0] - 1, t[1], t[2], t[3]), bd)
%o A393594     if t[1] > 0 and t[1] - 1 >= t[2] and ht((t[0], t[1] - 1, t[2], t[3])) <= bd:
%o A393594         count += f((t[0], t[1] - 1, t[2], t[3]), bd)
%o A393594     if t[2] > 0 and t[2] - 1 >= t[3] and ht((t[0], t[1], t[2] - 1, t[3])) <= bd:
%o A393594         count += f((t[0], t[1], t[2] - 1, t[3]), bd)
%o A393594     if t[3] > 0 and ht((t[0], t[1], t[2], t[3] - 1)) <= bd:
%o A393594         count += f((t[0], t[1], t[2], t[3] -1), bd)
%o A393594     return count
%o A393594 for n in range(1, 7):
%o A393594     a = 0
%o A393594     b = 0
%o A393594     for k in range(4, 4*n+1):
%o A393594         if k == 4:
%o A393594             a = f((n, n, n, n), k)
%o A393594             print(a)
%o A393594         if k > 4:
%o A393594             b = f((n, n, n, n), k)
%o A393594             print(b-a)
%o A393594             a = b
