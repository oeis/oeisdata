%S A393441 1,1,7,34,109,271,571,1072,1849,2989,4591,6766,9637,13339,18019,23836,
%T A393441 30961,39577,49879,62074,76381,93031,112267,134344,159529,188101,
%U A393441 220351,256582,297109,342259,392371,447796,508897,576049,649639,730066,817741,913087,1016539,1128544,1249561,1380061,1520527,1671454,1833349,2006731,2192131,2390092
%N A393441 a(n) = (n^4-n^3+2*n^2-2*n+2)/2.
%C A393441 a(n) is the maximum number of regions that can be formed in the plane by drawing n n-armed V's. This is the main diagonal of A386481.
%D A393441 David O. H. Cutler, Jonas Karlsson, and Neil J. A. Sloane, Cutting a Pancake with an Exotic Knife, In preparation, March 25 2026.
%H A393441 N. J. A. Sloane, <a href="/A393441/a393441.jpg">Illustration for a(3) = 34.</a>
%H A393441 N. J. A. Sloane, <a href="/A393441/a393441_1.jpg">Illustration for a(4) = 109.</a>
%H A393441 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (5,-10,10,-5,1).
%F A393441 From _Enrique Navarrete_, Mar 26 2026: (Start)
%F A393441 G.f.: (4*x^4 - x^3 + 12*x^2 - 4*x + 1)/(1 - x)^5.
%F A393441 a(n) = 5*a(n-1) - 10*a(n-2) + 10*a(n-3) - 5*a(n-4) + a(n-5).
%F A393441 E.g.f.: (1/2)*(x^4 + 5*x^3 + 6*x^2 + 2)*exp(x).
%F A393441 a(n) = A092365(n) - (n-1), n > 0. (End)
%t A393441 a[n_]:=(n^4-n^3+2*n^2-2*n+2)/2;Array[a,48,0] (* or *)
%t A393441 LinearRecurrence[{5,-10,10,-5,1},{1, 1, 7, 34, 109, 271},48] (* or *)
%t A393441 CoefficientList[Series[(-1+4x-12x^2+x^3-4x^4)/(-1+x)^5,{x,0,47}],x] (* _James C. McMahon_, Mar 25 2026 *)
