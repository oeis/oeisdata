%S A393615 1,2,6,38,77,154,274,422,620,856,1158,1535,1984,2471,3122,3775,4580,
%T A393615 5442,6406,7558,8752,10111,11573,13231,14971,16859,18934,21179,23525,
%U A393615 26155,28859,31802,34892,38223,41758,45554,49480,53594,58003,62703,67529,72658,78039
%N A393615 a(n) is the largest integer m such that every integer from 1 to m can be represented as a sum of at most n squares from the set {1^2, 2^2, 3^2, ..., n^2}.
%F A393615 a(n) > a(n-1) for n >= 2.
%F A393615 a(n) <= n^3 - 2*n + 1 for n >= 2.
%F A393615 n^3 - a(n) ~ C*n^(3/2) with C approximately 5.3 (conjectured, based on empirical data up to n = 100).
%e A393615 a(3) = 6 because using squares {1, 4, 9} with at most 3 addends, every integer from 1 to 6 is reachable (e.g., 6 = 1+1+4), but 7 cannot be represented (7 = 4+1+1+1 requires 4 addends).
%o A393615 (Python)
%o A393615 def a(n):
%o A393615     squares = [k*k for k in range(1, n+1)]
%o A393615     dp = [n+1] * (n**3 + 2)
%o A393615     dp[0] = 0
%o A393615     for s in squares:
%o A393615         for v in range(s, n**3 + 2):
%o A393615             if dp[v-s] + 1 < dp[v]:
%o A393615                 dp[v] = dp[v-s] + 1
%o A393615     result = 0
%o A393615     for v in range(1, n**3 + 2):
%o A393615         if dp[v] <= n: result = v
%o A393615         else: break
%o A393615     return result
%Y A393615 Cf. A000290.
%K A393615 nonn,new
%O A393615 1,2
