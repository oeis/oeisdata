%N A393411 Expansion of e.g.f. (1/x) * Series_Reversion( x/(1 + 3*x)^(2/3) ).
%H A393411 Vincenzo Librandi, <a href="/A393411/b393411.txt">Table of n, a(n) for n = 0..300</a>
%F A393411 E.g.f. A(x) satisfies A(x) = (1 + 3*x*A(x))^(2/3).
%F A393411 a(n) = 3^n * n! * binomial(2*(n+1)/3,n)/(n+1).
%F A393411 a(3*n+2) = 0 for n > 0.
%t A393411 a[n_]:=3^n*n!*Binomial[2*( n+1)/3,n]/(n+1); Table[a[n],{n,0,25}] (* _Vincenzo Librandi_, Apr 01 2026 *)
%o A393411 (PARI) a(n) = 3^n*n!*binomial(2*(n+1)/3, n)/(n+1);
%o A393411 (Magma) [1] cat [3^n*Factorial(n)*&*[(2*(n+1)/3-k): k in [0..n-1]]/Factorial(n)/(n+1): n in [1..25] ]; // _Vincenzo Librandi_, Apr 01 2026
