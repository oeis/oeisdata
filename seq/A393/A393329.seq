%I A393329 #61 May 27 2026 00:06:05
%S A393329 0,0,1,14,145,1330,11420,94066,752979,5902890,45544035,347016740,
%T A393329 2617376056,19577124644,145406256485,1073550481990,7885450036085,
%U A393329 57661336389846,419985058108884,3048385407665430,22057531003184695,159159907730783330,1145562037717754311,8226470282415530824
%N A393329 Self-convolution of the sequence b(n) = A004187(n) = F(4*n)/3, where F(n) are Fibonacci numbers.
%C A393329 Part of a family of self-convolutions of Fibonacci-related sequences F(k*n)/F(k).
%C A393329 Related to A395431, which is the self-convolution of F(3*n)/F(3).
%H A393329 D. Dmytryshyn, D. Gray, V. Khamitov, and Alex Stokolos, <a href="https://arxiv.org/abs/2603.08636">Convolved numbers of k-section of the Fibonacci sequence: properties, consequences</a>, arXiv:2603.08636 [math.CA], 2026; see also <a href="https://doi.org/10.15276/hait.09.2026.09">alternate link</a>, Herald of Advanced Information Technology. 2026. Vol. 9, No. 2. P. 129-139.
%H A393329 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (14,-51,14,-1).
%F A393329 a(n) = 14*a(n-1) - 51*a(n-2) + 14*a(n-3) - a(n-4) for n >= 4.
%F A393329 a(n) = (7*(n-1)*a(n-1) - n*a(n-2)) / (n-2) for n >= 3, a(0)=a(1)=0, a(2)=1.
%F A393329 a(n) = Sum_{j=1..n} b(j)*b(n-j), where b(j) = F(4*j)/3.
%F A393329 a(n) = GegenbauerC(n-2, 2, 7/2) for n >= 2.
%F A393329 a(n) = (q^(-4*(n+1)) / (q^4 - q^(-4))^3) * ((n-1)*(q^(8*(n+1)) - 1) - (n+1)*(q^(8*n) - q^8)), where q = (1+sqrt(5))/2.
%F A393329 a(n) = ((n-1)*F(4*n+4) - (n+1)*F(4*n-4)) / 135.
%F A393329 G.f.: x^2 / (1 - 7*x + x^2)^2.
%F A393329 E.g.f.: exp(7*x/2) * ( (7*x/45)*cosh(3*sqrt(5)*x/2) + (sqrt(5)*x/15 - 14*sqrt(5)/675)*sinh(3*sqrt(5)*x/2) ).
%p A393329 N := 15: a[0] := 0: a[1] := 0: a[2] := 1: a[3] := 14:
%p A393329 for j from 4 to N do
%p A393329 a[j] := 14*a[j - 1] - 51*a[j - 2] + 14*a[j - 3] - a[j - 4]:
%p A393329 end do:
%p A393329 seq(a[k], k = 0 .. N);
%t A393329 LinearRecurrence[{14, -51, 14, -1}, {0, 0, 1, 14}, 24] (* _Amiram Eldar_, May 17 2026 *)
%Y A393329 Cf. A000045, A004187, A395431.
%K A393329 nonn,easy,new
%O A393329 0,4
%A A393329 _Alex Stokolos_, May 16 2026
