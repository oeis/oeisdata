%N A393882 O.g.f. A(x) satisfies: [x^n] exp( n^8*x - n^2*A(x) ) = 0 for n >= 1.
%H A393882 Paul D. Hanna, <a href="/A393882/b393882.txt">Table of n, a(n) for n = 1..201</a>
%e A393882 O.g.f.: A(x) = x + 7938*x^2 + 5156672976*x^3 + 47636597594329632*x^4 + 3011599934331942158478000*x^5 + 860970137920054220201157626980032*x^6 + ...
%e A393882 ILLUSTRATION OF DEFINITION.
%e A393882 The table of coefficients of x^k/k! in exp( n^8*x - n^2*A(x) ) begins
%e A393882   n = 1: [1,      0,       -15876,      -30940037856, ...];
%e A393882   n = 2: [1,    252,            0,     -123792157440, ...];
%e A393882   n = 3: [1,   6552,     42785820,                 0, ...];
%e A393882   n = 4: [1,  65520,   4292616384,   280723898617344, 0, ...];
%e A393882   n = 5: [1, 390600, 152567963100, 59591962827633600, 23246950670834431690800, 0, ...]; ...
%e A393882 in which a diagonal, the coefficient of x^n in row n, is all zeros.
%e A393882 RELATED SERIES.
%e A393882 exp(A(x)) = 1 + x + 15877*x^2/2! + 30940085485*x^3/3! + 1143278466780299977*x^4/4! + 361391997841137123928182361*x^5/5! + 619898501471072841606391909590124621*x^6/6! + ...
%e A393882 where [x^n] exp(n^8*x) / exp(A(x))^(n^2) = 0 for n >= 1.
%o A393882 (PARI) {a(n,p=8,q=2) = my(A=[0], m); for(i=1, n+1, m=#A; A=concat(A, 0); A[m+1] = Vec( exp(m^p*x - m^q*Ser(A)) )[m+1]/(m^q) ); polcoef( Ser(A), n)}
%o A393882 for(n=1, 15, print1(a(n,8,2), ", "))
%Y A393882 Below, sequences with the parameters (p,q) indicated have an o.g.f. F(x) satisfying [x^n] exp( n^p*x - n^q*F(x) ) = 0 for n >= 1.
