%t A393167 fQ[x_] := Or[x == 1, Times @@ MapIndexed[Prime[First[#2]]^#1 &, ReverseSort[FactorInteger[x][[All, -1]] ] ] == x]; rad[x_] := rad[x] = Times @@ FactorInteger[x][[All, 1]]; Map[(r = rad[#]; Count[Range[#], _?(rad[#] == r &)]) &, Select[Range[2^13], fQ] ]
%t A393167 (* Alternative: load function f from A025487 and theta from the Mathematica link in A369609, then: *)
%t A393167 Map[theta[-#] &, Union@ Flatten@ f[6]]
