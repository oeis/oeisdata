%N A393799 The least prime p of three consecutive primes p,q,r such that q - p = 2n + 2 and r - q = 2n.
%C A393799 The sequence is not monotonic.
%C A393799 These primes are not balanced (A006562). But that does not preclude A096693(a(n)) from not being 0. Case in point is A096693(a(3)) = 1.
%e A393799 a(1) = 7 since 7, 11, 13 have differences of 4 and 2;
%e A393799 a(2) = 31 since 31, 37, 41 have differences of 6 and 4;
%e A393799 a(3) = 359 since 359, 367, 373 have differences of 8 and 6;
%t A393799 p = 2; q = 3; r = 5; t[_] := 0; While[p < 53000000, If[r + p + 2 == 2 q && t[(r - q)/2] == 0, t[(r - q)/2] = p]; {p, q, r} = {q, r, NextPrime[r]}]; t /@ Range@36
%o A393799 (PARI) upto(lim)={my(L=List([0]), d=0, q=5); forprime(p=7, lim, if(p-q==2*d, while(#L<=d, listput(L,0)); if(!L[d], L[d]=q-2-2*d)); d=(p-q)/2-1; q=p); my(k=1); while(L[k], k++); Vec(L[1..k-1])} \\ _Andrew Howroyd_, Feb 27 2026
%o A393799 (Python)
%o A393799 from gmpy2 import next_prime
%o A393799 from itertools import islice
%o A393799 def agen(): # generator of terms
%o A393799     adict, n = {None: None}, 1
%o A393799     p, q, r = 2, 3, 5
%o A393799     while True:
%o A393799         p, q, r = q, r, next_prime(r)
%o A393799         v = (r-q)//2 if q-p == r-q + 2 else None
%o A393799         if v not in adict:
%o A393799             adict[v] = int(p)
%o A393799             while n in adict: yield adict[n]; n += 1
%o A393799 print(list(islice(agen(), 34))) # _Michael S. Branicky_, Feb 28 2026
%Y A393799 Cf. A006562, A075540, A096693, A282707, A283145.
