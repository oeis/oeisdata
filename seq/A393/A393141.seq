%N A393141 a(n) = numerator(hypergeom([1, -n], [], -1/(n + 1))).
%F A393141 a(n) = numerator(Gamma(n+1, n+1) * exp(n + 1) / (n + 1)^n).
%F A393141 a(n) = numerator(Sum_{k=0..n} n! / ((n - k)! * (n + 1)^k)).
%F A393141 a(n) = numerator(Sum_{k=0..n} FallingFactorial(n, k) / (n + 1)^k ).
%p A393141 P := n -> hypergeom([1, -n], [], -1/(n + 1)):
%p A393141 seq(numer(simplify(P(n))), n = 0..19);
%o A393141 (Python)
%o A393141 from math import gcd
%o A393141 def A393141(n: int) -> int:
%o A393141     t_num, t_den = 1, 1   # term
%o A393141     s_num, s_den = 0, 1   # sum
%o A393141     for k in range(n + 1):
%o A393141         if k > 0:
%o A393141             t_num *= (n - k + 1)
%o A393141             t_den *= (n + 1)
%o A393141             g = gcd(t_num, t_den)
%o A393141             t_num //= g
%o A393141             t_den //= g
%o A393141         num = s_num * t_den + t_num * s_den
%o A393141         den = s_den * t_den
%o A393141         g = gcd(num, den)
%o A393141         s_num, s_den = num // g, den // g
%o A393141     return s_num
%o A393141 L = [A393141(n) for n in range(20)]; print(L)
%o A393141 (SageMath)
%o A393141 def a(n: int) -> int:
%o A393141     s = sum(falling_factorial(n, k) / (n + 1) ** k for k in range(n + 1))
%o A393141     return s.numerator()
%o A393141 print([a(n) for n in range(20)])
