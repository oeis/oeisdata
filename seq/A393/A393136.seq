%N A393136 G.f. A(x) satisfies A(x) = 1 - E(log(1 - x*(1 + E(A(x))))), where E is the Euler operator x*d/dx.
%F A393136 G.f. A(x) satisfies A(x) = 1 + x*A(x)*(1 + E(A(x))) + x*E^2(A(x)).
%F A393136 G.f.: 1 - E(log(1 - x*B(x))), where B(x) is the g.f. of A393959.
%F A393136 a(0) = 1; a(n) = ((n-1)^2+1) * a(n-1) + Sum_{k=1..n-1} k * a(k) * a(n-1-k).
%o A393136 (PARI) E(f) = x*deriv(f);
%o A393136 my(A=1, N=20); for(k=1, N, A=1+x*A*(1+E(A))+x*E(E(A))+x*O(x^N)); Vec(A)
%Y A393136 Cf. A003319, A111537, A262002, A393475, A393775.
%Y A393136 Cf. A393959.
