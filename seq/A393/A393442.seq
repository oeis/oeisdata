%t A393442 A393442[n_, k_] := n*(n-1) + If[k == 0 && n >= 1, 2, 1 + k + 2*n*k + k*(k-1)/2];
%t A393442 Table[A393442[k, n - k], {n, 0, 15}, {k, 0, n}] (* _Paolo Xausa_, Mar 30 2026 *)
%Y A393442 Row 0 is A000124, row 1 is essentially A034856; column 0 is both A014206 and A386480, columns 1 and 2 are (apart from their initial values) the same as column 0, and column 3 is essentially A002061.
