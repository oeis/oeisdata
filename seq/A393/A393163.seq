%S A393163 1,96,132,236,244,2943,5715,3808525,6314350,14977850,401024775,
%T A393163 921730375,7302585325,11116233425
%N A393163 Numbers k such that sigma(k) = psi(k) + pi(k) + Omega(k)^2.
%e A393163 96 is a term since sigma(96) = 252 = 192 + 24 + 6^2 = psi(96) + pi(96) + Omega(96)^2.
%o A393163 (PARI) dedpsi(f) = prod(k = 1, #f~, (f[k, 1]+1) * f[k, 1]^(f[k, 2]-1));
%o A393163 list(lim) = {my(q = 2, m = 0, f); print1(1, ", "); forprime(p = 3, lim, m++; for(k = q, p-1, f = factor(k); if(sigma(f) == dedpsi(f) + m + bigomega(f)^2, print1(k, ", "))); q = p); } \\ _Amiram Eldar_, Mar 05 2026
