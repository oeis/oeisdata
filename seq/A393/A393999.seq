%I A393999 #8 Mar 15 2026 14:57:39
%S A393999 72,108,200,288,392,432,500,648,675,800,864,968,972,1125,1152,1323,
%T A393999 1352,1372,1568,1944,2000,2312,2592,2888,3087,3200,3267,3456,3872,
%U A393999 3888,4000,4232,4563,4608,5000,5324,5408,5488,6075,6125,6272,6728,6912,7688,7803,8575
%N A393999 Achilles numbers whose prime power factor exponents are pairwise coprime.
%C A393999 Proper subset of Achilles numbers A052486.
%C A393999 Superset of A393816 (Achilles numbers with exactly 2 distinct prime factors); a(78) = 21600 = 2^5 * 3^3 * 5^2.
%C A393999 For n > 1, A087315(n) = Product_{i=1..n} prime(i)^prime(n-1+1) is the smallest number in this sequence with n distinct prime factors.
%H A393999 Michael De Vlieger, <a href="/A393999/b393999.txt">Table of n, a(n) for n = 1..10000</a>
%H A393999 <a href="/index/Pow#powerful">Index entries for sequences related to powerful numbers</a>.
%F A393999 {a(n)} = A052486 \ A394000.
%e A393999 Let s = A052486 and let t = A087315.
%e A393999 Table of n, a(n) for select n:
%e A393999    n                     a(n)
%e A393999 -----------------------------------------------------------
%e A393999    1       s(1) =        72 = 2^3 * 3^2              = t(2)
%e A393999   14      s(14) =      1125 = 3^2 * 5^3
%e A393999   20      s(21) =      1944 = 2^3 * 3^5
%e A393999   46      s(53) =      8575 = 5^2 * 7^3
%e A393999   78     s(100) =     21600 = 2^5 * 3^3 *  5^2       = t(3)
%e A393999  102     s(137) =     36000 = 2^5 * 3^2 *  5^3
%e A393999  110     s(151) =     42336 = 2^5 * 3^3 *  7^2
%e A393999  119     s(165) =     48600 = 2^3 * 3^5 *  5^2
%e A393999  169     s(251) =     98784 = 2^5 * 3^2 *  7^3
%e A393999  174     s(258) =    104544 = 2^5 * 3^3 * 11^2
%e A393999  293     s(490) =    324000 = 2^5 * 3^4 *  5^3
%e A393999 4631   s(14728) = 190512000 = 2^7 * 3^5 *  5^3 * 7^2 = t(4)
%t A393999 nn = 10^4; fQ[x_] := CoprimeQ @@ FactorInteger[x][[All, -1]]; Rest@ Union@ Flatten@ Table[If[fQ[#], #, Nothing] &[a^2*b^3], {b, Surd[nn, 3]}, {a, Sqrt[nn/b^3] } ]
%Y A393999 Cf. A001694, A052486, A087315, A126706, A286708, A393816, A394000.
%K A393999 nonn,easy
%O A393999 1,1
%A A393999 _Michael De Vlieger_, Mar 06 2026
