%U A393352 33558539,67109392,134226093,268435456,536888491,1073741824,2147516705,4294969372,8590000143,17179869526
%N A393352 Number of circular parking functions of length n avoiding the patterns 123 and 132.
%H A393352 Michael De Vlieger, <a href="/A393352/b393352.txt">Table of n, a(n) for n = 0..3322</a>
%H A393352 Lara Pudwell, <a href="https://faculty.valpo.edu/lpudwell/slides/AMS2025.pdf">Pattern avoidance in cyclic parking functions</a>, 2025.
%H A393352 Lara Pudwell, <a href="https://faculty.valpo.edu/lpudwell/papers/circpf.pdf">Pattern Avoidance in Circular Parking Functions</a>, Valparaiso Univ. (2026). See pp. 11 (Table 3), 13 (Theorem 16).
%F A393352 a(n) = (Sum_{i=1..n} 2^gcd(i, n))/2 - (n-1).
%e A393352 For n=4, the a(4)=9 parking functions are 1111, 1112, 1113, 1114, 1122, 1133, 1212, 1222, 1313.
%p A393352 a := n -> 1/2*add(2^igcd(i, n), i = 1 .. n) + 1 - n:
%p A393352 seq(a(n), n = 1 .. 35);
%t A393352 Table[Sum[2^GCD[i, n], {i, n}]/2 - (n - 1), {n, 0, 35}] (* _Michael De Vlieger_, Mar 13 2026 *)
