%N A393438 Let x = smallest even number missing from A390314 after A390314(n) has been found; a(n) = x/2.
%C A393438 It is conjectured that every even number will appear in A390314.
%H A393438 Michael De Vlieger, <a href="/A393438/b393438.txt">Table of n, a(n) for n = 1..10000</a>
%t A393438 Block[{c, k, s, p, v, nn}, nn = 75; c[_] := False; k = s = p = 1; c[1] = True; v = 2; Reap[Do[k = 1; While[Or[c[k], ! CoprimeQ[s + k, p*k]], k++]; c[k] = True; Sow[v/2]; s += k; p *= k; If[k == v, While[c[v], v += 2]], {n, 2, nn}] ][[-1, 1]] ] (* _Michael De Vlieger_, Mar 10 2026 *)
