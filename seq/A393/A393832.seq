%S A393832 0,112,121,123,132,134,143,145,154,156,165,167,176,178,187,189,198,
%T A393832 211,213,224,231,235,242,246,253,257,264,268,275,279,286,297,312,314,
%U A393832 321,325,336,341,347,352,358,363,369,374,385,396,413,415,422,426,431,437,448,451,459,462,473,484,495
%N A393832 Nonnegative integers that have only one largest digit m and the sum of the digits equal to 2*m.
%C A393832 The sequence is infinite because, apart from the initial zero term, for every term k it contains all the terms of the form k*10^h, where h is a positive integer.
%H A393832 Stefano Spezia, <a href="/A393832/b393832.txt">Table of n, a(n) for n = 1..10000</a>
%e A393832 286 is a term, since it has only one largest digit, 8, and 2 + 8 + 6 = 16 = 2*8.
%t A393832 Select[Range[0,500],Count[digits=IntegerDigits[#],mx=Max[digits]]==1 && DigitSum[#]==2*mx &]
%o A393832 (PARI) isok(k) = if (k==0, 1, my(d=digits(k), m=vecmax(d)); (#select(x->(x==m), d) == 1) && (vecsum(d)==2*m)); \\ _Michel Marcus_, Mar 05 2026
%Y A393832 Cf. A005843, A007953, A393841.
%K A393832 nonn,base,easy,new
%O A393832 1,2
