%N A393709 a(n) = least positive integer k such that (prime(n) + 3^k)/2 is prime, or -1 if no such prime exists.
%C A393709 a(204) > 129000 if it is not -1. - _Robert Israel_, Mar 02 2026
%H A393709 Robert Israel, <a href="/A393709/b393709.txt">Table of n, a(n) for n = 1..203</a>
%F A393709 If A039739(k)=3 then a(k)=1. - _Michel Marcus_, Mar 02 2026
%e A393709 (5 + 3^1)/2 = 4 = 9; (5 + 3^2)/2 = 7 (prime), so a(3) = 2.
%p A393709 f:= proc(n) local p, k;
%p A393709  p:= ithprime(n);
%p A393709  for k from 1 do if isprime((p+3^k)/2) then return k fi od:
%p A393709 end proc:
%p A393709 f(1):= -1:
%p A393709 map(f, [$1..203]); # _Robert Israel_, Mar 02 2026
%t A393709 f[n_] := Select[Range[100], PrimeQ[(Prime[n] + 3^#)/2] &, 1];
%t A393709 Join[{-1}, Flatten[Table[f[n], {n, 1, 120}]]]
%o A393709 (PARI) a(n) = if (n==1, -1, my(k=1,p=2); while (!ispseudoprime((prime(n) + 3^k)/2), k++); k); \\ _Michel Marcus_, Mar 02 2026
