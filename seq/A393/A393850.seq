%I A393850 #12 Apr 06 2026 05:42:54
%S A393850 1,1,5,62,1351,44054,1979334,116691252,8734012347,809689343462,
%T A393850 91150835442826,12257117475709820,1941425828513423990,
%U A393850 357868464911110222588,75971345302361770145036,18404389046663859881387688,5046988498282963188879094611,1555510528876163427021255631686,535387608728846127315766936404642
%N A393850 G.f. A(x) satisfies: [x^n] A(x)^(n+1) = n*(n+1) * [x^(n-1)] A(x)^(n+1) for n >= 1 with A'(0) = 1.
%C A393850 Conjecture: a(n) is odd iff n is a power of 2.
%H A393850 Paul D. Hanna, <a href="/A393850/b393850.txt">Table of n, a(n) for n = 0..512</a>
%F A393850 G.f. A(x) = Sum_{n>=0} a(n)*x^n satisfies the following formulas.
%F A393850 (1) [x^n] A(x)^(n+1) * (1 - n*(n+1)*x) = 0 for n >= 1 (by definition).
%F A393850 (2) A(x) = 1 + x*A(x)^2 * ( A(x)^2 + x*A(x)*A'(x) - 2*x^2*A'(x)^2 + x^2*A(x)*A''(x) ) / (A(x) - x*A'(x))^3.
%F A393850 (3) A(x) = x/Series_Reversion(G(x)) where G(x) = x + x^2 * d^2/dx^2 G(x)^2/2 is the g.f. of A393851, so that G(x) = x*A(G(x)).
%F A393850 a(n) ~ c * n^(2*n+2) / exp(2*n), where c = 4.8172872967346422952549021571815013036382547844... - _Vaclav Kotesovec_, Apr 06 2026
%e A393850 G.f.: A(x) = 1 + x + 5*x^2 + 62*x^3 + 1351*x^4 + 44054*x^5 + 1979334*x^6 + 116691252*x^7 + 8734012347*x^8 + 809689343462*x^9 + 91150835442826*x^10 + ...
%e A393850 RELATED SEQUENCES.
%e A393850 The table of coefficients of x^k in A(x)^n starts as
%e A393850   n = 1: [1, 1,  5,  62,  1351,  44054,  1979334, ...];
%e A393850   n = 2: [1, 2, 11, 134,  2851,  91430,  4064130, ...];
%e A393850   n = 3: [1, 3, 18, 217,  4515, 142389,  6260426, ...];
%e A393850   n = 4: [1, 4, 26, 312,  6359, 197212,  8574658, ...];
%e A393850   n = 5: [1, 5, 35, 420,  8400, 256201, 11013685, ...];
%e A393850   n = 6: [1, 6, 45, 542, 10656, 319680, 13584815, ...];
%e A393850   n = 7: [1, 7, 56, 679, 13146, 387996, 16295832, ...]; ...
%e A393850 In the above table, the main diagonal begins
%e A393850 [1, 2, 18, 312, 8400, 319680, 16295832, 1072681344, ...]
%e A393850 Notice that the n-th term of the secondary diagonal
%e A393850 [1, 3, 26, 420, 10656, 387996, ..., A393851(n+1)/n, ...]
%e A393850 multiplied by n*(n+1) yields the main diagonal after the initial term.
%e A393850 Also, the n-th term of the main diagonal divided by n yields
%e A393850 [1, 1, 6, 78, 1680, 53280, 2327976, ..., A393851(n), ...].
%e A393850 RELATED SERIES.
%e A393850 Series G(x) = x + x^2 * d^2/dx^2 G(x)^2/2 is the g.f. of A393851, which begins
%e A393850 G(x) = x + x^2 + 6*x^3 + 78*x^4 + 1680*x^5 + 53280*x^6 + 2327976*x^7 + 134085168*x^8 + ... + A393851(n)*x^n + ...
%e A393850 where G(x) = x*A(G(x)).
%e A393850 Other properties of G(x) include
%e A393850 (i) G(x/A(x)) = x,
%e A393850 (ii) G'(x/A(x)) = A(x)^2/(A(x) - x*A'(x)),
%e A393850 (iii) G''(x/A(x)) = A(x)^3 * (2*A(x)*A'(x) - 2*x*A'(x)^2 + x*A(x)*A''(x)) / (A(x) - x*A'(x))^3,
%e A393850 (iv) G(x) = x + x^2*G'(x)^2 + x^2*G(x)*G''(x).
%e A393850 If we substitute x/A(x) for x in (iv) then simplify by using (i)-(iii), we obtain the formula A(x) = 1 + x*A(x)^2 * ( A(x)^2 + x*A(x)*A'(x) - 2*x^2*A'(x)^2 + x^2*A(x)*A''(x) ) / (A(x) - x*A'(x))^3.
%o A393850 (PARI) \\ By definition
%o A393850 N=25; A=[1]; for(n=2, N, A=concat(A, 0); V=Vec(Ser(A)^n); A[#A] = V[#A-1]*(n-1) - V[#A]/n ); A
%o A393850 (PARI) \\ A(x) = x/Series_Reversion(G), G = x + x^2*d^2/dx^2 G^2/2
%o A393850 {a(n) = my(G=x+x^2, A=x); for(i=0, n, G = x + x^2*deriv(deriv(G^2/2 +x^2*O(x^n)))); A = x/serreverse(G); polcoef(GF=A, n)}
%o A393850 {upto(n) = a(n); Vec(GF)}
%o A393850 upto(25)
%Y A393850 Cf. A393851, A323693.
%K A393850 nonn,new
%O A393850 0,3
