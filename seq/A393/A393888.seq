%S A393888 1,1,2,12,116,1488,23320,427168,8903096,207404528,5332584624,
%T A393888 149891066560,4571808534832,150391362350944,5308182730319872,
%U A393888 200137985502837504,8029381213697817040,341585584249232541760,15361457031184673748480,728218200757741770027648,36297744440787064648161024
%N A393888 G.f. satisfies 3*A(x) = 1 + x + 2*A(x*A(x)).
%H A393888 Paul D. Hanna, <a href="/A393888/b393888.txt">Table of n, a(n) for n = 0..300</a>
%F A393888 G.f. A(x) = Sum_{n>=0} a(n)*x^n satisfies the following formulas.
%F A393888 (1) 3*A(x) = 1 + x + 2*A(x*A(x)).
%F A393888 (2) A(x) = 1 + Sum_{n>=0} 2^n * B^n(x) / 3^(n+1), where B(x) = x*A(x) and B^n(x) denotes the n-th iteration of B(x) with B^0(x) = x.
%F A393888 (3) 2*A(x) = 3*F(x) - x/F(x) - 1, where F(x) = A(x/F(x)) = x/Series_Reversion(x*A(x)).
%e A393888 G.f.: A(x) = 1 + x + 2*x^2 + 12*x^3 + 116*x^4 + 1488*x^5 + 23320*x^6 + 427168*x^7 + 8903096*x^8 + 207404528*x^9 + 5332584624*x^10 + ...
%e A393888 RELATED SERIES.
%e A393888 A(x*A(x)) = 1 + x + 3*x^2 + 18*x^3 + 174*x^4 + 2232*x^5 + 34980*x^6 + 640752*x^7 + 13354644*x^8 + 311106792*x^9 + 7998876936*x^10 + ...
%e A393888 where A(x) = (1 + x)/3 + (2/3)*A(x*A(x)).
%e A393888 If F(x) = A(x/F(x)), then
%e A393888 F(x) = 1 + x + x^2 + 8*x^3 + 75*x^4 + 972*x^5 + 15270*x^6 + 280328*x^7 + 5852107*x^8 + 136506148*x^9 + ...
%e A393888 where 2*A(x) = 3*F(x) - x/F(x) - 1.
%e A393888 RELATED TABLE.
%e A393888 The table of coefficients in the n-th iteration of x*A(x) begins
%e A393888   n = 0: [1, 0,  0,   0,    0,      0,       0, ...];
%e A393888   n = 1: [1, 1,  2,  12,  116,   1488,   23320, ...];
%e A393888   n = 2: [1, 2,  6,  35,  326,   4082,   62932, ...];
%e A393888   n = 3: [1, 3, 12,  75,  692,   8504,  129064, ...];
%e A393888   n = 4: [1, 4, 20, 138, 1300,  15870,  237972, ...];
%e A393888   n = 5: [1, 5, 30, 230, 2260,  27810,  414784, ...];
%e A393888   n = 6: [1, 6, 42, 357, 3706,  46588,  697064, ...];
%e A393888   n = 7: [1, 7, 56, 525, 5796,  75222, 1139096, ...];
%e A393888   ...
%e A393888 in which the following sum along column k equals a(k)
%e A393888 a(1) = 1 = 1/3 + 1*2/3^2 + 1*2^2/3^3 + 1*2^3/3^4 + 1*2^4/3^5 + ...
%e A393888 a(2) = 2 = 0/3 + 1*2/3^2 + 2*2^2/3^3 + 3*2^3/3^4 + 4*2^4/3^5 + ...
%e A393888 a(3) = 12 = 0/3 + 2*2/3^2 + 6*2^2/3^3 + 12*2^3/3^4 + 20*2^4/3^5 + ...
%e A393888 a(4) = 116 = 0/3 + 12*2/3^2 + 35*2^2/3^3 + 75*2^3/3^4 + 138*2^4/3^5 + ...
%e A393888 a(5) = 1488 = 0/3 + 116*2/3^2 + 326*2^2/3^3 + 692*2^3/3^4 + 1300*2^4/3^5 + ...
%e A393888 a(6) = 23320 = 0/3 + 1488*2/3^2 + 4082*2^2/3^3 + 8504*2^3/3^4 + 27810*2^5/3^6 + ...
%e A393888 a(7) = 427168 = 0/3 + 23320*2/3^2 + 62932*2^2/3^3 + 129064*2^3/3^4 + 237972*2^4/3^5 + ...
%e A393888 ...
%o A393888 (PARI) {a(n) = my(A=1+x); for(i=1, n, A = 1+x + 2*subst(A, x, x*A +x*O(x^n)) - 2*A); polcoef(GF=A, n)}
%o A393888 {upto(n) = a(n); Vec(GF)}
