%I A393860 #30 Jun 07 2026 18:39:39
%S A393860 2,3,4,7,8,11,16,23,27,31,32,43,47,59,67,71,79,83,103,107,128,131,139,
%T A393860 167,179,191,211,223,227,239,256,263,283,311,331,347,359,367,383,419,
%U A393860 431,439,443,463,467,479,499,503,512,547,563,571,587,599,607,619,643,647,659,683,691,719,743,787
%N A393860 Prime powers q such that q-1 is squarefree.
%C A393860 Prime powers of the form p^(2k), where p is odd and k>=1 are guaranteed not to belong to this sequence.
%p A393860 N:= 1000: # for terms <= N
%p A393860 R:= NULL:
%p A393860 p:= 1:
%p A393860 do
%p A393860   p:= nextprime(p);
%p A393860   if p > N then break fi;
%p A393860   for k from 1 by `if`(p=2,1,2) do
%p A393860      q:= p^k;
%p A393860      if q > N then break fi;
%p A393860      if NumberTheory:-IsSquareFree(q-1) then R:= R,q fi
%p A393860 od od:
%p A393860 sort([R]); # _Robert Israel_, May 31 2026
%t A393860 Select[Range[800],PrimePowerQ[#]&&SquareFreeQ[#-1] &] (* _Stefano Spezia_, Jun 01 2026 *)
%o A393860 (PARI) lista(nn) = for (q=1, nn, if(isprimepower(q) && issquarefree(q-1), print1(q, ", "))); \\ _Michel Marcus_, May 31 2026
%Y A393860 A supersequence of A039787. A subsequence of A246655.
%K A393860 nonn,new
%O A393860 1,1
%A A393860 _Roger Salmerón Vitó_, May 30 2026
