%T A393764 97816828413705040,125776784844261867600,202322792207916645666800,
%U A393764 398042334632375210744679680,940438668044289996907775127744,2628397838622257811970918101586880,8579795091273877351227072749607517696,32355183395235713189688333653980520785920
%N A393764 O.g.f. A(x) satisfies: [x^n] exp( n^2*(n+4)*x - n*A(x) ) = 0 for n >= 1.
%H A393764 Paul D. Hanna, <a href="/A393764/b393764.txt">Table of n, a(n) for n = 1..301</a>
%F A393764 a(n) ~ sqrt(1-w) * 3^(3*n + 1/3) * n^(2*n - 3/2) / (sqrt(2*Pi) * exp(2*n) * (3-w)^(2*n-1) * w^(n + 4/3)), where w = -A226750 = -LambertW(-3*exp(-3)). - _Vaclav Kotesovec_, Mar 02 2026
%e A393764 O.g.f.: A(x) = 5*x + 49*x^2 + 3792*x^3 + 726674*x^4 + 248954740*x^5 + 131319894744*x^6 + 97960976774752*x^7 + 97816828413705040*x^8 + ...
%e A393764 ILLUSTRATION OF DEFINITION.
%e A393764 The table of coefficients of x^k/k! in exp( n^2*(n+4)*x - n*A(x) ) begin
%e A393764   n = 1: [1,   0,   -98,  -22752,  -17411364, ...];
%e A393764   n = 2: [1,  14,     0,  -50992,  -37505408, ...];
%e A393764   n = 3: [1,  48,  2010,       0,  -63922212, ...];
%e A393764   n = 4: [1, 108, 11272, 1041696,          0, ...];
%e A393764   n = 5: [1, 200, 39510, 7592240, 1304911420, 0, ...];
%e A393764   ...
%e A393764 in which a diagonal, the coefficient of x^n in row n, equals all zeros.
%e A393764 RELATED SERIES.
%e A393764 exp(A(x)) = 1 + 5*x + 123*x^2/2! + 24347*x^3/3! + 17939353*x^4/4! + 30339404085*x^5/5! + 95484666584995*x^6/6! + ...
%e A393764 where [x^n] exp(n^2*(n+4)*x) / exp(A(x))^n = 0 for n >= 1.
%o A393764 (PARI) {a(n,k=4) = my(A=[0], m); for(i=1, n+1, m=#A; A=concat(A, 0); A[m+1] = Vec( exp(m^2*(m+k)*x - m*Ser(A)) )[m+1]/m ); polcoef( Ser(A), n)}
%o A393764 for(n=1, 15, print1(a(n,4), ", "))
