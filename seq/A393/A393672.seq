%I A393672 #15 Mar 10 2026 17:05:32
%S A393672 1,1,0,1,0,1,1,1,1,1,2,1,2,1,3,2,3,2,4,3,4,4,5,5,5,6,6,8,7,9,8,11,9,
%T A393672 13,11,15,13,17,15,20,18,22,21,25,25,29,29,32,34,36,39,41,46,46,52,52,
%U A393672 60,59,68,66,78,75,87,85,99,96,111,108,125,123,139,138
%N A393672 a(n) = number of partitions of n into distinct odd parts, no two of which differ by 2.
%C A393672 See the comment at A393671.
%H A393672 Sean A. Irvine, <a href="/A393672/b393672.txt">Table of n, a(n) for n = 0..10000</a>
%e A393672 a(19) counts these 3 partitions: 19, 13+5+1, 11+7+1.
%t A393672 prt[n_, sL_] := Module[{m = Length[sL], f}, If[n > Last[sL], Return["Extend sL"]];
%t A393672   f[i_, r_, b_] := f[i, r, b] = Which[r == 0, {{}}, r < 0 || i == 0, {}, True,
%t A393672      Join[f[i - 1, r, False], If[! b && s[[i]] <= r, Map[Prepend[#, sL[[i]]] &,
%t A393672         f[i - 1, r - sL[[i]], True]], {}]]]; Reverse[f[m, n, False]]]
%t A393672 z = 80;
%t A393672 s = 2*Range[z] - 1;
%t A393672 m = Map[{#, prt[#, s]} &, Range[z]]
%t A393672 u = Map[Last, m];
%t A393672 Map[Length, u]
%t A393672 (* _Peter J. C. Moses_, Jan 26 2026 *)
