%N A393657 Expansion of (1/x) * Series_Reversion( x * ( Sum_{k=0..3} (-x)^k )^3 ).
%H A393657 Vincenzo Librandi, <a href="/A393657/b393657.txt">Table of n, a(n) for n = 0..1000</a>
%F A393657 G.f.: (1/x) * Series_Reversion( x * ((1-x^4) / (1+x))^3 ).
%F A393657 a(n) = (1/(n+1)) * Sum_{k=0..floor(n/2)} (-1)^k * binomial(3*n+k+2,k) * binomial(4*n-2*k+2,n-2*k).
%F A393657 a(n) = (1/(n+1)) * Sum_{k=0..floor(n/4)} binomial(3*n+k+2,k) * binomial(3*n+3,n-4*k).
%t A393657 CoefficientList[Normal@Series[InverseSeries@Series[x*((1-x^4)/(1+x))^3,{x,0,50}]/x,{x,0,27}],x] (* _Vincenzo Librandi_, Mar 25 2026 *)
%o A393657 (PARI) a(n) = sum(k=0, n\4, binomial(3*n+k+2, k)*binomial(3*n+3, n-4*k))/(n+1);
%o A393657 (Magma) N := 25; R<x> := PowerSeriesRing(Rationals(), N+5); f:= x*((1-x^4)/(1+x))^3; g:= Reverse(f) div x; Coeffs := [Coefficient(g,i):i in [0..N]]; Coeffs; // _Vincenzo Librandi_, Mar 25 2026
