%N A393775 G.f. A(x) satisfies A(x) = 1 - E(log(1 - x*(1 + E^3(A(x))))), where E is the Euler operator x*d/dx.
%F A393775 G.f. A(x) satisfies A(x) = 1 + x*A(x)*(1 + E^3(A(x))) + x*E^4(A(x)).
%F A393775 G.f.: 1 - E(log(1 - x*B(x))), where B(x) is the g.f. of A394821.
%F A393775 a(0) = 1; a(n) = ((n-1)^4+1) * a(n-1) + Sum_{k=1..n-1} k^3 * a(k) * a(n-1-k).
%o A393775 (PARI) E(f) = x*deriv(f);
%o A393775 my(A=1, N=20); for(k=1, N, A=1+x*A*(1+E(E(E(A))))+x*E(E(E(E(A))))+x*O(x^N)); Vec(A)
