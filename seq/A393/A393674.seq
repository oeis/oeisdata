%I A393674 #10 Mar 10 2026 16:53:15
%S A393674 1,1,0,0,1,0,1,1,1,2,2,1,2,2,2,3,5,2,4,4,4,6,8,5,9,10,9,11,14,11,15,
%T A393674 17,17,19,25,20,30,30,28,33,41,37,47,51,52,58,70,63,80,87,87,97,111,
%U A393674 106,129,136,143,155,179,171,204,218,225,246,280,273,317,336
%N A393674 a(n) = number of partitions of n into distinct nonprime parts, no two of which are consecutive in A018252.
%C A393674 See the comment at A393671.
%H A393674 Sean A. Irvine, <a href="/A393674/b393674.txt">Table of n, a(n) for n = 0..10000</a>
%e A393674 a(16) counts these 5 partitions: 16, 15+1. 12+4, 10+6, 9+6+1.
%t A393674 prt[n_, sL_] := Module[{m = Length[sL], f}, If[n > Last[sL], Return["Extend sL"]];
%t A393674 f[i_, r_, b_] := f[i, r, b] = Which[r == 0, {{}}, r < 0 || i == 0, {}, True,
%t A393674 Join[f[i - 1, r, False], If[! b && s[[i]] <= r, Map[Prepend[#, sL[[i]]] &,
%t A393674 f[i - 1, r - sL[[i]], True]], {}]]];  Reverse[f[m, n, False]]]
%t A393674 z = 100;
%t A393674 s = Join[{1}, Select[Range[z], CompositeQ]];
%t A393674 m = Map[{#, prt[#, s]} &, Range[z]]
%t A393674 u = Map[Last, m];
%t A393674 Map[Length, u]
%t A393674 (* _Peter J. C. Moses_, Jan 26 2026 *)
%Y A393674 Cf. A018252, A096258, A393671, A393672, A393673, A393675, A393676.
%K A393674 nonn
%O A393674 0,10
