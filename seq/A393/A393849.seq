%N A393849 O.g.f. A(x) satisfies: [x^n] exp( n^9 * x ) / A(x) = 0 for n>0.
%H A393849 Paul D. Hanna, <a href="/A393849/b393849.txt">Table of n, a(n) for n = 0..100</a>
%e A393849 O.g.f.: A(x) = 1 + x + 130561*x^2 + 1268169652561*x^3 + 196425341268811084961*x^4 + 236460748444613412476233431261*x^5 + ...
%e A393849 ILLUSTRATION OF DEFINITION.
%e A393849 The table of coefficients of x^k/k! in exp(n^9*x)/A(x) begins
%e A393849   n = 1: [1,       0,       -261121,      -7609017132002, ...];
%e A393849   n = 2: [1,     511,             0,      -7609283997664, ...];
%e A393849   n = 3: [1,   19682,     387120003,                   0, ...];
%e A393849   n = 4: [1,  262143,   68718691328,   18006377981579296, 0, ...];
%e A393849   n = 5: [1, 1953124, 3814693098255, 7450560013815682610, 14547105795912570137404925, 0, ...];
%e A393849   ...
%e A393849 in which a diagonal, the coefficient of x^n in row n, is all zeros.
%o A393849 (PARI) {a(n,k=9) = my(A=[1]); for(i=1, n, A=concat(A, 0); m=#A; A[m] = Vec( exp(x*(m-1)^k +x*O(x^m)) / Ser(A) )[m] ); A[n+1]}
%o A393849 for(n=0, 15, print1( a(n,9), ", "))
%Y A393849 Sequences below with the given parameter p have an o.g.f. F(x) satisfying [x^n] exp( n^p*x ) / F(x) = 0 for n >= 1.
