%S A393383 0,1,3,4,6,8,9,10,11,12,13,15,16,15,17,17,18,19,20,21,22,24,25,21,22,
%T A393383 23,23,24,24,25,26,26,27,27,28,28,29,30,31,32,33,35,36,28,30,30,30,31,
%U A393383 32,32,32,33,33,34,34,34,35,35,36,36,37,37,37,38,38,39,39,40,40,41,41,42,43,44,45,46,48,49
%N A393383 Irregular triangle read by rows in which row n lists the number of cells under the symmetric Dyck paths of semilength n in the first quadrant of the square grid in nondecreasing order, n >= 0.
%C A393383 Both the column 1 and the right border are the same as in its supersequence A390502.
%C A393383 The number of cells equals the area under the symmetric Dyck path.
%C A393383 Equivalently row n lists the number of cells above the symmetric Dyck paths in fourth quadrant.
%C A393383 The diagram in the fourth quadrant of the square grid is the same as the Young diagram corresponding to a partition of T(n,k).
%C A393383 Note that at least one of the terms in the row n equals A024916(n), the sum of all divisors of all positive integers <= n, because the associated symmetric Dyck path is described in the n-th row of A237593.
%H A393383 Alois P. Heinz, <a href="/A393383/b393383.txt">Rows n = 0..17, flattened</a>
%e A393383 Triangle begins:
%e A393383    0;
%e A393383    1;
%e A393383    3,  4;
%e A393383    6,  8,  9;
%e A393383   10, 11, 12, 13, 15, 16;
%e A393383   ...
%e A393383 For n = 3 there are three symmetric Dyck paths of semilength 3 in the first quadrant of the square grid as shown below:
%e A393383     _         _ _       _ _ _
%e A393383      |_          |_          |
%e A393383        |_          |         |
%e A393383          |         |         |
%e A393383 .
%e A393383 The illustration of the third row of the triangle is as shown below:
%e A393383     _         _ _       _ _ _
%e A393383    |_|_      |_|_|_    |_|_|_|
%e A393383    |_|_|_    |_|_|_|   |_|_|_|
%e A393383    |_|_|_|   |_|_|_|   |_|_|_|
%e A393383       6         8         9
%e A393383 .
%p A393383 b:= proc(x, y) option remember; `if`(y<0 or y>x, 0, `if`(x=0, 1,
%p A393383        expand(b(x-1, y-1)*z^(2*y-1)+ b(x-1, y+1)*z^(2*y+1))))
%p A393383     end:
%p A393383 T:= n-> (p-> seq((i+n^2)/2$coeff(p, z, i), i=0..degree(p)))(
%p A393383              add(b(n, n-2*i), i=0..n/2)):
%p A393383 seq(T(n), n=0..7);  # _Alois P. Heinz_, Apr 01 2026
%Y A393383 Subsequence of A390502.
%Y A393383 Column 1 gives A000217.
%Y A393383 Row lengths give A001405.
%Y A393383 Right border gives A000290.
%Y A393383 Row sums give A394643.
%Y A393383 Cf. A024916, A088855, A109077, A109078, A237593, A339575.
%K A393383 nonn,tabf,look,changed
