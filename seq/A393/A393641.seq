%I A393641 #39 May 23 2026 14:34:24
%S A393641 2,3,5,11,13,17,19,41,43,109,113,241,257,331,673,683,1321,1613,2113,
%T A393641 2731,4051,5419,14449,20857,21841,26317,30269,38737,43691,61681,65537,
%U A393641 86171,87211,174763,268501,279073,384773,525313,1564921,2796203,3033169,4327489,6700417
%N A393641 Primes p that are the greatest prime factor of 2^k + 1 for some k.
%C A393641 Numbers that occur in A002587.
%C A393641 2 and odd primes p such that k = A002326((p-1)/2) is even and 2^(k/2) + 1 is p-smooth.
%e A393641 a(4) = 13 is a term because 13 is the greatest prime factor of 2^6 + 1 = 65 = 5 * 13.
%p A393641 A:= 2: count:= 1: P:= {}: p:= 2:
%p A393641 while count < 37 do
%p A393641   p:= nextprime(p);
%p A393641   m:= NumberTheory:-MultiplicativeOrder(2, p);
%p A393641   if m::odd then next fi;
%p A393641   m:= m/2;
%p A393641   t:= 2^m+1;
%p A393641   t:= t/p^padic:-ordp(t, p);
%p A393641   for q in P do if t mod q = 0 then
%p A393641     t:= t/q^padic:-ordp(t, q);
%p A393641     if t = 1 then break fi;
%p A393641   fi od;
%p A393641   if t = 1 then count:= count+1; A:= A, p; fi;
%p A393641   P:= P union {p};
%p A393641 od:
%p A393641 A;
%Y A393641 Includes A019434.
%Y A393641 Cf. A002326, A002587, A091317, A395945, A396002, A396044.
%K A393641 nonn
%O A393641 1,1
%A A393641 _Robert Israel_, May 13 2026
%E A393641 a(40)-a(43) from _Jinyuan Wang_, May 23 2026
