%I A393351 #19 Mar 03 2026 17:33:49
%S A393351 1,6,12,4,30,12,56,40,45,30,132,12,182,168,60,48,306,90,380,60,168,
%T A393351 132,552,120,175,546,54,56,870,60,992,224,132,306,840,180,1406,1140,
%U A393351 1092,120,1722,168,1892,132,90,552,2256,48,441,1050,612,364,2862,54,660,280
%N A393351 a(n) is the lcm of n and all (p_i + e_i) in the canonical prime factorization of n.
%C A393351 Fixed points of this sequence are the numbers in A392819.
%H A393351 Felix Huber, <a href="/A393351/b393351.txt">Table of n, a(n) for n = 1..10000</a>
%F A393351 a(n) = lcm(n, {p_i + e_i}), where p_i^{e_i} are the prime powers in the canonical factorization of n.
%F A393351 a(A392819(n)) = A392819(n).
%e A393351 a(8) = lcm(8, 2 + 3) = 40.
%e A393351 a(12) = lcm(12, 2 + 2, 3 + 1) = 12.
%p A393351 A393351 := proc(n) local i; ilcm(n, op([seq(i[1] + i[2], i in ifactors(n)[2])])); end proc: seq(A393351(n), n = 1 .. 56);
%t A393351 a[n_] := LCM @@ Join[{n}, (#[[1]] + #[[2]]) & /@ FactorInteger[n]]; a[1] = 1; Array[a, 60] (* _Amiram Eldar_, Feb 25 2026 *)
%o A393351 (PARI) a(n) = my(f=factor(n)); lcm(concat(n, vector(#f~, k, f[k,1]+f[k,2]))); \\ _Michel Marcus_, Feb 25 2026
%Y A393351 Cf. A001221, A009230, A008473, A390229, A392819.
%K A393351 nonn,easy,new
%O A393351 1,2
%A A393351 _Felix Huber_, Feb 25 2026
