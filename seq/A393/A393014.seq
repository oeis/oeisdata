%I A393014 #60 May 31 2026 00:58:55
%S A393014 3,5,7,127,19433,90352181,26315683709701629860193397,
%T A393014 615850986357618363622206847,2073722573406568398837217962245683
%N A393014 Primes that are palindromic in both base 2 and base 9.
%e A393014 127 is a term since 127 = 1111111_2 = 151_9, both palindromes.
%e A393014 19433 is a term since 19433 = 100101111101001_2 = 28582_9, both palindromes.
%e A393014 90352181 is a term since 90352181 = 101011000010101010100001101_2 = 208010802_9, both palindromes.
%t A393014 Select[Prime[Range[10^6]], PalindromeQ[#] && PalindromeQ[IntegerString[#, 2]] && PalindromeQ[IntegerString[#, 9]] &]
%o A393014 (PARI)
%o A393014 ispal(n,b)=my(d=digits(n,b));d==Vecrev(d);
%o A393014 forprime(p=2,10^15, if(ispal(p,2)&&ispal(p,9), print1(p, ", ")))
%o A393014 (Python)
%o A393014 from gmpy2 import next_prime, mpz
%o A393014 def ispal(n, b):
%o A393014     d = []
%o A393014     while n:
%o A393014         d.append(n % b)
%o A393014         n //= b
%o A393014     return d == d[::-1]
%o A393014 p = mpz(2)
%o A393014 while True:
%o A393014     if ispal(p, 2) and ispal(p, 9):
%o A393014         print(p, end=", ")
%o A393014     p = next_prime(p)
%Y A393014 Primes in A259385.
%Y A393014 Intersection of A016041 and A029977.
%Y A393014 Cf. A046472, A046473, A046477, A046478.
