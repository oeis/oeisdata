%N A393884 O.g.f. A(x) satisfies: [x^n] exp( n^8*x - n^4*A(x) ) = 0 for n >= 1.
%H A393884 Paul D. Hanna, <a href="/A393884/b393884.txt">Table of n, a(n) for n = 1..201</a>
%e A393884 O.g.f.: A(x) = x + 1800*x^2 + 548208000*x^3 + 2916139484160000*x^4 + 119102151694386600000000*x^5 + 23745283509761490666837427200000*x^6 + ...
%e A393884 ILLUSTRATION OF DEFINITION.
%e A393884 The table of coefficients of x^k/k! in exp( n^8*x - n^4*A(x) ) begins
%e A393884   n = 1: [1,      0,        -3600,       -3289248000, ...];
%e A393884   n = 2: [1,    240,            0,      -52655616000, ...];
%e A393884   n = 3: [1,   6480,     41698800,                 0, ...];
%e A393884   n = 4: [1,  65280,   4260556800,   277166776320000, 0, ...];
%e A393884   n = 5: [1, 390000, 152097750000, 59314311720000000, 23085407556125100000000, 0, ...]; ...
%e A393884 in which a diagonal, the coefficient of x^n in row n, is all zeros.
%e A393884 RELATED SERIES.
%e A393884 exp(A(x)) = 1 + x + 3601*x^2/2! + 3289258801*x^3/3! + 69987360815733601*x^4/4! + 14292258553381576114116001*x^5/5! + 17096604212785711058898284057814001*x^6/6! + ...
%e A393884 where [x^n] exp(n^8*x) / exp(A(x))^(n^4) = 0 for n >= 1.
%o A393884 (PARI) {a(n,p=8,q=4) = my(A=[0], m); for(i=1, n+1, m=#A; A=concat(A, 0); A[m+1] = Vec( exp(m^p*x - m^q*Ser(A)) )[m+1]/(m^q) ); polcoef( Ser(A), n)}
%o A393884 for(n=1, 15, print1(a(n,8,4), ", "))
%Y A393884 Below, sequences with the parameters (p,q) indicated have an o.g.f. F(x) satisfying [x^n] exp( n^p*x - n^q*F(x) ) = 0 for n >= 1.
