%I A393812 #7 Mar 10 2026 23:32:27
%S A393812 6,11,10,17,14,15,23,16,25,20,26,41,21,31,24,38,59,28,39,30,46,51,55,
%T A393812 71,33,35,47,34,53,40,58,89,42,62,69,77,44,65,83,48,75,52,97,54,56,87,
%U A393812 95,57,79,60,78,92,123,143,167,63,103,66,70,94,115,119,68,82
%N A393812 Irregular triangle read by rows; integers with identical sigma values occurring at least twice, rows ordered by their smallest term.
%C A393812 This sequence is a permutation of A206036.
%C A393812 The row length equals the number of occurrences of the corresponding sigma value (see A007609).
%C A393812 Each row contains at most one prime. If a prime p appears in a row, the row length equals A066075(A000720(p)).
%H A393812 Felix Huber, <a href="/A393812/b393812.txt">Rows 1 to 1601, flattened</a>
%e A393812 6 and 11 are in a row since sigma(6) = sigma(11) = 12.
%e A393812 30, 46, 51, 55 and 71 are in a row since sigma(30) = sigma(46) = sigma(51) = sigma(55) = sigma(71) = 72.
%e A393812 The triangle begins:
%e A393812     6   11
%e A393812    10   17
%e A393812    14   15   23
%e A393812    16   25
%e A393812    20   26   41
%e A393812    21   31
%e A393812    24   38   59
%e A393812    28   39
%e A393812    30   46   51   55   71
%e A393812    33   35   47
%e A393812    34   53
%e A393812    40   58   89
%e A393812    42   62   69   77
%e A393812    44   65   83
%e A393812    48   75
%e A393812    52   97
%e A393812    54   56   87   95
%e A393812    57   79
%e A393812    60   78   92  123  143  167
%e A393812    63  103
%e A393812    66   70   94  115  119
%e A393812    68   82
%p A393812 with(NumberTheory):
%p A393812 L := proc(N) # All rows with smallest number <= N
%p A393812     local t, k, d, i, m;
%p A393812     m := max(seq(sigma(k), k = 1 .. N)) - 1;
%p A393812     t := table();
%p A393812     for k to m do
%p A393812         d := sigma(k);
%p A393812         if assigned(t[d]) then
%p A393812             t[d] := [op(t[d]), k]
%p A393812         else
%p A393812             t[d] := [k]
%p A393812         end if
%p A393812     end do;
%p A393812     sort([seq(`if`(nops(t[op(i)]) > 1 and t[op(i)][1] <= N, t[op(i)], NULL), i in indices(t))], (x, y) -> x[1] < y[1]);
%p A393812 end proc:
%p A393812 T := proc(N) local l, w, i, j; l := L(N); w := 0; for i in l do for j to nops(i) do w := max(w, length(convert(i[j], string))); end do; end do; w := w + 2; for i in l do for j to nops(i) do printf(cat("%", w, "d"), i[j]); end do; printf("\n"); end do; end proc:
%p A393812 A393812 := proc(N) local i; seq(op(i), i in L(N)) end proc:
%p A393812 A393812(68); L(68); T(68);
%Y A393812 Cf. A000203, A007609, A066075, A206036, A211656, A392774.
%K A393812 tabf,nonn,new
