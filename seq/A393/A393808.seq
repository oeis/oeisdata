%I A393808 #56 Jul 08 2026 10:59:35
%S A393808 1,3,5,10,9,15,13,36,33,27,21,50,25,39,45,136,33,99,37,90,65,63,45,
%T A393808 180,145,75,261,130,57,135,61,400,105,99,117,330,73,111,125,324,81,
%U A393808 195,85,210,297,135,93,680,385,435,165,250,105,783,189,468,185,171,117,450,121,183
%N A393808 a(n) = Sum_{k=1..n} gcd(k^4,n).
%H A393808 Seiichi Manyama, <a href="/A393808/b393808.txt">Table of n, a(n) for n = 1..10000</a>
%F A393808 Multiplicative with a(p^e) = p^e + Sum_{k=0..e-1} (p^(e-k) - p^(e-k-1)) * p^min(4*k,e).
%F A393808 Equivalently, a(p^e) = p^e * ( 1 + ((p-1)/p) * Sum_{k=1..e} p^floor(3*k/4) ).
%F A393808 Let s and t be positive integers, and let a_{s,t}(n) = Sum_{k=1..n} gcd(k^s,n^t).
%F A393808 a_{s,t}(p^e) = p^min(s*e,t*e) + Sum_{k=0..e-1} (p^(e-k) - p^(e-k-1)) * p^min(s*k,t*e).
%F A393808 a_{s,t}(n) is multiplicative if and only if t <= s.
%F A393808 For t <= s, a_{s,t}(p^e) = p^e * ( 1 + ((p-1)/p) * Sum_{k=1..t*e} p^floor(((s-1)*k)/s) ).
%o A393808 (PARI) a(n) = sum(k=1, n, gcd(k^4, n));
%Y A393808 Cf. A018804, A078430, A372882, A397733.
%Y A393808 Cf. A343498, A396901, A396903.
%K A393808 nonn,mult
%O A393808 1,2
