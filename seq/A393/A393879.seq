%S A393879 1,1,1,1,4,10,20,47,127,331,823,2106,5618,15026,39846,106397,287750,
%T A393879 782040,2126598,5801625,15907428,43765796,120649100,333339472,
%U A393879 923427313,2563959061,7131839117,19871782003,55466575210,155070547136,434160557570
%N A393879 G.f. satisfies Sum_{n>=0} (-1)^n * A(x)^(n^2) = 1 - x - x^2 - x^3.
%C A393879 Conjecture: a(n)^(1/n) tends to (2 + (53 - 3*sqrt(201))^(1/3) + (53 + 3*sqrt(201))^(1/3))/3 = 2.9196395658394181451114139... - _Vaclav Kotesovec_, Apr 17 2026
%H A393879 Paul D. Hanna, <a href="/A393879/b393879.txt">Table of n, a(n) for n = 1..1000</a>
%H A393879 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/RamanujanThetaFunctions.html">Ramanujan Theta Functions.</a>
%F A393879 G.f. A(x) = Sum_{n>=0} a(n)*x^n satisfies the following formulas.
%F A393879 (1) 1-x-x^2-x^3 = Sum_{n>=0} (-1)^n * A(x)^(n^2).
%F A393879 (2) 1-x-x^2-x^3 = Sum_{n>=0} (-1)^n * A(x)^n * Product_{k=1..n} (1 + A(x)^(4*k-3)) / (1 + A(x)^(4*k-1)) due to a q-series identity.
%F A393879 (3) 1-x-x^2-x^3 = 1/(1 + A/(1 + (A^3-A)/(1 + A^5/(1 + (A^7-A^3)/(1 + A^9/(1 + (A^11-A^5)/(1 + A^13/(1 + (A^15-A^7)/(1 + ...))))))))) where A = A(x), a continued fraction due to an identity of a partial elliptic theta function.
%F A393879 (4) Sum_{n>=0} (-1)^n * A(x)^(2*n+1)/(1 + A(x)^(2*n+1)) = (x + x^2 + x^3)*(1 - x - x^2 - x^3).
%F A393879 (5) Sum_{n>=1} (-1)^n * n * A(x)^n/(1 + A(x)^n) = -(x + x^2 + x^3)*(1 - x - x^2 - x^3)*(1 - 2*(x + x^2 + x^3)*(1 - x - x^2 - x^3)).
%F A393879 (6) Product_{n>=1} (1 - A(x)^(2*n))*(1 - A(x)^(2*n-1))^2 = 1 - 2*x - 2*x^2 - 2*x^3, by the Jacobi triple product identity.
%e A393879 G.f.: A(x) = x + x^2 + x^3 + x^4 + 4*x^5 + 10*x^6 + 20*x^7 + 47*x^8 + 127*x^9 + 331*x^10 + 823*x^11 + 2106*x^12 + ...
%o A393879 (PARI) {a(n) = my(A=[0,1]); for(i=1,n, A = concat(A,0);
%o A393879 A[#A] = polcoef(-(1-x-x^2-x^3) + sum(m=0,sqrtint(#A), (-1)^m * Ser(A)^(m^2) ), #A-1) ); polcoef(GF=Ser(A),n)}
%o A393879 {upto(n) = a(n); Vec(GF)}
%o A393879 upto(30)
%o A393879 \\ Verify formulas
%o A393879 A = GF
%o A393879 sum(n=0,#A, (-1)^n * A^(n^2) )
%o A393879 sum(n=0,#A, (-1)^n * A^n * prod(k=1,n, (1 + A^(4*k-3)) / (1 + A^(4*k-1)) ))
%Y A393879 Cf. A393880.
%K A393879 nonn,new
%O A393879 1,5
%A A393879 _Paul D. Hanna_, Apr 09 2026
