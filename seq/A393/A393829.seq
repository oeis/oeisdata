%t A393829 a[n_]:=Module[{c=Prime[n]-2},While[PrimeOmega[c]!=2,c=c-2];c];Array[a,58,5] (* _James C. McMahon_, Mar 07 2026 *)
%o A393829 (PARI) a393829(n) = forstep(k=prime(n)-2, 9, -2, if(bigomega(k)==2, return(k)));-1
