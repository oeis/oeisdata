%N A393073 Convolution of the two tribonacci sequences A000073 and A001590.
%H A393073 <a href="/index/Rec#order_06">Index entries for linear recurrences with constant coefficients</a>, signature (2,1,0,-3,-2,-1).
%F A393073 G.f.: (1 - x)*x^3/(1 - x - x^2 - x^3)^2.
%F A393073 a(n) = Sum_{i=0..n} A000073(i)*A001590(n-i).
%F A393073 a(n) = A073778(n+1) - A073778(n) .
%F A393073 a(n+4) + a(n+3) - a(n+2) - a(n+1) = A292401(n).
%F A393073 (n-3)*a(n) = (2*n - 7)*a(n-1) + 3*a(n-2) + 3*a(n-3) - (n-2)*a(n-4).
%F A393073 (n^2 - 9)*a(n) = (11*n - 37)*a(n-1) + (2*n^2 - 7*n + 15)*a(n-2) + (2*n^2 - 5*n + 15)*a(n-3) + (n^2 - 7*n + 10)*a(n-4).
%F A393073 a(n) = 2*a(n-1) + a(n-2) - 3*a(n-4) - 2*a(n-5) - a(n-6).
%t A393073 LinearRecurrence[{2, 1, 0, -3, -2, -1}, {0, 0, 0, 1, 1, 3}, 41]
