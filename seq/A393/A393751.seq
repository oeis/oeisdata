%S A393751 1,2,24,560,19760,952224,59446016,4655116800,447065498880,
%T A393751 51742756060160,7113091186432000,1146991576069128192,
%U A393751 214577639106735550464,46122420013368910561280,11292648489680280840437760,3125327548938685099433525248,971008708989091049942761930752,336584875476291673400834923560960
%N A393751 G.f. A(x) satisfies A(x) = x + x*d^2/dx^2 A(x)^3/3.
%H A393751 Paul D. Hanna, <a href="/A393751/b393751.txt">Table of n, a(n) for n = 1..401</a>
%F A393751 G.f. A(x) = Sum_{n>=1} a(n)*x^n satisfies the following formulas.
%F A393751 (1) A(x) = x + x*d^2/dx^2 A(x)^3/3.
%F A393751 (2) A(x) = x + 2*x*A(x)*A'(x)^2 + x*A(x)^2*A''(x).
%F A393751 (3) A(x) = x * (1 + A(x)^2*A''(x)) / (1 - 2*x*A'(x)^2).
%F A393751 (4) A(x) = Series_Reversion(x/F(x)) where F(x) = 1 + x*F(x)^3 * (2*F(x)^2 - 2*x^2*F'(x)^2 + x^2*F(x)*F''(x)) / (F(x) - x*F'(x))^3 is the g.f. of A393750.
%F A393751 a(n) ~ c * n!^2 * n, where c = 0.54073886138441178563454150530670772256748... - _Vaclav Kotesovec_, Mar 15 2026
%e A393751 G.f.: A(x) = x + 2*x^2 + 24*x^3 + 560*x^4 + 19760*x^5 + 952224*x^6 + 59446016*x^7 + 4655116800*x^8 + 447065498880*x^9 + ...
%e A393751 RELATED SERIES.
%e A393751 A(x)^3 = x^3 + 6*x^4 + 84*x^5 + 1976*x^6 + 68016*x^7 + 3184608*x^8 + 193963200*x^9 + 14902183296*x^10 + ...
%e A393751 where A(x) = x + x*d^2/dx^2 A(x)^3/3.
%e A393751 Given A(x/F(x)) = x and A(x) = x*F(A(x)), then F(x) is the g.f. A393750, which begins
%e A393751 F(x) = 1 + 2*x + 20*x^2 + 432*x^3 + 15008*x^4 + 732032*x^5 + 46719936*x^6 + 3746127360*x^7 + ... + A393750(n)*x^n + ...
%e A393751 where [x^n] F(x)^(n+1) * (1 - (n+1)^2*x*F(x)) = 0 for n >= 1.
%o A393751 (PARI) {a(n) = my(A=x+x^2); for(i=1, n, A = x + x*deriv(deriv(A^3/3 +x^2*O(x^n)))); polcoeff(A, n)}
%o A393751 for(n=1, 25, print1(a(n), ", "))
%Y A393751 Cf. A393750, A088716.
%K A393751 nonn,changed
%O A393751 1,2
%A A393751 _Paul D. Hanna_, Mar 07 2026
