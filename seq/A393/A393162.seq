%I A393162 #16 Mar 15 2026 16:14:46
%S A393162 1,1053,15921,478950,829549375,27708756025
%N A393162 Numbers k such that sigma(k) = psi(k) + pi(k) + Omega(k).
%e A393162 1053 is a term since sigma(1053) = 1694 = 1512 + 177 + 5 = psi(1053) + pi(1053) + Omega(1053).
%o A393162 (PARI) dedpsi(f) = prod(k = 1, #f~, (f[k, 1]+1) * f[k, 1]^(f[k, 2]-1));
%o A393162 list(lim) = {my(q = 2, m = 0, f); print1(1, ", "); forprime(p = 3, lim, m++; for(k = q, p-1, f = factor(k); if(sigma(f) == dedpsi(f) + m + bigomega(f), print1(k, ", "))); q = p); } \\ _Amiram Eldar_, Mar 05 2026
%Y A393162 Cf. A000203, A000720, A001615, A001222, A390234.
