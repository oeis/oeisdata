%e A393890   n = 7: [1, 7, 70, 987, 18690, 449666, 13105372, ...];
%e A393890   ...
%e A393890 in which the following sum along column k equals a(k)
%e A393890 a(1) = 1 = 1/5 + 1*4/5^2 + 1*4^2/5^3 + 1*4^3/5^4 + 1*4^4/5^5 + ...
%e A393890 a(2) = 4 = 0/5 + 1*4/5^2 + 2*4^2/5^3 + 3*4^3/5^4 + 4*4^4/5^5 + ...
%e A393890 a(3) = 48 = 0/5 + 4*4/5^2 + 10*4^2/5^3 + 18*4^3/5^4 + 28*4^4/5^5 + ...
%e A393890 a(4) = 912 = 0/5 + 48*4/5^2 + 117*4^2/5^3 + 213*4^3/5^4 + 342*4^4/5^5 + ...
%e A393890 a(5) = 22784 = 0/5 + 912*4/5^2 + 2180*4^2/5^3 + 3918*4^3/5^4 + 6264*4^4/5^5 + ...
%e A393890 a(6) = 690496 = 0/5 + 22784*4/5^2 + 53796*4^2/5^3 + 95616*4^3/5^4 + 151526*4^4/5^5 + ...
%e A393890 a(7) = 24314624 = 0/5 + 690496*4/5^2 + 1616880*4^2/5^3 + 2850492*4^3/5^4 + 4483036*4^4/5^5 + ...
%e A393890 ...
%o A393890 (PARI) {a(n) = my(A=1+x); for(i=1, n, A = 1+x + 4*subst(A, x, x*A +x*O(x^n)) - 4*A); polcoef(GF=A, n)}
%o A393890 {upto(n) = a(n); Vec(GF)}
