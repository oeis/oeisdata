%T A393714 2,24,6,14,10,12,6,30,6,14,6,26,4,28,8,10,12,18,4,38,6,18,12,28,6,26,
%U A393714 8,22,14,26,4,46,8,12,18,28,8,40,8,26,6,32,6,50
%N A393714 a(n) = number of triples (x, y, z) such that x^2 + y*z = n, where x, y, z are positive integers and x is coprime to y*z.
%C A393714 a(5) = 4 counts these triples: (1, 1, 4), (1, 2, 2), (1, 4, 1), (2, 1, 1).
%t A393714 t[n_, c_] := Module[{r}, r = Flatten[Table[If[n - x^2 <= 0, {},
%t A393714        Map[({x, #, Quotient[n - x^2, #]} &),
%t A393714        Select[Divisors[n - x^2], Divisible[n - x^2, #] &]]], {x, 1,
%t A393714        Floor[Sqrt[n - 1]]}], 1]; Select[r, Apply[c, #] &]];
%t A393714 c = CoprimeQ[#1, #2 #3] &; Table[{n, t[n, c]}, {n, 1, 30}]
%t A393714 Join[{0}, Table[Length[t[n, c]], {n, 1, 130}]]
