%N A393240 a(n) is the permanent of the n-th order Hankel matrix whose generic element is given by A000045(i+j-1) with i,j = 1, ..., n.
%C A393240 The Hankel transform of A000045 has the following polynomial as g.f. 1 + x + x^2: the matrices are singular for n > 2.
%H A393240 N. J. A. Sloane, <a href="/transforms.txt">Transforms</a>.
%e A393240 a(3) = 44:
%e A393240   [1  1  2]
%e A393240   [1  2  3]
%e A393240   [2  3  5]
%t A393240 a[0]=1; a[n_]:=Permanent[Table[Fibonacci[i+j-1], {i, 1, n},{j, 1, n}]]; Array[a,15,0]
%Y A393240 Cf. A000045, A120297, A374668.
%K A393240 nonn,new
%O A393240 0,3
