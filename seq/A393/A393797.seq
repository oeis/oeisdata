%S A393797 4,1,5,3,6,22,7,23,14,27,15,29,93,30,94,31,95,61,111,62,119,63,123,
%T A393797 379,125,381,126,382,127,383,251,447,253,479,254,495,255,503,1527,507,
%U A393797 1531,509,1533,510,1534,511,1535,1015,1791,1019,1919,1021,1983,1022,2015
%N A393797 Position where n first occurs in A393336.
%C A393797 The number of 0's in the binary representation of a(n) is at most 2. - _Chai Wah Wu_, Mar 06 2026
%H A393797 Chai Wah Wu, <a href="/A393797/b393797.txt">Table of n, a(n) for n = 0..10000</a> (terms 0..200 from Ruud H.G. van Tol)
%H A393797 Chai Wah Wu, <a href="/A393797/a393797_2.pdf">A characterization of OEIS A393797</a>
%o A393797 (PARI) a(n)= for(i=1, oo, my(d=binary(i)); if(n == 2*d*-[-#d..-1]~ - binomial(#d+1, 2), return(i)))
%o A393797 (PARI) a(n)= n||return(4); my(k=(sqrtint(n*8)+1)\2, t=binomial(k+1, 2)-n); if(t%2, t+=k++; if(!(k%2), t+=k++)); my(m=t\2, a=2^k-1); if(!m, a, m<k, a-2^(m-1), a-2^(k-2)-2^(m-k)); \\ port of the Python code; _Ruud H.G. van Tol_, Mar 08 2026
%o A393797 (Python)
%o A393797 from math import isqrt, comb
%o A393797 def A393797(n):
%o A393797     if n == 0: return 4
%o A393797     k = isqrt(n<<3)+1>>1
%o A393797     t = comb(k+1,2)-n
%o A393797     if t&1:
%o A393797         k += 1
%o A393797         t += k
%o A393797         if k&1^1:
%o A393797             k += 1
%o A393797             t += k
%o A393797     m, a = t>>1, (1<<k)-1
%o A393797     if m == 0:
%o A393797         return a
%o A393797     elif m < k:
%o A393797         return a-(1<<m-1)
%o A393797     else:
%o A393797         return a-(1<<k-2)-(1<<m-k) # _Chai Wah Wu_, Mar 06 2026
%Y A393797 Cf. A393336.
%K A393797 nonn,base,changed
%O A393797 0,1
