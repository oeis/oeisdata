%N A393819 a(n) is the greatest odd semiprime < 2*prime(n).
%H A393819 James C. McMahon, <a href="/A393819/b393819.txt">Table of n, a(n) for n = 3..10000</a>
%p A393819 a:= proc(n) local k; for k from 2*ithprime(n)-1 by -2
%p A393819       while numtheory[bigomega](k)<>2 do od; k
%p A393819     end:
%p A393819 seq(a(n), n=3..58);  # _Alois P. Heinz_, Mar 06 2026
%t A393819 a[n_]:=Module[{c=2Prime[n]-1},While[PrimeOmega[c]!=2,c=c-2];c];Array[a,56,3] (* _James C. McMahon_, Mar 06 2026 *)
%o A393819 (PARI) a393819(n) = forstep(k=2*prime(n)-1, 9, -2, if(bigomega(k)==2, return(k))); -1
