%S A393254 2,2,1,5,5,17,89,59,107,71,167,17,191,347,1667,1457,197,281,101,137,
%T A393254 137,149,989,4049,4157,1019,311,5519,101,2201,7739,6161,6131,3257,
%U A393254 9767,13757,9257,2549,4601,7571,13679,6131,6197,7919,599,5279,9929,1061,101,4637,1931,14657
%N A393254 Smallest k such that both n! + k and n! + k + 2 are primes.
%C A393254 This sequence represents the distance from n! to the first twin prime pair following it.
%C A393254 Because n! acts as a strong Mertens filter (being divisible by all primes <= n), the local density of primes immediately following n! is significantly higher than in random intervals of similar magnitude.
%C A393254 Empirical observation by the author suggests that a(n) < n^3 for all n >= 2, which implies a highly compact bound for the first twin prime pair after a factorial. This sequence is the twin-prime analog to A037153.
%H A393254 Robert Israel, <a href="/A393254/b393254.txt">Table of n, a(n) for n = 0..367</a>
%F A393254 a(n) = min { k >= 0 | n! + k is prime and n! + k + 2 is prime }.
%e A393254 For n = 3, 3! = 6. For k = 1, 2, 3, 4, the pairs (6+k, 6+k+2) are (7,9), (8,10), (9,11), and (10,12), none of which are twin primes. For k = 5, (11, 13) are twin primes, so a(3) = 5.
%e A393254 For n = 4, 4! = 24. For k = 1, 2, 3, 4, the numbers 24+k (25, 26, 27, 28) are all composite. For k = 5, (29, 31) are twin primes, so a(4) = 5.
%p A393254 f:= proc(n) local N,k;
%p A393254    N:= n!;
%p A393254    for k from 5 by 6 do
%p A393254      if isprime(N+k) and isprime(N+k+2) then return k fi
%p A393254    od
%p A393254 end proc:
%p A393254 f(0):= 2: f(1):= 2: f(2):= 1:
%p A393254 map(f, [$0..60]); # _Robert Israel_, Mar 08 2026
%t A393254 a[n_]:=Module[{k=0}, While[!PrimeQ[n!+k]||!PrimeQ[n!+k+2], k++]; k]; Array[a,52,0] (* _Stefano Spezia_, Mar 08 2026 *)
%o A393254 (Python)
%o A393254 from sympy import isprime, factorial
%o A393254 def A393254(n):
%o A393254     fact_n = factorial(n)
%o A393254     k = 0
%o A393254     while True:
%o A393254         if isprime(fact_n + k) and isprime(fact_n + k + 2):
%o A393254             return k
%o A393254         k += 1
%o A393254 print([A393254(n) for n in range(0, 16)])
%o A393254 (PARI) a(n) = my(k=0, f=n!); while (!(ispseudoprime(f+k) && ispseudoprime(f+k+2)), k++); k; \\ _Michel Marcus_, Mar 08 2026
