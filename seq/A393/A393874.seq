%N A393874 O.g.f. A(x) satisfies: [x^n] exp( n^7*x - n^4*A(x) ) = 0 for n >= 1.
%H A393874 Paul D. Hanna, <a href="/A393874/b393874.txt">Table of n, a(n) for n = 1..201</a>
%e A393874 O.g.f.: A(x) = x + 392*x^2 + 18393804*x^3 + 10664500259840*x^4 + 36365399284006880000*x^5 + 490848817029959167266614400*x^6 + ...
%e A393874 ILLUSTRATION OF DEFINITION.
%e A393874 The table of coefficients of x^k/k! in exp( n^7*x - n^4*A(x) ) begins
%e A393874   n = 1: [1,     0,       -784,      -110362824, ...];
%e A393874   n = 2: [1,   112,          0,     -1768615040, ...];
%e A393874   n = 3: [1,  2106,    4371732,               0, ...];
%e A393874   n = 4: [1, 16128,  259911680,   4157128783872, 0, ...];
%e A393874   n = 5: [1, 77500, 6005760000, 465301473235000, 35876031106752400000, 0, ...]; ...
%e A393874 in which a diagonal, the coefficient of x^n in row n, is all zeros.
%e A393874 RELATED SERIES.
%e A393874 exp(A(x)) = 1 + x + 785*x^2/2! + 110365177*x^3/3! + 255948449536129*x^4/4! + 4363849194687214176881*x^5/5! + 353411174447793677420489825041*x^6/6! + ...
%e A393874 where [x^n] exp(n^7*x) / exp(A(x))^(n^4) = 0 for n >= 1.
%o A393874 (PARI) {a(n,p=7,q=4) = my(A=[0], m); for(i=1, n+1, m=#A; A=concat(A, 0); A[m+1] = Vec( exp(m^p*x - m^q*Ser(A)) )[m+1]/(m^q) ); polcoef( Ser(A), n)}
%o A393874 for(n=1, 15, print1(a(n,7,4), ", "))
%Y A393874 Below, sequences with the parameters (p,q) indicated have an o.g.f. F(x) satisfying [x^n] exp( n^p*x - n^q*F(x) ) = 0 for n >= 1.
