%N A393915 a(n) = Sum_{k=0..n} binomial(n,k)^2 * binomial(2*k,k) * k!.
%F A393915 Recurrence: n*(2*n - 5)*a(n) = (16*n^3 - 52*n^2 + 38*n - 11)*a(n-1) - (n-1)*(32*n^3 - 128*n^2 + 162*n - 71)*a(n-2) + 16*(n-2)^2*(n-1)*(2*n - 3)*a(n-3).
%F A393915 a(n) ~ Pi^(-1/2) * 2^(2*n) * exp(sqrt(n) - n - 1/8) * n^(n - 1/4) * (1 + 61/(96*sqrt(n))).
%F A393915 Sum_{n>=0} a(n)*x^n/(n!)^2 = B(x)*C(x) where B(x) = Sum_{n>=0} x^n/(n!)^2 and C(x) = Sum_{n>=0} binomial(2*n,n)*x^n/n!. - _Paul D. Hanna_, May 12 2026
%F A393915 a(n) = hypergeom([1/2, -n, -n], [1], 4). - _Peter Luschny_, May 12 2026
%p A393915 a := n -> hypergeom([1/2, -n, -n], [1], 4): seq(simplify(a(n)), n = 0..18);  # _Peter Luschny_, May 12 2026
%t A393915 Table[Sum[Binomial[n, k]^2 * Binomial[2*k, k] * k!, {k, 0, n}], {n, 0, 20}]
%Y A393915 Cf. A002893, A336293.
%K A393915 nonn,new
%O A393915 0,2
%A A393915 _Vaclav Kotesovec_, May 12 2026
