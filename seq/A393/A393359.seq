%S A393359 1,2,3,12,5,60,7,840,504,7560,11,0,13,360360,2522520,10810800,17,0,19,
%T A393359 0,465585120,349188840,23,0,1062600,8923714800,57366738000,
%U A393359 14456417976000,29,0,31,6498159880212000,5662884427200,4760556688800,15200373988800,0,37,102748681866600,485721041551200,0
%N A393359 a(n) is the number of ways to successively choose subsets of sizes equal to the proper divisors of n from [n], each choice taken from the remaining elements.
%C A393359 If the sum of the proper divisors of n exceeds n (i.e., n is abundant), the process cannot be completed and a(n) = 0.
%C A393359 Equivalently, for sigma(n) <= 2n, a(n) is the number of ordered set partitions of [n] into parts of sizes equal to the proper divisors of n together with one additional part of size n minus their sum.
%C A393359 For perfect n, the remainder part has size 0 and a(n) = n!/Product_{d|n, d<n} d!. Thus perfect numbers are exactly those n for which the selection process exhausts [n] without remainder.
%H A393359 Felix Huber, <a href="/A393359/b393359.txt">Table of n, a(n) for n = 1..1364</a>
%F A393359 a(n) = 0 if sigma(n) > 2*n, otherwise:
%F A393359   a(n) = Product_{i=1..tau(n)-1} binomial(n - Sum_{j=1..i-1} d_j, d_i), where d_1 > ... > d_{tau(n)-1} are the proper divisors of n.
%F A393359   a(n) = n!/((2*n - sigma(n))!*Product_{d|n, d<n} d!).
%F A393359 a(p) = p for primes p.
%e A393359 a(6) = binomial(6, 3)*binomial(3, 2)*binomial(1, 1) = 60 (perfect).
%e A393359 a(10) = binomial(10, 5)*binomial(5, 2)*binomial(3, 1) = 7560 (deficient).
%e A393359 a(11) = binomial(11, 1) = 11 (prime).
%e A393359 a(12) = 0 since sigma(12) = 28 > 24 (abundant).
%p A393359 A393359 := proc(n)
%p A393359     local d, k, m, a;
%p A393359     d := NumberTheory:-Divisors(n);
%p A393359     m := n;
%p A393359     a := 1;
%p A393359     for k from nops(d) - 1 by -1 to 1 do
%p A393359         m := m - d[k];
%p A393359         if m < 0 then return 0 end if;
%p A393359         a := a*binomial(m + d[k], d[k])
%p A393359     end do;
%p A393359     a
%p A393359 end proc:
%p A393359 seq(A393359(n), n = 1 .. 40);
%Y A393359 Cf. A000005, A000203, A007318, A007837, A023645, A027750, A038041.
%K A393359 nonn,new
%O A393359 1,2
