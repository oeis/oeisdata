%N A393660 Expansion of (1/x) * Series_Reversion( x * ( Sum_{k=0..5} (-x)^k )^3 ).
%H A393660 Vincenzo Librandi, <a href="/A393660/b393660.txt">Table of n, a(n) for n = 0..1000</a>
%F A393660 G.f.: (1/x) * Series_Reversion( x * ((1-x^6) / (1+x))^3 ).
%F A393660 a(n) = (1/(n+1)) * Sum_{k=0..floor(n/6)} binomial(3*n+k+2,k) * binomial(3*n+3,n-6*k).
%t A393660 CoefficientList[Normal@Series[InverseSeries@Series[x*((1-x^6)/(1+x))^3,{x,0,50}]/x,{x,0,20}],x] (* _Vincenzo Librandi_, Mar 24 2026 *)
%o A393660 (PARI) a(n) = sum(k=0, n\6, binomial(3*n+k+2, k)*binomial(3*n+3, n-6*k))/(n+1);
%o A393660 (Magma) N := 25; R<x> := PowerSeriesRing(Rationals(), N+5); f:= x*((1-x^6)/(1+x))^3; g:= Reverse(f) div x; Coeffs := [Coefficient(g,i):i in [0..N]]; Coeffs; // _Vincenzo Librandi_, Mar 24 2026
