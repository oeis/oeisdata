%S A393748 1,2,3,6,15,44,125,568,2337,12650,78770,611952,4670612,53985322,
%T A393748 588296122,8476173572,136159829764,2789679854068,56580675586853,
%U A393748 1695358864944894,48760209017690780,1861276478642614456,77886241973352349297,4206052280136144958052,225888522329929627644590
%N A393748 Number of totally symmetric planar subpartitions of the size n pyramidal planar partition.
%C A393748 The planar partition having its subpartitions counted is:
%C A393748   n n-1 ... 2 1
%C A393748   n-1 n-2 ... 1
%C A393748   ... ...
%C A393748   2 1
%C A393748   1
%C A393748 A planar partition is said to be totally symmetric if it is invariant by the action of S_3.
%C A393748 The number of all subpartitions regardless of symmetry is given by A115965.
%C A393748 The number of symmetric subpartitions is given by A388969.
%C A393748 The number of cyclically symmetric subpartitions is given by A393786.
%H A393748 Ludovic Schwob, <a href="/A393748/b393748.txt">Table of n, a(n) for n = 0..34</a>
%e A393748 The a(4) = 15 totally symmetric planar subpartitions of the pyramidal planar partition of size 4 are:
%e A393748   Ø        1        21       22       22       311      321      321
%e A393748                     1        21       22       1        21       22
%e A393748                                                1        1        1
%e A393748 .
%e A393748   332      332      4111     4211     4211     4321     4321
%e A393748   311      321      1        2        22       311      321
%e A393748   21       21       1        1        1        21       21
%e A393748                     1        1        1        1        1
%o A393748 (Python)
%o A393748 def covers(l0, n, k):
%o A393748     L = [[]]
%o A393748     for i in range(min(k, (n-k-1)//2)+1):
%o A393748         L2 = []
%o A393748         b = l0[i] if i < len(l0) and l0[i] < k-i else k-i+1
%o A393748         b = min(b, n-k-2*i)
%o A393748         for l in L:
%o A393748             if i > 0:
%o A393748                 b2 = min(l[i-1]-1, b) if l[i-1]>0 else 0
%o A393748             else:
%o A393748                 b2 = b
%o A393748             for j in range(0, b2+1):
%o A393748                 l2 = l.copy()
%o A393748                 l2.append(j)
%o A393748                 L2.append(l2)
%o A393748         L = L2
%o A393748     return [tuple(l) for l in L]
%o A393748 def a(n):
%o A393748     t = tuple()
%o A393748     D = {t:1}
%o A393748     for k in range(n):
%o A393748         D2 = {}
%o A393748         for l in D:
%o A393748             for t in covers(l, n, k):
%o A393748                 if t in D2:
%o A393748                     D2[t] += D[l]
%o A393748                 else:
%o A393748                     D2[t] = D[l]
%o A393748         D = D2
%o A393748     return sum(D.values())
%o A393748 print([a(n) for n in range(15)])
%Y A393748 Cf. A005157, A115965, A388969, A393786.
%K A393748 nonn,new
