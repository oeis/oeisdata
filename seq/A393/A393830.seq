%N A393830 a(n) is the difference between the nearest upper and lower odd semiprime neighbors of prime(n), divided by 2.
%H A393830 James C. McMahon, <a href="/A393830/b393830.txt">Table of n, a(n) for n = 5..10000</a>
%F A393830 a(n) = (A393828(n) - A393829(n))/2.
%t A393830 a[n_]:=Module[{c=Prime[n]-2,cu=Prime[n]+2},While[PrimeOmega[c]!=2,c=c-2];While[PrimeOmega[cu]!=2,cu=cu+2];(cu-c)/2];Array[a,88,5] (* _James C. McMahon_, Mar 07 2026 *)
%o A393830 (PARI) \\ using the functions from the related sequences
%o A393830 a(n) = (a393828(n) - a393829(n))/2
