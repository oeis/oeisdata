%I A393324 #28 Apr 21 2026 15:20:39
%S A393324 2,5,13,103,709,5449,19609,1009457,9699667,380570173,9953878901,
%T A393324 127943760811,7146308038801,291915793384129,8911446124470821,
%U A393324 650891537300922833,28740108149817929593,1247748737866031606063
%N A393324 Smallest prime p such that omega(q^2 - p^2) = n where q is the next prime after p.
%e A393324 3^2 - 2^2 = 5 and omega(5) = 1 and no smaller prime has this property. So a(1) = 2.
%e A393324 7^2 - 5^2 = 24 and omega(24) = 2 and no smaller prime has this property. So a(2) = 5.
%e A393324 17^2 - 13^2 = 120 and omega(120) = 3 and no smaller prime has this property. So a(3) = 13.
%o A393324 (PARI) a(n)=forprime(p=2,+oo,my(q=nextprime(p+1),d=q^2-p^2,x=omega(d));if(x==n,return(p)))
%Y A393324 Cf. A000040, A001221, A069482.
%K A393324 nonn,more,new
%O A393324 1,1
