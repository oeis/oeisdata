%I A393851 #17 Apr 06 2026 05:46:37
%S A393851 1,1,6,78,1680,53280,2327976,134085168,9854198208,900703644480,
%T A393851 100279679084640,13365699196126464,2101710159460349568,
%U A393851 385070904484106218560,81325226013059329862400,19613807542113984574387200,5357757629116650614137214976,1645635585210454451039859802368,564682418034506683082149700814336
%N A393851 G.f. satisfies A(x) = x + x^2 * d^2/dx^2 A(x)^2/2.
%H A393851 Paul D. Hanna, <a href="/A393851/b393851.txt">Table of n, a(n) for n = 1..512</a>
%F A393851 G.f. A(x) = Sum_{n>=1} a(n)*x^n satisfies the following formulas.
%F A393851 (1) A(x) = x + x^2 * d^2/dx^2 A(x)^2/2.
%F A393851 (2) A(x) = x + x^2 * d/dx A(x)*A'(x).
%F A393851 (3) A(x) = x + x^2*A'(x)^2 + x^2*A(x)*A''(x).
%F A393851 (4) A(x) = x * (1 + x*A'(x)^2) / (1 - x^2*A''(x)).
%F A393851 (5) A(x) = Series_Reversion(x/F(x)) where F(x) is the g.f. of A393850 and satisfies [x^n] F(x)^(n+1) * (1 - n*(n+1)*x) = 0 for n >= 1.
%F A393851 (6) A(x) = x*F(A(x)) where F(x) is the g.f. of A393850 (as in formula (5)).
%F A393851 a(n) = n*(n-1)/2 * Sum_{k=1..n-1} a(k)*a(n-k) for n > 1 with a(1) = 1.
%F A393851 a(n) ~ c * n^(2*n) / exp(2*n), where c = 4.8172872967346422952549021571815013036382547844... - _Vaclav Kotesovec_, Apr 06 2026
%e A393851 G.f.: A(x) = x + x^2 + 6*x^3 + 78*x^4 + 1680*x^5 + 53280*x^6 + 2327976*x^7 + 134085168*x^8 + 9854198208*x^9 + ...
%e A393851 RELATED SERIES.
%e A393851 A(x)^2 = x^2 + 2*x^3 + 13*x^4 + 168*x^5 + 3552*x^6 + 110856*x^7 + 4788756*x^8 + 273727728*x^9 + ...
%e A393851 d/dx A(x)^2/2 = x + 3*x^2 + 26*x^3 + 420*x^4 + 10656*x^5 + 387996*x^6 + 19155024*x^7 + 1231774776*x^8 + ...
%e A393851 where A(x) = x + x^2 * d^2/dx^2 A(x)^2/2.
%e A393851 Let F(x) satisfy A(x/F(x)) = x and A(x) = x*F(A(x)), then F(x) is the g.f. A393850, which begins
%e A393851 F(x) = 1 + x + 5*x^2 + 62*x^3 + 1351*x^4 + 44054*x^5 + 1979334*x^6 + 116691252*x^7 + ... + A393850(n)*x^n + ...
%e A393851 where [x^n] F(x)^(n+1) * (1 - n*(n+1)*x) = 0 for n >= 1.
%o A393851 (PARI) {a(n) = my(A=x+x^2); for(i=1, n, A = x + x^2*deriv(deriv(A^2/2 +x^2*O(x^n)))); polcoef(GF=A, n)}
%o A393851 {upto(n) = a(n); Vec(GF)}
%o A393851 upto(25)
%Y A393851 Cf. A393850, A393629.
%K A393851 nonn,new
%O A393851 1,3
%A A393851 _Paul D. Hanna_, Mar 28 2026
