%I A393678 #6 Mar 26 2026 15:28:19
%S A393678 0,1,5,9,16,24,34,45,59,73,90,108,128,149,173,197,224,252,282,313,347,
%T A393678 381,418,456,496,537,581,625,672,720,770,821,875,929,986,1044,1104,
%U A393678 1165,1229,1293,1360,1428,1498,1569,1643,1717,1794,1872,1952,2033,2117
%N A393678 Lower (1/2,1/3) midsequence of (n^2) and ((n+1)^2); see Comments.
%C A393678 Suppose that s = (s(n)) and t = (t(n)) are sequences of numbers and h > 0 and k > 0. The lower (h, k)-midsequence of s and t is floor(h*s + k*t); the upper (h, k)-midsequence of s and t is ceiling(h*s + k*t).
%H A393678 <a href="/index/Rec#order_06">Index entries for linear recurrences with constant coefficients</a>, signature (1,1,0,-1,-1,1).
%F A393678 a(n) = a(n-1) + a(n-2) - a(n-4) - a(n-5) + a(n-6), with (a(0),...,a(5)) = (0, 1, 5, 9, 16, 24).
%F A393678 G.f.: -x*(1 + 4*x + 3*x^2 + 2*x^3)/((-1 + x)^3*(1 + x)*(1 + x + x^2)).
%e A393678 s = (n^2) = A000290 = (0, 1, 4, 9, 16, 25, 36, ...).
%e A393678 t = ((n+1)^2) = (1, 4, 9, 16, 25, 36, 49, 64, ...).
%e A393678 u(n) = (0, 1, 5, 9, 16, 24, 34, 45, 59, 73, 90, 108, ...).
%e A393678 v(n) = (1, 2, 5, 10, 17, 25, 35, 46, 59, 74, 91, 109, ...).
%t A393678 f[n_] := n^2; g[n_] := (n+1)^2; r = 1/2; s = 1/3;
%t A393678 u[n_] := Floor[r*f[n] + s*g[n]];
%t A393678 v[n_] := Ceiling[r*f[n] + s*g[n]];
%t A393678 Table[u[n], {n, 0, 50}]   (* A393678 *)
%t A393678 Table[v[n], {n, 0, 50}]   (* A393679 *)
%t A393678 (* Also *)
%t A393678 LinearRecurrence[{1,1,0,-1,-1,1}, {0, 1, 5, 9, 16, 24}, 50]    (* A393678 *)
%t A393678 LinearRecurrence[{2,-1,0,0,0,1,-2,1}, {1,2,5,10,17,25,35,46}, 50]    (* A393679 *)
%Y A393678 Cf. A000290, A000578, A393679, A393680.
%K A393678 nonn,easy,new
%O A393678 0,3
%A A393678 _Clark Kimberling_, Mar 19 2026
