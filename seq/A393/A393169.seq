%U A393169 2942769446256640000,-94279187753194819375,0,353018122024352269610125,-40937838893267972784128000,3345548432456755080233803125
%N A393169 E.g.f. A(x) satisfies A(x)^6 = 1 + 6*x*A(x).
%H A393169 Paul D. Hanna, <a href="/A393169/b393169.txt">Table of n, a(n) for n = 0..500</a>
%F A393169 E.g.f. A(x) = Sum_{n>=0} a(n)*x^n/n! satisfies the following formulas.
%F A393169 (1) A(x) = (1 + 6*x*A(x))^(1/6).
%F A393169 (2) A(x) = 1 / (1 - 6*x/A(x)^5)^(1/6).
%F A393169 (3) A( x/(1-6*x)^(5/6) ) = 1/(1 - 6*x)^(1/6).
%F A393169 (4) A(x) = (1/x)*Series_Reversion( x/(1 + 6*x)^(1/6) ).
%F A393169 (5) A(x) = ( x/Series_Reversion( x/(1 - 6*x)^(5/6) ) )^(1/5).
%F A393169 (6) [x^(n+1)] A(x)^(5*n) = 5*n*A008542(n)/(n+1)! for n >= 0, where A008542(n) = Product_{k=1..n-1} (6*k+1).
%F A393169 From _Seiichi Manyama_, Mar 22 2026: (Start)
%F A393169 a(n) = 6^n * n! * binomial((n+1)/6,n)/(n+1).
%F A393169 a(6*n+5) = 0. (End)
%e A393169 E.g.f.: A(x) = 1 + x - 3*x^2/2! + 16*x^3/3! - 91*x^4/4! + 21505*x^6/6! - 788480*x^7/7! + 22733865*x^8/8! - 566558720*x^9/9! + 10659501125*x^10/10! - 15604904436275*x^12/12! + ...
%e A393169 where A(x)^6 = 1 + 6*x*A(x) and A(x) = 1/(A(x)^5 - 6*x).
%e A393169 It is instructive to examine the coefficients in A(x)^n.
%e A393169 The table of coefficients of x^k/k! in A(x)^n begins
%e A393169   n =  1: [1,  1,  -3,   16,  -91,     0,  21505, ...];
%e A393169   n =  2: [1,  2,  -4,   14,    0, -1870,  56320, ...];
%e A393169   n =  3: [1,  3,  -3,    0,  165, -3840,  76545, ...];
%e A393169   n =  4: [1,  4,   0,  -20,  320, -4860,  71680, ...];
%e A393169   n =  5: [1,  5,   5,  -40,  405, -4480,  43225, 0, ...];
%e A393169   n =  6: [1,  6,  12,  -54,  384, -2730,      0, ...];
%e A393169   n =  7: [1,  7,  21,  -56,  245,     0, -45815, ...];
%e A393169   n =  8: [1,  8,  32,  -40,    0,  3080, -81920, ...];
%e A393169   n =  9: [1,  9,  45,    0, -315,  5760, -98415, ...];
%e A393169   n = 10: [1, 10,  60,   70, -640,  7290, -89600, ...];
%e A393169   n = 11: [1, 11,  77,  176, -891,  7040, -55055, 0, ...];
%e A393169   n = 12: [1, 12,  96,  324, -960,  4620,      0, ...];
%e A393169   n = 13: [1, 13, 117,  520, -715,     0,  65065, ...];
%e A393169   n = 14: [1, 14, 140,  770,    0, -6370, 125440, ...];
%e A393169   n = 15: [1, 15, 165, 1080, 1365,-13440, 164025, ...];
%e A393169   ...
%o A393169 (PARI) {a(n) = my(A = (1/x)*serreverse( x/(1 + 6*x + x*O(x^n))^(1/6) )); n!*polcoef(A,n)}
%o A393169 for(n=0,30,print1(a(n),", "))
