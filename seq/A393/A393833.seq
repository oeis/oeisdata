%I A393833 #24 Mar 14 2026 17:07:21
%S A393833 6,18,104,162,7502,46875,811246,140450,19026866
%N A393833 Least integer k having exactly 2n+2 divisors such that the sequence of its 2n+1 proper divisors modulo n is a palindrome.
%C A393833 Conjecture: for every integer n>=1, there always exists at least one integer k such that its proper divisors are palindromic modulo n.
%C A393833 The interest lies in studying the interaction between the prime factorization of k and the cycles of the multiplicative groups Z/n.
%C A393833 a(11) = 8591078, a(13) = 109836782, a(14) = 223492082, a(15) = 47642342, a(17) = 290818781, a(19) = 1135131371, a(23) = 666068821. - _Sean A. Irvine_, Mar 12 2026
%e A393833 -----------------------------------------------------------------
%e A393833 n      a(n)     Number of             patterns modulo n
%e A393833              proper divisors            (palindromes)
%e A393833 -----------------------------------------------------------------
%e A393833 1          6      3          [0,0,0]
%e A393833 2         18      5          [1,0,1,0,1]
%e A393833 3        104      7          [1,2,1,2,1,2,1]
%e A393833 4        162      9          [1,2,3,2,1,2,3,2,1]
%e A393833 5       7502     11          [1,2,1,2,1,2,1,2,1,2,1]
%e A393833 6      46875     13          [1,3,5,3,1,3,5,3,1,3,5,3,1]
%e A393833 7     811246     15          [1,2,1,2,1,2,1,2,1,2,1,2,1,2,1]
%e A393833 8     140450     17          [1,2,5,2,1,2,5,2,1,2,5,2,1,2,5,2,1]
%e A393833 9   19026866     19          [1,2,1,2,1,2,1,2,1,2,1,2,1,2,1,2,1,2,1]
%e A393833 a(9) = 19^4*37^3, 19==1 (mod 9), 37==1 (mod 9).
%p A393833 with(numtheory):
%p A393833 with(ListTools):
%p A393833 get_an := proc(n)
%p A393833     local k, divs, props, mods, target_divs;
%p A393833         target_divs := 2*n + 2;
%p A393833         for k from 2 do
%p A393833         divs := divisors(k);
%p A393833            if nops(divs) = target_divs then
%p A393833             props := [op(1..nops(divs)-1, divs)];
%p A393833             mods := map(x -> x mod n, props);
%p A393833              # Test of the palindrome
%p A393833             if mods = Reverse(mods) then
%p A393833                 # printf("Pour n = %d, a(n) = %d\n", n, k);
%p A393833                 # printf("Suite mod %d : %a\n", n, mods);
%p A393833                 return k;
%p A393833             fi;
%p A393833         fi;
%p A393833     od:
%p A393833 end proc:
%p A393833 # n from 2 to 9
%p A393833 for i from 2 to 9 do
%p A393833     get_an(i);
%p A393833 od:
%o A393833 (PARI) isok(k, n) = if (numdiv(k) == (2*n+2), my(v=apply(x->Mod(x, n), setminus(divisors(k), Set(k)))); v == Vecrev(v));
%o A393833 a(n) = my(k=1); while (!isok(k, n), k++); k; \\ _Michel Marcus_, Mar 05 2026
%Y A393833 Cf. A000005, A032741.
%K A393833 nonn,more,new
%O A393833 1,1
%A A393833 _Michel Lagneau_, Mar 01 2026
%E A393833 a(9) corrected by _Michel Marcus_, Mar 05 2026
