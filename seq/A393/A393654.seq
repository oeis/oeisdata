%S A393654 0,2,2,0,0,0,0,0,12,8,0,10,16,14,8,4,12,36,48,72,36,0,0,0,210,240,162,
%T A393654 72,2,8,180,360,884,884,530,212,0,50,160,798,1368,3744,3328,1452,528,
%U A393654 4,20,300,800,5964,8946,14950,11960,4314,1438,0,40,160,3626,8288,31320,41760,57904,42112,12402,3816
%N A393654 Triangle read by rows: T(n,k), for n >= 4 and 3 <= k < n, is the number of irreducible meanders with n intersections and k tangential intersections.
%C A393654 An irreducible meander is a type of singular meander that has no nontrivial submeanders.
%H A393654 Yury Belousov, <a href="/A393654/b393654.txt">Rows n = 5..19, with 3 <= k < n, flattened</a>.
%H A393654 Yury Belousov, <a href="http://ftp.pdmi.ras.ru/pub/publicat/znsl/v549/p049.pdf">Singular meanders</a>, Zap. Nauchn. Sem. POMI, 549 (2025), 49-64.
%H A393654 Yury Belousov, <a href="https://arxiv.org/abs/2112.10289">Prime Factorization of Meanders</a>, arXiv:2112.10289 [math.CO], 2025.
%H A393654 Yury Belousov, <a href="https://github.com/YuryBelousov/meander_factorization">C++ code for generating the sequence</a>, GitHub.
%F A393654 T(n, k) = 0 for k < 3 and for k = n;
%F A393654 T(2*m, 3) = 0 for m >= 2;
%F A393654 T(2*m+1, 3) = phi(m+3) - 2 for m >= 1, where phi(x) is Euler's totient function;
%F A393654 T(2*m+1, 4) = (m-1)*(phi(m+3) - 2) for m >= 2;
%F A393654 Sum_{k >= 0} T(k+1, k)*t^k = (1/8)*(-1 + ((1 - 3*t)/(1 + t))^(1/2))^4;
%F A393654 Sum_{k >= 0} T(k+2, k)*t^k = -(2*t - 1 + ((1-3*t)/(1+t))^(1/2))/((1-3*t)*(1+t)^5)^(1/2).
%e A393654 The triangle T(n,k), n >= 4, 3 <= k < n, begins:
%e A393654   0;
%e A393654   2, 2;
%e A393654   0, 0, 0;
%e A393654   0, 0, 12, 8;
%e A393654   0, 10, 16, 14, 8;
%e A393654   4, 12, 36, 48, 72, 36;
%e A393654   ...
%K A393654 nonn,tabl,hard,new
%O A393654 4,2
%A A393654 _Yury Belousov_, Mar 24 2026
