%N A393924 Numbers that are either squarefree or squareful.
%C A393924 Union of A001694 and A005117.
%C A393924 Complement of A332785.
%C A393924 Differs from A317101 where A317101 does not have 144=2^4*3^2. - _R. J. Mathar_, Mar 06 2026
%H A393924 Michael De Vlieger, <a href="/A393924/b393924.txt">Table of n, a(n) for n = 1..10000</a>
%F A393924 Sum_{n>=1} 1/a(n)^s = zeta(s)/zeta(2*s) + zeta(2*s)*zeta(3*s)/zeta(6*s) - 1 for s > 1. - _Amiram Eldar_, Mar 07 2026
%t A393924 Select[Range[120], Or[SquareFreeQ[#], Divisible[#, Apply[Times, FactorInteger[#][[All, 1]] ]^2] ] &]
%o A393924 (Python)
%o A393924 from math import isqrt
%o A393924 from sympy import integer_nthroot
%o A393924 from oeis_sequences.OEISsequences import squarefreepi
%o A393924 def A393924(n):
%o A393924     def f(x):
%o A393924         c, l = n+1+x-squarefreepi(x), 0
%o A393924         j = isqrt(x)
%o A393924         while j>1:
%o A393924             k2 = integer_nthroot(x//j**2,3)[0]+1
%o A393924             w = squarefreepi(k2-1)
%o A393924             c -= j*(w-l)
%o A393924             l, j = w, isqrt(x//k2**3)
%o A393924         c -= squarefreepi(integer_nthroot(x,3)[0])-l
%o A393924         return c
%o A393924     m, k = n, f(n)
%o A393924     while m != k: m, k = k, f(k)
%o A393924     return m # _Chai Wah Wu_, Mar 03 2026
%o A393924 (PARI) isok(k) = my(f=factor(k)); issquarefree(k) || (vecmin(f[,2]) >= 2); \\ _Michel Marcus_, Mar 04 2026
%o A393924 (PARI) lista(len)= my(a=List(), i=0); while(#a<len, if(issquarefree(i++) || vecmin(factor(i)[, 2])>1, listput(~a, i))); Vec(a); \\ _Ruud H.G. van Tol_, Mar 04 2026
%Y A393924 Cf. A001694, A005117, A332785.
%K A393924 nonn,easy,new
