%I A393604 #23 Mar 23 2026 11:00:14
%S A393604 2,3,4,5,6,7,8,9,10,15,16,21,25,27,28,35,36,49,50,64,81,126,135,225,
%T A393604 245,525,686,875,1029,1728,2048,2401,2430,3125,3136,4000,4375,5120,
%U A393604 6144,10976,15625,16875,19683,32805,65536,118098,250047,321489,390625,458752,589824
%N A393604 Greater of two consecutive 7-smooth numbers that are coprime.
%H A393604 Michael S. Branicky, <a href="/A393604/b393604.txt">Table of n, a(n) for n = 1..316</a> (terms 1..234 from Michael De Vlieger, 235..255 from Chai Wah Wu)
%e A393604 Let s = A002473 and b = A393603.
%e A393604 Table of n, b(n), and a(n) for select n:
%e A393604  n          b(n)           a(n)
%e A393604 ------------------------------------------
%e A393604  1    s(1) =  1 = 1          2 = 2
%e A393604  2    s(2) =  2 = 2          3 = 3
%e A393604  3    s(3) =  3 = 3          4 = 2^2
%e A393604  4    s(4) =  4 = 2^2        5 = 5
%e A393604  5    s(5) =  5 = 5          6 = 2   * 3
%e A393604 10   s(12) = 14 = 2   * 7   15 = 3   * 5
%e A393604 11   s(13) = 15 = 3   * 5   16 = 2^4
%e A393604 12   s(16) = 20 = 2^2 * 5   21 = 3   * 7
%e A393604 13   s(18) = 24 = 2^3 * 3   25 = 5^2
%e A393604 17   s(24) = 35 = 5   * 7   36 = 2^2 * 3^2
%t A393604 s = Block[{nn = 600000}, Flatten@ Table[2^a * 3^b * 5^c * 7^d, {a, 0, nn}, {b, 0, Log[3, nn/2^a]}, {c, 0, Log[5, n/(2^a * 3^b)]}, {d, 0, Log[7, n/(2^a * 3^b * 5^c)] } ] ]; Select[Partition[s, 2, 1], CoprimeQ @@ # &][[All, -1]]
%o A393604 (Python) # uses code/imports in A002473
%o A393604 from math import gcd
%o A393604 from itertools import count, islice, pairwise
%o A393604 def agen(): yield from (g for l, g in pairwise(A002473gen()) if gcd(l, g) == 1)
%o A393604 print(list(islice(agen(), 51))) # _Michael S. Branicky_, Mar 21 2026
%Y A393604 Cf. A002473, A353576, A393603.
%K A393604 nonn
%O A393604 1,1
%A A393604 _Michael De Vlieger_, Feb 24 2026
