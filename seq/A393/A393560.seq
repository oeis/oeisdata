%I A393560 #35 Mar 29 2026 15:49:40
%S A393560 2,3,2,23,19,11,41,47,17,179,43,167,233,83,29,479,67,107,227,79,41,
%T A393560 131,229,191,449,103,701,167,173,59,2789,127,263,1019,349,71,887,227,
%U A393560 233,479,163,251,257,263,359,1931,1409,863,587,499,101,311,953,107,2309,223,797,347,353,479,3659
%N A393560 a(n) is the smallest prime p for which ((n+1)*p + 1)/n is also prime.
%H A393560 Robert Israel, <a href="/A393560/b393560.txt">Table of n, a(n) for n = 1..10000</a>
%e A393560 a(1) = 2 because prime 2 and ((1+1)*2 + 1)/1 = 5 is also prime;
%e A393560 a(2) = 3 because prime 3 and ((2+1)*3 + 1)/2 = 5 is also prime;
%e A393560 a(3) = 2 because prime 2 and ((3+1)*2 + 1)/3 = 3 is also prime.
%p A393560 f:= proc(n) local p0,d,p;
%p A393560    if n::even then p0:= n-1; d:= n
%p A393560    else p0:= 2*n-1; d:= 2*n
%p A393560    fi;
%p A393560    for p from p0 by d do
%p A393560      if isprime(p) and isprime(((n+1)*p+1)/n) then return p fi
%p A393560    od
%p A393560 end proc: f(1):= 2: f(3):= 2:
%p A393560 map(f, [$1..100]); # _Robert Israel_, Mar 23 2026
%t A393560 a[n_] := Module[{p = 2}, While[! PrimeQ[((n + 1)*p + 1)/n], p = NextPrime[p]]; p]; Array[a, 60] (* _Amiram Eldar_, Mar 23 2026 *)
%Y A393560 Cf. A005384, A158709, A158721, A394311.
%Y A393560 Cf. A038700 (((n+1)*p + 1)/n is an integer).
%K A393560 nonn
%O A393560 1,1
%A A393560 _Juri-Stepan Gerasimov_, Mar 22 2026
