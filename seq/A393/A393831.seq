%U A393831 4497538518542272,91466606592215713,1949700995818868550,43473246452284266217,1012094032318938813700,24559509943397268789885,620193897540379196963560
%N A393831 Number of derangements p of n points on a circle such that if x is next to y, then p(x) is not next to p(y).
%C A393831 Also the number of ways of seating n people around a table for the second time without anyone sitting next to the same person or sitting in the same seat. Bounded above by A089222 and A288208.
%C A393831 Conjecture: series for log(a(n)/n!) begins with -3 - 5/n - 11/n^2 - ...
%H A393831 Liam Courtright, <a href="/A393831/b393831.txt">Table of n, a(n) for n = 0..27</a>
%e A393831 For n=6 the a(6)=12 solutions are (in one-line notation) 246315, 251364, 264135, 314625, 352641, 415362, 462531, 514263, 536241, 631524, 635142, 642513. Coincidentally, these are all 6-cycles; compare with e.g. the n=7 solution 2461375=(142)(3576) or e.g. the n=8 solution 27513846=(1472)(35)(68).
%o A393831 (PARI)
%o A393831 { A393831(n) = my(A = matrix(n, n, i, j, abs(i-j)>1 && abs(i-j)!=n-1)); parsum(s=1, 2^n-1, my(M=vecextract(A, s, s), d=matsize(M)[1], v=matid(d), pos=0); for(k=0, n-1, if(bitand(s>>k, 1), pos++; for(m=1,d,v[pos,m]=0)); v=M*v); (-1)^(n-d)*trace(v) ); } \\ assumes n>0, modified from PARI code for A288208 by _Max Alekseyev_
%o A393831 (C++)
%o A393831 int64_t a(int n) { // assumes n>0
%o A393831     int c[n];
%o A393831     for (int i = 0; i < n; i++) {
%o A393831         c[i] = i;
%o A393831     }
%o A393831     int64_t r = 0;
%o A393831     int w;
%o A393831     int k;
%o A393831     bool s = true;
%o A393831     while (s) {
%o A393831         w = -1;
%o A393831         for (int i = 0; i < n; i++) {
%o A393831             if (c[i] == i) {
%o A393831                 w = i;
%o A393831                 break;
%o A393831             }
%o A393831             k = abs(c[i==n-1 ? 0 : i+1] - c[i]);
%o A393831             if (k == 1 || k == n-1) {
%o A393831                 w = (i==n-1 ? i : i+1);
%o A393831                 break;
%o A393831             }
%o A393831         }
%o A393831         if (w == -1) {
%o A393831             r++;
%o A393831         }
%o A393831         else {
%o A393831             std::sort(c+w+1,c+n);
%o A393831             std::reverse(c+w+1,c+n);
%o A393831         }
%o A393831         s = std::next_permutation(c,c+n);
%o A393831     }
%o A393831     return r;
%o A393831 }
%Y A393831 Cf. A288208, A000166, A002464, A089222.
