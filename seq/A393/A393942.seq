%S A393942 7,9,14,18,29,58,8653,16288,17306,20360,24432,30540,33550337,67100674,
%T A393942 137438691329,183248814085,274877382658,274877415424,275951155328,
%U A393942 292057253888,293198102536,343596769280,344938944160,365071567360,366497628170,412316123136,413926732992
%N A393942 Numbers m such that phi(m) is a perfect number (A000396).
%C A393942 Corresponding values of phi(m): 6, 6, 6, 6, 28, 28, 8128, 8128, 8128, 8128, 8128, 8128, ...
%C A393942 Conjecture: number m = 18 is the only number such that tau(m) and phi(m) are both perfect numbers.
%C A393942 Conjecture is false: with m = 2^61 * 17 * 65537 * ((2^2281-1)*2^2200+1), tau(m) and phi(m) are both perfect numbers. - _Michel Marcus_, Mar 12 2026
%H A393942 Michel Marcus, <a href="/A393942/b393942.txt">Table of n, a(n) for n = 1..338</a>
%H A393942 factordb, <a href="https://factordb.com/index.php?id=1100000000764174646">(2^2281-1)*2^2200+1</a>.
%e A393942 Number 18 is in the sequence because phi(18) = 6 (perfect number).
%t A393942 Select[Range[10^5], DivisorSigma[-1, EulerPhi[#]] == 2 &] (* _Amiram Eldar_, Mar 03 2026 *)
%o A393942 (Magma) [m: m in [1..10^6] | &+Divisors(EulerPhi(m)) eq 2 * EulerPhi(m)];
%o A393942 (PARI) isok(m) = my(t=eulerphi(m)); sigma(t) == 2*t; \\ _Michel Marcus_, Mar 12 2026
%o A393942 (PARI) lista() = my(list=List(), v=select(x->ispseudoprime(2^x-1), primes(111))); for (i=1, #v, my(p = v[i], w = invphi(2^(p-1)*(2^p - 1))); for (j=1, #w, listput(list, w[j]));); Vec(list); \\ _Michel Marcus_, Mar 12 2026
