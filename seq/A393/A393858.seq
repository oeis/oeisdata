%I A393858 #10 Mar 12 2026 10:39:34
%S A393858 1,1,8,323,71744,93490314,727730885904,33959564479215663,
%T A393858 9506844256155307363184,15967952298182575739616638918,
%U A393858 160920360619184154438348221909038160,9730240939147953721887778948650331100790526,3530102903116927033293337372253488902802779616465216
%N A393858 G.f. A(x) satisfies: A( x - x*A(6*x)/6 ) = x.
%C A393858 Conjecture: a(n) is odd iff n is a power of 2.
%C A393858 Conjecture: a(n) == 1 (mod 7) for n >= 1.
%H A393858 Paul D. Hanna, <a href="/A393858/b393858.txt">Table of n, a(n) for n = 1..80</a>
%F A393858 G.f. A(x) = Sum_{n>=1} a(n)*x^n satisfies the following formulas.
%F A393858 (1) A( x - x*A(6*x)/6 ) = x.
%F A393858 (2) A(x) = INV(x - x*INV(x - 6*x*INV(x - 6^2*x*INV(x - 6^3*x*INV(x - 6^4*x*INV(x - ...)))))), where INV(F(x)) = series reversion of F(x).
%F A393858 (3) A(x) = x + Sum_{n>=1} d^(n-1)/dx^(n-1) x^n * (A(6*x)/6)^n / n!.
%F A393858 (4) A(x) = x * exp( Sum_{n>=1} d^(n-1)/dx^(n-1) x^(n-1) * (A(6*x)/6)^n / n! ).
%e A393858 G.f.: A(x) = x + x^2 + 8*x^3 + 323*x^4 + 71744*x^5 + 93490314*x^6 + 727730885904*x^7 + 33959564479215663*x^8 + ...
%e A393858 The g.f. A(x) results from infinitely nested series reversions as shown below.
%e A393858 Series_Reversion(A(x)) = x - x*B(x) where
%e A393858 B(x) = x + 6*x^2 + 288*x^3 + 69768*x^4 + 92980224*x^5 + 726980681664*x^6 + ...
%e A393858 Series_Reversion(B(x)) = x - 6*x*C(x) where
%e A393858 C(x) = x + 36*x^2 + 10368*x^3 + 15069888*x^4 + 120502370304*x^5 + ...
%e A393858 Series_Reversion(C(x)) = x - 6^2*x*D(x) where
%e A393858 D(x) = x + 216*x^2 + 373248*x^3 + 3255095808*x^4 + 156171071913984*x^5 + ...
%e A393858 Series_Reversion(D(x)) = x - 6^3*x*E(x) where
%e A393858 E(x) = x + 1296*x^2 + 13436928*x^3 + 703100694528*x^4 + 202397709200523264*x^5 + ...
%e A393858 ...
%o A393858 (PARI) {a(n,k=6) = my(A=x); for(i=1, n, A = serreverse(x - x*subst(A, x, k*x)/k +x*O(x^n)); ); polcoef(GF=A, n)}
%o A393858 {upto(n,k=6) = a(n,k); Vec(GF)}
%o A393858 upto(20)
%o A393858 (PARI) {a(n,k=6) = my(A=x+x^2); for(j=0, n, A = serreverse(x - k^(n-j)*x*A + x*O(x^n))); polcoef(GF=A, n)}
%o A393858 {upto(n,k=6) = a(n,k); Vec(GF)}
%o A393858 upto(20)
%Y A393858 Cf. A000108 (k=0), A088714 (k=1), A195195 (k=2), A195196 (k=3).
%Y A393858 Cf. A393856 (k=4), A393857 (k=5), A393859 (k=7).
