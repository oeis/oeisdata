%I A393998 #8 Mar 13 2026 16:37:22
%S A393998 0,27,51,72,147,156,198,246,126,252,294,249,282,282,273,270,282,267,
%T A393998 321,327,336,396,324,414,318,375,519,510,498,651,651,651,405,429,708,
%U A393998 483,564,690,420,375,729,729,603,639,336,660,567,759,375,579,618,645,621,633,708,666,507,672,423,954
%N A393998 a(n) is the least y such that A393978(n)^2 - y^2 is an anagram of y^2.
%C A393998 All terms are divisible by 3.
%H A393998 Robert Israel, <a href="/A393998/b393998.txt">Table of n, a(n) for n = 1..10000</a>
%F A393998 A004186(A393978(n)^2 - a(n)^2) = A004186(a(n)^2).
%e A393998 a(7) = 198 because A393978(7) = 264 and 264^2 = 198^2 + 30492, where 30492 is an anagram of 198^2 = 39204, and 198 is the least number that works.
%p A393998 # given a list of the first N terms of A393978, for some N
%p A393998 f:= proc(x) local s,d,y0,y,r,L;
%p A393998      s:= x^2;
%p A393998      d:= ilog10(s/2)+1;
%p A393998      y0:= ceil(sqrt(max(10^(d-1),s-10^d)));
%p A393998      y0:= 3*ceil(y0/3);
%p A393998      for y from y0 by 3 do
%p A393998        if y^2 >= 10^d then return FAIL fi;
%p A393998        L:= sort(convert(y^2,base,10));
%p A393998        r:= x^2 - y^2;
%p A393998        if r < 10^(d-1) then next fi;
%p A393998        if sort(convert(r,base,10)) = L then return y fi
%p A393998      od
%p A393998 end proc:
%p A393998 f(0):= 0:
%p A393998 map(f, A393978);
%Y A393998 Cf. A004186, A393978, A394001.
%K A393998 nonn,base
%O A393998 1,2
%A A393998 _Robert Israel_, Mar 06 2026
