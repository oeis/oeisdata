%N A393881 O.g.f. A(x) satisfies [x^n] exp( n^8*x - n*A(x) ) = 0 for n >= 1.
%H A393881 Paul D. Hanna, <a href="/A393881/b393881.txt">Table of n, a(n) for n = 1..201</a>
%F A393881 B(x) = x + (1/(m+1)) * A((m+1)^8 * x^(m+1)) satisfies [x^n] exp(n*x*(1+n^7*x^m) - n*B(x) ) = 0 for n >= 1. - _Seiichi Manyama_, Apr 09 2026
%F A393881 a(n) ~ sqrt(1-c) * 8^(8*n - 1) * n^(7*n - 3/2) / (sqrt(2*Pi) * (8-c)^(7*n - 1) * c^n * exp(7*n)), where c = -LambertW(-8*exp(-8)). - _Vaclav Kotesovec_, Apr 09 2026
%e A393881 O.g.f.: A(x) = x + 16129*x^2 + 15563242302*x^3 + 191052153489802826*x^4 + 15081298564187890612096820*x^5 + 5171552655308185041350838724425732*x^6 + ...
%e A393881 ILLUSTRATION OF DEFINITION.
%e A393881 The table of coefficients of x^k/k! in exp( n^8*x - n*A(x) ) begins
%e A393881   n = 1: [1,      0,       -32258,      -93379453812, ...];
%e A393881   n = 2: [1,    254,            0,     -186791681752, ...];
%e A393881   n = 3: [1,   6558,     42910590,                 0, ...];
%e A393881   n = 4: [1,  65532,   4294313992,   281024555258448, 0, ...];
%e A393881   n = 5: [1, 390620, 152583823110, 59601700079759540, 23258068857768686288380, 0, ...]; ...
%e A393881 in which a diagonal, the coefficient of x^n in row n, is all zeros.
%e A393881 RELATED SERIES.
%e A393881 exp(A(x)) = 1 + x + 32259*x^2/2! + 93379550587*x^3/3! + 4585252060395012313*x^4/4! + 1809755850658928585842171641*x^5/5! + 3723517922682734127904060798909975051*x^6/6! + ...
%e A393881 where [x^n] exp(n^8*x) / exp(A(x))^n = 0 for n >= 1.
%o A393881 (PARI) {a(n,p=8,q=1) = my(A=[0], m); for(i=1, n+1, m=#A; A=concat(A, 0); A[m+1] = Vec( exp(m^p*x - m^q*Ser(A)) )[m+1]/(m^q) ); polcoef( Ser(A), n)}
%o A393881 for(n=1, 15, print1(a(n,8,1), ", "))
%Y A393881 Below, sequences with the parameters (p,q) indicated have an o.g.f. F(x) satisfying [x^n] exp( n^p*x - n^q*F(x) ) = 0 for n >= 1.
