%e A393607 For m=3, the primes p such that p (mod 3) = 2 are 2,5,11,17,23,29,41,..., as in row 3.
%t A393607 t = Prime[Table[Take[Select[Range[500], Mod[Prime[#], n] == n - 1 &], 20], {n, 1, 20}]];
%t A393607 Grid[t]  (* array *)
%t A393607 v[n_, k_] := t[[n]][[k]];
%t A393607 Table[v[n - k + 1, k], {n, 12}, {k, n, 1, -1}] // Flatten (* sequence *)
