%e A393606 For m=3, the primes p such that (p mod 3) = 2 are 2,5,11,17,23,29,41,..., indexed by 1,3,5,7,9,10,13, as in row 3.
%t A393606 t = Table[Take[Select[Range[500], Mod[Prime[#], n] == n - 1 &], 20], {n, 1, 20}];
%t A393606 Grid[t]  (* array *)
%t A393606 v[n_, k_] := t[[n]][[k]];
%t A393606 Table[v[n - k + 1, k], {n, 12}, {k, n, 1, -1}] // Flatten (* sequence *)
