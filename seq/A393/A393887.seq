%N A393887 O.g.f. A(x) satisfies: [x^n] exp( n^8*x - n^7*A(x) ) = 0 for n >= 1.
%H A393887 Paul D. Hanna, <a href="/A393887/b393887.txt">Table of n, a(n) for n = 1..201</a>
%e A393887 O.g.f.: A(x) = x + 64*x^2 + 6097356*x^3 + 14466433875968*x^4 + 312747515408352500000*x^5 + 36841286348255273884142017536*x^6 + ...
%e A393887 ILLUSTRATION OF DEFINITION.
%e A393887 The table of coefficients of x^k/k! in exp( n^8*x - n^7*A(x) ) begins
%e A393887   n = 1: [1,      0,        -128,         -36584136, ...];
%e A393887   n = 2: [1,    128,           0,       -4686963712, ...];
%e A393887   n = 3: [1,   4374,    18851940,                 0, ...];
%e A393887   n = 4: [1,  49152,  2413821952,   117838623670272, 0, ...];
%e A393887   n = 5: [1, 312500, 97646250000, 30505344989375000, 9500186856013810000000, 0, ...]; ...
%e A393887 in which a diagonal, the coefficient of x^n in row n, is all zeros.
%e A393887 RELATED SERIES.
%e A393887 exp(A(x)) = 1 + x + 129*x^2/2! + 36584521*x^3/3! + 347194559409697*x^4/4! + 37529703585021558898641*x^5/5! + 26525726395922693496057051288481*x^6/6! + ...
%e A393887 where [x^n] exp(n^8*x) / exp(A(x))^(n^7) = 0 for n >= 1.
%o A393887 (PARI) {a(n,p=8,q=7) = my(A=[0], m); for(i=1, n+1, m=#A; A=concat(A, 0); A[m+1] = Vec( exp(m^p*x - m^q*Ser(A)) )[m+1]/(m^q) ); polcoef( Ser(A), n)}
%o A393887 for(n=1, 15, print1(a(n,8,7), ", "))
%Y A393887 Below, sequences with the parameters (p,q) indicated have an o.g.f. F(x) satisfying [x^n] exp( n^p*x - n^q*F(x) ) = 0 for n >= 1.
