%S A393710 0,0,0,0,0,0,0,1,0,1,0,1,0,2,0,1,2,1,0,3,0,2,2,1,1,4,0,1,3,3,0,4,1,3,
%T A393710 3,1,2,5,0,3,3,4,0,4,3,3,5,1,1,8,0,4,4,3,2,4,3,5,4,3,2,8,0,2,8,4,2,6,
%U A393710 1,6,4,4,3,8,3,2,8,3,1,9,1,10,4,1,4,8
%N A393710 a(n) = number of triples (x, y, z) such that x^2 + y*z = n, where x, y, z are positive integers satisfying x < y < z.
%C A393710 Conjecture: each nonnegative positive integer occurs only finitely many times.
%e A393710 a(86) = 4 counts these triples: (1, 5, 17), (3, 7, 11), (4, 5, 14), (4, 7, 10).
%e A393710 Conjecture: a(1722) = 0 and a(n) > 0 for n > 1722; a(1482) = 1 and a(n) != 1 for n > 1482.
%t A393710 t[n_, c_] := Module[{r}, r = Flatten[Table[If[n - x^2 <= 0, {},
%t A393710        Map[({x, #, Quotient[n - x^2, #]} &),
%t A393710         Select[Divisors[n - x^2], Divisible[n - x^2, #] &]]], {x, 1,
%t A393710        Floor[Sqrt[n - 1]]}], 1]; Select[r, Apply[c, #] &]];
%t A393710 c = (#1 < #2 && #2 < #3 &); Table[{n, t[n, c]}, {n, 1, 30}]
%t A393710 Join[{0}, Table[Length[t[n, c]], {n, 1, 130}]]
