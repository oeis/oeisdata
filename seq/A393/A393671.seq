%I A393671 #14 Mar 04 2026 14:02:39
%S A393671 1,0,1,1,0,1,0,2,0,1,1,1,0,2,1,1,2,1,2,2,3,1,3,2,3,1,4,1,3,2,4,3,4,4,
%T A393671 4,3,5,4,4,6,4,5,6,6,6,6,6,8,7,7,10,9,6,11,9,10,10,13,8,13,11,17,10,
%U A393671 18,14,13,17,18,14,19,17,19,18,24,21,20,23,24,22
%N A393671 a(n) = number of partitions of n into distinct prime parts, no two of which are adjacent primes.
%H A393671 Alois P. Heinz, <a href="/A393671/b393671.txt">Table of n, a(n) for n = 0..10000</a>
%e A393671 a(24) counts these 3 partitions of 24: 19+5 = 17+7 = 17+5+2.
%p A393671 b:= proc(n, i) option remember; `if`(n=0, 1, `if`(i<1, 0,
%p A393671       b(n, i-1)+`if`(ithprime(i)>n, 0, b(n-ithprime(i), i-2))))
%p A393671     end:
%p A393671 a:= n-> b(n, numtheory[pi](n)):
%p A393671 seq(a(n), n=0..100);  # _Alois P. Heinz_, Mar 03 2026
%t A393671 prt[n_, sL_] := Module[{m = Length[sL], f}, If[n > Last[sL], Return["Extend sL"]];
%t A393671 f[i_, r_, b_] := f[i, r, b] = Which[r == 0, {{}}, r < 0 || i == 0, {}, True,
%t A393671 Join[f[i - 1, r, False], If[! b && s[[i]] <= r, Map[Prepend[#, sL[[i]]] &,
%t A393671 f[i - 1, r - sL[[i]], True]], {}]]]; Reverse[f[m, n, False]]]
%t A393671 z = 100;
%t A393671 s = Array[Prime, z];
%t A393671 m = Map[{#, prt[#, s]} &, Range[z]]
%t A393671 u = Map[Last, m];
%t A393671 Map[Length, u]
%t A393671 (* _Peter J. C. Moses_, Jan 26 2026 *)
%Y A393671 Cf. A000040, A000586, A393672, A393673, A393674, A393675, A393676.
%K A393671 nonn
%O A393671 0,8
