%I A393923 #6 Mar 10 2026 18:05:11
%S A393923 1,2,3,8,5,6,7,64,27,10,11,72,13,14,15,1024,17,1296,19,200,21,22,23,
%T A393923 31104,125,26,729,392,29,30,31,32768,33,34,35,1119744,37,38,39,8000,
%U A393923 41,42,43,968,675,46,47,53747712,343,400000,51,1352,53,2902376448,55,21952
%N A393923 Product of numbers k <= n that have the same squarefree kernel as n.
%C A393923 Let rad = A007947; rad(n) | n for all n.
%C A393923 For squarefree n, a(n) = n.
%C A393923 For proper prime powers n = p^m (in A246547), a(p^m) = p^A000217(m), also a number in A246547.
%C A393923 For n in A126706, a(n) > n and a(n)/rad(n) >= n; a(n) is in A286708.
%C A393923 Thus, if n is nonsquarefree (in A013929), a(n) is powerful (in A001694). No terms are in A332785 as a consequence.
%C A393923 Analogous to A243103, with respect to A008479 and A369609 instead of A010846 and A162306.
%H A393923 Michael De Vlieger, <a href="/A393923/b393923.txt">Table of n, a(n) for n = 1..10000</a>
%H A393923 Michael De Vlieger, <a href="/A393923/a393923.png">Log log scatterplot of log a(n)/log 10</a>, n = 1..10^5.
%F A393923 a(n) is product of row n of A369609.
%F A393923 a(n) = A007947(n)^A008479(n) * Product_{i=1..A008479(n)} S(i), where S(i) is the i-th term in row n of A162306.
%e A393923 Table of n, a(n) for select n:
%e A393923    n       a(n)  factor(a(n))  row n of A369609
%e A393923   ------------------------------------------------
%e A393923    4         8 = 2^3           {2, 4}
%e A393923    8        64 = 2^6           {2, 4, 8}
%e A393923    9        27 = 3^3           {3, 9}
%e A393923   12        72 = 2^3 * 3^2     {6, 12}
%e A393923   16      1024 = 2^10          {2, 4, 8, 16}
%e A393923   18      1296 = 2^4 * 3^4     {6, 12, 18}
%e A393923   20       200 = 2^3 * 5^2     {10, 20}
%e A393923   24     31104 = 2^7 * 3^5     {6, 12, 18, 24}
%e A393923   25       125 = 5^3           {5, 25}
%e A393923   27       729 = 3^6           {3, 9, 27}
%e A393923   28       392 = 2^3 * 7^2     {14, 28}
%e A393923   32     32768 = 2^15          {2, 4, 8, 16, 32}
%e A393923   36   1119744 = 2^9 * 3^7     {6, 12, 18, 24, 36}
%t A393923 rad[x_] := Times @@ FactorInteger[x][[All,1]]; Table[r = rad[n]; Times @@ Select[Range[n], rad[#] == r &], {n, 120}]
%Y A393923 Cf. A000217, A001694, A005117, A007947, A008479, A013929, A162306, A243103, A246547, A286708, A332785, A369609, A381498, A393924.
%K A393923 nonn,easy,nice
%O A393923 1,2
%A A393923 _Michael De Vlieger_, Mar 03 2026
