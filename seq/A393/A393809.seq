%I A393809 #29 Apr 29 2026 00:40:48
%S A393809 7,19,89,337,1693,2311,17299,297991,744199,9122471,11244967,17451491,
%T A393809 23442299,105929209,584136199,716797951
%N A393809 Primes p such that p^2 = (a+b+c)*b + 1 for some primitive Pythagorean triple (a,b,c).
%C A393809 Here b can be either of the legs of the Pythagorean triple.
%F A393809 Primes p such that p^2 = 4*x^3*y + 4*x^2*y^2 + 1 or 2*x^4 + 2*x^3*y - 2*x^2*y^2 - 2*x*y^3 + 1 for some x,y with 0 < y < x, x and y coprime and one of them even.
%e A393809 a(1) = 7 because 7^2 = (3+4+5)*4+1 where (3,4,5) is a primitive Pythagorean triple and 7 is prime.
%e A393809 a(2) = 19 because 19^2 = (5+12+13)*12+1 where (5,12,13) is a primitive Pythagorean triple and 19 is prime.
%e A393809 a(3) = 89 because 89^2 = (11+60+61)*60+1 where (11, 60, 61) is a primitive Pythagorean triple and 89 is prime.
%e A393809 The first case where b < a is a(7) = 17299 where 17299^2 = (23701+5580+24349)*5580+1 and (23701,5580,24349) is a primitive Pythagorean triple and 17299 is prime.
%e A393809 The first case where b is odd is a(8) = 297991 where 297991^2 = (122320+174279+212921)*174279+1 and (122320,174279,212921) is a primitive Pythagorean triple and 297991 is prime.
%p A393809 N:= 10^9: # for terms <= N
%p A393809 R:= NULL:
%p A393809 for x from 1 while 4*x^3+4*x^2+1 <= N^2 do
%p A393809   for y from (x mod 2)+1 to x-1 by 2 do
%p A393809     if igcd(x,y) > 1 then next fi;
%p A393809     Q:= 4*x^3*y + 4*x^2*y^2 + 1;
%p A393809     if Q > N^2 then break fi;
%p A393809     if issqr(Q) and isprime(sqrt(Q)) then R:= R, sqrt(Q) fi;
%p A393809 od od:
%p A393809 for x from 1 while 8*x^3 - 8*x^2 + 2*x + 1 <= N^2 do
%p A393809     y0:= (x mod 2) + 1;
%p A393809     S:= sort(select(t -> t >= y0 and t <= x-1, [y0, fsolve((2*x^2 + 2*x*z)*(x^2-z^2)+1 = N^2),x-1]));
%p A393809     for i from 1 to nops(S)-1 do
%p A393809        ym:= (S[i]+S[i+1])/2;
%p A393809        if (2*x^2 + 2*x*ym)*(x^2-ym^2)+1 <= N^2 then
%p A393809          y1:= ceil(S[i]);
%p A393809          if y1 + x mod 2 = 0 then y1:= y1+1 fi;
%p A393809          for y from y1 to S[i+1] by 2 do
%p A393809            if igcd(x,y) > 1 then next fi;
%p A393809            Q2:= (2*x^2 + 2*x*y)*(x^2 - y^2) + 1;
%p A393809            if issqr(Q2) and isprime(sqrt(Q2)) then
%p A393809               a:= x^2 - y^2; b:= 2*x*y; c:= x^2 + y^2;
%p A393809               R:= R, sqrt(Q2);
%p A393809   fi od fi od od:
%p A393809 sort([R]);
%Y A393809 Primes in A395517.
%K A393809 nonn,more,new
%O A393809 1,1
%A A393809 _Will Gosnell_ and _Robert Israel_, Apr 26 2026
