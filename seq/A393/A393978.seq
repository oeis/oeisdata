%I A393978 #17 Mar 18 2026 20:45:32
%S A393978 0,39,69,105,225,240,264,276,321,342,348,351,354,357,366,390,393,399,
%T A393978 462,465,492,522,525,537,585,621,660,690,702,738,747,753,759,765,777,
%U A393978 789,792,798,804,807,816,828,837,849,855,858,861,867,873,876,906,909,924,933,963,990,999,1005,1029,1035
%N A393978 Numbers x such that x^2 = y^2 + r for some y, where r is an anagram of y^2.
%C A393978 An anagram of x is a number whose base-10 representation is a permutation of that of x, where leading zeros are not allowed (except for x = 0).
%C A393978 All terms are divisible by 3.
%H A393978 Robert Israel, <a href="/A393978/b393978.txt">Table of n, a(n) for n = 1..10000</a>
%e A393978 a(6) = 240 is a term because 240^2 = 156^2 + 33264, where 33264 is an anagram of 156^2 = 24336.
%e A393978 The first term with more than one such representation is a(7) = 264, where 264^2 = 198^2 + 30492 = 231^2 + 16335, where 30492 is an anagram of 198^2 = 39204 and 16335 is an anagram of 231^2 = 53361.
%p A393978 g:= proc(n) local d, L, i;
%p A393978   L:= convert(n, base, 10); d:= nops(L);
%p A393978   select(issqr, convert(map(t -> n + add(t[i]*10^(i-1), i=1..d), select( t -> t[-1] <> 0, combinat:-permute(L))), set))
%p A393978 end proc:
%p A393978 A:=map(sqrt,select(`<=`, `union`({0}, op(map(g, {seq(i^2, i=1..2000)}))), 4*10^6)):
%p A393978 sort(convert(A,list));
%t A393978 ClearAll[permNumber,g,Q,U,U2,A];
%t A393978 permNumber[n_]:=Module[{d=Reverse[IntegerDigits[n]]},FromDigits[Reverse[#]]&/@Select[Permutations[d],Last[#]!=0&]];
%t A393978 g[n_]:=Select[n+permNumber[n],IntegerQ[Sqrt[#]]&];
%t A393978 Q=Table[k^2,{k,1,2000}];
%t A393978 U=Union[Join[Flatten[g/@Q],{0}]];
%t A393978 U2=Select[U,#<=4*10^6&];
%t A393978 A=Sort[Sqrt/@U2];
%t A393978 A (* _Vincenzo Librandi_, Mar 12 2026, after Maple. *)
%Y A393978 Cf. A393975, A393998, A398401.
%K A393978 nonn,base,new
%O A393978 1,2
%A A393978 _Robert Israel_, Mar 05 2026
