%I A393676 #11 Mar 18 2026 18:47:01
%S A393676 1,1,1,2,1,3,2,4,4,6,6,8,9,11,13,15,18,20,26,27,34,36,46,48,60,63,78,
%T A393676 83,100,107,129,138,163,177,206,225,259,284,324,358,403,447,500,556,
%U A393676 617,689,760,849,932,1041,1140,1274,1389,1551,1689,1883,2046,2279
%N A393676 a(n) = number of partitions of n into distinct parts such that if x and y are parts and x < y then y - x != 2.
%e A393676 a(8) counts these 4 partitions: 8, 7+1, 6+2, 5+2+1.
%t A393676 prt[n_, sL_] := Module[{m = Length[sL], f}, If[n > Last[sL], Return["Extend sL"]];
%t A393676 f[i_, r_, {b1_, b2_}] := f[i, r, {b1, b2}] = Which[r == 0, {{}}, r < 0 || i == 0, {}, True,
%t A393676 Join[f[i - 1, r, {False, b1}], If[! b2 && sL[[i]] <= r, Prepend[#, sL[[i]]] & /@
%t A393676 f[i - 1, r - sL[[i]], {True, b1}], {}]]];  Reverse[f[m, n, {False, False}]]]
%t A393676 z = 30;
%t A393676 s = Range[z];
%t A393676 m = Map[{#, prt[#, s]} &, Range[z]]
%t A393676 u = Map[Last, m];
%t A393676 Map[Length, u]
%t A393676 (* _Peter J. C. Moses_, Jan 26 2026 *)
%Y A393676 Cf. A000009, A393671, A393672, A393673, A393674, A393676.
%K A393676 nonn
