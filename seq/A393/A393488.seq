%N A393488 G.f.: A(x) satisfies A(x) = Sum_{j>=0} x^(j*(j+1)/2) * A(x)^j / Product_{k=1..j} (1 - x^k * A(x)).
%o A393488 (PARI)
%o A393488 tri(n) = {n*(n+1)/2}
%o A393488 A_x(N) = {my(x='x+O('x^(N+1)), A=1); for(i=1, N, A = sum(j=0,N, (x^tri(j) * A^j)/prod(k=1,j, (1 - x^k*A)))); Vec(A)}
