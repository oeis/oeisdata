%S A393859 1,1,9,481,167937,404407577,6800120127457,800088549123479905,
%T A393859 658915325136059491021097,3798522973354690874461870388481,
%U A393859 153284148829522118670763106532386412193,43298980101066352571258622877280192620659603257,85616231904649066390533078310576833498493337981771136193
%N A393859 G.f. A(x) satisfies A( x - x*A(7*x)/7 ) = x.
%C A393859 Conjecture: a(n) == 1 (mod 8) for n >= 1.
%H A393859 Paul D. Hanna, <a href="/A393859/b393859.txt">Table of n, a(n) for n = 1..80</a>
%F A393859 G.f. A(x) = Sum_{n>=1} a(n)*x^n satisfies the following formulas.
%F A393859 (1) A( x - x*A(7*x)/7 ) = x.
%F A393859 (2) A(x) = INV(x - x*INV(x - 7*x*INV(x - 7^2*x*INV(x - 7^3*x*INV(x - 7^4*x*INV(x - ...)))))), where INV(F(x)) = series reversion of F(x).
%F A393859 (3) A(x) = x + Sum_{n>=1} d^(n-1)/dx^(n-1) x^n * (A(7*x)/7)^n / n!.
%F A393859 (4) A(x) = x * exp( Sum_{n>=1} d^(n-1)/dx^(n-1) x^(n-1) * (A(7*x)/7)^n / n! ).
%e A393859 G.f.: A(x) = x + x^2 + 9*x^3 + 481*x^4 + 167937*x^5 + 404407577*x^6 + 6800120127457*x^7 + 800088549123479905*x^8 + ...
%e A393859 The g.f. A(x) results from infinitely nested series reversions as shown below.
%e A393859 Series_Reversion(A(x)) = x - x*B(x) where
%e A393859 B(x) = x + 7*x^2 + 441*x^3 + 164983*x^4 + 403216737*x^5 + 6796878146639*x^6 + ...
%e A393859 Series_Reversion(B(x)) = x - 7*x*C(x) where
%e A393859 C(x) = x + 49*x^2 + 21609*x^3 + 56589169*x^4 + 968123385537*x^5 + ...
%e A393859 Series_Reversion(C(x)) = x - 7^2*x*D(x) where
%e A393859 D(x) = x + 343*x^2 + 1058841*x^3 + 19410084967*x^4 + 2324464248674337*x^5 + ...
%e A393859 Series_Reversion(D(x)) = x - 7^3*x*E(x) where
%e A393859 E(x) = x + 2401*x^2 + 51883209*x^3 + 6657659143681*x^4 + 5581038661067083137*x^5 + ...
%e A393859 ...
%o A393859 (PARI) {a(n,k=7) = my(A=x); for(i=1, n, A = serreverse(x - x*subst(A, x, k*x)/k +x*O(x^n)); ); polcoef(GF=A, n)}
%o A393859 {upto(n,k=7) = a(n,k); Vec(GF)}
%o A393859 upto(20)
%o A393859 (PARI) {a(n,k=7) = my(A=x+x^2); for(j=0, n, A = serreverse(x - k^(n-j)*x*A + x*O(x^n))); polcoef(GF=A, n)}
%o A393859 {upto(n,k=7) = a(n,k); Vec(GF)}
%o A393859 upto(20)
