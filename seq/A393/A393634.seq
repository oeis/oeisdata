%I A393634 #31 Apr 06 2026 23:04:37
%S A393634 0,3,11,19,51,801,2833
%N A393634 Numbers m such that there is no solution to the equation phi(k+m) = sigma(k).
%C A393634 0, and m such that A094466(m) = -1.
%C A393634 If m is odd and k is an odd prime with phi(m+k) = sigma(k), then phi(m+k) <= (m+k)/2 while sigma(k) = k+1, so k <= m-2.
%C A393634 If k is composite and phi(m+k) = sigma(k), then phi(m+k) <= m+k-2 while sigma(k) >= 1 + k + sqrt(k), so k <= (m-3)^2.
%C A393634 This means that when m is odd, a finite search can determine that m is a term.
%C A393634 a(8) > 100000 if it exists.
%e A393634 a(3) = 11 is a term because phi(11+k) <> sigma(k) for 1 <= k <= (11-3)^2 = 64.
%p A393634 f:= proc(n) local km, k; uses NumberTheory;
%p A393634   km:= max(2,(n-3)^2);
%p A393634   for k from 1 to km do
%p A393634       if phi(n+k) = sigma(k) then return k fi;
%p A393634   od;
%p A393634   if n::odd then return -1 fi;
%p A393634   k:= km;
%p A393634   do
%p A393634     k:= nextprime(k);
%p A393634     if phi(n+k) = k+1 then return k fi
%p A393634   od;
%p A393634 end proc:
%p A393634 f(0):= -1:
%p A393634 select(n -> f(n) = -1, [$0..3000]);
%t A393634 f[n_]:=Module[{km,k},km=Max[2,(n-3)^2]; For[k=1,k<=km,k++,If[EulerPhi[n+k]==DivisorSigma[1,k],Return[k]]]; If[OddQ[n],Return[-1]]; k=km; While[True,k=NextPrime[k];If[EulerPhi[n+k]==k+1,Return[k]]];]; f[0]=-1; Select[Range[0,20000],f[#]==-1&] (* _Vincenzo Librandi_, Mar 30 2026 *)
%o A393634 (Magma) f := function(n) if n eq 0 then return -1; end if; km := Max(2,(n-3)^2); for k in [1..km] do if EulerPhi(n+k) eq SumOfDivisors(k) then return k; end if; end for; if IsOdd(n) then return -1; end if; k := km; repeat k := NextPrime(k); until EulerPhi(n+k) eq k+1; return k; end function; [n : n in [0..1000] | f(n) eq -1]; // _Vincenzo Librandi_, Mar 30 2026
%Y A393634 Cf. A094466.
%K A393634 nonn,more,new
%O A393634 1,2
%A A393634 _Robert Israel_, Mar 29 2026
