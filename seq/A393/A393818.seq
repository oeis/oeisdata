%N A393818 a(n) is the least odd semiprime > 2*prime(n).
%H A393818 Vincenzo Librandi, <a href="/A393818/b393818.txt">Table of n, a(n) for n = 1..10000</a>
%p A393818 a:= proc(n) local k; for k from 2*ithprime(n)+1 by 2
%p A393818       while numtheory[bigomega](k)<>2 do od; k
%p A393818     end:
%p A393818 seq(a(n), n=1..58);  # _Alois P. Heinz_, Mar 06 2026
%t A393818 a[n_]:=Module[{k=2*Prime[n]+1},While[PrimeOmega[k]!=2,k+=2]; k]; Array[a,58,1] (* _Vincenzo Librandi_, Mar 08 2026 *)
%o A393818 (PARI) a393818(n) = forstep(k=2*prime(n)+1, oo, 2, if(bigomega(k)==2, return(k)))
%o A393818 (Magma)  N := 58; seq := []; for n in [1..N] do if n le 2 then k := 9; else k := 2*NthPrime(n) + 1; while &+[e[2] : e in Factorization(k)] ne 2 do k +:= 2; end while; end if; Append(~seq, k); end for; seq; // _Vincenzo Librandi_, Mar 08 2026
