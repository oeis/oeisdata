%U A393955 139174640542003978240,12233003976328500000000,1154537363767101233299456,116449585838640863629672960,12500573099908938063034318848
%N A393955 Expansion of e.g.f. ( 1 + Series_Reversion( x*exp(-x*(2+x)) ) )^2.
%F A393955 E.g.f.: 1 + log( (1/x) * Series_Reversion( x*exp(-x*(2+x)) ) ).
%F A393955 E.g.f.: B(x)^2, where B(x) is the e.g.f. of A192949.
%F A393955 a(0) = 1; a(n) = (n-1)! * Sum_{k=0..floor(n/2)} n^k * (2*n)^(n-2*k) * binomial(n-k,k)/(n-k)!.
%F A393955 a(n) ~ (1 + sqrt(3))^(n + 1/2) * n^(n-1) / (sqrt(2) * 3^(1/4) * exp((1 - sqrt(3)/2)*n)). - _Vaclav Kotesovec_, Mar 18 2026
%t A393955 Join[{1}, Table[(n-1)! * Sum[n^k*(2*n)^(n - 2*k)*Binomial[n-k, k]/(n-k)!, {k, 0, Floor[n/2]}], {n, 1, 20}]] (* _Vaclav Kotesovec_, Mar 18 2026 *)
%o A393955 (PARI) my(N=20, x='x+O('x^N)); Vec(serlaplace((1+serreverse(x*exp(-x*(2+x))))^2))
%Y A393955 Cf. A192949, A393954.
%K A393955 nonn
%O A393955 0,2
%A A393955 _Seiichi Manyama_, Mar 04 2026
