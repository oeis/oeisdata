%S A393997 0,3,3,11,8,22,18,18,8,35,15,6,14,8,41,49,32,11,24,6,51,146,11,32,69,
%T A393997 13,55,36,30,38,39,9,44,149,8,29,94,20,117,81,18,105,170,48,27,152,43,
%U A393997 16,28,24,19,76,22,158,106,9,100,52,30,57,71,116,84,124,77,39
%N A393997 Number of steps to reach the end of the cycle starting with n/(2n+1), or -1 if the end of the cycle is never reached, in the following process: If the numerator is even, divide the fraction by 2, otherwise multiply the fraction by 3 and add 1.
%C A393997 Generalization of the "3x+1" problem to a class of rational numbers x = n/(2n+1).
%C A393997 Conjecture: a finite cycle is always reached (checked for n <= 10^5).
%e A393997 a(1) = 3 since 1/3 -> 2 -> 1 -> 4 (-> 2 already in trajectory).
%e A393997 a(2) = 3 because 2/5 -> 1/5 -> 8/5 -> 4/5 (where 4/5 is the last term of the trajectory because the following term, 2/5, is already in the trajectory).
%e A393997 a(3) = 11 because the trajectory of 3/(2*3+1) = 3/7 requires 11 iterations to reach the last term of the cycle: 3/7 -> 16/7 -> 8/7 -> 4/7 -> 2/7 -> 1/7 -> 10/7 -> 5/7 -> 22/7 -> 11/7 -> 40/7 -> 20/7 is the last term because the following term 10/7 is already in the trajectory. Note that the rational 10/7 has two antecedents: 1/7 and 20/7 are in the same trajectory (this property is conjecturally impossible in the classical 3x + 1 problem with x integer). The periodic nontrivial loop contains 6 distinct rational numbers (10/7 -> 5/7 -> 22/7 -> 11/7 -> 40/7 -> 20/7).
%t A393997 a[n_] := Module[{f = n/(2 n + 1), seen},
%t A393997 seen = {f};
%t A393997 While[True,
%t A393997 f = If[EvenQ[Numerator[f]], f/2, 3 f + 1];
%t A393997 If[MemberQ[seen, f], Return[Length[seen] - 1]];
%t A393997 AppendTo[seen, f];]]
%o A393997 (Python)
%o A393997 from gmpy2 import mpq
%o A393997 def a(n):
%o A393997     f = mpq(n, 2*n+1)
%o A393997     seen = {f}
%o A393997     while True:
%o A393997         f = 3*f+1 if f.numerator&1 else f/2
%o A393997         if f in seen:
%o A393997             return len(seen) - 1
%o A393997         seen.add(f)
%o A393997 print([a(n) for n in range(70)]) # _Michael S. Branicky_, Jun 02 2026
