%I A393720 #21 Mar 07 2026 11:21:06
%S A393720 11,11,11,43,47,131,131,131,143,167,167,179,293,293,293,293,359,1439,
%T A393720 1439,1439,1439,1439,1439,1439,1439,1439,1439,1439,1439,1439,1439,
%U A393720 1439,1439,1439,1439,1439,2100599,2480099,2489759,2789639,2789639,2989139,2989139,3063059
%N A393720 The smallest number k such that the digit reversals of k, when written in all bases 2 to n, are greater than k.
%H A393720 Scott R. Shannon, <a href="/A393720/b393720.txt">Table of n, a(n) for n = 2..126</a>
%F A393720 a(n) >= a(n-1).
%e A393720 a(6) = 47 as 47 = 101111_2 = 1202_3 = 233_4 = 142_5 = 115_6 whose digit reversals are 111101_2 = 61, 2021_3 = 61, 332_4 = 62, 241_5 = 71, 511_6 = 187, all of which are greater than 47.
%e A393720 a(10) = 143. See A393903.
%p A393720 rev:= proc(n,b) local L,i;
%p A393720   L:= convert(n,base,b);
%p A393720   add(L[-i]*b^(i-1),i=1..nops(L))
%p A393720 end proc:
%p A393720 f:= proc(n) local b;
%p A393720   for b from 2 do
%p A393720     if rev(n,b) <= n then return b-1 fi
%p A393720   od
%p A393720 end proc:
%p A393720 R:= NULL: m:= 2:
%p A393720 for x from 2 to 10^7 do
%p A393720 v:= f(x);
%p A393720 if v >= m then
%p A393720    R:= R, x$(v-m+1);
%p A393720    m:= v+1;
%p A393720 fi
%p A393720 od:
%p A393720 R; # _Robert Israel_, Mar 04 2026
%t A393720 a[n_]:=Module[{k=1},While[!AllTrue[IntegerReverse[k,Range[2,n]],#>k&],k++];k];Array[a,36,2] (* _James C. McMahon_, Mar 04 2026 *)
%o A393720 (PARI) lista(nn)= my(a=vector(nn), c=0, n); forstep(k=3, oo, 2, n=1; while(n++ <= nn+1 && fromdigits(Vecrev(digits(k, n)), n)>k, ); while(c<n-2, a[c++]=k); c<nn||break); a; \\ (usable for nn <= 90) _Ruud H.G. van Tol_, Mar 05 2026
