%F A393974 a(n) = C(n,3) + 216*C(n,4) + 23325*C(n,5) + 772880*C(n,6) + 13381781*C(n,7) + 143627512*C(n,8) + 1039241647*C(n,9) + 5338438070*C(n,10) + 20105261220*C(n,11) + 56501068800*C(n,12) + 119067989040*C(n,13) + 186575669280*C(n,14) + 211891680000*C(n,15) + 165361996800*C(n,16) + 79394515200*C(n,17) + 17643225600*C(n,18).
