%N A393974 Number of transitive relations on an n-set with exactly nine ordered pairs.
%H A393974 Paolo Xausa, <a href="/A393974/b393974.txt">Table of n, a(n) for n = 0..10000</a>
%H A393974 <a href="/index/Rec#order_19">Index entries for linear recurrences with constant coefficients</a>, signature (19,-171,969,-3876,11628,-27132,50388,-75582,92378,-92378,75582,-50388,27132,-11628,3876,-969,171,-19,1).
%F A393974 a(n) = C(n,3) + 216*C(n,4) + 23325*C(n,5) + 772880*C(n,6) + 13381781*C(n,7) + 143627512*C(n,8) + 1039241647*C(n,9) + 5338438070*C(n,10) + 20105261220*C(n,11) + 56501068800*C(n,12) + 119067989040*C(n,13) + 186575669280*C(n,14) + 211891680000*C(n,15) + 165361996800*C(n,16) + 79394515200*C(n,17) + 17643225600*C(n,18).
%e A393974 a(3) = 1 because the universal relation on a 3-set is the only relation that has exactly nine ordered pairs.
%t A393974 A393974[n_] := Total[{1, 216, 23325, 772880, 13381781, 143627512, 1039241647, 5338438070, 20105261220, 56501068800, 119067989040, 186575669280, 211891680000, 165361996800, 79394515200, 17643225600}*Binomial[n, Range[3, 18]]];
