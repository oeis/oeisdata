%I A393629 #29 Mar 15 2026 11:13:09
%S A393629 1,2,18,320,8900,349272,18268768,1227437568,103121910000,
%T A393629 10605699500000,1312001998456864,192338778147669504,
%U A393629 32989474092036530432,6546924275825254630400,1488811048818515040384000,384660038301755562823876608,112065111544624574602376611584,36567847977074013559415164853760
%N A393629 G.f. satisfies A(x) = x + x*d/dx ( x*d/dx A(x)^2/2 ).
%H A393629 Paul D. Hanna, <a href="/A393629/b393629.txt">Table of n, a(n) for n = 1..401</a>
%F A393629 G.f. A(x) = Sum_{n>=1} a(n)*x^n satisfies the following formulas.
%F A393629 (1) A(x) = x + x*d/dx ( x*d/dx A(x)^2/2 ).
%F A393629 (2) A(x) = x + x*A(x)*A'(x) + x^2*A'(x)^2 + x^2*A(x)*A''(x).
%F A393629 (3) A(x) = x * (1 + x*A'(x)^2) / (1 - x*A'(x) - x^2*A''(x)).
%F A393629 (4) A(x) = Series_Reversion(x/F(x)) where F(x) is the g.f. of A323693 and satisfies [x^n] F(x)^(n+1) * (1 - (n+1)^2*x) = 0 for n >= 1.
%F A393629 (5) d/dx A(x)^2/2 = G(x) - 1 where G(x) is the g.f. of A323694.
%F A393629 a(n) = A216733(n) / n for n >= 1.
%F A393629 a(n) = n * A323694(n-1) for n >= 1.
%F A393629 a(n) ~ c * n!^2, where c = 1.00095034093694419071357524982261039600503... - _Vaclav Kotesovec_, Mar 15 2026
%e A393629 G.f.: A(x) = x + 2*x^2 + 18*x^3 + 320*x^4 + 8900*x^5 + 349272*x^6 + 18268768*x^7 + 1227437568*x^8 + 103121910000*x^9 + ...
%e A393629 RELATED SERIES.
%e A393629 A(x)^2 = x^2 + 4*x^3 + 40*x^4 + 712*x^5 + 19404*x^6 + 745664*x^7 + 38357424*x^8 + 2546220000*x^9 + ...
%e A393629 where A(x) = x + x*d/dx ( x*d/dx A(x)^2/2 ).
%e A393629 Let F(x) satisfy A(x/F(x)) = x and A(x) = x*F(A(x)), then F(x) is the g.f. A323693, which begins
%e A393629 F(x) = 1 + 2*x + 14*x^2 + 228*x^3 + 6332*x^4 + 255800*x^5 + 13862744*x^6 + 962576816*x^7 + ... + A323693(n)*x^n + ...
%e A393629 where [x^n] F(x)^(n+1) * (1 - (n+1)^2*x) = 0 for n >= 1
%e A393629 and F(x) = 1 + x*F(x)^2 * (2*F(x)^2 - x*F(x)*F'(x) - x^2*F'(x)^2 + x^2*F(x)*F''(x)) / (F(x) - x*F'(x))^3.
%o A393629 (PARI) {a(n) = my(A=x+x^2); for(i=1, n, A = x + x*deriv(x*deriv(A^2/2 +x^2*O(x^n)))); polcoef(GF=A, n)}
%o A393629 {upto(n) = a(n); Vec(GF)}
%o A393629 upto(25)
%o A393629 (PARI) {upto(N) = my(A=x+x^2); for(i=1, N, A = x + x*deriv(x*deriv(A^2/2 +x^2*O(x^N)))); Vec(A)}
%o A393629 upto(25) \\ _Joerg Arndt_, Mar 09 2026
