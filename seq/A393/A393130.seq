%I A393130 #25 Apr 02 2026 13:01:38
%S A393130 1,8,12,14,24,39,47,58,62,64,81,148,177,225,318,397,751,1244,1245,
%T A393130 2189,4062,4715
%N A393130 Numbers k such that there is a reversible prime of the form 10^k - 4*10^m - 1.
%C A393130 "Reversible prime" means an emirp (cf. A006567) or a palindromic prime (A002385), here: palindromic wing prime (PWP, cf. A077798). Here we have near-repdigit primes with all (k) digits 9 except for one digit 5.
%C A393130 The definition implies that 0 < m < k except for m = 0 if k = 1, and we can assume WLOG m < k/2; then 10^k - 4*10^m - 1 is the larger and 10^k - 4*10^(k-m-1) - 1 is the smaller of the two emirps, unless 2m = k-1, in which case it is a PWP.
%e A393130 For k = 1, m = 0, we have 10^1 - 1 - 4*10^0 = 5, a palindromic prime.
%e A393130 For k = 8, m = 3, we have 10^8 - 1 - 4*10^3 = 99995999, an emirp, with reverse prime 99959999.
%e A393130 For k = 12, m = 1, we have 10^12 - 1 - 4*10^1 = 999999999959, an emirp, with reverse prime 959999999999.
%e A393130 For k = 14, m = 1, we have 10^14 - 1 - 4*10^1 = 99999999999959, again an emirp, with reverse prime 95999999999999.
%t A393130 q[k_]:=Module[{m=Range[k/2]},AnyTrue[m,PrimeQ[10^k-4*10^#-1]&&PrimeQ[IntegerReverse[10^k-4*10^#-1]]&]];Join[{1},Select[Range[400],q]] (* _James C. McMahon_, Apr 02 2026 *)
%o A393130 (PARI) is_A393130(k, r=10^k-1)=for(m=1, k\/2-1, ispseudoprime(r-10^(k-m-1)*4)&& ispseudoprime(r-10^m*4)&& return(m))||k==1 /* return the m-value if it exists (but 1 for k=1), else 0 */
%o A393130 for(k=1, oo, is_A393130(k) && print1(k", "))
%Y A393130 Cf. A393126, A393129 (similar with distinct digit 8 and 7, respectively).
%Y A393130 Cf. A006567 (emirps), A004086 (n with digits reversed), A173594 (near-repdigit emirps).
%Y A393130 Cf. A002385 (palindromic primes), A077798 (palindromic wing primes).
%K A393130 nonn,hard,more,base,changed
%O A393130 1,2
%A A393130 _M. F. Hasler_, Mar 24 2026
%E A393130 a(17)-a(22) from _Michael S. Branicky_, Mar 25 2026
