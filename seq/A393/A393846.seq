%N A393846 O.g.f. A(x) satisfies: [x^n] exp( n^6 * x ) / A(x) = 0 for n>0.
%H A393846 Paul D. Hanna, <a href="/A393846/b393846.txt">Table of n, a(n) for n = 0..100</a>
%e A393846 O.g.f.: A(x) = 1 + x + 1985*x^2 + 62861994*x^3 + 11442690973075*x^4 + 7570836550478960487*x^5 + 13956629370284243750857868*x^6 + ...
%e A393846 ILLUSTRATION OF DEFINITION.
%e A393846 The table of coefficients of x^k/k! in exp(n^6*x)/A(x) begins
%e A393846   n = 1: [1,     0,     -3969,    -377160056, ...];
%e A393846   n = 2: [1,    63,         0,    -377660150, ...];
%e A393846   n = 3: [1,   728,    526015,             0, ...];
%e A393846   n = 4: [1,  4095,  16765056,   68243238154, 0, ...];
%e A393846   n = 5: [1, 15624, 244105407, 3813401695600, 59285380255397541, 0, ...];
%e A393846   ...
%e A393846 in which a diagonal, the coefficient of x^n in row n, is all zeros.
%o A393846 (PARI) {a(n,k=6) = my(A=[1]); for(i=1, n, A=concat(A, 0); m=#A; A[m] = Vec( exp(x*(m-1)^k +x*O(x^m)) / Ser(A) )[m] ); A[n+1]}
%o A393846 for(n=0, 15, print1( a(n,6), ", "))
%Y A393846 Sequences below with the given parameter p have an o.g.f. F(x) satisfying [x^n] exp( n^p*x ) / F(x) = 0 for n >= 1.
%Y A393846 Cf. A304322 (p=2), A304323 (p=3), A304324 (p=4), A304325 (p=5).
%Y A393846 Cf. A393847 (p=7), A393848 (p=8), A393849 (p=9).
