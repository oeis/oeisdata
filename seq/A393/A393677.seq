%I A393677 #10 Mar 18 2026 18:49:03
%S A393677 1,3,9,17,29,43,61,81,105,131,161,193,229,267,309,353,401,451,505,561,
%T A393677 621,683,749,817,889,963,1041,1121,1205,1291,1381,1473,1569,1667,1769,
%U A393677 1873,1981,2091,2205,2321,2441,2563,2689,2817,2949,3083,3221,3361,3505
%N A393677 Upper (1,1/2) midsequence of (n^2) and ((n+1)^2); see Comments.
%C A393677 Suppose that s = (s(n)) and t = (t(n)) are sequences of numbers and h > 0 and k > 0. The lower (h, k)-midsequence of s and t is floor(h*s + k*t); the upper (h, k)-midsequence of s and t is ceiling(h*s + k*t).
%H A393677 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (2,0,-2,1).
%F A393677 a(n) = 2*a(n-1) - 2*a(n-3) + a(n-4), with (a(0),...,a(3)) = (1, 3, 9, 17).
%F A393677 G.f.: (-1 - x - 3*x^2 - x^3)/((-1 + x)^3*(1 + x)).
%e A393677 s = (n^2) = A000290 = (0, 1, 4, 9, 16, 25, 36, ...).
%e A393677 t = ((n+1)^2) = (1, 4, 9, 16, 25, 36, 49, 64, ...).
%e A393677 u(n) = (0, 3, 8, 17, 28, 43, 60, 81, 104, 131, 160, ...) = A227017.
%e A393677 v(n) = (1, 3, 9, 17, 29, 43, 61, 81, 105, 131, 161, ...).
%t A393677 f[n_] := n^2; g[n_] := (n+1)^2; r = 1; s = 1/2;
%t A393677 u[n_] := Floor[r*f[n] + s*g[n]];
%t A393677 v[n_] := Ceiling[r*f[n] + s*g[n]];
%t A393677 Table[u[n], {n, 0, 50}]   (* A227017 *)
%t A393677 Table[v[n], {n, 0, 50}]   (* A393677 *)
%t A393677 (* Also *)
%t A393677 LinearRecurrence[{2,0,-2,1}, {0, 3, 8, 17}, 50]   (* A227017 *)
%t A393677 LinearRecurrence[{2,0,-2,1}, {1, 3, 9, 17}, 50]   (* A393677 *)
%Y A393677 Cf. A000290, A000578, A227017, A393678.
%K A393677 nonn,easy
%O A393677 0,2
%A A393677 _Clark Kimberling_, Mar 12 2026
