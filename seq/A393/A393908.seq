%U A393908 2735717214249,15451586796891,87272004061435,492920419867581,2784060522985585,15724633666463625,88814198766038561
%N A393908 a(n) = Sum_{i=0..n} Sum_{j=0..i} binomial(n+2*i,3*i) * binomial(i+2*j,3*j).
%H A393908 Seiichi Manyama, <a href="/A393908/b393908.txt">Table of n, a(n) for n = 0..1000</a>
%H A393908 <a href="/index/Rec#order_09">Index entries for linear recurrences with constant coefficients</a>, signature (13,-63,154,-215,189,-108,40,-9,1).
%F A393908 G.f.: ((1-x) * ((1-x)^3 - x))^2 / (((1-x)^3 - x)^3 - x*(1-x)^6).
%F A393908 a(n) = 13*a(n-1) - 63*a(n-2) + 154*a(n-3) - 215*a(n-4) + 189*a(n-5) - 108*a(n-6) + 40*a(n-7) - 9*a(n-8) + a(n-9).
%F A393908 G.f.: 1 / ( (1-x) * (1-B(x)) * (1-B(B(x))) ), where B(x) = x/(1-x)^3.
%F A393908 G.f.: (C(x)/x)^(1/3), where C(x) is the g.f. of A396209.
%o A393908 (PARI) a(n) = sum(i=0, n, sum(j=0, i, binomial(n+2*i, 3*i)*binomial(i+2*j, 3*j)));
