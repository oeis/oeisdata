%N A393642 First differences of fifth powers of triangular numbers.
%C A393642 Row sums of A022521 treated as a regular triangle.
%H A393642 Kelvin Voskuijl, <a href="/A393642/b393642.txt">Table of n, a(n) for n = 0..10000</a>
%H A393642 <a href="/index/Rec#order_10">Index entries for linear recurrences with constant coefficients</a>, signature (10,-45,120,-210,252,-210,120,-45,10,-1).
%F A393642 a(n) = (5*n^9 + 10*n^7 + n^5)/16.
%F A393642 From _Stefano Spezia_, Apr 02 2026: (Start)
%F A393642 G.f.: x*(1 + 232*x + 5158*x^2 + 27664*x^3 + 47290*x^4 + 27664*x^5 + 5158*x^6 + 232*x^7 + x^8)/(1 - x)^10.
%F A393642 E.g.f.: exp(x)*x*(16 + 1920*x + 18160*x^2 + 42360*x^3 + 36156*x^4 + 13440*x^5 + 2320*x^6 + 180*x^7 + 5*x^8)/16. (End)
%t A393642 A393642[n_] := (5*n^9 + 10*n^7 + n^5)/16; Array[A393642, 25, 0] (* or *)
%t A393642 Differences[PolygonalNumber[Range[-1, 24]]^5] (* _Paolo Xausa_, Apr 09 2026 *)
%o A393642 (PARI) a(n) = (5*n^9+10*n^7+n^5)/16
%o A393642 (Python)
