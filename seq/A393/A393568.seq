%I A393568 #21 Apr 21 2026 19:19:35
%S A393568 1,3,7,61,317,2137,19009,212593,2937059,48867691,959016481,
%T A393568 21825206783,567967917709,16703952063479,549692222905069
%N A393568 a(1)=1; for n >= 1, a(n+1) = prime(k) where k > a(n) is least k such that prime(k) + k is prime.
%F A393568 a(1) = 1; for n >= 2, a(n) = prime(k), where k is the smallest integer > a(n-1) such that prime(k) + k is prime.
%e A393568 a(2) = 3 because 3 is the first prime p=prime(k) with k > a(1) = 1 such that p + k is prime (3 + 2 = 5 is prime).
%e A393568 a(3) = 7 because 7 is the first prime p=prime(k) with k > a(2) = 3 such that p + k is prime (7 + 4 = 11 is prime).
%e A393568 a(4) = 61 because 61 is the first prime p=prime(k) with k > a(3) = 7 such that p + k is prime (61 + 18 = 79 is prime).
%t A393568 FilteredPrimeIndexSequence[n_]:=Module[{seq={1}, k}, While[Length[seq]<n, k=seq[[-1]]+1; While[!PrimeQ[Prime[k]+ k], k++]; AppendTo[seq, Prime[k]]; ]; seq]; FilteredPrimeIndexSequence[15]
%o A393568 (Magma) a := [1]; for i in [2..11] do k := a[#a] + 1; while not IsPrime(NthPrime(k) + k) do k +:= 1; end while; Append(~a, NthPrime(k)); end for; a;
