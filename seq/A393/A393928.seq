%I A393928 #31 Mar 26 2026 09:11:12
%S A393928 3,5,11,11,41,10267,832361,1565437,52112257,335021996291,15203906741
%N A393928 Smallest prime q such that the set of p-1 consecutive primes starting at q forms a complete system of residues modulo p (excluding p mod p), where p=prime(n).
%C A393928 Conjecture: for any prime number p, there exists at least one prime number q such that the sequence of p-1 consecutive prime numbers {p_k, p_{k+1},...,p_{k+p-2}} with p_k = q forms a complete system of nonzero residues modulo p.
%D A393928 P. G. L. Dirichlet, Beweis des Satzes ... unendlich viele Primzahlen enthält, Abh. Königl. Preuß. Akad. Wiss., 1837, pp. 45-81.
%D A393928 G. H. Hardy, J. E. Littlewood, Some problems of "Partitio numerorum"; III: On the expression of a number as a sum of primes, Acta Math. 44 (1923), pp. 1-70.
%D A393928 J. Maynard, Small gaps between primes, Ann. of Math. 181 (2015), pp. 383-413.
%e A393928 ------------------------------------------------------------
%e A393928   p       q    [p-1 consecutive primes]      {residues modulo p}
%e A393928 ------------------------------------------------------------
%e A393928   2       3    [3]                           {1}
%e A393928   3       5    [5, 7]                        {1, 2}
%e A393928   5      11    [11, 13, 17, 19               {1, 2, 3, 4}
%e A393928   7      11    [11, 13, 17, 19, 23, 29]      {1,..., 6}
%e A393928  11      41    [41, 43,..., 79]              {1,..., 10}
%e A393928  13   10267    [10267,..., 10343]            {1,..., 12}
%p A393928 restart;
%p A393928 findPQ := proc(limit_p)
%p A393928     local p, q, residues, current_q, i, target;
%p A393928     p := 2;
%p A393928     while p <= limit_p do
%p A393928         target := {seq(i, i=1..p-1)};
%p A393928         q := 2;
%p A393928         while true do
%p A393928             residues := {};
%p A393928             current_q := q;
%p A393928             for i from 1 to p-1 do
%p A393928                 residues := residues union {current_q mod p};
%p A393928                 current_q := nextprime(current_q);
%p A393928             end do;
%p A393928             if residues = target then
%p A393928                 printf("p = %d, q = %d\n", p, q);
%p A393928                 break;
%p A393928             end if;
%p A393928             q := nextprime(q);
%p A393928         end do;
%p A393928         p := nextprime(p);
%p A393928     end do;
%p A393928 end proc:
%p A393928 findPQ(17);
%o A393928 (PARI) isok(p, q) = my(list=List); listput(list, q); for (i=2, p-1, q=nextprime(q+1); listput(list, q)); my(v=vector(p-1, k, list[k] % p)); vecmin(v) && (#Set(v) == p-1);
%o A393928 a(n) = my(p=prime(n), q=nextprime(p+1)); while (!isok(p,q), q=nextprime(q+1)); q; \\ _Michel Marcus_, Mar 03 2026
%Y A393928 Cf. A000040.
%K A393928 nonn,hard,more,new
%O A393928 1,1
%A A393928 _Michel Lagneau_, Mar 03 2026
%E A393928 a(7)-a(9) corrected by _Michel Marcus_, Mar 06 2026
