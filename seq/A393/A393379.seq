%I A393379 #32 Mar 25 2026 22:26:30
%S A393379 1,2,3,4,6,8,12,16,20,24,32,36,40,48,56,64,72,88,96,112,128,144,192
%N A393379 The records of min(d(k), d(k+1), d(k+2)), where d(k) is the number of divisors of k (A000005).
%e A393379 12 is in this sequence because 12 is the value of min(d(1274), d(1275), d(1276)), where d(1274) = 12, d(1275) = 12, and d(1276) = 12. And there is no number k < 1274 where min(d(k), d(k+1), d(k+2)) >= 12.
%o A393379 (PARI) print1(r=1); for(n=2, 1e5, if(min(min(numdiv(n), numdiv(n+1)), numdiv(n+2))>r, r=min(min(numdiv(n), numdiv(n+1)), numdiv(n+2)); print1(", "r)))
%Y A393379 Cf. A000005, A394327.
%K A393379 nonn,more,new
%O A393379 1,2
