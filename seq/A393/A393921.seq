%I A393921 #10 Mar 03 2026 16:55:03
%S A393921 1,1,2,12,60,450,3960,40320,470400,6161400,89737200,1433678400,
%T A393921 24985144800,470929258800,9552934591200,207416225016000,
%U A393921 4800763199232000,117985032861696000,3068809378322688000,84220901965565164800,2432308571799698592000,73740283173518978016000
%N A393921 Number of ordered set partitions of [n] whose set of block sizes covers an initial interval.
%H A393921 Alois P. Heinz, <a href="/A393921/b393921.txt">Table of n, a(n) for n = 0..424</a>
%e A393921 The ordered set partition of [6], 4|23|16|5 has the set of block sizes {1,2} so it is counted under a(6) = 3960.
%p A393921 b:= proc(n, i, p) option remember; uses combinat; `if`(n=0, p!, add(
%p A393921       b(n-i*j, i+1, p+j)*multinomial(n, n-i*j, i$j)/j!, j=1..n/i))
%p A393921     end:
%p A393921 a:= n-> b(n, 1, 0):
%p A393921 seq(a(n), n=0..21);  # _Alois P. Heinz_, Mar 03 2026
%o A393921 (PARI)
%o A393921 subsets(S) = {my(s=List()); for(i=0, 2^(#S) -1, my(x=List()); for(j=1, #S, if(bitand(i, 1<<(j-1)), listput(x, S[j]))); listput(s, Vec(x))); Vec(s)}
%o A393921 C_x(k,N) = { my(x='x+O('x^(N+1)), S = subsets(vector(k,i,i)),  v= sum(i=2,#S, (-1)^(k-#S[i])/(1-sum(k=1,#S[i], x^S[i][k] / S[i][k]!)))); v}
%o A393921 D_x(N) = { my(x='x+O('x^(N+1))); Vec(serlaplace(1 + sum(i=1,floor(sqrt(2*N)+1/2), C_x(i,N))))}
%Y A393921 Cf. A000670, A393098.
%K A393921 nonn,new
%O A393921 0,3
%A A393921 _John Tyler Rascoe_, Mar 02 2026
