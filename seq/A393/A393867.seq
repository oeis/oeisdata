%I A393867 #13 Mar 29 2026 23:47:01
%S A393867 1,3,25,287,7601,116337,3740017,80014415,2949026857,133787267943,
%T A393867 4200083163057,241983191914853,11120075525056265,530169345622378745,
%U A393867 30835220884142971385,2029889748240816948527,141614089508017106620961,8967246922112275916862825,750640275823651591748840329,57132832447805992338691195027
%N A393867 Logarithic derivative of A393866.
%C A393867 Conjecture: a(n) is divisible by prime(n) for n > 1.
%C A393867 Conjecture: all terms are odd.
%H A393867 Paul D. Hanna, <a href="/A393867/b393867.txt">Table of n, a(n) for n = 1..500</a>
%e A393867 L.g.f.: L(x) = x + 3*x^2/2 + 25*x^3/3 + 287*x^4/4 + 7601*x^5/5 + 116337*x^6/6 + 3740017*x^7/7 + 80014415*x^8/8 + 2949026857*x^9/9 + 133787267943*x^10/10 + ...
%e A393867 where exponentiation yields F(x), the g.f. of A393866:
%e A393867 exp(L(x)) = F(x) = 1 + x + 2*x^2 + 10*x^3 + 82*x^4 + 1610*x^5 + 21103*x^6 + 557487*x^7 + 10593462*x^8 + ... + A393866(n)*x^n + ...
%e A393867 which satisfies [x^n] F(x)^prime(n) * (1 - prime(n)*x) = 0 for n >= 1.
%e A393867 Dividing a(n) by prime(n) for n > 1 yields
%e A393867 a(n)/prime(n) = [1, 5, 41, 691, 8949, 220001, 4211285, 128218559, 4613354067, 135486553647, 6540086267969, 271221354269665, ...].
%o A393867 (PARI) \\ Set N to desired number of terms
%o A393867 N=30; F=[1]; for(n=1, N, F=concat(F, 0); V=Vec(Ser(F)^prime(n)); F[#F] = V[#F-1] - V[#F]/prime(n) ); A = Vec(x*Ser(F)'/Ser(F))
%o A393867 \\ Test: a(n) == 0 (mod prime(n)) for n > 1 - returns '1' if true
%o A393867 for(n=2,N, print1( denominator( A[n]/prime(n) ),", "))
%K A393867 nonn
%O A393867 1,2
%A A393867 _Paul D. Hanna_, Mar 29 2026
