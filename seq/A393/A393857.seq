%I A393857 #12 Mar 12 2026 21:55:07
%S A393857 1,1,7,205,26869,16984687,53213653657,831942602359489,
%T A393857 65003836062077317555,25392838513187592979535977,
%U A393857 49595692435523156976760613696881,484333578684657611923045982847378096811,23649107302381551922331603304729820707599712217,5773708192232098345610507852263841713045392936721384825
%N A393857 G.f. A(x) satisfies A( x - x*A(5*x)/5 ) = x.
%C A393857 Conjecture: a(n) == 1 (mod 6) for n >= 1.
%H A393857 Paul D. Hanna, <a href="/A393857/b393857.txt">Table of n, a(n) for n = 1..80</a>
%F A393857 G.f. A(x) = Sum_{n>=1} a(n)*x^n satisfies the following formulas.
%F A393857 (1) A( x - x*A(5*x)/5 ) = x.
%F A393857 (2) A(x) = INV(x - x*INV(x - 5*x*INV(x - 5^2*x*INV(x - 5^3*x*INV(x - 5^4*x*INV(x - ...)))))), where INV(F(x)) = series reversion of F(x).
%F A393857 (3) A(x) = x + Sum_{n>=1} d^(n-1)/dx^(n-1) x^n * (A(5*x)/5)^n / n!.
%F A393857 (4) A(x) = x * exp( Sum_{n>=1} d^(n-1)/dx^(n-1) x^(n-1) * (A(5*x)/5)^n / n! ).
%e A393857 G.f.: A(x) = x + x^2 + 7*x^3 + 205*x^4 + 26869*x^5 + 16984687*x^6 + 53213653657*x^7 + 831942602359489*x^8 + 65003836062077317555*x^9 + ...
%e A393857 The g.f. A(x) results from infinitely nested series reversions as shown below.
%e A393857 Series_Reversion(A(x)) = x - x*B(x) where
%e A393857 B(x) = x + 5*x^2 + 175*x^3 + 25625*x^4 + 16793125*x^5 + 53077146875*x^6 + ...
%e A393857 Series_Reversion(B(x)) = x - 5*x*C(x) where
%e A393857 C(x) = x + 25*x^2 + 4375*x^3 + 3203125*x^4 + 10495703125*x^5 + ...
%e A393857 Series_Reversion(C(x)) = x - 5^2*x*D(x) where
%e A393857 D(x) = x + 125*x^2 + 109375*x^3 + 400390625*x^4 + 6559814453125*x^5 + ...
%e A393857 Series_Reversion(D(x)) = x - 5^3*x*E(x) where
%e A393857 E(x) = x + 625*x^2 + 2734375*x^3 + 50048828125*x^4 + 4099884033203125*x^5 + ...
%e A393857 ...
%o A393857 (PARI) {a(n,k=5) = my(A=x); for(i=1, n, A = serreverse(x - x*subst(A, x, k*x)/k +x*O(x^n)); ); polcoef(GF=A, n)}
%o A393857 {upto(n,k=5) = a(n,k); Vec(GF)}
%o A393857 upto(20)
%o A393857 (PARI) {a(n,k=5) = my(A=x+x^2); for(j=0, n, A = serreverse(x - k^(n-j)*x*A + x*O(x^n))); polcoef(GF=A, n)}
%o A393857 {upto(n,k=5) = a(n,k); Vec(GF)}
%o A393857 upto(20)
