%T A393878 3342385090874597996152,38909387112360144183385281,
%U A393878 632627036534917139794066064890,13892153601661400502034219999005321,400880771663304718586443086620740599300,14858422568507260411221678654917591940073441
%N A393878 Expansion of e.g.f. Sum_{n>=0} Stirling2(3*n,n) * x^n * exp(n*x).
%C A393878 In general, for m > 1, Sum_{k=0..n} Stirling2(m*k,k) * k^(n-k) * n! / (n-k)! ~ c * m^(m*n) * n^(m*n) / (sqrt(1-w) * exp(m*n) * w^n * (m-w)^((m-1)*n)), where w = -LambertW(-m*exp(-m)) and c = 1 for m > 2 and c = exp(w*(2-w)/4) for m = 2. - _Vaclav Kotesovec_, Apr 28 2026
%H A393878 Paul D. Hanna, <a href="/A393878/b393878.txt">Table of n, a(n) for n = 0..200</a>
%F A393878 E.g.f. A(x) = Sum_{n>=0} a(n)*x^n/n! satisfies the following formulas.
%F A393878 (1) A(x) = Sum_{n>=0} n^(3*n) * exp(-n^3*x*exp(x)) * x^n * exp(n*x) / n!.
%F A393878 (2) A(x) = Sum_{n>=0} Stirling2(3*n,n) * x^n * exp(n*x).
%F A393878 (3) A( LambertW(x) ) = Sum_{n>=0} A217913(n)*x^n, where A217913(n) = A008277(3*n,n) for n >= 1 and A008277 equals the Stirling numbers of second kind.
%F A393878 (4) a(n) = n! * Sum_{k=0..n} Stirling2(3*k,k) * k^(n-k)/(n-k)!, for n >= 0.
%F A393878 a(n) ~ 3^(3*n) * n^(3*n) / (sqrt(1-w) * exp(3*n) * w^n * (3-w)^(2*n)), where w = -A226750 = -LambertW(-3*exp(-3)). - _Vaclav Kotesovec_, Apr 28 2026
%e A393878 E.g.f.: A(x) = 1 + x + 64*x^2/2! + 18525*x^3/3! + 14895316*x^4/4! + 25587189345*x^5/5! + 80457113721726*x^6/6! + ...
%e A393878 where
%e A393878 A(x) = 1 + exp(-x*exp(x))*x*exp(x) + 2^6*exp(-2^3*x*exp(x))*x^2*exp(2*x)/2! + 3^9*exp(-3^3*x*exp(x))*x^3*exp(3*x)/3! + 4^12*exp(-4^3*x*exp(x))*x^4*exp(4*x)/4! + ... + n^(3*n)*exp(-n^3*x*exp(x))*x^n*exp(n*x)/n! + ...
%e A393878 Also, we have the integer series
%e A393878 A( LambertW(x) ) = 1 + x + 31*x^2 + 3025*x^3 + 611501*x^4 + 210766920*x^5 + 110687251039*x^6 + ... + A217913(n)*x^n + ...
%t A393878 Join[{1}, Table[n! * Sum[StirlingS2[3*k,k] * k^(n-k)/(n-k)!, {k,0,n}], {n,1,20}]] (* _Vaclav Kotesovec_, Apr 28 2026 *)
%o A393878 (PARI) \\ Formula (1)
%o A393878 {a(n) = my(A=1, E = x*exp(x + x*O(x^n)));
%o A393878 A = 1 + sum(m=1, n, m^(3*m) * exp(-m^3*E) * E^m/m!); polcoef(EGF=A, n)}
%o A393878 {upto(n) = a(n); Vec(serlaplace(EGF))}
%o A393878 upto(20)
%o A393878 (PARI) \\ Formula (2)
%o A393878 {a(n) = my(A=1); A = sum(m=0, n, stirling(3*m, m, 2) * x^m * exp(m*x +x*O(x^n))); polcoef(EGF=A, n)}
%o A393878 {upto(n) = a(n); Vec(serlaplace(EGF))}
%o A393878 upto(20)
%o A393878 (PARI) \\ Formula (4)
%o A393878 {a(n) = n! * if(n==0, 1, sum(k=0, n, stirling(3*k, k, 2) * k^(n-k)/(n-k)! ) )}
%o A393878 for(n=0, 20, print1(a(n), ", "))
