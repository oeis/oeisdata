%I A393675 #8 Mar 16 2026 23:18:59
%S A393675 1,0,0,0,1,0,1,0,1,1,1,0,2,1,2,2,3,0,4,1,4,3,5,2,7,5,6,7,9,6,12,8,12,
%T A393675 11,16,10,22,14,20,20,28,20,33,27,34,36,43,36,56,48,58,58,71,62,88,76,
%U A393675 92,93,114,98,139,122,148,149,178,161,209,195,228,233
%N A393675 a(n) = number of partitions of n into distinct composite parts, no two of which are consecutive in A002808.
%e A393675 a(16) counts these 3 partitions: 16, 12+4, 10+6.
%t A393675 prt[n_, sL_] := Module[{m = Length[sL], f}, If[n > Last[sL], Return["Extend sL"]];
%t A393675 f[i_, r_, b_] := f[i, r, b] = Which[r == 0, {{}}, r < 0 || i == 0, {}, True,
%t A393675 Join[f[i - 1, r, False], If[! b && s[[i]] <= r, Map[Prepend[#, sL[[i]]] &,
%t A393675 f[i - 1, r - sL[[i]], True]], {}]]];  Reverse[f[m, n, False]]]
%t A393675 z = 100;
%t A393675 s = Select[Range[z], CompositeQ];
%t A393675 m = Map[{#, prt[#, s]} &, Range[z]]
%t A393675 u = Map[Last, m];
%t A393675 Map[Length, u]
%t A393675 (* _Peter J. C. Moses_, Jan 26 2026 *)
%Y A393675 Cf. A018252, A393671, A393672, A393673, A393674, A393676.
%K A393675 nonn,new
