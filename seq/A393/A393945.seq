%e A393945 a(5) = 22: 00000, 00001, 00010, 00011, 00100, 00110, 00111, 01000, 01001, 01100, 01110, 01111, 10000, 10001, 10010, 10011, 10101, 11000, 11001, 11100, 11110, 11111.
