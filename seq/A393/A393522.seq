%I A393522 #18 Mar 02 2026 15:48:06
%S A393522 1,2,2,3,4,6,8,10,12,14,20,26,34,42,52,62,82,106,138,172,212,262,330,
%T A393522 426,554,692,862,1062,1322,1706,2218,2772,3462,4312,5312,6826,8874,
%U A393522 11092,13862,17312,21562,27306,35498,44372,55462,69312,86562,109226,141994
%N A393522 Maximum word length generated by acyclic context-free grammar in double Greibach normal form whose grammar size is at most n.
%C A393522 Let G be an acyclic context-free grammar in double Greibach normal form; that is, every rule is either of the form A -> aBCb, or A -> ab, where A,B,C are nonterminal symbols, and a,b are terminal symbols, in both cases not necessarily distinct. Hotz (1978) proved that every context-free language can be generated by a grammar in double Greibach normal form.
%C A393522 If we bound the grammar size above by n, then the maximum word length that can be generated by such a grammar G is a(n). Here, grammar size is understood as the sum of the lengths of the right-hand sides in all productions.
%C A393522 Also, for a context-free language L, let mpcf(L) denote the minimum constant such that the context-free pumping lemma holds for L. In Gruber/Holzer (2026), it is shown that mpcf(L) <= a(n)+1 for each language that can be generated by some context-free grammar in double Greibach normal form of size at most n.
%C A393522 As proved in Gruber/Holzer (2025a), the corresponding sequence for unrestricted context-free grammars is A000792, and an analogous statement holds for the pumping constant in that case. The case of grammars in Greibach normal form is treated in Gruber/Holzer (2025b), leading to A389642.
%D A393522 H. Gruber and M. Holzer, On Pumping Constants and Smallest Grammars for Context-Free Languages. In M. Dolores Jiménez López and György Vaszil, editors, Languages of Cooperation and Communication: Essays Dedicated to Erzsébet Csuhaj-Varjú to Celebrate Her Scientific Career, volume 15840 of Lecture Notes in Computer Science, pages 54--68. Springer, 2025.
%D A393522 H. Gruber and M. Holzer, On Pumping Constants and Smallest Grammars for Context-Free Languages, Part II — Greibach Normal Form, preprint, 2025.
%D A393522 H. Gruber and M. Holzer, On Pumping Constants and Smallest Grammars for Context-Free Languages, Part III — Double Greibach Normal Form, preprint, 2026.
%D A393522 G. Hotz, Normal-form transformations of context-free grammars. Acta Cybernetica, 4 (1978), pages 65-84.
%F A393522 a(n) = max_{1<=k<=n-3} (k * a(n-k-2)+2) with base values a(1)=1 and a(2)=a(3)=2.
%F A393522 For n>=30, a(n) = 4 * a(n-6)+2 if n mod 6 = 0 or n mod 6 = 1, and a(n) = 5 * a(n-7)+2 otherwise.
%F A393522 a(n) = {
%F A393522   (5 * 4^(n/6) - 2) / 3,               if n mod 6 = 0 and n >= 6
%F A393522   (13 * 4^((n - 1)/6) - 4) / 6,        if n mod 6 = 1 and n >= 7
%F A393522   (65 * 4^((n - 8)/6) - 8) / 6,        if n mod 6 = 2 and n >= 14
%F A393522   (325 * 4^((n - 15)/6) - 28) / 6,     if n mod 6 = 3 and n >= 21
%F A393522   (1625 * 4^((n - 22)/6) - 128) / 6,   if n mod 6 = 4 and n >= 28
%F A393522   (8125 * 4^((n - 29)/6) - 628) / 6,   if n mod 6 = 5 and n >= 35
%F A393522 }. Also, a(1)=1, a(2)=a(3)=2, a(4)=3, a(5)=4, a(8)=10, a(9)=12, a(10)=14, a(11)=20 a(15)=52, a(16)=62, a(17)=82, a(22)=262, a(23)=330, and a(29)=1322.
%e A393522 An acyclic context-free grammar in double Greibach normal form attaining the bound for n=27 has the following productions:
%e A393522   A_1 -> aA_2A_2A_2A_2A_2a
%e A393522   A_2 -> aA_3A_3A_3A_3A_3a
%e A393522   A_3 -> aA_4A_4A_4A_4a
%e A393522   A_4 -> aA_5A_5A_5a
%e A393522   A_5 -> aa
%e A393522 The lengths of the right-hand sides correspond to the fact that
%e A393522   a(27)=5*a(20)+2, a(20)=5*a(13)+2, a(13)=4*a(7)+2, a(7)=3*a(2)+2, a(2)=2.
%p A393522 A393522 := proc(n)
%p A393522     local sporadic;
%p A393522     sporadic := table([
%p A393522         1=1, 2=2, 3=2, 4=3, 5=4,
%p A393522         8=10, 9=12, 10=14, 11=20,
%p A393522         15=52, 16=62, 17=82,
%p A393522         22=262, 23=330, 29=1322
%p A393522     ]);
%p A393522     if assigned(sporadic[n]) then
%p A393522         return sporadic[n];
%p A393522     end if;
%p A393522     if n mod 6 = 0 and n >= 6 then
%p A393522         return (5*4^(n/6) - 2)/3;
%p A393522     elif n mod 6 = 1 and n >= 7 then
%p A393522         return (13*4^((n-1)/6) - 4)/6;
%p A393522     elif n mod 6 = 2 and n >= 14 then
%p A393522         return (65*4^((n-8)/6) - 8)/6;
%p A393522     elif n mod 6 = 3 and n >= 21 then
%p A393522         return (325*4^((n-15)/6) - 28)/6;
%p A393522     elif n mod 6 = 4 and n >= 28 then
%p A393522         return (1625*4^((n-22)/6) - 128)/6;
%p A393522     else
%p A393522         return (8125*4^((n-29)/6) - 628)/6;
%p A393522     end if;
%p A393522 end proc:
%o A393522 (Python)
%o A393522 def a(n: int) -> int:
%o A393522     sporadic = {
%o A393522         1: 1, 2: 2, 3: 2, 4: 3, 5: 4,
%o A393522         8: 10, 9: 12, 10: 14, 11: 20,
%o A393522         15: 52, 16: 62, 17: 82,
%o A393522         22: 262, 23: 330, 29: 1322
%o A393522     }
%o A393522     if n in sporadic:
%o A393522         return sporadic[n]
%o A393522     r = n % 6
%o A393522     if r == 0:
%o A393522         return (5 * (4 ** (n // 6)) - 2) // 3
%o A393522     if r == 1:
%o A393522         return (13 * (4 ** ((n - 1) // 6)) - 4) // 6
%o A393522     if r == 2:
%o A393522         return (65 * (4 ** ((n - 8) // 6)) - 8) // 6
%o A393522     if r == 3:
%o A393522         return (325 * (4 ** ((n - 15) // 6)) - 28) // 6
%o A393522     if r == 4:
%o A393522         return (1625 * (4 ** ((n - 22) // 6)) - 128) // 6
%o A393522     return (8125 * (4 ** ((n - 29) // 6)) - 628) // 6
%Y A393522 Cf. A000792 (unrestricted context-free grammars), A389642 (grammars in Greibach normal form).
%K A393522 nonn,easy
%O A393522 1,2
%A A393522 _Hermann Gruber_, Feb 18 2026
