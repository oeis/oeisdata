%N A393861 O.g.f. A(x) satisfies: [x^n] exp( n^6*x - n*A(x) ) = 0 for n >= 1.
%H A393861 Paul D. Hanna, <a href="/A393861/b393861.txt">Table of n, a(n) for n = 1..201</a>
%e A393861 O.g.f.: A(x) = x + 961*x^2 + 20561046*x^3 + 2828414859434*x^4 + 1502423959642724800*x^5 + 2312053430216556675157356*x^6 + ...
%e A393861 ILLUSTRATION OF DEFINITION.
%e A393861 The table of coefficients of x^k/k! in exp( n^6*x - n*A(x) ) begins
%e A393861   n = 1: [1,     0,     -1922,    -123366276, ...];
%e A393861   n = 2: [1,    62,         0,    -247209208, ...];
%e A393861   n = 3: [1,   726,    521310,             0, ...];
%e A393861   n = 4: [1,  4092,  16736776,   67930503696, 0, ...];
%e A393861   n = 5: [1, 15620, 243974790, 3809969172020, 59136370172157820, 0, ...]; ...
%e A393861 in which a diagonal, the coefficient of x^n in row n, is all zeros.
%e A393861 RELATED SERIES.
%e A393861 exp(A(x)) = 1 + x + 1923*x^2/2! + 123372043*x^3/3! + 67882461185305*x^4/4! + 180291216939299026041*x^5/5! + 1664679553611433504038181771*x^6/6! + ...
%e A393861 where [x^n] exp(n^6*x) / exp(A(x))^n = 0 for n >= 1.
%o A393861 (PARI) {a(n,p=6,q=1) = my(A=[0], m); for(i=1, n+1, m=#A; A=concat(A, 0); A[m+1] = Vec( exp(m^p*x - m^q*Ser(A)) )[m+1]/(m^q) ); polcoef( Ser(A), n)}
%o A393861 for(n=1, 15, print1(a(n,6,1), ", "))
%Y A393861 Below, sequences with the parameters (p,q) indicated have an o.g.f. F(x) satisfying [x^n] exp( n^p*x - n^q*F(x) ) = 0 for n >= 1.
