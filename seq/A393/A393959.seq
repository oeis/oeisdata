%U A393959 98114412012247145164,19345043177513116273952,4374978683118395206019280,1124998536966973517751588592,326400398540961682716386832439
%N A393959 G.f. A(x) satisfies A(x) = 1 - E^2(log(1 - x*A(x))), where E is the Euler operator x*d/dx.
%F A393959 G.f.: 1 + E(B(x)), where B(x) is the g.f. of A393136.
%F A393959 a(n) = n * A393136(n) for n > 0.
%F A393959 a(0) = 1; a(n) = n^2 * a(n-1) + Sum_{k=1..n-1} (n/k) * a(k) * a(n-1-k).
%e A393959      -E(log(1 - x*A(x))) =     x + 3*x^2 + 22*x^3 +  295*x^4 + ...
%e A393959 1 - E^2(log(1 - x*A(x))) = 1 + x + 6*x^2 + 66*x^3 + 1180*x^4 + ...
%o A393959 (PARI) E(f) = x*deriv(f);
%o A393959 my(A=1, N=20); for(k=1, N, A=1-E(E(log(1-x*A)))+x*O(x^N)); Vec(A)
%Y A393959 Cf. A003319, A393977, A394821.
%Y A393959 Cf. A393136.
%K A393959 nonn,new
