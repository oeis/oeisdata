%T A393489 9,8,4,4,2,3,2,3,4,8,2,3,4,4,5,8,9,9,8,5,1,4,8,5,2,4,4,2,1,1,2,9,9,6,
%U A393489 7,2,8,5,4,2,5,4,4,1,9,2,7,9,8,8,1,3,7,6,4,4,7,0,1,8,1,9,8,6,9,8,8,0,6,5,7
%N A393489 Decimal expansion of the asymptotic mean of the number of exponential unitary divisors.
%H A393489 Nicuşor Minculete and László Tóth, <a href="https://doi.org/10.71352/ac.35.205">Exponential unitary divisors</a>, Annales Univ. Sci. Budapest., Sect. Comp., Vol. 35 (2011), pp. 205-216. See eq. (8), p. 209.
%H A393489 Y. F. S. Pétermann, <a href="https://ac.inf.elte.hu/Vol_032_2010/doi/143_32.pdf">Arithmetical functions involving exponential divisors: Note on two papers by L. Tóth</a>, Annales Univ. Sci. Budapest., Sect. Comp., Vol. 32 (2010), pp. 143-149. See Theorem A, p. 144.
%H A393489 László Tóth, <a href="https://ac.inf.elte.hu/Vol_027_2007/doi/155_27.pdf">On certain arithmetic functions involving exponential divisors, II</a>, Annales Univ. Sci. Budapest., Sect. Comp., Vol. 27 (2007), pp. 155-166; <a href="https://arxiv.org/abs/0708.3557">arXiv preprint</a>, arXiv:0708.3557 [math.NT], 2007-2009. See Theorem 4, p. 158.
%F A393489 Equals lim_{n->oo} (1/n) * Sum_{k=1..n} A278908(k).
%F A393489 Equals Product_{p prime} (1-1/p) * (1 + Sum_{k>=1} (2^omega(k)/p^k)), where 2^omega(k) = 2^A001221(k) = A034444(k).
%F A393489 Equals Product_{p prime} (1 + Sum_{k>=2} (2^omega(k) - 2^omega(k-1))/p^k).
%e A393489 1.543165319373179880943326634299788984423234823445899...
%o A393489 (PARI) c(m) = prodeulerrat((1-1/p) * (1 + sum(k = 1, m, 2^omega(k)/p^k)));
%o A393489 {my(c1 = 0, c2 = 1, m = 1); while(c2 != c1, c1 = c2; c2 = c(m); m++); c2}
%Y A393489 Cf. A001221, A034444, A278908, A327837, A358659, A361255.
%K A393489 nonn,cons
%O A393489 1,2
