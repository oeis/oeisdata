%N A393275 a(n) = Sum_{k=0..floor(n/4)} binomial(2*k,k) * binomial(n-1,n-4*k).
%H A393275 Vincenzo Librandi, <a href="/A393275/b393275.txt">Table of n, a(n) for n = 0..1000</a>
%F A393275 G.f.: 1/sqrt(1 - 4*x^4/(1-x)^4).
%F A393275 D-finite with recurrence: 3*n*a(n) + (-7 + n)*a(n + 1) + (-20 - 10*n)*a(n + 2) + (30 + 10*n)*a(n + 3) + (-5*n - 20)*a(n + 4) + (n + 5)*a(n + 5) = 0. - _Robert Israel_, Mar 08 2026
%p A393275 f:= gfun:-rectoproc({3*n*a(n) + (-7 + n)*a(n + 1) + (-20 - 10*n)*a(n + 2) + (30 + 10*n)*a(n + 3) + (-5*n - 20)*a(n + 4) + (n + 5)*a(n + 5), a(0) = 1, a(1) = 0, a(2) = 0, a(3) = 0, a(4) = 2},a(n), remember):
%p A393275 map(f, [$0..35]); # _Robert Israel_, Mar 08 2026
%t A393275 Table[Sum[Binomial[2*k,k]*Binomial[n-1,n-4*k],{k,0,Floor[n/4]}],{n,0,35}] (* _Vincenzo Librandi_, Feb 11 2026 *)
%o A393275 (PARI) a(n) = sum(k=0, n\4, binomial(2*k, k)*binomial(n-1, n-4*k));
%o A393275 (Magma) [&+[Binomial(2*k, k)* Binomial(n-1, n-4*k) : k in [0..Floor(n/4)]] : n in [0..43] ]; // _Vincenzo Librandi_, Feb 11 2026
