%N A393843 O.g.f. A(x) satisfies: [x^n] exp( n*(n+1)*(n+2)*x - 6*n*A(x) ) = 0 for n >= 1.
%H A393843 Paul D. Hanna, <a href="/A393843/b393843.txt">Table of n, a(n) for n = 1..301</a>
%e A393843 O.g.f.: A(x) = x + 6*x^2 + 434*x^3 + 78576*x^4 + 25656840*x^5 + 12991627368*x^6 + 9358343638056*x^7 + 9067492522513152*x^8 + ...
%o A393843 (PARI) {a(n,k=3) = my(A=[0], m); for(i=1, n+1, m=#A; A=concat(A, 0); A[m+1] = Vec( exp( k!*binomial(m+k-1,m-1)*x - k!*m*Ser(A) ) )[m+1]/(k!*m) ); polcoef( Ser(A), n)}
%o A393843 for(n=1, 15, print1(a(n,3), ", "))
