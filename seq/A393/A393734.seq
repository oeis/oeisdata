%I A393734 #9 Mar 07 2026 04:31:09
%S A393734 1,1,3,16,104,891,8354,83951,876172,9422525,103666600
%N A393734 Number of free polyominoes in the {7,4} tessellation of the hyperbolic plane.
%F A393734 a(n) = P{p,q}(n) (the number of {p,q} polyominoes of size n) is equal to P{p,oo}(n) for n <= q; also P{p,q}(q+1) = P{p,oo}(q+1) + floor((p-1)/2) - floor((3+q(p-2))/2). In this case, p=7, q=4 and P{p,oo} = A005419.
%Y A393734 Cf. A333018, A393735, A393736, A393737, A393738, A005419.
%K A393734 nonn,more,changed
%O A393734 1,3
