%S A393865 1,16,70956,3330535424,761427167500000,582638218357483190016,
%T A393865 1187008821625861701216334704,5506679118574470385180689045127168,
%U A393865 51905786971852539256016172008925964546272,911575007335118525114451713722405610230204800000,27865918521652658229502411938764349911066494279853276416
%N A393865 O.g.f. A(x) satisfies: [x^n] exp( n^6*x - n^5*A(x) ) = 0 for n >= 1.
%H A393865 Paul D. Hanna, <a href="/A393865/b393865.txt">Table of n, a(n) for n = 1..201</a>
%e A393865 O.g.f.: A(x) = x + 16*x^2 + 70956*x^3 + 3330535424*x^4 + 761427167500000*x^5 + 582638218357483190016*x^6 + ...
%e A393865 ILLUSTRATION OF DEFINITION.
%e A393865 The table of coefficients of x^k/k! in exp( n^6*x - n^5*A(x) ) begins
%e A393865   n = 1: [1,     0,       -32,       -425736, ...];
%e A393865   n = 2: [1,    32,         0,     -13689088, ...];
%e A393865   n = 3: [1,   486,    228420,             0, ...];
%e A393865   n = 4: [1,  3072,   9404416,   28253085696, 0, ...];
%e A393865   n = 5: [1, 12500, 156150000, 1948044575000, 24004031093200000, 0, ...]; ...
%e A393865 in which a diagonal, the coefficient of x^n in row n, is all zeros.
%e A393865 RELATED SERIES.
%e A393865 exp(A(x)) = 1 + x + 33*x^2/2! + 425833*x^3/3! + 79934556385*x^4/4! + 91371659904759441*x^5/5! + 419500065486328595531521*x^6/6! + ...
%e A393865 where [x^n] exp(n^6*x) / exp(A(x))^(n^5) = 0 for n >= 1.
%o A393865 (PARI) {a(n,p=6,q=5) = my(A=[0], m); for(i=1, n+1, m=#A; A=concat(A, 0); A[m+1] = Vec( exp(m^p*x - m^q*Ser(A)) )[m+1]/(m^q) ); polcoef( Ser(A), n)}
%o A393865 for(n=1, 15, print1(a(n,6,5), ", "))
%Y A393865 Below, sequences with the parameters (p,q) indicated have an o.g.f. F(x) satisfying [x^n] exp( n^p*x - n^q*F(x) ) = 0 for n >= 1.
%Y A393865 Cf. A393861 (6,1), A393862 (6,2), A393863 (6,3), A393864 (6,4).
%Y A393865 Cf. A393875 (7,5), A393885 (8,5).
%K A393865 nonn,new
%O A393865 1,2
