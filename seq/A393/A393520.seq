%I A393520 #13 Apr 07 2026 00:20:37
%S A393520 2,3,11,13,31,101,113,307,311,1021,1031,1103,1201,1301,3011,11003,
%T A393520 30011,110221,111211,112111,122011,1000211,1001003,1010201,1020101,
%U A393520 1100311,1101103,1101211,1102111,1111021,1112011,1120001,1121011,1130011,1201111,3001001,3011011,10002121,10011101,10012001
%N A393520 Primes p such that the reversal of p^2 is the square of a prime.
%C A393520 The first two terms that are not in A085306 are a(8) = 307 and a(55) = 30001253.
%C A393520 The first two terms p such that the square root of the reversal of p^2 is neither p nor the reversal of p are a(69) = 110092211 and a(81) = 112191011 (whose squares are each other's reversals).
%e A393520 a(5) = 31 is a term because 31^2 = 961 whose reversal 169 = 13^2, and 13 is prime.
%p A393520 filter:= proc(p) local r;
%p A393520 if not isprime(p) then return false fi;
%p A393520 r:= rev(p^2);
%p A393520 issqr(r) and isprime(sqrt(r))
%p A393520 end proc:
%p A393520 select(filter, [2,seq(i,i=3..2*10^6,2)]);
%t A393520 Select[Prime[Range[10^5]],PrimeQ[Sqrt[IntegerReverse[#^2]]] &] (* _Stefano Spezia_, Apr 05 2026 *)
%o A393520 (PARI) isok(p) = if (isprime(p), my(r = fromdigits(Vecrev(digits(p^2)))); issquare(r) && isprime(sqrtint(r))); \\ _Michel Marcus_, Apr 05 2026
%Y A393520 Cf. A085306. Contains A065378.
%K A393520 nonn,base,new
%O A393520 1,1
%A A393520 _Robert Israel_, Apr 05 2026
