%I A393708 #13 Mar 08 2026 23:33:27
%S A393708 1800,2700,3528,4500,5292,5400,7200,8712,9000,9800,10584,10800,12168,
%T A393708 12348,13068,13500,14112,16200,18000,18252,20808,21168,21600,24200,
%U A393708 24300,24500,24696,25992,26136,28800,31212,31752,33075,33800,34300,34848,36000,36504,37044
%N A393708 Achilles numbers with more than 2 distinct prime factors.
%C A393708 Intersection of A000977 and A052486.
%H A393708 Michael De Vlieger, <a href="/A393708/b393708.txt">Table of n, a(n) for n = 1..10000</a>
%H A393708 <a href="/index/Pow#powerful">Index entries for sequences related to powerful numbers</a>.
%e A393708 Let s = A052486.
%e A393708 Table of n, a(n) for select n:
%e A393708  n              a(n)
%e A393708 --------------------------------------------
%e A393708  1   s(20)  =  1800 = 2^3 * 3^2 *  5^2
%e A393708  2   s(25)  =  2700 = 2^2 * 3^3 *  5^2
%e A393708  3   s(31)  =  3528 = 2^3 * 3^2 *  7^2
%e A393708  4   s(36)  =  4500 = 2^2 * 3^2 *  5^3
%e A393708  5   s(40)  =  5292 = 2^2 * 3^3 *  7^2
%e A393708  6   s(42)  =  5400 = 2^3 * 3^3 *  5^2
%e A393708  7   s(50)  =  7200 = 2^5 * 3^2 *  5^2
%e A393708  8   s(54)  =  8712 = 2^3 * 3^2 * 11^2
%e A393708 10   s(60)  =  9800 = 2^3 * 5^2 *  7^2
%e A393708 33   s(129) = 33075 = 3^3 * 5^2 *  7^2
%e A393708 81   s(237) = 88200 = 2^3 * 3^2 *  5^2 * 7^2
%p A393708 filter:= proc(n) local F;
%p A393708    F:= ifactors(n)[2];
%p A393708    nops(F) > 2 and andmap(`>`,F[..,2],1) and igcd(F[..,2])=1
%p A393708 end proc:
%p A393708 select(F, [$1..50000]); # _Robert Israel_, Mar 03 2026
%t A393708 With[{nn = 40000}, Union@ Flatten@ Rest@ Table[If[And[Length[#] > 2, GCD @@ # == 1] &@ FactorInteger[#][[All, -1]], #, Nothing] &[a^2*b^3], {b, Surd[nn, 3]}, {a, Sqrt[nn/b^3] } ] ]
%o A393708 (PARI) isok(k)=my(f=factor(k)); k>9 && vecmin(f[,2])>1 && gcd(f[,2])==1 && omega(f)>2; \\ _Michel Marcus_, Mar 03 2026
