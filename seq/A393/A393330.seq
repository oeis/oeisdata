%T A393330 2081310,4174170,23993970,46786740,1752280530,727987260,1155284130,
%U A393330 1125164040
%N A393330 a(n) is the smallest k for which A391684(k) = n.
%p A393330 f:= proc(n)
%p A393330   nops(select(d -> (n/d)^2-1 mod d = 0, NumberTheory:-Divisors(n)))
%p A393330 end proc:
%p A393330 N:= 19: # for a(1)..a(N)
%p A393330 V:= Vector(N): count:= 0:
%p A393330 for x from 1 while count < N do
%p A393330   v:= f(x);
%p A393330   if v <= N and V[v] = 0 then V[v]:= x; count:= count+1; fi:
%p A393330 od:
%p A393330 convert(V,list); # _Robert Israel_, May 06 2026
%t A393330 seq[len_] := Module[{v = Table[0, {len}], n = 0, c = 0, i}, While[c < len, n++; i = DivisorSum[n, 1 &, Divisible[(n/#)^2 - 1, #] &]; If[i <= len && v[[i]] == 0, v[[i]] = n; c++]]; v]; seq[14] (* _Amiram Eldar_, May 07 2026 *)
%o A393330 (PARI) f(n) = sumdiv(n, d, (((n/d)^2-1) % d) == 0); \\ A391684
%o A393330 a(n) = my(k=1); while (f(k) !=n, k++); k; \\ _Michel Marcus_, May 07 2026
