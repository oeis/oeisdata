%N A393475 G.f. A(x) satisfies A(x) = 1 - E(log(1 - x*(1 + E^2(A(x))))), where E is the Euler operator x*d/dx.
%F A393475 G.f. A(x) satisfies A(x) = 1 + x*A(x)*(1 + E^2(A(x))) + x*E^3(A(x)).
%F A393475 G.f.: 1 - E(log(1 - x*B(x))), where B(x) is the g.f. of A393977.
%F A393475 a(0) = 1; a(n) = ((n-1)^3+1) * a(n-1) + Sum_{k=1..n-1} k^2 * a(k) * a(n-1-k).
%o A393475 (PARI) E(f) = x*deriv(f);
%o A393475 my(A=1, N=20); for(k=1, N, A=1+x*A*(1+E(E(A)))+x*E(E(E(A)))+x*O(x^N)); Vec(A)
