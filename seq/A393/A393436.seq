%t A393436 Block[{c, k, s, p, u, nn}, nn = 65; c[_] := False; k = s = p = 1; c[1] = True; u = 2; Reap[Do[k = u; While[Or[c[k], ! CoprimeQ[s + k, p*k]], k++]; c[k] = True; Sow[s]; s += k; p *= k; If[k == u, While[c[u], u++]], {n, 2, nn}] ][[-1, 1]] ] (* _Michael De Vlieger_, Mar 10 2026 *)
