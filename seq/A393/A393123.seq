%T A393123 223210275,262331175,1465324625,3147146375,8989476475
%N A393123 Numbers k such that sigma(k) = psi(k) + pi(k) + Omega(k)^3.
%e A393123 344 is a term since sigma(344) = 660 = 528 + 68 + 4^3 = psi(344) + pi(344) + Omega(344)^3.
%o A393123 (PARI) dedpsi(f) = prod(k = 1, #f~, (f[k, 1]+1) * f[k, 1]^(f[k, 2]-1));
%o A393123 list(lim) = {my(q = 2, m = 0, f); print1(1, ", "); forprime(p = 3, lim, m++; for(k = q, p-1, f = factor(k); if(sigma(f) == dedpsi(f) + m + bigomega(f)^3, print1(k, ", "))); q = p); } \\ _Amiram Eldar_, Mar 05 2026
