%I A393541 #32 Mar 21 2026 10:02:17
%S A393541 30,690,210,420,4830,4620,9660,39270,90090,60060,106260,180180,318780,
%T A393541 510510,1492260,1531530,1021020,1381380,3063060,5419260,4144140,
%U A393541 12432420,9699690,29609580,29099070,35225190,19399380,26246220,38798760,77597520,70450380,78738660
%N A393541 Least composite divisible by the sum of three of its distinct prime divisors in exactly n different ways.
%C A393541 All the numbers found are divisible by 30.
%C A393541 Terms of the sequence which can be divided by all the possible sums of 3 of their different prime divisors are 30, 420, ...
%H A393541 Giovanni Resta, <a href="/A393541/b393541.txt">Table of n, a(n) for n = 1..100</a> (first 45 terms from Paolo P. Lava).
%e A393541 a(4) = 420 because its prime factors are 2, 3, 5, 7 and
%e A393541   420/(2+3+5) = 42;  420/(2+3+7) = 35;  420/(2+5+7) = 30;  420/(3+5+7) = 28.
%e A393541 a(10) = 60060 because its prime factors are 2, 3, 5, 7, 11, 13 and
%e A393541   60060 /(2+3+5) = 6006;  60060 /(2+3+7) = 5005;  60060 /(2+5+7) = 4290;  60060 /(2+5+13) = 3003;
%e A393541   60060 /(2+7+11) = 3003;  60060 /(2+7+13) = 2730;  60060/(2+11+13) = 2310;  60060 /(3+5+7) = 4004;
%e A393541   60060 /(3+5+13) = 2860;  60060 /(3+7+11) = 2860.
%t A393541 a[n_]:=Module[{k=4},While[ Total[Boole[Divisible[k,Total/@Subsets[First/@FactorInteger[k],{3}]]]]!=n,k++];k];Array[a,15] (* _James C. McMahon_, Mar 14 2026 *)
