%N A393873 O.g.f. A(x) satisfies: [x^n] exp( n^7*x - n^3*A(x) ) = 0 for n >= 1.
%H A393873 Paul D. Hanna, <a href="/A393873/b393873.txt">Table of n, a(n) for n = 1..201</a>
%e A393873 O.g.f.: A(x) = x + 900*x^2 + 60264000*x^3 + 45080435520000*x^4 + 188707522069890000000*x^5 + 3025031182134203198563200000*x^6 + ...
%e A393873 ILLUSTRATION OF DEFINITION.
%e A393873 The table of coefficients of x^k/k! in exp( n^7*x - n^3*A(x) ) begins
%e A393873   n = 1: [1,     0,      -1800,      -361584000, ...];
%e A393873   n = 2: [1,   120,          0,     -2896128000, ...];
%e A393873   n = 3: [1,  2160,    4617000,               0, ...];
%e A393873   n = 4: [1, 16320,  266227200,   4317926400000, 0, ...];
%e A393873   n = 5: [1, 78000, 6083775000, 474454152000000, 36857499669315000000, 0, ...]; ...
%e A393873 in which a diagonal, the coefficient of x^n in row n, is all zeros.
%e A393873 RELATED SERIES.
%e A393873 exp(A(x)) = 1 + x + 1801*x^2/2! + 361589401*x^3/3! + 1081931908546801*x^4/4! + 22644908064551238858001*x^5/5! + 2178022587036578013496540707001*x^6/6! + ...
%e A393873 where [x^n] exp(n^7*x) / exp(A(x))^(n^3) = 0 for n >= 1.
%o A393873 (PARI) {a(n,p=7,q=3) = my(A=[0], m); for(i=1, n+1, m=#A; A=concat(A, 0); A[m+1] = Vec( exp(m^p*x - m^q*Ser(A)) )[m+1]/(m^q) ); polcoef( Ser(A), n)}
%o A393873 for(n=1, 15, print1(a(n,7,3), ", "))
%Y A393873 Below, sequences with the parameters (p,q) indicated have an o.g.f. F(x) satisfying [x^n] exp( n^p*x - n^q*F(x) ) = 0 for n >= 1.
