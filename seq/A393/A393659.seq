%N A393659 Expansion of (1/x) * Series_Reversion( x * ( Sum_{k=0..5} (-x)^k )^2 ).
%H A393659 Vincenzo Librandi, <a href="/A393659/b393659.txt">Table of n, a(n) for n = 0..1000</a>
%F A393659 G.f.: (1/x) * Series_Reversion( x * ((1-x^6) / (1+x))^2 ).
%F A393659 a(n) = (1/(n+1)) * Sum_{k=0..floor(n/6)} binomial(2*n+k+1,k) * binomial(2*n+2,n-6*k).
%t A393659 CoefficientList[Normal@Series[InverseSeries@Series[x*((1-x^6)/(1+x))^2,{x,0,50}]/x,{x,0,27}],x] (* _Vincenzo Librandi_, Mar 26 2026 *)
%o A393659 (PARI) a(n) = sum(k=0, n\6, binomial(2*n+k+1, k)*binomial(2*n+2, n-6*k))/(n+1);
%o A393659 (Magma) N := 35; R<x> := PowerSeriesRing(Rationals(), N+5); f:= x*((1-x^6)/(1+x))^2; g:= Reverse(f) div x; Coeffs := [Coefficient(g,i):i in [0..N]]; Coeffs; // _Vincenzo Librandi_, Mar 26 2026
