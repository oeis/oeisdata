%T A393766 280074358196364240,380332054752913044144,642017615373988371316080,
%U A393766 1318319053876851041202270336,3235961655020103289427942421696,9358894730999498868738520510289472,31505747046642247007603936060957023488,122167683295653632783831578374237675279360
%N A393766 O.g.f. A(x) satisfies: [x^n] exp( n^2*(n+6)*x - n*A(x) ) = 0 for n >= 1.
%H A393766 Paul D. Hanna, <a href="/A393766/b393766.txt">Table of n, a(n) for n = 1..301</a>
%F A393766 a(n) ~ sqrt(1-w) * 3^(3*n + 1) * n^(2*n - 3/2) / (sqrt(2*Pi) * exp(2*n) * (3-w)^(2*n-1) * w^(n+2)), where w = -A226750 = -LambertW(-3*exp(-3)). - _Vaclav Kotesovec_, Mar 02 2026
%e A393766 O.g.f.: A(x) = 7*x + 81*x^2 + 7140*x^3 + 1527426*x^4 + 575094060*x^5 + 329150631240*x^6 + 263602136467152*x^7 + 280074358196364240*x^8 + ...
%e A393766 ILLUSTRATION OF DEFINITION.
%e A393766 The table of coefficients of x^k/k! in exp( n^2*(n+6)*x - n*A(x) ) begin
%e A393766   n = 1: [1,   0,  -162,   -42840,  -36579492, ...];
%e A393766   n = 2: [1,  18,     0,   -97344,  -79695360, ...];
%e A393766   n = 3: [1,  60,  3114,        0, -137648484, ...];
%e A393766   n = 4: [1, 132, 16776,  1872000,          0, ...];
%e A393766   n = 5: [1, 240, 56790, 13026600, 2650869180, 0, ...];
%e A393766   ...
%e A393766 in which a diagonal, the coefficient of x^n in row n, equals all zeros.
%e A393766 RELATED SERIES.
%e A393766 exp(A(x)) = 1 + 7*x + 211*x^2/2! + 46585*x^3/3! + 37986505*x^4/4! + 70388045527*x^5/5! + 240024640799179*x^6/6! + ...
%e A393766 where [x^n] exp(n^2*(n+6)*x) / exp(A(x))^n = 0 for n >= 1.
%o A393766 (PARI) {a(n,k=6) = my(A=[0], m); for(i=1, n+1, m=#A; A=concat(A, 0); A[m+1] = Vec( exp(m^2*(m+k)*x - m*Ser(A)) )[m+1]/m ); polcoef( Ser(A), n)}
%o A393766 for(n=1, 15, print1(a(n,6), ", "))
%Y A393766 Cf. A393760, A317347, A393761, A393762, A393763, A393764, A393765, A393767.
