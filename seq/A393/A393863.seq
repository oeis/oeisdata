%N A393863 O.g.f. A(x) satisfies: [x^n] exp( n^6*x - n^3*A(x) ) = 0 for n >= 1.
%H A393863 Paul D. Hanna, <a href="/A393863/b393863.txt">Table of n, a(n) for n = 1..201</a>
%e A393863 O.g.f.: A(x) = x + 196*x^2 + 1997892*x^3 + 162416882432*x^4 + 56765045709658000*x^5 + 61618456433240675155008*x^6 + ...
%e A393863 ILLUSTRATION OF DEFINITION.
%e A393863 The table of coefficients of x^k/k! in exp( n^6*x - n^3*A(x) ) begins
%e A393863   n = 1: [1,     0,      -392,     -11987352, ...];
%e A393863   n = 2: [1,    56,         0,     -96250048, ...];
%e A393863   n = 3: [1,   702,    482220,             0, ...];
%e A393863   n = 4: [1,  4032,  16231936,   64477665792, 0, ...];
%e A393863   n = 5: [1, 15500, 240201000, 3720098081000, 57069283577704000, 0, ...]; ...
%e A393863 in which a diagonal, the coefficient of x^n in row n, is all zeros.
%e A393863 RELATED SERIES.
%e A393863 exp(A(x)) = 1 + x + 393*x^2/2! + 11988529*x^3/3! + 3898053591121*x^4/4! + 6811825022297454081*x^5/5! + 44365329527182186764295321*x^6/6! + ...
%e A393863 where [x^n] exp(n^6*x) / exp(A(x))^(n^3) = 0 for n >= 1.
%o A393863 (PARI) {a(n,p=6,q=3) = my(A=[0], m); for(i=1, n+1, m=#A; A=concat(A, 0); A[m+1] = Vec( exp(m^p*x - m^q*Ser(A)) )[m+1]/(m^q) ); polcoef( Ser(A), n)}
%o A393863 for(n=1, 15, print1(a(n,6,3), ", "))
%Y A393863 Below, sequences with the parameters (p,q) indicated have an o.g.f. F(x) satisfying [x^n] exp( n^p*x - n^q*F(x) ) = 0 for n >= 1.
