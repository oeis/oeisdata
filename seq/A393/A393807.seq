%T A393807 525,535,545,606,616,626,636,646,656,707,717,727,737,747,757,767,808,
%U A393807 818,828,838,848,858,868,878,909,919,929,939,949,959,969,979,989,11011,12021,13031,14041,15051
%N A393807 Palindromes that have only one smallest digit (strict minimum).
%C A393807 All terms have an odd number of digits. The sequence is infinite.
%C A393807 Differs first from A266139 in not having 12121. - _R. J. Mathar_, Mar 06 2026
%H A393807 Michael S. Branicky, <a href="/A393807/b393807.txt">Table of n, a(n) for n = 1..10000</a>
%t A393807 Select[Range[0,15200],PalindromeQ[#] &&Count[digits=IntegerDigits[#], Min[digits]]==1 &] (* _Stefano Spezia_, Feb 28 2026 *)
%o A393807 (Python)
%o A393807 from itertools import count, islice, product
%o A393807 def agen():
%o A393807     yield from range(10)
%o A393807     for digs in count(3, step=2):
%o A393807         for first in "123456789":
%o A393807             for left in product("123456789", repeat=(digs-3)//2):
%o A393807                 left = "".join(left)
%o A393807                 mn = int(min(first+left))
%o A393807                 for mid in "".join(map(str, range(0, mn))):
%o A393807                     yield int(first + left + mid + left[::-1] + first)
%o A393807 print(list(islice(agen(), 60))) # _Michael S. Branicky_, Feb 28 2026
%Y A393807 Supersequence of A393015.
%Y A393807 Cf. A002113, A110785, A134970.
