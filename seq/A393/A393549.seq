%I A393549 #19 Mar 24 2026 23:14:42
%S A393549 0,9,252,4464,62784,763920,8455680,88367040,896734080,8996734080,
%T A393549 90000000000,900000000000,9000000000000,90000000000000,
%U A393549 900000000000000,9000000000000000,90000000000000000,900000000000000000,9000000000000000000,90000000000000000000,900000000000000000000
%N A393549 a(n) is the number of n-digit numbers in which at least one digit occurs more than once.
%H A393549 <a href="/index/Rec#order_01">Index entries for linear recurrences with constant coefficients</a>, signature (10).
%F A393549 a(n) = 9*(10^(n-1) - 9!/(10 - n)!) for n <= 10.
%F A393549 a(n) = 9*10^(n-1) for n > 10.
%F A393549 a(n) = 10*a(n-1) for n > 11.
%F A393549 E.g.f.: 9*(exp(10*x) - (1 + x)^10)/10.
%t A393549 a[n_]:=9*(10^(n-1)-9!/(10-n)!); Array[a,21]
%Y A393549 Cf. A007318, A052268, A073531, A109303.
%K A393549 nonn,base,easy,new
