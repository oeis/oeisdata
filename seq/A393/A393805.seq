%I A393805 #11 Mar 10 2026 22:46:45
%S A393805 7,9,11,17,19,21,25,41,1871
%N A393805 Numbers k for which omega(k)*omega(k + 2)*omega(k + 4)*omega(k + 6)*omega(k + 8) = 2 where omega = A001221.
%C A393805 All terms are odd.
%e A393805    k    |  omega(k)*omega(k + 2)*omega(k + 4)*omega(k + 6)*omega(k + 8)
%e A393805 -----------------------------------------------------------------------
%e A393805      7  |    1     *      1     *     1      *      1     *      2     =    2
%e A393805      9  |    1     *      1     *     1      *      2     *      1     =    2
%e A393805     11  |    1     *      1     *     2      *      1     *      1     =    2
%e A393805     17  |    1     *      1     *     2      *      1     *      1     =    2
%e A393805     19  |    1     *      2     *     1      *      1     *      1     =    2
%e A393805     21  |    2     *      1     *     1      *      1     *      1     =    2
%e A393805     25  |    1     *      1     *     1      *      1     *      2     =    2
%e A393805     41  |    1     *      1     *     2      *      1     *      1     =    2
%e A393805   1871  |    1     *      1     *     2      *      1     *      1     =    2
%t A393805 Select[Range[2000],PrimeNu[#]PrimeNu[#+2]PrimeNu[#+4]PrimeNu[#+6]PrimeNu[#+8]==2 &] (* _Stefano Spezia_, Feb 28 2026 *)
%o A393805 (Magma) [k: k in [1..10^6] | #PrimeDivisors(k)*#PrimeDivisors(k+2)*#PrimeDivisors(k+4)*#PrimeDivisors(k+6)*#PrimeDivisors(k+8) eq 2];
%Y A393805 Cf. A000961, A001221, A392232, A393108.
%K A393805 nonn,hard,more
%O A393805 1,1
%A A393805 _Juri-Stepan Gerasimov_, Feb 27 2026
