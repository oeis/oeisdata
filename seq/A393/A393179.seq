%N A393179 Number of k <= 2^(n-1) such that tau(k) = n where tau = A000005.
%C A393179 For prime p, A000005(p^(n-1)) = n.
%C A393179 a(n) = 1 if n is noncomposite (A008578) and a(n) > 1 if n is composite (A002808).
%e A393179  n \   k                                                                         | a(n)
%e A393179 ---------------------------------------------------------------------------------------
%e A393179  1  |  1                                                                         |  1
%e A393179  2  |  2                                                                         |  1
%e A393179  3  |  4                                                                         |  1
%e A393179  4  |  6, 8                                                                      |  2
%e A393179  5  |  16                                                                        |  1
%e A393179  6  |  12, 18, 20, 28, 32                                                        |  5
%e A393179  7  |  64                                                                        |  1
%e A393179  8  |  24, 30, 40, 42, 54, 56, 66, 70, 78, 88, 102, 104, 105, 110, 114, 128      | 16
%e A393179  9  |  36, 100, 196, 225, 256                                                    |  5
%e A393179  10 |  48, 80, 112, 162, 176, 208, 272, 304, 368, 405, 464, 496, 512             | 13
%t A393179 d[k_] := d[k] = DivisorSigma[0, k]; a[n_] := Count[Range[2^(n - 1)], _?(d[#] == n &)]; Array[a, 20] (* _Amiram Eldar_, Mar 11 2026 *)
%o A393179 (Magma) [#[k: k in [1..2^(n - 1)] | #Divisors(k) eq n]: n in [1..23]];
%o A393179 (PARI) a(n) = #select(x->(numdiv(x)==n), [1..2^(n-1)]); \\ _Michel Marcus_, Mar 11 2026
%o A393179 (PARI) list(nmax) = {my(v = vector(nmax), n); for(k = 1, 2^(nmax-1), n = numdiv(k); if(n <= nmax && k <= (1 << (n-1)), v[n]++)); v;} \\ _Amiram Eldar_, Mar 11 2026
