%I A393803 #47 Apr 13 2026 22:37:12
%S A393803 0,1,2,5,10,12,13,14,20,22,24,25,26,33,35,36,37,38,42,43,53,69,71,72,
%T A393803 73,74,77,88,100,106,113,116,120,121,122,124,137,138,139,142,147,150,
%U A393803 151,154,156,157,158,178,184,197,201,203,204,205,206,209,210,211,214,226,228,229
%N A393803 Numbers whose number of nonzero digits is identical in base 2 and 3.
%H A393803 Vincenzo Manto, <a href="/A393803/b393803.txt">Table of n, a(n) for n = 1..9999</a>
%p A393803 q:= n-> (f-> f(n, 2)=f(n, 3))((k, b)-> nops(subs(0=[][], convert(k, base, b)))):
%p A393803 select(q, [$0..230])[];  # _Alois P. Heinz_, Apr 01 2026
%t A393803 q[k_] := DigitCount[k, 2, 1] == Total[DigitCount[k, 3, {1, 2}]]; Select[Range[0, 230], q] (* _Amiram Eldar_, Mar 29 2026 *)
%o A393803 (Python)
%o A393803 def nonzero_digits(n, b):
%o A393803     count = 0
%o A393803     while n > 0:
%o A393803         if n % b: count += 1
%o A393803         n //= b
%o A393803     return count
%o A393803 def ok(n):
%o A393803     return nonzero_digits(n, 2) == nonzero_digits(n, 3)
%o A393803 print([k for k in range(230) if ok(k)]) # _Vincenzo Manto_, Apr 08 2026
%Y A393803 Cf. A000120, A160384.
%K A393803 nonn,base
%O A393803 1,3
%A A393803 _Vincenzo Manto_, Mar 29 2026
