%N A393872 O.g.f. A(x) satisfies: [x^n] exp( n^7*x - n^2*A(x) ) = 0 for n >= 1.
%H A393872 Paul D. Hanna, <a href="/A393872/b393872.txt">Table of n, a(n) for n = 1..201</a>
%e A393872 O.g.f.: A(x) = x + 1922*x^2 + 187142472*x^3 + 183597468457376*x^4 + 953514172711909259000*x^5 + 18276387681088598468952311136*x^6 + ...
%e A393872 ILLUSTRATION OF DEFINITION.
%e A393872 The table of coefficients of x^k/k! in exp( n^7*x - n^2*A(x) ) begins
%e A393872   n = 1: [1,     0,      -3844,     -1122854832, ...];
%e A393872   n = 2: [1,   124,          0,     -4495232576, ...];
%e A393872   n = 3: [1,  2178,    4709088,               0, ...];
%e A393872   n = 4: [1, 16368,  267849920,   4364188418304, 0, ...];
%e A393872   n = 5: [1, 78100, 6099513900, 476328953399200, 37082797167367284400, 0, ...]; ...
%e A393872 in which a diagonal, the coefficient of x^n in row n, is all zeros.
%e A393872 RELATED SERIES.
%e A393872 exp(A(x)) = 1 + x + 3845*x^2/2! + 1122866365*x^3/3! + 4406343778748425*x^4/4! + 114421722800299315939001*x^5/5! + 13158999817180739155646851915021*x^6/6! + ...
%e A393872 where [x^n] exp(n^7*x) / exp(A(x))^(n^2) = 0 for n >= 1.
%o A393872 (PARI) {a(n,p=7,q=2) = my(A=[0], m); for(i=1, n+1, m=#A; A=concat(A, 0); A[m+1] = Vec( exp(m^p*x - m^q*Ser(A)) )[m+1]/(m^q) ); polcoef( Ser(A), n)}
%o A393872 for(n=1, 15, print1(a(n,7,2), ", "))
%Y A393872 Below, sequences with the parameters (p,q) indicated have an o.g.f. F(x) satisfying [x^n] exp( n^p*x - n^q*F(x) ) = 0 for n >= 1.
