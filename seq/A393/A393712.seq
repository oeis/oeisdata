%N A393712 a(n) = number of triples (x, y, z) such that x^2 + y*z = n, where x, y, z are positive integers satisfying x < y <= z.
%e A393712 a(19) = 3 counts these triples: (1, 2, 9), (1, 3, 6), (2, 3, 5).
%t A393712 t[n_, c_] := Module[{r}, r = Flatten[Table[If[n - x^2 <= 0, {},
%t A393712        Map[({x, #, Quotient[n - x^2, #]} &),
%t A393712         Select[Divisors[n - x^2], Divisible[n - x^2, #] &]]], {x, 1,
%t A393712        Floor[Sqrt[n - 1]]}], 1]; Select[r, Apply[c, #] &]];
%t A393712 c = (#1 < #2 && #2 <= #3 &); Table[{n, t[n, c]}, {n, 1, 30}]
%t A393712 Join[{0}, Table[Length[t[n, c]], {n, 1, 130}]]
