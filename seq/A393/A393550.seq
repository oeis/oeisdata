%S A393550 1,320793350,485567925,905738150,1751006325,9169290725,9881908925
%N A393550 Numbers k such that sigma(k) = psi(k) + pi(k) + Omega(k)^9.
%e A393550 320793350 is a term since sigma(320793350) = 597336768 = 578067840 + 17315803 + 5^9 = psi(320793350) + pi(320793350) + Omega(320793350)^9.
%o A393550 (PARI) dedpsi(f) = prod(k = 1, #f~, (f[k, 1]+1) * f[k, 1]^(f[k, 2]-1));
%o A393550 list(lim) = {my(q = 2, m = 0, f); print1(1, ", "); forprime(p = 3, lim, m++; for(k = q, p-1, f = factor(k); if(sigma(f) == dedpsi(f) + m + bigomega(f)^9, print1(k, ", "))); q = p); } \\ _Amiram Eldar_, Mar 20 2026
