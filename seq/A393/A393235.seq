%o A393235 (PARI) C_xy(N) = {my(x='x+O('x^(N+1)), A=1); for(i=1,N, A= 1/(1 - A*y*sum(k=1,N, x^k/(1 + x^k*y*A)))); vector(N-1, n, Vecrev(polcoeff(A, n-1)))}
