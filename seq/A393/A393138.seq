%N A393138 Triangle read by rows. T(n, k) = Sum_{i=0..k} C(k, i) * C(n - i, floor((n - i) / 2)).
%F A393138 T(n, k) = T(n, k-1) + T(n-1, k-1) for k > 0, binomial(n, floor(n / 2)) if k = 0.
%e A393138 Triangle begins:
%e A393138   [0]   1;
%e A393138   [1]   1,   2;
%e A393138   [2]   2,   3,   5;
%e A393138   [3]   3,   5,   8,  13;
%e A393138   [4]   6,   9,  14,  22,  35;
%e A393138   [5]  10,  16,  25,  39,  61,   96;
%e A393138   [6]  20,  30,  46,  71, 110,  171,  267;
%e A393138   [7]  35,  55,  85, 131, 202,  312,  483,  750;
%e A393138   [8]  70, 105, 160, 245, 376,  578,  890, 1373, 2123;
%e A393138   [9] 126, 196, 301, 461, 706, 1082, 1660, 2550, 3923, 6046;
%p A393138 T := proc(n, k) option remember; ifelse(k = 0, binomial(n, iquo(n, 2)), T(n, k-1) + T(n-1, k-1)) end: for n from 0 to 9 do seq(T(n, k), k = 0..n) od;
%o A393138 (Python)
%o A393138 from math import comb as binom
%o A393138 def A393138(n: int, k: int) -> int:
%o A393138     return sum(binom(k, i) * binom(n-i, (n-i) >> 1) for i in range(k + 1))
%o A393138 for n in range(10): print([A393138(n, k) for k in range(n + 1)])
%Y A393138 T(n, 0) = A001405(n), T(n, n) = A005773(n+1), A393139 (row sums).
