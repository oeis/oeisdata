%I A393707 #21 Mar 12 2026 13:53:24
%S A393707 3,2,1,82,173,677,4637,7337,5225,97162,533225,523589,522335,523325,
%T A393707 49138342,52232510,1098900,52222610,52223600,109433225,99522500,522500
%N A393707 a(n) is the smallest positive integer that can be written in exactly n ways as the sum of a square and the reverse of a square.
%C A393707 a(n) is the first k such that A393705(k) = n.
%C A393707 From _David Consiglio, Jr._, Mar 03 2026: (Start)
%C A393707 a(22) > 8 * 10^9, a(23) = 52259900, a(24) = 52260890, a(25) = 52332500, a(27) = 110533500, a(30) = 52310225, a(47) = 52250000, a(49) = 52277225.
%C A393707 There are now a few instances of terms very near one another a(10)-a(13); a(15), a(17), a(18); a(23)-a(25); a(47), a(49)) all with starting digits 52. Why do these groupings occur? (End)
%C A393707 a(31) = 109989000. - _Michael S. Branicky_, Mar 12 2026
%F A393707 A393705(a(n)) = n.
%e A393707 a(3) = 82 because 82 = 36 + 46 = 64 + 18 = 81 + 1 where 36, 64 and 81 are squares and 46, 18 and 1 are the reverses of the squares 64, 81 and 1.
%p A393707 rev:= proc(n) local L,i;
%p A393707   L:= convert(n,base,10);
%p A393707   add(L[-i]*10^(i-1),i=1..nops(L))
%p A393707 end proc:
%p A393707 N:= 10^6: V:= Array(0..N,datatype=integer[1]):
%p A393707 for x from 0 to 1000 do
%p A393707   V[x^2]:= V[x^2]+1;
%p A393707   for i from 1 to 9 do
%p A393707     for j from 0 to 1000 do
%p A393707       y:= rev((i+10*j)^2);
%p A393707       z:= x^2+y;
%p A393707       if z <= N then V[z]:= V[z]+1 fi
%p A393707 od od od:
%p A393707 A:= Array(0..13):
%p A393707 for i from 1 to 10^6 do
%p A393707   if A[V[i]] = 0 then A[V[i]]:= i; fi
%p A393707 od:
%p A393707 convert(A,list);
%o A393707 (Python)
%o A393707 from array import array
%o A393707 hits = array('i', [0]) * 2000000000
%o A393707 squares = sorted([x**2 for x in range(15000)])
%o A393707 reverse_squares = sorted(list(set([int(str(a)[::-1]) for a in squares])))
%o A393707 hits[0] = 999 #don't count zero
%o A393707 for a in squares:
%o A393707     for b in reverse_squares:
%o A393707         hits[a+b] += 1
%o A393707 for q in range(0,22):
%o A393707     print(hits.index(q), end=", ")
%o A393707 # _David Consiglio, Jr._, Mar 03 2026
