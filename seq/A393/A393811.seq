%I A393811 #39 Mar 11 2026 18:05:04
%S A393811 1,6,20,27,32,37,44,57,92,95,98,109,170,228,254,258,284,339,349,370,
%T A393811 375,576,658,684,693,726,800,986,1054,1176,1216,1236,1278,1373,1397,
%U A393811 1410,1581,1704,1724,1727,1760,1893,1903,1954,2019,2383,2384,2458,2477,2591,2627
%N A393811 Integers k such that f(5k), f(5k+2), and f(5k+4) are all prime where f(x) = 2*x^2+2*x+1 = x^2+(x+1)^2.
%C A393811 The existence of infinitely many such integers k would immediately imply the infinitude of primes of the form x^2+(x+1)^2.
%H A393811 Alois P. Heinz, <a href="/A393811/b393811.txt">Table of n, a(n) for n = 1..10000</a>
%e A393811 For k=1, we get the three prime numbers of the form x^2+(x+1)^2: f(5)=61, f(7)=113, f(9)=181.
%e A393811 For k=6, we obtain the three prime numbers of the form x^2+(x+1)^2: f(30)=1861, f(32)=2113, f(34)=2381.
%p A393811 q:= k-> (f-> andmap(isprime, [f(5*k+2*i)$i=0..2]))(x-> 2*x^2+2*x+1):
%p A393811 select(q, [$0..2700])[];  # _Alois P. Heinz_, Mar 07 2026
%t A393811 ClearAll[f]
%t A393811 f[x_] := 2 x^2 + 2 x + 1
%t A393811 bound = 10^6;
%t A393811 results =
%t A393811   Select[Range[1, bound],
%t A393811    PrimeQ[f[5 #]] && PrimeQ[f[5 # + 2]] && PrimeQ[f[5 # + 4]] &];
%t A393811 Length[results]
%t A393811 results
%t A393811 Max[results]
%o A393811 (PARI) f(x) = 2*x^2+2*x+1;
%o A393811 isok(k) = isprime(f(5*k)) && isprime(f(5*k+2)) && isprime(f(5*k+4)); \\ _Michel Marcus_, Mar 07 2026
%o A393811 (Python)
%o A393811 from itertools import count, islice
%o A393811 from sympy import isprime
%o A393811 def A393811_gen(startvalue=1): # generator of terms >= startvalue
%o A393811     for k in count(max(startvalue,1)):
%o A393811         if isprime(m:=10*k*(5*k+1)+1) and isprime(m+40*k+12) and isprime(m+80*k+40):
%o A393811             yield k
%o A393811 A393811_list = list(islice(A393811_gen(),51)) # _Chai Wah Wu_, Mar 11 2026
%Y A393811 Cf. A027862.
%K A393811 nonn
