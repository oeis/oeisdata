%S A393763 4,36,2604,471456,153941040,77949764208,56150061828336,
%T A393763 54404955135078912,68156337346386179040,107174418868091062967040,
%U A393763 206698301747199115385571072,479871405497148373579406192640,1320497324108367814170304802767872,4251174638430062338734634870654520064,15833848575753418838990864636144026356480
%N A393763 O.g.f. A(x) satisfies: [x^n] exp( n^2*(n+3)*x - n*A(x) ) = 0 for n >= 1.
%H A393763 Paul D. Hanna, <a href="/A393763/b393763.txt">Table of n, a(n) for n = 1..301</a>
%F A393763 a(n) ~ sqrt(1-w) * 3^(3*n) * n^(2*n - 3/2) / (sqrt(2*Pi) * exp(2*n) * (3-w)^(2*n-1) * w^(n+1)), where w = -A226750 = -LambertW(-3*exp(-3)). - _Vaclav Kotesovec_, Mar 02 2026
%e A393763 O.g.f.: A(x) = 4*x + 36*x^2 + 2604*x^3 + 471456*x^4 + 153941040*x^5 + 77949764208*x^6 + 56150061828336*x^7 + 54404955135078912*x^8 + ...
%e A393763 ILLUSTRATION OF DEFINITION.
%e A393763 The table of coefficients of x^k/k! in exp( n^2*(n+3)*x - n*A(x) ) begin
%e A393763   n = 1: [1,   0,   -72,  -15624, -11299392, ...];
%e A393763   n = 2: [1,  12,     0,  -34704, -24171264, ...];
%e A393763   n = 3: [1,  42,  1548,       0, -40853808, ...];
%e A393763   n = 4: [1,  96,  8928,  739296,         0, ...];
%e A393763   n = 5: [1, 180, 32040, 5559480, 867343680, 0, ...];
%e A393763   ...
%e A393763 in which a diagonal, the coefficient of x^n in row n, equals all zeros.
%e A393763 RELATED SERIES.
%e A393763 exp(A(x)) = 1 + 4*x + 88*x^2/2! + 16552*x^3/3!+ 11587648*x^4/4! + 18713330944*x^5/5! + 56584856838016*x^6/6! + ...
%e A393763 where [x^n] exp(n^2*(n+3)*x) / exp(A(x))^n = 0 for n >= 1.
%o A393763 (PARI) {a(n,k=3) = my(A=[0], m); for(i=1, n+1, m=#A; A=concat(A, 0); A[m+1] = Vec( exp(m^2*(m+k)*x - m*Ser(A)) )[m+1]/m ); polcoef( Ser(A), n)}
%o A393763 for(n=1, 15, print1(a(n,3), ", "))
%Y A393763 Cf. A393760, A317347, A393761, A393762, A393764, A393765, A393766, A393767.
