%I A393140 #21 Mar 09 2026 07:47:51
%S A393140 1,1,2,2,6,10,3,15,48,39,6,36,168,264,210,10,80,500,1170,1830,960,20,
%T A393140 180,1380,4260,9900,10260,5340,35,385,3570,13755,42420,65520,67620,
%U A393140 26250,70,840,8960,41160,157920,323680,498400,384440,148610
%N A393140 Triangle read by rows. T(n, k) = C(n, k)*C(k, floor(k/2))*Sum_{i=0..k} C(k, i)*C(n-i, floor((n-i)/2)).
%C A393140 T(n, n - k) is the number of length-n walks on N^2 (the first quadrant of Z^2) by a king starting at (0, 0) of which k moves are horizontal. - _Natalia L. Skirrow_, Mar 06 2026
%H A393140 Paolo Xausa, <a href="/A393140/b393140.txt">Table of n, a(n) for n = 0..11475</a> (rows 0..150 of the triangle, flattened).
%F A393140 Using the notation a // b := floor(a / b).
%F A393140 T(n, k) = ((n - k + 1) * T(n, k - 1) + n * T(n - 1, k - 1)) // ((k + 1) // 2) for k > 0, and C(n, n // 2) for k = 0.
%F A393140 T(n, k) = A107230(n, n - k) * A393138(n, k).
%e A393140 Triangle starts:
%e A393140   [0] [ 1]
%e A393140   [1] [ 1,   2]
%e A393140   [2] [ 2,   6,   10]
%e A393140   [3] [ 3,  15,   48,    39]
%e A393140   [4] [ 6,  36,  168,   264,    210]
%e A393140   [5] [10,  80,  500,  1170,   1830,    960]
%e A393140   [6] [20, 180, 1380,  4260,   9900,  10260,   5340]
%e A393140   [7] [35, 385, 3570, 13755,  42420,  65520,  67620,  26250]
%e A393140   [8] [70, 840, 8960, 41160, 157920, 323680, 498400, 384440, 148610]
%t A393140 A393140[n_, k_] := A393140[n, k] = If[k == 0, Binomial[n, Quotient[n, 2]], Quotient[(n-k+1)*A393140[n, k-1] + n*A393140[n-1, k-1], Quotient[k+1, 2]]];
%t A393140 Table[A393140[n, k], {n, 0, 10}, {k, 0, n}] (* _Paolo Xausa_, Mar 09 2026 *)
%o A393140 (Python)
%o A393140 from math import comb
%o A393140 from functools import lru_cache
%o A393140 @lru_cache(maxsize=None)
%o A393140 def T(n: int, k: int) -> int:
%o A393140     if k == 0: return comb(n, n // 2)
%o A393140     return ((n - k + 1) * T(n, k - 1) + n * T(n - 1, k - 1)) // ((k + 1) // 2)
%o A393140 for n in range(9): print([T(n, k) for k in range(n + 1)])
%Y A393140 T(n,0) = A001405, T(n,n) = A151312, A151331 (row sums).
%Y A393140 Cf. A107230, A393138.
%K A393140 nonn,tabl,walk,new
%O A393140 0,3
%A A393140 _Peter Luschny_, Mar 06 2026
