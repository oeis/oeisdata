%U A393711 4,8,7,5,7,9,5,5,11,4,5,10,5,12,6,2,9
%N A393711 a(n) = number of triples (x, y, z) such that x^2 + y*z = n, where x, y, z are positive integers satisfying x <= y < z.
%e A393711 a(13) = 3 counts these triples: (1,1,12), (1,2,6), (1,3,4).
%t A393711 t[n_, c_] := Module[{r}, r = Flatten[Table[If[n - x^2 <= 0, {},
%t A393711        Map[({x, #, Quotient[n - x^2, #]} &),
%t A393711         Select[Divisors[n - x^2], Divisible[n - x^2, #] &]]], {x, 1,
%t A393711        Floor[Sqrt[n - 1]]}], 1]; Select[r, Apply[c, #] &]];
%t A393711 c = (#1 <= #2 && #2 < #3 &); Table[{n, t[n, c]}, {n, 1, 30}]
%t A393711 Join[{0}, Table[Length[t[n, c]], {n, 1, 130}]]
