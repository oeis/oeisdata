%T A393771 5,4,9,8,4,7,5,0,4,6,6,3,2,5,1,0,4,7,9,6,6,2,2,0,6,5,4,3,6,6,9,3,9,5,
%U A393771 0,8,4,5,2,9,4,0,5,4,7,1,1,5,2,3,5,6,7,9,8,3,1,3,8,8,7,3,2,3,8,9,3,5,8,9,2,7,1,8,3,5,9,0,0,1,3,7,2,5,3,5
%N A393771 Real part of Sum_{n>=0} (2*Pi*i + 1/2^n)^n / n!.
%C A393771 A related identity is Sum_{n>=0} (p + q^n)^n * r^n/n! = Sum_{n>=0} exp(p*q^n*r) * q^(n^2) * r^n/n!. Here, p = 2*Pi*i, q = 1/2, and r = 1.
%F A393771 Equals Re(Sum_{n>=0} (2*Pi*i + 1/2^n)^n / n!) (see A393772 for the imaginary part).
%F A393771 Equals Sum_{n>=0} cos(2*Pi/2^n) / (n! * 2^(n^2)).
%e A393771 x = 0.50023076561905600891171637414061555498475046632510...
%e A393771 Constant x = 1 - 1/2 + 0/(2!*2^4) + sqrt(1/2)/(3!*2^9) + sqrt((1+sqrt(1/2))/2)/(4!*2^16) + sqrt((1+sqrt((1+sqrt(1/2))/2))/2)/(5!*2^25) + ... + cos(2*Pi/2^n)/(n!*2^(n^2)) + ...
%e A393771 equals the real part of: Sum_{n>=0} (2*Pi*i + 1/2^n)^n/n! = (0.5002307656... + i*0.03148042134...).
%o A393771 (PARI) \\ x = real( Sum_{n>=0} (2*Pi*i + 1/2^n)^n/n! ).
%o A393771 \p200 \\ set desired precision
%o A393771 {x = real( suminf(n=0, (2*Pi*I + 1/2^n)^n/n! ) )}
%o A393771 for(n=1,120, print1(floor(x*10^n)%10,", "))
%o A393771 (PARI) \\ x = Sum_{n>=0} cos(2*Pi/2^n) / (n! * 2^(n^2)).
%o A393771 \p200 \\ set desired precision
%o A393771 {x = suminf(n=0, cos(2*Pi/2^n)/(n!*2^(n^2)) )}
%o A393771 for(n=1,120, print1(floor(x*10^n)%10,", "))
%Y A393771 Cf. A393772.
%K A393771 nonn,cons
%O A393771 0,1
