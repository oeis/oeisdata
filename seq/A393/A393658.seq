%N A393658 Expansion of (1/x) * Series_Reversion( x * ( Sum_{k=0..5} (-x)^k ) ).
%H A393658 Vincenzo Librandi, <a href="/A393658/b393658.txt">Table of n, a(n) for n = 0..1000</a>
%F A393658 G.f.: (1/x) * Series_Reversion( x * (1-x^6) / (1+x) ).
%F A393658 a(n) = (1/(n+1)) * Sum_{k=0..floor(n/6)} binomial(n+k,k) * binomial(n+1,n-6*k).
%t A393658 CoefficientList[Normal@Series[InverseSeries@Series[x*((1-x^6)/(1+x)),{x,0,50}]/x,{x,0,37}],x] (* _Vincenzo Librandi_, Mar 26 2026 *)
%o A393658 (PARI) a(n) = sum(k=0, n\6, binomial(n+k, k)*binomial(n+1, n-6*k))/(n+1);
%o A393658 (Magma) N := 35; R<x> := PowerSeriesRing(Rationals(), N+5); f:= x*((1-x^6)/(1+x));g:= Reverse(f) div x; Coeffs := [Coefficient(g,i):i in [0..N]]; Coeffs; // _Vincenzo Librandi_, Mar 26 2026
