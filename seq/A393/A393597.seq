%N A393597 a(n) is the permanent of the n X n matrix whose generic element M[i,j] is equal to C(n, (j-i) mod n).
%e A393597 a(3) = 82:
%e A393597   [1, 3, 3]
%e A393597   [3, 1, 3]
%e A393597   [3, 3, 1]
%p A393597 a:= n-> `if`(n=0, 1, LinearAlgebra[Permanent](
%p A393597          Matrix(n, shape=Circulant[[binomial(n,i)$i=1..n]]))):
%p A393597 seq(a(n), n=0..14);  # _Alois P. Heinz_, Mar 30 2026
%t A393597 a[0]:=1; a[n_]:=Permanent[Table[Binomial[n,Mod[j-i,n]],{i,n},{j,n}]]; Array[a,15,0]
%o A393597 (PARI) a(n) = matpermanent(matrix(n, n, i, j, binomial(n, (j-i) % n))); \\ _Michel Marcus_, Mar 30 2026
%Y A393597 Cf. A048954 (determinant).
%K A393597 nonn,new
%O A393597 0,3
