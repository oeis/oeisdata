%N A393844 O.g.f. A(x) satisfies: [x^n] exp( n*(n+1)*(n+2)*(n+3)*x - 24*n*A(x) ) = 0 for n >= 1.
%H A393844 Paul D. Hanna, <a href="/A393844/b393844.txt">Table of n, a(n) for n = 1..301</a>
%e A393844 O.g.f.: A(x) = x + 54*x^2 + 39744*x^3 + 88611984*x^4 + 421361844480*x^5 + 3612288309760512*x^6 + 50492393659919683584*x^7 + 1074721683380042338099200*x^8 + ...
%o A393844 (PARI) {a(n,k=4) = my(A=[0], m); for(i=1, n+1, m=#A; A=concat(A, 0); A[m+1] = Vec( exp( k!*binomial(m+k-1,m-1)*x - k!*m*Ser(A) ) )[m+1]/(k!*m) ); polcoef( Ser(A), n)}
%o A393844 for(n=1, 15, print1(a(n,4), ", "))
