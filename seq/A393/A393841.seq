%N A393841 a(n) is the number of n-digit terms in A393832.
%H A393841 <a href="/index/Rec#order_10">Index entries for linear recurrences with constant coefficients</a>, signature (10,-45,120,-210,252,-210,120,-45,10,-1).
%H A393841 <a href="/index/Com#comp">Index entries for sequences related to compositions</a>.
%F A393841 a(n) = Sum_{m=2..9} Sum_{k=2..m} binomial(m-1,k-1)*(n*binomial(n-1,n-k-1) - (n - 1)*binomial(n-2,n-k-2)) for n > 1.
%F A393841 a(n) = (6168960 - 6536880*n + 37332*n^2 + 117548*n^3 + 124551*n^4 + 65730*n^5 + 19278*n^6 + 3192*n^7 + 279*n^8 + 10*n^9)/362880 for n > 1.
%F A393841 a(n) = 10*a(n-1) - 45*a(n-2) + 120*a(n-3) - 210*a(n-4) + 252*a(n-5) - 210*a(n-6) + 120*a(n-7) - 45*a(n-8) + 10*a(n-9) - a(n-10) for n > 11.
%F A393841 Limit_{n->oo} a(n+1)/a(n) = 1.
%F A393841 G.f.: x*(1 - 10*x + 153*x^2 - 540*x^3 + 1092*x^4 - 1386*x^5 + 1134*x^6 - 588*x^7 + 180*x^8 - 27*x^9 + x^10)/(1 - x)^10.
%F A393841 E.g.f.: exp(x)*(17 - 17*x + 17*x^2/2 + 91*x^3/6 + 245*x^4/24 + 77*x^5/24 + 371*x^6/720 + 31*x^7/720 + 71*x^8/40320 + x^9/36288) - 17 + x.
%t A393841 a[1]=1; a[n_]:=(6168960 - 6536880*n + 37332*n^2 + 117548*n^3 + 124551*n^4 + 65730*n^5 + 19278*n^6 + 3192*n^7 + 279*n^8 + 10*n^9)/362880; Array[a,31]
