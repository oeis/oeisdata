%N A393820 a(n) is the difference between the nearest upper and lower odd semiprime neighbors of 2*prime(n), divided by 2.
%H A393820 James C. McMahon, <a href="/A393820/b393820.txt">Table of n, a(n) for n = 3..10000</a>
%F A393820 a(n) = (A393818(n) - A393819(n))/2.
%t A393820 a[n_]:=Module[{c=2Prime[n]-1,cu=2Prime[n]+1},While[PrimeOmega[c]!=2,c=c-2];While[PrimeOmega[cu]!=2,cu=cu+2];(cu-c)/2];Array[a,88,3] (* _James C. McMahon_, Mar 07 2026 *)
%o A393820 (PARI) \\ using the functions from the related sequences
%o A393820 a(n) = (a393818(n) - a393819(n))/2
