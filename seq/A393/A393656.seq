%N A393656 Expansion of (1/x) * Series_Reversion( x * ( Sum_{k=0..3} (-x)^k )^2 ).
%H A393656 Vincenzo Librandi, <a href="/A393656/b393656.txt">Table of n, a(n) for n = 0..1000</a>
%F A393656 G.f.: (1/x) * Series_Reversion( x * ((1-x^4) / (1+x))^2 ).
%F A393656 a(n) = (1/(n+1)) * Sum_{k=0..floor(n/2)} (-1)^k * binomial(2*n+k+1,k) * binomial(3*n-2*k+1,n-2*k).
%F A393656 a(n) = (1/(n+1)) * Sum_{k=0..floor(n/4)} binomial(2*n+k+1,k) * binomial(2*n+2,n-4*k).
%t A393656 CoefficientList[Normal@Series[InverseSeries@Series[x*((1-x^4)/(1+x))^2,{x,0,50}]/x,{x,0,27}],x] (* _Vincenzo Librandi_, Mar 24 2026 *)
%o A393656 (PARI) a(n) = sum(k=0, n\4, binomial(2*n+k+1, k)*binomial(2*n+2, n-4*k))/(n+1);
%o A393656 (Magma) N := 25; R<x> := PowerSeriesRing(Rationals(), N+5); f:= x*((1-x^4)/(1+x))^2; g:= Reverse(f) div x; Coeffs := [Coefficient(g,i):i in [0..N]]; Coeffs; // _Vincenzo Librandi_, Mar 24 2026
