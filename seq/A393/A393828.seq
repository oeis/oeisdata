%t A393828 a[1]=9;a[n_]:=Module[{c=Prime[n]+2},While[PrimeOmega[c]!=2,c=c+2];c];Array[a,62] (* _James C. McMahon_, Mar 07 2026 *)
%o A393828 (PARI) a393828(n) = forstep(k=prime(n)+2, oo, 2, if(bigomega(k)==2, return(max(9,k))))
