%I A393477 #30 Mar 29 2026 22:22:15
%S A393477 1,119807919,9534193025,9534194075,12043640675,12436160275
%N A393477 Numbers k such that sigma(k) = psi(k) + pi(k) + Omega(k)^10.
%e A393477 119807919 is a term since sigma(119807919) = 215759232 = 199162368 + 6831239 + 5^10 = psi(119807919) + pi(119807919) + Omega(119807919)^10.
%o A393477 (PARI) dedpsi(f) = prod(k = 1, #f~, (f[k, 1]+1) * f[k, 1]^(f[k, 2]-1));
%o A393477 list(lim) = {my(q = 2, m = 0, f); print1(1, ", "); forprime(p = 3, lim, m++; for(k = q, p-1, f = factor(k); if(sigma(f) == dedpsi(f) + m + bigomega(f)^10, print1(k, ", "))); q = p); } \\ _Amiram Eldar_, Mar 24 2026
