%T A393601 1031239839,8562015562,71723401701,605451716640,5145184411955,
%U A393601 43981774022235,377922738857370,3262475975651046,28281265990714773,246082714591631961,2148534248816073196
%N A393601 Expansion of (1/x) * Series_Reversion( x / ((1+x)^3 * (1+x^2)^3) ).
%H A393601 Vincenzo Librandi, <a href="/A393601/b393601.txt">Table of n, a(n) for n = 0..500</a>
%F A393601 a(n) = (1/(n+1)) * Sum_{k=0..floor(n/2)} binomial(3*n+3,k) * binomial(3*n+3,n-2*k).
%F A393601 a(n) = (1/(n+1)) * Sum_{k=0..floor(n/4)} (-1)^k * binomial(3*n+3,k) * binomial(4*n-4*k+2,3*n+2).
%F A393601 G.f.: B(x)^3, where B(x) is the g.f. of A200731.
%t A393601 CoefficientList[Normal@Series[InverseSeries@Series[x/((1+x)^3*(1+x^2)^3),{x,0,25}]/x,{x,0,27}], x] (* _Vincenzo Librandi_, Mar 26 2026 *)
%o A393601 (PARI) my(N=30, x='x+O('x^N)); Vec(serreverse(x/((1+x)^3*(1+x^2)^3))/x)
%o A393601 (PARI) a(n, s=2, t=3, u=3) = sum(k=0, n\s, binomial(t*(n+1), k)*binomial(u*(n+1), n-s*k))/(n+1);
%o A393601 (Magma) N:= 35; R<x>:= PowerSeriesRing(Rationals(), N+5); f:= x/((1+x)^3*(1+x^2)^3); g:= Reverse(f) div x; Coeffs := [Coefficient(g,i):i in [0..N]]; Coeffs; // _Vincenzo Librandi_, Mar 26 2026
