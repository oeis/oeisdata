%U A393854 1124092061740721156975888283516384,847407328075222230380235066124690880000,995470268256052077384803840592163060415989504,1744311450714495627539492241068129870998549358936064
%N A393854 O.g.f. A(x) satisfies: [x^n] exp( n^5*x - n^4*A(x) ) = 0 for n >= 1.
%H A393854 Paul D. Hanna, <a href="/A393854/b393854.txt">Table of n, a(n) for n = 1..201</a>
%e A393854 O.g.f.: A(x) = x + 8*x^2 + 7452*x^3 + 48548864*x^4 + 1136677600000*x^5 + 70034986070462592*x^6 + ...
%e A393854 ILLUSTRATION OF DEFINITION.
%e A393854 The table of coefficients of x^k/k! in exp( n^5*x - n^4*A(x) ) begins
%e A393854   n = 1: [1,    0,     -16,      -44712, ...];
%e A393854   n = 2: [1,   16,       0,     -723584, ...];
%e A393854   n = 3: [1,  162,   24948,           0, ...];
%e A393854   n = 4: [1,  768,  585728,   432101376, 0, ...];
%e A393854   n = 5: [1, 2500, 6240000, 15522055000, 37680117040000, 0, ...]; ...
%e A393854 in which a diagonal, the coefficient of x^n in row n, is all zeros.
%e A393854 RELATED SERIES.
%e A393854 exp(A(x)) = 1 + x + 17*x^2/2! + 44761*x^3/3! + 1165352449*x^4/4! + 136407145468721*x^5/5! + 50426008695759634321*x^6/6! + ...
%e A393854 where [x^n] exp(n^5*x) / exp(A(x))^(n^4) = 0 for n >= 1.
%o A393854 (PARI) {a(n,p=5,q=4) = my(A=[0], m); for(i=1, n+1, m=#A; A=concat(A, 0); A[m+1] = Vec( exp(m^p*x - m^q*Ser(A)) )[m+1]/(m^q) ); polcoef( Ser(A), n)}
%o A393854 for(n=1, 15, print1(a(n,5,4), ", "))
%Y A393854 Below, sequences with the parameters (p,q) indicated have an o.g.f. F(x) satisfying [x^n] exp( n^p*x - n^q*F(x) ) = 0 for n >= 1.
%Y A393854 Cf. A319944 (5,1), A393852 (5,2), A393853 (5,3).
%Y A393854 Cf. A393864 (6,4), A393874 (7,4), A393884 (8,4).
