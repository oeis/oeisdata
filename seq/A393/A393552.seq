%T A393552 4951760157143491424441862144,4726143985013034288556068553395716096,
%U A393552 73075081866545145910200683026960909940431650816,18260659593852162222067751059472598012305414686778089799680
%N A393552 Number of distinct line sets in an n-gon connecting vertices and midpoints, disallowing same-edge connections, up to rotations and reflections.
%C A393552 There are n vertices and n midpoints. The total number of lines connecting vertices and midpoints is 2*n*(n-2).
%H A393552 Paolo Xausa, <a href="/A393552/b393552.txt">Table of n, a(n) for n = 3..41</a>
%H A393552 Rhys Feltman, <a href="/A393552/a393552.py.txt">Python script that calculates number of configurations of the lines connecting vertices and midpoints in an n-gon</a>
%H A393552 Rhys Feltman, <a href="/A393552/a393552.txt">List of the 20 configurations of lines connecting vertices and midpoints for a triangle</a>
%F A393552 Where c is the number of cycles in each of the 2n symmetries, a(n) = Sum_{2^c}/(2n).
%F A393552 a(n) = (1/2) * ( 2^floor((n*(2*n-3)-3)/2) + 2^floor((n*(2*n-3)-2)/2) + (1/n) * Sum_{d|n} phi(d)*2^((2*n - 3 - d mod 2)*n/d) ). - _Andrew Howroyd_, Mar 02 2026
%e A393552 For n = 3, a(3) = 20, since there are 20 distinct ways you can connect vertices and midpoints without using the same edge, including the empty and full configurations.
%t A393552 A393552[n_] := (2^Quotient[# - 3, 2] + 2^Quotient[# - 2, 2] + DivisorSum[n, EulerPhi[#]*2^((2*n - 3 - Mod[#, 2])*n/#) &]/n)/2 & [n*(2*n - 3)];
%t A393552 Array[A393552, 10, 3] (* _Paolo Xausa_, Mar 09 2026 *)
%o A393552 (PARI)
%o A393552 r(n) = {my(m=2*n*(n-2)); if(n%2, 2^((m+n-1)/2), 3*2^((m+n)/2-2))}
%o A393552 c(n) = {my(m=2*n*(n-2)); sumdiv(n, d, eulerphi(d)*2^if(n%2, m/d, (m-n)/d + gcd(d,2)*n/d))/n}
%o A393552 a(n) = {(c(n) + r(n))/2} \\ _Andrew Howroyd_, Feb 21 2026
%Y A393552 Cf. A191563.
%K A393552 nonn
%O A393552 3,1
%A A393552 _Rhys Feltman_, Feb 20 2026
