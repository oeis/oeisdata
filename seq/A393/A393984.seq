%U A393984 302049012729161725378560000,4454989520743493117582376960000,92950790729047047971705255362560000,2668743485551052734888225563381596160000
%N A393984 a(n) = (n!)^4 * Sum_{1<=i<=j<=n} 1/(i*j)^2.
%H A393984 Seiichi Manyama, <a href="/A393984/b393984.txt">Table of n, a(n) for n = 0..144</a>
%H A393984 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/HarmonicNumber.html">Harmonic Number</a>
%F A393984 a(n) = (n!)^4 * (H(n,2)^2 + H(n,4))/2 where H(n,r) = Sum_{k=1..n} 1/k^r.
%F A393984 a(n) = 2 * (n!)^6 * Sum_{k=1..n} (-1)^(k-1)/(k^4 * (n-k)! * (n+k)!).
%F A393984 a(n) = n^2 * (2*n^2-2*n+1) * a(n-1) - n^2 * (n-1)^6 * a(n-2) + ((n-1)!)^4 for n > 1.
%F A393984 a(n) ~ 7 * Pi^6 * n^(4*n+2) / (90 * exp(4*n)). - _Vaclav Kotesovec_, May 08 2026
%t A393984 Table[n!^4*(HarmonicNumber[n, 2]^2 + HarmonicNumber[n, 4])/2, {n, 0, 20}] (* _Vaclav Kotesovec_, May 08 2026 *)
%o A393984 (PARI) a(n) = 2*n!^6*sum(k=1, n, (-1)^(k-1)/(k^4*(n-k)!*(n+k)!));
%o A393984 (Python)
%o A393984 from math import factorial
%o A393984 from sympy import harmonic
%o A393984 def A393984(n): return int(factorial(n)**4*(harmonic(n,2)**2+harmonic(n,4))/2) # _Chai Wah Wu_, May 08 2026
