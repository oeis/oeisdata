%t A393609 f[n_] := Fibonacci[n]; r = GoldenRatio;
%t A393609 w[n_, k_] := f[k + 1]*Floor[n*r] + (n - 1) f[k];
%t A393609 p[n_, k_] := Prime[w[n, k]];
%t A393609 Table[p[n, k], {n, 1, 12}, {k, 1, 12}] // Column
%t A393609 Flatten[Table[p[n, k], {n, 1, 12}, {k, 1, 12}]]  (* array *)
%t A393609 Flatten[Table[p[n - k + 1, k], {n, 1, 12}, {k, n, 1, -1}]]  (* sequence *)
%Y A393609 Cf. A000040, A035513.
