%I A393816 #7 Mar 08 2026 23:28:58
%S A393816 72,108,200,288,392,432,500,648,675,800,864,968,972,1125,1152,1323,
%T A393816 1352,1372,1568,1944,2000,2312,2592,2888,3087,3200,3267,3456,3872,
%U A393816 3888,4000,4232,4563,4608,5000,5324,5408,5488,6075,6125,6272,6728,6912,7688,7803,8575
%N A393816 Achilles numbers with exactly 2 distinct prime factors.
%C A393816 Intersection of A007774 and A052486.
%H A393816 Michael De Vlieger, <a href="/A393816/b393816.txt">Table of n, a(n) for n = 1..10000</a>
%H A393816 <a href="/index/Pow#powerful">Index entries for sequences related to powerful numbers</a>.
%e A393816 Let s = A052486.
%e A393816 Table of n, a(n) for select n:
%e A393816  n            a(n)
%e A393816 ------------------------------
%e A393816  1   s(1)  =   72 = 2^3 *  3^2
%e A393816  9   s(9)  =  675 = 3^3 *  5^2
%e A393816 12   s(12) =  968 = 2^3 * 11^2
%e A393816 19   s(19) = 1568 = 2^5 *  7^2
%e A393816 20   s(21) = 1944 = 2^3 *  3^5
%e A393816 40   s(46) = 6125 = 5^3 *  7^2
%t A393816 With[{nn = 10000}, Union@ Flatten@ Rest@ Table[If[And[Length[#] == 2, GCD @@ # == 1] &@ FactorInteger[#][[All, -1]], #, Nothing] &[a^2*b^3], {b, Surd[nn, 3]}, {a, Sqrt[nn/b^3] } ] ]
%o A393816 (PARI) isok(k)=my(f=factor(k)); k>9 && vecmin(f[,2])>1 && gcd(f[,2])==1 && omega(f)==2; \\ _Michel Marcus_, Mar 03 2026
%Y A393816 Cf. A001694, A007774, A013929, A024619, A052486, A126706, A200511, A286708, A355462.
%K A393816 nonn,easy,new
%O A393816 1,1
