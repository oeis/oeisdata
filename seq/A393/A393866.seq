%S A393866 1,1,2,10,82,1610,21103,557487,10593462,339062614,13734633778,
%T A393866 396036333970,20579031011201,876507655312569,38770769823590773,
%U A393866 2095528583370973781,129010872768620618787,8461720386355980968547,506790238377256700760459,40023759959023038602678651,2897244094881589021494018202
%N A393866 G.f. A(x) satisfies [x^n] A(x)^prime(n) = prime(n) * [x^(n-1)] A(x)^prime(n) for n >= 1.
%C A393866 The value lim_{n->oo} a(n)/A002110(n) appears to exist and be near 0.078..., where primorial A002110(n) = Product_{k=1..n} prime(k).
%H A393866 Paul D. Hanna, <a href="/A393866/b393866.txt">Table of n, a(n) for n = 0..500</a>
%F A393866 G.f. A(x) = Sum_{n>=0} a(n)*x^n satisfy the following formulas.
%F A393866 (1) [x^n] A(x)^prime(n) * (1 - prime(n)*x) = 0 for n >= 1 (by definition).
%F A393866 (2) [x^n] A'(x)/A(x) == 0 (mod prime(n)) for n > 1 (conjecture - see A393867).
%e A393866 G.f.: A(x) = 1 + x + 2*x^2 + 10*x^3 + 82*x^4 + 1610*x^5 + 21103*x^6 + 557487*x^7 + 10593462*x^8 + 339062614*x^9 + 13734633778*x^10 + ...
%e A393866 RELATED SEQUENCES.
%e A393866 The table of coefficients of x^k in A(x)^prime(n) begins
%e A393866   [1,  2,   5,   24,   188,   3424,   45854,  1165260, ...];
%e A393866   [1,  3,   9,   43,   324,   5484,   74627,  1829553, ...];
%e A393866   [1,  5,  20,  100,   715,  10551,  146065,  3355725, ...];
%e A393866   [1,  7,  35,  189,  1323,  17325,  239876,  5199580, ...];
%e A393866   [1, 11,  77,  495,  3542,  38962,  520685, 10172151, ...];
%e A393866   [1, 13, 104,  728,  5369,  55861,  726193, 13519701, ...];
%e A393866   [1, 17, 170, 1394, 11118, 108902, 1335775, 22708175, ...];
%e A393866   ...
%e A393866 in which the terms of the main diagonal
%e A393866 [1, 3, 20, 189, 3542, 55861, 1335775, ...]
%e A393866 multiplied by the primes gives the adjacent diagonal
%e A393866 [2, 9, 100, 1323, 38962, 726193, 22708175, ...].
%e A393866 The logarithmic derivative of g.f. A(x) begins
%e A393866 A393867 = [1, 3, 25, 287, 7601, 116337, 3740017, ...]
%e A393866 where A393867(n) appears to be divisible by prime(n) for n > 1:
%e A393866 A393867 = [1, 3*1, 5*5, 7*41, 11*691, 13*8949, 17*220001, ...].
%e A393866 Runs of consecutive odd/even terms begin
%e A393866 A393868 = [2, 4, 2, 4, 8, 2, 6, 4, 10, 6, 4, 2, 2, 2, 4, 4, 2, 2, 6, 2, 2, 2, 8, 2, 2, 4, 2, 6, 2, 12, 2, 2, 2, 6, 8, 2, 8, 4, 4, 2, 2, 2, 2, 2, 6, ...].
%o A393866 (PARI) \\ By definition; set N to desired number of terms
%o A393866 N=30; A=[1]; for(n=2, N, A=concat(A, 0); V=Vec(Ser(A)^prime(n-1)); A[#A] = V[#A-1] - V[#A]/prime(n-1) ); A
%o A393866 \\ Demonstrate definition - returns all zeros
%o A393866 GF=Ser(A); for(n=1,N-1, print1(polcoef(GF^prime(n)*(1 - prime(n)*x),n),", "))
%o A393866 \\ Test: [x^n] A'(x)/A(x) == 0 (mod prime(n)) - returns '1' if true
%o A393866 GF=Ser(A); for(n=2,N-1, print1( denominator( Vec(GF'/GF)[n]/prime(n) ),", "))
%Y A393866 Cf. A393867 (log derivative), A393868 (runs of odd/even terms).
%K A393866 nonn,new
%O A393866 0,3
%A A393866 _Paul D. Hanna_, Mar 29 2026
