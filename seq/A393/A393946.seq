%S A393946 12,18,20,24,28,40,44,45,48,50,52,54,56,60,63,68,75,76,80,84,88,90,92,
%T A393946 96,98,99,104,112,116,117,120,124,126,132,135,136,140,147,148,150,152,
%U A393946 153,156,160,162,164,168,171,172,175,176,184,188,189,192,198,204,207
%N A393946 Numbers that are neither squarefree nor squareful, with prime power factor exponents that are pairwise coprime.
%C A393946 Smallest a(n) with m distinct prime factors is 2*A002110(m) with m > 1.
%C A393946 A332785(52) = 180 = 2^2 * 3^2 * 5 is not in this sequence.
%H A393946 Michael De Vlieger, <a href="/A393946/b393946.txt">Table of n, a(n) for n = 1..10000</a>
%F A393946 {a(n)} = A332785 \ A393947.
%e A393946 Let s = A332785.
%e A393946 Table of n, a(n) for select n:
%e A393946     n                a(n)
%e A393946 ------------------------------------------------------
%e A393946     1       s(1) =    12 = 2^2 *  3
%e A393946     2       s(2) =    18 = 2   *  3^2
%e A393946     3       s(3) =    20 = 2^2 *  5
%e A393946     4       s(4) =    24 = 2^3 *  3
%e A393946     5       s(5) =    28 = 2^2 *  7
%e A393946     8       s(8) =    45 = 3^2 *  5
%e A393946    14      s(14) =    60 = 2^2 *  3 * 5
%e A393946    52      s(53) =   184 = 2^3 * 23
%e A393946   128     s(132) =   420 = 2^2 *  3 * 5 * 7
%e A393946  1578    s(1688) =  4620 = 2^2 *  3 * 5 * 7 * 11
%e A393946 21200   s(23075) = 60060 = 2^2 *  3 * 5 * 7 * 11 * 13
%t A393946 fQ[x_] := And[Times @@ # != 1, ! AllTrue[#, # > 1 &], CoprimeQ @@ #] &@ FactorInteger[x][[All, -1]]; Select[Range[210], fQ]
%o A393946 (Magma) fQ := function(x) F := Factorization(x); e := [f[2] : f in F]; return #e gt 0 and &*e ne 1 and exists(v){v : v in e | v eq 1} and GCD(e) eq 1; end function; [ n : n in [1..210] | fQ(n) ]; // _Vincenzo Librandi_, Mar 13 2026
