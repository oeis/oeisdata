%N A393885 O.g.f. A(x) satisfies: [x^n] exp( n^8*x - n^5*A(x) ) = 0 for n >= 1.
%H A393885 Paul D. Hanna, <a href="/A393885/b393885.txt">Table of n, a(n) for n = 1..201</a>
%e A393885 O.g.f.: A(x) = x + 784*x^2 + 168020892*x^3 + 692305070944256*x^4 + 23009977691689348700000*x^5 + 3860311382312331777461112137472*x^6 + ...
%e A393885 ILLUSTRATION OF DEFINITION.
%e A393885 The table of coefficients of x^k/k! in exp( n^8*x - n^5*A(x) ) begins
%e A393885   n = 1: [1,      0,        -1568,       -1008125352, ...];
%e A393885   n = 2: [1,    224,            0,      -32282490112, ...];
%e A393885   n = 3: [1,   6318,     39536100,                 0, ...];
%e A393885   n = 4: [1,  64512,   4160192512,   267142853910528, 0, ...];
%e A393885   n = 5: [1, 387500, 150151350000, 58176700233275000, 22485678904847930800000, 0, ...]; ...
%e A393885 in which a diagonal, the coefficient of x^n in row n, is all zeros.
%e A393885 RELATED SERIES.
%e A393885 exp(A(x)) = 1 + x + 1569*x^2/2! + 1008130057*x^3/3! + 16615325742548833*x^4/4! + 2761197406095147880978641*x^5/5! + 2779424211832464022646779940899201*x^6/6! + ...
%e A393885 where [x^n] exp(n^8*x) / exp(A(x))^(n^5) = 0 for n >= 1.
%o A393885 (PARI) {a(n,p=8,q=5) = my(A=[0], m); for(i=1, n+1, m=#A; A=concat(A, 0); A[m+1] = Vec( exp(m^p*x - m^q*Ser(A)) )[m+1]/(m^q) ); polcoef( Ser(A), n)}
%o A393885 for(n=1, 15, print1(a(n,8,5), ", "))
%Y A393885 Below, sequences with the parameters (p,q) indicated have an o.g.f. F(x) satisfying [x^n] exp( n^p*x - n^q*F(x) ) = 0 for n >= 1.
