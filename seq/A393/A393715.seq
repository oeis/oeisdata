%N A393715 a(n) = number of triples (x, y, z) such that x^2 + y*z = n, where x, y, z are positive integers with gcd(x, y*z) > 1.
%e A393715 a(10) = 4 counts these triples : (2, 1, 6), (2, 2, 3), (2, 3, 2), (2, 6, 1).
%t A393715 t[n_, c_] := Module[{r}, r = Flatten[Table[If[n - x^2 <= 0, {},
%t A393715        Map[({x, #, Quotient[n - x^2, #]} &),
%t A393715        Select[Divisors[n - x^2], Divisible[n - x^2, #] &]]], {x, 1,
%t A393715        Floor[Sqrt[n - 1]]}], 1]; Select[r, Apply[c, #] &]];
%t A393715 c = (! CoprimeQ[#1, #2 #3] &); Table[{n, t[n, c]}, {n, 1, 30}]
%t A393715 Join[{0}, Table[Length[t[n, c]], {n, 1, 130}]]
