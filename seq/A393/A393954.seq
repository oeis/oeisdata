%U A393954 27409394579262,223110429785275,1824795182575650,14988782110022490,123592674062444070,1022669887394585295
%N A393954 Expansion of ( 1 + Series_Reversion( x*(1-2*x-x^2) ) )^2.
%F A393954 G.f.: 2 - x / Series_Reversion( x*(1-2*x-x^2) ).
%F A393954 G.f.: B(x)^2, where B(x) is the g.f. of A192945.
%F A393954 a(0) = 1, a(1) = 2; a(n) = (1/(n-1)) * Sum_{k=0..floor(n/2)} 2^(n-2*k) * binomial(2*n-2-k,n-2) * binomial(n-k,k).
%F A393954 a(n) ~ sqrt(77 - 19*sqrt(7)) * (17 + 7*sqrt(7))^n / (9 * sqrt(21*Pi) * n^(3/2) * 2^(2*n-1)). - _Vaclav Kotesovec_, Mar 18 2026
%t A393954 Join[{1, 2}, Table[1/(n-1) * Sum[2^(n - 2*k)*Binomial[2*n-2-k, n-2] * Binomial[n-k, k], {k, 0, n/2}], {n, 2, 30}]] (* _Vaclav Kotesovec_, Mar 18 2026 *)
%o A393954 (PARI) my(N=30, x='x+O('x^N)); Vec((1+serreverse(x*(1-2*x-x^2)))^2)
%Y A393954 Cf. A120591, A192945, A393955.
%K A393954 nonn
%O A393954 0,2
