%T A393889 6998043525885,307831417695909,14577640870303377,739536100222798899,
%U A393889 40020776276242083507,2301691209030102539259,140217912528862509036117,9021108445527923796514437,611285061740709140815872789
%N A393889 G.f. A(x) satisfies 4*A(x) = 1 + x + 3*A(x*A(x)).
%H A393889 Paul D. Hanna, <a href="/A393889/b393889.txt">Table of n, a(n) for n = 0..300</a>
%F A393889 G.f. A(x) = Sum_{n>=0} a(n)*x^n satisfies the following formulas.
%F A393889 (1) 4*A(x) = 1 + x + 3*A(x*A(x)).
%F A393889 (2) A(x) = 1 + Sum_{n>=0} 3^n * B^n(x) / 4^(n+1), where B(x) = x*A(x) and B^n(x) denotes the n-th iteration of B(x) with B^0(x) = x.
%F A393889 (3) 3*A(x) = 4*F(x) - x/F(x) - 1, where F(x) = A(x/F(x)) = x/Series_Reversion(x*A(x)).
%F A393889 a(n) ~ c * n^(n + 1/4 + 2*log(4/3)) / (exp(n) * log(4/3)^n), where c = 0.28592046327618102388... - _Vaclav Kotesovec_, Apr 06 2026
%F A393889 From _Seiichi Manyama_, Apr 06 2026: (Start)
%F A393889 Let b(n,k) = [x^n] A(x)^k.
%F A393889 b(0,1) = b(1,1) = 1;   b(n,1) =     3 * Sum_{j=1..n-1} b(j,1) * b(n-j,j).
%F A393889 For k > 1, b(0,k) = 1; b(n,k) = (1/n) * Sum_{j=1..n} ((k+1)*j-n) * b(j,1) * b(n-j,k).
%F A393889 a(n) = b(n,1). (End)
%e A393889 G.f.: A(x) = 1 + x + 3*x^2 + 27*x^3 + 387*x^4 + 7317*x^5 + 168237*x^6 + 4503789*x^7 + 136727055*x^8 + 4625789067*x^9 + ...
%e A393889 RELATED SERIES.
%e A393889 A(x*A(x)) = 1 + x + 4*x^2 + 36*x^3 + 516*x^4 + 9756*x^5 + 224316*x^6 + 6005052*x^7 + 182302740*x^8 + 6167718756*x^9 + ...
%e A393889 where A(x) = (1 + x)/4 + (3/4)*A(x*A(x)).
%e A393889 If F(x) = A(x/F(x)), then
%e A393889 F(x) = 1 + x + 2*x^2 + 20*x^3 + 286*x^4 + 5426*x^5 + 124968*x^6 + 3349446*x^7 + 101773794*x^8 + 3445660160*x^9 + ...
%e A393889 where 3*A(x) = 4*F(x) - x/F(x) - 1.
%e A393889 RELATED TABLE.
%e A393889 The table of coefficients in the n-th iteration of x*A(x) begins
%e A393889   n = 0: [1, 0,  0,   0,     0,      0,       0, ...];
