%e A393889 a(4) = 387 = 0/4 + 27*3^1/4^2 + 70*3^2/4^3 + 135*3^3/4^4 + 228*3^4/4^5 + ...
%e A393889 a(5) = 7317 = 0/4 + 387*3^1/4^2 + 978*3^2/4^3 + 1861*3^3/4^4 + 3148*3^4/4^5 + ...
%e A393889 a(6) = 168237 = 0/4 + 7317*3^1/4^2 + 18192*3^2/4^3 + 34133*3^3/4^4 + 57196*3^4/4^5 + ...
%e A393889 a(7) = 4503789 = 0/4 + 168237*3^1/4^2 + 413694*3^2/4^3 + 767905*3^3/4^4 + 1274540*3^4/4^5 + ...
%e A393889 ...
%o A393889 (PARI) {a(n) = my(A=1+x); for(i=1, n, A = 1+x + 3*subst(A, x, x*A +x*O(x^n)) - 3*A); polcoef(GF=A, n)}
