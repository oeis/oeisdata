%I A393870 #8 Apr 09 2026 06:19:28
%S A393870 1,1,1,17,1073,233057,162914977,393655557105,3621917124488273,
%T A393870 133226240824791674049,19624220687881648314654017,
%U A393870 11492078014674660008578595923153,26687444439054693854632370585189355889,245823847319683526991559127588138987722168353
%N A393870 G.f. A(x) satisfies [x^(n+2)] A^(2^n)(x) = n*2^n * [x^(n+1)] A^(2^n)(x) for n >= 1, where A^k(x) denotes the k-th iteration of A(x).
%C A393870 Compare to [x^(n+2)] F^(2^n)(x) = 2^n * [x^(n+1)] F^(2^n)(x) for n >= 0 when F(x) = x/(1-x) in which case F^(2^n)(x) = x/(1 - 2^n*x) is the 2^n iteration of x/(1-x).
%C A393870 Note: it is conjectured that this sequence will continue to consist of integers (true for at least the initial 151 terms); if there are fractional coefficients eventually, then this sequence would list the numerators of those fractions.
%C A393870 This sequence grows rather quickly; a(50) has 696 digits, a(100) has 2,894 digits, and a(150) has 6,596 digits.
%C A393870 All terms appear to be odd.
%H A393870 Paul D. Hanna, <a href="/A393870/b393870.txt">Table of n, a(n) for n = 1..151</a>
%F A393870 a(n) ~ n * 2^((n-2)^2). - _Vaclav Kotesovec_, Apr 09 2026
%e A393870 G.f.: A(x) = x + x^2 + x^3 + 17*x^4 + 1073*x^5 + 233057*x^6 + 162914977*x^7 + 393655557105*x^8 + 3621917124488273*x^9 + 133226240824791674049*x^10 + ...
%e A393870 The table of coefficients of x^k in the 2^n-iteration of A(x) begins
%e A393870   n = 0: [1,  1,    1,    17,    1073,   233057,  162914977, ...];
%e A393870   n = 1: [1,  2,    4,    40,    2256,   473888,  327717440, ...];
%e A393870   n = 2: [1,  4,   16,   128,    5120,   982016,  663212032, ...];
%e A393870   n = 3: [1,  8,   64,   640,   15360,  2146304, 1359773696, ...];
%e A393870   n = 4: [1, 16,  256,  4352,   94208,  6029312, 2887647232, ...];
%e A393870   n = 5: [1, 32, 1024, 33280, 1130496, 47710208, 7633633280, ...];
%e A393870   ...
%e A393870 where [x^(n+2)] A^(2^n)(x) = n*2^n * [x^(n+1)] A^(2^n)(x)
%e A393870   n = 1: 4 / 2 = 1*2;
%e A393870   n = 2: 128 / 16 = 2*2^2;
%e A393870   n = 3: 15360 / 640 = 3*2^3;
%e A393870   n = 4: 6029312 / 94208 = 4*2^4;
%e A393870   n = 5: 7633633280 / 47710208 = 5*2^5;
%e A393870   ...
%o A393870 (PARI) \\ Routine to obtain the 2^n iteration of F(x)
%o A393870 {IT2(n,F) = my(G=F); for(i=1,n, G = subst(G,x,G));G}
%o A393870 \\ Generate g.f. A(x) by definition
%o A393870 {a(n) = my(V=[1,1],A,m); for(i=3,n, V = concat(V,0); A = x*Ser(V); m = #V-2;
%o A393870 V[#V] = -polcoef( IT2(m,A) * (1 - m*2^m*x), m+2)/2^m ); A=x*Ser(V); polcoef(GF=A,n)}
%o A393870 {upto(n) = a(n); Vec(GF)}
%o A393870 upto(20)
%o A393870 \\ Verify g.f. formula - returns all zeros if true
%o A393870 {for(n=1,#GF-2,print1( polcoef( IT2(n,GF) * (1 - n*2^n*x), n+2),","))}
%K A393870 nonn
%O A393870 1,4
%A A393870 _Paul D. Hanna_, Apr 08 2026
