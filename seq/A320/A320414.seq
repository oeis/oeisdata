%I A320414 #16 Apr 12 2026 08:40:53
%S A320414 1,5,144,10082,1264535,245875182,68150171838,25482852420656,
%T A320414 12358294214448753,7544949396113515915,5664150492647564303056,
%U A320414 5129806105907894893467492,5516524251630079831171874313,6950350571025359814277640201432,10142321626803167978417939290871040,16972169807104759800475307306764090752,32287069027792648627362032680785777091413
%N A320414 O.g.f. A(x) satisfies [x^n] exp(-n*A(x)) / (1 - n^2*x) = 0 for n >= 1.
%C A320414 It is remarkable that this sequence should consist entirely of integers.
%H A320414 Paul D. Hanna, <a href="/A320414/b320414.txt">Table of n, a(n) for n = 1..200</a>
%F A320414 From _Seiichi Manyama_, Apr 10 2026: (Start)
%F A320414 a(n) = n^(2*n-2) + (1/n) * Sum_{k=1..n-1} k * c_n(k) * e_n(n-k),
%F A320414 where c_n(k) = n^(2*k-1)/k - a(k) for 1 <= k <= n-1,
%F A320414 and e_n(0) = 1, e_n(k) = (n/k) * Sum_{j=1..k} j * c_n(j) * e_n(k-j) for 1 <= k <= n-1. (End)
%e A320414 G.f.: A(x) = x + 5*x^2 + 144*x^3 + 10082*x^4 + 1264535*x^5 + 245875182*x^6 + 68150171838*x^7 + 25482852420656*x^8 + 12358294214448753*x^9 + ...
%e A320414 ILLUSTRATION OF DEFINITION.
%e A320414 The table of coefficients of x^k/k! in exp(-n*A(x)) / (1 - n^2*x) begins:
%e A320414   n=1: [1,  0,   -9,   -862,   -241719,  -151666596, -176990046545, ...];
%e A320414   n=2: [1,  2,    0,  -1616,   -495232,  -308287632, -357675223424, ...];
%e A320414   n=3: [1,  6,   87,      0,   -693639,  -475046118, -548265525633, ...];
%e A320414   n=4: [1, 12,  360,  14240,         0,  -586861344, -749452608128, ...];
%e A320414   n=5: [1, 20,  975,  69430,   5820185,           0, -861802226825, ...];
%e A320414   n=6: [1, 30, 2136, 226368,  31268736,  4762503504,             0, ...];
%e A320414   n=7: [1, 42, 4095, 597044, 115492713, 27293766318, 6830535431671, 0, ...]; ...
%e A320414 in which the coefficient of x^n in row n forms a diagonal of zeros.
%e A320414 RELATED SERIES.
%e A320414 exp(A(x)) = 1 + x + 11*x^2/2! + 895*x^3/3! + 245785*x^4/4! + 153050681*x^5/5! + 177988541251*x^6/6! + 344758772825671*x^7/7! + 1030280671456569905*x^8/8! + ...
%e A320414 exp(-A(x)) = 1 - x - 9*x^2/2! - 835*x^3/3! - 238271*x^4/4! - 150458001*x^5/5! - 176080046969*x^6/6! - 342201963425491*x^7/7! - 1024667102754203775*x^8/8! + ...
%o A320414 (PARI) {a(n) = my(A=[1]); for(i=1, n, A=concat(A, 0); m=#A; A[m] = Vec( exp(-m*x*Ser(A))/(1-m^2*x +x^2*O(x^m)))[m+1]/m ); A[n]}
%o A320414 for(n=1, 20, print1(a(n), ", "))
%o A320414 (Ruby)
%o A320414 def A320414(n)
%o A320414   a = [0]
%o A320414   (1..n).each{|i|
%o A320414     c = [0] + (1..i - 1).map{|k| i ** (2 * k - 1) / k.to_r - a[k]}
%o A320414     e = [1]
%o A320414     (1..i - 1).each{|k| e << i / k.to_r * (1..k).inject(0){|s, j| s + j * c[j] * e[k - j]}}
%o A320414     a << i ** (2 * i - 2) + (1..i - 1).inject(0){|s, k| s + k * c[k] * e[i - k]}.to_i / i
%o A320414   }
%o A320414   a[1..-1]
%o A320414 end
%o A320414 p A320414(20) # _Seiichi Manyama_, Apr 10 2026
