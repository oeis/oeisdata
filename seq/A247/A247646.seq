%I A247646 #22 Apr 14 2026 00:47:13
%S A247646 1,1,3,3,1,1,3,9,5,7,1,1,1,3,9,15,12,10,9,3,1,1,1,3,9,15,27,16,20,12,
%T A247646 14,3,3,1,1,1,3,9,15,27,37,27,25,24,18,16,6,3,3,1,1,1,3,9,15,27,37,55,
%U A247646 33,39,29,33,20,22,6,6,3,3,1,1
%N A247646 Irregular triangle read by rows, arising in enumeration of lattice paths in strips.
%C A247646 It would be nice to have a more explicit definition.
%H A247646 Johann Cigler, <a href="https://arxiv.org/abs/1501.04750">Some remarks and conjectures related to lattice paths in strips along the x-axis</a>, arXiv:1501.04750 [math.CO], 2015-2016.
%e A247646 Triangle begins:
%e A247646   1,
%e A247646   1,3,3,1,
%e A247646   1,3,9,5,7,1,1,
%e A247646   1,3,9,15,12,10,9,3,1,1,
%e A247646   1,3,9,15,27,16,20,12,14,3,3,1,1,
%e A247646   ...
%t A247646 v3[x_, k_] := Expand@Cancel[(1+2x+4x^2+2x^3+x^4 - x^(k-1) (k(k+1)/2+2(k+1)x+(-k^2+2k+4)x^2 + (6-2k)x^3 + (6-5k+k^2)x^4/2) + 2x^(2k-1) (k+x-(k-2)x^2) - x^(3k-1)) / ((1-x)^3 (1+x)^2)];
%t A247646 Table[CoefficientList[v3[x, k+2], x], {k,0,6}] // Flatten (* _Andrei Zabolotskii_, Apr 12 2026 *)
%Y A247646 The diagonals on the left are given by A247643.
%K A247646 nonn,tabf
%O A247646 0,3
%A A247646 _N. J. A. Sloane_, Sep 23 2014
