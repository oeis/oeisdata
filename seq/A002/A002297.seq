%I A002297 M2262 N0893 #44 Apr 22 2026 08:20:32
%S A002297 1,1,3,2,115,11,5887,151,259723,15619,381773117,655177,20646903199,
%T A002297 27085381,467168310097,2330931341,75920439315929441,12157712239,
%U A002297 5278968781483042969,37307713155613,9093099984535515162569,339781108897078469,168702835448329388944396777
%N A002297 Numerator of (2/Pi) * Integral_{x>=0} (sin x / x)^n dx.
%C A002297 a(n)/A002298(n) is the probability that round(x_1 + ... + x_n) = round(x_1) + ... + round(x_n), where x_1, ..., x_n are independent uniformly distributed random variables in [0, 1] (Hopkins, 2016; Lessard, 2024). - _Amiram Eldar_, Apr 22 2026
%D A002297 N. J. A. Sloane, A Handbook of Integer Sequences, Academic Press, 1973 (includes this sequence).
%D A002297 N. J. A. Sloane and Simon Plouffe, The Encyclopedia of Integer Sequences, Academic Press, 1995 (includes this sequence).
%H A002297 T. D. Noe, <a href="/A002297/b002297.txt">Table of n, a(n) for n=1..100</a>
%H A002297 A. H. R. Grimsey, <a href="https://doi.org/10.1080/14786444508521508">On the accumulation of chance effects and the Gaussian frequency distribution</a>, Phil. Mag., 36 (1945), 294-295.
%H A002297 David Hopkins, <a href="https://www.jstor.org/stable/44161646">Will my numbers add up correctly if I round them?</a>, The Mathematical Gazette, Vol. 100, No. 549 (2016), pp. 396-409; <a href="https://m-a.org.uk/resources/Example-Article-Gazette-Hopkins-Rounding.pdf">alternative link</a>.
%H A002297 Laurent Lessard, <a href="https://laurentlessard.com/bookproofs/round-round-get-a-round">Round, round, get a round</a>, Book Proofs, 2024.
%H A002297 R. G. Medhurst and J. H. Roberts, <a href="https://doi.org/10.1090/S0025-5718-1965-0172446-8">Evaluation of the integral I_n(b) = (2/Pi)*Integral_{0..inf} (sin x / x)^n cos (bx) dx</a>, Math. Comp., 19 (1965), 113-117.
%F A002297 a(n) = numerator((n/2^(n-1)) * Sum_{r=0..n/2} (-1)^r*(n-2*r)^(n-1)/(r!*(n-r)!)). - _Sean A. Irvine_, Oct 01 2013
%F A002297 From _Amiram Eldar_, Apr 22 2026: (Start)
%F A002297 a(n)/A002298(n) = A261398(n)/A000165(n-1).
%F A002297 a(n)/A002298(n) ~ sqrt(6/(Pi*n)). (End)
%e A002297 1, 1, 3/4, 2/3, 115/192, 11/20, ...
%t A002297 a[n_] := Numerator[ (2/Pi)*Integrate[ (Sin[x]/x)^n, {x, 0, Infinity}] ]; Table[ a[n], {n, 1, 21}] (* _Jean-François Alcover_, Dec 19 2011 *)
%t A002297 (* Alternative: *)
%t A002297 Numerator@Table[Sum[(-1)^k (n-2k)^(n-1) Binomial[n, k], {k, 0, n/2}]/((n-1)! 2^(n-1)), {n, 1, 30}] (* _Vladimir Reshetnikov_, Sep 02 2016 *)
%o A002297 (PARI) a(n) = numerator((n/2^(n-1)) * sum(r=0, n/2, (-1)^r*(n-2*r)^(n-1)/(r!*(n-r)!))); \\ _Michel Marcus_, Oct 02 2013
%Y A002297 Cf. A002298 (denominators), A000165, A002304, A002305, A261398.
%Y A002297 Essentially the same as A049330, except for the n=4 term.
%K A002297 nonn,frac,easy,nice,changed
%O A002297 1,3
%A A002297 _N. J. A. Sloane_
%E A002297 a(22)-a(23) from _T. D. Noe_, Feb 22 2014
