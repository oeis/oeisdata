%I A002506 #27 Jul 23 2026 09:45:45
%S A002506 8,96,3072,184320,17694720,2477260800,475634073600,119859786547200,
%T A002506 38355131695104000,15188632151261184000,7290543432605368320000,
%U A002506 4170190843450270679040000,2802368246798581896314880000,2185847232502893879125606400000,1958519120322592915696543334400000
%N A002506 Denominators of coefficients of even powers of x of the expansion of Bessel function J_2(x).
%D A002506 Ilya Nikolaevich Bronstein and Konstantin Semendjajew, Taschenbuch der Mathematik, 7th German ed. 1965, ch. 4.4.7.
%H A002506 T. D. Noe, <a href="/A002506/b002506.txt">Table of n, a(n) for n = 0..50</a>
%H A002506 <a href="/index/Be#Bessel">Index entries for sequences related to Bessel functions or polynomials</a>.
%F A002506 a(n) = 2^(2n+k) * n! * (n+k)! here for k=2, i.e., Bessel's J2(x).
%F A002506 a(n) - 4*n*(n+2)*a(n-1) = 0. - _R. J. Mathar_, Jun 20 2013
%F A002506 From _Amiram Eldar_, Jul 23 2026: (Start)
%F A002506 a(n) ~ Pi * (2*n)^(2*n+3) / exp(2*n).
%F A002506 Sum_{n>=0} 1/a(n) = BesselI(2,1).
%F A002506 Sum_{n>=0} (-1)^n/a(n) = BesselJ(2,1). (End)
%e A002506 a(2) = 3072 = 64*2*24, J2(x) = x^2/8 - x^4/96 + x^6/3072 - x^8/184320 +- ...
%t A002506 Denominator[Take[CoefficientList[Series[BesselJ[2,x],{x,0,30}],x],{3,-1,2}]] (* corrected by _Harvey P. Dale_, Sep 21 2013 *)
%Y A002506 Cf. A002474 (J_1), this sequence (J_2), A014401 (J_3), A061403 (J_4), A061404 (J_5), A061405 (J_6), A061406 (J_7), A061407 (J_8), A061440 (J_9), A061441 (J_10).
%K A002506 nonn,easy,changed
%O A002506 0,1
%A A002506 _N. J. A. Sloane_
