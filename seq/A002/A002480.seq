%I A002480 M0683 N0252 #33 Jul 11 2026 09:44:37
%S A002480 0,2,3,5,8,11,12,14,18,20,21,27,29,30,32,35,44,45,48,50,53,56,59,62,
%T A002480 66,72,75,77,80,83,84,93,98,99,101,107,108,110,116,120,125,126,128,
%U A002480 131,140,146,147,149,155,158,162
%N A002480 Numbers of the form 2x^2 + 3y^2.
%C A002480 By genus theory, k > 0 if and only if it has an odd number of total prime factors congruent to 2, 3, 5, 11 (mod 24) counted with multiplicity, and each prime factor congruent to 13, 17, 19, 23 (mod 24) occurs with an even multiplicity. See also _Jeremy Lovejoy_'s comment in A108563. - _Jianing Song_, Jul 11 2026
%D A002480 David A. Cox, Primes of the Form x^2 + n y^2, Wiley, 1989.
%D A002480 N. J. A. Sloane, A Handbook of Integer Sequences, Academic Press, 1973 (includes this sequence).
%D A002480 N. J. A. Sloane and Simon Plouffe, The Encyclopedia of Integer Sequences, Academic Press, 1995 (includes this sequence).
%H A002480 Jianing Song, <a href="/A002480/b002480.txt">Table of n, a(n) for n = 1..10000</a> (first 252 terms from Peter Munn)
%H A002480 L. Euler, <a href="https://www.math.uni-bielefeld.de/~sieben/Euler_Algebra.ocr.pdf">Vollstaendige Anleitung zur Algebra, Zweiter Theil</a>, reprinted in: Opera Omnia. Teubner, Leipzig, 1911, Series (1), Vol. 1, p. 425.
%H A002480 Rick L. Shepherd, <a href="https://www.digitalgreensboro.org/record/14435">Binary quadratic forms and genus theory</a>, Master of Arts Thesis, University of North Carolina at Greensboro, 2013.
%H A002480 N. J. A. Sloane et al., <a href="https://oeis.org/wiki/Binary_Quadratic_Forms_and_OEIS">Binary Quadratic Forms and OEIS</a> (Index to related sequences, programs, references)
%o A002480 (PARI) isA002480(n) = {
%o A002480 if(n==0, return(1));
%o A002480 my(f=factor(n), w=#f~, p, count=0);
%o A002480 for(i=1, w,
%o A002480     p=f[i,1];
%o A002480     if(p==2 || p==3 || p%24==5 || p%24==11, count+=f[i,2]);
%o A002480     if(p%24>12 && f[i,2]%2, return(0));
%o A002480 );
%o A002480 return(count%2);
%o A002480 } \\ _Jianing Song_, Jul 11 2026
%Y A002480 For primes see A084865.
%Y A002480 Cf. A000075 (growth), A002481, A108563.
%K A002480 nonn,easy,changed
%O A002480 1,2
%A A002480 _N. J. A. Sloane_, _Mira Bernstein_
