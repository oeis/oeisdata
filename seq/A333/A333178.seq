%I A333178 #12 Apr 07 2026 10:19:47
%S A333178 2,5,7,9,13,23,19,21,25,45,33,51,43,65,65,55,61,89,69,91,97,115,85,
%T A333178 115,99,147,105,133,111,223,129,133,175,203,179,183,159,235,215,205,
%U A333178 181,337,193,233,233,287,213,283,229,331,299,289,243,359,301,301,343,385,279,461
%N A333178 a(n) = Sum_{d|n, gcd(d, n/d) = 1} prime(d).
%C A333178 a(n) >= prime(n) + 2 for n > 1, with equality iff n is a prime power (A246655). - _Robert Israel_, Apr 07 2026
%H A333178 Robert Israel, <a href="/A333178/b333178.txt">Table of n, a(n) for n = 1..10000</a>
%F A333178 Sum_{d|n, gcd(d, n/d) = 1} (-1)^omega(n/d) * a(d) = prime(n).
%p A333178 f:= proc(n) local F, t, D, d;
%p A333178    F:= map(t -> t[1]^t[2], ifactors(n)[2]);
%p A333178    D:= map(convert, combinat:-powerset(F), `*`);
%p A333178    add(ithprime(d), d=D)
%p A333178 end proc:
%p A333178 map(f, [$1..100]); # _Robert Israel_, Apr 07 2026
%t A333178 a[n_] := Sum[If[GCD[n/d, d] == 1, Prime[d], 0], {d, Divisors[n]}]; Table[a[n], {n, 1, 60}]
%o A333178 (PARI) a(n) = sumdiv(n, d, if (gcd(d, n/d) ==1, prime(d))); \\ _Michel Marcus_, Mar 10 2020
%Y A333178 Cf. A000040, A001221, A007445, A076479, A246655, A333177.
%K A333178 nonn,look
%O A333178 1,1
