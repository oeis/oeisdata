%U A333536 31,31,32,32,33,33,33,33,34,34,34,35,36,36,36,36,36,36,37,37,38,38,38,39,39,39,39,39,40,41,41,41,42
%N A333536 Number of sqrt(n-1)-smooth numbers <= n.
%H A333536 Alois P. Heinz, <a href="/A333536/b333536.txt">Table of n, a(n) for n = 1..20000</a>
%p A333536 a:=[];
%p A333536 for n from 1 to 100 do
%p A333536    c:=0;
%p A333536    for m from 1 to n do
%p A333536       if A006530(m)^2 < n then c:=c+1; fi; od:
%p A333536 a:=[op(a),c];
%p A333536 od:
%p A333536 a;
%o A333536 (Python)
%o A333536 from math import isqrt
%o A333536 from sympy import prevprime, integer_log
%o A333536 def A333536(n):
%o A333536     if n < 5: return int(not n==1)
%o A333536     def g(x, m): return x.bit_length() if m==2 else sum(g(x//(m**i), prevprime(m))for i in range(integer_log(x, m)[0]+1))
%o A333536     return g(n,prevprime(isqrt(n-1)+1)) # _Chai Wah Wu_, Mar 13 2026
%Y A333536 The following are all different versions of sqrt(n)-smooth numbers: A048098, A063539, A064775, A295084, A333535.
