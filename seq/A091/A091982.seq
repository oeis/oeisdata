%I A091982 #16 Jul 04 2026 01:07:58
%S A091982 1,4181,6721,13201,34561,51841,64681,90061,96049,97921,163081,186961,
%T A091982 197209,268801,283361,302101,330929,399001,489601,520801,636641,
%U A091982 655201,920577,999941,1034881,1072513,1081649,1084201,1106561,1317121,1346269,1392169,1533601
%N A091982 Nonprimes k such that Mod(k,4) == 1 and denominator(Fibonacci((k-1)/4)/k) = 1.
%H A091982 Giovanni Resta, <a href="/A091982/b091982.txt">Table of n, a(n) for n = 1..2500</a>
%t A091982 Select[Range[1, 10^6, 4], And[! PrimeQ@ #, Denominator[Fibonacci[(# - 1)/4]/#] == 1] &] (* _Michael De Vlieger_, May 07 2017 *)
%o A091982 (Python)
%o A091982 from itertools import islice, count
%o A091982 from sympy import isprime
%o A091982 def A091982_gen(): # generator of terms
%o A091982     def fibonacci_mod(n,m): # fibonacci(n) mod m
%o A091982         a, b, c, d, a2, b2, c2, d2 = 1, 1, 1, 0, 1, 0, 0, 1
%o A091982         for x in bin(n)[2:]:
%o A091982             e, f = b2*c2%m, a2+d2
%o A091982             a2, b2, c2, d2 = (pow(a2,2,m)+e)%m, b2*f%m, c2*f%m, (pow(d2,2,m)+e)%m
%o A091982             if x=='1':
%o A091982                 a2, b2, c2, d2 = (a2*a+b2*c)%m, (a2*b+b2*d)%m, (c2*a+d2*c)%m, (c2*b+d2*d)%m
%o A091982         return c2
%o A091982     for m in count(1,4):
%o A091982         if not isprime(m) and fibonacci_mod(m-1>>2,m)==0:
%o A091982             yield m
%o A091982 A091982_list = list(islice(A091982_gen(),20)) # _Chai Wah Wu_, Jul 03 2026
%Y A091982 For primes see A047272.
%K A091982 nonn,easy,changed
%O A091982 1,2
%A A091982 Mohammed Bouayoun (bouyao(AT)wanadoo.fr), Mar 17 2004
%E A091982 a(16)-a(33) from _Giovanni Resta_, May 06 2017
