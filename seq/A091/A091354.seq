%I A091354 #8 Jul 16 2026 00:52:44
%S A091354 1,4,16,70,344,1908,11904,83028,642960,5490560,51373420,523581128,
%T A091354 5781166688,68819889018,879350377816,12012238559559,174794145558664,
%U A091354 2700485871440464,44163954923956850,762460145368056070,13861236620211195036,264742781380412710922,5301084059254984610172
%N A091354 Row sums of the matrix cube of triangle A091351, in which the k-th column lists the row sums of A091351^k (the k-th power of A091351 when considered as a lower triangular matrix).
%C A091354 Also equals the third column of triangle A091351.
%H A091354 Paul D. Hanna, <a href="/A091354/b091354.txt">Table of n, a(n) for n = 0..300</a>
%o A091354 (PARI) \\ Using Matrix Products
%o A091354 {A091351(n, k) = my(M=matrix(2, 2, r, c, if(r>=c, 1)), D, L); for(i=2, n,
%o A091354 \\ D = M shift down 1 row
%o A091354 D = matrix(#M+1, #M+1, r, c, if(r==1, 0, if(c>#M, 0, M[r-1, c])) );
%o A091354 \\ L = New matrix, shifted left 1 column
%o A091354 L = D + D^2;
%o A091354 \\ New matrix = L shifted right 1 column
%o A091354 M = matrix(#M+1, #M+1, r, c, if(c==1, 1, L[r, c-1]) ));
%o A091354 TM = M; M[n+1, k+1]}
%o A091354 \\ Print up to n terms of column 3 of triangle A091351
%o A091354 {upto(n) = A091351(n+3, 3); for(r=0, n, print1(TM[r+4, 4], ", "))}
%o A091354 upto(25) \\ _Paul D. Hanna_, Jul 15 2026
%Y A091354 Cf. A091351, A091352, A091353.
%K A091354 nonn,changed
%O A091354 0,2
