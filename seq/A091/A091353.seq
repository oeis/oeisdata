%I A091353 #8 Jul 16 2026 00:52:48
%S A091353 1,3,9,30,115,510,2602,15133,99367,729962,5949393,53392902,524077321,
%T A091353 5592200388,64520858034,801031071955,10654883235991,151253483735767,
%U A091353 2283450321888155,36544617881242655,618220383026770560,11025656534922994894,206803438287872063439,4070432269061083833900
%N A091353 Row sums of the matrix square of triangle A091351, in which the k-th column lists the row sums of A091351^k (the k-th power of A091351 when considered as a lower triangular matrix).
%C A091353 Also equals the second column of triangle A091351.
%H A091353 Paul D. Hanna, <a href="/A091353/b091353.txt">Table of n, a(n) for n = 0..300</a>
%o A091353 (PARI) \\ Using Matrix Products
%o A091353 {A091351(n, k) = my(M=matrix(2, 2, r, c, if(r>=c, 1)), D, L); for(i=2, n,
%o A091353 \\ D = M shift down 1 row
%o A091353 D = matrix(#M+1, #M+1, r, c, if(r==1, 0, if(c>#M, 0, M[r-1, c])) );
%o A091353 \\ L = New matrix, shifted left 1 column
%o A091353 L = D + D^2;
%o A091353 \\ New matrix = L shifted right 1 column
%o A091353 M = matrix(#M+1, #M+1, r, c, if(c==1, 1, L[r, c-1]) ));
%o A091353 TM = M; M[n+1, k+1]}
%o A091353 \\ Print up to n terms of column 2 of triangle A091351
%o A091353 {upto(n) = A091351(n+2, 2); for(r=0, n, print1(TM[r+3, 3], ", "))}
%o A091353 upto(25) \\ _Paul D. Hanna_, Jul 15 2026
%Y A091353 Cf. A091351, A091352, A091354.
%K A091353 nonn,changed
%O A091353 0,2
