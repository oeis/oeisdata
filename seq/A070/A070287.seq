%S A070287 1,3,4,12,14,24,28,36,48,60,72,78,84,96,120,144,168,180,192,240,248,
%T A070287 264,288,312,336,360,420,432,480,496,576,620,672,684,720,780,792,798,
%U A070287 840,864,924,936,960,1008,1056,1080,1092,1104,1176,1240,1260,1344,1368
%N A070287 Numbers k such that the equation lcm(sigma(x),phi(x))=k has solutions.
%H A070287 Robert Israel, <a href="/A070287/b070287.txt">Table of n, a(n) for n = 1..5000</a>
%p A070287 N:= 2000: # for terms <= N
%p A070287 S:= select(`<=`,{seq(ilcm(NumberTheory:-sigma(x), NumberTheory:-phi(x)),x=1..N)},N):
%p A070287 sort(convert(S,list)); # _Robert Israel_, Jun 08 2026
%o A070287 (PARI) for(n=1,2000,if(0<sum(i=1,n,if(lcm(sigma(i),eulerphi(i))-n,0,1)),print1(n,",")))
%Y A070287 Includes A084921. Cf. A009286.
%K A070287 easy,nonn
%O A070287 1,2
%A A070287 _Benoit Cloitre_, May 10 2002
