%T A394735 349,359,379,389,397,401,439,449,457,463,479,487,491,499,613,643,673,
%U A394735 683,701,719,739,743,757,761,769,823,853,859,877,883,907,911,929,937
%N A394735 Primes prime(k) such that prime(k+1) - prime(k) is a perfect power.
%H A394735 Vincenzo Manto, <a href="/A394735/b394735.txt">Table of n, a(n) for n = 1..2500</a>
%F A394735 a(n) = prime(A113451(n)).
%e A394735 7 is a term since the gap with next prime (11) is 4 (2^2) which is a perfect power.
%e A394735 11 is not a term since the gap with the next prime (13) is 2 which is not a perfect power.
%t A394735 Select[Prime[Range[300]], With[{g = NextPrime[#] - #}, g == 1 || (g > 3 && GCD @@ FactorInteger[g][[All, 2]] > 1)] &]
%Y A394735 Cf. A000040, A001597, A001223, A151799, A113451.
%K A394735 nonn
%O A394735 1,1
