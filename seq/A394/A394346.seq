%T A394346 48000,1764,1936,46,2654208,375,2704,2916,131712,58,6480000,62,196608,
%U A394346 4356,4624,4900,90699264,74,5776,6084,20480000,82,24893568,86,511104,546750,8464,94,2548039680,1029,750000,10404,843648,106
%N A394346 a(n) = tau(n) * pod(n) where tau(k) = the number of the divisors of k (A000005) and pod(k) = the product of the divisors of k (A007955).
%H A394346 James C. McMahon, <a href="/A394346/b394346.txt">Table of n, a(n) for n = 1..10000</a>
%F A394346 a(n) = A000005(n) * A007955(n).
%F A394346 a(n) = A324528(n) * A306671(n).
%F A394346 a(p) = 2p for p prime.
%e A394346 a(6) = tau(6) * pod(6) = 4 * 36 = 144.
%t A394346 a[n_]:=DivisorSigma[0,n]Times@@Divisors[n];Array[a,53] (* _James C. McMahon_, May 14 2026 *)
%o A394346 (Magma) [#Divisors(n) * &*Divisors(n): n in [1..60]];
%o A394346 (PARI) a(n) = my(d=divisors(n)); #d*vecprod(d); \\ _Michel Marcus_, May 14 2026
%Y A394346 Cf. A000005 (tau(n)), A000203 (sigma(n)), A007955 (pod(n)).
%Y A394346 Cf. A064987 (n * sigma(n)), A338576 (n * pod(n)).
