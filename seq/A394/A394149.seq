%S A394149 0,1,3,16,102,713,5280,40697,323103,2624433,21708228,182242642,
%T A394149 1548903270,13301866836,115255146696,1006339773529,8845885832247,
%U A394149 78217080831633,695240828778384,6208667251654181,55678046188233957,501204564513317552,4527295727614227492
%N A394149 G.f. A(x) satisfies 3*A(x)^6-2*A(x)^5+9x*A(x)^4-3x*A(x)^3+6x^2*A(x)^2-x^2*A(x)+x^3=0.
%C A394149 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with blue root where red vertices can be followed by red or blue vertices, blue vertices can be followed by vertices of any colors, and green vertices can be followed by red or green vertices.
%H A394149 Nathan Fox, <a href="/A394149/b394149.txt">Table of n, a(n) for n = 0..300</a>
%H A394149 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394149 (Python)
%o A394149 def A394149(n):
%o A394149     A = [[1, 1, 0], [1, 1, 1], [1, 0, 1]]
%o A394149     if n == 0:
%o A394149         return 0
%o A394149     m = len(A)
%o A394149     output = [[1] for i in range(m)]
%o A394149     for l in range(2, n + 1):
%o A394149         for i in range(m):
%o A394149             term = 0
%o A394149             for k in range(1, l):
%o A394149                 for j in range(m):
%o A394149                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394149             output[i].append(term)
%o A394149     return output[1][n - 1]
%Y A394149 Cf. A394148, A394150.
%K A394149 nonn
%O A394149 0,3
%A A394149 _Nathan Fox_, Mar 11 2026
