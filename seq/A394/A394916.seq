%N A394916 Expansion of (Sum_{k>=0} binomial(5*k,k) * x^k)^3.
%F A394916 a(n) = Sum_{i,j,k >= 0 and i+j+k=n} binomial(5*i,i) * binomial(5*j,j) * binomial(5*k,k).
%F A394916 G.f.: B(x)^3 where B(x) is the g.f. of A001449.
%F A394916 a(n) = Sum_{k=0..n} (k+1) * 4^k * binomial(5*n+2,n-k).
%F A394916 a(n) = Sum_{k=0..n} (k+1) * 5^k * binomial(5*n-k,n-k).
%F A394916 a(0) = 1; a(n) = (15/n) * Sum_{k=0..n-1} 4^k * binomial(k+3,3) * binomial(5*n+2,n-1-k).
%F A394916 a(0) = 1; a(n) = (15/n) * Sum_{k=0..n-1} 5^k * binomial(k+3,3) * binomial(5*n-2-k,n-1-k).
%o A394916 (PARI) a(n) = sum(k=0, n, (k+1)*4^k*binomial(5*n+2, n-k));
