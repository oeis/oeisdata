%S A394650 20,480,17680,867840,53008000,3868262400,328200070400,31743511756800,
%T A394650 3447768313600000,415545796853760000,55041558756762624000,
%U A394650 7948018349009534976000,1242718216339451289600000,209174003345404408627200000,37712045770845433775923200000,7250740898779197968241131520000
%N A394650 Number of index 12*n free subgroups of SL_2(Z).
%C A394650 The number of free subgroups of index 12*n+{1,...,11} is 0, hence sequence is only for 12*n.
%H A394650 Wilfried Imrich, <a href="https://doi.org/10.1007/BF01226441">On the number of subgroups of given index in SL_2(Z)</a>, Archiv der Mathematik, vol. 31, 1978, pp. 224-231.
%F A394650 a(n) = 12*n*a(n-1) + Sum_{k = 1 .. n-2} a(k)*a(n-1-k) (Theorem 2 from Imrich).
%p A394650 a := proc(n) option remember: local i: if n = 1 then 20:
%p A394650 else 12*n*a(n-1)+add(a(k)*a(n-1-k), k = 1 .. n-2): fi: end:
%p A394650 seq(a(n), n = 1 .. 16);
%K A394650 nonn,new
%O A394650 1,1
%A A394650 _Lorenzo Sauras Altuzarra_, Apr 24 2026
