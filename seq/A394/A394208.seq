%N A394208 Expansion of Product_{k>=1} (1 + x^(k*(3*k-2))) / (1 - x^(k*(3*k-2))).
%C A394208 Convolution of A279281 and A279041.
%H A394208 Vaclav Kotesovec, <a href="/A394208/b394208.txt">Table of n, a(n) for n = 0..10000</a>
%F A394208 a(n) ~ Gamma(1 + b/d) * ((4-sqrt(2))*zeta(3/2))^(2/3 + b/(3*d)) * d^(1/6 + b/(3*d)) * exp(3*Pi^(1/3) * ((4-sqrt(2))*zeta(3/2))^(2/3) * (n/d)^(1/3) / 4) / (2^(7/2 + 3*b/(2*d)) * sqrt(3) * Pi^(7/6 - b/(6*d)) * n^(7/6 + b/(3*d))), where d = 3, b = -2.
%t A394208 nmax = 120; CoefficientList[Series[Product[(1 + x^(k*(3*k-2))) / (1 - x^(k*(3*k-2))), {k, 1, Floor[Sqrt[1 + 3*nmax]/3 + 1]}], {x, 0, nmax}], x]
