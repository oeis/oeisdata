%N A394598 Decimal expansion of the mean distance between two points selected independently at random within the interior of a regular octagon with unit circumradius.
%H A394598 Uwe Bäsel, <a href="https://arxiv.org/abs/2101.03815">The moments of the distance between two random points in a regular polygon</a>, arXiv:2101.03815 [math.PR], 2021.
%F A394598 Equals (4*sqrt(2)*Pi)/3 + 2*sqrt(2 - sqrt(2)) * (1/5 + 13*sqrt(2)/120 - (1/20 + sqrt(2)/60 + 2*Pi/3) * sqrt(2 + sqrt(2)) - (14 + 91*sqrt(2)/10) * log(2 + sqrt(2))/48 + (1 + 7*sqrt(2)/10) * log(2 - sqrt(2))/48 + (1/3 - sqrt(2)/4) * log(2 + sqrt(2 + sqrt(2)))/20 + (21 + 29*sqrt(2)/2) * log(2 + sqrt(2 - sqrt(2)))/40).
%e A394598 0.860007978015497247289475476698227488793382581154266...
%t A394598 RealDigits[(4*Sqrt[2]*Pi)/3 + 2*Sqrt[2 - Sqrt[2]]*(1/5 + 13*Sqrt[2]/120 - (1/20 + Sqrt[2]/60 + 2*Pi/3)*Sqrt[2 + Sqrt[2]] - (14 + 91*Sqrt[2]/10)*Log[2 + Sqrt[2]]/48 + (1 + 7*Sqrt[2]/10)*Log[2 - Sqrt[2]]/48 + (1/3 - Sqrt[2]/4)*Log[2 + Sqrt[2 + Sqrt[2]]]/20 + (21 + 29*Sqrt[2]/2)*Log[2 + Sqrt[2 - Sqrt[2]]]/40), 10, 120][[1]]
%o A394598 (PARI) (4*sqrt(2)*Pi)/3 + 2*sqrt(2 - sqrt(2)) * (1/5 + 13*sqrt(2)/120 - (1/20 + sqrt(2)/60 + 2*Pi/3) * sqrt(2 + sqrt(2)) - (14 + 91*sqrt(2)/10) * log(2 + sqrt(2))/48 + (1 + 7*sqrt(2)/10) * log(2 - sqrt(2))/48 + (1/3 - sqrt(2)/4) * log(2 + sqrt(2 + sqrt(2)))/20 + (21 + 29*sqrt(2)/2) * log(2 + sqrt(2 - sqrt(2)))/40)
%Y A394598 Cf. A091505 (square), A093064 (triangle), A093070 (disk), A394596 (pentagon), A394597 (hexagon), this constant (octagon), A394599 (10-gon), A394600 (12-gon), A394601 (rhombus), A394602 (rectangle).
