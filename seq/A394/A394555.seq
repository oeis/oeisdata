%e A394555 .
%e A394555 Subset key:
%e A394555 A = Achilles A052486.
%e A394555 B = A303606, perfect powers of squarefree composite k (in A120944).
%e A394555 C = A386762, perfect powers of k that are neither squarefree nor powerful (in A332785).
%e A394555 D = A383394, perfect powers of Achilles k (in A052486) - none less than 2^46.
%t A394555 nn = 50000; rad[x_] := Times @@ FactorInteger[x][[All, 1]]; t = Rest@ Union@ Flatten@ Table[a^2*b^3, {b, Surd[nn, 3]}, {a, Sqrt[nn/b^3]}]; s[x_] := Module[{r}, r = rad[x]; Total@ Select[Range[x], rad[#] == r &] ]; Select[t, rad[#] == rad[s[#] ] &]
%t A394555 (* Alternative: first download the regs function from the link at A369609, then: *)
%t A394555 nn = 2^32; rad[x_] := Times @@ FactorInteger[x][[All, 1]]; s = Rest@ Union@ Flatten@ Table[a^2*b^3, {b, Surd[nn, 3]}, {a, Sqrt[nn/b^3] } ]; mm = Length[s]; Monitor[Reap[Do[If[rad[Total@ regs[-#] ] == rad[#], Print[#]; Sow[#]] &@ s[[c]], {c, Length[s] } ] ][[-1, 1]], {c, mm}]
%Y A394555 Cf. A007947, A008479, A013929, A052486, A126706, A332785, A369609, A381498, A391625, A393919.
