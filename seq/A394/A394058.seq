%T A394058 21,7,2,8,7,2,11,25,2,2,5,6,5,16,8,2,2,3,2,2,13,2,5,6,11,2,2,4,3,10,3,
%U A394058 2,7,3,3,5,11,4,3,4,4,2,7,12,7,8,15,4,4,2,3
%N A394058 Conjectured least integer k>1 such that n^k has the smallest average of digits, or -1 if no such k exists.
%C A394058 All terms have been verified up to k <= 20000.
%C A394058 For n <= 84000, the largest term is a(38541) = 188.
%H A394058 James C. McMahon, <a href="/A394058/b394058.txt">Table of n, a(n) for n = 1..5000</a>
%e A394058 a(3) = 21, because 3^21 = 10460353203, which has the smallest average of digits of ~2.45 for any 3^k and 1 < k <= 20000.
%e A394058 a(10) = -1, because the average of digits of 10^k decreases indefinitely as k increases.
%t A394058 a[1]=2;a[n_]:=Module[{s=DigitSum[#]/IntegerLength[#]&/@(n^Range[2,200])},If[IntegerQ[Log10[n]],-2,SequencePosition[s,{Min[s]}][[1,1]]]+1] (* Increase range of k for n^k when n>84000 *);Array[a,80] (* _James C. McMahon_, Mar 21 2026 *)
%Y A394058 Cf. A394057.
%K A394058 sign,base
%O A394058 1,1
