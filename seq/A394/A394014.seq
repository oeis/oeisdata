%T A394014 213261497387,6055326082297,192920799371107,6835354560254959,
%U A394014 267262287705383293
%N A394014 a(1)=1; for n >= 1, a(n+1) = prime(k) where k > a(n) is least k such that prime(k) - k is prime.
%F A394014 a(1) = 1; for n >= 2, a(n) = prime(k), where k is the smallest integer > a(n-1) such that prime(k) - k is prime.
%e A394014 a(2) = 5 because 5 is the first prime p(k) with k > a(1) = 1 such that p(k) - k is prime (5 - 3 = 2 is prime).
%e A394014 a(4) = 43 because 43 is the first prime p(k) with k > a(3) = 13 such that p(k) - k is prime (43 - 14 = 29 is prime).
%e A394014 a(5) = 193 because 193 is the first prime p(k) with k > a(4) = 43 such that p(k) - k is prime (193 - 44 = 149 is prime).
%t A394014 FilteredPrimeIndexSequence[n_]:=Module[{seq={1},k},While[Length[seq]<n,k=seq[[-1]]+1; While[!PrimeQ[Prime[k]-k],k++]; AppendTo[seq,Prime[k]];]; seq]; FilteredPrimeIndexSequence[15]
%o A394014 (Magma) A := [1]; for i in [2..11] do k := A[#A] + 1; while not IsPrime(NthPrime(k) - k) do k +:= 1; end while; Append(~A, NthPrime(k)); end for; A;
