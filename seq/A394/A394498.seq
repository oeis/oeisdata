%N A394498 Number of ordered rooted trees with total edge weight n such that all groups of sibling edges have weights in standard order.
%F A394498 G.f.: A(x) satisfies A(x) = Sum_{j>=0} x^(j*(j+1)/2) * A(x)^j / Product_{k=1..j} (1 - A(x) * (x - x^(k+1))/(1-x)).
%o A394498 (PARI)
%o A394498 tri(n) = {n*(n+1)/2}
%o A394498 A_x(N) = {my(x='x+O('x^(N+1)), A=1); for(i=1, N, A = sum(j=0,N, (x^tri(j) * A^j)/prod(k=1,j, (1 - A * (x - x^(k+1))/(1-x))  ))); Vec(A)}
%Y A394498 Row sums of A395304.
