%U A394236 24467315529,91484661593,343063807700,1289912538048,4861963178427,18367386630365,69533618025044,263748085976074,1002242485086417,3814987038980359
%N A394236 Number of circular parking functions of length n avoiding the pattern 123.
%H A394236 Lara Pudwell, <a href="https://faculty.valpo.edu/lpudwell/slides/AMS2025.pdf">Pattern avoidance in cyclic parking functions</a>, 2025.
%H A394236 Lara Pudwell, <a href="https://faculty.valpo.edu/lpudwell/papers/circpf.pdf">Pattern Avoidance in Circular Parking Functions</a>, Valparaiso Univ. (2026). See p. 6 (Table 2).
%F A394236 a(n) = 2*binomial(2n-1, n-1)/(n+1) - binomial(n+1, 2) + (Sum_{i=1..n} 2^gcd(i, n))/2.
%e A394236 For n=4, the a(4)=16 parking functions are 1111, 1112, 1113, 1114, 1122, 1132, 1133, 1142, 1143, 1212, 1222, 1313, 1322, 1332, 1422, 1432.
%p A394236 a := proc(n) local i; 1/2*add(2^gcd(i, n), i = 1 .. n) - binomial(n + 1, 2) + 2*binomial(2*n - 1, n - 1)/(n + 1); end proc:
%p A394236 seq(a(i), i = 1 .. 30);
%t A394236 Table[2*Binomial[2*n - 1, n - 1]/(n + 1) - Binomial[n + 1, 2] + Sum[2^GCD[i, n], {i, n}]/2, {n, 30}] (* _Michael De Vlieger_, Mar 13 2026 *)
