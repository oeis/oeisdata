%I A394815 #13 May 06 2026 12:08:44
%S A394815 5652,6948,16452,20772,27792,44532,65700,67428,126612,143568,180288,
%T A394815 194868,195732,212868,216900,218628,236772,276372,299700,328788,
%U A394815 369828,377172,390672,400068,402768,425988,437652,441108,463248,483408,491328,530532,536868,539712
%N A394815 Numbers k in A014574 (averages of twin prime pairs) such that gcd(k, sigma(k)) = 2.
%C A394815 Conjecture: every term is divisible by 36.
%C A394815 Conjecturally, A394757 is the disjoint union of this sequence and A394399.
%e A394815 For k = 5652: k-1 = 5651 and k+1 = 5653 are prime; also sigma(5652) = 14378 and gcd(5652, 14378) = 2, so 5652 is a term.
%e A394815 For k = 18: k-1 = 17 and k+1 = 19 are prime; also sigma(18) = 39 and gcd(18, 39) = 3, so 18 is not a term.
%t A394815 q[k_]:=PrimeQ[k-1]&&PrimeQ[k+1]&&GCD[k,DivisorSigma[1,k]]==2;Select[Range[539712],q] (* _James C. McMahon_, May 06 2026 *)
%o A394815 (Python)
%o A394815 from sympy import divisor_sigma, gcd, isprime
%o A394815 def ok(k):
%o A394815     return isprime(k-1) and isprime(k+1) and gcd(k, divisor_sigma(k)) == 2
%o A394815 print([k for k in range(1, 600000) if ok(k)])
%Y A394815 Subsequence of A394757.
%Y A394815 Cf. A014574, A392199, A394399.
%K A394815 nonn,new
%O A394815 1,1
%A A394815 _Aied Sulaiman_, May 01 2026
