%I A394403 #12 Mar 25 2026 20:50:32
%S A394403 1,276543,73296375,274611750,9076584475,25403983825
%N A394403 Numbers k such that sigma(k) = psi(k) + pi(k) + Omega(k)^8.
%e A394403 276543 is a term since sigma(276543) = 399464 = 368736 + 24167 + 3^8 = psi(276543) + pi(276543) + Omega(276543)^8.
%o A394403 (PARI) dedpsi(f) = prod(k = 1, #f~, (f[k, 1]+1) * f[k, 1]^(f[k, 2]-1));
%o A394403 list(lim) = {my(q = 2, m = 0, f); print1(1, ", "); forprime(p = 3, lim, m++; for(k = q, p-1, f = factor(k); if(sigma(f) == dedpsi(f) + m + bigomega(f)^8, print1(k, ", "))); q = p); } \\ _Amiram Eldar_, Mar 19 2026
