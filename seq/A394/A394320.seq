%T A394320 1536,63375,2031616,36581523,0,1,48,2905,175104,9208065,362283008,
%U A394320 7828053417,0,1,63,4992,407435,30867456,1966158735,91620376576,2309644635483,0
%N A394320 Square array A(n,k), n>=0, k>=0, read by antidiagonals downwards, where A(n,k) = (2*n)! * [x^(2*n)] (f(x)^k + f(-x)^k)/2 and f(x) = 1/(cos(x) + sin(x)).
%H A394320 Paolo Xausa, <a href="/A394320/b394320.txt">Table of n, a(n) for n = 0..11324</a> (first 150 antidiagonals, flattened).
%F A394320 A(0,k) = 1 and A(n,k) = 2*k*(k+1) * A(n-1,k+2) - k^2 * A(n-1,k) for n > 0.
%e A394320 Square array begins:
%e A394320   1,      1,       1,       1,        1, ...
%e A394320   0,      3,       8,      15,       24, ...
%e A394320   0,     57,     256,     705,     1536, ...
%e A394320   0,   2763,   17408,   63375,   175104, ...
%e A394320   0, 250737, 2031616, 9208065, 30867456, ...
%t A394320 A394320[n_, k_] := A394320[n, k] = If[n == 0, 1, 2*k*(k+1)*A394320[n-1, k+2] - k^2*A394320[n-1, k]];
%t A394320 Table[A394320[k, n-k], {n, 0, 10}, {k, 0, n}] (* _Paolo Xausa_, Apr 17 2026 *)
%o A394320 (PARI) a(n, k) = if(n==0, 1, 2*k*(k+1)*a(n-1, k+2)-k^2*a(n-1, k));
%Y A394320 Columns k=0..2 give A000007, A000281, A253165.
%Y A394320 Cf. A341268, A395232, A395233.
%K A394320 nonn,tabl
%O A394320 0,5
