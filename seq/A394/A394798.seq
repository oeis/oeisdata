%I A394798 #7 Apr 11 2026 17:17:06
%S A394798 0,0,0,0,0,0,0,1,0,1,1,1,0,2,0,0,1,0,2,1,1,0,1,1,1,1,1,0,2,0,3,1,0,0,
%T A394798 3,0,0,1,2,0,1,0,1,3,1,0,1,1,2,2,0,1,3,0,3,2,3,0,5,0,3,1,2,2,3,2,2,2,
%U A394798 3,0,4,1,4,4,4,0,3,0,1,3,1,0,5,0,2,2,3
%N A394798 For n >= 2, the number of bases b <= n for which the average of the digits of n base b equals the average of the digits of n^2 base b.
%C A394798 The largest term for n <= 10^5 is a(68544) = 162.
%e A394798 a(9) = 1 because 9_6 is {1, 3} and (9^2)_6 is {2, 1, 3}, and the average of each of these sets of digits equals 2, and this is the only such example for n = 9.
%e A394798 a(15) = 2 because 15_3 is {1, 2, 0} and (15^2)_3 is {2, 2, 1, 0, 0} which each average 1, and 15_10 is {1, 5} and (15^2)_10 is {2, 2, 5} which each average 3.
%t A394798 a[n_]:=Module[{b=Range[2,n]},Count[Mean/@IntegerDigits[n,b]-Mean/@IntegerDigits[n^2,b],0]];Array[a,87,2] (* _James C. McMahon_, Apr 11 2026 *)
%o A394798 (PARI) a(n)={my(c=0); for(b=2, n, my(d1=digits(n, b), d2=digits(n^2, b)); if(vecsum(d1)/#d1==vecsum(d2)/#d2, c++)); c}
%K A394798 nonn,base
%O A394798 2,14
%A A394798 _Charles L. Hohn_, Apr 01 2026
