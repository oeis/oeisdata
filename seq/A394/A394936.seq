%I A394936 #33 May 07 2026 17:55:27
%S A394936 2,13,7,883,19652537
%N A394936 The smallest prime with equal digit sums in exactly the first n prime bases.
%e A394936 13 = 1101_2 = 111_3 = 23_5, with digit sums 3,3,5. So a(2) = 13.
%e A394936 7 = 111_2 = 21_3 = 12_5 = 10_7, with digit sums 3,3,3,1. So a(3) = 7.
%t A394936 q[v_] := Equal @@ Most[v] && v[[-1]] != v[[1]]; a[n_] := Module[{p = 2, ps = Prime[Range[n + 1]]}, While[!q[DigitSum[p, #] & /@ ps], p = NextPrime[p]]; p]; Array[a, 4] (* _Amiram Eldar_, May 07 2026 *)
%o A394936 (PARI) isok(p, n) = my(v=vector(n, b, sumdigits(p, prime(b)))); (#Set(v) == 1) && (v[n] != sumdigits(p, prime(n+1)));
%o A394936 a(n) = my(p=2); while (!isok(p,n), p=nextprime(p+1)); p; \\ _Michel Marcus_, May 07 2026
%Y A394936 Cf. A000040, A240236, A037301, A053735, A135127, A135121, A180017, A212222.
