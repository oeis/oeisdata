%I A394540 #16 Apr 03 2026 19:03:48
%S A394540 1,2,1,1,2,3,1,2,1,1,2,1,3,2,1,1,2,1,2,3,1,1,2,1,2,1,3,1,2,1,2,1,3,1,
%T A394540 2,1,2,1,1,2,3,4,1,2,1,1,2,3,1,2,1,1,2,1,3,2,1,1,2,1,2,3,1,1,2,1,2,1,
%U A394540 3,1,2,1,2,1,3,1,2,1,2,1,1,2,3,1,4,2,1
%N A394540 Sequence where, for every step t starting from 2, k is appended if t is a multiple of s(k-1) where s(k) is the Sylvester's sequence (A000058). If multiple numbers trigger on the same step, they are appended in increasing order.
%C A394540 The frequency of k in this sequence is 1/s(k-1). This can be viewed as a probability mass function since Sum_{k>0} 1/s(k-1) = 1.
%C A394540 The arithmetic mean approaches Sum_{k>0} k/s(k-1) = 1.69103020... in the limit.
%C A394540 The geometric mean approaches Product_{k>1} k^(1/s(k-1)) = 1.523673650289... in the limit.
%H A394540 Wikipedia, <a href="https://en.wikipedia.org/wiki/Sylvester%27s_sequence">Sylvester's sequence</a>
%e A394540 At step t=2, we append a 1 because 2 is a multiple of s(0)=2.
%e A394540 At step t=3, we append a 2 because 3 is a multiple of s(1)=3.
%e A394540 At step t=4, we append a 1 because 4 is a multiple of s(0)=2.
%e A394540 At step t=6, we append a 1 and then 2 because 6 is a multiple of both 2 and 3.
%e A394540 At step t=7, we append a 3 because 7 is a multiple of s(2)=7.
%t A394540 seq[len_] := Module[{n = 1, m = 1, c = 0, v = {}, s}, s[0] = 2; s[k_] := s[k] = s[k - 1]^2 - s[k - 1] + 1; While[c < len, n++; Do[If[Divisible[n, s[i - 1]], AppendTo[v, i]; c++; If[i == m + 1, m++]], {i, m + 1}]]; v]; seq[100] (* _Amiram Eldar_, Mar 24 2026 *)
%o A394540 (Python)
%o A394540 from itertools import islice
%o A394540 def sylvester(k):
%o A394540     if k == 0: return 2
%o A394540     s = sylvester(k-1)
%o A394540     return s*s - s + 1
%o A394540 def sample_sylvester_distribution():
%o A394540     n, num_reached = 1, 1
%o A394540     while n := n+1:
%o A394540         for num in range(1, num_reached+2):
%o A394540             if n % sylvester(num-1) == 0:
%o A394540                 yield num
%o A394540                 num_reached += num == num_reached+1
%o A394540 A394540 = list(islice(sample_sylvester_distribution(), 120))
%Y A394540 Cf. A000058, A381522, A381900, A382093.
%K A394540 nonn
%O A394540 1,2
