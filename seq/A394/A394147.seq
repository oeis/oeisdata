%S A394147 0,1,3,15,90,597,4221,31188,237978,1860945,14835645,120126495,
%T A394147 985235004,8167843404,68334799500,576222235704,4892225240610,
%U A394147 41785703027433,358800637223277,3095504824833885,26819466144996546,233253438212851485,2035680638193663093
%N A394147 G.f. A(x) satisfies 3*A(x)^3+(6x-2)*A(x)^2+x*A(x)+x^2=0.
%C A394147 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with blue root where red vertices can be followed by red or blue vertices, blue vertices can be followed by vertices of any color, and green vertices can only be followed by red vertices.
%H A394147 Nathan Fox, <a href="/A394147/b394147.txt">Table of n, a(n) for n = 0..300</a>
%H A394147 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394147 (Python)
%o A394147 def A394147(n):
%o A394147     A = [[1, 1, 0], [1, 1, 1], [1, 0, 0]]
%o A394147     if n == 0:
%o A394147         return 0
%o A394147     m = len(A)
%o A394147     output = [[1] for i in range(m)]
%o A394147     for l in range(2, n + 1):
%o A394147         for i in range(m):
%o A394147             term = 0
%o A394147             for k in range(1, l):
%o A394147                 for j in range(m):
%o A394147                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394147             output[i].append(term)
%o A394147     return output[1][n - 1]
%Y A394147 Cf. A394146.
%K A394147 nonn,new
%O A394147 0,3
%A A394147 _Nathan Fox_, Mar 11 2026
