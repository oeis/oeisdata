%N A394494 Expansion of e.g.f. (1/x) * Series_Reversion( x*(1 - 4*x)^(1/4) ).
%H A394494 Vincenzo Librandi, <a href="/A394494/b394494.txt">Table of n, a(n) for n = 0..300</a>
%F A394494 E.g.f. A(x) satisfies A(x) = 1/(1 - 4*x*A(x))^(1/4).
%F A394494 a(n) = 4^n * n! * binomial((5*n-3)/4,n)/(n+1).
%F A394494 a(n) ~ 5^(5*n/4-1/4)*exp(-n)*n^(n-1). - _Stefano Spezia_, Mar 22 2026
%t A394494 a[n_]:=4^n*n!*Binomial[(5 n-3)/4,n]/(n+1); Table[a[n],{n,0,20}] (* _Vincenzo Librandi_, Mar 28 2026 *)
%o A394494 (PARI) a(n) = 4^n*n!*binomial((5*n-3)/4, n)/(n+1);
%o A394494 (Magma) [1] cat [4^n*Factorial(n)*&*[((5*n-3)/4-k): k in [0..n-1]]/Factorial(n)/(n+1): n in [1..20]]; // _Vincenzo Librandi_, Mar 28 2026
