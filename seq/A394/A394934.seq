%e A394934 See also the link in A394935 showing a(1) .. a(5).
%t A394934 (* support functions restate functions in the respective sequences *)
%t A394934 a014105[n_] := n(2n+1)
%t A394934 a240542[n_] := Sum[(-1)^(k+1) Ceiling[(n+1)/k-(k+1)/2], {k, 1, Floor[-1/2+1/2 Sqrt[8 n+1]]}]
%t A394934 a394934[b_] := Select[Map[a014105, Range[b]], a240542[#]==a240542[#-1]&]-1
%t A394934 a394934[70]
%Y A394934 Cf. A014105, A071562, A237593, A240542, A298856, A394935.
%K A394934 nonn,new
