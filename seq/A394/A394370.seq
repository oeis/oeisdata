%I A394370 #49 Jun 08 2026 21:42:11
%S A394370 1,1,1,2,1,1,1,1,2,1,1,3,1,1,2,1,1,1,1,2,1,1,1,1,4,3,2,1,1,1,1,2,1,1,
%T A394370 1,1,2,1,3,1,1,2,1,1,1,5,1,2,1,1,1,1,4,3,2,1,1,1,1,2,1,1,1,1,2,1,3,1,
%U A394370 1,1,2,1,1,1,6,1,2,1,1,1,4,3,1,2,1,1,1,2
%N A394370 A sequence constructed by greedily sampling the probability distribution given by log_2(1+1/i)^2 - log_2(1+1/(i+1))^2 to minimize ratio discrepancy.
%C A394370 The probability mass function used here is a simple example of a power-law tail distribution. The p=1 case of the family below is the Gauss-Kuzmin distribution. As a consequence of the lighter tail, both the arithmetic mean and the geometric mean of this sequence are finite.
%C A394370 A general family of these distributions is given by log_2(1+1/i)^p - log_2(1+1/(i+1))^p where p>0. The p=1 case is the Gauss-Kuzmin distribution (A084580).
%C A394370 Properties change sharply at p=1, the geometric mean remains finite for all p but the arithmetic mean becomes finite for p>1 and infinite for p<=1.
%C A394370 | mean       | 0 < p <= 1 | p > 1  |
%C A394370 | ---------- | ---------- | ------ |
%C A394370 | arithmetic |     oo     | finite |
%C A394370 | geometric  |   finite   | finite |
%C A394370 The Fisher information is always finite and given by Sum_{i=1..inf} ((ln(log_2(1+1/i))*(log_2(1+1/i))^p - ln(log_2(1+1/(i+1)))*(log_2(1+1/(i+1)))^p)^2) / ((log_2(1+1/i))^p - (log_2(1+1/(i+1)))^p).
%C A394370 This sequence is generated by the D'Hondt (or Jefferson) apportionment method for the given distribution.
%C A394370 From _Jwalin Bhatt_, Jun 03 2026: (Start)
%C A394370 The arithmetic mean equals Sum_{i>=1} log_2(1+1/i)^2 = 2.0338912546... and for general power p in the family above, it equals Sum_{i>=1} log_2(1+1/i)^p.
%C A394370 The geometric mean equals Product_{i>=1} (1+1/i)^(log_2(1+1/(i+1))^2) = 1.469227314899... and for general power p in the family above it equals Product_{i>=1} (1+1/i)^(log_2(1+1/(i+1))^p).
%C A394370 (End)
%H A394370 Jwalin Bhatt, <a href="/A394370/b394370.txt">Table of n, a(n) for n = 1..10000</a>
%H A394370 Wikipedia, <a href="https://en.wikipedia.org/wiki/D%27Hondt_method">D'Hondt method</a>.
%e A394370 Let p(k) denote the probability of k and c(k) denote the count of occurrences of k so far.
%e A394370 We take the ratio of the actual occurrences c(k)+1 to the probability and pick the one with the lowest value.
%e A394370 Since p(k) is monotonic decreasing, we only need to compute c(k) once we see c(k-1).
%e A394370 | n | (c(1)+1)/p(1) | (c(2)+1)/p(2) | (c(3)+1)/p(3) | choice |
%e A394370 |---|---------------|---------------|---------------|--------|
%e A394370 | 1 |     1.520     |       -       |       -       |   1    |
%e A394370 | 2 |     3.040     |     5.884     |       -       |   1    |
%e A394370 | 3 |     4.560     |     5.884     |       -       |   1    |
%e A394370 | 4 |     6.080     |     5.884     |       -       |   2    |
%e A394370 | 5 |     6.080     |    11.769     |    14.573     |   1    |
%t A394370 pdf[i_] := Log2[1+1/i]^2 - Log2[1+1/(i+1)]^2
%t A394370 samplePDF[numCoeffs_] := Module[
%t A394370   {coeffs = {}, counts = {0}, minTime, minIndex, time},
%t A394370 Do[
%t A394370     minTime = Infinity;
%t A394370     Do[
%t A394370       time = (counts[[i]] + 1)/pdf[i];
%t A394370       If[time < minTime, minIndex = i; minTime = time],
%t A394370       {i, 1, Length[counts]}
%t A394370     ];
%t A394370     If[minIndex == Length[counts], AppendTo[counts, 0]];
%t A394370     counts[[minIndex]] += 1;
%t A394370     AppendTo[coeffs, minIndex],
%t A394370     {numCoeffs}
%t A394370   ];
%t A394370   coeffs
%t A394370 ]
%t A394370 A394370 = samplePDF[120]
%o A394370 (Python)
%o A394370 from mpmath import iv
%o A394370 def pdf(k):
%o A394370     return iv.log(1+1/k,2)**2 - iv.log(1+1/(k+1),2)**2
%o A394370 def sample_log_tail_distribution(num_coeffs):
%o A394370   coeffs, counts = [], [0]
%o A394370   for _ in range(num_coeffs):
%o A394370     min_time = iv.inf
%o A394370     for i, count in enumerate(counts, start=1):
%o A394370       time = (count+1) / pdf(i)
%o A394370       if time < min_time:
%o A394370         min_index, min_time = i, time
%o A394370     if min_index == len(counts):
%o A394370       counts.append(0)
%o A394370     counts[min_index-1] += 1
%o A394370     coeffs.append(min_index)
%o A394370   return coeffs
%o A394370 A394370 = sample_log_tail_distribution(120)
%Y A394370 Cf. A084580, A393100, A394401, A396405.
%K A394370 nonn,new
%O A394370 1,4
