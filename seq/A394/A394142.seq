%T A394142 641278125,4906551925,38082333652,299161679020,2374285935782,
%U A394142 19009255256765,153349252634092,1245249010912888,10170369472358633,83489241602340722,688481467240020797
%N A394142 G.f. A(x) satisfies (x+1)*A(x)^5-(x+2)*A(x)^4+(2x^2+3x+1)*A(x)^3-(x^2+3x)*A(x)^2+3x^2*A(x)-x^3=0.
%C A394142 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with green root where red vertices can only be followed by blue vertices, blue vertices can be followed by vertices of any colors, and green vertices can be followed by red or green vertices.
%H A394142 Nathan Fox, <a href="/A394142/b394142.txt">Table of n, a(n) for n = 0..300</a>
%H A394142 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394142 (Python)
%o A394142 def A394142(n):
%o A394142     A = [[0, 1, 0], [1, 1, 1], [1, 0, 1]]
%o A394142     if n == 0:
%o A394142         return 0
%o A394142     m = len(A)
%o A394142     output = [[1] for i in range(m)]
%o A394142     for l in range(2, n + 1):
%o A394142         for i in range(m):
%o A394142             term = 0
%o A394142             for k in range(1, l):
%o A394142                 for j in range(m):
%o A394142                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394142             output[i].append(term)
%o A394142     return output[2][n - 1]
%Y A394142 Cf. A394140, A394141.
%K A394142 nonn,new
%O A394142 0,3
%A A394142 _Nathan Fox_, Mar 11 2026
