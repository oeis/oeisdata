%I A394309 #19 Apr 12 2026 19:15:54
%S A394309 1,1,1,4,13,56,277,1429,8489,51769,344961,2391698,17496661,133658565,
%T A394309 1060426557,8749399966,74494928017,655734728718,5936865639625,
%U A394309 55292734329958,528332681177821,5174197047357241,51867294310990885,531492968044248844,5562798258563207737
%N A394309 Number of peakless Motzkin paths of length n with up steps in n colors.
%C A394309 A peakless Motzkin path of length n is a lattice path from (0,0) to (n,0) using only steps U = (1,1), F = (1,0) and D = (1,-1) but no consecutive steps UD.
%H A394309 Alois P. Heinz, <a href="/A394309/b394309.txt">Table of n, a(n) for n = 0..670</a>
%H A394309 Wikipedia, <a href="https://en.wikipedia.org/wiki/Motzkin_number">Motzkin number</a>
%F A394309 a(n) = Sum_{k>=0} n^k * A089732(n,k).
%F A394309 a(n) == 1 (mod n) for n>=1.
%p A394309 b:= proc(x, y, t, k) option remember; `if`(y<0 or y>x, 0,
%p A394309      `if`(x=0, 1, k*b(x-1, y+1, true, k)+b(x-1, y, false, k)+
%p A394309      `if`(t, 0, b(x-1, y-1, false, k))))
%p A394309     end:
%p A394309 a:= n-> b(n,0,false,n):
%p A394309 seq(a(n), n=0..24);
%Y A394309 Cf. A001006, A089732, A307906.
%K A394309 nonn
%O A394309 0,4
%A A394309 _Alois P. Heinz_, Apr 12 2026
