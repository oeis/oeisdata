%S A394990 1,3,6,14,30,62,115,217,467,1022,1515,3481,7669,13147,23235,50947,
%T A394990 129455,258529,347861,849583,1548233,4188889,6955513,13264529,
%U A394990 32136021,63500391,126167093,250203119,513437625,819933439,2108238657,4042815511,8587869953,13930220515
%N A394990 a(n) is the larger of the two factors whose product is A394987.
%C A394990 The factors may be equal, but no example for n>1 is known.
%e A394990 See A394987.
%o A394990 (Python)
%o A394990 from sympy.utilities.iterables import multiset_permutations
%o A394990 from sympy import divisors
%o A394990 def A394990(n):
%o A394990     a = 1<<n-1
%o A394990     b = a<<1
%o A394990     k = (n<<1)-1
%o A394990     for l in range(k,0,-1):
%o A394990         for s in multiset_permutations('0'*(k+1-l)+'1'*l):
%o A394990             m = int(''.join(s),2)
%o A394990             for d in divisors(m):
%o A394990                 if d**2>m:
%o A394990                     break
%o A394990                 if a<=d<b and a*d<=m<b*d:
%o A394990                     return m//d # _Chai Wah Wu_, Apr 11 2026
%Y A394990 A394989 is the smaller factor.
%Y A394990 Cf. A053644, A394987, A395003, A395004.
%K A394990 nonn,new
%O A394990 1,2
%A A394990 _Hugo Pfoertner_, Apr 09 2026
%E A394990 a(24)-a(34) from _Chai Wah Wu_, Apr 10 2026
