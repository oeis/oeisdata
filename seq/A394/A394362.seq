%U A394362 2,3,1,2,1,2,1,2,1,3,1,1,1,2,1,1,1,2,2,1,1,3,2,2,1,2,2,2,1,2,1,1
%N A394362 Number of divisors d of n which also divide n/d + 1.
%H A394362 James C. McMahon, <a href="/A394362/b394362.txt">Table of n, a(n) for n = 1..10000</a>
%e A394362 a(2) = 2 because 2/d + 1 == 0 (mod d) for d = 1 (or 2) of n = 2;
%e A394362 a(6) = 3 because 6/d + 1 == 0 (mod d) for d = 1 (or 2, 3) of n = 6, but d = 6 is a nondivisor of 2 = 6/6 + 1.
%p A394362 a:= n-> add(`if`(irem(n/d+1, d)=0, 1, 0), d=numtheory[divisors](n)):
%p A394362 seq(a(n), n=1..100);  # _Alois P. Heinz_, Mar 20 2026
%t A394362 fmod[n_,d_]:=Mod[n/d+1,d];a[n_]:=Module[{d=Divisors[n]},Count[fmod[n,d],0]];Array[a,100] (* _James C. McMahon_, Mar 28 2026 *)
%o A394362 (Magma) [#[d: d in Divisors(n) | ((n div d) + 1) mod d eq 0]: n in [1..100]];
%Y A394362 Cf. A000005, A014567, A046951, A069059, A163671 (number of divisors d of n which also divide n/d - 1).
%K A394362 nonn,new
%O A394362 1,2
