%S A394132 0,1,2,7,31,156,850,4888,29221,179856,1132397,7259878,47235460,
%T A394132 311120458,2070502678,13901297853,94047022187,640504062010,
%U A394132 4387716737209,30213888841234,209018060143371,1451994168031332,10124518109790684,70837165324963952,497157791239583372
%N A394132 G.f. A(x) satisfies A(x)^5+(x-2)*A(x)^4+(1-x)*A(x)^3+x*A(x)^2-x*A(x)+x^2=0.
%C A394132 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with red root where red vertices can be followed by blue or green vertices, blue vertices can only be followed red vertices, and green vertices can be followed by red or green vertices.
%H A394132 Nathan Fox, <a href="/A394132/b394132.txt">Table of n, a(n) for n = 0..300</a>
%H A394132 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394132 (Python)
%o A394132 def A394132(n):
%o A394132     A = [[0, 1, 1], [1, 0, 0], [1, 0, 1]]
%o A394132     if n == 0:
%o A394132         return 0
%o A394132     m = len(A)
%o A394132     output = [[1] for i in range(m)]
%o A394132     for l in range(2, n + 1):
%o A394132         for i in range(m):
%o A394132             term = 0
%o A394132             for k in range(1, l):
%o A394132                 for j in range(m):
%o A394132                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394132             output[i].append(term)
%o A394132     return output[0][n - 1]
%Y A394132 Cf. A394133, A394134.
%K A394132 nonn,new
%O A394132 0,3
%A A394132 _Nathan Fox_, Mar 11 2026
