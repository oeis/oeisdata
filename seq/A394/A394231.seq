%N A394231 Expansion of 1 / sqrt(1 - 10*x + 17*x^2).
%C A394231 Second binomial transform of A001850.
%C A394231 Diagonal of the rational function 1 / (1 - x^2 - 5*x*y - 2*y^2).
%F A394231 E.g.f.: exp(5*x) * BesselI(0,2*sqrt(2)*x).
%F A394231 Coefficient of x^n in (1 + 5*x + 2*x^2)^n.
%F A394231 n * a(n) = 5 * (2*n-1) * a(n-1) - 17 * (n-1) * a(n-2) with a(0) = 1, a(1) = 5.
%F A394231 a(n) = Sum_{k=0..floor(n/2)} binomial(n,2*k) * binomial(2*k,k) * 2^k * 5^(n-2*k).
%t A394231 nmax = 22; CoefficientList[Series[1/Sqrt[1 - 10 x + 17 x^2], {x, 0, nmax}], x]
%t A394231 nmax = 22; CoefficientList[Series[Exp[5 x] BesselI[0, 2 Sqrt[2] x], {x, 0, nmax}], x] Range[0, nmax]!
%t A394231 a[0] = 1; a[1] = 5; a[n_] := a[n] = (5 (2 n - 1) a[n - 1] - 17 (n - 1) a[n - 2])/n; Table[a[n], {n, 0, 22}]
%t A394231 Table[Sum[Binomial[n, 2 k] Binomial[2 k, k] 2^k 5^(n - 2 k), {k, 0, Floor[n/2]}], {n, 0, 22}]
%Y A394231 Cf. A001850, A006139, A059304, A080609, A081671, A084601, A098409, A154340, A394232, A394233.
%K A394231 nonn
%O A394231 0,2
