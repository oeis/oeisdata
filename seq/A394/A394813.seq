%T A394813 10010,45760,39039,2730,1,8,980,31668,307450,784212,355446,10922,1,9,
%U A394813 1632,84966,1508988,8666515,13021320,3215397,43690,1
%N A394813 Triangle read by rows: T(n, k) is the k-th even-indexed column of the array A394582.
%C A394813 This triangle represents the scaling phase of the parity-dependent recurrence defined in A394582. It is the counterpart to the central factorial triangle A008957.
%F A394813 T(n, k) = A394582(n - k + 1, 2*k) for 1 <= k <= n.
%F A394813 T(n, 1) = n, T(n, n) = 1;
%F A394813 T(n, k) = (n-k+1)^2 * T(n-1, k-1) + (n-k+1) * Sum_{j=1..n-k} (j * T(j+k-2, k-1)) for 1 < k < n.
%F A394813 T(n, k) = ((n - k + 1) / (2*n - 2*k + 1)!) * Sum_{i=0..2*n - 2*k + 1} (-1)^(2*n - 2*k + 1 - i) * binomial(2*n - 2*k + 1, i) * (i - n + k)^(2*n - 1).
%F A394813 T(n, k) = (n - k + 1) * Sum_{j=0..2*n - 1} binomial(2*n - 1, j) * (k - n)^(2*n - 1 - j) * Stirling2(j, 2*n - 2*k + 1).
%F A394813 From _Peter Luschny_, Apr 02 2026: (Start)
%F A394813 T(n, k) = 2*m*Sum_{j=0..n-k}((-1)^j*(m - j)^(2*n)/((2*m - j)!*j!) where m = n - k + 1.
%F A394813 T(n, k) = Sum_{j=0..n-k} ((-1)^j*binomial(2*m, j)*(m-j)^(2*n))/(2*m-1)! where m = n - k + 1.
%F A394813 T(n, k) = ((m * T(n - 1, k)) / (n - k)) + (m^2 * T(n - 1, k - 1)) where m = n - k + 1, with boundary conditions T(n, 1) = n and T(n, n) = 1. (End)
%e A394813 The triangle starts:
%e A394813   1;
%e A394813   2,   1;
%e A394813   3,  10,     1;
%e A394813   4,  42,    42,      1;
%e A394813   5, 120,   441,    170,      1;
%e A394813   6, 275,  2508,   4224,    682,      1;
%e A394813   7, 546, 10010,  45760,  39039,   2730,     1;
%e A394813   8, 980, 31668, 307450, 784212, 355446, 10922, 1;
%p A394813 T := proc(n, k) local m; m := n-k+1; 2*m*sum((-1)^j*(m-j)^(2*n)/((2*m-j)!*j!), j=0..n-k) end:
%p A394813 for n from 1 to 9 do seq(T(n, k), k = 1..n) od;
%o A394813 (Python)
%o A394813 from functools import cache
%o A394813 @cache
%o A394813 def T(n: int, k: int) -> int:
%o A394813     if k == 1: return n
%o A394813     if n == k: return 1
%o A394813     return (((n - k + 1) * T(n - 1, k)) // (n - k)) + (((n - k + 1) ** 2) * T(n - 1, k - 1))
%o A394813 for n in range(1, 10): print([T(n, k) for k in range(1, n + 1)])  # _Peter Luschny_, Apr 02 2026
