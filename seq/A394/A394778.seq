%U A394778 63094160413469746866,4017636490580390866266,271653262635061388935170,19440301089648918968229186
%N A394778 G.f. A(x) satisfies A(x) = 1 - 2*x * d/dx log(1 - x*A(x)^2).
%H A394778 Vincenzo Librandi, <a href="/A394778/b394778.txt">Table of n, a(n) for n = 0..300</a>
%F A394778 G.f. A(x) satisfies A(x) = 1 + x*A(x)^2*(1 + A(x)) + 2*x^2*d/dx(A(x)^2).
%F A394778 a(0) = 1; a(n) = (2*n-1) * Sum_{k=0..n-1} a(k) * a(n-1-k) + Sum_{i, j, k>=0 and i+j+k=n-1} a(i)*a(j)*a(k).
%t A394778 a={1}; nmax=20; Do[s1=Sum[a[[k+1]] a[[n-k]],{k,0,n-1}]; s2=Sum[a[[i+1]] a[[j+1]] a[[n-1-i-j+1]],{i,0,n-1},{j,0,n-1-i}]; AppendTo[a,(2 n-1) s1+s2];,{n,1,nmax}]; a (* _Vincenzo Librandi_, Apr 02 2026 *)
%o A394778 (Magma) nmax := 20; a := [1]; for n in [1..nmax] do s1 := &+[ a[k+1] * a[n-k] : k in [0..n-1] ]; s2 := &+[ a[i+1] * a[j+1] * a[n-1-i-j+1] : i, j in [0..n-1] | i+j le n-1 ]; Append(~a, (2*n - 1)*s1 + s2); end for; a; // _Vincenzo Librandi_, Apr 02 2026
