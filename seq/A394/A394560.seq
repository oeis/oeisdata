%U A394560 172099871969612167917,13303515237938026956117,1099337226665329471438431,96707522894891123331439803,9023068677396457200506257701
%N A394560 The coefficients of the exponential expansion of the compositional inverse of f(t) = Sum_{m>=1} tau3(m)*(-1)^(m + 1)*t^m/m.
%C A394560 Here tau3(m) refers to the number of ordered factorizations into three factors of its argument m.
%o A394560 (SageMath)
%o A394560 def A007425(n: int) -> list[int]:
%o A394560     tau = lambda n: ZZ(sloane.A000005[n])
%o A394560     tau3 = lambda n: sum(tau(d) for d in divisors(n))
%o A394560     return [tau3(k+1) for k in range(n+1)]
%o A394560 def LagrangeInversion(t, N: int) -> list[int]:
%o A394560     a = t(N)
%o A394560     c = [QQ(0)]*(N+1); c[0] = 1
%o A394560     A = [ZZ(0)]*(N+1)
%o A394560     h = [QQ(0)]*(N+1); h[0] = 1
%o A394560     for n in range(1, N+1):
%o A394560         h[n] = -sum((-1)^j * a[j] * h[n-j] / (j+1) for j in range(1, n+1))
%o A394560     fact = 1
%o A394560     for k in range(1, N+1):
%o A394560         for n in range(k-1, -1, -1):
%o A394560             s = c[n]
%o A394560             for j in range(1, n+1): s += h[j]*c[n-j]
%o A394560             c[n] = s
%o A394560         fact *= k
%o A394560         A[k] = fact * c[k-1]
%o A394560     return A
%o A394560 print(LagrangeInversion(A007425, 19))  # _Peter Luschny_, Mar 27 2026
%Y A394560 Cf. A394559, A393519, A007425 (tau3).
%K A394560 nonn,new
