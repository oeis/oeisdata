%N A394822 a(n) = (2*n)! * [x^n] (1 + s * sinh(2*s)) where s = sinh(x^(1/2)/2). Row sums of A394823.
%p A394822 s := sinh(x^(1/2)/2): ser := series(1 + s*sinh(2*s), x, 21):
%p A394822 seq((2*n)!*coeff(ser, x, n), n = 0..20);
%o A394822 (Python)
%o A394822 from functools import cache
%o A394822 @cache
%o A394822 def cfact2(n, j):
%o A394822     if j == 1 or j == n: return 1
%o A394822     if j < 1 or j > n: return 0
%o A394822     return cfact2(n-1, j-1) + j * j * cfact2(n-1, j)
%o A394822 def a(n: int):
%o A394822     return 1 if n == 0 else sum(j*cfact2(n, j) for j in range(1, n + 1))
%o A394822 L = [a(n) for n in range(0, 20)]; print(L)
%Y A394822 Cf. A394823.
%K A394822 nonn,new
