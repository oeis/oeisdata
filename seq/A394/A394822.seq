%I A394822 #27 Apr 05 2026 05:37:23
%S A394822 1,1,3,14,89,737,7696,98093,1490687,26542518,545598045,12787451789,
%T A394822 338242587616,10009697903337,328904762907595,11920843347833790,
%U A394822 473823597606008273,20548002984943505609,967771470672870445808,49298811173324614524853,2706106551826175626366823
%N A394822 Expansion of o.g.f. 1 + Sum_{n>=1} (n * x^n / Product_{k=1..n} (1 - k^2*x)). Row sums of A394823.
%C A394822 Total number of blocks (for n > 0) in all partitions of the set {1, 1', 2, 2', ..., n, n'} according to the rules of A135920.
%C A394822 a(n) is the total number of blocks (nonempty subsets Vj) across all partitions described in A135920. While A135920 is the number of such partitions, this sequence is the total number of blocks within all those partitions.
%F A394822 a(0) = 1; a(n) = Sum_{k=1..n} A394813(n, k).
%F A394822 a(0) = 1; for n > 0: a(n) = Sum_{k=1..n} (n - k + 1) * A008957(n, k).
%F A394822 a(0) = 1; for n > 0: E.g.f.: (E(x) - 1) * E'(E(x) - 1), where E(x) = cosh(sqrt(2*x)).
%F A394822 a(n) = (2*n)! * [x^n] (1 + s * sinh(2*s)) where s = sinh(x^(1/2)/2). - _Peter Luschny_, Apr 04 2026
%e A394822 a(3) = 14: From A135920, there are 7 such partitions of {1, 1', 2, 2', 3, 3'}:
%e A394822   1 partition into k=1 block: {1,1',2,2',3,3'} (gives 1 block);
%e A394822   5 partitions into k=2 blocks, for example {1,1',2,2'}{3,3'} (gives 5 * 2 = 10 blocks);
%e A394822   1 partition into k=3 blocks: {1,1'}{2,2'}{3,3'} (gives 3 blocks).
%e A394822   Total number of blocks = 1 + 10 + 3 = 14.
%e A394822 a(4) = 89: From A135920, there are 37 such partitions of {1, 1', ..., 4, 4'}:
%e A394822   1 partition into k=1 block, counted with weight (4-1+1)=4: 1 * 4 = 4;
%e A394822   14 partitions into k=2 blocks, each counted with weight (4-2+1)=3: 14 * 3 = 42;
%e A394822   21 partitions into k=3 blocks, each counted with weight (4-3+1)=2: 21 * 2 = 42;
%e A394822   1 partition into k=4 blocks, counted with weight (4-4+1)=1: 1 * 1 = 1.
%e A394822   Total weighted sum: 4 + 42 + 42 + 1 = 89.
%p A394822 s := sinh(x^(1/2)/2): ser := series(1 + s*sinh(2*s), x, 21):
%p A394822 seq((2*n)!*coeff(ser, x, n), n = 0..20);  # _Peter Luschny_, Apr 04 2026
%t A394822 A[x_] = 1 + Sum[n * x^n/Product[1 - k^2 x, {k, 1, n}], {n, 1, 21}];
%t A394822 CoefficientList[A[x] + O[x]^21, x]  (* _Peter Luschny_, Apr 04 2026 *)
%o A394822 (Python)
%o A394822 from functools import cache
%o A394822 @cache
%o A394822 def cfact2(n, j):
%o A394822     if j == 1 or j == n: return 1
%o A394822     if j < 1 or j > n: return 0
%o A394822     return cfact2(n-1, j-1) + j * j * cfact2(n-1, j)
%o A394822 def a(n: int): return 1 if n == 0 else sum(j*cfact2(n, j) for j in range(1, n + 1))
%o A394822 L = [a(n) for n in range(0, 20)]; print(L)  # _Peter Luschny_, Apr 04 2026
%Y A394822 Cf. A394823, A135920 (number of partitions), A394813 (triangle), A394582 (parent array), A008957 (central factorials).
%K A394822 nonn,new
%O A394822 0,3
