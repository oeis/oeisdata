%T A394461 746,950,1194,1499,1872,2331,2885,3575,4402,5399,6618,8081,9833,11948,
%U A394461 14478,17484,21101,25372,30462,36492,43650,52047,62043,73735,87534,103685,122710,144842,170902
%N A394461 Number of partitions p of n such that 3 * (the least multiplicity of the parts of p) is a part of p.
%F A394461 G.f.: Sum_{j>=1} Product_{k>=1} (1 - delta(3*j,k) + q^(j*k)/(1-q^k)) - Product_{k>=1} (1 - delta(3*j,k) + q^((j+1)*k)/(1-q^k)), where delta(j,k) is the Kronecker delta.
%e A394461 a(8) counts these 6 partitions: 53, 431, 332, 3221, 32111, 311111".
%o A394461 (PARI) my(N=60, q='q+O('q^N)); concat([0, 0], Vec(sum(j=1, N, prod(k=1, 3*N, 1-(3*j==k)+q^(j*k)/(1-q^k))-prod(k=1, 3*N, 1-(3*j==k)+q^((j+1)*k)/(1-q^k)))))
%Y A394461 Cf. A365614, A394460.
%K A394461 nonn
%O A394461 1,5
%A A394461 _Seiichi Manyama_, Mar 21 2026
