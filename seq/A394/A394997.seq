%U A394997 110,1,8,23,36,8,43,1,23,8,43,1,115,1,8,23,23,8,43,1,77
%N A394997 Wiener index of the divisor prime graph of n.
%H A394997 Purva J. Makadiya, Mahesh M. Jariya, and Prashant J. Makadiya, <a href="https://arxiv.org/abs/2604.06907">Topological Indices of Divisor Prime Graphs</a>, arXiv:2604.06907 [math.CO], 2026. See W p. 4.
%F A394997 a(n) = A337524(n) - A063647(n).
%F A394997 a(n) = tau(n)*(tau(n)-1) - (Product_{k=1..r} (2*a_k+1) - 1)/2 where tau(n) is A000005(n) and r is omega(n)=A001221(n), for n = Product_{k=1..r} p_i^a_k.
%t A394997 Table[d = DivisorSigma[0, n]; d*(d - 1) - 1/2*(DivisorSigma[0, n^2] - 1), {n, 80}] (* _Michael De Vlieger_, Apr 09 2026 *)
%o A394997 (PARI) a(n) = my(f=factor(n), d=numdiv(f)); d*(d-1) - (prod(i=1, #f~, (2*f[i,2]+1)) - 1)/2;
%Y A394997 Cf. A001221, A063647, A337524.
%K A394997 nonn
%O A394997 1,4
