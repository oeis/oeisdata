%I A394958 #16 Jul 04 2026 09:56:52
%S A394958 0,4,20,60,64,80,84,100,136,144,150,156,196,220,224,240,260,320,324,
%T A394958 360,380,444,580,600,660,700,736,900,960,1020,1024,1040,1056,1100,
%U A394958 1260,1280,1344,1404,1440,1476,1484,1600,1620,1640,1680,1736,1780,1824,1884,2020,2100,2176,2304,2400,2436,2480
%N A394958 Numbers k such that k = x*y = w*z with x + y and w - z squares.
%C A394958 If k is a term, then so is k * m^4 for all m.
%C A394958 All terms are even.
%H A394958 Robert Israel, <a href="/A394958/b394958.txt">Table of n, a(n) for n = 1..10000</a>
%e A394958 a(6) = 80 is a term because 80 = 80 * 1 = 20 * 4 with 80 + 1 = 81 = 9^2 and 20 - 4 = 16 = 4^2 squares.
%p A394958 filter:= proc(n) local D;
%p A394958    D:= select(t -> t^2 >= n, NumberTheory:-Divisors(n));
%p A394958    ormap(t -> issqr(t + n/t), D) and ormap(t -> issqr(t - n/t), D)
%p A394958 end proc:
%p A394958 filter(0):= true:
%p A394958 select(filter, [seq(i,i=0..10000,2)]);
%Y A394958 0 and intersection of A218381 and A395626. Includes A013709.
%K A394958 nonn
%O A394958 1,2
%A A394958 _Robert Israel_, Jul 02 2026
