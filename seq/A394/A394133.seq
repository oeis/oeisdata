%S A394133 0,1,1,3,12,56,288,1583,9129,54578,335522,2108754,13492814,87615489,
%T A394133 575986999,3826311988,25646949717,173243532072,1178199786364,
%U A394133 8060658132743,55439470986851,383105416597112,2658636183714792,18520888690187382,129471023915349560
%N A394133 G.f. A(x) satisfies A(x)^5-2*A(x)^4+(4x+1)*A(x)^3-(3x^2+3x)*A(x)^2+(x^3+3x^2)*A(x)-x^3=0.
%C A394133 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with blue root where red vertices can be followed by blue or green vertices, blue vertices can only be followed red vertices, and green vertices can be followed by red or green vertices.
%H A394133 Nathan Fox, <a href="/A394133/b394133.txt">Table of n, a(n) for n = 0..300</a>
%H A394133 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394133 (Python)
%o A394133 def A394133(n):
%o A394133     A = [[0, 1, 1], [1, 0, 0], [1, 0, 1]]
%o A394133     if n == 0:
%o A394133         return 0
%o A394133     m = len(A)
%o A394133     output = [[1] for i in range(m)]
%o A394133     for l in range(2, n + 1):
%o A394133         for i in range(m):
%o A394133             term = 0
%o A394133             for k in range(1, l):
%o A394133                 for j in range(m):
%o A394133                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394133             output[i].append(term)
%o A394133     return output[1][n - 1]
%Y A394133 Cf. A394132, A394134.
%K A394133 nonn,new
%O A394133 0,4
%A A394133 _Nathan Fox_, Mar 11 2026
