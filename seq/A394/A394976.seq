%I A394976 #23 Apr 14 2026 19:03:54
%S A394976 7,1,19,125,1453,89,13687,397549,7708537,68529640373,4472029801,
%T A394976 2598638688071,149780635937,162580897794660958,11231299844779783,
%U A394976 676470671886391879633,3688053840923281541,38065792685808703577,2659842854283579394387
%N A394976 Numerators of the coefficient of Pi^(2n+1) in Plouffe's formula for zeta(2n+1).
%C A394976 Equals A057866((n+1)/2) for odd n.
%H A394976 Jwalin Bhatt, <a href="/A394976/b394976.txt">Table of n, a(n) for n = 1..273</a>
%H A394976 Simon Plouffe, <a href="http://www.plouffe.fr/simon/inspired2.pdf">Identities inspired by Ramanujan Notebooks (part 2)</a>, April 2006.
%H A394976 Linas Vepštas, <a href="https://doi.org/10.1007/s11139-011-9335-9">On Plouffe's Ramanujan identities</a>, The Ramanujan Journal, Vol. 27 (2012), pp. 387-408; <a href="https://arxiv.org/abs/math/0609775">arXiv preprint</a>, arXiv:math/0609775 [math.NT], 2006-2010.
%H A394976 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/RiemannZetaFunction.html">Riemann Zeta Function</a>.
%F A394976 Limit_{n->oo} (a(n)/A394977(n)) * Pi^(2n+1) = coth(Pi) (A175316).
%t A394976 a[n_] := Module[{n0 = n, s, s1, s2, frac},
%t A394976   If[OddQ[n], (* 4n - 1 case *)
%t A394976    n0 = Floor[n/2] + 1;
%t A394976    s = Sum[
%t A394976      (-1)^j * Binomial[4*n0, 2*j] * BernoulliB[4*n0 - 2*j] * BernoulliB[2*j],
%t A394976      {j, 0, 2*n0}
%t A394976    ];
%t A394976    frac = -2^(4*n0 - 2) * s / Factorial[4*n0];
%t A394976    ,
%t A394976    (* 4n + 1 case *)
%t A394976    n0 = Floor[n/2];
%t A394976    s1 = Sum[
%t A394976      (-4)^(n0 + j) * Binomial[4*n0 + 2, 4*j] * BernoulliB[4*n0 - 4*j + 2] * BernoulliB[4*j],
%t A394976      {j, 0, n0}
%t A394976    ];
%t A394976    s2 = Sum[
%t A394976      (-4)^j * Binomial[4*n0 + 2, 2*j] * BernoulliB[4*n0 - 2*j + 2] * BernoulliB[2*j],
%t A394976      {j, 0, 2*n0 + 1}
%t A394976    ];
%t A394976    frac = 2^(4*n0 + 1) * (s1 + s2/2) / (Factorial[4*n0 + 2] * (1 + (-4)^n0 - 2^(4*n0 + 1)));
%t A394976   ];
%t A394976   Numerator[frac]
%t A394976 ]
%o A394976 (Python)
%o A394976 from sympy import binomial, bernoulli, factorial
%o A394976 def a(n):
%o A394976     if n%2 == 1: # 4n - 1
%o A394976         n = n//2 + 1
%o A394976         s = sum(
%o A394976             (-1)**j * binomial(4*n, 2*j) * bernoulli(4*n-2*j) * bernoulli(2*j)
%o A394976             for j in range(2*n + 1)
%o A394976         )
%o A394976         frac = -2**(4*n-2) * s / factorial(4*n)
%o A394976     else: # 4n + 1
%o A394976         n //= 2
%o A394976         s1 = sum(
%o A394976             (-4)**(n+j) * binomial(4*n+2, 4*j) * bernoulli(4*n-4*j+2) * bernoulli(4*j)
%o A394976             for j in range(n+1)
%o A394976         )
%o A394976         s2 = sum(
%o A394976             (-4)**j * binomial(4*n+2, 2*j) * bernoulli(4*n-2*j+2) * bernoulli(2*j)
%o A394976             for j in range(2*n+2)
%o A394976         )
%o A394976         frac = 2**(4*n+1) * (s1+s2/2) / factorial(4*n+2) / (1 + (-4)**n - 2**(4*n+1))
%o A394976     return frac.numerator
%Y A394976 Cf. A057866, A175316, A394977 (denominators).
%K A394976 nonn,frac
%O A394976 1,1
%A A394976 _Jwalin Bhatt_, Apr 08 2026
