%I A394562 #13 Mar 29 2026 22:02:32
%S A394562 2,3,4,0,1,2,5,3,4,0,1,2,6,3,2,4,5,0,1,2,3,4,7,0,1,2,3,6,5,2,4,0,1,3,
%T A394562 2,4,5,0,1,2,3,6,2,4,8,3,0,1,2,5,4,3,7,0,1,2,3,4,2,6,5,0,1,2,3,4,0,1,
%U A394562 2,3,5,4,2,6,0,1,3,2,4,7,5,0,1,2,3,4,2
%N A394562 A sequence constructed by greedily sampling the Hermite distribution, with both parameters as 1, to minimize ratio discrepancy.
%C A394562 The distribution is given by the PDF p(k) = (Sum_{i=0..floor(k/2)} 1/(i!*(k-2*i)!)) / e^2 = 2F0([-k/2, (1-k)/2], [], 4) / (e^2 * k!). It has p(0)=p(1)=1/e^2 which is less than p(2). From p(2) onwards it is strictly decreasing.
%C A394562 The arithmetic mean approaches Sum_{k>=1} k * p(k) = 3 in the limit.
%C A394562 From _Pontus von Brömssen_, Mar 25 2026: (Start)
%C A394562 This sequence is generated by the D'Hondt (or Jefferson) apportionment method for the Hermite(1,1) distribution (choosing the smallest element in case of ties).
%C A394562 Since p(0) = p(1), (0,1) always come in pairs.
%C A394562 (End)
%H A394562 Jwalin Bhatt, <a href="/A394562/b394562.txt">Table of n, a(n) for n = 1..10001</a>
%H A394562 Wikipedia, <a href="https://en.wikipedia.org/wiki/D&#39;Hondt_method">D'Hondt method</a>.
%H A394562 Wikipedia, <a href="https://en.wikipedia.org/wiki/Hermite_distribution">Hermite distribution</a>.
%e A394562 Let p(k) denote the probability of k and c(k) denote the count of occurrences of k so far.
%e A394562 We take the ratio of the actual occurrences c(k)+1 to the probability and pick the one with the lowest value. In case of ties pick the smallest k.
%e A394562 Since p(k) is monotonic decreasing from k=2 onwards, we only need to compute c(k) once we see c(k-1) but we also need to keep track of p(0) and p(1) from the start. Let f(k) = (c(k)+1)/(p(k)*(e^2)).
%e A394562 | n |  f(0)  |  f(1)  |  f(2)  |  f(3)  |  f(4)  |  f(5)  | choice |
%e A394562 |---|--------|--------|--------|--------|--------|--------|--------|
%e A394562 | 1 |    1   |    1   |   2/3  |    -   |    -   |    -   |   2    |
%e A394562 | 2 |    1   |    1   |   4/3  |   6/7  |    -   |    -   |   3    |
%e A394562 | 3 |    1   |    1   |   4/3  |  12/7  |  24/25 |    -   |   4    |
%e A394562 | 4 |    1   |    1   |   4/3  |  12/7  |  48/25 |  48/27 |   0    |
%e A394562 | 5 |    2   |    1   |   4/3  |  12/7  |  48/25 |  48/27 |   1    |
%t A394562 pdf[i_] := HypergeometricPFQ[{-i/2, (1-i)/2}, {}, 4]/((E^2)*i!)
%t A394562 samplePDF[numCoeffs_] := Module[
%t A394562   {coeffs = {}, counts = {0,0,0}, minTime, minIndex, time},
%t A394562 Do[
%t A394562     minTime = Infinity;
%t A394562     Do[
%t A394562       time = (counts[[i]] + 1)/pdf[i-1];
%t A394562       If[time < minTime, minIndex = i; minTime = time],
%t A394562       {i, 1, Length[counts]}
%t A394562     ];
%t A394562     If[minIndex == Length[counts], AppendTo[counts, 0]];
%t A394562     counts[[minIndex]] += 1;
%t A394562     AppendTo[coeffs, minIndex-1],
%t A394562     {numCoeffs}
%t A394562   ];
%t A394562   coeffs
%t A394562 ]
%t A394562 A394562 = samplePDF[120]
%o A394562 (Python)
%o A394562 from math import factorial
%o A394562 from fractions import Fraction
%o A394562 def hermite(k):
%o A394562     return sum(Fraction(1, (factorial(i)*factorial(k-2*i))) for i in range(1+k//2))
%o A394562 def sample_hermite_distribution(num_coeffs):
%o A394562   coeffs, counts = [], [0,0,0]
%o A394562   for _ in range(num_coeffs):
%o A394562     min_time = float('infinity')
%o A394562     for i, count in enumerate(counts):
%o A394562       time = (count+1) / hermite(i)
%o A394562       if time < min_time:
%o A394562         min_index, min_time = i, time
%o A394562     if min_index == len(counts)-1:
%o A394562       counts.append(0)
%o A394562     counts[min_index] += 1
%o A394562     coeffs.append(min_index)
%o A394562   return coeffs
%o A394562 A394562 = sample_hermite_distribution(120)
%Y A394562 Cf. A072334, A386016, A393100, A393161, A393663.
