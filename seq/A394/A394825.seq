%N A394825 Array read by ascending antidiagonals: A(n, k) = Sum_{j=0..k} binomial(k, j) * j^(n + j) * (1 - j)^(k - j).
%F A394825 row_ogf(n, y) = Sum_{j>=0} ((j^(n + j) * y^j) / (1 - y*(1 - j))^(j + 1).
%F A394825 col_egf(k, x) = Sum_{j>=0} binomial(k, j) * j^j * (1 - j)^(k - j) * exp(x*j).
%F A394825 The bivariate generating function is exponential in x and ordinary in y:
%F A394825 biv_gf(x, y) = Sum_{j>=0} (j^j * y^j * exp(x*j)) / (1 - y*(1 - j))^(j + 1).
