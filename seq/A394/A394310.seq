%U A394310 873360370035565,8750606225568966,87655681172037954,877883602836107139,8790682286910283101,88013238064412080119,881093550115629692808
%N A394310 a(n) is the number of n-digit numbers that are not powers of primes.
%F A394310 Limit_{n->oo} a(n)/a(n-1) = 10.
%F A394310 a(n) = A052268(n) - A304520(n) for n > 1.
%t A394310 a[n_]:=Module[{k=0},For[i=10^(n-1),i<=10^n-1,i++,If[Length[FactorInteger[i]]>1,k++]]; k]; Array[a,7]
%Y A394310 Cf. A024619, A052268, A304520.
%K A394310 nonn,base
%O A394310 1,2
