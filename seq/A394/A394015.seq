%N A394015 a(n) = (2*n)! * [x^(2*n)] cos(x) * cos(2*x) / cos(4*x).
%F A394015 a(n) = (-1)^n * (9^n + 1)/2 - Sum_{k=0..n-1} (-16)^(n-k) * binomial(2*n,2*k) * a(k).
%o A394015 (PARI) a_vector(n) = my(v=vector(n+1)); for(i=0, n, v[i+1]=(-1)^i*(9^i+1)/2-sum(j=0, i-1, (-16)^(i-j)*binomial(2*i, 2*j)*v[j+1])); v;
