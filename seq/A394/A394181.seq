%I A394181 #31 May 24 2026 15:26:55
%S A394181 2,3,4,5,3,7,4,3,5,6,7,3,4,6,5,3,8,5,7,5,8,3,5,3,10,6,9,8,5,3,4,6,5,4,
%T A394181 3,10,7,4,5,3,10,6,11,3,5,3,7,5,8,5,7,4,3,5,3,7,3,4,6,7,9,5,3,4,6,5,4,
%U A394181 3,7,3,11,14,8,3,5,6,7,5,4,6,5,3,8,5,7
%N A394181 Simultaneously grow three sequences S, T and A starting with S(1)=T(1)=a(1)=2. Search for the smallest integer m in S so that one of its multiples k*m is larger than T(n) and closer to T(n) than (k-1)*m. If this is true, a(n+1) = m and T(n+1) = k*m. Otherwise, add the smallest positive integer, m, to S that holds this property.
%C A394181 a(n) has an infinite number of different integers because the maximum k*m can never exceed the lowest common multiple of the elements in S.
%H A394181 Sean A. Irvine and David Consiglio, Jr., <a href="/A394181/b394181.txt">Table of n, a(n) for n = 1..10000</a>
%e A394181 a(25) = 10.
%e A394181 T(25) = 40.
%e A394181 At this point, S = {2,3,4,5,6,7,8,10}.
%e A394181 What is a(26)?
%e A394181 Try S(1)=2. No, 20*2 = 40. We need a number that increases T(26).
%e A394181 Try S(2)=3. No, 14*3 = 42 which is not as close to 40 as 13*3 = 39. T(26) needs to increase so this also fails.
%e A394181 S(3)=4, S(4)=5 both fail.
%e A394181 S(5)=6 succeeds because 7*6=42 which is closer to T(25)=40 than 6*6=36. Therefore a(26)=6 and T(26)=42.
%e A394181 What is a(27)? All elements of S fail so we need to add the smallest positive integer that works. It's 9. T(27)=45. a(27)=9. Now S = {2,3,4,5,6,7,8,9,10}.
%o A394181 (Python)
%o A394181 S = [2]
%o A394181 T = [2]
%o A394181 a = [2]
%o A394181 def A394181(n):
%o A394181     while len(a) < n:
%o A394181         add_flag = False
%o A394181         for N in sorted(list(set(S))):
%o A394181             for k in range(1,len(a)+1):
%o A394181                 if k*N > T[-1] and abs(T[-1] - k*N) < abs(T[-1]-(k-1)*N):
%o A394181                     S.append(N)
%o A394181                     a.append(N)
%o A394181                     T.append(k*N)
%o A394181                     add_flag = True
%o A394181                 if add_flag:
%o A394181                     break
%o A394181             if add_flag:
%o A394181                 break
%o A394181         if add_flag == False:
%o A394181             for N in [q for q in range(1,100) if q not in S]:
%o A394181                 for k in range(1,len(a)+1):
%o A394181                     if k*N > T[-1] and abs(T[-1] - k*N) < abs(T[-1]-(k-1)*N):
%o A394181                         add_flag = True
%o A394181                         S.append(N)
%o A394181                         a.append(N)
%o A394181                         T.append(k*N)
%o A394181                         break
%o A394181                 if add_flag:
%o A394181                     break
%o A394181     return(a)
%o A394181 # _David Consiglio, Jr._, May 22 2026
