%S A394117 0,1,2,7,30,144,744,4049,22906,133537,797404,4855941,30057724,
%T A394117 188635684,1197865288,7684428374,49735550690,324418503536,
%U A394117 2130770610246,14080910729781,93563778237028,624781101890740,4190678175148708,28222633284905036,190770359607743460
%N A394117 G.f. A(x) satisfies A(x)^5+(2x-2)*A(x)^4+A(x)^3+(4x^2-2x)*A(x)^2+x^3=0.
%C A394117 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with blue root where red vertices can only be followed by green vertices, blue vertices can be followed by red or blue vertices, and green vertices can be followed by blue or green vertices.
%H A394117 Nathan Fox, <a href="/A394117/b394117.txt">Table of n, a(n) for n = 0..300</a>
%H A394117 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394117 (Python)
%o A394117 def A394117(n):
%o A394117     A = [[0, 0, 1], [1, 1, 0], [0, 1, 1]]
%o A394117     if n == 0:
%o A394117         return 0
%o A394117     m = len(A)
%o A394117     output = [[1] for i in range(m)]
%o A394117     for l in range(2, n + 1):
%o A394117         for i in range(m):
%o A394117             term = 0
%o A394117             for k in range(1, l):
%o A394117                 for j in range(m):
%o A394117                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394117             output[i].append(term)
%o A394117     return output[1][n - 1]
%Y A394117 Cf. A394116, A394118.
%K A394117 nonn,new
%O A394117 0,3
%A A394117 _Nathan Fox_, Mar 11 2026
