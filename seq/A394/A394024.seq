%T A394024 110,125,138,155,175,191,212,236,260,288,320,350,387,425,468,512,567,
%U A394024 617,679,745,814,887,974,1058,1160,1263,1376,1494,1632,1769,1922,2086,2262
%N A394024 Number of partitions p of n with multiplicity of each part at most 3, satisfying max(p) <= 3 * min(p).
%H A394024 Vincenzo Librandi, <a href="/A394024/b394024.txt">Table of n, a(n) for n = 1..1000</a>
%F A394024 G.f.: Sum_{j>=1} q^j*(1-q^(3*j))/(1-q^j) * Product_{k=j+1..3*j} (1-q^(4*k))/(1-q^k).
%e A394024 a(8) = 10 counts these partitions: 8, 62, 53, 44, 422, 332, 3311, 3221, 32111, 22211.
%t A394024 Nmax=60; a=Rest@CoefficientList[Series[Sum[q^j*(1-q^(3*j))/(1-q^j)*Product[(1-q^(4*k))/(1-q^k),{k,j+1,3*j}],{j,1,Nmax}],{q,0,Nmax}],q] (* _Vincenzo Librandi_, Mar 10 2026 *)
%o A394024 (Magma) N := 60; R<q> := PowerSeriesRing(Integers(), N+1); S := &+[ q^j*(1-q^(3*j))/(1-q^j) * &*[(1-q^(4*k))/(1-q^k) : k in [j+1..3*j]] : j in [1..N] ]; [Coefficient(S,n) : n in [1..N]]; // _Vincenzo Librandi_, Mar 10 2026
