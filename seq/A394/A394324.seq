%S A394324 1,1,1,2,1,3,2,4,4,5,4,8,6,8,10,11,10,15,13,18,20,21,22,31,29,33,36,
%T A394324 44,42,54,52,65,65,74,78,96,91,105,109,132,127,152,151,177,184,205,
%U A394324 208,247,246,284,288,328,331,381,392,440,451,501,515,594,596,661,691,763,789,877,898,990
%N A394324 Number of partitions p of n such that (minimal multiplicity of the parts of p) >= (maximal part of p).
%H A394324 Vincenzo Librandi, <a href="/A394324/b394324.txt">Table of n, a(n) for n = 1..1000</a>
%F A394324 G.f.: Sum_{j>=1} q^(j^2)/(1-q^j) * Product_{k=1..j-1} (1+q^(j*k)/(1-q^k)).
%e A394324 a(6) counts these 3 partitions: 222, 2211, 111111.
%t A394324 Table[Sum[SeriesCoefficient[q^(j^2)/(1-q^j)*Product[1+q^(j*k)/(1-q^k),{k,1,j-1}],{q,0,n}],{j,1,Nmax}],{n,1,Nmax}] (* _Vincenzo Librandi_, Mar 18 2026 *) after PARI.
%o A394324 (PARI) my(N=70, q='q+O('q^N)); Vec(sum(j=1, N, q^j^2/(1-q^j)*prod(k=1, j-1, 1+q^(j*k)/(1-q^k))))
%o A394324 (Magma) N:=70; R<q>:=PowerSeriesRing(Integers(), N);S:= R!0;for j in [1..N] do term:=q^(j^2)/(1-q^j); for k in [1..j-1] do term *:=(1+q^(j*k)/(1-q^k)); end for; S+:=term; end for;Coefficients(S); // _Vincenzo Librandi_, Mar 18 2026
%Y A394324 Cf. A394325.
