%I A394402 #10 Mar 26 2026 15:25:36
%S A394402 1,11361222,54656650,31649929962
%N A394402 Numbers k such that sigma(k) = psi(k) + pi(k) + Omega(k)^7.
%e A394402 11361222 is a term since sigma(11361222) = 25897872 = 23051952 + 748768 + 8^7 = psi(11361222) + pi(11361222) + Omega(11361222)^7.
%o A394402 (PARI) dedpsi(f) = prod(k = 1, #f~, (f[k, 1]+1) * f[k, 1]^(f[k, 2]-1));
%o A394402 list(lim) = {my(q = 2, m = 0, f); print1(1, ", "); forprime(p = 3, lim, m++; for(k = q, p-1, f = factor(k); if(sigma(f) == dedpsi(f) + m + bigomega(f)^7, print1(k, ", "))); q = p); } \\ _Amiram Eldar_, Mar 19 2026
