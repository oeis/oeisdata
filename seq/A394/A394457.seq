%S A394457 20705,10260809,49412285,36088029809,12776643626669,4814276586744869,
%T A394457 467990340706021769,23829581848886203949,2766180610579269910949,
%U A394457 4293096093583957935236429,710227947280872221381807549
%N A394457 Least Lucas-Carmichael number (A006972) that is the product of exactly n primes congruent to 1 modulo 4.
%o A394457 (PARI)
%o A394457 lucas_carmichael_1mod4(A, B, k) = A=max(A, vecprod(primes(k+1))\2); local f; (f = (m, l, lo, k) -> my(list=List()); my(hi=sqrtnint(B\m, k)); if(lo > hi, return(list)); if(k==1, lo=max(lo, ceil(A/m)); my(t=lift(-1/Mod(m, l))); while(t < lo, t += l); forstep(p=t, hi, l, if(p%4 == 1 && isprime(p) && (m*p+1) % (p+1) == 0, listput(list, m*p))), forprime(p=lo, hi, if(p%4 == 1 && gcd(m, p+1) == 1, list=concat(list, f(m*p, lcm(l, p+1), p+1, k-1))))); list); vecsort(Vec(f(1, 1, 3, k)));
%o A394457 a(n) = if(n < 3, return()); my(x=1, y=2*x); while(1, my(v=lucas_carmichael_1mod4(x, y, n)); if(#v >= 1, return(v[1])); x=y+1; y=2*x);
%Y A394457 Analogous to A394179.
