%N A394523 E.g.f. A(x) satisfies A(x) = 1/(1 - 4*x*A(x)^3)^(1/4).
%H A394523 Vincenzo Librandi, <a href="/A394523/b394523.txt">Table of n, a(n) for n = 0..300</a>
%F A394523 a(n) = 4^n * n! * binomial((7*n+1)/4,n)/(7*n+1).
%t A394523 a[n_]:=If[n==0,1,Product[(7*n+1-4*k),{k,0,n-1}]/(7*n+1)]; Table[a[n],{n,0,18}] (* _Vincenzo Librandi_, Mar 28 2026 *)
%o A394523 (PARI) a(n) = 4^n*n!*binomial((7*n+1)/4, n)/(7*n+1);
%o A394523 (Magma) [n eq 0 select 1 else (4^n*&*[((7*n+1)/4-k): k in [0..n-1] ])/(7*n+1): n in [0..23]]; // _Vincenzo Librandi_, Mar 28 2026
