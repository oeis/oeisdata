%I A394352 #17 Mar 25 2026 16:41:45
%S A394352 1,1,2,1,1,3,1,1,2,1,1,3,1,1,2,1,1,3,1,1,2,3,1,3,1,1,2,1,1,3,1,1,2,1,
%T A394352 1,3,1,1,2,1,1,3,1,3,2,1,1,3,1,1,2,1,1,3,1,1,2,1,1,3,1,1,2,1,1,3,1,1,
%U A394352 2,1,1,3,1,1,2,1,1,3,1,1,2,1,1,3,1,1,2,3,1,3,1,1,2,1,1,3,1,1,2
%N A394352 a(n) is the least positive k such that n and 10^n - k are coprime.
%C A394352 If n = p^k where p is a prime other than 3 and k >= 1, then a(n) = 1.
%H A394352 Robert Israel, <a href="/A394352/b394352.txt">Table of n, a(n) for n = 1..10000</a>
%F A394352 a(n) = 10^n - A108908(n).
%e A394352 a(6) = 3 because gcd(6, 10^6-1) = 3 and gcd(6, 10^6-2) = 2 but gcd(6, 10^6-3) = 1.
%p A394352 f:= proc(n) local t,k;
%p A394352   t:= 10^n;
%p A394352   for k from 1 do
%p A394352     if igcd(t-k,n) = 1 then return k fi
%p A394352   od
%p A394352 end proc:
%p A394352 map(f, [$1..100]);
%t A394352 a[n_]:=Module[{k=1},While[GCD[n,10^n-k]>1, k++]; k]; Array[a,99] (* _Stefano Spezia_, Mar 21 2026 *)
%o A394352 (PARI) a(n) = my(k=1); while (gcd(n, 10^n-k) !=1, k++); k; \\ _Michel Marcus_, Mar 21 2026
%Y A394352 Cf. A011557, A108908, A394357.
%K A394352 nonn,easy,new
%O A394352 1,3
%A A394352 _Robert Israel_, Mar 17 2026
