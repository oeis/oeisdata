%S A394417 2,6,30,10,14,42,66,110,130,78,102,34,38,114,138,506,462,210,70,35,15,
%T A394417 105,21,3,33,330,390,39,51,255,165,55,77,770,1190,1122,2046,930,870,
%U A394417 406,182,26,74,222,246,410,190,266,546,1794,483,399,57,95,570,1290,1806
%N A394417 The radical value of the product of adjacent terms of A394416.
%C A394417 In the first 10^6 terms the only prime values are 3, 5, 7 and 17 - it is plausibly no more exist, although this is unknown.
%H A394417 Scott R. Shannon, <a href="/A394417/b394417.txt">Table of n, a(n) for n = 1..10000</a>
%H A394417 Scott R. Shannon, <a href="/A394417/a394417.png">Image of the first 100000 terms</a>.
%F A394417 a(n) = A007947(A394416(n)*A394416(n+1)).
%t A394417 Block[{c, j, k, q, r, rad, s, v, nn}, nn = 120; c[_] := False; q[_] := False; rad[x_] := rad[x] = Times @@ FactorInteger[x][[All, 1]]; Map[Set[c[#], True] &, s = {1, 2}]; MapApply[Set[q[rad[Times @@ {##}]], True] &, Partition[s, 2, 1]]; v = 1; j = Last[s]; While[Or[! SquareFreeQ[v], q[rad[v] ] ], v++]; {2}~Join~Reap[Do[k = j - 1; While[And[k > 1, Or[c[k], q[Set[r, rad[j*k]]], CoprimeQ[k, j] ] ], k--]; If[k == 1, k = j + 1; While[Or[c[k], q[Set[r, rad[j*k] ] ], CoprimeQ[k, j] ], k++] ]; Sow[r]; Set[{c[k], q[r], j}, {True, True, k}]; If[r == v, While[Or[! SquareFreeQ[v], q[rad[v] ] ], v++]], {n, Length[s] + 1, nn}] ][[-1, 1]] ] (* _Michael De Vlieger_, Mar 29 2026 *)
%Y A394417 Cf. A394416, A007947.
