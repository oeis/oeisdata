%T A394199 60,60,76,80,88,98,104,130,128,156,156,182,200,214,244,252,296,308,
%U A394199 348,370,404,446,484,528,568,618,664,736,782,860,912,998,1072,1158,1252
%N A394199 Expansion of Product_{k>=1} (1 + x^(k*(k+3)/2)) / (1 - x^(k*(k+3)/2)).
%C A394199 Convolution of A393987 and A319799.
%H A394199 Vaclav Kotesovec, <a href="/A394199/b394199.txt">Table of n, a(n) for n = 0..10000</a>
%F A394199 a(n) ~ Gamma(1 + b/d) * ((4-sqrt(2))*zeta(3/2))^(2/3 + b/(3*d)) * d^(1/6 + b/(3*d)) * exp(3*Pi^(1/3) * ((4-sqrt(2))*zeta(3/2))^(2/3) * (n/d)^(1/3) / 4) / (2^(7/2 + 3*b/(2*d)) * sqrt(3) * Pi^(7/6 - b/(6*d)) * n^(7/6 + b/(3*d))), where d = 1/2, b = 3/2.
%t A394199 nmax = 100; CoefficientList[Series[Product[(1 + x^(k*(k+3)/2)) / (1 - x^(k*(k+3)/2)), {k, 1, Floor[Sqrt[9 + 8*nmax]/2 + 1]}], {x, 0, nmax}], x]
%Y A394199 Cf. A103265, A280366, A393987, A319799.
%K A394199 nonn
%O A394199 0,3
