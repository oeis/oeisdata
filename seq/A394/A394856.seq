%S A394856 4,5,6,7,7,8,9,10,10,11,11,12,13,13,14,14,15,15,16,16,17,17,18,18,19,
%T A394856 19,20,20,21,21,21,22,22,23,23,24,24,24,25,25,26,26,27,27,27,28,28,29,
%U A394856 29,29,30,30,30,31,31,32,32,32,33,33,33,34,34,35,35,35,36
%N A394856 a(n) is the largest integer k such that the k-th Bell number does not exceed 2^(n+k).
%C A394856 The sequence is well-defined because the Bell numbers, A000110(k), grow super-exponentially while the binary budget 2^(n+k) grows only exponentially. The sequence is a surjective mapping onto the integers >= 4. The sequence is nondecreasing and exhibits bounded growth; specifically, the first differences a(n) - a(n-1) are in {0, 1} for n > 0. This sequence represents a representational capacity limit between the structural complexity of set partitions, A000110(k), and a binary addressing budget of 2^(n+k). Equivalently, a(n) is the maximum size k of a set such that its partitions can be mapped injectively into the power set of a domain of size n + k. It was empirically observed that the first 17 terms of this sequence (for n = 0..16) match the terms of A271490(n) for n = 4..20. While A271490 (related to distinct distances on an n X n grid) is computationally hard to evaluate, this sequence is easy to compute.
%F A394856 a(n) = max { k >= 0 : A000110(k) <= 2^(n+k) }.
%e A394856 a(0) = 4 because A000110(4) = 15 <= 2^4 = 16, but A000110(5) = 52 > 2^5 = 32.
%e A394856 a(1) = 5 because A000110(5) = 52 <= 2^(5+1) = 64, but A000110(6) = 203 > 2^(6+1) = 128.
%e A394856 a(3) = 7 because A000110(7) = 877 <= 2^(7+3) = 1024, but A000110(8) = 4140 > 2^(8+3) = 2048.
%e A394856 a(20) = 17 because A000110(17) = 82864869804 <= 2^(17+20) = 137438953472, but A000110(18) = 682076806159 > 2^(18+20) = 274877906944.
%e A394856 a(30) = 21 because A000110(21) = 474869816156751 <= 2^(21+30) = 2251799813685248, but A000110(22) = 4506715738447323 > 2^(22+30) = 4503599627370496.
%p A394856 max_n := 66;
%p A394856 k := 0;
%p A394856 for n from 0 to max_n do
%p A394856     while combinat[bell](k+1) <= 2^(n+1+k) do
%p A394856         k := k + 1;
%p A394856     end do;
%p A394856     printf("%d %d\n", n, k);
%p A394856 end do;
%t A394856 maxN = 66; k = 0; seq = Table[While[BellB[k + 1] <= 2^(n + k + 1), k++]; k, {n, 0, maxN}]; seq
%o A394856 (MATLAB)
%o A394856 % Set the number of terms to generate here:
%o A394856 max_n = 66;
%o A394856 k = sym(0);
%o A394856 for n = 0:max_n
%o A394856         while vpa(bellb(double(k+1)) ) <= vpa(2^(n+double(k)+1))
%o A394856  	  k = k + 1;
%o A394856 	end
%o A394856 	fprintf('%d %d\n', n, double(k));
%o A394856 end
%o A394856 function b = bellb(k_val)
%o A394856   % Ensure input is a standard numeric integer for array sizing
%o A394856   k_val = double(k_val);
%o A394856   if k_val == 0, b = sym(1); return; end
%o A394856   % Initialize symbolic array for Bell numbers
%o A394856   B = sym(zeros(1, k_val+1));
%o A394856   B(1) = 1;
%o A394856   for i = 1:k_val
%o A394856     s = sym(0);
%o A394856     for j = 0:i-1
%o A394856       s = s + nchoosek(i-1, j) * B(j+1);
%o A394856     end
%o A394856     B(i+1) = s;
%o A394856   end
%o A394856   b = B(k_val+1);
%o A394856 end
%o A394856 (Python)
%o A394856 from fractions import Fraction
%o A394856 from sympy import bell
%o A394856 from oeis_sequences.OEISsequences import bsearch
%o A394856 def A394856(n): return bsearch(lambda x:Fraction(bell(x),1<<x),1<<n) # _Chai Wah Wu_, Apr 12 2026
