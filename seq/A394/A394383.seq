%I A394383 #23 Mar 25 2026 21:48:28
%S A394383 1,2,3,4,5,9,7,16,27,25,11,81,13,49,125,256,17,729,19,625,343,121,23,
%T A394383 6561,3125,169,19683,2401,29,15625,31,65536,1331,289,16807,531441,37,
%U A394383 361,2197,390625,41,117649,43,14641,1953125,529,47,43046721,823543,9765625,4913
%N A394383 a(n) = f^(n/f), where f is the largest prime factor of n.
%C A394383 a(n) is also a left-associative power tower of the prime factors of n with the largest prime factor as the base.
%H A394383 Vincenzo Librandi, <a href="/A394383/b394383.txt">Table of n, a(n) for n = 1..1000</a>
%F A394383 a(n) = A006530(n)^(n/A006530(n)).
%F A394383 a(n) = A006530(n)^A052126(n).
%e A394383 The largest prime factor of 6 is 3; therefore a(6) = 3^(6/3) = 3^2 = 9.
%p A394383 a:= n-> (f-> f^(n/f))(max(1,ifactors(n)[2][.., 1])):
%p A394383 seq(a(n), n=1..51);  # _Alois P. Heinz_, Mar 22 2026
%t A394383 a[n_]:=(f=Max[First/@FactorInteger[n]])^(n/f); Array[a,50,2] (* _Stefano Spezia_, Mar 22 2026 *)
%o A394383 (PARI) a(n) = if (n==1, 1, my(g=vecmax(factor(n)[,1])); g^(n/g)); \\ _Michel Marcus_, Mar 20 2026
%o A394383 (Magma) a:= function(n) if n eq 1 then return 1; end if; f := Max([p[1]: p in Factorization(n)]); return f^(n div f); end function; [a(n) : n in [1..50]]; // _Vincenzo Librandi_, Mar 25 2026
%Y A394383 Cf. A006530, A052126, A275465, A394384.
%K A394383 nonn,easy
%O A394383 1,2
