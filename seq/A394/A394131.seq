%S A394131 0,1,3,15,89,581,4038,29336,220240,1695605,13315828,106257097,
%T A394131 859130719,7023217920,57951394929,482026134067,4037358333500,
%U A394131 34022819337989,288257913027022,2453989709607860,20981075483681907,180078361008867767,1551013396406423466
%N A394131 G.f. A(x) satisfies A(x)^5+A(x)^4+(5x-1)*A(x)^3+x*A(x)^2+(6x^2-x)*A(x)+x^3=0.
%C A394131 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with blue root where red vertices can be followed by red or blue vertices, blue vertices can be followed by vertices of any colors, and green vertices can only be followed by green vertices.
%H A394131 Nathan Fox, <a href="/A394131/b394131.txt">Table of n, a(n) for n = 0..300</a>
%H A394131 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394131 (Python)
%o A394131 def A394131(n):
%o A394131     A = [[1, 1, 0], [1, 1, 1], [0, 0, 1]]
%o A394131     if n == 0:
%o A394131         return 0
%o A394131     m = len(A)
%o A394131     output = [[1] for i in range(m)]
%o A394131     for l in range(2, n + 1):
%o A394131         for i in range(m):
%o A394131             term = 0
%o A394131             for k in range(1, l):
%o A394131                 for j in range(m):
%o A394131                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394131             output[i].append(term)
%o A394131     return output[1][n - 1]
%Y A394131 Cf. A394130.
%K A394131 nonn
%O A394131 0,3
%A A394131 _Nathan Fox_, Mar 11 2026
