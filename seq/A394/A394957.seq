%I A394957 #15 Jul 14 2026 17:26:07
%S A394957 6,7,12,13,14,19,21,22,23,32,33,34,45,46,47,52,60,61,62,77,78,79,96,
%T A394957 97,98,117,118,119,140,141,142,165,166,167,192,193,194,221,222,223,
%U A394957 252,253,254,285,286,287,320,321,322,357,358,359,396,397,398,437,438,439
%N A394957 Numbers k for which the pairwise sumset of the distinct binomial coefficients in row k of Pascal's triangle is not maximal.
%C A394957 All terms of A028347, A028872 and A008865 from their 3rd terms onward belong to this sequence.
%C A394957 The three infinite quadratic families arise from local collisions among binomial coefficients. The family d^2 - 4 comes from binomial(n, m - 2) + binomial(n, m + 2) = 2*binomial(n, m); the families d^2 - 3 and d^2 - 2 are obtained from this by Pascal propagation.
%C A394957 Besides 6, 7 and the three quadratic families, the only additional known terms are 19 and 52. The sporadic term 19 arises from binomial(19, 4) + binomial(19, 7) = 2*binomial(19, 6). The sporadic term 52 arises from binomial(52, 16) + binomial(52, 21) = binomial(52, 19) + binomial(52, 20).
%C A394957 Computations for all n <= 1000 found no further terms.
%C A394957 Every collision binomial(n, i) + binomial(n, j) = binomial(n, r) + binomial(n, s) with i < r <= s < j <= floor(n/2) corresponds to an equality of two disjoint block sums of Delta(k) = binomial(n, k + 1) - binomial(n, k). Experimentally, in all collisions found up to n <= 1000 one has r - i <= 3, s - r <= 1 and j - s <= 2.
%C A394957 For all n <= 1000, the defect binomial(floor(n/2) + 2, 2) - #{binomial(n, i) + binomial(n, j) : 0 <= i <= j <= floor(n/2)} is either 0 or 1, and is 1 exactly for the terms of this sequence up to this bound.
%H A394957 Felix Huber, <a href="/A394957/b394957.txt">Table of n, a(n) for n = 1..1000</a>
%H A394957 Felix Huber, <a href="/A394957/a394957.txt">Final note on the conjectural formula, proved cases, computational evidence, and remaining open exclusions</a>
%F A394957 Conjecture: The sequence is {6, 7, 19, 52} union {d^2 - 4, d^2 - 3, d^2 - 2 : d >= 4}, sorted increasingly.
%e A394957 32 is a term because binomial(32, 11) + binomial(32, 15) = 2*binomial(32, 13).
%e A394957 19 is a term because binomial(19, 4) + binomial(19, 7) = 2*binomial(19, 6).
%e A394957 52 is a term because binomial(52, 16) + binomial(52, 21) = binomial(52, 19) + binomial(52, 20).
%p A394957 A394957 := proc(n) option remember;
%p A394957     local k, l, t, i, j, s;
%p A394957     if n =1 then return 6 end if;
%p A394957     for k from A394957(n - 1) + 1 do
%p A394957         l := [seq(binomial(k, i), i = 0 .. floor(k/2))];
%p A394957         t := table():
%p A394957         for i from 1 to nops(l) do
%p A394957             for j from i to nops(l) do
%p A394957                 s := l[i] + l[j];
%p A394957                 if assigned(t[s]) then
%p A394957                     return k
%p A394957                 end if;
%p A394957                 t[s] := 1;
%p A394957             end do
%p A394957         end do
%p A394957     end do
%p A394957 end proc:
%p A394957 seq(A394957(n), n = 1 .. 58);
%Y A394957 Cf. A007318, A008865, A028347, A028872, A132311, A132312, A205536.
%K A394957 nonn,new
%O A394957 1,1
%A A394957 _Felix Huber_, Jul 08 2026
