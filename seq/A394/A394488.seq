%N A394488 Expansion of e.g.f. (1/x) * Series_Reversion( x/(1 + 5*x)^(1/5) ).
%H A394488 Vincenzo Librandi, <a href="/A394488/b394488.txt">Table of n, a(n) for n = 0..300</a>
%F A394488 E.g.f. A(x) satisfies A(x) = (1 + 5*x*A(x))^(1/5).
%F A394488 a(n) = 5^n * n! * binomial((n+1)/5,n)/(n+1).
%F A394488 a(5*n+4) = 0.
%t A394488 a[n_]:=5^n*n!*Binomial[( n+1)/5,n]/(n+1); Table[a[n],{n,0,20}] (* _Vincenzo Librandi_, Apr 01 2026 *)
%o A394488 (PARI) a(n) = 5^n*n!*binomial((n+1)/5, n)/(n+1);
%o A394488 (Magma) [1] cat [5^n*Factorial(n)*&*[((n+1)/5-k): k in [0..n-1]]/Factorial(n)/(n+1): n in [1..20] ]; // _Vincenzo Librandi_, Apr 01 2026
