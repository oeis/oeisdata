%S A394315 1,6092,65187,143253,176751,18785650,25548350,72396625,507733590,
%T A394315 686593375,1138786375,1325580025,2083558890,2335420375,2727499625
%N A394315 Numbers k such that sigma(k) = psi(k) + pi(k) + Omega(k)^6.
%e A394315 6092 is a term since sigma(6092) = 10668 = 9144 + 795 + 3^6 = psi(6092) + pi(6092) + Omega(6092)^6.
%o A394315 (PARI) dedpsi(f) = prod(k = 1, #f~, (f[k, 1]+1) * f[k, 1]^(f[k, 2]-1));
%o A394315 list(lim) = {my(q = 2, m = 0, f); print1(1, ", "); forprime(p = 3, lim, m++; for(k = q, p-1, f = factor(k); if(sigma(f) == dedpsi(f) + m + bigomega(f)^6, print1(k, ", "))); q = p); } \\ _Amiram Eldar_, Mar 15 2026
