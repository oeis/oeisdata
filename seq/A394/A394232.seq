%U A394232 240356788028928,2058330146595840,17657749982408704,151716952747917312,1305392197618561024,11245951765492015104,96994770149873909760
%N A394232 Expansion of 1 / sqrt(1 - 12*x + 28*x^2).
%C A394232 3rd binomial transform of A001850.
%C A394232 Diagonal of the rational function 1 / (1 - x^2 - 6*x*y - 2*y^2).
%F A394232 E.g.f.: exp(6*x) * BesselI(0,2*sqrt(2)*x).
%F A394232 Coefficient of x^n in (1 + 6*x + 2*x^2)^n.
%F A394232 n * a(n) = 6 * (2*n-1) * a(n-1) - 28 * (n-1) * a(n-2) with a(0) = 1, a(1) = 6.
%F A394232 a(n) = Sum_{k=0..floor(n/2)} binomial(n,2*k) * binomial(2*k,k) * 2^(n-k) * 3^(n-2*k).
%t A394232 nmax = 22; CoefficientList[Series[1/Sqrt[1 - 12 x + 28 x^2], {x, 0, nmax}], x]
%t A394232 nmax = 22; CoefficientList[Series[Exp[6 x] BesselI[0, 2 Sqrt[2] x], {x, 0, nmax}], x] Range[0, nmax]!
%t A394232 a[0] = 1; a[1] = 6; a[n_] := a[n] = (6 (2 n - 1) a[n - 1] - 28 (n - 1) a[n - 2])/n; Table[a[n], {n, 0, 22}]
%t A394232 Table[Sum[Binomial[n, 2 k] Binomial[2 k, k] 2^(n - k) 3^(n - 2 k), {k, 0, Floor[n/2]}], {n, 0, 22}]
%Y A394232 Cf. A001850, A006139, A059304, A080609, A084601, A098409, A098410, A154346, A394231, A394233.
%K A394232 nonn,new
%O A394232 0,2
