%I A394410 #41 Mar 29 2026 22:18:29
%S A394410 1,3,5,17,157,12469,77750305,3022555041534493,
%T A394410 4567919489552793374727018180037,
%U A394410 10432944231518126190458416657023933731548823182242327927044209
%N A394410 Quadratic recurrence sequence with a(1)=1, a(2)=3, and a(n) = (a(n-1)^2 + a(n-2)^2)/2 for n > 2.
%C A394410 All terms are odd.
%C A394410 For n >= 4, a(n) mod 8 follows the period-3 cycle (1, 5, 5).
%C A394410 All terms except a(2) = 3 are sums of two squares.
%C A394410 a(n) is prime for n = 2, 3, 4, 5, and 10. The first composite term is a(6) = 37*337.
%C A394410 _Thomas Ordowski_ conjectured in A056826 that if a(n) is prime, then (a(n)^a(n) + 1)/(a(n) + 1) is also prime.
%D A394410 G. Everest, A. van der Poorten, I. Shparlinski, and T. Ward, Recurrence Sequences, American Mathematical Society, 2003.
%F A394410 a(n) = (a(n-1)^2 + a(n-2)^2)/2 for n > 2, with a(1) = 1, a(2) = 3.
%F A394410 a(n) ~ 2*C^(2^n) where C = 1.1462901..., equivalently log(a(n)) ~ 0.1365302*2^n + log(2).
%e A394410 a(3) = (3^2 + 1^2)/2 = 10/2 = 5.
%e A394410 a(4) = (5^2 + 3^2)/2 = 34/2 = 17.
%e A394410 a(5) = (17^2 + 5^2)/2 = 314/2 = 157.
%e A394410 a(6) = (157^2 + 17^2)/2 = 24938/2 = 12469.
%p A394410 a:= proc(n) option remember;
%p A394410      `if`(n<3, 2*n-1, (a(n-1)^2+a(n-2)^2)/2)
%p A394410     end:
%p A394410 seq(a(n), n=1..10);  # _Alois P. Heinz_, Mar 20 2026
%o A394410 (Python)
%o A394410 from functools import lru_cache
%o A394410 @lru_cache(maxsize=None)
%o A394410 def a(n):
%o A394410     if n == 1:
%o A394410         return 1
%o A394410     if n == 2:
%o A394410         return 3
%o A394410     return (a(n-1)**2 + a(n-2)**2) // 2
%o A394410 print([a(n) for n in range(1, 10)])
%o A394410 (PARI) lista(nn) = {my(va=vector(nn+2)); va[1]=1;va[2]=3;for(n=1, nn, va[n+2]=(va[n]^2+va[n+1]^2)/2;);va;} \\ _Bruce Nye_, Mar 20 2026
%Y A394410 Cf. A000290 (squares), A001481 (sums of two squares), A002315 (NSW numbers), A001333 (Pell-related).
%Y A394410 Cf. A056826 (primes in this sequence satisfy a related primality conjecture, per T. Ordowski, 2013).
%K A394410 nonn,new
