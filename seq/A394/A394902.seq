%U A394902 2,3,4,4,0,6,4,4,8,3,7,4,3,3,2,6,8,0,1,0,0,4,5,2,7,4,8,2,9,7,5,7,1,0,2,3,1,6,3
%N A394902 Decimal expansion of the generalized continued fraction 1 + sqrt(1)/(2 + sqrt(2)/(3 + sqrt(3)/(4 + sqrt(4)/(5 + ...)))).
%C A394902 This constant is the canonical member of a family of generalized continued fractions with sqrt(k) numerators and k+1 denominators, starting from k=1. It was suggested in the discussion of A394404 as the most natural form.
%F A394902 Equals 1 + sqrt(1)/(2 + sqrt(2)/(3 + sqrt(3)/(4 + sqrt(4)/(5 + ...)))).
%e A394902 1.4138332202346037...
%o A394902 (Java)
%o A394902 import java.math.BigDecimal;
%o A394902 import java.math.MathContext;
%o A394902 import java.math.RoundingMode;
%o A394902 public class Main {
%o A394902     public static BigDecimal sqrt(BigDecimal x, MathContext mc) {
%o A394902         BigDecimal guess = new BigDecimal(Math.sqrt(x.doubleValue()), mc);
%o A394902         BigDecimal two = BigDecimal.valueOf(2);
%o A394902         for (int i = 0; i < 30; i++) {
%o A394902             guess = guess.add(x.divide(guess, mc)).divide(two, mc);
%o A394902         }
%o A394902         return guess;
%o A394902     }
%o A394902     public static BigDecimal a(int n, MathContext mc) {
%o A394902         BigDecimal result = BigDecimal.ZERO;
%o A394902         for (int i = n; i >= 1; i--) {
%o A394902             result = sqrt(BigDecimal.valueOf(i), mc)
%o A394902                     .divide(BigDecimal.valueOf(i + 1).add(result), mc);
%o A394902         }
%o A394902         return BigDecimal.ONE.add(result);
%o A394902     }
%o A394902     public static void main(String[] args) {
%o A394902         MathContext mc = new MathContext(120, RoundingMode.HALF_UP);
%o A394902         BigDecimal C = a(10000, mc);
%o A394902         String dec = C.setScale(85, RoundingMode.HALF_UP)
%o A394902                       .toString().split("\\.")[1];
%o A394902         System.out.println(String.join(", ", dec.substring(0, 80).split("")));
%o A394902     }
%o A394902 }
%Y A394902 Cf. A394404.
%K A394902 nonn,cons,new
%O A394902 1,2
