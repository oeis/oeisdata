%N A394830 Number of divisors d of n that do not divide n/d - 1.
%F A394830 a(n) = A000005(n) - A163671(n).
%p A394830 f:= n -> nops(select(d -> n/d - 1 mod d <> 0, NumberTheory:-Divisors(n))):
%p A394830 map(f, [$1..100]); # _Robert Israel_, Apr 06 2026
%t A394830 a[n_] := DivisorSum[n, 1 &, !Divisible[n/# - 1, #] &]; Array[a, 100] (* _Amiram Eldar_, Apr 04 2026 *)
%o A394830 (Magma) [#[d: d in Divisors(n) | not ((n div d) - 1) mod d eq 0]: n in [1..100]];
%o A394830 (PARI) a(n) = sumdiv(n, d, ((n/d - 1) % d) != 0); \\ _Michel Marcus_, Apr 04 2026
