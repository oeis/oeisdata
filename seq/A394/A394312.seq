%S A394312 1,2372,7564,10136,39969,40023,55917,61389,69723,13124150,20751050,
%T A394312 49385450
%N A394312 Numbers k such that sigma(k) = psi(k) + pi(k) + Omega(k)^5.
%e A394312 2372 is a term since sigma(2372) = 4158 = 3564 + 351 + 3^5 = psi(2372) + pi(2372) + Omega(2372)^5.
%o A394312 (PARI) dedpsi(f) = prod(k = 1, #f~, (f[k, 1]+1) * f[k, 1]^(f[k, 2]-1));
%o A394312 list(lim) = {my(q = 2, m = 0, f); print1(1, ", "); forprime(p = 3, lim, m++; for(k = q, p-1, f = factor(k); if(sigma(f) == dedpsi(f) + m + bigomega(f)^5, print1(k, ", "))); q = p); } \\ _Amiram Eldar_, Mar 15 2026
