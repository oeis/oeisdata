%I A394510 #54 Jul 08 2026 19:25:23
%S A394510 0,72,132,684,924,2436,2976,5928,6888,11760,13260,20532,22692,32844,
%T A394510 35784,49296,53136,70488,75348,97020,103020,129492,136752,168504,
%U A394510 177144,214656,224796,268548,280308,330780,344280,401952,417312,482664,500004,573516,592956,675108,696768,788040
%N A394510 a(2*k) = 2*k*(5*k+1)*(10*k+1), a(2*k+1) = 2*(k+1)*(5*k+4)*(10*k+9), with k >= 0.
%C A394510 Solutions Y to the Diophantine equation 10*X^3 + X^2 = Y^2.
%C A394510 Corresponding values of X are in A132356.
%C A394510 When X = 2*h*(5*h+1) with h = 0, -1, 1, -2, 2, -3, 3, -4, 4, ..., then, Y = 2*h*(5*h+1)*|10*h+1|, so Y / X = |10*h+1| and belongs to A090771 for Y > X > 0.
%H A394510 <a href="/index/Rec#order_07">Index entries for linear recurrences with constant coefficients</a>, signature (1,3,-3,-3,3,1,-1).
%F A394510 a(n) = A132356(n) * sqrt(10*A132356(n)+1).
%F A394510 a(n) = A132356(n) * A090771(n+1).
%F A394510 a(n) = ((2*n+1-(-1)^n)*(10*n+5-(-1)^n)*(10*n+5-3*(-1)^n)) / 16.
%F A394510 G.f.: 12*x*(6 + 5*x + 28*x^2 + 5*x^3 + 6*x^4)/((1 - x)^4*(1 + x)^3). - _Stefano Spezia_, Jun 30 2026
%e A394510 With a(1) = 72, we get 10*8^3 + 8^2 = 72^2.
%e A394510 With a(2) = 132, we get 10*12^3 + 12^2 = 132^2.
%e A394510 With a(3) = 684, we get 10*36^3 + 36^2 = 684^2.
%o A394510 (Python)
%o A394510 def A394510(n): return (n+1)*(5*(n>>1)+4)*(5*n+4) if n&1 else n*(5*(n>>1)+1)*(5*n+1) # _Chai Wah Wu_, Jun 30 2026
%Y A394510 Cf. A090771, A132356.
%K A394510 nonn,easy,new
%O A394510 0,2
%A A394510 _Bernard Schott_, Jun 30 2026
