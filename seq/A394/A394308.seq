%N A394308 a(n) is the number of n-digit numbers that are primes or squares of primes.
%F A394308 a(n) = pi(10^n) - pi(10^(n-1)) + pi(10^(n/2)) - pi(10^((n-1)/2)).
%F A394308 a(n) = A006879(n) + A379566(n).
%F A394308 Limit_{n->oo} a(n)/a(n-1) = 10.
%t A394308 a[n_]:=PrimePi[10^n]-PrimePi[10^(n-1)]+PrimePi[10^(n/2)]-PrimePi[10^((n-1)/2)]; Array[a,22]
