%I A394423 #13 Mar 28 2026 18:08:29
%S A394423 3,3,7,6,33,541133,54271403,80107607
%N A394423 a(n) is the smallest index k such that the subsequence of prime gaps b(k), b(k+1),..., b(k+2n) is a palindrome of length 2n+1, where b(k) = A001223(k).
%C A394423 Conjecture: Consider a sequence of 5 consecutive prime numbers p(k), p(k+1), p(k+2), p(k+3), p(k+4) whose successive gaps form the even palindrome (d,6,6,d). This palindrome does not exist. If it did exist, for all k > 3, the gap d would necessarily be a multiple of 3.
%C A394423 All palindromes considered are odd-length, because the prime gaps alternate irregularly and do not allow perfect symmetry over an even-length span. Except (2,2) the only natural even-length palindrome is the pair (6,6).
%C A394423 This sequence illustrates the local symmetric structure of prime gaps and the frequent occurrence of the (6,6) pair in prime constellations.
%e A394423 Initial solutions:
%e A394423 n  | a(n)=k | [A001223(k), A001223(k+1),...,A001223(k+2n)]
%e A394423 ------------------------------------------------------------
%e A394423 1  |      3 | [2, 4, 2]
%e A394423 2  |      3 | [2, 4, 2, 4, 2]
%e A394423 3  |      7 | [2, 4, 6, 2, 6, 4, 2]
%e A394423 4  |      6 | [4, 2, 4, 6, 2, 6, 4, 2, 4]
%e A394423 5  |     33 | [2, 10, 2, 6, 6, 4, 6, 6, 2, 10, 2]
%e A394423 6  | 541133 | [4, 6, 12, 18, 2, 10, 20, 10, 2, 18, 12, 6, 4]
%p A394423 next_gap := proc(i)
%p A394423 ithprime(i+1) - ithprime(i);
%p A394423 end proc:
%p A394423 find_smallest_k_palindrome := proc(n, max_iter)
%p A394423     local A, i, k, j, sublist;
%p A394423     A := [];
%p A394423     for i from 1 to max_iter do
%p A394423         A := [op(A), next_gap(i)];
%p A394423         if nops(A) >= 2*n+1 then
%p A394423             for k from 1 to nops(A)-2*n do
%p A394423                 sublist := [seq(A[t], t=k..k+2*n)];
%p A394423                 if sublist = ListTools:-Reverse(sublist) then
%p A394423                     return [k, sublist];
%p A394423                 end if;
%p A394423             end do;
%p A394423         end if;
%p A394423     end do;
%p A394423     return FAIL;
%p A394423 end proc:for n from 1 to 8 do
%p A394423     result := find_smallest_k_palindrome(n, 20000);
%p A394423     if result <> FAIL then
%p A394423         printf("n=%d, k=%d, %a\n", n, result[1], result[2]);
%p A394423     else
%p A394423         printf("n=%d, aucun\n", n);
%p A394423     end if;
%p A394423 end do:
%Y A394423 Cf. A000005, A001223, A393833, A394059.
%K A394423 nonn,hard,more,new
%O A394423 1,1
%A A394423 _Michel Lagneau_, Mar 20 2026
%E A394423 a(7)-a(8) from _Sean A. Irvine_, Mar 28 2026
