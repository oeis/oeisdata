%I A394885 #14 Apr 08 2026 15:21:42
%S A394885 1,2,9,375,4802,33614,117649,759999669,2143588810,10604499373
%N A394885 Terms of A099308 for which A051903 obtains value n for the first time.
%C A394885 I conjecture that the sequence is strictly growing, and is well defined for all n. At least terms a(9) .. a(14) exist, see example in A394887.
%C A394885 Note the many same terms with A394889.
%F A394885 For n >= 1, a(n) >= A151800(n)^n > A000312(n).
%o A394885 (PARI)
%o A394885 m=-1; k=0; for(n=1,2^35,if(!(n%(2^25)),print1("("n")")); e=A051903(n); if(e>m && A359550(n) && is_A099308(n), m=e; k++; write("b394885.txt", k, " ", n); print1(n,"(",m,"), ")));
%Y A394885 Cf. A000312, A003415, A051903, A099308, A151800, A394884.
%Y A394885 Cf. also A394887, A394889.
%K A394885 nonn,more
%O A394885 0,2
%A A394885 _Antti Karttunen_, Apr 06 2026
