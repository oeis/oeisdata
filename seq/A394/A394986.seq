%T A394986 660,672,720,756,780,792,840,864,924,936,960,1008,1020,1080,1140,1176,
%U A394986 1200,1260,1320,1344,1380,1440,1500,1512,1560,1584,1620,1680,1728,1740,1848,1860,1872,1920
%N A394986 Numbers k whose set of proper divisors can be split into 2 subsets s1 and s2 such that Sum_{x in s1} x^2 - Sum_{x in s2} x^2 = k.
%C A394986 As sigma_2(a(n)) - a(n)^2 - a(n) must be even sigma_2(a(n)) must be even (cf. A001157). - _David A. Corneth_, Apr 11 2026
%H A394986 David A. Corneth, <a href="/A394986/a394986.gp.txt">PARI program</a>
%e A394986 48 is a term, since its divisors are 1, 2, 3, 4, 6, 8, 12, 16, 24, and 1^2 - 2^2 - 3^2 - 4^2 - 6^2 - 8^2 - 12^2 - 16^2 + 24^2 = 48.
%t A394986 q[n_] := Module[{d = Join[Most[Divisors[n]]^2, {n}], sum, x}, sum = Plus @@ d; EvenQ[sum] && CoefficientList[Product[1 + x^i, {i, d}], x][[1 + sum/2]] > 0]; Select[Range[2000], q] (* _Amiram Eldar_, Apr 09 2026 *)
%o A394986 (PARI) isok(k) = my(d=select(x->(x!=k), divisors(k)), nb=#d); forsubset(nb, s, my(v1 = apply(x->d[x], Vec(s)), v2 = setminus(d, Vec(v1))); if (k == norml2(v1) - norml2(v2), return(1));); \\ _Michel Marcus_, Apr 12 2026
