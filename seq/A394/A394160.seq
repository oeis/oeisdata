%I A394160 #6 Mar 14 2026 14:59:49
%S A394160 0,1,2,8,43,268,1819,13045,97227,745604,5844754,46623033,377225094,
%T A394160 3088283361,25535731043,212944894883,1788853050907,15123990251860,
%U A394160 128590992795553,1098832100070298,9431853146939588,81285121705277069,703080812906355030
%N A394160 G.f. A(x) satisfies (x-1)*A(x)^5-x*A(x)^4+(-2x^2+2x)*A(x)^3-x^2*A(x)+x^3=0.
%C A394160 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with blue root where red vertices can be followed by vertices of any colors, blue vertices can be followed red or green vertices, and green vertices can only be followed by red vertices.
%H A394160 Nathan Fox, <a href="/A394160/b394160.txt">Table of n, a(n) for n = 0..300</a>
%H A394160 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394160 (Python)
%o A394160 def A394160(n):
%o A394160     A = [[1, 1, 1], [1, 0, 1], [1, 0, 0]]
%o A394160     if n == 0:
%o A394160         return 0
%o A394160     m = len(A)
%o A394160     output = [[1] for i in range(m)]
%o A394160     for l in range(2, n + 1):
%o A394160         for i in range(m):
%o A394160             term = 0
%o A394160             for k in range(1, l):
%o A394160                 for j in range(m):
%o A394160                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394160             output[i].append(term)
%o A394160     return output[1][n - 1]
%Y A394160 Cf. A394159, A394161.
%K A394160 nonn
%O A394160 0,3
%A A394160 _Nathan Fox_, Mar 12 2026
