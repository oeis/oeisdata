%S A394224 21600,36000,42336,48600,86400,95256,98784,104544,121500,144000,
%T A394224 146016,169344,196000,225000,235224,249696,274400,311904,324000,
%U A394224 328536,333396,337500,383328,395136,418176,437400,457056,484000,486000,540000,561816,584064,632736,676000
%N A394224 Achilles numbers with more than 2 distinct prime factors, whose prime power factor exponents are pairwise coprime.
%C A394224 For n > 1, A087315(n) = Product_{i=1..n} prime(i)^prime(n-i+1) is the smallest number in this sequence with n distinct prime factors.
%H A394224 Michael De Vlieger, <a href="/A394224/b394224.txt">Table of n, a(n) for n = 1..10000</a>
%H A394224 <a href="/index/Pow#powerful">Index entries for sequences related to powerful numbers</a>.
%F A394224 {a(n)} = A393708 \ A394000 = A393999 \ A393816.
%e A394224 Let s = A052486 and t = A393708.
%e A394224 Table of n, a(n) for select n:
%e A394224   n                               a(n)
%e A394224 --------------------------------------------------------------
%e A394224   1     s(100) =    t(23) =     21600 = 2^5 * 3^3 *  5^2
%e A394224   2     s(137) =    t(37) =     36000 = 2^5 * 3^2 *  5^3
%e A394224   3     s(151) =    t(44) =     42336 = 2^5 * 3^3 *  7^2
%e A394224   4     s(165) =    t(50) =     48600 = 2^3 * 3^5 *  5^2
%e A394224   5     s(233) =    t(80) =     86400 = 2^7 * 3^3 *  5^2
%e A394224   6     s(244) =    t(83) =     95256 = 2^3 * 3^5 *  7^2
%e A394224   7     s(251) =    t(89) =     98784 = 2^5 * 3^2 *  7^3
%e A394224   8     s(258) =    t(92) =    104544 = 2^5 * 3^3 * 11^2
%e A394224   9     s(284) =   t(105) =    121500 = 2^2 * 3^5 *  5^3
%e A394224  19     s(490) =   t(216) =    324000 = 2^5 * 3^4 *  5^3
%e A394224  62    s(1139) =   t(620) =   1488375 = 3^5 * 5^3 *  7^2
%e A394224 911   s(14728) = t(11008) = 190512000 = 2^7 * 3^5 *  5^3 * 7^2
%t A394224 nn = 2^20; fQ[x_] := And[Length[#] > 2, GCD @@ # == 1, CoprimeQ @@ #] &[FactorInteger[x][[All, -1]] ]; Union@ Flatten@ Table[If[fQ[#], #, Nothing] &[a^2*b^3], {b, Surd[nn, 3]}, {a, Sqrt[nn/b^3] } ]
%o A394224 (PARI) is(n)={if(n<21600, return(0)); my(f=factor(n)); if(omega(f)<3, return(0)); f=f[,2]~; if(vecmin(f)==1, return(0)); if(#Set(f) < #f, return(0)); for(i=1, #f, for(j = i+1, #f, if(gcd(f[i], f[j])>1, return(0)))); 1} \\ _David A. Corneth_, Mar 18 2026
