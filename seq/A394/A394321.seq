%N A394321 Number of partitions p of n such that (maximal multiplicity of the parts of p) <= 2 * (maximal part of p).
%F A394321 G.f.: Sum_{j>=1} q^j*(1-q^(2*j^2))/(1-q^j) * Product_{k=1..j-1} (1-q^((2*j+1)*k))/(1-q^k).
%e A394321 a(8) counts these 20 partitions: 8, 71, 62, 611, 53, 521, 5111, 44, 431, 422, 4211, 41111, 332, 3311, 3221, 32111, 311111, 2222, 22211, 221111.
%o A394321 (PARI) my(N=50, q='q+O('q^N)); Vec(sum(j=1, N, q^j*(1-q^(2*j^2))/(1-q^j)*prod(k=1, j-1, (1-q^((2*j+1)*k))/(1-q^k))))
