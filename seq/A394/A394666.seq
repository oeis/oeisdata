%N A394666 a(n) = n! mod (2*n - 1).
%C A394666 Conjecturally, a(n) = 0 iff n > 5 and 2*n - 1 is not a prime.
%F A394666 a(n) = n! mod (2*n - 1).
%e A394666 For n = 1: a(1) = 1! mod (2*1 - 1) = 1 mod 1 = 0.
%e A394666 For n = 2: a(2) = 2! mod (2*2 - 1) = 2 mod 3 = 2.
%e A394666 For n = 3: a(3) = 3! mod (2*3 - 1) = 6 mod 5 = 1.
%p A394666 seq(n! mod (2*n - 1), n=1..100);
%t A394666 Table[Mod[n!, 2*n - 1], {n, 1, 100}]
%o A394666 (Python)
%o A394666 from math import factorial
%o A394666 print([factorial(n) % (2*n - 1) for n in range(1, 101)])
%Y A394666 Cf. A000142, A005408.
%Y A394666 Fixed points are 2*A066160.
%Y A394666 Zero points are A104275 (except 5).
