%N A394491 Expansion of e.g.f. (1/x) * Series_Reversion( x/(1 + 5*x)^(4/5) ).
%H A394491 Vincenzo Librandi, <a href="/A394491/b394491.txt">Table of n, a(n) for n = 0..300</a>
%F A394491 E.g.f. A(x) satisfies A(x) = (1 + 5*x*A(x))^(4/5).
%F A394491 a(n) = 5^n * n! * binomial(4*(n+1)/5,n)/(n+1).
%F A394491 a(5*n+4) = 0 for n > 0.
%t A394491 a[n_]:=5^n*n!*Binomial[4*( n+1)/5,n]/(n+1); Table[a[n],{n,0,18}] (* _Vincenzo Librandi_, Mar 31 2026 *)
%o A394491 (PARI) a(n) = 5^n*n!*binomial(4*(n+1)/5, n)/(n+1);
%o A394491 (Magma) [1] cat [5^n*Factorial(n)*&*[(4*(n+1)/5-k): k in [0..n-1]] / Factorial(n)/(n+1): n in [1..20] ]; // _Vincenzo Librandi_, Mar 31 2026
