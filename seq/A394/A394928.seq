%T A394928 1204128304533,40715945397036,1487912239203663,58433798472764400,
%U A394928 2454200161942343265,109766407591209650622,5208561684751109322519,261344615907574522464606,13825121832773891624058645
%N A394928 Number of endofunctions f:{1,2,...,n}-> {1,2,...,n} whose smallest weakly connected component has exactly 2 nodes.
%C A394928 a(n) is always divisible by A001865(2) = 3.
%F A394928 E.g.f.: exp(-x)*(1-exp(-3*x^2/2)) / (1+LambertW(-x)).
%F A394928 Limit_{n->oo} a(n) / n^n = exp(-1/e)*(1-exp(-3/(2*e^2))).
%F A394928 a(n) = (-1)^n*(1-A362278(n)) + Sum_{k=1..n} binomial(n, k)*k^(k-1)*a(n-k) for n >= 1.
%F A394928 a(n) = 3*Sum_{k=1..floor(n/2)} (-1)^(n-k+1) * binomial(n, 2*k) * 3^(k-1)*A001147(k) * A069856(n-2*k) for n >= 2.
%p A394928 a := exp(-x)*(1-exp(-3*x^2/2)) / (1+LambertW(-x)):
%p A394928 ser := series(a, x = 0, 21): seq(n!*coeff(ser, x, n), n = 0 .. 20);
%o A394928 (Python)
%o A394928 from functools import lru_cache
%o A394928 from math import comb
%o A394928 @lru_cache(None)
%o A394928 def b(n):
%o A394928     return 1 if n < 2 else b(n-1) - 3*(n-1)*b(n-2)
%o A394928 @lru_cache(None)
%o A394928 def a(n):
%o A394928     return (-1)**n*(1-b(n)) + sum(comb(n,k)*k**(k-1)*a(n-k) for k in range(1, n+1))
%o A394928 print([a(n) for n in range(21)])
%Y A394928 Column k=2 of triangle A347999.
%Y A394928 Cf. A000169, A001147, A001865, A069856, A350134, A362278.
