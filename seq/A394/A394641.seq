%S A394641 0,1,2,2,3,2,3,3,4,3,3,3,4,4,4,3,5,3,4,4,4,4,4,3,5,5,5,4,5,4,4,4,6,4,
%T A394641 4,4,5,5,5,5,5,4,5,5,5,4,4,4,6,6,6,4,6,5,5,5,6,5,5,4,5,5,5,5,7,4,5,5,
%U A394641 5,4,5,4,6,6,6,6,6,5,6,6,6,5,5,5,6,6,6
%N A394641 a(n) is the number of digits in the canonical snowball representation of n.
%C A394641 See A397794 for the definition of the canonical snowball representation of a number.
%C A394641 We ignore leading zeros.
%C A394641 For any v >= 0, there are A071724(v) occurrences of v.
%H A394641 Rémy Sigrist, <a href="/A394641/b394641.txt">Table of n, a(n) for n = 0..8192</a>
%F A394641 a(2*n) = a(n) + 1 for any n > 0.
%F A394641 a(2^k) = k + 1 for any k >= 0.
%e A394641 The first terms are:
%e A394641   n   a(n)  snowball(n)
%e A394641   --  ----  -----------
%e A394641    0     0          (0)
%e A394641    1     1            1
%e A394641    2     2           10
%e A394641    3     2           11
%e A394641    4     3          100
%e A394641    5     2           21
%e A394641    6     3          110
%e A394641    7     3          101
%e A394641    8     4         1000
%e A394641    9     3          111
%e A394641   10     3          210
%e A394641   11     3          121
%e A394641   12     4         1100
%e A394641   13     4         1001
%e A394641   14     4         1010
%e A394641   15     3          211
%e A394641   16     5        10000
%o A394641 (PARI) a(n) = { my (b = 2, s = 0, d); while (n, d = n % b; n \= b; s++; b = 2+d;); return (s); }
%Y A394641 Cf. A071724, A084558, A397794.
%K A394641 nonn,base,new
%O A394641 0,3
%A A394641 _Rémy Sigrist_, Jul 17 2026
