%I A394589 #17 Mar 31 2026 18:20:16
%S A394589 -1,-1,0,-1,1,1,3,5,10,14,22,32,47,65,91,122,167,221,293,382,499,640,
%T A394589 824,1047,1331,1674,2106,2626,3274,4053,5012,6162,7569,9247,11286,
%U A394589 13713,16641,20117,24287,29221,35112,42063,50322,60041,71543,85038,100950,119574
%N A394589 Number of partitions of n with at least one even part minus the number of partitions of n into odd parts.
%H A394589 Alois P. Heinz, <a href="/A394589/b394589.txt">Table of n, a(n) for n = 0..10000</a>
%F A394589 a(n) = A047967(n) - A000009(n).
%F A394589 a(n) = A000041(n) - 2*A000009(n).
%F A394589 a(n) = Sum_{k=1..A000792(n)} (-1)^k * A339095(n,k).
%F A394589 a(n) mod 2 = A040051(n).
%e A394589 a(6) = 3 = 7 - 4 = #{21111, 2211, 222, 321, 411, 42, 6} - #{111111, 3111, 33, 51}.
%p A394589 b:= proc(n, i, t) option remember; `if`(n=0 or i=1, t,
%p A394589       b(n, i-1, t)+b(n-i, min(n-i, i), `if`(i::even, 1, t)))
%p A394589     end:
%p A394589 a:= n-> b(n$2, -1):
%p A394589 seq(a(n), n=0..47);
%p A394589 # Alternative:
%p A394589 b:= proc(n) option remember; `if`(n=0, 1, add(b(n-j)*add(
%p A394589      `if`(d::odd, d, 0), d=numtheory[divisors](j)), j=1..n)/n)
%p A394589     end:
%p A394589 a:= n-> combinat[numbpart](n)-2*b(n):
%p A394589 seq(a(n), n=0..47);
%Y A394589 Alternating row sums of A339095.
%Y A394589 Cf. A000009, A000041, A000792, A040051, A047967.
%K A394589 sign
%O A394589 0,7
%A A394589 _Alois P. Heinz_, Mar 25 2026
