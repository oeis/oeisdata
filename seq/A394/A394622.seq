%S A394622 2,3,6,7,5,6,1,3,8,2,6,0,6,0,8,0,0,1,4,9,9,8,3,8,0,4,1,3,3,8,4,0,2,2,
%T A394622 8,5,6,7,4,9,8,7,8,8,5,1,1,9,1,7,0,9,6,4,6,7,4,7,4,9,6,0,5,0,7,1,7,8,
%U A394622 7,4,7,8,3,2,4,1,6,6,1,3,6,0,7,3,9,8,8,6,0,6,5,3,8,3,6,2,5,8,1,7,7,1,8,3,5
%N A394622 Decimal expansion of Sum_{n>=2} mu(n)*n*(-zeta'(n)^2/zeta(n)^2+zeta''(n)/zeta(n))) (negated).
%H A394622 Artur Kawalec, <a href="https://arxiv.org/abs/2603.21535">On the series expansion of the prime zeta function about s = 1 and its coefficients</a>, arXiv:2603.21535 [math.NT], 2026, p. 3 eq. 15 and 17.
%F A394622 Equals Sum_{p primes} (2*p-1)*log(p)^2/(p*(p-1)^2).
%F A394622 Equals second derivative of the function P(x)-log(zeta(x)) at x = 1 (negated), where P(x) is the prime zeta function.
%e A394622 2.36756138260608001499838...
%t A394622 $MaxExtraPrecision = 1000; ratfun = (2*p-1)/(p*(p-1)^2); zetas = 0; ratab = Table[konfun = Together[Simplify[ratfun - c*(p^power/(p^power - 1)^2)]]; coefs = CoefficientList[Numerator[konfun], p]; sol = Solve[Last[coefs] == 0, c][[1]]; zetas = zetas + c*(-Zeta'[power]^2/Zeta[power]^2 + Zeta''[power]/Zeta[power]) /. sol; ratfun = konfun /. sol, {power, 2, 20}]; Do[Print[N[Sum[Log[p]^2*ratfun /. p -> Prime[k], {k, 1, m}] + zetas, 105]], {m, 2000, 20000, 2000}] (* _Vaclav Kotesovec_, Mar 30 2026 *)
%o A394622 (PARI) sum(n=2,10000,moebius(n)*n*(-zeta'(n)^2/zeta(n)^2+zeta''(n)/zeta(n)))
%Y A394622 Cf. A008683, A393690.
%K A394622 nonn,cons,new
%O A394622 1,1
%A A394622 _Artur Jasinski_, Mar 26 2026
