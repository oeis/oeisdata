%I A394882 #24 Apr 09 2026 17:25:55
%S A394882 1,3,14,42,147,441,1408,4224,13013,39039,118482,355446,1071799,
%T A394882 3215397,9668036,29004108,87099705,261299115,784246870,2352740610,
%U A394882 7059619931,21178859793,63542171784,190626515352,571901915677,1715705747031,5147206719578,15441620158734,46325218390143,138975655170429
%N A394882 a(n) = 3*a(n-1) + (n mod 2)*floor(2^(n+1)/3) for n > 1, a(1) = 1.
%C A394882 The odd-indexed terms a(2*k-1) correspond to a diagonal of the central factorial triangle A036969.
%H A394882 Paolo Xausa, <a href="/A394882/b394882.txt">Table of n, a(n) for n = 1..1000</a>
%H A394882 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (3,5,-15,-4,12).
%F A394882 a(n) = A394582(3, n).
%F A394882 a(n) = 3*a(n-1) + [n mod 2]*A000975(n), with a(1)=1.
%F A394882 a(2n-1) = 13*a(2n-3) - 36*a(2n-5) + 1, a(2n) = 3 * a(2n-1) with a(0) = 0, a(1) = 1, a(2) = 3, a(3) = 14, a(4) = 42.
%F A394882 a(n) = ( (1-(-1)^n)/2 + 3*(1+(-1)^n)/2 ) * (1/24 - 4^(k+1)/15 + 9^(k+1)/40), where k = floor((n+1)/2) (Formula for odd terms is adapted from Antonio Alberto Olivares's work on A002451).
%F A394882 a(2n-1) = A002451(n), a(2n) = 3 * A002451(n).
%F A394882 G.f.: x/((1 - x)*(1 + x)*(1 - 2*x)*(1 + 2*x)*(1 - 3*x)). - _Stefano Spezia_, Apr 05 2026
%p A394882 a := n -> ifelse(n = 1, 1, 3*a(n-1) + ifelse(irem(n, 2) = 0, 0, iquo(2^(n+1), 3))):
%p A394882 seq(a(k), k = 1..30);  # _Peter Luschny_, Apr 09 2026
%t A394882 LinearRecurrence[{3, 5, -15, -4, 12}, {1, 3, 14, 42, 147}, 30] (* _Paolo Xausa_, Apr 09 2026 *)
%o A394882 (Python)
%o A394882 def a_row3(max_n):
%o A394882     res = [1, 3, 14, 42]
%o A394882     if max_n <= 4: return res[:max_n]
%o A394882     for i in range(4, max_n):
%o A394882         if (i + 1) % 2 != 0:
%o A394882             val = 13 * res[i-2] - 36 * res[i-4] + 1
%o A394882             res.append(val)
%o A394882         else:
%o A394882             res.append(3 * res[i-1])
%o A394882     return res
%o A394882 print(a_row3(30))
%Y A394882 Cf. A394582 (parent array), A008957, A002451, A000975, A036969.
%K A394882 nonn,easy,new
%O A394882 1,2
