%T A394190 10560,8000,4936,3488,2296,1472,864,384,46080,138240,157440,119040,
%U A394190 77664,57216,42672,30048,21024,14016,8448,3840,645120,2257920,2634240,1989120,1345344,1016064,781728,603552,448416,331008,238656,162816,99840,46080
%N A394190 Irregular triangle read by rows: T(n,k) is the number of linear intervals of height k in the weak order on B_n (0 <= k <= 2*n-1).
%C A394190 An interval is linear of height k if it is isomorphic to the total order on k+1 elements.
%F A394190 Row sums give A394191.
%e A394190 Triangle begins:
%e A394190      8,    8,    6,    4;
%e A394190     48,   72,   68,   52,   20,    8;
%e A394190    384,  768,  800,  608,  340,  200,  112,   48;
%o A394190 (SageMath)
%o A394190 def T(n, k):
%o A394190     if k < 0 or k > 2*n-1:
%o A394190         return 0
%o A394190     nW = factorial(n) * 2^n
%o A394190     if k == 0:
%o A394190         return nW
%o A394190     if k == 1:
%o A394190         return nW * n/2
%o A394190     coef = lambda h, i: sum(binomial(h+i+1, h-j) * binomial(j+i, j)
%o A394190                             for j in range(h+1)) / 2^(h+1) / (h+i+1) / binomial(h+i, i)
%o A394190     s = 1/(k+1) if k%2 == 1 else 0
%o A394190     if k < n:
%o A394190         s += 2*(n-k)/(k+1)
%o A394190     if k == 3:
%o A394190         s += 1/4
%o A394190     s += 2 * sum(coef(k-2*i-1, i) for i in range(max(0, k-n), k//2))
%o A394190     return s * nW
%Y A394190 Cf. A000165, A391308 (type A), A394191, A394193 (type D).
%K A394190 nonn,tabf,new
%O A394190 2,1
