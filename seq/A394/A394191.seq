%U A394191 2526211145770905600,88540079644999987200,3277778214686614732800,127816199725548928204800,5236837210991185241702400,224924818493068660850688000
%N A394191 Total number of linear intervals in the weak order on the Coxeter group B_n.
%C A394191 An interval is linear of height k if it is isomorphic to the total order on k+1 elements.
%C A394191 See A394190 for the number of linear intervals of a given height.
%o A394191 (SageMath)
%o A394191 def a(n):
%o A394191     s = 1 + n/2
%o A394191     coef = lambda h, i: sum(binomial(h+i+1, h-j) * binomial(j+i, j)
%o A394191                             for j in range(h+1)) / 2^(h+1) / (h+i+1) / binomial(h+i, i)
%o A394191     for k in range(2, 2*n):
%o A394191         if k%2 == 1:
%o A394191             s += 1/(k+1)
%o A394191         if k < n:
%o A394191             s += 2*(n-k)/(k+1)
%o A394191         if k == 3:
%o A394191             s += 1/4
%o A394191         s += 2 * sum(coef(k-2*i-1, i) for i in range(max(0, k-n), k//2))
%o A394191     return s * factorial(n) * 2^n
%o A394191 print([a(n) for n in range(2, 20)])
%Y A394191 Cf. A000165, A344216, A394190.
%K A394191 nonn,new
%O A394191 2,1
