%I A394313 #55 May 13 2026 10:25:48
%S A394313 2,3,5,13,37,59,73,89,139,157,179,193,233,269,277,313,353,359,397,457,
%T A394313 479,509,557,577,613,619,673,677,719,733,757,809,839,877,953,977,997,
%U A394313 1019,1049,1069,1093,1109,1153,1213,1237,1319,1439,1453,1511,1579,1597,1619,1657,1699,1753,1873,1877
%N A394313 Primes that are the least prime factor of some Fibonacci number.
%C A394313 Primes that occur in A139044.
%C A394313 Primes p such that for all smaller primes q, A001177(p) is not divisible by A001177(q).
%H A394313 Robert Israel, <a href="/A394313/b394313.txt">Table of n, a(n) for n = 1..2500</a>
%e A394313 a(5) = 37 is a term because A000045(19) = 4181 = 37 * 113, whose least prime factor is 37.
%p A394313 G:= proc(m) local a,b,t,i,L;
%p A394313    a:= 0; b:= 1; L:= NULL;
%p A394313    for i from 2 do
%p A394313      t:= b; b:= a+b mod m; a:= t;
%p A394313      if b = 0 then return i fi;
%p A394313    od;
%p A394313 end proc:
%p A394313 p:= 1: M:= {}: R:= NULL: count:= 0:
%p A394313 while count < 100 do
%p A394313   p:= nextprime(p);
%p A394313   v:= G(p);
%p A394313   if ormap(m -> v mod m = 0, M) then next fi;
%p A394313   M:= M union {v};
%p A394313   R:= R,p;
%p A394313   count:= count+1;
%p A394313 od:
%p A394313 R;
%Y A394313 Cf. A000045, A001177, A139044, A395931, A394708.
%K A394313 nonn,new
%O A394313 1,1
%A A394313 _Robert Israel_, May 12 2026
