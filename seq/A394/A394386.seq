%o A394386 (PARI) C_xy(N) = { my(x='x+O('x^(N+2)), h = (-1 + x^2 + y*x^2 + (1 - x^2)*sqrt((1 - y*x^2/(1 - x^2))^2 - 4*y*x/(1 - x^2)))/(-2*y*x)); vector(N-1, n, Vecrev(polcoeff(h, n-1)))}
