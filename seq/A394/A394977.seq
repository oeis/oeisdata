%I A394977 #19 Apr 14 2026 19:03:49
%S A394977 180,294,56700,3704778,425675250,257432175,390769879500,
%T A394977 112024529867250,21438612514068750,1881063815762259253125,
%U A394977 1211517431782539131250,6948173623016040171631875,3952575621190533915703125,42344185423359347502790906715625
%N A394977 Denominators of the coefficient of Pi^(2n+1) in Plouffe's formula for zeta(2n+1).
%C A394977 Equals A057867((n+1)/2) for odd n.
%H A394977 Jwalin Bhatt, <a href="/A394977/b394977.txt">Table of n, a(n) for n = 1..225</a>
%H A394977 Simon Plouffe, <a href="http://www.plouffe.fr/simon/inspired2.pdf">Identities inspired by Ramanujan Notebooks (part 2)</a>, April 2006.
%H A394977 Linas Vepštas, <a href="https://doi.org/10.1007/s11139-011-9335-9">On Plouffe's Ramanujan identities</a>, The Ramanujan Journal, Vol. 27 (2012), pp. 387-408; <a href="https://arxiv.org/abs/math/0609775">arXiv preprint</a>, arXiv:math/0609775 [math.NT], 2006-2010.
%H A394977 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/RiemannZetaFunction.html">Riemann Zeta Function</a>.
%F A394977 Limit_{n->oo} (A394976(n)/a(n)) * Pi^(2n+1) = coth(Pi) (A175316).
%t A394977 a[n_] := Module[{n0 = n, s, s1, s2, frac},
%t A394977   If[OddQ[n], (* 4n - 1 case *)
%t A394977    n0 = Floor[n/2] + 1;
%t A394977    s = Sum[
%t A394977      (-1)^j * Binomial[4*n0, 2*j] * BernoulliB[4*n0 - 2*j] * BernoulliB[2*j],
%t A394977      {j, 0, 2*n0}
%t A394977    ];
%t A394977    frac = -2^(4*n0 - 2) * s / Factorial[4*n0];
%t A394977    ,
%t A394977    (* 4n + 1 case *)
%t A394977    n0 = Floor[n/2];
%t A394977    s1 = Sum[
%t A394977      (-4)^(n0 + j) * Binomial[4*n0 + 2, 4*j] * BernoulliB[4*n0 - 4*j + 2] * BernoulliB[4*j],
%t A394977      {j, 0, n0}
%t A394977    ];
%t A394977    s2 = Sum[
%t A394977      (-4)^j * Binomial[4*n0 + 2, 2*j] * BernoulliB[4*n0 - 2*j + 2] * BernoulliB[2*j],
%t A394977      {j, 0, 2*n0 + 1}
%t A394977    ];
%t A394977    frac = 2^(4*n0 + 1) * (s1 + s2/2) / (Factorial[4*n0 + 2] * (1 + (-4)^n0 - 2^(4*n0 + 1)));
%t A394977   ];
%t A394977   Denominator[frac]
%t A394977 ]
%o A394977 (Python)
%o A394977 from sympy import binomial, bernoulli, factorial
%o A394977 def a(n):
%o A394977     if n%2 == 1: # 4n - 1
%o A394977         n = n//2 + 1
%o A394977         s = sum(
%o A394977             (-1)**j * binomial(4*n, 2*j) * bernoulli(4*n-2*j) * bernoulli(2*j)
%o A394977             for j in range(2*n + 1)
%o A394977         )
%o A394977         frac = -2**(4*n-2) * s / factorial(4*n)
%o A394977     else: # 4n + 1
%o A394977         n //= 2
%o A394977         s1 = sum(
%o A394977             (-4)**(n+j) * binomial(4*n+2, 4*j) * bernoulli(4*n-4*j+2) * bernoulli(4*j)
%o A394977             for j in range(n+1)
%o A394977         )
%o A394977         s2 = sum(
%o A394977             (-4)**j * binomial(4*n+2, 2*j) * bernoulli(4*n-2*j+2) * bernoulli(2*j)
%o A394977             for j in range(2*n+2)
%o A394977         )
%o A394977         frac = 2**(4*n+1) * (s1+s2/2) / factorial(4*n+2) / (1 + (-4)**n - 2**(4*n+1))
%o A394977     return frac.denominator
%Y A394977 Cf. A057867, A175316, A394976 (numerators).
%K A394977 nonn,frac,new
%O A394977 1,1
%A A394977 _Jwalin Bhatt_, Apr 08 2026
