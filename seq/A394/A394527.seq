%I A394527 #10 Mar 29 2026 18:08:50
%S A394527 156,198,231,270,273,324,396,444,579,603,633,636,660,666,699,768,774,
%T A394527 807,849,960,963,966,1014,1065,1077,1113,1134,1137,1224,1236,1266,
%U A394527 1293,1398,1434,1449,1452,1464,1521,1614,1653,1656,1677,1698,1722,1887,1890,1938,1944,1965,1992,2052,2142,2148
%N A394527 Positive numbers k such that there is exactly one m such that m^2 - k^2 is an anagram of k^2.
%C A394527 All terms are divisible by 3.
%H A394527 Robert Israel, <a href="/A394527/b394527.txt">Table of n, a(n) for n = 1..1000</a>
%e A394527 a(3) = 231 is a term because 264^2 - 231^2 = 16335 is an anagram of 231^2 = 53361, and for no other m is m^2 - 231^2 an anagram of 53361.
%p A394527 filter:= proc(n) local L, t, m, k, r;
%p A394527   L:= sort(convert(n^2, base, 10));
%p A394527   m:= 10^ilog10(n^2);
%p A394527   t:= 0;
%p A394527   for k from ceil(sqrt(n^2+m)) to floor(sqrt(n^2+10*m)) by 3 do
%p A394527     if sort(convert(k^2-n^2, base, 10)) = L then
%p A394527       t:= t+1; if t = 2 then return false fi
%p A394527     fi
%p A394527   od;
%p A394527 t = 1
%p A394527 end proc:
%p A394527 select(filter, 3*[$1..1000]);
%Y A394527 Cf. A393978, A393998, A394001, A394502.
%K A394527 nonn,new
%O A394527 1,1
%A A394527 _Robert Israel_, Mar 23 2026
