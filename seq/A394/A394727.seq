%N A394727 Expansion of e.g.f. exp( sqrt(1-x^2) - 1 + x*(1 + arcsin(x)) ).
%F A394727 a(0) = 1; a(n) = a(n-1) + (n-1)! * Sum_{k=1..floor(n/2)} binomial(2*(k-1),k-1)/((2*k-1) * 4^(k-1)) * a(n-2*k)/(n-2*k)!.
%o A394727 (PARI) my(N=30, x='x+O('x^N)); Vec(serlaplace(exp(sqrt(1-x^2)-1+x*(1+asin(x)))))
