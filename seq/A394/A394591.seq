%S A394591 3,8,12,19,34,42,46,73,74,91,106,107,145,184,204,241,225,291,248,321,
%T A394591 372,333,394,418,516,523,554,655,672,708,659,721,796,818,913,1000,
%U A394591 1010,1101,1134,1124,1155,1108,1177,1292,1289,1407,1468,1533,1531,1717
%N A394591 Sum of the distinct prime divisors of C(3*n, n).
%C A394591 See A394454.
%H A394591 Vincenzo Librandi, <a href="/A394591/b394591.txt">Table of n, a(n) for n = 1..1000</a>
%F A394591 a(n) = sopf(binomial(3*n,n)) = A008472(A005809(n)).
%e A394591 a(4) = 19 because binomial(12,4) = 495 = 3^2*5*11 and 3+5+11 = 19.
%e A394591 a(5) = 34 because binomial(15,5) = 3003 = 3*7*11*13 and 3+7+11+13 = 34.
%t A394591 a[n_]:=Total[FactorInteger[Binomial[3*n, n]][[All, 1]]]; Table[a[n], {n, 1, 50}]
%o A394591 (Magma) a := func<n | &+PrimeDivisors(Binomial(3*n, n))>; N := 50; [a(n) : n in [1..N]];
%o A394591 (Python)
%o A394591 from math import comb
%o A394591 from sympy import primefactors
%o A394591 def A394591(n): return sum(primefactors(comb(3*n,n))) # _Chai Wah Wu_, Mar 30 2026
%Y A394591 Cf. A005809, A006480, A008472, A394454.
%K A394591 nonn,changed
%O A394591 1,1
