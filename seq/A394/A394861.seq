%T A394861 529453731088018880,714659851519226088256,1248242128234910707751424,
%U A394861 2765463683822737687868023296,7639261481963568351066404843520,25922272228391131111733145043636224
%N A394861 a(n) = Sum_{1<= i < j < k <= n} ( n!/(i*j*k) )^3.
%H A394861 Seiichi Manyama, <a href="/A394861/b394861.txt">Table of n, a(n) for n = 0..182</a>
%H A394861 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/HarmonicNumber.html">Harmonic Number</a>
%F A394861 a(n) = (n!)^3 * (H(n,3)^3 - 3*H(n,3)*H(n,6) + 2*H(n,9))/6 where H(n,r) = Sum_{k=1..n} 1/k^r.
%F A394861 a(n) = A249677(n,n-3) = [x^(n-3)] Product_{k=0..n} (1 + k^3*x).
%F A394861 a(n) = (n^3 + (n-1)^3 + (n-2)^3) * a(n-1) - ((n-1)^6 + (n-1)^3 * (n-2)^3 + (n-2)^6) * a(n-2) + (n-2)^9 * a(n-3) + ((n-3)!)^3 for n > 2.
%o A394861 (PARI) a(n) = polcoef(prod(k=0, n, 1+k^3*x), n-3);
%Y A394861 Cf. A249677, A394716.
%K A394861 nonn,new
