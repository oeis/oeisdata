%I A394619 #6 Apr 07 2026 01:01:08
%S A394619 1,1,1,2,1,2,2,1,1,3,1,1,2,2,3,1,1,3,1,1,3,3,2,3,1,4,1,1,2,2,3,3,1,1,
%T A394619 6,1,3,3,2,2,3,4,1,1,3,2,1,3,4,3,1,6,1,1,1,3,7,2,1,2,5,2,3,3,3,1,3,1,
%U A394619 4,3,4,2,3,2,3,1,9,1,1,1,2,2,7,3,1,6,1
%N A394619 Number of divisors d | k such that d is neither squarefree nor squareful (in A332785) and k = A126706(n).
%C A394619 Let s = A126706; a(n) is the cardinality of d in row s(n) of A027750 such that d is in A332785.
%C A394619 This sequence resembles A380691 for small terms, however, A380691(15) = 3 but a(n) = 2. See example.
%H A394619 Michael De Vlieger, <a href="/A394619/b394619.txt">Table of n, a(n) for n = 1..10000</a>
%F A394619 a(n) = A391719(A126706(n)) = A000005(k) - A005361(k) - 2^A001221(k) + 1 for k in A126706.
%F A394619 a(n) <= A376514(s(n)).
%e A394619 Table of n, a(n) for select n:
%e A394619   n a(n)   s(n)  List of d | s(n) such that d is in A332785
%e A394619 -----------------------------------------------------------
%e A394619   1   1     12   {12}
%e A394619   2   1     18   {18}
%e A394619   3   1     20   {20}
%e A394619   4   2     24   {12, 24}
%e A394619   5   1     28   {28}
%e A394619  10   3     48   {12, 24, 48}
%e A394619  26   4     96   {12, 24, 48, 96}
%e A394619  35   6    120   {12, 20, 24, 40, 60, 120}
%e A394619  57   7    180   {12, 18, 20, 45, 60, 90, 180}
%e A394619  61   5    192   {12, 24, 48, 96, 192}
%e A394619  77   9    240   {12, 20, 24, 40, 48, 60, 80, 120, 240}
%e A394619 571   8   1536   {12, 24, 48, 96, 192, 384, 768, 1536}
%e A394619 .
%e A394619 Let b = A380691. For 2 nonzero positive numbers j and m that are not coprime, let quality Q(j,m) be rad(j) | m but rad(m) does not divide j. In A380691, we want divisor pairs (d,k/d) such that only one of Q(d,k/d) and Q(k/d,d) is true.
%e A394619 a(15) = 3 since, among divisors of s(15) = 60, only {12, 24, 60} are neither squarefree nor powerful.
%e A394619 b(15) = 2 because, among divisors pairs (d,k/d) for k = s(15) = 60, we look for (d,k/d) as described above. Only (2,30) and (3,20) qualify; note that both Q(6,10) and Q(10,6) are true and so (6,10) is not included.
%t A394619 fQ[x_] := And[! SquareFreeQ[x], Min@ FactorInteger[x][[;; , -1]] == 1]; s = Select[Range[300], Nor[SquareFreeQ[#], PrimePowerQ[#]] &]; Table[DivisorSum[s[[n]], 1 &, fQ], {n, Length[s]}] (* or *)
%t A394619 f[x_] := Times @@ (# + 1) - Times @@ # - 2^Length[#] + 1 &[FactorInteger[x][[;; , -1]] ]; Array[f, 120]; s = Select[Range[300], Nor[SquareFreeQ[#], PrimePowerQ[#]] &]; Map[f, s]
%Y A394619 Cf. A000005, A001221, A005361, A027750, A126706, A332785, A376514, A380691, A391719.
%K A394619 nonn,easy,new
%O A394619 1,4
