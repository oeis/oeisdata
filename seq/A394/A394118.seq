%T A394118 436421205,2858217986,18849164100,125061063603,834215722121,
%U A394118 5591204973825,37634685232220,254298774171157,1724315099244201,11729240635903664,80017705755640388
%N A394118 G.f. A(x) satisfies A(x)^5-2*A(x)^4+(4x+1)*A(x)^3-5x*A(x)^2+(2x^2+x)*A(x)-x^2=0.
%C A394118 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with green root where red vertices can only be followed by green vertices, blue vertices can be followed by red or blue vertices, and green vertices can be followed by blue or green vertices.
%H A394118 Nathan Fox, <a href="/A394118/b394118.txt">Table of n, a(n) for n = 0..300</a>
%H A394118 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394118 (Python)
%o A394118 def A394118(n):
%o A394118     A = [[0, 0, 1], [1, 1, 0], [0, 1, 1]]
%o A394118     if n == 0:
%o A394118         return 0
%o A394118     m = len(A)
%o A394118     output = [[1] for i in range(m)]
%o A394118     for l in range(2, n + 1):
%o A394118         for i in range(m):
%o A394118             term = 0
%o A394118             for k in range(1, l):
%o A394118                 for j in range(m):
%o A394118                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394118             output[i].append(term)
%o A394118     return output[2][n - 1]
%Y A394118 Cf. A394116, A394117.
%K A394118 nonn
%O A394118 0,3
%A A394118 _Nathan Fox_, Mar 11 2026
