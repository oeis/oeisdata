%U A394818 298493219945303175,16392036941979061071,986729309825162666799,64784791274694379877703,4618773443181937984415895
%N A394818 Number of set partitions of [n] such that the elements of the k-th block can each be k different colors.
%C A394818 Here the blocks of a given set partition are ordered by their least element.
%H A394818 Alois P. Heinz, <a href="/A394818/b394818.txt">Table of n, a(n) for n = 0..319</a>
%F A394818 G.f.: A(y) = Sum_{i>=0} i!*y^i / Product_{j=1..i} (1 - y*j*(j+1)/2).
%e A394818 a(3) = 15: {{1,2,3}}, {{1,2},{3_a}}, {{1,2},{3_b}}, {{1,3},{2_a}}, {{1,3},{2_b}}, {{1},
%e A394818 {2_a,2_a}}, {{1},{2_a,2_b}}, {{1},{2_b,2_a}}, {{1},{2_b,2_b}}, {{1},{2_a},{3_a}}, {{1},{2_a},{3_b}}, {{1},{2_a},{3_c}}, {{1},{2_b},{3_a}}, {{1},{2_b},{3_b}}, {{1},{2_b},{3_c}}.
%p A394818 b:= proc(n, m) option remember; `if`(n=0, 1,
%p A394818       (b(n-1, m)*m/2+b(n-1, m+1))*(m+1))
%p A394818     end:
%p A394818 a:= n-> b(n, 0):
%p A394818 seq(a(n), n=0..19);  # _Alois P. Heinz_, May 02 2026
%o A394818 (PARI) A_y(N) = {my(y='y+O('y^(N+1)), A = sum(i=0,N,  i!*y^i / prod(j=1,i, 1 - y*j*(j+1)/2))); Vec(A)}
