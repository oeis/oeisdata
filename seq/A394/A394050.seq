%I A394050 #12 Apr 15 2026 22:22:27
%S A394050 1800,2700,3528,4500,5292,5400,7200,8712,9000,9800,10584,12168,12348,
%T A394050 13068,13500,14112,18252,20808,21600,24200,24300,24500,24696,25992,
%U A394050 26136,28800,31212,33075,33800,34300,34848,36000,36504,37044,38088,38988,39200,42336,47432
%N A394050 Achilles numbers with more than 2 distinct prime factors, whose exponents that are all pairwise indivisible.
%C A394050 Numbers k in A393708 (intersection of A000977 and A052486) that are also in A317101.
%C A394050 All Achilles numbers in A393816 (with just 2 distinct prime factors) have prime exponents that pairwise indivisible.
%C A394050 It is not always true that a(n) is either in A392927 or in A394224; a(4128739) = 31492800000000 = 2^12 * 3^9 * 5^8 is in neither.
%H A394050 Michael De Vlieger, <a href="/A394050/b394050.txt">Table of n, a(n) for n = 1..10000</a>
%e A394050 Let s = A052486, t = A392927, and q = A394224.
%e A394050 Table of n, a(n) for select n:
%e A394050         n                               a(n)
%e A394050   --------------------------------------------------------------------------
%e A394050         1        s(20) =    t(1) =     1800 =  2^3 * 3^2 * 5^2
%e A394050         2        s(25) =    t(2) =     2700 =  2^2 * 3^3 * 5^2
%e A394050         3        s(31) =    t(3) =     3528 =  2^3 * 3^2 * 7^2
%e A394050         4        s(36) =    t(4) =     4500 =  2^2 * 3^2 * 5^3
%e A394050         5        s(40) =    t(5) =     5292 =  2^2 * 3^3 * 7^2
%e A394050        19       s(100) =    q(1) =    21600 =  2^5 * 3^3 * 5^2
%e A394050        28       s(129) =   t(27) =    33075 =  3^3 * 5^2 * 7^2
%e A394050        32       s(137) =    q(2) =    36000 =  2^5 * 3^2 * 5^3
%e A394050        38       s(151) =    q(3) =    42336 =  2^5 * 3^3 * 7^2
%e A394050        65       s(237) =   t(60) =    88200 =  2^3 * 3^2 * 5^2 * 7^2
%e A394050      1592      s(3268) = t(1459) = 10672200 =  2^3 * 3^2 * 5^2 * 7^2 * 11^2
%e A394050   4128739   s(6505162) =     31492800000000 = 2^12 * 3^9 * 5^8
%e A394050 .
%e A394050 A393708(12) = 10800 = 2^4 * 3^3 * 5^2 is not in this sequence since among exponents, we have 2 | 4.
%t A394050 nn = 2^16; fQ[x_] := And[Length[#] > 2, GCD @@ # == 1, Count[Tuples[#, 2], _?(And[UnsameQ @@ #, Divisible @@ #] &)] == 0] &[FactorInteger[x][[All, -1]] ]; Union@ Flatten@ Table[If[fQ[#], #, Nothing] &[a^2*b^3], {b, Surd[nn, 3]}, {a, Sqrt[nn/b^3] } ]
%Y A394050 Cf. A000977, A052486, A317101, A392927, A393708, A393816, A394000, A394224.
%K A394050 nonn,easy
%O A394050 1,1
%A A394050 _Michael De Vlieger_, Apr 06 2026
