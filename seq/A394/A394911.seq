%I A394911 #11 Apr 12 2026 18:12:19
%S A394911 12,162,2187,59049,1594323,43046721,1162261467,31381059609,
%T A394911 847288609443,22876792454961,617673396283947,16677181699666569,
%U A394911 450283905890997363,12157665459056928801,328256967394537077627,8862938119652501095929,239299329230617529590083,6461081889226673298932241
%N A394911 a(n) = denominator( (2/3)^n*(1/8 - (1/24)*(1/9)^n) ).
%C A394911 a(n) is the denominator of the moment of inertia about its center (x = 1/2) of the set obtained at the n-th iteration of the Cantor set's construction.
%H A394911 Wikipedia, <a href="https://en.wikipedia.org/wiki/Cantor_set">Cantor set</a>.
%H A394911 <a href="/index/Rec#order_01">Index entries for linear recurrences with constant coefficients</a>, signature (27).
%F A394911 a(n) = 3^(3*n + 1) = A013732(n) for n > 1.
%F A394911 a(n) = 27*a(n-1) for n > 2.
%F A394911 G.f.: 3*(4 - 54*x - 729*x^2)/(1 - 27*x).
%F A394911 E.g.f.: 3*(exp(27*x) + 27*x + 3).
%e A394911 The sequence of the moments of inertia begins as:
%e A394911 1/12, 13/162, 121/2187, 2186/59049, 39364/1594323, 708584/43046721, ...
%t A394911 a[n_]:=Denominator[(2/3)^n(1/8-1/24(1/9)^n)]; Array[a,18,0]
%Y A394911 Cf. A013732, A394910 (numerators).
%K A394911 nonn,easy,frac,changed
%O A394911 0,1
