%N A394209 Number of primes p such that 3^(n-1) <= p < 3^n.
%C A394209 The n-th term is the number of primes in the half-open interval [3^(n-1), 3^n) where n > 0.
%F A394209 a(n) = |{p in primes : 3^(n-1) <= p < 3^n}|.
%F A394209 From _Alois P. Heinz_, May 08 2026: (Start)
%F A394209 a(n) = A000720(A024023(n)) - A000720(A024023(n-1)).
%F A394209 a(n) = A055729(n) - A055729(n-1) for n>=3. (End)
%e A394209 a(1) = |{2}| = 1.
%e A394209 a(2) = |{3, 5, 7}| = 3.
%e A394209 a(3) = |{11, 13, 17, 19, 23}| = 5.
%t A394209 Differences[PrimePi[3^Range[0, 33] - 1]] (* _Amiram Eldar_, May 09 2026 *)
%Y A394209 Cf. A000040, A000244, A000720, A024023, A055729, A162145, A006879.
