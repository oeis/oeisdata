%I A394314 #24 Apr 09 2026 10:10:03
%S A394314 0,0,2,12,62,300,1382,6132,26462,111900,466262,1922052,7861262,
%T A394314 31968300,129451142,522554772,2104502462,8460925500,33972580022,
%U A394314 136277216292,546270078062,2188564999500,8764716156902,35090237298612,140455075596062,562102698366300,2249258014965782,8999573791473732
%N A394314 a(n) = 2^(2*n-1) - 3^n + 2^n - 1, n > 0; a(0)=0.
%C A394314 Number of strings of length n defined on {0,1,2,3} such that both 0 and 1 appear at least once and the combined number of 0's and 1's is even (for ternary strings see A092438).
%C A394314 Equivalently, number of walks of length n-1 on the K_4 graph with loops with set of vertices {0,1,2,3} such that two chosen vertices, say 1 and 2, are visited at least once and the total number of times the vertex set {1,2} is visited is even.
%H A394314 Paolo Xausa, <a href="/A394314/b394314.txt">Table of n, a(n) for n = 0..1000</a>
%H A394314 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (10,-35,50,-24).
%F A394314 a(n) = 10*a(n-1) - 35*a(n-2) + 50*a(n-3) - 24*a(n-4), n > 4.
%F A394314 G.f.: 2*x^2*(6*x^2 - 4*x + 1)/(24*x^4 - 50*x^3 + 35*x^2 - 10*x + 1).
%F A394314 E.g.f.: (1/2)*(exp(4*x) - 2*exp(3*x) + 2*exp(2*x) - 2*exp(x) + 1).
%F A394314 a(n) = A092880(n)/2 - 1 for n>0.
%e A394314 For n=4, the following are the sets of vertices in which 1 and 2 are visited at least once and the total number of times the vertex set {1,2} is visited is even (number of walks in parentheses): {0,0,1,2} (12), {0,1,2,3} (24), {1,2,3,3} (12), {1,1,1,2} (4), {1,1,2,2} (6), {1,1,1,2} (4).
%t A394314 A394314[n_] := If[n == 0, 0, 2^(2*n-1) - 3^n + 2^n - 1]; Array[A394314, 30, 0] (* or *)
%t A394314 LinearRecurrence[{10, -35, 50, -24}, {0, 0, 2, 12, 62}, 30] (* _Paolo Xausa_, Apr 09 2026 *)
%o A394314 (PARI) lista(nn) = {my(va=vector(nn+1));va[1]=0;for(n=1, nn, va[n+1]=2^(2*n-1)-3^n+2^n-1;);va;} \\ _Bruce Nye_, Mar 19 2026
%Y A394314 Cf. A092438, A092880.
