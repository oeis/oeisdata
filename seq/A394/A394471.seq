%I A394471 #30 Mar 26 2026 22:02:11
%S A394471 19,31,47,53,71,79,113,131,139,149,167,179,199,211,263,269,313,353,
%T A394471 373,421,467,619,643,653,677,719,829,853,887,919,941,953,1031,1061,
%U A394471 1069,1097,1109,1193,1213,1223,1231,1259,1367,1399,1451,1489,1499,1511,1607,1759
%N A394471 Primes of the form prime(k) + prime(k+2) - 1, where prime(k) is the k-th prime.
%H A394471 Nikhil Sharma, <a href="/A394471/b394471.txt">Table of n, a(n) for n = 1..1000</a>
%e A394471 k=2: prime(2)+prime(4)-1 = 3+7-1 = 9 = 3*3, not prime, not a term.
%e A394471 k=3: prime(3)+prime(5)-1 = 5+11-1 = 15 = 3*5, not prime, not a term.
%e A394471 k=4: prime(4)+prime(6)-1 = 7+13-1 = 19, prime, so 19 is a term.
%e A394471 k=6: prime(6)+prime(8)-1 = 13+19-1 = 31, prime, so 31 is a term.
%p A394471 select(t -> isprime(prime(t)+prime(t+2)-1), [$2..100]);
%t A394471 Select[Table[Prime[k]+Prime[k+2]-1,{k,2,500}],PrimeQ]
%o A394471 (Python)
%o A394471 from sympy import prime, isprime
%o A394471 print([prime(k)+prime(k+2)-1 for k in range(2,500) if isprime(prime(k)+prime(k+2)-1)])
%Y A394471 Cf. A111255, A023201, A001359, A005384, A005385.
%K A394471 nonn
%O A394471 1,1
