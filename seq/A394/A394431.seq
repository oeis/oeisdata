%N A394431 The smallest base b < n where the sum of the digits for the number n in the base b is the largest, with 1 < b < n and a(1) = a(2) = 1.
%F A394431 Conjecture: a(n) = ceiling((n+1)/2) for n>8. - _Sean A. Irvine_, Mar 25 2026
%e A394431 For n = 5:
%e A394431   n in base 2 = [1, 0, 1] -> digsum(5, 2) = 2.
%e A394431   n in base 3 = [1, 2] -> digsum(5, 3) = 3.
%e A394431   n in base 4 = [1, 1] -> digsum(5, 4) = 2.
%e A394431   Base 3 has the largest sum of the digits for n = 5 therefore a(5) = 3.
%t A394431 a[1]=1;a[2]=1;a[n_]:=Module[{s=DigitSum[n,Range[2,n]]}, SequencePosition[s,{Max[s]}][[1,1]]+1];Array[a,71] (* _James C. McMahon_, Mar 25 2026 *)
%o A394431 (PARI) a(n) = if (n<=2, 1, my(v=vector(n-1, b, if (b>1, sumdigits(n, b))), m=vecmax(v), w=select(x->(x==m), v, 1)); w[1]); \\ _Michel Marcus_, Mar 21 2026
