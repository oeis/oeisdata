%S A394431 1,1,2,3,3,4,4,3,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,15,
%T A394431 15,16,16,17,17,18,18,19,19,20,20,21,21,22,22,23,23,24,24,25,25,26,26,
%U A394431 27,27,28,28,29,29,30,30,31,31,32,32,33,33,34,34,35,35,36,36
%N A394431 The smallest base b < n where the sum of the digits for the number n in the base b is the largest, with 1 < b < n and a(1) = a(2) = 1.
%H A394431 Robert Israel, <a href="/A394431/b394431.txt">Table of n, a(n) for n = 1..10000</a>
%F A394431 Conjecture: a(n) = ceiling((n+1)/2) for n>8. - _Sean A. Irvine_, Mar 25 2026
%e A394431 For n = 5:
%e A394431   n in base 2 = [1, 0, 1] -> digsum(5, 2) = 2.
%e A394431   n in base 3 = [1, 2] -> digsum(5, 3) = 3.
%e A394431   n in base 4 = [1, 1] -> digsum(5, 4) = 2.
%e A394431   Base 3 has the largest sum of the digits for n = 5 therefore a(5) = 3.
%p A394431 f:= proc(n) local b,s,sb,bmax;
%p A394431   s:= 0;
%p A394431   for b from 2 to n-1 while (b-1) * (1 + ilog[b](n)) > s do
%p A394431     sb:= convert(convert(n,base,b),`+`);
%p A394431     if sb > s then s:= sb; bmax:= b fi
%p A394431   od;
%p A394431   bmax;
%p A394431 end proc:
%p A394431 f(1):= 1: f(2):= 1:
%p A394431 map(f, [$1..100]); # _Robert Israel_, Jul 09 2026
%t A394431 a[1]=1;a[2]=1;a[n_]:=Module[{s=DigitSum[n,Range[2,n]]}, SequencePosition[s,{Max[s]}][[1,1]]+1];Array[a,71] (* _James C. McMahon_, Mar 25 2026 *)
%o A394431 (PARI) a(n) = if (n<=2, 1, my(v=vector(n-1, b, if (b>1, sumdigits(n, b))), m=vecmax(v), w=select(x->(x==m), v, 1)); w[1]); \\ _Michel Marcus_, Mar 21 2026
%Y A394431 Cf. A007953, A329814.
%K A394431 nonn,base,changed
%O A394431 1,3
