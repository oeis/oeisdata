%I A394558 #9 Mar 30 2026 20:47:32
%S A394558 240,264,354,357,366,390,393,492,522,525,816,828,837,855,858,876,933,
%T A394558 990,1038,1053,1101,1137,1170,1179,1197,1386,1545,1575,1761,1797,1809,
%U A394558 1815,1857,1875,1878,1884,1911,1938,1953,2058,2073,2148,2157,2169,2184,2235,2256,2259,2271,2292,2295,2307
%N A394558 Numbers k such that k^2 = j^2 + r for some j, where r is an anagram of j^2.
%C A394558 All terms are divisible by 3.
%H A394558 Robert Israel, <a href="/A394558/b394558.txt">Table of n, a(n) for n = 1..10000</a>
%e A394558 a(3) = 354 is a term because 354^2 = 282^2 + 45792 where 45792 is an anagram of 282^2 = 79524.
%p A394558 g:= proc(n) local L, S, m, k, r;
%p A394558   L:= sort(convert(n^2, base, 10));
%p A394558   m:= 10^ilog10(n^2);
%p A394558   S:= {};
%p A394558   for k from ceil(sqrt(n^2+m)) to floor(sqrt(n^2+10*m)) by 3 do
%p A394558     if sort(convert(k^2-n^2, base, 10)) = L then S:= S union {k} fi
%p A394558   od;
%p A394558   S
%p A394558 end proc:
%p A394558 S:= `union`(seq(g(k),k=3..9999,3)):
%p A394558 sort(convert(S,list));
%Y A394558 Cf. A393978, A393998, A394001, A394502, A394527.
%K A394558 nonn,base,new
%O A394558 1,1
%A A394558 _Robert Israel_, Mar 24 2026
