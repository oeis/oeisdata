%U A394673 20,1,3,7,21,1,2,11,22,1,23,1,2,3,6,8,24
%N A394673 Irregular triangle T(n, k), n > 0, k = 1..A282446(n), read by rows; the n-th row lists the recursive divisors of n (as defined in A282446).
%H A394673 Rémy Sigrist, <a href="/A394673/b394673.txt">Table of n, a(n) for n = 1..10005</a> (rows for n = 1..1476 flattened)
%H A394673 Rémy Sigrist, <a href="/A394673/a394673.pdf">Illustration of initial terms</a>
%H A394673 <a href="/index/Di#divisors">Index entries for sequences related to divisors</a>
%F A394673 T(n, 1) = 1.
%F A394673 T(n, 2) = A020639(n) for any n > 1.
%F A394673 T(n, A282446(n)) = n.
%F A394673 Sum_{k = 1..A282446(n)} = A333926(n).
%e A394673 Triangle T(n, k) begins:
%e A394673   n   n-th row
%e A394673   --  ------------------
%e A394673    1  1
%e A394673    2  1, 2
%e A394673    3  1, 3
%e A394673    4  1, 2, 4
%e A394673    5  1, 5
%e A394673    6  1, 2, 3, 6
%e A394673    7  1, 7
%e A394673    8  1, 2, 8
%e A394673    9  1, 3, 9
%e A394673   10  1, 2, 5, 10
%e A394673   11  1, 11
%e A394673   12  1, 2, 3, 4, 6, 12
%e A394673   13  1, 13
%e A394673   14  1, 2, 7, 14
%e A394673   15  1, 3, 5, 15
%e A394673   16  1, 2, 4, 16
%e A394673   17  1, 17
%e A394673   18  1, 2, 3, 6, 9, 18
%e A394673   19  1, 19
%e A394673   20  1, 2, 4, 5, 10, 20
%e A394673 .
%e A394673 See also Links section.
%o A394673 (PARI) A287957(n, k) = my (g=factor(gcd(n, k))); return (prod(i=1, #g~, g[i, 1]^A287957(valuation(n, g[i, 1]), valuation(k, g[i, 1]))))
%o A394673 row(n) = select(d -> A287957(n, d)==d, divisors(n))
%Y A394673 Cf. A020639, A282446, A333926 (row sums), A394674.
%K A394673 nonn,tabf
%O A394673 1,3
