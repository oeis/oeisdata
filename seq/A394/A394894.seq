%I A394894 #12 Apr 13 2026 15:18:54
%S A394894 1,2,3,6,13,18,36,72,123,206,423,768,1382,2659,4920,9291,17519,34127,
%T A394894 64210,122175,234927,449206,860652,1651460
%N A394894 Number of integers x in range 2^(n-1) .. (2^n)-1 such that the u-th arithmetic derivative of A019565(x) is zero for some u.
%C A394894 Number of squarefree terms of A099308 whose greatest prime factor (A006530) is prime(n) [in other words, that are prime(n)-smooth but not prime(n-1)-smooth].
%C A394894 Number of integers x in range A002110(n-1) .. A002110(n)-1 such that the u-th arithmetic derivative of A276086(x) is zero for some u, and A328114(x) = 1, where A002110(n) is the n-th primorial, and A328114 gives the largest digit in the primorial base.
%C A394894 Question: Are a(5) = 13 and a(11) = 423 the only cases where a(n) > 2*a(n-1)?
%C A394894 Ratio of a(n)/2^(n-1) shrinks like this:
%C A394894 1:                1/1 = 1.00
%C A394894 2:                2/2 = 1.00
%C A394894 3:                3/4 = 0.750
%C A394894 4:                6/8 = 0.750
%C A394894 5:              13/16 = 0.813
%C A394894 6:              18/32 = 0.563
%C A394894 7:              36/64 = 0.563
%C A394894 8:             72/128 = 0.563
%C A394894 9:            123/256 = 0.480
%C A394894 10:           206/512 = 0.402
%C A394894 11:          423/1024 = 0.413
%C A394894 12:          768/2048 = 0.375
%C A394894 13:         1382/4096 = 0.337
%C A394894 14:         2659/8192 = 0.325
%C A394894 15:        4920/16384 = 0.300
%C A394894 16:        9291/32768 = 0.284
%C A394894 17:       17519/65536 = 0.267
%C A394894 18:      34127/131072 = 0.260
%C A394894 19:      64210/262144 = 0.245
%C A394894 20:     122175/524288 = 0.233
%C A394894 21:    234927/1048576 = 0.224
%C A394894 22:    449206/2097152 = 0.214
%C A394894 23:    860652/4194304 = 0.205
%C A394894 24:   1651460/8388608 = 0.197
%F A394894 a(n) = A394890(n,1).
%e A394894 Of the four squarefree numbers in range A019565(2^(3-1)..(2^3)-1), i.e., A019565(4..7): 5, 10, 15, 30, only one (15) is in A099309, while the three others are in A099308, therefore a(3) = 3.
%o A394894 (PARI)
%o A394894 A003415checked(n) = if(n<=1, 0, my(f=factor(n), s=0); for(i=1, #f~, if(f[i, 2]>=f[i, 1], return(0), s += f[i, 2]/f[i, 1])); (n*s));
%o A394894 is_A099308(n) = { while(n>1, n = A003415checked(n)); (n); };
%o A394894 A019565(n) = { my(m=1, p=2); while(n>0, if(n%2, m *= p); n >>= 1; p = nextprime(1+p)); (m); };
%o A394894 A394894(n) = sum(i=2^(n-1),(2^n)-1,is_A099308(A019565(i)));
%Y A394894 The leftmost column of irregular triangle A394890.
%Y A394894 Cf. A002110, A003415, A006530, A019565, A099308, A276086, A328114.
%K A394894 nonn,more,new
%O A394894 1,2
