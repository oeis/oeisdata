%N A394372 a(1)=1, a(2)=2, a(3)=3; for n > 3, a(n) = a(n-1) + gcd(n, a(n-2) * a(n-3)).
%t A394372 a[n_] := a[n] = If[n < 4, n, a[n-1] + GCD[n, a[n-2]*a[n-3]]]; Array[a, 100] (* _Amiram Eldar_, Apr 17 2026 *)
%o A394372 (Python)
%o A394372 import math
%o A394372 def a(n):
%o A394372     if n == 1: return 1
%o A394372     if n == 2: return 2
%o A394372     if n == 3: return 3
%o A394372     x, y, z = 1, 2, 3
%o A394372     for i in range(4, n+1):
%o A394372         x, y, z = y, z, z + math.gcd(i, y * x)
%o A394372     return z
%o A394372 print([a(n) for n in range(1, 61)])
