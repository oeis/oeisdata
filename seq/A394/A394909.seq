%T A394909 27,274,2,1,37,37,61,408,2,45,41,1,29,1,1,121,178,1,2,237,2,361,81,18,
%U A394909 46,448,1,1,1,10,1,1743,20,4,180
%N A394909 a(n) is the number of products x*y of two integers 2^(n-1) <= x <= y < 2^n such that the Hamming weight of this product is maximized.
%C A394909 Number of products of two n-bit integers x<=y with maximum Hamming weight A394988(n).
%e A394909 a(2) = 2: the 2 pairs of 2-bit numbers with A394998(2)=2 are 2*3=6=110_2 and 3*3=9=1001_2;
%e A394909 a(7) = 7: the 7 pairs of 7-bit numbers, whose product has the maximum Hamming weight of A394998(7)=12 are 65*126=8190=1111111111110_2, 69*115=7935=1111011111111_2, 70*117=8190, 75*109=8175=1111111101111_2, 78*105=8190, 90*91=8190, 105*117=12285=10111111111101_2.
%o A394909 (Python)
%o A394909 from sympy.utilities.iterables import multiset_permutations
%o A394909 from sympy import divisors
%o A394909 def A394909(n):
%o A394909     a = 1<<n-1
%o A394909     b = a<<1
%o A394909     k = (n<<1)-1
%o A394909     for l in range(k,0,-1):
%o A394909         c = 0
%o A394909         for s in multiset_permutations('0'*(k+1-l)+'1'*l):
%o A394909             m = int(''.join(s),2)
%o A394909             for d in divisors(m):
%o A394909                 if d**2>m:
%o A394909                     break
%o A394909                 if a<=d<b and a*d<=m<b*d:
%o A394909                     c += 1
%o A394909         if c:
%o A394909             return c # _Chai Wah Wu_, Apr 10 2026
