%T A394139 1116773044,8463323632,64683640051,497999144726,3858699223862,
%U A394139 30067745845088,235468907374386,1852285897565836,14629457346782604,115964861319175536,922269694511198782
%N A394139 G.f. A(x) satisfies (x-1)*A(x)^4+(-2x^2+3x-1)*A(x)^3+(-2x^2+3x)*A(x)^2-3x^2*A(x)+x^3=0.
%C A394139 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with green root where red vertices can only be followed by blue vertices, blue vertices can be followed by vertices of any color, and green vertices can only be followed by red vertices.
%C A394139 Appears that sequence A244062 gives the coefficients on -1/A(x), where A(x) is the generating function for this sequence.
%H A394139 Nathan Fox, <a href="/A394139/b394139.txt">Table of n, a(n) for n = 0..300</a>
%H A394139 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394139 (Python)
%o A394139 def A394139(n):
%o A394139     A = [[0, 1, 0], [1, 1, 1], [1, 0, 0]]
%o A394139     if n == 0:
%o A394139         return 0
%o A394139     m = len(A)
%o A394139     output = [[1] for i in range(m)]
%o A394139     for l in range(2, n + 1):
%o A394139         for i in range(m):
%o A394139             term = 0
%o A394139             for k in range(1, l):
%o A394139                 for j in range(m):
%o A394139                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394139             output[i].append(term)
%o A394139     return output[2][n - 1]
%Y A394139 Cf. A244062, A394138.
%K A394139 nonn,new
%O A394139 0,4
%A A394139 _Nathan Fox_, Mar 11 2026
