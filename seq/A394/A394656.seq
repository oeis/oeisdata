%I A394656 #24 May 07 2026 08:09:23
%S A394656 0,0,0,1,8,40,160,525,1456,3528,7680,15345,28600,50336,84448,136045,
%T A394656 211680,319600,470016,675393,950760,1314040,1786400,2392621,3161488,
%U A394656 4126200,5324800,6800625,8602776,10786608,13414240,16555085,20286400,24693856,29872128,35925505,42968520
%N A394656 a(n) = binomial(n,3) + 4*binomial(n,4) + 10*binomial(n,5) + 20*binomial(n,6).
%C A394656 a(n) is the number of ordered set partitions of an n-set into 2 sets such that the first set has either 3, 2, 1 or no elements, the second set has no restrictions, and three elements are selected from the second set.
%C A394656 Note that the coefficients 1,4,10,20 in formula for a(n) are triangular pyramidal numbers (in accordance with the selection of three elements from the second set).
%C A394656 a(n) is also the number of ternary strings of length n with exactly three 1's, at most three 0's and any number of 2's.
%H A394656 <a href="/index/Rec#order_07">Index entries for linear recurrences with constant coefficients</a>, signature (7,-21,35,-35,21,-7,1).
%F A394656 a(n) = n*(n-1)*(n-2)^2*(n^2-7*n+18)/36.
%F A394656 E.g.f.: (1 + x + x^2/2 + x^3/6)*x^3/6*exp(x).
%F A394656 G.f.: x^3*(1 + x + 5*x^2 + 13*x^3)/(1 - x)^7. - _Stefano Spezia_, May 03 2026
%e A394656 The 525 set partitions for n=7 are the following (where the 3 elements selected from the second set are in parentheses):
%e A394656   { }, {(1),(2),(3),4,5,6,7} (35 of these);
%e A394656   {1}, {(2),(3),(4),5,6,7}   (140 of these);
%e A394656   {1,2}, {(3),(4),(5),6,7}   (210 of these);
%e A394656   {1,2,3}, {(4),(5),(6),7}   (140 of these).
%t A394656 a[n_]:=n*(n-1)*(n-2)^2*(n^2-7*n+18)/36; Array[a,37,0] (* _Stefano Spezia_, May 03 2026 *)
%Y A394656 Cf. A006000, A361099, A361474.
%K A394656 nonn,easy,new
%O A394656 0,5
