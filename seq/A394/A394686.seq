%U A394686 499,503,509,521,547,563,601,607,613,631,641,643,647,653,661,673,677,683,691,709,727,743
%N A394686 Primes, p, such that the sum of p and an anagram of itself produce another prime, q.
%C A394686 No leading zeros allowed.
%t A394686 fQ[p_] := Union[ PrimeQ[ p + Select[ FromDigits /@ Permutations[ IntegerDigits[ p]], # > 10^(IntegerLength[ p] - 1) &]]][[-1]]; Select[ Prime@ Range @135, fQ]
