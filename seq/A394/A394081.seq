%t A394081 A394081[n_, k_] := If[n == 0, 1, n^(n-k)*Gamma[k+1, k+1]*Exp[k+1]];
%t A394081 Table[A394081[n, k], {n, 0, 10}, {k, 0, n}] (* _Paolo Xausa_, Apr 10 2026 *)
%o A394081 (Python)
%o A394081 from mpmath import mp, gammainc, exp, nint
%o A394081 def T(n: int, k: int) -> int:
%o A394081     mp.dps = 50
%o A394081     if k == 0: return n**n
%o A394081     val = n ** (n - k) * gammainc(k + 1, k + 1) * exp(k + 1)
%o A394081     return int(nint(val))
%o A394081 for n in range(8): print([T(n, k) for k in range(n + 1)])
