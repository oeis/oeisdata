%N A394904 Numbers x*y such that x + y or |x - y| is a square.
%C A394904 Equivalently, numbers k such that k/d +- d is a square for some d | k. - _M. F. Hasler_, Jun 18 2026
%H A394904 Žiga Pirc, <a href="/A394904/b394904.txt">Table of n, a(n) for n = 1..10000</a>
%e A394904 5 is in the sequence since 5-1 = 2^2, a square.
%e A394904 7 is not here since neither 7+1 nor 7-1 is a square.
%o A394904 (PARI) select( {is_A394904(n)=fordiv(n+!n,d,(issquare(n/d-d)||issquare(n/d+d))&&return(1);d*d>=n&&return)}, [0..111]) \\ _M. F. Hasler_, Jun 18 2026
%o A394904 (Python)
%o A394904 from itertools import count, islice
%o A394904 from sympy import divisors
%o A394904 from sympy.ntheory.primetest import is_square
%o A394904 def A394904_gen(startvalue=0): # generator of terms >= startvalue
%o A394904     for k in count(max(startvalue,0)):
%o A394904         if k == 0:
%o A394904             yield k
%o A394904         else:
%o A394904             for d in divisors(k):
%o A394904                 if d**2>k:
%o A394904                     break
%o A394904                 if is_square(k//d+d) or is_square(k//d-d):
%o A394904                     yield k
%o A394904                     break
%o A394904 A394904_list = list(islice(A394904_gen(), 30)) # _Chai Wah Wu_, Jun 19 2026
%Y A394904 Cf. A218381, A395626.
