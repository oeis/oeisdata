%N A394524 E.g.f. A(x) satisfies A(x) = 1/(1 - 4*x*A(x)^4)^(1/4).
%H A394524 Vincenzo Librandi, <a href="/A394524/b394524.txt">Table of n, a(n) for n = 0..300</a>
%F A394524 a(n) = 4^n * n! * binomial((8*n+1)/4,n)/(8*n+1).
%F A394524 E.g.f.: (2/(1 + sqrt(1-16*x)))^(1/4).
%t A394524 a[n_]:=If[n==0,1,Product[(8*n+1-4*k),{k,0,n-1}]/(8*n+1)]; Table[a[n],{n,0,17}] (* _Vincenzo Librandi_, Mar 28 2026 *)
%o A394524 (PARI) a(n) = 4^n*n!*binomial((8*n+1)/4, n)/(8*n+1);
%o A394524 (Magma) [n eq 0 select 1 else (4^n*&*[((8*n+1)/4-k): k in [0..n-1] ])/(8*n+1): n in [0..23]]; // _Vincenzo Librandi_, Mar 28 2026
