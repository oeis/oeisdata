%I A394229 #11 Apr 22 2026 17:27:04
%S A394229 5,12,24,38,94,57,505,390,262,872,451,480,604,2114,1569,2056,1258,
%T A394229 1962,7218,13008,1303,9670,6512,7695,14618,6401,6585,35868,13779,
%U A394229 22548,57097,31970,53238,17482,27631,21764,40433,103009,47833,29579,87083,49367,73401,118731,120214,222462,224045,144042
%N A394229 a(n) is the first start of exactly n consecutive numbers that are not the sum of a nonnegative cube and a triangular number.
%C A394229 a(n) is the start of a run of exactly n consecutive numbers in A014156.
%e A394229 a(3) = 24 because 24, 25 and 26 are not the sum of a nonnegative cube and a triangular number, but 23 = 2^3 + 5*6/2 and 27 = 3^3 + 0*1/2 are.
%p A394229 N:= 10^7: # for terms before the first term > N
%p A394229 nC:= floor(surd(N,3)): C:= {seq(i^3,i=0..nC)}:
%p A394229 nT:= floor((sqrt(1+8*N)-1)/2): T:= {seq(i*(i+1)/2,i=0..nT)}:
%p A394229 A:= sort(convert(select(`<=`,{seq(seq(c+t,c=C),t=T)},N),list)):
%p A394229 dA:= A[2..-1]-A[1..-2]:
%p A394229 m:= min({$1..max(dA)+1} minus convert(dA,set)):
%p A394229 V:= Vector(m-2);
%p A394229 for i from 2 to m-1 do
%p A394229 if member(i, dA, 'k') then V[i-1]:= A[k]+1 fi
%p A394229 od;
%p A394229 convert(V,list);
%Y A394229 Cf. A014156.
%K A394229 nonn,new
%O A394229 1,1
%A A394229 _Robert Israel_, Apr 17 2026
