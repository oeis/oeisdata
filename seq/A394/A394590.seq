%U A394590 539424704140269574276,322575897023940844552204,64712722269670777415835976,50899350828638565957558873763,13240165399882959143766305222394
%N A394590 Number of permutations of [2*n] with the number moved left exceeding the number moved right by n.
%F A394590 a(n) = A062866(2*n,n) = Sum_{e=0..floor(n/2)} binomial(2*n,n+2*e) * A271697(n+2*e,e).
%e A394590 a(3) = 6 because the 6 permutations of [6] where the number of elements moved left exceeds the number of elements moved right by 3 are:
%e A394590   [1, 6, 2, 3, 4, 5] (Fixed: {1}, Right: {2->6}, Left: {3->2, 4->3, 5->4, 6->5})
%e A394590   [6, 2, 1, 3, 4, 5] (Fixed: {2}, Right: {1->6}, Left: {3->1, 4->3, 5->4, 6->5})
%e A394590   [6, 1, 3, 2, 4, 5] (Fixed: {3}, Right: {1->6}, Left: {2->1, 4->2, 5->4, 6->5})
%e A394590   [6, 1, 2, 4, 3, 5] (Fixed: {4}, Right: {1->6}, Left: {2->1, 3->2, 5->3, 6->5})
%e A394590   [6, 1, 2, 3, 5, 4] (Fixed: {5}, Right: {1->6}, Left: {2->1, 3->2, 4->3, 6->4})
%e A394590   [5, 1, 2, 3, 4, 6] (Fixed: {6}, Right: {1->5}, Left: {2->1, 3->2, 4->3, 5->4}).
%o A394590 (PARI) E(n, k) = sum(j=0, k, (-1)^j*binomial(n+1, j)*(k+1-j)^n);
%o A394590 a271697(n, k) = sum(j=0, n, (-1)^(n-j)*binomial(n, j)*E(j, k));
%o A394590 a(n) = sum(e=0, n\2, binomial(2*n, n+2*e)*a271697(n+2*e, e));
%Y A394590 Cf. A062866, A271697.
%K A394590 nonn,new
%O A394590 0,4
%A A394590 _Seiichi Manyama_, Apr 23 2026
