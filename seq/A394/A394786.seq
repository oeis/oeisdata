%N A394786 a(n) = number of triples (x, y, z) such that x^2 + y*z = n, where x,y,z are positive integers satisfying x^2 < y*z.
%e A394786 a(10) = 7 counts these triples: (1, 1, 9), (1, 3, 3), (1, 9, 1), (2, 1, 6), (2, 2, 3), (2, 3, 2), (2, 6, 1).
%t A394786 t[n_, c_] := Module[{r}, r = Flatten[Table[If[n - x^2 <= 0, {},
%t A394786        Map[({x, #, Quotient[n - x^2, #]} &),
%t A394786        Select[Divisors[n - x^2], Divisible[n - x^2, #] &]]], {x, 1,
%t A394786        Floor[Sqrt[n - 1]]}], 1]; Select[r, Apply[c, #] &]];
%t A394786 c = ((#1)^2 < #2*#3 &);
%t A394786 Join[{0}, Table[Length[t[n, c]], {n, 1, 130}]]
