%I A394545 #16 Mar 30 2026 20:15:57
%S A394545 2,3,4,5,6,7,8,9,11,22,33,44,55,66,77,88,99,101,111,121,131,141,151,
%T A394545 161,171,181,191,202,212,222,232,242,262,282,292,303,313,333,353,363,
%U A394545 373,383,393,404,424,454,474,484,505,515,535,545,565,606,626,707,717
%N A394545 Base 10 palindromes greater than 1 such that division by their highest prime factor also results in a palindrome.
%C A394545 252 is the smallest palindrome not in this list.
%H A394545 Mathematics Stack Exchange, <a href="https://math.stackexchange.com/questions/200835/are-there-infinitely-many-super-palindromes">Are there infinitely many "super-palindromes"?</a>.
%e A394545 2 is in this list since its highest prime factor is 2. 2/2=1 is a palindrome.
%e A394545 22 is in this list since its highest prime factor is 2. 22/2=11 is a palindrome.
%e A394545 252 is not in this list since its highest prime factor is 7. 252/7=36 is not a palindrome.
%t A394545 q[k_] := PalindromeQ[k] && PalindromeQ[k/FactorInteger[k][[-1, 1]]]; Select[Range[2, 720], q] (* _Amiram Eldar_, Mar 24 2026 *)
%o A394545 (Python)
%o A394545 from itertools import islice
%o A394545 from sympy import primefactors
%o A394545 from oeis_sequences.OEISsequences import is_pal, pal10_gen
%o A394545 def A394545_gen(): # generator of terms
%o A394545     return filter(lambda m: m>1 and is_pal(m//max(primefactors(m))), pal10_gen())
%o A394545 A394545_list = list(islice(A394545_gen(),57)) # _Chai Wah Wu_, Mar 29 2026
%Y A394545 Cf. A002113, A394544.
%K A394545 nonn,easy,base
%O A394545 1,1
%A A394545 _Robin Jones_, Mar 24 2026
