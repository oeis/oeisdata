%S A394609 108,1949792,5674984,696281988,1394173160,1394174840,1394179880,
%T A394609 1394181160,1394182280,1394182360
%N A394609 Numbers k such that sigma(k) = psi(k) + phi(k) + pi(k).
%e A394609 108 is a term since sigma(108) = 280 = 216 + 36 + 28 = psi(108) + phi(108) + pi(108).
%o A394609 (PARI) dedpsi(f) = prod(k = 1, #f~, (f[k, 1]+1) * f[k, 1]^(f[k, 2]-1));
%o A394609 list(lim) = {my(q = 2, m = 0, f); forprime(p = 3, lim, m++; for(k = q, p-1, f = factor(k); if(sigma(f) == dedpsi(f) + eulerphi(f) + m, print1(k, ", "))); q = p); } \\ _Amiram Eldar_, Mar 26 2026
%Y A394609 Cf. A000010, A000203, A000720, A001615.
