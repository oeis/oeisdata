%N A394780 G.f. A(x) satisfies A(x) = 1 - x/2 * d/dx log(1 - 2*x*A(x)^2).
%H A394780 Vincenzo Librandi, <a href="/A394780/b394780.txt">Table of n, a(n) for n = 0..300</a>
%F A394780 G.f. A(x) satisfies A(x) = 1 - x*A(x)^2*(1 - 2*A(x)) + x^2*d/dx(A(x)^2).
%F A394780 a(0) = 1; a(n) = (n-2) * Sum_{k=0..n-1} a(k) * a(n-1-k) + 2 * Sum_{i, j, k>=0 and i+j+k=n-1} a(i) * a(j) * a(k).
%t A394780 a[0]=1; a[n_]:=a[n]=(n-2)Sum[a[k]a[n-1-k],{k,0,n-1}]+2Sum[a[i]a[j]a[n-1-i-j],{i,0,n-1},{j,0,n-1-i}]; Table[a[n],{n,0,20}] (* _Vincenzo Librandi_, Apr 02 2026 *)
