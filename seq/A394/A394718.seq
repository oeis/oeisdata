%I A394718 #30 May 14 2026 21:38:13
%S A394718 1,9,3025,1903664161,9903365616948251868225,
%T A394718 22309173926869425179456178309988068048151564650625,
%U A394718 347344242690551218689875522294777681772995698601451664233760078879673569943084142016961541085081108860391681
%N A394718 a(n) such that the n-th partial nested radical sqrt(a(1) + sqrt(a(2) + ... + sqrt(a(n)))) = n.
%C A394718 Every term in the sequence is a perfect square.
%C A394718 The number of digits in a(n) approximately doubles with each successive term.
%F A394718 a(n) = A083869(n)^2.
%e A394718 n = 1: sqrt(a(1)) = 1, so a(1) = 1;
%e A394718 n = 2: sqrt(a(1) + sqrt(a(2))) = 2, so a(2) = 9;
%e A394718 n = 3: sqrt(a(1) + sqrt(a(2) + sqrt(a(3)))) = 3, so a(3) = 3025;
%e A394718 n = 4: sqrt(a(1) + sqrt(a(2) + sqrt(a(3) + sqrt(a(4))))) = 4, so a(4) = 1903664161;
%e A394718 ...
%o A394718 (Python)
%o A394718 num_terms = 6 # Number of terms to be generated
%o A394718 a = [1]
%o A394718 for n in range(2, num_terms + 1):
%o A394718     R = n
%o A394718     for k in range(1, n):
%o A394718         R = R**2 - a[k-1]
%o A394718     a_n = R**2
%o A394718     a.append(a_n)
%o A394718 print(a)
%Y A394718 Cf. A083869.
%K A394718 nonn,easy,new
%O A394718 1,2
%A A394718 _S. S. Krishna Chaitanya Bulusu_, Apr 27 2026
