%N A394279 Number of induced cubes in the n X n black bishop graph.
%H A394279 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/BlackBishopGraph.html">Black Bishop Graph</a>.
%H A394279 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/CubePolynomial.html">Cube Polynomial</a>.
%H A394279 <a href="/index/Rec#order_07">Index entries for linear recurrences with constant coefficients</a>, signature (3,-1,-5,5,1,-3,1).
%F A394279 a(n) = (n + 1)*(3 - 3*(-1)^n + n*(n + 1)*(n + 2))/24.
%F A394279 a(n) = 3*a(n-1)-a(n-2)-5*a(n-3)+5*a(n-4)+a(n-5)-3*a(n-6)+a(n-7).
%F A394279 G.f.: x*(-1-3*x^2)/((-1+x)^5*(1+x)^2).
%t A394279 Table[(n + 1) (3 - 3 (-1)^n + n (n + 1) (n + 2))/24, {n, 20}]
%t A394279 LinearRecurrence[{3, -1, -5, 5, 1, -3, 1}, {1, 3, 11, 25, 54, 98, 170}, 20]
%t A394279 CoefficientList[Series[(-1 - 3 x^2)/((-1 + x)^5 (1 + x)^2), {x, 0, 20}], x]
