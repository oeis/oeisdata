%H A394204 Vaclav Kotesovec, <a href="/A394204/b394204.txt">Table of n, a(n) for n = 0..10000</a>
%F A394204 a(n) ~ Gamma(1 + b/d) * ((4-sqrt(2))*zeta(3/2))^(2/3 + b/(3*d)) * d^(1/6 + b/(3*d)) * exp(3*Pi^(1/3) * ((4-sqrt(2))*zeta(3/2))^(2/3) * (n/d)^(1/3) / 4) / (2^(7/2 + 3*b/(2*d)) * sqrt(3) * Pi^(7/6 - b/(6*d)) * n^(7/6 + b/(3*d))), where d = 2, b = -1.
%t A394204 nmax = 100; CoefficientList[Series[Product[(1 + x^(k*(2*k-1))) / (1 - x^(k*(2*k-1))), {k, 1, Floor[Sqrt[1 + 8*nmax]/4 + 1]}], {x, 0, nmax}], x]
