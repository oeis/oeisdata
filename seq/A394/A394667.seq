%I A394667 #13 Apr 02 2026 21:20:17
%S A394667 4,6,10,14,22,26,34,38,44,46,55,58,62,74,77,82,86,88,94,106,110,118,
%T A394667 121,122,134,142,143,146,154,158,166,176,178,187,194,202,206,211,214,
%U A394667 218,226,233,244,254,262,266,274,277,278,298,299,302,310,314,323,326,332,334,343,344
%N A394667 Integers which can be written as the sum of a prime and an anagram of that prime.
%C A394667 Leading zeros are not allowed.
%C A394667 Obviously, all numbers which are twice a prime, A100484, are in the sequence.
%e A394667 14 is a member of this sequence since it is equal to 7 + 7;
%e A394667 44 is a member of this sequence since it is equal to 13 + 31;
%e A394667 128 is not a member even though 109 + 19 = 128; etc.
%t A394667 fQ[n_] := Block[{c = 0, m = 1, pn = 1 + PrimePi[ n]}, While[m < pn, p = Prime[ m]; If[ MemberQ[ p + Select[ FromDigits /@ Permutations[ IntegerDigits[ p]], # > 10^(IntegerLength[ p] - 1) &], n], Break[]]; m++]; m < pn]; Select[ Range@ 345, fQ]
%Y A394667 Cf. A100484, A393958, A392563.
%K A394667 base,nonn
%O A394667 1,1
%A A394667 _Robert G. Wilson v_, Mar 28 2026
