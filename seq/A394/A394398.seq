%S A394398 0,1,2,2,2,2,2,3,2,2,2,2,2,2,3,2,2,2,2,2,3,2,2,3,2,2,2,2,2,2,2,2,2,2,
%T A394398 3,2,2,2,2,2,2,2,2,2,2,2,2,3,2,2,2,2,2,2,3,3,2,2,2,2,2,2,3,2,2,2,2,2,
%U A394398 2,2,2,2,2,2,2,2,2,2,2,3,2,2,2,2,2,2,2,2,2,2
%N A394398 Number of integers k, 1<= k < n, such that n|(k^2-1) and k|n^2-1.
%C A394398 From _Robert Israel_, Mar 19 2026: (Start)
%C A394398 k=n and k=n-1 always work, so a(n) >= 2 for n > 2.
%C A394398 If n = x*(x+2), then k = x+1 works, so a(n) >= 3 if x > 1.
%C A394398 Also if n = x*(x^2-2), then k = x^2-1 works, so again a(n) >= 3 if x > 1.  (End)
%H A394398 Robert Israel, <a href="/A394398/b394398.txt">Table of n, a(n) for n = 1..10000</a>
%H A394398 Srikanth Cherukupally, <a href="https://arxiv.org/abs/2603.17434">On the size of {a : 1 <= a < n, n|a^2 - 1, a|n^2 - 1} for number n</a>, arXiv:2603.17434 [math.NT], 2026.
%F A394398 a(n) is the number of divisors d of n^2-1 such that d<n and n divides d^2-1. - _Chai Wah Wu_, Mar 19 2026
%p A394398 f:= proc(n) local k; nops(select(t -> n^2-1 mod t = 0, NumberTheory:-RootsOfUnity(2,n))) end proc:
%p A394398 f(1):= 0:
%p A394398 map(f, [$1..100]); # _Robert Israel_, Mar 19 2026
%t A394398 a[n_]:=Sum[Boole[Mod[k^2-1,n]==0&&Mod[n^2-1,k]==0],{k,1,n-1}] Table[a[n],{n,1,120}] (* _Vincenzo Librandi_, Mar 21 2026 *)
%o A394398 (PARI) a(n) = sum(k=1, n-1, !((k^2-1) % n) && !((n^2-1)%k));
%o A394398 (Python)
%o A394398 from itertools import takewhile
%o A394398 from sympy import divisors
%o A394398 def A394398(n): return sum(1 for d in takewhile(lambda x:x<n, divisors(n**2-1)) if not (d**2-1)%n) # _Chai Wah Wu_, Mar 19 2026
%o A394398 (Python)
%o A394398 from sympy import sqrt_mod
%o A394398 def A394398(n): return sum(1 for d in sqrt_mod(1,n,all_roots=True) if not (n**2-1)%d) if n>1 else 0 # _Chai Wah Wu_, Mar 20 2026, after _Robert Israel_
%o A394398 (Magma) a := function(n) s := 0; for k in [1..n-1] do if ((k^2-1) mod n eq 0) and ((n^2-1) mod
%o A394398 k eq 0) then s +:= 1; end if; end for; return s; end function; [a(n) : n in [1..120]]; // _Vincenzo Librandi_, Mar 21 2026
%Y A394398 Cf. A060594, A129296.
%K A394398 nonn
%O A394398 1,3
