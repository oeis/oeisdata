%N A394521 E.g.f. A(x) satisfies A(x) = 1/(1 - 3*x*A(x)^3)^(1/3).
%H A394521 Vincenzo Librandi, <a href="/A394521/b394521.txt">Table of n, a(n) for n = 0..300</a>
%F A394521 a(n) = 3^n * n! * binomial((6*n+1)/3,n)/(6*n+1).
%F A394521 E.g.f.: (2/(1 + sqrt(1-12*x)))^(1/3).
%t A394521 a[n_]:=If[n==0,1,Product[(6*n+1-3*k),{k,0,n-1}]/(6*n+1)]; Table[a[n],{n,0,18}] (* _Vincenzo Librandi_, Mar 27 2026 *)
%o A394521 (PARI) a(n) = 3^n*n!*binomial((6*n+1)/3, n)/(6*n+1);
%o A394521 (Magma) [n eq 0 select 1 else (3^n*&*[((6*n+1)/3-k): k in [0..n-1] ])/(6*n+1): n in [0..23]]; // _Vincenzo Librandi_, Mar 27 2026
