%N A394509 Numbers k for which sopf(2*k) = sopf(k + 2) where sopf = A008472.
%H A394509 Robert Israel, <a href="/A394509/b394509.txt">Table of n, a(n) for n = 1..10000</a>
%p A394509 sopf:= n -> convert(NumberTheory:-PrimeFactors(n),`+`):
%p A394509 select(n -> sopf(2*n) = sopf(n+2), [$1..10000]); # _Robert Israel_, Mar 30 2026
%t A394509 sopf[k_] := Total[FactorInteger[k][[;; , 1]]]; sopf[1] = 0; q[k_] := sopf[2*k] == sopf[k + 2]; Select[Range[2000], q] (* _Amiram Eldar_, Mar 23 2026 *)
%o A394509 (Magma) [k: k in [1..1900] | (2*k) eq 1 select 0 else &+[p[1]: p in Factorization(2*k)] eq ((k+2) eq 1 select 0 else &+[p[1]: p in Factorization(k+2)])];
%o A394509 (PARI) isok(k) = vecsum(factor(2*k)[, 1]) == vecsum(factor(k+2)[, 1]); \\ _Michel Marcus_, Mar 23 2026
