%U A394569 146,147,150,153,158,160,165,166,171,174,178,180,186,194,195,198,200,202
%N A394569 Numbers k such that gcd(k, Omega(k)) is prime.
%C A394569 No prime belongs to this sequence since, for any prime k, Omega(k) = 1 and gcd(k, 1) = 1, which is not prime.
%C A394569 2^n is a term if and only if n == 2 (mod 4), since Omega(2^n) = n and gcd(2^n, n) = 2 only in this case.
%e A394569 For k = 6: Omega(6) = 2 and gcd(6, 2) = 2, which is prime, so 6 is a term.
%e A394569 For k = 8: Omega(8) = 3 and gcd(8, 3) = 1, which is not prime, so 8 is not a term.
%t A394569 Select[Range[200], PrimeQ[GCD[#, PrimeOmega[#]]] &] (* _Amiram Eldar_, Mar 25 2026 *)
%o A394569 (Python)
%o A394569 from sympy import factorint, gcd, isprime
%o A394569 def ok(k): return isprime(gcd(k, sum(factorint(k).values())))
%o A394569 print([k for k in range(1, 400) if ok(k)])
