%I A394803 #8 Apr 03 2026 10:08:57
%S A394803 2,3,3,7,5,11,7,31,17,53,11,23,13,103,29,31,17,19,37,173,41,43,23,47,
%T A394803 73,179,53,29,109,139,31,149,389,67,251,71,37,569,401,79,41,83,43,953,
%U A394803 89,673,47,797,97,1103,101,103,53,107,109,1217,113,1303,59,1451
%N A394803 a(n) is the least prime number of the form A392155(k) + ... + A392155(n) for some k in 1..n.
%C A394803 All prime numbers appear in this sequence.
%H A394803 Rémy Sigrist, <a href="/A394803/b394803.txt">Table of n, a(n) for n = 1..10000</a>
%H A394803 Rémy Sigrist, <a href="/A394803/a394803.png">Colored logarithmic scatterplot of the first 25000 terms</a> (where the color is function of n-k: black pixels when n-k = 0, gray pixels when n-k = 1, other colors otherwise)
%e A394803 For n = 25:
%e A394803 - A392155(25) = 25 is not prime,
%e A394803 - A392155(24) + A392155(25) = 24 + 26 = 50 is not prime,
%e A394803 - A392155(23) + A392155(24) + A392155(25) = 23 + 24 + 26 = 73 is prime,
%e A394803 - so a(25) = 73.
%o A394803 (PARI) { s = 0; for (n = 1, #a = vector(60), for (v = 1, oo, if (!bittest(s, v), t = v; forstep (k = n, 1, -1, if (isprime(t += a[k]), s += 2^(a[n] = v); print1 (t", "); break (2); ); ); ); ); ); }
%Y A394803 Cf. A392155.
%K A394803 nonn
%O A394803 1,1
%A A394803 _Rémy Sigrist_, Apr 02 2026
