%F A394029 G.f.: Sum_{j>=1} q^(4*j)*(1-q^(3*j))*(1-q^(9*j))/((1-q^j)*(1-q^(3*j))) * Product_{k=j+1..3*j-1} (1-q^(4*k))/(1-q^k).
%t A394029 Nmax=80; Rest@CoefficientList[Series[Sum[q^(4*j)*(1-q^(3*j))*(1-q^(9*j))/((1-q^j)*(1-q^(3*j)))*Product[(1-q^(4*k))/(1-q^k),{k,j+1,3*j-1}],{j,1,Nmax}],{q,0,Nmax}]//Normal,q] (* _Vincenzo Librandi_, Mar 08 2026 *)
%o A394029 (Magma) N := 80; R<q> := PowerSeriesRing(Integers(), N+5); gf := &+[ q^(4*j)*(1-q^(3*j))*(1-q^(9*j))/((1-q^j)*(1-q^(3*j))) * &*[(1-q^(4*k))/(1-q^k) : k in [j+1..3*j-1]] : j in [1..N] ]; [Coefficient(gf,n) : n in [1..N]]; // _Vincenzo Librandi_, Mar 08 2026
