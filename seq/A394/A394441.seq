%N A394441 a(n) = Sum_{k=0..n} Sum_{j=0..k} (-1)^(k - j)*binomial(k, j)*j^(n - k)*2^j. Row sums of A394444.
%p A394441 a := n -> local k, j; add(add((-1)^(k - j)*binomial(k, j)*j^(n - k)*2^j, j = 0 .. k), k = 0 .. n); seq(a(n), n = 0..25);
%t A394441 Unprotect[Power]; Power[0,0]=1; Protect[Power]; a[n_]:= Sum[Sum[(-1)^(k - j)*Binomial[k, j]*j^(n - k)*2^j,{j,0,k}],{k,0,n}]; Array[a,26,0] (* _Stefano Spezia_, Mar 21 2026 *)
