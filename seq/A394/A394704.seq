%T A394704 21259,48034,21259,1379,1,1,5140,152644,665758,665758,152644,5140,1,1,
%U A394704 19296,1052076,8069856,15271974,8069856,1052076,19296,1,1,72920,7082120,89918720,290346728,290346728,89918720,7082120,72920,1
%N A394704 Triangle read by rows: coefficients of reciprocal polynomials refining A013499.
%C A394704 Define an integer-valued polynomial p_n(x) = Product_{i=1..n} ((n+1)*x+i) * (2*x+1) / n!. Then the n-th row describes the numerator of the generating function Sum_{k >= 0} p_n(k) t^k as a rational function.
%e A394704 The first few rows are:
%e A394704   1,    1;
%e A394704   1,    6,     1;
%e A394704   1,   26,    26,     1;
%e A394704   1,  100,   310,   100,     1;
%e A394704   1,  372,  2752,  2752,   372,    1;
%e A394704   1, 1379, 21259, 48034, 21259, 1379, 1;
%o A394704 (SageMath)
%o A394704 x = polygen(QQ, 'x')
%o A394704 t = x.parent()[['t']].gen()
%o A394704 def row(n):
%o A394704     pn = prod((n+1)*x+i for i in range(1, n+1)) * (2*x+1) / factorial(n)
%o A394704     poly = (1 - t)**(n + 2) * sum(pn(k) * t**k for k in range(n + 2)).O(n + 2)
%o A394704     return poly.coefficients()
%Y A394704 Row sums are A013499(n+1) if n >= 1.
%Y A394704 Similar to A108267, A395490.
%K A394704 nonn,tabf,new
%O A394704 0,4
%A A394704 _F. Chapoton_, Apr 26 2026
