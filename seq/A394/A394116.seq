%S A394116 0,1,1,3,13,66,364,2111,12664,77853,487589,3098863,19930627,129458464,
%T A394116 847941004,5593838322,37132420061,247835922698,1662152295702,
%U A394116 11195577583449,75700837876997,513654611900204,3496381454815240,23868386315806536,163372487283786302
%N A394116 G.f. A(x) satisfies A(x)^5-(2x+3)*A(x)^4+(7x+1)*A(x)^3-(4x^2+3x)*A(x)^2+3x^2*A(x)-x^3=0.
%C A394116 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with red root where red vertices can only be followed by green vertices, blue vertices can be followed by red or blue vertices, and green vertices can be followed by blue or green vertices.
%H A394116 Nathan Fox, <a href="/A394116/b394116.txt">Table of n, a(n) for n = 0..300</a>
%H A394116 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394116 (Python)
%o A394116 def A394116(n):
%o A394116     A = [[0, 0, 1], [1, 1, 0], [0, 1, 1]]
%o A394116     if n == 0:
%o A394116         return 0
%o A394116     m = len(A)
%o A394116     output = [[1] for i in range(m)]
%o A394116     for l in range(2, n + 1):
%o A394116         for i in range(m):
%o A394116             term = 0
%o A394116             for k in range(1, l):
%o A394116                 for j in range(m):
%o A394116                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394116             output[i].append(term)
%o A394116     return output[0][n - 1]
%Y A394116 Cf. A394117, A394118.
%K A394116 nonn
%O A394116 0,4
%A A394116 _Nathan Fox_, Mar 11 2026
