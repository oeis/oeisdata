%U A394883 89595660,124738614,171087708,231474530,309276240,408490875,533819286,690753987,885675196,1125954348,1420065360
%N A394883 a(n) = n^2*(n + 1)*(n + 2)*(2*n + 1)*(2*n + 3)*(5*n - 1)/360.
%C A394883 The odd-indexed terms a(2k-1) correspond to a diagonal of the central factorial triangle A036969.
%H A394883 Paolo Xausa, <a href="/A394883/b394883.txt">Table of n, a(n) for n = 1..10000</a>
%H A394883 <a href="/index/Rec#order_08">Index entries for linear recurrences with constant coefficients</a>, signature (8,-28,56,-70,56,-28,8,-1).
%F A394883 a(n) = A394582(n, 6).
%F A394883 a(n) = n * A060493(n).
%F A394883 a(n) = n * Sum_{k=1..n} k^2 * Sum_{i=1..k} i^2.
%F A394883 a(n) = (1/(2*n-1)!) * Sum_{j = 1..n} (-1)^(n+j) * j^(2*n+4) * binomial(2*n, n-j).
%F A394883 From _Stefano Spezia_, Apr 05 2026: (Start)
%F A394883 G.f.: x*(1 + 34*x + 133*x^2 + 100*x^3 + 12*x^4)/(1 - x)^8.
%F A394883 E.g.f.: exp(x)*x*(360 + 7200*x + 19080*x^2 + 14880*x^3 + 4395*x^4 + 516*x^5 + 20*x^6)/360. (End)
%F A394883 Sum_{n>=1} 1/a(n) = -18750*sqrt(5)*Pi*sqrt(2*sqrt(5)+5)/1309 - 10*Pi^2 + 1022555/3927 + (234375*log(5) - 408320*log(2))/1309 + (46875*sqrt(5)/1309)*log((3+sqrt(5))/2).
%t A394883 A394883[n_] := n^2*(n + 1)*(n + 2)*(2*n + 1)*(2*n + 3)*(5*n - 1)/360;
%t A394883 Array[A394883, 30] (* _Paolo Xausa_, Apr 16 2026 *)
%o A394883 (PARI) a(n)=n^2*(n + 1)*(n + 2)*(2*n + 1)*(2*n + 3)*(5*n - 1)/360
%o A394883 (Python)
%o A394883 def a(n): return (n**2)*(n + 1)*(n + 2)*(2*n + 1)*(2*n + 3)*(5*n - 1)//360
%o A394883 print([a(n) for n in range(1,31)]) # _Shreyansh Jaiswal_, Apr 09 2026
