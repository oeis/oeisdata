%I A394165 #26 May 27 2026 17:22:36
%S A394165 1,2,3,5,8,13,20,32,51,81,130,207,329,523,835,1334,2120,3358,5287,
%T A394165 8357,13231,20895,32908,51654,81110,127535,200405,314237,490849,
%U A394165 766020,1197116,1871742,2922315,4547174,7058961,10957148,17014762,26414148,40945715,63317745,97787201
%N A394165 Number of binary words x of length n such that for every prefix of length k, the product of j+1 over all positions j where x_j=1 is at most 2^k.
%C A394165 Equivalently, a(n) counts binary words whose every prefix remains below a cumulative multiplicative bound.
%C A394165 In logarithmic form, the condition is Sum_{j=1..k} x_j*log_2(j+1) <= k for every prefix length k.
%H A394165 Michael S. Branicky, <a href="/A394165/b394165.txt">Table of n, a(n) for n = 0..60</a>
%F A394165 a(n) = #{x in {0,1}^n : for every k <= n, Product_{j=1..k, x_j=1} (j+1) <= 2^k}.
%e A394165 a(0)=1, since the empty word is counted.
%e A394165 a(1)=2, since both 0 and 1 satisfy the condition.
%e A394165 a(2)=3, since 00, 01 and 10 are counted, while 11 is excluded because 2*3 > 2^2.
%t A394165 a[0] = 1; a[n_Integer?NonNegative] := a[n] = Module[{s, u, p, q, c, k}, s = <|1 -> 1|>; Do[u = <||>; KeyValueMap[(p = #1; c = #2; u[p] = Lookup[u, p, 0] + c; q = p (k + 1); If[q <= 2^k, u[q] = Lookup[u, q, 0] + c]) &, s]; s = u, {k, 1, n}]; Total[Values[s]]];
%t A394165 Table[a[n], {n, 0, 29}] (* _Robert P. P. McKone_, May 25 2026 *)
%o A394165 (Python)
%o A394165 from collections import defaultdict
%o A394165 def a(n):
%o A394165     states = {1: 1}
%o A394165     for k in range(1, n+1):
%o A394165         new = defaultdict(int)
%o A394165         limit = 2**k
%o A394165         for P, c in states.items():
%o A394165             new[P] += c
%o A394165             P1 = P*(k+1)
%o A394165             if P1 <= limit:
%o A394165                 new[P1] += c
%o A394165         states = dict(new)
%o A394165     return sum(states.values())
%o A394165 print([a(n) for n in range(30)])
%Y A394165 Cf. A298072.
%K A394165 nonn,base,new
%O A394165 0,2
%A A394165 _Patrick Bini_, May 25 2026
%E A394165 a(30) onward from _Michael S. Branicky_, May 25 2026
