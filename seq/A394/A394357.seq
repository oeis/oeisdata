%I A394357 #12 Mar 28 2026 21:24:56
%S A394357 1,3,6,526235,286,58395,2860,31278555,5310
%N A394357 a(n) is the least k such that k and 10^k - n are coprime but k and 10^k - j are not coprime for 1 <= j < n.
%C A394357 a(n) is the least k such that A394352(k) = n.
%C A394357 a(10) > 10^9.
%C A394357 a(11) = 210630.
%C A394357 a(13) = 55515460.
%C A394357 a(17) = 878370.
%e A394357 a(3) = 6 because 10^6 - 1 and 10^6 - 2 are not coprime to 6 but 10^6 - 3 is, and 6 is the smallest number that works.
%p A394357 h:= proc(n) local q,k;
%p A394357   for k from 1 do
%p A394357     q:= 10 &^ n - k mod n;
%p A394357     if igcd(q, n) = 1 then return k fi;
%p A394357   od
%p A394357 end proc:
%p A394357 V:= Vector(9): count:= 0:
%p A394357 for k from 1 while count < 9 do
%p A394357   v:= h(k);
%p A394357   if V[v] = 0 then V[v]:= k; count:= count+1 fi;
%p A394357 od:
%p A394357 convert(V,list);
%t A394357 h[n_]:=Module[{k=1,q},While[True,q=Mod[PowerMod[10,n,n]-k,n];If[GCD[q,n]==1,Return[k]];k++]]; V=ConstantArray[0,9];count=0;k=1;While[count<9,v=h[k];If[v<=9&&V[[v]]==0,V[[v]]=k;count++];k++]; V (* _Vincenzo Librandi_, Mar 21 2026 *)
%Y A394357 Cf. A108908, A394352.
%K A394357 nonn,more
%O A394357 1,2
%A A394357 _Robert Israel_, Mar 17 2026
