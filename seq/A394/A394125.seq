%S A394125 0,1,1,4,21,124,784,5190,35525,249448,1787164,13014018,96045816,
%T A394125 716835362,5401299830,41032881582,313943494861,2416985112916,
%U A394125 18710413090548,145551177806590,1137230230117100,8920556483902262,70223724722562526,554604880381209050
%N A394125 G.f. A(x) satisfies A(x)^6+A(x)^5-2x*A(x)^4-x*A(x)^3+(x^3+3x^2)*A(x)^2-3x^3*A(x)+x^4=0.
%C A394125 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with red root where red vertices can only be followed by blue vertices, blue vertices can be followed by vertices of any color, and green vertices can only be followed by green vertices.
%H A394125 Nathan Fox, <a href="/A394125/b394125.txt">Table of n, a(n) for n = 0..300</a>
%H A394125 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394125 (Python)
%o A394125 def A394125(n):
%o A394125     A = [[0, 1, 0], [1, 1, 1], [0, 0, 1]]
%o A394125     if n == 0:
%o A394125         return 0
%o A394125     m = len(A)
%o A394125     output = [[1] for i in range(m)]
%o A394125     for l in range(2, n + 1):
%o A394125         for i in range(m):
%o A394125             term = 0
%o A394125             for k in range(1, l):
%o A394125                 for j in range(m):
%o A394125                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394125             output[i].append(term)
%o A394125     return output[0][n - 1]
%Y A394125 Cf. A394126.
%K A394125 nonn,new
%O A394125 0,4
%A A394125 _Nathan Fox_, Mar 11 2026
