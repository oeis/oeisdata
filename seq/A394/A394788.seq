%N A394788 a(n) = number of triples (x, y, z) such that 2*x^2 + y*z = n, where x, y, z are positive integers satisfying x <= y < z.
%e A394788 a(20) = 5 counts these triples: (1, 1, 18), (1, 2, 9), (1, 3, 6), (2, 2, 6), (2, 3, 4).
%t A394788 t[n_, c_] := Module[{r}, r = Flatten[Table[If[n - 2 x^2 <= 0, {},
%t A394788 Map[({x, #, Quotient[n - 2 x^2, #]} &),
%t A394788 Select[Divisors[n - 2 x^2], Divisible[n - 2 x^2, #] &]]],
%t A394788 {x, 1, Floor[Sqrt[n - 1]]}], 1]; Select[r, Apply[c, #] &]];
%t A394788 c = (#1 <= #2 < #3 &);
%t A394788 Table[{n, t[n, c]}, {n, 1, 60}]
%t A394788 u = Join[{0},Table[Length[t[n, c]], {n, 1, 130}]]
