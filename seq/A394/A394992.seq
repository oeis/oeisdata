%I A394992 #18 Apr 27 2026 22:45:27
%S A394992 0,1,5,23,113,620,3864,27425,220387,1986067,19867435,218559496,
%T A394992 2622760320,34096005553,477344395553,7160166765335,114562670423669,
%U A394992 1947565402905260,35056177267225032,666067368116363777,13321347362429609695,279748294611289717891,6154462481449075202335
%N A394992 a(n) = n! * Sum_{k=0..n} F(2*k)/k!, where F(n) is the n-th Fibonacci number, A000045(n).
%C A394992 This sequence occurs in the setting of expressing Euler's number e as the ratio of two infinite sums involving the Fibonacci numbers. Gardner (2005/2006) seems to have been the first to give such an identity, which was reprinted in 2009. Unfortunately, that identity is incorrect, see Pietrobon (2013). However, many such identities do exist; one involving a(n) is given in the formula section.
%D A394992 Martin Gardner, Dr. Matrix on little known Fibonacci curiosities, Journal of Recreational Mathematics, 34(3):183-190, 2005/2006.
%D A394992 Martin Gardner, The Fibonacci Sequence: When you were a Tadpole and I was a Fish, Chapter 10, Hill and Wang, New York, 2009, pp. 106-113.
%H A394992 Hans J. H. Tuenter, <a href="/A394992/b394992.txt">Table of n, a(n) for n = 0..100</a>
%H A394992 Daniel Pietrobon, <a href="https://math.stackexchange.com/questions/360468">Identity for e in terms of the Fibonacci sequence</a>, Math StackExchange, Apr 13 2013.
%F A394992 E.g.f.: (2/sqrt(5))*exp(3*x/2)*sinh(sqrt(5)*x/2)/(1-x).
%F A394992 a(n) = F(2*n) + n*a(n-1).
%F A394992 a(n+3) = (n+6)*a(n+2) - (3*n+7)*a(n+1) + (n+1)*a(n).
%F A394992 a(n)/n! ~ (exp(1+phi)-exp(2-phi))/sqrt(5) = 2*e*sqrt(e/5)*sinh(sqrt(5)/2) = 5.475496883... = e*A098689.
%F A394992 a(n) ~ sqrt(2*Pi/5)*n^(n+1/2)*exp(1+phi-n)*(1-exp(-sqrt(5))) where phi is A001622.
%F A394992 a(n) = Sum_{k=0..n} binomial(n,k)*A111139(k).
%F A394992 A111139(n) = Sum_{k=0..n} binomial(n,k)*(-1)^(n-k)*a(k).
%F A394992 a(n)/A111139(n), n>0, is strictly increasing with limit e.
%t A394992 a[n_] := n!*Sum[Fibonacci[2*k]/k!,{k,0,n}]; Table[a[n],{n,0,25}]
%Y A394992 Cf. A111139, A098689, A394993.
%Y A394992 Cf. A000045, A001906, A001622 (phi), A001113 (e).
%K A394992 nonn,easy,new
%O A394992 0,3
%A A394992 _Hans J. H. Tuenter_, Apr 10 2026
