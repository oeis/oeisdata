%U A394578 136961314772,551523077078,2192459135132,8820559289228,35092889525192,141080547968978,561660049273988
%N A394578 a(n) = 2^(2*n-1) * p(n, n+1/2), where p(n,x) is the Lagrange interpolating polynomial through (1,0) and (k,1) for k=2..n+1.
%C A394578 Conjecture: a(n+1)/a(n) -> 1/4.
%C A394578 Conjecture D-finite with recurrence n*a(n) +2*(-2*n+1)*a(n-1) +16*(-n+3)*a(n-2) +32*(2*n-7)*a(n-3)=0. - _R. J. Mathar_, Jun 30 2026
%t A394578 t[0] = {0}; t[n_] := t[n] = Join[t[n - 1], {1}];
%t A394578 p[n_, x_] := Expand[InterpolatingPolynomial[t[n], x]];
%t A394578 Table[(1/2) 4^n  p[n, n + 1/2], {n, 0, 40}]
%t A394578 Labeled[Plot[{p[1, x], p[2, x], p[3, x], p[4, x], p[5, x]}, {x, -1, 7}], "Plot of p[n,x] for n=1..5."]
%Y A394578 Cf. A395640, A396722, A396724.
