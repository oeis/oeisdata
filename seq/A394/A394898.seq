%e A394898   14 |  1,  0,  3,  0;
%e A394898   15 |  1,  1, -1,  5;
%e A394898   16 |  1,  0,  0,  0,  0;
%e A394898   17 |  1, 15;
%e A394898   18 |  1,  0, -1,  0, -3,  0;
%e A394898   19 |  1, 17;
%e A394898   20 |  1,  0,  0, -3,  0,  0;
%e A394898   21 |  1,  1,  1,  7;
%e A394898   22 |  1,  0,  7,  0;
%e A394898   23 |  1, 21;
%e A394898   24 |  1,  0, -1, -2, -2, -4, -4,  0;
%e A394898   25 |  1,  3, 15;
%e A394898   26 |  1,  0,  9,  0;
%e A394898   27 |  1,  1,  3,  9;
%e A394898   28 |  1,  0,  0, -1,  0,  0;
%e A394898   ...
%t A394898 Flatten@ Table[Prepend[#2 - 2*#1 & @@@ Partition[Divisors[n], 2, 1], 1], {n, 28}] (* _Michael De Vlieger_, Apr 08 2026 *)
%o A394898 (PARI)
%o A394898 rows_up_to = 2048;
%o A394898 A394898_tr(n,k) = if(1==k,1,my(divs=divisors(n)); divs[k]-2*divs[k-1]);
%o A394898 A394898_list(rows_up_to) = { my(lista=List([])); for(row=1,rows_up_to, for(k=1, numdiv(row), listput(lista,A394898_tr(row,k)))); Vec(lista); };
%o A394898 v394898 = A394898_list(rows_up_to);
%o A394898 A394898(n) = v394898[n]; \\ _Antti Karttunen_, Apr 20 2026
%Y A394898 Row sums give A033879.
%Y A394898 Row lengths give A000005.
%Y A394898 Column 1 gives A000012.
