%e A394898    4 |  1,  0,  0;
%e A394898    5 |  1,  3;
%e A394898    6 |  1,  0, -1,  0;
%e A394898    7 |  1,  5;
%e A394898    8 |  1,  0,  0,  0;
%e A394898    9 |  1,  1,  3;
%e A394898   10 |  1,  0,  1,  0;
%e A394898   11 |  1,  9;
%e A394898   12 |  1,  0, -1, -2, -2,  0;
