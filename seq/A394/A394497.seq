%S A394497 1,3,3,9,5,9,7,27,9,15,11,27,13,21,15,81,17,27,19,45,21,33,23,81,25,
%T A394497 39,27,63,29,45,31,243,33,51,35,81,37,57,39,135,41,63,43,99,45,69,47,
%U A394497 243,49,75,51,117,53,81,55,189,57,87,59,135,61,93,63,729,65,99,67,153,69,105,71,243,73,111,75,171
%N A394497 Recurrence: a(2*n + 1) = 2*n + 1, a(2*n) = 3*a(n).
%C A394497 All numbers are of form 3^m * (2n + 1), m,n >= 0.
%H A394497 Vincenzo Librandi, <a href="/A394497/b394497.txt">Table of n, a(n) for n = 1..10000</a>
%F A394497 a(n) = (3/2)^A007814(n) * n = 3^A007814(n) * A000265(n).
%F A394497 a(n) = 2 * A085062(n) + 1.
%F A394497 a(2^n) = 3^n.
%t A394497 Clear[a];a[n_]:=a[n]=If[OddQ[n],n,3a[n/2]];Table[a[n],{n,1,80}] (* _Vincenzo Librandi_, Mar 22 2026 *)
%o A394497 (PARI) a(n)=(3/2)^valuation(n,2)*n
%o A394497 (Magma) function a(n) if IsOdd(n) then return n; else return 3*a(n div 2); end if; end function; seq:= [a(n):n in [1..80]];seq; // _Vincenzo Librandi_, Mar 22 2026
%Y A394497 Cf. A085062.
%K A394497 nonn,easy,new
%O A394497 1,2
