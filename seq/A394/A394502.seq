%I A394502 #14 Mar 29 2026 17:30:31
%S A394502 156,336,282,1593,1323,4428,3582,1746,4302,10473,11352,10323,18918,
%T A394502 3678,32133,15519,11292,31968,32670,29208,19023,34872,13278,32208,
%U A394502 32469,32418,34128,35754,50187,101709,100218,95154,91251,100476,51996,32376,104559,101274,40872,91248,101418,66276,85743
%N A394502 a(n) is the least positive integer k such that there are exactly n positive integers m where m^2 - k^2 is an anagram of k^2.
%C A394502 All terms are multiples of 3.
%e A394502 a(3) = 282 because there are exactly 3 positive integers m where m^2 - 282^2 is an anagram of 282^2 = 79524, namely 354^2 - 282^2 = 45792, 357^2 - 282^2 = 47925, and 393^2 - 282^2 = 74925, and 282 is the least number that works.
%p A394502 N:= 50: # for a(1) .. a(N)
%p A394502 V:= Vector(N): count:= 0:
%p A394502 f:= proc(n) local L, t,m, k, r;
%p A394502   L:= sort(convert(n^2,base,10));
%p A394502   m:= 10^ilog10(n^2);
%p A394502   t:= 0;
%p A394502   for k from ceil(sqrt(n^2+m)) to floor(sqrt(n^2+10*m)) by 3 do
%p A394502     if sort(convert(k^2-n^2,base,10)) = L then t:= t+1 fi
%p A394502   od;
%p A394502   t
%p A394502 end proc;
%p A394502 for n from 3 by 3 while count < N do
%p A394502   v:= f(n);
%p A394502   if v > 0 and v <= N and V[v] = 0 then count:= count+1; V[v]:= n fi
%p A394502 od:
%p A394502 convert(V,list);
%Y A394502 Cf. A393978, A393998, A394001.
%K A394502 nonn,base,new
%O A394502 1,1
%A A394502 _Robert Israel_, Mar 22 2026
