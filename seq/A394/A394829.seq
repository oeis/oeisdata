%I A394829 #16 Apr 14 2026 22:53:04
%S A394829 0,8,10,34,38,78,84,140,148,220,230,318,330,434,448,568,584,720,738,
%T A394829 890,910,1078,1100,1284,1308,1508,1534,1750,1778,2010,2040,2288,2320,
%U A394829 2584,2618,2898,2934,3230,3268,3580,3620,3948,3990,4334,4378,4738,4784,5160,5208,5600,5650,6058,6110,6534,6588
%N A394829 Numbers of the form h*(9*h+1), where h = 0, -1, 1, -2, 2, -3, 3, ...
%C A394829 Integer values of k*(k+1)/9.
%C A394829 Nonnegative integers m such that 36*m+1 is a perfect square.
%C A394829 Interleaving of {m*(9*m+1)} (m >= 0) and {(m+1)*(9*m+8)} (m >= 0).
%H A394829 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (1,2,-2,-1,1).
%F A394829 G.f.: 2*x*(4 + x + 4*x^2) / ((1+x)^2*(1-x)^3).
%F A394829 a(n) = A219395(n+1)/2.
%F A394829 a(n) = n*(9*n+2)/4 for n even, a(n) = (n+1)*(9*n+7)/4 for n odd.
%F A394829 a(n) = n*(n+1)/2 + 7*floor((n+1)/2)^2.
%F A394829 a(n) = (18*n*(n+1) + 7*(1 - (2*n+1)*(-1)^n))/8.
%F A394829 a(n) - a(n-1) = n if n is even, 8*n if n is odd (n >= 1).
%F A394829 a(n) = a(n-1) + 2*a(n-2) - 2*a(n-3) - a(n-4) + a(n-5) for n >= 5, with a(0)=0, a(1)=8, a(2)=10, a(3)=34, a(4)=38.
%e A394829 a(0) = 0*(9*0+1) = 0, h = 0.
%e A394829 a(1) = (-1)*(9*(-1)+1) = 8, h = -1.
%e A394829 a(2) = 1*(9*1+1) = 10, h = 1.
%e A394829 a(3) = (-2)*(9*(-2)+1) = 34, h = -2.
%p A394829 a:= n-> `if`(n::even, n*(9*n+2)/4, (n+1)*(9*n+7)/4):
%p A394829 seq(a(n), n=0..55);
%t A394829 a[n_]:=(18*n*(n+1)+7*(1-(2*n+1)*(-1)^n))/8; Array[a,55,0]
%o A394829 (PARI)
%o A394829 a(n)=(18*n*(n+1)+7*(1-(2*n+1)*(-1)^n))/8
%o A394829 vector(55,n,a(n-1))
%o A394829 (Python)
%o A394829 def a(n): return (18*n*(n+1) + 7*(1-(2*n+1)*(-1)**n))//8
%o A394829 print([a(n) for n in range(55)])
%Y A394829 Cf. numbers k such that h*k+1 is a square: A005563 (h=1), A046092 (h=2), A001082 (h=3), A002378 (h=4), A036666 (h=5), A062717 (h=6), A132354 (h=7), A000217 (h=8), A132355 (h=9), A132356 (h=10), A152749 (h=12), A219389 (h=13), A219390 (h=14), A204221 (h=15), A074378 (h=16), A219394 (h=17), A219395 (h=18), A219396 (h=19), A219190 (h=20), A219391 (h=21), A219392 (h=22), A219393 (h=23), A001318 (h=24), A219259 (h=25), A217441 (h=26), A219258 (h=27), A219191 (h=28).
%K A394829 nonn,easy,new
