%U A394454 563,642,604,687,661,679,768,758,742,761,851,857,941,1031,990,1097,1190,1220
%N A394454 Sum of distinct prime divisors of C(2*n, n).
%C A394454 Conjecture: for every prime p, the set {n >= 1 : p divides C(2*n, n)} is infinite.
%C A394454 Consequently, every prime appears infinitely often in a(n), and lim sup a(n) = oo.
%H A394454 Vincenzo Librandi, <a href="/A394454/b394454.txt">Table of n, a(n) for n = 1..1000</a>
%F A394454 a(n) = A008472(A000984(n)).
%F A394454 a(n) <= A034387(2*n) ~ 2n^2/log n. - _Charles R Greathouse IV_, Apr 27 2026
%e A394454 n = 4: binomial(8,4) = 70 = 2 * 5 * 7 -> a(4) = 2 + 5 + 7 = 14.
%e A394454 n = 5: binomial(10,5) = 252 = 2^2 * 3^2 * 7 -> a(5) = 2 + 3 + 7 = 12.
%p A394454 a:= n-> add(i[1], i=ifactors(binomial(2*n,n))[2]):
%p A394454 seq(a(n), n=1..56);  # _Alois P. Heinz_, Mar 25 2026
%t A394454 a[n_]:=Total[FactorInteger[Binomial[2 n,n]][[All,1]]]; Table[a[n],{n,1,50}]
%o A394454 (Magma) a := func<n | &+PrimeDivisors(Binomial(2*n, n))>; N := 50; [a(n) : n in [1..N]];
%o A394454 (PARI) a(n)=vecsum(factor(binomial(2*n, n))[, 1]) \\ _Charles R Greathouse IV_, Apr 27 2026
%o A394454 (PARI) a(n) = {my(res = 0); forprime(p = 2, 2*n, if(val(2*n, p) - 2*val(n, p) > 0, res+=p)); res}
%o A394454 val(n, p) = my(r=0); while(n, r+=n\=p); r \\ _David A. Corneth_, May 14 2026
%o A394454 (Python)
%o A394454 from collections import Counter
%o A394454 from sympy import factorint
%o A394454 def A394454(n):
%o A394454     c = Counter()
%o A394454     for i in range(n+1,2*n+1):
%o A394454         c += factorint(i)
%o A394454     for i in range(2,n+1):
%o A394454         c -= factorint(i)
%o A394454     return sum(c) # _Chai Wah Wu_, Apr 27 2026
