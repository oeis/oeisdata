%S A394012 1,4,28,88,1808,3640,4672,189696,969024,1106560,454144,30500608,
%T A394012 283202304,768866560,608608000,70084096,7023401984,102145838080,
%U A394012 482087237632,874291658240,528271744000,15728822272,2198253613056,45907596773376,328529466417152,1007419817564160,1361675399884800,664565853952000
%N A394012 Triangle T(n,k), n >= 1, 0 <= k <= n-1, read by rows, where T(1,0) = 1 and T(n,k) = 2*(k+1)*(2*k+1) * T(n-1,k+1) + 4*((4*k + 1)*n + 2*k^2 - 3*k - 1) * T(n-1,k) + 2*(4*n + 2*k - 3)*(2*n + k - 3) * T(n-1,k-1), with T(n,k) = 0 if k < 0 or k >= n.
%H A394012 Seiichi Manyama, <a href="/A394012/b394012.txt">Rows n = 1..140, flattened</a>
%e A394012 n\k |       0         1          2          3          4
%e A394012 ----+----------------------------------------------------
%e A394012   1 |       1;
%e A394012   2 |       4,       28;
%e A394012   3 |      88,     1808,      3640;
%e A394012   4 |    4672,   189696,    969024,   1106560;
%e A394012   5 |  454144, 30500608, 283202304, 768866560, 608608000;
%o A394012 (PARI) T(n, k) = if(k<0 || k>=n, 0, if(n==1 && k==0, 1, 2*(k+1)*(2*k+1)*T(n-1, k+1)+4*((4*k+1)*n+2*k^2-3*k-1)*T(n-1, k)+2*(4*n+2*k-3)*(2*n+k-3)*T(n-1, k-1)));
%Y A394012 Columns k=0..1 give A281180, A391180.
%K A394012 nonn,tabl
%O A394012 1,2
%A A394012 _Seiichi Manyama_, Apr 13 2026
