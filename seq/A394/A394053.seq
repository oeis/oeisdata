%U A394053 14,2,2,5,15,2,2,5,15,3,2,5,16,3,2,5,16,3,3,5,17,3,3,5,18,3,3,5,18,3,4
%N A394053 Irregular triangle read by rows: T(n,k) is the number of positive integers <= n with k odd divisors.
%C A394053 T(n,k) is also the number of positive integers <= n with k partitions into consecutive parts.
%C A394053 T(n,k) is also the number of positive integers m <= n whose symmetric representation of sigma(m) has k subparts.
%H A394053 Sean A. Irvine, <a href="/A394053/b394053.txt">Table of n, a(n) for n = 1..10000</a>
%e A394053 Triangle begins:
%e A394053   -----------------
%e A394053    n\k  1  2  3  4
%e A394053   -----------------
%e A394053    1 |  1;
%e A394053    2 |  2;
%e A394053    3 |  2, 1;
%e A394053    4 |  3, 1;
%e A394053    5 |  3, 2;
%e A394053    6 |  3, 3;
%e A394053    7 |  3, 4;
%e A394053    8 |  4, 4;
%e A394053    9 |  4, 4, 1;
%e A394053   10 |  4, 5, 1;
%e A394053   11 |  4, 6, 1;
%e A394053   12 |  4, 7, 1;
%e A394053   13 |  4, 8, 1;
%e A394053   14 |  4, 9, 1;
%e A394053   15 |  4, 9, 1, 1;
%e A394053   16 |  5, 9, 1, 1;
%e A394053   ...
%t A394053 T[nmax_] := Module[{t = Table[DivisorSigma[0, n/2^IntegerExponent[n, 2]], {n, 1, nmax}]}, Table[Tally[t[[1 ;; k]]][[;; , 2]], {k, 1, nmax}] // Flatten]; T[30] (* _Amiram Eldar_, Mar 12 2026 *)
%Y A394053 Row sums give A000027.
%Y A394053 Column 1 gives A070939, n >= 1.
%Y A394053 Analogous to A394052 and A394054.
%Y A394053 Cf. A053624 (row numbers where the triangle widens).
%Y A394053 Cf. A001227, A038547, A237593, A279387, A299765.
%K A394053 nonn,tabf,look,changed
%O A394053 1,2
