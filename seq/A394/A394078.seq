%N A394078 a(n) = Sum_{k=0..n} (-1)^(k + 1) * k^(n - k) * Gamma(k, -k) / exp(k). Row sums of A393142.
%o A394078 (Python)
%o A394078 from mpmath import mp, gammainc, exp, nint
%o A394078 def a(n: int) -> int:
%o A394078     if n == 0: return 1
%o A394078     mp.dps = 50
%o A394078     val = sum((-1)**(k + 1) * k**(n - k) * gammainc(k, -k) / exp(k) for k in range(1, n + 1))
%o A394078     return int(nint(val))
%o A394078 print([a(n) for n in range(21)])
