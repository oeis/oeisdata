%F A394801 G.f. A(x) satisfies A(x) = 1 - x*A(x) + x*A(x)^2 + x^3*A(x) + x^4*d/dx A(x).
%F A394801 a(0) = 1, a(1) = a(2) = 0; a(n) = (n-2)*a(n-3) + Sum_{k=1..n-1} a(k) * a(n-1-k).
%F A394801 a(n) = A394799(n) - Sum_{k=0..n-1} a(k) * A394799(n-1-k).
%F A394801 G.f.: B(x)/(1+x*B(x)), where B(x) is the g.f. of A394799.
%t A394801 terms = 33; A[_] = 1; Do[A[x_] = 1-x^3 * D[Log[1-x*A[x]],x]+O[x]^terms // Normal, terms]; CoefficientList[A[x], x] (* _Stefano Spezia_, Apr 02 2026 *)
