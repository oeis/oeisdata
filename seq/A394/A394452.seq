%N A394452 Greater of two consecutive numbers of the form 2^i*5^j with i, j >= 0, that are coprime.
%H A394452 Michael De Vlieger, <a href="/A394452/b394452.txt">Table of n, a(n) for n = 1..23</a>
%e A394452 Let s = A003592 and b = A394408.
%e A394452 Table of n, a(n) for n = 1..12:
%e A394452  n          b(n)     a(n)
%e A394452 ----------------------------
%e A394452  1     s(1) = 1        2
%e A394452  2     s(3) = 2^2      5
%e A394452  3     s(4) = 5        2^3
%e A394452  4     s(9) = 5^2      2^5
%e A394452  5    s(16) = 5^3      2^7
%e A394452  6    s(25) = 2^9      5^4
%e A394452  7    s(68) = 2^16     5^7
%e A394452  8   s(132) = 2^23     5^10
%e A394452  9   s(217) = 2^30     5^13
%e A394452 10   s(323) = 2^37     5^16
%e A394452 11   s(450) = 2^44     5^19
%e A394452 12   s(598) = 2^51     5^22
%t A394452 s = With[{nn = 10^80}, Union@ Flatten@ Table[2^i* 5^j, {i, 0, Log2[nn]}, {j, 0, Log[5, nn/2^i] } ] ]; Select[Partition[s, 2, 1], CoprimeQ @@ # &][[;; , -1]]
