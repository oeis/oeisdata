%I A394855 #8 Apr 10 2026 08:17:29
%S A394855 8,9,24,25,39,44,45,48,49,56,62,63,74,75,80,81,87,95,98,99,104,116,
%T A394855 117,120,121,125,135,146,147,152,153,168,169,170,171,174,175,183,200,
%U A394855 206,207,224,225,231,244,245,248,249,255,260,261,274,275,278,279,288
%N A394855 Numbers k such that prime tower factorizations of k and k+1 share some prime number.
%C A394855 The prime tower factorization of a number is defined in A182318.
%C A394855 Two consecutive numbers, say k and k+1, cannot share a prime factor (since gcd(k, k+1) = 1). However, their prime tower factorizations can share some prime numbers.
%H A394855 Rémy Sigrist, <a href="/A394855/b394855.txt">Table of n, a(n) for n = 1..10000</a>
%H A394855 Rémy Sigrist, <a href="/A394855/a394855.pdf">Illustration of initial terms</a>
%F A394855 A284761(a(n)) <> 1.
%e A394855 See Links section.
%o A394855 (PARI) A336965(n) = { my (f=factor(n), v=vecprod(f[, 1]~)); for (k=1, #f~, v=lcm(v, A336965(f[k, 2]))); v }
%o A394855 is(k) = gcd(A336965(k), A336965(k+1))!=1
%Y A394855 Cf. A182318, A284761, A286068 (a subsequence).
%K A394855 nonn,new
%O A394855 1,1
%A A394855 _Rémy Sigrist_, Apr 04 2026
