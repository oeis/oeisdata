%N A394200 Expansion of Product_{k>=1} (1 + x^(k*(k+2))) / (1 - x^(k*(k+2))).
%H A394200 Vaclav Kotesovec, <a href="/A394200/b394200.txt">Table of n, a(n) for n = 0..10000</a>
%F A394200 a(n) ~ Gamma(1 + b/d) * ((4-sqrt(2))*zeta(3/2))^(2/3 + b/(3*d)) * d^(1/6 + b/(3*d)) * exp(3*Pi^(1/3) * ((4-sqrt(2))*zeta(3/2))^(2/3) * (n/d)^(1/3) / 4) / (2^(7/2 + 3*b/(2*d)) * sqrt(3) * Pi^(7/6 - b/(6*d)) * n^(7/6 + b/(3*d))), where d = 1, b = 2.
%t A394200 nmax = 150; CoefficientList[Series[Product[(1 + x^(k*(k+2))) / (1 - x^(k*(k+2))), {k, 1, Floor[Sqrt[1 + nmax] + 1]}], {x, 0, nmax}], x]
