%T A394873 145,164,180,201,219,244,264,291,315,345,371,405,434,471,504,544,580,
%U A394873 625,664,712,756,808,855,912,963,1024,1080,1145,1205,1276,1340,1415,1485,1565,1639
%N A394873 Number of 1's in the partitions of n into exactly 5 parts.
%H A394873 Seiichi Manyama, <a href="/A394873/b394873.txt">Table of n, a(n) for n = 0..10000</a>
%H A394873 <a href="/index/Par#part">Index entries for sequences related to partitions</a>
%H A394873 <a href="/index/Rec#order_10">Index entries for linear recurrences with constant coefficients</a>, signature (1,1,0,0,-2,0,0,1,1,-1).
%F A394873 G.f.: x^5 * Sum_{j=0..4} 1 / Product_{k=1..j} (1 - x^k).
%F A394873 G.f.: x^5 * Sum_{j=0..4} (5-j) * x^j / Product_{k=1..j} (1 - x^k).
%F A394873 a(n) = a(n-1) + a(n-2) - 2*a(n-5) + a(n-8) + a(n-9) - a(n-10) for n > 15.
%e A394873 The partitions of 8 into exactly 5 parts are:
%e A394873 41111 contains four 1's.
%e A394873 32111 contains three 1's.
%e A394873 22211 contains two 1's.
%e A394873 So a(8) = 4 + 3 + 2 = 9.
%o A394873 (PARI) my(N=60, x='x+O('x^N)); concat([0, 0, 0, 0, 0], Vec(x^5*sum(j=0, 4, 1/prod(k=1, j, 1-x^k))))
%Y A394873 Column k=5 of A394828.
%Y A394873 Cf. A026811.
%K A394873 nonn,easy,new
%O A394873 0,6
%A A394873 _Seiichi Manyama_, May 13 2026
