%U A394716 23075728090638862938144768,50829133553976135556548919296,139764726764087926884028696756224,472500813583621452881213310763008000
%N A394716 a(n) = Sum_{1 <= i < j <= n} ( n!/(i*j) )^3.
%H A394716 Seiichi Manyama, <a href="/A394716/b394716.txt">Table of n, a(n) for n = 0..181</a>
%H A394716 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/HarmonicNumber.html">Harmonic Number</a>
%F A394716 a(n) = (n!)^3 * (H(n,3)^2 - H(n,6))/2 where H(n,r) = Sum_{k=1..n} 1/k^r.
%F A394716 a(n) = A249677(n,n-2) = [x^(n-2)] Product_{k=0..n} (1 + k^3*x).
%F A394716 a(n) = (n^3 + (n-1)^3) * a(n-1) - (n-1)^6 * a(n-2) + ((n-2)!)^3 for n > 1.
%o A394716 (PARI) a(n) = polcoef(prod(k=0, n, 1+k^3*x), n-2);
%Y A394716 Cf. A000399, A001820, A395068.
%Y A394716 Cf. A249677.
