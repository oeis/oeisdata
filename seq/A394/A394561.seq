%t A394561 achillesQ[x_] := And[Min[#] > 1, GCD @@ # == 1] &[FactorInteger[x][[;; , -1]] ]; s = With[{nn = 2^13}, Rest@ Select[Union@ Flatten@ Table[a^2*b^3, {b, Surd[nn, 3]}, {a, Sqrt[nn/b^3] } ], Not @* PrimePowerQ] ]; Table[DivisorSum[s[[n]], 1 &, achillesQ], {n, 100}]
