%U A394912 0,0,0,0,1,10,10,6,0,0,0,0,1,16,3,0,1,20,5,0,0,0,1
%N A394912 Irregular triangle read by rows: T(n,k) = number of k-gonal faces in Johnson solid J_n, with 3 <= k <= A394913(n).
%C A394912 A 10-gon is the highest-sided polygon a Johnson solid can have as a face.
%C A394912 All terms in columns k = 7 and k = 9 are zero (there are no Johnson solids with heptagons or 9-gons as faces).
%H A394912 Paolo Xausa, <a href="/A394912/b394912.txt">Table of n, a(n) for n = 1..356</a> (all 92 rows, flattened).
%H A394912 Wikipedia, <a href="https://en.wikipedia.org/wiki/List_of_Johnson_solids">List of Johnson solids</a>.
%e A394912 Triangle begins:
%e A394912   n\k|   3   4   5   6   7   8   9  10
%e A394912   -------------------------------------
%e A394912    1 |   4,  1;
%e A394912    2 |   5,  0,  1;
%e A394912    3 |   4,  3,  0,  1;
%e A394912    4 |   4,  5,  0,  0,  0,  1;
%e A394912    5 |   5,  5,  1,  0,  0,  0,  0,  1;
%e A394912    6 |  10,  0,  6,  0,  0,  0,  0,  1;
%e A394912    7 |   4,  3;
%e A394912    8 |   4,  5;
%e A394912    9 |   5,  5,  1;
%e A394912   10 |  12,  1;
%e A394912   11 |  15,  0,  1;
%e A394912   12 |   6;
%e A394912   13 |  10;
%e A394912   14 |   6,  3;
%e A394912   15 |   8,  4;
%e A394912   16 |  10,  5;
%e A394912   17 |  16;
%e A394912   18 |   4,  9,  0,  1;
%e A394912   19 |   4, 13,  0,  0,  0,  1;
%e A394912   20 |   5, 15,  1,  0,  0,  0,  0,  1;
%e A394912   ...
%e A394912 Johnson solid J_6 (pentagonal rotunda) has 10 triangular faces, 0 square faces, 6 pentagonal faces, 0 hexagonal faces, 0 heptagonal faces, 0 octagonal faces, 0 9-gonal faces and 1 10-gonal face.
%t A394912 A394912row[n_] := BinCounts[#, {3, Max[#] + 1}] & [Map[Length, PolyhedronData["J" <> ToString[n], "FaceIndices"]]];
%t A394912 Array[A394912row, 92] (* Gives the full sequence *)
%o A394912 (Python)
%o A394912 def A394912(n, k=None): # see A394913 for definition of JS
%o A394912     "Return [T(n,k), k = 3 .. A394913(n)] if k is not given."
%o A394912     if (L := getattr(A394912, f"J{n}", 0))==0:
%o A394912         setattr(A394912, f"J{n}", L := [len(f) for f in JS[n-1]['faces']])
%o A394912     return sum(L==k for L in L) if k else [A394912(n, k)for k in range(3,max(L)+1)]
%o A394912 for n in range(1,20): print(A394912(n)) # _M. F. Hasler_, Apr 10 2026
%Y A394912 Cf. A242731 (row sums), A394913 (row lengths + 2), A394914 (right border).
%Y A394912 Cf. A343954 (column k = 3).
%Y A394912 Cf. other columns (padded with 0's): A343955 (k = 4), A343956 (k = 5), A343957 (k = 6), A343958 (k = 8), A343959 (k = 10).
%Y A394912 Cf. A306949 (number of nonzero elements in each row).
