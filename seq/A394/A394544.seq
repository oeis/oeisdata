%S A394544 1,1,2,3,2,5,3,7,2,3,11,11,11,11,11,11,11,11,11,101,37,11,131,47,151,
%T A394544 23,19,181,191,101,53,37,29,11,7,131,17,47,73,101,313,19,37,7,353,11,
%U A394544 373,383,131,101,23,53,31,37,227,29,79,11,19,101,103,7,107,109,37
%N A394544 Largest prime factor of the n-th base 10 palindrome with a(1)=a(2)=1.
%H A394544 Paolo Xausa, <a href="/A394544/b394544.txt">Table of n, a(n) for n = 1..10000</a>
%F A394544 a(n) = A006530(A002113(n)) for n>1.
%t A394544 Join[{1}, Map[FactorInteger[#][[-1, 1]] &, Select[Range[1000], PalindromeQ]]] (* _Paolo Xausa_, Mar 30 2026 *)
%o A394544 (Python)
%o A394544 from sympy import integer_log, primefactors
%o A394544 def A394544(n):
%o A394544     if n == 1: return 1
%o A394544     x = 10**integer_log(n>>1,10)[0]
%o A394544     y = 10*x
%o A394544     return max(primefactors((c:=n-x)*x+int(str(c)[-2::-1] or '0') if n<x+y else (c:=n-y)*y+int(str(c)[::-1] or '0')),default=1) # _Chai Wah Wu_, Mar 30 2026
%Y A394544 Cf. A006530, A002113, A394545, A394546.
%K A394544 nonn,easy,base
%O A394544 1,3
