%I A394864 #14 Apr 13 2026 18:03:39
%S A394864 1,1,1,4,7,34,70,368,819,4494,10471,59024,141747,813932
%N A394864 Number of achiral polyominoes with n octagonal cells of the hyperbolic regular tiling with Schläfli symbol {8,8}.
%C A394864 The Mathematica program below is for any regular tiling with Schläfli symbol {p,q} and 1/p + 1/q <= 1/2. It works for only n < 2q - 2. Another program for oriented polyominoes allows us to calculate the other two chirality classes. Note that for n <= q, the results are the same as for {p,oo}. An achiral polyomino has an axis of symmetry.
%F A394864 a(n) = 2*A393744(n) - A394862(n) = A394862(n) - 2*A394863(n) = A393744(n) - A394863(n).
%t A394864 p = 8; q = 8; nmax = 2q - 3; (* does not work for n>2q-3 *)
%t A394864 Table[If[EvenQ[n],Binomial[(p-1)n/2,n/2]/((p-2)n/2+1),If[OddQ[p],(p-1)Binomial[(p-1)n/2-1,(n-1)/2]/((p-2)n+1),p Binomial[(p-1)n/2-1/2,(n-1)/2]/((p-2)n+2)]]-If[n<q,0,If[OddQ[p],If[OddQ[q],If[OddQ[n-q],((p-2)(q-1)+2)Binomial[((p-1)n-q+1)/2,(n-q+1)/2]/((p-2)n+2)+(p(q+1)-2q)Binomial[((p-1)n-q-1)/2,(n-q-1)/2]/((p-2)n+2)-(p-2)(q-1)Binomial[((p-1)n-q-1)/2,(n-q+1)/2]/((p-2)n)-(p-2)(q+1)Binomial[((p-1)n-q-3)/2,(n-q-1)/2]/((p-2)n),((p-2)q+1)Binomial[((p-1)n-q-1)/2,(n-q)/2]/((p-2)n+1)-((p-2)q-1)Binomial[((p-1)n-q-3)/2,(n-q)/2]/((p-2)n-1)],If[OddQ[n-q],((p-2)(q-1)+1)Binomial[((p-1)n-q)/2,(n-q+1)/2]/((p-2)n+1)-((p-2)(q-1)-1)Binomial[((p-1)n-q-2)/2,(n-q+1)/2]/((p-2)n-1)-(((p-2)(q+1)-1))Binomial[((p-1)n-q)/2-2,(n-q-1)/2]/((p-2)n-1),2((p-2)q+2)Binomial[((p-1)n-q)/2,(n-q)/2]/((p-2)n+2)-2((p-2)q)Binomial[((p-1)n-q-2)/2,(n-q)/2]/((p-2)n)]],If[OddQ[q],If[OddQ[n-q],(((p-2)(q-1)+2)/2)Binomial[((p-1)n-q+1)/2,(n-q+1)/2]/((p-2)n/2+1)-(p-2)(q-1)Binomial[((p-1)n-q-1)/2,(n-q+1)/2]/((p-2)n),((p-2)q+2)Binomial[((p-1)n-q)/2,(n-q)/2]/((p-2)n+2)-((p-2)q)Binomial[((p-1)n-q-2)/2,(n-q)/2]/((p-2)n)],If[OddQ[n-q],((p-2)(q-1)+2)Binomial[((p-1)n-q+1)/2,(n-q+1)/2]/((p-2)n+2)-(p-2)(q-1)Binomial[((p-1)n-q-1)/2,(n-q+1)/2]/((p-2)n),((p-2)q+2)Binomial[((p-1)n-q)/2,(n-q)/2]/((p-2)n+2)-((p-2)q)Binomial[((p-1)n-q-2)/2,(n-q)/2]/((p-2)n)]]]],{n,0,nmax}]
%Y A394864 Cf. A394862 (oriented), A393744 (unoriented), A394863 (chiral), A143547 {8,oo}.
%K A394864 nonn,hard,more,new
%O A394864 0,4
%A A394864 _Robert A. Russell_, Apr 04 2026
