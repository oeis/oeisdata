%S A394166 0,1,2,4,8,5,10,16,32,3,33,48,256,6,34,64,40,17,9,65,41,80,128,7,130,
%T A394166 144,18,19,146,272,512,20,42,21,136,68,138,69,160,81,11,257,168,84,
%U A394166 162,85,170,260,514,36,66,37,258,129,24,25,384,385,26,1024,192,12
%N A394166 Lexicographically earliest sequence of distinct nonnegative integers whose binary plot has no two pixels within a knights' move's distance.
%C A394166 For any k >= 0, the first term >= 2^k is a power of two.
%C A394166 Is this a permutation of the nonnegative integers?
%H A394166 Rémy Sigrist, <a href="/A394166/b394166.txt">Table of n, a(n) for n = 0..10000</a>
%H A394166 Rémy Sigrist, <a href="/A394166/a394166_1.gp.txt">PARI program</a>
%F A394166 a(n) AND 4*a(n+1) = 0 (where AND denotes the bitwise AND operator).
%F A394166 4*a(n) AND a(n+1) = 0.
%F A394166 a(n) AND 2*a(n+2) = 0.
%F A394166 2*a(n) AND a(n+2) = 0.
%e A394166 The first terms, alongside their binary expansions with dots instead of zeros, are:
%e A394166   n   a(n)  bin(a(n))
%e A394166   --  ----  ---------
%e A394166    0     0
%e A394166    1     1          1
%e A394166    2     2         1.
%e A394166    3     4        1..
%e A394166    4     8       1...
%e A394166    5     5        1.1
%e A394166    6    10       1.1.
%e A394166    7    16      1....
%e A394166    8    32     1.....
%e A394166    9     3         11
%e A394166   10    33     1....1
%e A394166   11    48     11....
%e A394166   12   256  1........
%e A394166   13     6        11.
%e A394166   14    34     1...1.
%e A394166   15    64    1......
%e A394166   16    40     1.1...
%o A394166 (PARI) \\ See Links section.
%o A394166 (Python)
%o A394166 from itertools import count, islice
%o A394166 def agen(): # generator of terms
%o A394166     aset, m, an2, an1 = {0, 1}, 2, 0, 1
%o A394166     yield from [0, 1]
%o A394166     for n in count(2):
%o A394166         mask = (an1<<2)|(an1>>2)|(an2<<1)|(an2>>1)
%o A394166         an2, an1 = an1, next(k for k in count(m) if not (k in aset or k&mask))
%o A394166         yield an1
%o A394166         aset.add(an1)
%o A394166         while m in aset: m += 1
%o A394166 print(list(islice(agen(), 62))) # _Michael S. Branicky_, May 25 2026
%Y A394166 Cf. A109812, A396426, A396484.
%K A394166 nonn,base,new
%O A394166 0,3
