%U A394779 168872984900652293940,15033758089387826162280,1427064430403254319969700,143904080643463039108019439,15364277472812027516420970837
%N A394779 G.f. A(x) satisfies A(x) = 1 - 3*x * d/dx log(1 - x*A(x)^2).
%H A394779 Vincenzo Librandi, <a href="/A394779/b394779.txt">Table of n, a(n) for n = 0..300</a>
%F A394779 G.f. A(x) satisfies A(x) = 1 + x*A(x)^2*(2 + A(x)) + 3*x^2*d/dx(A(x)^2).
%F A394779 a(0) = 1; a(n) = (3*n-1) * Sum_{k=0..n-1} a(k) * a(n-1-k) + Sum_{i, j, k>=0 and i+j+k=n-1} a(i) * a(j) * a(k).
%t A394779 a={1};nmax=20; Do[s1=Sum[a[[k+1]] a[[n-k]],{k,0,n-1}]; s2=Sum[a[[i+1]] a[[j+1]] a[[n-1-i-j+1]{i,0,n-1},{j,0,n-1-i}]; AppendTo[a,(3 n-1) s1+s2];,{n,1,nmax}]; a (* _Vincenzo Librandi_, Apr 02 2026 *)
%o A394779 (Magma) nmax := 20; a := [1]; for n in [1..nmax] do s1 := &+[a[k+1]*a[n-k]: k in [0..n-1]]; s2 := &+[&+[a[i+1]*a[j+1]*a[n-i-j]: j in [0..n-1-i]]: i in [0..n-1]];Append(~a, (3*n-1)*s1+s2); end for; a; // _Vincenzo Librandi_, Apr 02 2026
