%U A394198 960261079538073600,33735701275921612800,1251834624646683033600,48927351154151522304000,2009139126253980431155200,86482397103403554570240000
%N A394198 Total number of linear intervals in the weak order on the Coxeter group D_n.
%C A394198 An interval is linear of height k if it is isomorphic to the total order on k+1 elements.
%C A394198 See A394193 for the number of linear intervals of a given height.
%o A394198 (SageMath)
%o A394198 def a(n):
%o A394198     s = 1 + n/2
%o A394198     for k in range(2, n):
%o A394198         s += 2 * (n-k+1)/(k+1)
%o A394198         if k == 3:
%o A394198             s += 1/2
%o A394198     return s * factorial(n) * 2^(n-1)
%o A394198 print([a(n) for n in range(4, 20)])
%Y A394198 Cf. A002866, A344216 (type A), A394191 (type B), A394193.
%K A394198 nonn,new
%O A394198 4,1
