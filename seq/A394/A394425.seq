%N A394425 The number of exponential divisors of the biquadratefree numbers.
%H A394425 Amiram Eldar, <a href="/A394425/b394425.txt">Table of n, a(n) for n = 1..10000</a>
%F A394425 a(n) = A049419(A046100(n)).
%F A394425 a(n) = A278908(A046100(n)).
%F A394425 a(n) = A307848(A046100(n)).
%F A394425 a(n) = A323308(A046100(n)).
%F A394425 Asymptotic mean: Limit_{m->oo} (1/m) * Sum_{k=1..m} a(k) = zeta(4) * Product_{p prime} (1 + 1/p^2 - 2/p^4) = 1.441534735906095536828... .
%t A394425 f[p_, e_] := If[e < 4, DivisorSigma[0, e], 0]; s[1] = 1; s[n_] := Times @@ f @@@ FactorInteger[n]; Select[Array[s, 150], # > 0 &]
%o A394425 (PARI) list(lim) = {my(d); for(k = 1, lim, d = vecprod(apply(x -> if(x < 4, numdiv(x), 0), factor(k)[, 2])); if(d > 0, print1(d, ", ")));}
