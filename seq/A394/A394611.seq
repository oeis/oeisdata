%T A394611 13,15,17,21,26,18,22,22,24,27,22,26,30,28,37,20,26,36,27,27,29,29,31,
%U A394611 30,40,36,35,38,31,33,44,43,37,47,33,46,44,48,46,48,50,51,43,45,38,35,46,55,45,43,49,61,49,63,52
%N A394611 a(1) = 0. For n > 1, a(n) is the number of ways to write a(n-1) as the sum of two previous terms with distinct positions in the sequence.
%C A394611 Conjecture: Many numbers, beginning with 5 and 9, never occur in this sequence (see A397471).
%C A394611 It follows from the Erdős-Fuchs theorem that the average behavior of a representation function cannot be too close to a linear function, but it is still possible to give an estimate for the growth of this sequence as n/sqrt(2) because if we write g(x) = Sum_{k>=0} x^floor(k/sqrt(2)), then we know that [x^m] (1/2)*(g(x)^2-g(x^2)) will be relatively close to m or even exactly m in many cases. - _Thomas Scheuerle_, Jun 29 2026
%H A394611 Sean A. Irvine, <a href="/A394611/b394611.txt">Table of n, a(n) for n = 1..10000</a>
%H A394611 Sean A. Irvine, <a href="/A394611/a394611_1.txt.gz">Table of n, a(n) for n = 1..1000000</a> [4.3M, gzip]
%F A394611 a(n) = [x^a(n-1)] (1/2)*(g(x)^2-g(x^2)), where g(x) = Sum_{k=1..n-1} x^a(k). - _Thomas Scheuerle_, Jun 29 2026
%e A394611 a(2) = 0, since we only have one previous term.
%e A394611 a(3) = 1, since a(1) + a(2) = a(2).
%e A394611 a(4) = 2, since a(1) + a(3) = a(3) and a(2) + a(3) = a(3).
%p A394611 P:=proc(q) local a,b,j,k,n,v; v:=[0]; for n from 1 to q do a:=v[nops(v)]; b:=0;
%p A394611 for k from 1 to nops(v)-1 do for j from k+1 to nops(v) do if v[k]+v[j]=a then b:=b+1;
%p A394611 fi; od; od; v:=[op(v),b]; od; op(v); end: P(100); # _Paolo P. Lava_, Jul 02 2026
%o A394611 (Python)
%o A394611 def sequence(N=100):
%o A394611     a = [0]  # a(1) = 0
%o A394611     for n in range(1, N):
%o A394611         target = a[n - 1]  # a(n)
%o A394611         count = 0
%o A394611         # count pairs (i < j) with i,j in [0..n-1]
%o A394611         for i in range(n):
%o A394611             for j in range(i + 1, n):
%o A394611                 if a[i] + a[j] == target:
%o A394611                     count += 1
%o A394611         a.append(count)
%o A394611     return a
%o A394611 seq = sequence(100)
%o A394611 print(seq)
%o A394611 (Python)
%o A394611 from collections import Counter
%o A394611 from itertools import islice
%o A394611 def A394611_gen(): # generator of terms
%o A394611     alst, an, c = [], 0, Counter()
%o A394611     while True:
%o A394611         an = c[an]
%o A394611         yield an
%o A394611         c.update(an+ai for ai in alst)
%o A394611         alst.append(an)
%o A394611 print(list(islice(A394611_gen(), 83))) # _Michael S. Branicky_, Jun 26 2026
%o A394611 (PARI)
%o A394611 ListA(max_n) = {my(M=Map(), v=[0], c=0, p=0);  while(#v<max_n, c=0; mapisdefined(M, v[#v], &c); v=concat(v, c); for(k=1, #v-1, c=0; p=v[#v]+v[k]; mapisdefined(M, p, &c); mapput(~M, p, c+1))); v} \\ _Thomas Scheuerle_, Jun 29 2026
