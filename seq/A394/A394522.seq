%N A394522 E.g.f. A(x) satisfies A(x) = 1/(1 - 4*x*A(x)^2)^(1/4).
%H A394522 Vincenzo Librandi, <a href="/A394522/b394522.txt">Table of n, a(n) for n = 0..300</a>
%F A394522 a(n) = 4^n * n! * binomial((6*n+1)/4,n)/(6*n+1).
%t A394522 a[n_]:=If[n==0,1,Product[(6*n+1-4*k),{k,0,n-1}]/(6*n+1)];Table[a[n],{n,0,18}] (* _Vincenzo Librandi_, Mar 27 2026 *)
%o A394522 (PARI) a(n) = 4^n*n!*binomial((6*n+1)/4, n)/(6*n+1);
%o A394522 (Magma) [n eq 0 select 1 else (4^n*&*[((6*n+1)/4-k): k in [0..n-1] ])/(6*n+1): n in [0..23]]; // _Vincenzo Librandi_, Mar 27 2026
