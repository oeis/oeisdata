%e A394823   [9]  0, 1, 43690, 3215397, 13021320, 8666515, 1508988, 84966, 1632, 9;
%p A394823 u := sqrt(2*x*(cosh(y^(1/2)) - 1)): ser := series(1 + u*sinh(u)/2, y, 11):
%p A394823 ycoeff := n -> expand((2*n)!*simplify(coeff(ser, y, n))):
%p A394823 row := n -> local k; seq(coeff(ycoeff(n), x, k), k = 0..n):
%p A394823 seq(print(row(n)), n = 0..9);
%o A394823 (Python)
%o A394823 from functools import cache
%o A394823 @cache
%o A394823 def cfact2(n, j):
%o A394823     if j == 0: return int(n == 0)
%o A394823     if j < 1 or j > n: return 0
%o A394823     return cfact2(n-1, j-1) + j * j * cfact2(n-1, j)
%o A394823 def T(n, j): return 1 if n == 0 else j*cfact2(n, j)
%o A394823 for n in range(10): print([T(n, j) for j in range(n + 1)])
%Y A394823 Cf. A108678 (subdiagonal), A020988 (column 1), A394822 (row sums), A394813 (row reversed and (1,1)-based).
