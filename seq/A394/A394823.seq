%N A394823 Triangle read by rows: T(n, k) = (2*n)! * [x^k] [y^n] (1 + u*sinh(u)/2) where u = sqrt(2*x*(cosh(y^(1/2)) - 1)).
%e A394823 Triangle starts:
%e A394823   [0]  1;
%e A394823   [1]  0, 1;
%e A394823   [2]  0, 1,     2;
%e A394823   [3]  0, 1,    10,       3;
