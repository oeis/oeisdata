%S A394114 0,1,2,8,39,208,1167,6765,40130,242202,1481760,9165540,57215859,
%T A394114 359958581,2279833865,14524538490,93015366122,598436440310,
%U A394114 3866256171094,25072771650309,163157870767460,1065080825123292,6972959424775712,45773731747620847,301228328628125486
%N A394114 G.f. A(x) satisfies A(x)^8-3*A(x)^7+(7x+3)*A(x)^6-(14x+1)*A(x)^5+(13x^2+8x)*A(x)^4-(14x^2+x)*A(x)^3+(7x^3+3x^2)*A(x)^2-3x^3*A(x)+x^4=0.
%C A394114 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with green root where red vertices can only be followed by red vertices, blue vertices can only be followed by red or blue vertices, and green vertices can only be followed by blue or green vertices.
%H A394114 Nathan Fox, <a href="/A394114/b394114.txt">Table of n, a(n) for n = 0..300</a>
%H A394114 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394114 (Python)
%o A394114 def A394114(n):
%o A394114     A = [[1, 0, 0], [1, 1, 0], [0, 1, 1]]
%o A394114     if n == 0:
%o A394114         return 0
%o A394114     m = len(A)
%o A394114     output = [[1] for i in range(m)]
%o A394114     for l in range(2, n + 1):
%o A394114         for i in range(m):
%o A394114             term = 0
%o A394114             for k in range(1, l):
%o A394114                 for j in range(m):
%o A394114                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394114             output[i].append(term)
%o A394114     return output[2][n - 1]
%K A394114 nonn,new
%O A394114 0,3
%A A394114 _Nathan Fox_, Mar 11 2026
