%I A394482 #7 Mar 31 2026 20:01:59
%S A394482 10800,16200,18000,21168,31752,40500,43200,45000,49392,52272,64800,
%T A394482 67500,72000,73008,78408,84672,97200,98000,109512,111132,124848,
%U A394482 127008,137200,145800,155952,172800,172872,180000,187272,190512,191664,197568,209088,228528,233928
%N A394482 Achilles numbers whose prime power factor multiplicities are not pairwise indivisible.
%C A394482 Proper subset of A394000, in turn a proper subset of A393708.
%C A394482 Smallest a(n) with m distinct prime factors is 12*A002110(m) for m > 2.
%C A394482 Intersection of A052486 and A317101 = A052486 \ A317616.
%H A394482 Michael De Vlieger, <a href="/A394482/b394482.txt">Table of n, a(n) for n = 1..10000</a>
%H A394482 <a href="/index/Pow#powerful">Index entries for sequences related to powerful numbers</a>.
%e A394482 Let s = A052486.
%e A394482 Table of n, a(n) for select n:
%e A394482    n                          a(n)
%e A394482   ----------------------------------------------------------------------
%e A394482       1       s(64) =       10800 = 2^4 * 3^3 * 5^2
%e A394482       2       s(84) =       16200 = 2^3 * 3^4 * 5^2
%e A394482       3       s(89) =       18000 = 2^4 * 3^2 * 5^3
%e A394482       4       s(98) =       21168 = 2^4 * 3^3 * 7^2
%e A394482       5      s(127) =       31752 = 2^3 * 3^4 * 7^2
%e A394482      59      s(625) =      496125 = 3^4 * 5^3 * 7^2
%e A394482      62      s(643) =      529200 = 2^4 * 3^3 * 5^2 * 7^2
%e A394482    1555     s(8363) =    64033200 = 2^4 * 3^3 * 5^2 * 7^2 * 11^2
%e A394482   27221   s(116468) = 10821610800 = 2^4 * 3^3 * 5^2 * 7^2 * 11^2 * 13^2
%t A394482 nn = 2^18; fQ[x_] := And[GCD @@ # == 1, Count[Tuples[#, 2], _?(And[UnsameQ @@ #, Divisible @@ #] &)] > 0] &[FactorInteger[x][[All, -1]] ]; Union@ Flatten@ Table[If[fQ[#], #, Nothing] &[a^2*b^3], {b, Surd[nn, 3]}, {a, Sqrt[nn/b^3] } ]
%Y A394482 Cf. A001694, A013929, A024619, A052486, A126706, A286708, A317101, A393708, A394000.
%K A394482 nonn,easy
%O A394482 1,1
