%I A394734 #5 Apr 15 2026 00:03:27
%S A394734 1,2,2,1,5,1,3,7,3,2,10,3,2,34,2,0,31,1,6,25,1,23,21,2,1,1,20,4,1,278,
%T A394734 13,15,1,15,116,9,11,12,4,197,1,2,751,1,42,2,9,12,6,2,151,169,7,1,9,8,
%U A394734 6,2157,1,516,1,6,121,130,1,6,119,1,469,4,446,1,4,6
%N A394734 a(n) is the number of subsets of proper divisors of A023196(n) that add to A023196(n).
%C A394734 a(n) is the number of partitions of A023196(n) into distinct proper divisors of A023196(n).
%H A394734 Felix Huber, <a href="/A394734/b394734.txt">Table of n, a(n) for n = 1..1000</a>
%F A394734 a(n) = 0 iff A023196(n) is weird (A006037).
%F A394734 a(n) = 1 iff A023196(n) is a term of A064771.
%e A394734 a(2) = 2 because A023196(2) = 12, whose proper divisors are {1, 2, 3, 4, 6}. Exactly two subsets of these divisors sum to 12: {1, 2, 3, 6} and {2, 4, 6}.
%p A394734 with(NumberTheory):
%p A394734 f := proc(n)
%p A394734     local l, g;
%p A394734     l := [op(Divisors(n) minus {n})];
%p A394734     g := proc(m, i) option remember;
%p A394734         `if`(m = 0, 1, `if`(i < 1, 0, g(m, i - 1) + `if`(l[i] > m, 0, g(m - l[i], i - 1))))
%p A394734     end proc:
%p A394734     g(n, nops(l));
%p A394734 end proc:
%p A394734 A394734 := proc(n)
%p A394734     local k, c;
%p A394734     k := 1;
%p A394734     c := 0;
%p A394734     do
%p A394734         k := k + 1;
%p A394734         if sigma(k) >= 2*k then
%p A394734             c := c + 1;
%p A394734             if c = n then
%p A394734                 return f(k);
%p A394734             end if;
%p A394734         end if;
%p A394734     end do;
%p A394734 end proc:
%p A394734 seq(A394734(n), n = 1 .. 74);
%Y A394734 Cf. A000396, A005835, A006037, A023196, A027750, A064771, A096356.
%K A394734 nonn,new
%O A394734 1,2
%A A394734 _Felix Huber_, Apr 10 2026
