%U A394281 2053230379200,22585534171200,432889404948000,6233607431251200,96101447898456000,1328104694380464000
%N A394281 Number of partitions of [n] whose set of block sizes equals [k] for k = A003056(n).
%C A394281 k = A003056(n) is the largest integer such that the k-th triangular number A000217(k) is <= n.
%C A394281 The sequence is not monotonic: a(n) < a(n-1) for all triangular numbers n >= 15.
%H A394281 Alois P. Heinz, <a href="/A394281/b394281.txt">Table of n, a(n) for n = 0..685</a>
%H A394281 Wikipedia, <a href="https://en.wikipedia.org/wiki/Partition_of_a_set">Partition of a set</a>
%F A394281 a(A000217(n)) = A022915(n).
%F A394281 a(n) <= A393098(n).
%e A394281 a(4) = 6: 12|3|4, 13|2|4, 1|23|4, 14|2|3, 1|24|3, 1|2|34.
%e A394281 a(5) = 25: 12|34|5, 12|35|4, 12|3|45, 12|3|4|5, 13|24|5, 13|25|4, 13|2|45, 13|2|4|5, 14|23|5, 15|23|4, 1|23|45, 1|23|4|5, 14|25|3, 14|2|35, 14|2|3|5, 15|24|3, 1|24|35, 1|24|3|5, 15|2|34, 1|25|34, 1|2|34|5, 15|2|3|4, 1|25|3|4, 1|2|35|4, 1|2|3|45.
%p A394281 f:= proc(n) option remember; floor((sqrt(1+8*n)-1)/2) end:
%p A394281 b:= proc(n, i) option remember; uses combinat; `if`(n=0,
%p A394281       `if`(i=0, 1, 0), add(b(n-i*j, i-1)*multinomial
%p A394281           (n, n-i*j, i$j)/j!, j=`if`(i=1, n, 1..n/i)))
%p A394281     end:
%p A394281 a:= n-> b(n, f(n)):
%p A394281 seq(a(n), n=0..26);
%Y A394281 Cf. A000110, A000217, A003056, A022915, A393098.
%Y A394281 Last elements of rows in A387082.
