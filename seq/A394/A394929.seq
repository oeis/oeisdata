%N A394929 Decimal expansion of Sum_{n>=3} 1/(n*log(n)^2*log(log(n))^2).
%e A394929 33.356072619438034552727014285...
%t A394929 Sum[1/(n Log[n]^2 Log[Log[n]]^2), {n, 3, Infinity}]
%o A394929 (PARI)
%o A394929 /* procedure by Bill Allombert */
%o A394929 sumposlog(g)=sumalt(k=1,(-1)^(k+1)*sumpos(n=0,g(log(k)+n*log(2))/k))
%o A394929 sumposlog(n->if(n>=1,1/(n^2*log(n)^2)))
