%S A394140 0,1,1,4,22,138,930,6561,47800,356728,2712758,20944303,163738947,
%T A394140 1293610671,10312170488,82843804507,670045658032,5451693184584,
%U A394140 44591169828366,366447128131373,3024200357007623,25053501077514721,208272200149758543,1736864093227610857
%N A394140 G.f. A(x) satisfies (x+1)*A(x)^5-x*A(x)^4-(2x^2+x)*A(x)^3+(2x^3+3x^2)*A(x)^2-3x^3*A(x)+x^4=0.
%C A394140 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with red root where red vertices can only be followed by blue vertices, blue vertices can be followed by vertices of any colors, and green vertices can be followed by red or green vertices.
%H A394140 Nathan Fox, <a href="/A394140/b394140.txt">Table of n, a(n) for n = 0..300</a>
%H A394140 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394140 (Python)
%o A394140 def A394140(n):
%o A394140     A = [[0, 1, 0], [1, 1, 1], [1, 0, 1]]
%o A394140     if n == 0:
%o A394140         return 0
%o A394140     m = len(A)
%o A394140     output = [[1] for i in range(m)]
%o A394140     for l in range(2, n + 1):
%o A394140         for i in range(m):
%o A394140             term = 0
%o A394140             for k in range(1, l):
%o A394140                 for j in range(m):
%o A394140                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394140             output[i].append(term)
%o A394140     return output[0][n - 1]
%Y A394140 Cf. A394141, A394142.
%K A394140 nonn,new
%O A394140 0,4
