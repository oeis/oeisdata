%S A394113 0,1,2,8,38,196,1062,5948,34122,199368,1181946,7091104,42970030,
%T A394113 262614732,1616892286,10019797940,62450153746,391237723920,
%U A394113 2462401840434,15563223849080,98741660652470,628666916068948,4015472430316566,25724064741436780,165246645058125658
%N A394113 G.f. A(x) satisfies A(x)^4-(x+1)*A(x)^3+4*x*A(x)^2-(x^2+x)*A(x)+x^2=0.
%C A394113 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with green root where red vertices can only occur as leaves, blue vertices can only be followed by red or blue vertices, and green vertices can be followed by blue or green vertices.
%H A394113 Nathan Fox, <a href="/A394113/b394113.txt">Table of n, a(n) for n = 0..300</a>
%H A394113 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394113 (Python)
%o A394113 def A394113(n):
%o A394113     A = [[0, 0, 0], [1, 1, 0], [0, 1, 1]]
%o A394113     if n == 0:
%o A394113         return 0
%o A394113     m = len(A)
%o A394113     output = [[1] for i in range(m)]
%o A394113     for l in range(2, n + 1):
%o A394113         for i in range(m):
%o A394113             term = 0
%o A394113             for k in range(1, l):
%o A394113                 for j in range(m):
%o A394113                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394113             output[i].append(term)
%o A394113     return output[2][n - 1]
%K A394113 nonn
%O A394113 0,3
%A A394113 _Nathan Fox_, Mar 11 2026
