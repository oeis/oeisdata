%N A394853 Expansion of g^7/(6-5*g)^4, where g = 1+x*g^6 is the g.f. of A002295.
%F A394853 G.f.: (Sum_{k>=0} binomial(6*k+3,k) * x^k) * (Sum_{k>=0} binomial(6*k,k) * x^k)^3.
%F A394853 Sum_{k>=1} a(k-1) * x^k/k^2 = (1/12) * log( Sum_{k>=0} binomial(6*k+6,k) * x^k ).
%F A394853 a(n) = ((n+1)/12) * (binomial(6*n+5,n) + Sum_{k=0..n+1} 5^(n+1-k) * binomial(6*n+6,k)).
%o A394853 (PARI) a(n) = (n+1)*(binomial(6*n+5, n)+sum(k=0, n+1, 5^(n+1-k)*binomial(6*n+6, k)))/12;
