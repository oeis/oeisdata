%S A394185 3,13,30,55,89,133,188,255,335,429,538,663,805,965,1144,1343,1563,
%T A394185 1805,2070,2359,2673,3013,3380,3775,4199,4653,5138,5655,6205,6789,
%U A394185 7408,8063,8755,9485,10254,11063,11913,12805,13740,14719,15743,16813,17930,19095,20309
%N A394185 a(n) = n^3/6 + 3*n^2 + 41*n/6 + 3.
%C A394185 For n >= 1, number of ways to distribute a mass equal to 3 under the repunit list of size n, in a quincunx grid that satisfies the constraint: the value of a cell is <= to the sum of the values of the two cells located just above it.
%H A394185 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (4,-6,4,-1).
%F A394185 a(n) = n^3/6 + 3*n^2 + 41*n/6 + 3.
%e A394185 When n=1, the repunit list of size 1 is [1], under which there exist 13 ways to distribute 3:
%e A394185 -
%e A394185     [1]        [1]        [1]        [1]        [1]        [1]        [1]
%e A394185     1 .        1 .        1 .        1 .        . 1        . 1        . 1
%e A394185    1 . .      1 . .      . 1 .      . 1 .      . 1 .      . 1 .      . . 1
%e A394185   1 . . .    . 1 . .    . 1 . .    . . 1 .    . 1 . .    . . 1 .    . . 1 .
%e A394185 -
%e A394185     [1]        [1]        [1]        [1]        [1]        [1]
%e A394185     . 1        1 1        1 1        1 1        1 .        . 1
%e A394185    . . 1      1 . .      . 1 .      . . 1      1 1 .      . 1 1
%e A394185   . . . 1    . . . .    . . . .    . . . .    . . . .    . . . .
%t A394185 a[n_] := n^3/6 + 3*n^2 + 41*n/6 + 3; Array[a, 45, 0] (* _Amiram Eldar_, May 16 2026 *)
%o A394185 (PARI) a(n)=1/6*n^3+3*n^2+41/6*n+3
%o A394185 vector(45, n, a(n-1))
%Y A394185 Cf. A052905 (for mass 2).
%K A394185 nonn,easy
%O A394185 0,1
%A A394185 _Luc Rousseau_, May 15 2026
