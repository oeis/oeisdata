%I A394033 #10 Mar 16 2026 17:46:31
%S A394033 1,2,3,5,7,9,13,12,16,11,34,17,19,27,29,89,18,22,28,32,37,233,31,23,
%T A394033 51,33,38,42,610,44,41,59,61,71,43,48,1597,47,49,67,64,74,79,87,53,
%U A394033 4181,81,57,70,75,77,85,95,97,58,10946,115,60,73,83,80,101,103
%N A394033 Rectangular array, read by descending antidiagonals: denominators in the best lower approximating array to the golden ratio, phi (A001622). (See Comments).
%C A394033 Let Q = {a/b: gcd(a,b)=1, a>0, b>0}; i.e., the positive rationals, reduced to lowest terms, and let x be a positive irrational number. For any dense subset S of Q, a sequence of fractions a(n)/b(n) in S is the S-best lower approximating sequence if it satisfies these three conditions:
%C A394033 (1)  a(1)/b(1) < a(2)/b(2) < a(3)/b(3) < ... < x
%C A394033 (2)  b(1) < b(2) < b(3) < ...
%C A394033 (3)  if b(k) < v < b(k+1) for some u/v in S and k>=1, then u/v is not between a(k)/b(k) and a(k+1)/b(k+1).
%C A394033 Define the best lower approximating array to x by rows, r(n,k), for k>=1, as follows:
%C A394033 Row 1: With S = Q, put r(1,1) = a(1)/b(1), where a(1) = floor(x) and b(1)=1. The terms r(1,k) are then uniquely determined by conditions (1), (2), (3).  Note that row 1 consists of the lower convergents to x.
%C A394033 Rows n>=2: With S = (Q after deleting all fractions in rows 1,2,...,n-1), let r(n,1) = the fraction a/b in S that is nearest x and < x and has least denominator b that is new; i.e., a/b is not in the first n-1 rows. The terms of row (r(n,k)) are uniquely determined by (1), (2), (3).
%C A394033 Every row and every column converges to x. Regarding the arrays of denominators and numerators for the lower and upper best approximating arrays, every row and every column is strictly increasing.
%C A394033 For the present array, x = phi.
%e A394033 Corner of array of denominators:
%e A394033    1     2    5   13   34   89  233  610  1597  4181  10946  28657
%e A394033    3     7   12   17   18   31   44   47    81   115    123    212
%e A394033    9    16   19   22   23   41   49   57    60   107    128    149
%e A394033    11   27   28   51   59   67   70   73   133   154    157    280
%e A394033    29   32   33   61   64   75   83   86   159   167    175    183
%e A394033    37   38   71   74   77   80   96   99   185   191    301    322
%e A394033 Corner of array of numerators:
%e A394033     1    3    8   21    55   144   377   987  2584  6765  17711
%e A394033     4   11   19   27    29    50    71    76   131   186    199
%e A394033    14   25   30   35    37    66    79    92    97   173    207
%e A394033    17   43   45   82    95   108   113   118   215   249    254
%e A394033    46   51   53   98   103   121   134   139   257   270    283
%e A394033    59   61  114  119   124   129   155   160   299   309    487
%e A394033 Corner of array of approximations:
%e A394033    1.        1.5       1.6       1.61538   1.61765
%e A394033    1.33333   1.57143   1.58333   1.58824   1.61111
%e A394033    1.55556   1.5625    1.57895   1.59091   1.6087
%e A394033    1.54545   1.59259   1.60714   1.60784   1.61017
%e A394033    1.58621   1.59375   1.60606   1.60656   1.60938
%e A394033    1.59459   1.60526   1.60563   1.60811   1.61039
%t A394033 x = GoldenRatio; numRows = 6; numCols = 12;
%t A394033 usedValues = {}; lowerArray = Table[Null, {numRows}, {numCols}];
%t A394033 For[n = 1, n <= numRows, n++, b = 1;
%t A394033   foundStart = False;
%t A394033   While[! foundStart, a = Floor[b*x]; val = a/b;
%t A394033    If[val < x && GCD[a, b] == 1 && ! MemberQ[usedValues, val],
%t A394033     lowerArray[[n, 1]] = val;
%t A394033     AppendTo[usedValues, val]; foundStart = True, b++]];
%t A394033   For[k = 1, k < numCols, k++, currentVal = lowerArray[[n, k]];
%t A394033    currentB = Denominator[currentVal];
%t A394033    nextVal = Null; testB = currentB + 1;
%t A394033    While[nextVal === Null, testA = Floor[testB*x];
%t A394033     candidate = testA/testB;
%t A394033     If[GCD[testA, testB] == 1 && candidate > currentVal &&
%t A394033       candidate < x && ! MemberQ[usedValues, candidate],
%t A394033      nextVal = candidate;
%t A394033      AppendTo[usedValues, candidate];
%t A394033      lowerArray[[n, k + 1]] = nextVal, testB++]];];];
%t A394033 Grid[lowerArray]  (* Lower best approximating array to golden ratio *)
%t A394033 Grid[N[lowerArray]]  (* approximations *)
%t A394033 Grid[Denominator[lowerArray]]  (* A394033 *)
%t A394033 Grid[Numerator[lowerArray]]    (* A394034 *)
%Y A394033 Cf. A001622, A001519 (row 1), A394035, A394036, A394037.
%K A394033 nonn,tabl,frac
%O A394033 1,2
