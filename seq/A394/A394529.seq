%S A394529 0,1,7,37,177,806,3566,15485,66373,281794,1187730,4977666,20765322,
%T A394529 86300332,357533468,1477270877,6089863853,25054822922,102900891818,
%U A394529 421968327062,1728015429278,7067810392532,28876515741188,117861738978482,480627231175202,1958328570638036
%N A394529 Total number of cells under all Dyck paths of semilength n in the first quadrant of the square grid.
%C A394529 The total number of cells equals the total area under all Dyck paths.
%C A394529 Equivalently, total number of cells above all Dyck paths of semilength n in the fourth quadrant of the square grid.
%C A394529 For the illustration of a(1)..a(4) in the fourth quadrant see the Eric Weisstein's World of Mathematics in the Links section.
%H A394529 Alois P. Heinz, <a href="/A394529/b394529.txt">Table of n, a(n) for n = 0..1659</a>
%H A394529 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/DyckPath.html">Dyck Path</a>.
%F A394529 From _Alois P. Heinz_, Mar 23 2026: (Start)
%F A394529 G.f.: ((5*x-1-2*x^2)/(x*(1-4*x)^(3/2))+(1-3*x)/(x*(1-4*x)))/2.
%F A394529 a(n) = (n^2 * A000108(n) + A008549(n))/2.
%F A394529 a(n) = (n^2 * binomial(2*n,n)/(n+1) + 4^n - binomial(2*n+1,n))/2. (End)
%F A394529 a(n) ~ 2^(2*n-1)*sqrt(n/Pi). - _Stefano Spezia_, Mar 23 2026
%e A394529 For n = 3 there are five Dyck paths of semilength 3 in the first quadrant of the square grid as shown below:
%e A394529     _         _         _ _       _ _       _ _ _
%e A394529      |_        |_ _        |         |_          |
%e A394529        |_          |       |_          |         |
%e A394529          |         |         |         |         |
%e A394529 .
%e A394529 The total number of cells under all Dyck paths is 6 + 7 + 7 + 8 + 9 = 37 as shown below:
%e A394529     _         _         _ _       _ _       _ _ _
%e A394529    |_|_      |_|_ _    |_|_|     |_|_|_    |_|_|_|
%e A394529    |_|_|_    |_|_|_|   |_|_|_    |_|_|_|   |_|_|_|
%e A394529    |_|_|_|   |_|_|_|   |_|_|_|   |_|_|_|   |_|_|_|
%e A394529       6         7         7         8         9
%e A394529 .
%e A394529 So a(3) = 37.
%p A394529 a:= n-> (n^2*binomial(2*n,n)/(n+1)+4^n-binomial(2*n+1, n))/2:
%p A394529 seq(a(n), n=0..25);  # _Alois P. Heinz_, Mar 23 2026
%t A394529 A394529[n_] := (n^2*Binomial[2*n, n]/(n + 1) + 4^n - Binomial[2*n + 1, n])/2;
%t A394529 Array[A394529, 30, 0] (* _Paolo Xausa_, Apr 06 2026 *)
%Y A394529 Row sums of A390502.
%Y A394529 Cf. A000108, A000290, A000302, A008549, A129182, A193694, A227543, A393383, A394643.
%K A394529 nonn,easy,changed
