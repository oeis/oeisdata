%I A394433 #17 Mar 24 2026 22:47:06
%S A394433 4,6,9,10,14,21,22,25,26,30,34,38,39,45,46,49,55,57,58,62,66,70,74,75,
%T A394433 82,86,93,94,99,102,105,106,111,118,121,122,129,130,134,138,142,146,
%U A394433 153,154,155,158,165,166,169,170,174,175,178,182,183,190,194,195
%N A394433 Numbers k such that gcd(k, phi(k)) is prime.
%C A394433 No prime k belongs to the sequence, because for prime k, phi(k) = k-1 and consecutive numbers are coprime, i.e. gcd(k, k-1) = 1, which is not prime.
%C A394433 All squares of primes (p^2) belong to the sequence, because phi(p^2) = p^2 - p and gcd(p^2, p^2 - p) = p, which is prime.
%C A394433 Squarefree terms are A350586. - _Robert Israel_, Mar 20 2026
%e A394433 For k = 9: phi(9) = 6 and gcd(9, 6) = 3, which is prime, so 9 is a term.
%e A394433 For k = 8: phi(8) = 4 and gcd(8, 4) = 4, which is not prime, so 8 is not a term.
%p A394433 filter:= k -> isprime(igcd(k, NumberTheory:-phi(k))):
%p A394433 select(filter, [$1..300]); # _Robert Israel_, Mar 20 2026
%t A394433 Select[Range[210], PrimeQ[GCD[#, EulerPhi[#]]] &] (* _Amiram Eldar_, Mar 20 2026 *)
%o A394433 (Python)
%o A394433 from sympy import totient, gcd, isprime
%o A394433 def ok(k): return isprime(gcd(k, totient(k)))
%o A394433 print([k for k in range(1, 300) if ok(k)])
%o A394433 (PARI) isok(k) = isprime(gcd(k, eulerphi(k))); \\ _Michel Marcus_, Mar 20 2026
%Y A394433 Cf. A000010, A003277, A054395, A392199.
%Y A394433 A001248 and A350586 are subsequences.
%K A394433 nonn,easy
%O A394433 1,1
