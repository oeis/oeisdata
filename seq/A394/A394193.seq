%U A394193 5160960,20643840,24084480,18063360,10321920,6881280,4423680,2580480,92897280,418037760,495452160,371589120,222953472,154828800,106168320,69672960,41287680
%N A394193 Irregular triangle read by rows: T(n,k) is the number of linear intervals of height k in the weak order on D_n (0 <= k <= n-1).
%C A394193 An interval is linear of height k if it is isomorphic to the total order on k+1 elements.
%F A394193 Row sums give A394198.
%e A394193 Triangle begins:
%e A394193    192,    384,    384,    288;
%e A394193   1920,   4800,   5120,   3840,   1536;
%e A394193  23040,  69120,  76800,  57600,  27648,  15360;
%o A394193 (SageMath)
%o A394193 def T(n, k):
%o A394193     if k < 0 or k >= n:
%o A394193         return 0
%o A394193     nW = factorial(n) * 2^(n-1)
%o A394193     if k == 0:
%o A394193         return nW
%o A394193     if k == 1:
%o A394193         return nW * n/2
%o A394193     s = 2 * (n-k+1)/(k+1)
%o A394193     if k == 3:
%o A394193         s += 1/2
%o A394193     return s * nW
%Y A394193 Cf. A002866, A391308 (type A), A394190 (type B), A394198.
%K A394193 nonn,tabf
