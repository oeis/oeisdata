%S A394455 1,1,2,3,5,7,13,19,35,51,96,141,267,393,750,1107,2123,3139,6046,8953,
%T A394455 17303,25653,49721,73789,143365,212941,414584,616227,1201917,1787607,
%U A394455 3492117,5196627,10165779,15134931,29643870,44152809,86574831,128996853,253188111,377379369,741365049
%N A394455 Degree of the minimal polynomial of the symmetry-reduced transfer matrix for 3-coloring of n X L grid graphs.
%C A394455 This sequence represents the degree of the minimal polynomial for the transfer matrix of the q=3 antiferromagnetic Potts model (equivalent to 3-coloring) on a square lattice strip of width n.
%C A394455 Due to the S_3 color-permutation symmetry and Z_2 spatial reflection symmetry, the transfer matrix is highly degenerate. The number of distinct nonzero eigenvalues collapses from the raw state space dimension (3 * 2^(n-1)) to the values given in this sequence.
%C A394455 The first differences of this sequence, a(n) - a(n-1), exactly reproduce the terms of A005717 in pairs: 1, 1, 2, 2, 6, 6, 16, 16, 45, 45, 126, 126, 357, 357...
%C A394455 The pairwise (stepwise) growth is a geometric consequence of the bipartite nature of the square grid. Increasing the width n alternates between "breaking" a bipartite pairing (creating new topological states) and "closing" the connections.
%C A394455 At q=3, the underlying Temperley-Lieb algebra TL_n(sqrt(3)) is non-semisimple because q=3 is a Beraha number (B_6=3). The mandatory closure step cannot generate new irreducible representations due to the vanishing of the P_5 Jones-Wenzl projector (P_5=0), causing the difference to duplicate the previous step.
%C A394455 The subsequence of odd-indexed terms a(2n-1) exactly reproduces A005773(n) (number of directed animals).
%C A394455 The subsequence of even-indexed terms a(2n) exactly reproduces A002426(n) (central trinomial coefficients).
%D A394455 P. Fendley and V. Krushkal, Tutte chromatic identities from the Temperley-Lieb algebra, Geometry & Topology, 13 (2009), 709-741.
%D A394455 J. Salas and A. D. Sokal, Transfer Matrices and Partition-Function Zeros for Antiferromagnetic Potts Models. V. Further Results for the Square-Lattice Chromatic Polynomial, Journal of Statistical Physics, 135 (2009), 279-373.
%D A394455 R. Shrock, Exact Potts Model Partition Functions on Ladder Graphs, Physica A: Statistical Mechanics and its Applications, 283 (2000), 388-446.
%H A394455 P. Fendley and V. Krushkal, <a href="https://arxiv.org/abs/0711.0016">Tutte chromatic identities from the Temperley-Lieb algebra</a>, arXiv:0711.0016 [math.CO], 2007.
%H A394455 J. Salas and A. D. Sokal, <a href="https://arxiv.org/abs/0711.1738">Transfer Matrices and Partition-Function Zeros for Antiferromagnetic Potts Models. V.</a>, arXiv:0711.1738 [cond-mat.stat-mech], 2007.
%H A394455 R. Shrock, <a href="https://arxiv.org/abs/cond-mat/0106607">Potts Model Partition Functions for Self-Dual Families of Strip Graphs</a>, arXiv:cond-mat/0106607 [cond-mat.stat-mech], 2001.
%H A394455 Yi-Zhong Wang, <a href="https://github.com/ReddiFSH2007/3-Coloring-Recurrence-Order">3-Coloring-Recurrence-Order: C++ transfer-matrix algorithm with Berlekamp-Massey</a>
%F A394455 a(n) - a(n-1) = A005717(floor((n-1)/2)) for n >= 3.
%F A394455 a(n) = 1 + Sum_{j=3..n} A005717(floor((j-1)/2)) for n >= 3.
%F A394455 a(2*n - 1) = A005773(n) for n >= 1.
%F A394455 a(2*n) = A002426(n) for n >= 1.
%e A394455 For n=3, a(3) = a(2) + A005717(1) = 1 + 1 = 2.
%e A394455 For n=4, a(4) = a(3) + A005717(1) = 2 + 1 = 3.
%e A394455 For n=5, a(5) = a(4) + A005717(2) = 3 + 2 = 5.
%e A394455 For n=6, a(6) = a(5) + A005717(2) = 5 + 2 = 7.
%e A394455 For n=7, a(7) = a(6) + A005717(3) = 7 + 6 = 13.
%e A394455 For n=8, a(8) = a(7) + A005717(3) = 13 + 6 = 19.
%p A394455 A005717 := proc(n) option remember; if n=0 then 0 elif n=1 then 1 else (3*(n-1)*n*A005717(n-2)+(2*n-1)*n*A005717(n-1))/((n+1)*(n-1)) fi end:
%p A394455 a := proc(n) option remember; if n<=2 then 1 else a(n-1)+A005717(iquo(n-1,2)) fi end:
%p A394455 seq(a(n), n=1..20);
%t A394455 A005717[0] = 0; A005717[1] = 1;
%t A394455 A005717[n_] := A005717[n] = (3*(n-1)*n*A005717[n-2] + (2*n-1)*n*A005717[n-1])/((n+1)*(n-1));
%t A394455 a[1] = a[2] = 1;
%t A394455 a[n_] := a[n] = a[n-1] + A005717[Floor[(n-1)/2]];
%t A394455 Table[a[n], {n, 1, 41}]
%o A394455 (Python)
%o A394455 def A005717(): # Generator for A005717 by _Peter Luschny_, May 16 2016
%o A394455     a, b, k = 0, 1, 1
%o A394455     while True:
%o A394455         yield b
%o A394455         k += 1
%o A394455         a, b = b, (3*(k-1)*k*a + (2*k-1)*k*b) // ((k+1)*(k-1))
%o A394455 def a():
%o A394455     yield 1
%o A394455     yield 1
%o A394455     curr = 1
%o A394455     A = A005717()
%o A394455     while True:
%o A394455         val = next(A)
%o A394455         curr += val
%o A394455         yield curr
%o A394455         curr += val
%o A394455         yield curr
%o A394455 seq = a()
%o A394455 print([next(seq) for _ in range(41)])
%Y A394455 Cf. A005717.
%Y A394455 Bisections give A005773, A002426.
%K A394455 nonn,new
%O A394455 1,3
%A A394455 _Yi-Zhong Wang_, Mar 21 2026
