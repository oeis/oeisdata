%S A394047 1,1,0,1,1,0,1,2,3,0,1,3,7,27,0,1,4,12,60,387,0,1,5,18,100,837,7317,0,
%T A394047 1,6,25,148,1359,15570,168237,0,1,7,33,205,1963,24867,354159,4503789,
%U A394047 0,1,8,42,272,2660,35328,559440,9408852,136727055,0,1,9,52,350,3462,47086,785916,14747022,284015997,4625789067,0
%N A394047 Square array A(n,k), n >= 0, k >= 0, read by antidiagonals downwards, where column k is the expansion of B(x)^k, where B(x) is the g.f. of A393889.
%F A394047 A(n,0) = 0^n.
%F A394047 A(0,1) = A(1,1) = 1;   A(n,1) =     3 * Sum_{j=1..n-1} A(j,1) * A(n-j,j).
%F A394047 For k > 1, A(0,k) = 1; A(n,k) = (1/n) * Sum_{j=1..n} ((k+1)*j-n) * A(j,1) * A(n-j,k).
%e A394047 Square array begins:
%e A394047   1,    1,     1,     1,     1,     1, ...
%e A394047   0,    1,     2,     3,     4,     5, ...
%e A394047   0,    3,     7,    12,    18,    25, ...
%e A394047   0,   27,    60,   100,   148,   205, ...
%e A394047   0,  387,   837,  1359,  1963,  2660, ...
%e A394047   0, 7317, 15570, 24867, 35328, 47086, ...
%o A394047 (PARI) a(n, k, m=3) = if(n*k<=1, k^n, if(k==1, m*sum(j=1, n-1, a(j, 1)*a(n-j, j)), sum(j=1, n, ((k+1)*j-n)*a(j, 1)*a(n-j, k))/n));
%Y A394047 Columns k=0..1 give A000007, A393889.
%Y A394047 Cf. A392378, A392379, A394901.
%K A394047 nonn,tabl,new
%O A394047 0,8
%A A394047 _Seiichi Manyama_, Apr 06 2026
