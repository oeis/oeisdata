%I A394463 #5 Apr 01 2026 16:56:17
%S A394463 48,162,175,180,208,225,245,300,320,325,336,368,450,475,520,539,567,
%T A394463 616,624,688,775,833,845,847,848,875,880,912,920,925,1075,1127,1134,
%U A394463 1168,1216,1225,1300,1323,1328,1352,1360,1375,1377,1421,1488,1496,1521,1525,1536
%N A394463 Numbers k such that the sum of distinct prime factors and the sum of their exponents are divisible in at least one direction, while the corresponding products are divisible in neither direction.
%C A394463 Numbers k such that A008472(k) and A001222(k) are divisible in at least one direction, but A007947(k) and A005361(k) are divisible in neither direction.
%C A394463 No term t is squarefree (since then A005361(t) = 1, hence A005361(t) | A007947(t)); hence no primes.
%C A394463 No term t is a prime power: for t = p^m we have A008472(t) = p and A001222(t) = m, so the sum condition holds only when m = 1 or p | m, exactly when A005361(t) = m and A007947(t) = p are divisible in at least one direction.
%H A394463 Felix Huber, <a href="/A394463/b394463.txt">Table of n, a(n) for n = 1..10000</a>
%F A394463 Disjoint from A126706.
%e A394463 175 = 5^2*7^1 is a term since (5 + 7) is divisible by (2 + 1) and 5*7 is not divisible by 2*1 (nor vice versa).
%e A394463 48 = 2^4*3^1 is a term since (2 + 3) divides (4 + 1) and 2*3 does not divide 4*1 (nor vice versa).
%e A394463 1536 = 2^9*3^1 is a term since (2 + 3) divides (9 + 1) and 2*3 does not divide 9*1 (nor vice versa).
%p A394463 A394463 := proc(n)
%p A394463     option remember;
%p A394463     local f, i, k, m, p, s, t;
%p A394463     if n = 1 then return 48 end if;
%p A394463     for k from A394463(n - 1) + 1 do
%p A394463         f := ifactors(k)[2];
%p A394463         m := mul(i[1], i in f);
%p A394463         p := mul(i[2], i in f);
%p A394463         if irem(m, p) <> 0 and irem(p, m) <> 0 then
%p A394463             s := add(i[1], i in f);
%p A394463             t := add(i[2], i in f);
%p A394463             if irem(s, t) = 0 or irem(t, s) = 0 then
%p A394463                 return k
%p A394463             end if
%p A394463         end if
%p A394463     end do;
%p A394463 end proc:
%p A394463 seq(A394463(n), n = 1 .. 49);
%Y A394463 Cf. A001221, A001222, A005361, A007947, A008472, A126706, A390784, A392819.
%K A394463 nonn,new
%O A394463 1,1
%A A394463 _Felix Huber_, Mar 28 2026
