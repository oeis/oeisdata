%T A394891 29,30,31,32,34,35,36,37,38,39,41,42,43,44,45,46,48,49,50,51,52,53,54,
%U A394891 55,56,57,58,59,61,62,63,65,66,67,68,69,71,73,74,76,77,78,79,80,81,82,83,84,85,86,87,88,89,90,91
%N A394891 Numbers k such that A143293(k) has no factor of the form p^p, where A143293 is the partial sums of the primorial numbers.
%C A394891 Numbers k such that A143293(k) is in A048103.
%H A394891 Antti Karttunen, <a href="/A394891/b394891.txt">Table of n, a(n) for n = 1..10000</a>
%o A394891 (PARI)
%o A394891 A143293(n) = { if(n==0, return(1)); my(P=1, s=1); forprime(p=2, prime(n), s+=P*=p); s; };
%o A394891 A359550(n) = { my(pp); forprime(p=2, , pp = p^p; if(!(n%pp), return(0)); if(pp > n, return(1))); };
%o A394891 is_A394891(k) = A359550(A143293(k));
%Y A394891 Cf. A048103, A143293, A359550, A394892 (complement).
%Y A394891 Cf. A328313 [= A276085(A143293(a(n)))].
%K A394891 nonn
%O A394891 1,3
%A A394891 _Antti Karttunen_, Apr 06 2026
