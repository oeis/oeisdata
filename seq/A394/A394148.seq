%S A394148 0,1,2,9,53,356,2581,19661,155043,1254364,10351031,86774158,736874763,
%T A394148 6325043778,54788337068,478309946984,4204179459618,37174135406700,
%U A394148 330437370585319,2951048424582137,26466203370915031,238262410398531864,2152354178774972524
%N A394148 G.f. A(x) satisfies 3*A(x)^6-7*A(x)^5+(9x+5)*A(x)^4-(11x+1)*A(x)^3+(6x^2+3x)*A(x)^2-3x^2*A(x)+x^3=0.
%C A394148 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with red root where red vertices can be followed by red or blue vertices, blue vertices can be followed by vertices of any colors, and green vertices can be followed by red or green vertices.
%H A394148 Nathan Fox, <a href="/A394148/b394148.txt">Table of n, a(n) for n = 0..300</a>
%H A394148 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394148 (Python)
%o A394148 def A394148(n):
%o A394148     A = [[1, 1, 0], [1, 1, 1], [1, 0, 1]]
%o A394148     if n == 0:
%o A394148         return 0
%o A394148     m = len(A)
%o A394148     output = [[1] for i in range(m)]
%o A394148     for l in range(2, n + 1):
%o A394148         for i in range(m):
%o A394148             term = 0
%o A394148             for k in range(1, l):
%o A394148                 for j in range(m):
%o A394148                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394148             output[i].append(term)
%o A394148     return output[0][n - 1]
%Y A394148 Cf. A394149, A394150.
%K A394148 nonn,new
%O A394148 0,3
%A A394148 _Nathan Fox_, Mar 11 2026
