%I A394358 #29 Mar 25 2026 22:47:24
%S A394358 0,1,2,3,5,9,20,30,55,114,174,318,667,1015,1856,3885,5915,10815,22646,
%T A394358 34476,63037,131988,200940,367404,769285,1171165,2141390,4483719,
%U A394358 6826049,12480933,26133032,39785130,72744211,152314470,231884730,423984330,887753791,1351523251
%N A394358 Integers k such that 8*k^2 + m*k is a pronic number (A002378) for some m in {-6, -2, 2, 6}.
%C A394358 The integer solutions exist when the discriminant 32*k^2 + 4*m*k + 1 is a perfect square.
%F A394358 8*k^2 + m*k = p*(p+1) for m in {-6, -2, 2, 6} and k, p >= 0.
%e A394358 For k = 1, m = -6: 8*1^2 - 6*1 = 2, which is 1*2 (pronic).
%e A394358 For k = 2, m = -6: 8*2^2 - 6*2 = 20, which is 4*5 (pronic).
%e A394358 For k = 5, m = 2: 8*5^2 + 2*5 = 210, which is 14*15 (pronic).
%o A394358 (PARI)
%o A394358 is_pronic(x) = (x >= 0) && issquare(4*x + 1);
%o A394358 { for(n=0, 1000,
%o A394358     if(is_pronic(8*n^2 + 6*n) || is_pronic(8*n^2 - 6*n) || is_pronic(8*n^2 + 2*n) || is_pronic(8*n^2 - 2*n),
%o A394358        print1(n, ", ")
%o A394358     )
%o A394358   )
%o A394358 }
%o A394358 (PARI) is_a394358(n) = forstep(k=-6, 6, 4, if(issquare(32*n^2 + 4*k*n + 1), return(1))); 0 \\ _Hugo Pfoertner_, Mar 17 2026
