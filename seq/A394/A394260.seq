%I A394260 #13 Mar 18 2026 22:41:00
%S A394260 1,2652,6714,27693,29709,29763,31527,1401836975,1906377025,5777842175
%N A394260 Numbers k such that sigma(k) = psi(k) + pi(k) + Omega(k)^4.
%e A394260 2652 is a term since sigma(2652) = 7056 = 6048 + 383 + 5^4 = psi(2652) + pi(2652) + Omega(2652)^4.
%o A394260 (PARI) dedpsi(f) = prod(k = 1, #f~, (f[k, 1]+1) * f[k, 1]^(f[k, 2]-1));
%o A394260 list(lim) = {my(q = 2, m = 0, f); print1(1, ", "); forprime(p = 3, lim, m++; for(k = q, p-1, f = factor(k); if(sigma(f) == dedpsi(f) + m + bigomega(f)^4, print1(k, ", "))); q = p); } \\ _Amiram Eldar_, Mar 14 2026
