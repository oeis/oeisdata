%N A394233 Expansion of 1 / sqrt(1 - 14*x + 41*x^2).
%C A394233 4th binomial transform of A001850.
%C A394233 Diagonal of the rational function 1 / (1 - x^2 - 7*x*y - 2*y^2).
%F A394233 E.g.f.: exp(7*x) * BesselI(0,2*sqrt(2)*x).
%F A394233 Coefficient of x^n in (1 + 7*x + 2*x^2)^n.
%F A394233 n * a(n) = 7 * (2*n-1) * a(n-1) - 41 * (n-1) * a(n-2) with a(0) = 1, a(1) = 7.
%F A394233 a(n) = Sum_{k=0..floor(n/2)} binomial(n,2*k) * binomial(2*k,k) * 2^k * 7^(n-2*k).
%t A394233 nmax = 22; CoefficientList[Series[1/Sqrt[1 - 14 x + 41 x^2], {x, 0, nmax}], x]
%t A394233 nmax = 22; CoefficientList[Series[Exp[7 x] BesselI[0, 2 Sqrt[2] x], {x, 0, nmax}], x] Range[0, nmax]!
%t A394233 a[0] = 1; a[1] = 7; a[n_] := a[n] = (7 (2 n - 1) a[n - 1] - 41 (n - 1) a[n - 2])/n; Table[a[n], {n, 0, 22}]
%t A394233 Table[Sum[Binomial[n, 2 k] Binomial[2 k, k] 2^k 7^(n - 2 k), {k, 0, Floor[n/2]}], {n, 0, 22}]
%Y A394233 Cf. A001850, A006139, A059304, A080609, A084601, A098410, A104454, A154347, A394231, A394232.
