%S A394123 0,1,3,16,101,692,4978,36992,281373,2178268,17098550,135733168,
%T A394123 1087586002,8783575592,71421811716,584204775488,4803645283549,
%U A394123 39682630468140,329190956012878,2741196495964112,22904981901932294,191995275425129496,1614031189494809340
%N A394123 G.f. A(x) satisfies A(x)^4-A(x)^3+4x*A(x)^2-x*A(x)+x^2=0.
%C A394123 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with red root where neither blue nor green vertices can be followed by red vertices.
%H A394123 Nathan Fox, <a href="/A394123/b394123.txt">Table of n, a(n) for n = 0..300</a>
%H A394123 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394123 (Python)
%o A394123 def A394123(n):
%o A394123     A = [[1, 1, 1], [0, 1, 1], [0, 1, 1]]
%o A394123     if n == 0:
%o A394123         return 0
%o A394123     m = len(A)
%o A394123     output = [[1] for i in range(m)]
%o A394123     for l in range(2, n + 1):
%o A394123         for i in range(m):
%o A394123             term = 0
%o A394123             for k in range(1, l):
%o A394123                 for j in range(m):
%o A394123                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394123             output[i].append(term)
%o A394123     return output[0][n - 1]
%K A394123 nonn,new
%O A394123 0,3
%A A394123 _Nathan Fox_, Mar 11 2026
