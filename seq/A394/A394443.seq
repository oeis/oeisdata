%N A394443 a(n) = Sum_{k=0..n} Sum_{j=0..k} (-1)^(k - j) * binomial(k, j) * j^n * 2^j.
%H A394443 Alois P. Heinz, <a href="/A394443/b394443.txt">Table of n, a(n) for n = 0..362</a>
%F A394443 a(n) = Sum_{k=0..n} A394444(n, k).
%p A394443 a := n -> local j, k; add(add((-1)^(k-j)*binomial(k, j)*j^n*2^j, j = 0..k), k = 0..n): seq(a(n), n = 0..18);
%p A394443 # Alternative:
%p A394443 b:= proc(n, k) option remember;
%p A394443      `if`(n=0, 1, k*(b(n-1, k)+b(n-1, k-1)))
%p A394443     end:
%p A394443 a:= n-> add(b(n, k), k=0..n):
%p A394443 seq(a(n), n=0..18);  # _Alois P. Heinz_, Apr 28 2026
