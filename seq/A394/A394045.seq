%N A394045 a(0) = 0, a(n) = Sum_{k=1..n} binomial(n+1, k+1)*A053507(k) for n > 0.
%C A394045 Partial sums of column k=3 of A203092.
%C A394045 a(n)+3 is divisible by 2*A007531(n) if n is of the form 6*k+5 (A016969).
%F A394045 E.g.f.: exp(x)*(-3 + (1+x)*T^3/6 + x*T^2/2 + 3*x*T/2 + 3*x*(1+1/T)) where T = -LambertW(-x).
%F A394045 G.f.: Sum_{k>=1} (k-1)*(k-2)/2*k^(k-3)*x^k/(1-x)^(k+2).
%F A394045 Limit_{n->oo} a(n) / (n^(n-1)) = exp(exp(-1))/2.
%p A394045 T := -LambertW(-x): a := exp(x)*(-3 + (1+x)*T^3/6 + x*T^2/2 + 3*x*T/2 + 3*x*(1+1/T)):
%p A394045 ser := series(a, x = 0, 22): seq(n!*coeff(ser, x, n), n = 0 .. 20);
%o A394045 (Python)
%o A394045 from math import comb
%o A394045 def a(n):
%o A394045     return sum(comb(n+1, k+1)*comb(k-1, 2)*k**(k-3) for k in range(3, n+1))
%o A394045 print([a(n) for n in range(21)])
