%U A394373 26460,29280,196272,35360,37680,41454,49280,49932,271188,58520,64428,68040,77700,78540,82708,90068,97920
%N A394373 a(n) is the least integer that is a vampire number in base n (see A014575 for base 10).
%H A394373 Michael S. Branicky, <a href="/A394373/b394373.txt">Table of n, a(n) for n = 2..348</a>
%o A394373 (PARI) isv(n, b)=my(v=digits(n, b)); if(#v%2, return(0)); fordiv(n, d, if(#digits(d,b)==#v/2 && #digits(n/d,b)==#v/2 && vecsort(v)==vecsort(concat(digits(d,b), digits(n/d,b))) && (d%b || (n/d)%b), return(1))); 0;
%o A394373 a(n) = my(k=1); while (!isv(k, n), k++); k;
%o A394373 (Python)
%o A394373 from itertools import count
%o A394373 from sympy import divisors
%o A394373 from sympy.ntheory.factor_ import digits
%o A394373 def is_vampire(n, base):
%o A394373     s = sorted(digits(n, base)[1:])
%o A394373     if len(s)&1: return False
%o A394373     divs, L, U = divisors(n), base**((len(s)//2)-1), base**(len(s)//2)
%o A394373     for i in range((len(divs)+1)//2+1):
%o A394373         x, y = divs[i], divs[-1-i]
%o A394373         if L <= x < U and L <= y < U and (x%base or y%base):
%o A394373             t, u = digits(x, base)[1:], digits(y, base)[1:]
%o A394373             if len(t) == len(u) and sorted(t+u) == s:
%o A394373                 return True
%o A394373     return False
%o A394373 def a(n):
%o A394373     for d in count(2, 2):
%o A394373         v = next((k for k in range(n**(d-1), n**d) if is_vampire(k, n)), None)
%o A394373         if v: return v
%o A394373 print([a(n) for n in range(2, 46)]) # _Michael S. Branicky_, Jun 12 2026
%Y A394373 Cf. A014575 (base 10), A392325 (base 12).
%K A394373 nonn,base,changed
