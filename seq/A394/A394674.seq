%S A394674 1,2,3,4,5,2,3,7,8,9,2,5,11,3,4,13,2,7,3,5,16,17,2,9,19,4,5,3,7,2,11,
%T A394674 23,3,8,25,2,13,27,4,7,29,2,3,5,31,32,3,11,2,17,5,7,4,9,37,2,19,3,13,
%U A394674 5,8,41,2,3,7,43,4,11,5,9,2,23,47,3,16,49,2,25
%N A394674 Irregular triangle T(n, k), n > 0, k = 1..A064372(n), read by rows; the n-th row corresponds to the minimal nonempty subset of A164336 with least common recursive multiple n.
%C A394674 See A287958 for the definition of a recursive multiple.
%C A394674 This sequence has similarities with A141810; they differ when A001221(n) <> A064372(n); for example, for row n = 64 = 2^(2*3), A141810 contains 64 whereas the present sequence contains 4 and 8.
%H A394674 Rémy Sigrist, <a href="/A394674/b394674.txt">Table of n, a(n) for n = 1..10001</a> (rows for n = 1..4278 flattened)
%H A394674 <a href="/index/Di#divisors">Index entries for sequences related to divisors</a>
%e A394674 Triangle T(n, k) begins:
%e A394674   n     n-th row
%e A394674   ----  ------------
%e A394674      1  1
%e A394674      2  2
%e A394674      3  3
%e A394674      4  4
%e A394674      5  5
%e A394674      6  2, 3
%e A394674      7  7
%e A394674      8  8
%e A394674      9  9
%e A394674     10  2, 5
%e A394674     11  11
%e A394674     12  3, 4
%e A394674     13  13
%e A394674     14  2, 7
%e A394674     15  3, 5
%e A394674     16  16
%e A394674     17  17
%e A394674     18  2, 9
%e A394674     19  19
%e A394674     20  4, 5
%o A394674 (PARI) row(n) = { my (r = []); if (n==1, r = [1], my (f = factor(n)); for (k = 1, #f~,
%o A394674 r = concat(r, apply (x -> f[k, 1]^x, row(f[k, 2]))););); return (vecsort(r)); }
%Y A394674 Cf. A001221, A064372, A141810, A287958, A394673.
%K A394674 nonn,new
%O A394674 1,2
%A A394674 _Rémy Sigrist_, Mar 28 2026
