%N A394520 E.g.f. A(x) satisfies A(x) = 1/(1 - 3*x*A(x)^2)^(1/3).
%H A394520 Vincenzo Librandi, <a href="/A394520/b394520.txt">Table of n, a(n) for n = 0..300</a>
%F A394520 a(n) = 3^n * n! * binomial((5*n+1)/3,n)/(5*n+1).
%t A394520 a[n_]:=If[n==0,1,Product[(5*n+1-3*k),{k,0,n-1}]/(5*n+1)]; Table[a[n],{n,0,18}] (* _Vincenzo Librandi_, Mar 26 2026 *)
%o A394520 (PARI) a(n) = 3^n*n!*binomial((5*n+1)/3, n)/(5*n+1);
%o A394520 (Magma) [n eq 0 select 1 else (3^n*&*[((5*n+1)/3-k): k in [0..n-1] ])/(5*n+1): n in [0..23]]; // _Vincenzo Librandi_, Mar 26 2026
