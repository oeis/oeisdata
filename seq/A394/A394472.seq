%N A394472 a(n) = Product_{k=1..n} (2*prime(n)-prime(k)).
%H A394472 Amiram Eldar, <a href="/A394472/b394472.txt">Table of n, a(n) for n = 1..289</a>
%e A394472 For n = 7, prime(7) = 17 and 2*prime(7) = 2*17 = 34 and (34-2)*(34-3)*(34-5)*(34-7)*(34-11)*(34-13)*(34-17) = 6377779296; so a(7) = 6377779296.
%t A394472 a[n_]:=Product[2*Prime[n]-Prime[k],{k,1,n}];Array[a,16] (* _James C. McMahon_, Mar 25 2026 *)
