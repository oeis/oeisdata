%U A394644 88611696649089,1130462209111113,10212735104853921,144902514011469201,2044079025318139041,20917213499088185049,314199901858301847873
%N A394644 Expansion of e.g.f. exp((4/3)*x^3+x).
%H A394644 Wilfried Imrich, <a href="https://doi.org/10.1007/BF01226441">On the number of subgroups of given index in SL_2(Z)</a>, Archiv der Mathematik, vol. 31, 1978, pp. 224-231.
%F A394644 D-finite with recurrence: a(n) = a(n-1)+4*(n-1)*(n-2)*a(n-3).
%F A394644 a(n) = n!*Sum_{k = 0 .. floor(n/3)} (4/3)^k/((n-3*k)!*k!).
%F A394644 a(n) ~ 2^(2*n/3) * n^(2*n/3) * exp(2^(-2/3)*n^(1/3) - 2*n/3) / sqrt(3). - _Vaclav Kotesovec_, Apr 01 2026
%p A394644 seq(LREtools:-REtoproc(a(k) = a(k-1)+4*(k-1)*(k-2)*a(k-3), a(k), {a(0) = 1, a(1) = 1, a(2) = 1})(n), n = 0 .. 25);
%t A394644 a[n_]:= n!*Sum[(4/3)^k/((n-3*k)!*k!),{k,0,Floor[n/3]}]; Array[a,25,0] (* _Stefano Spezia_, Mar 30 2026 *)
