%I A394768 #15 Apr 09 2026 00:16:29
%S A394768 0,0,0,0,0,0,0,2,3,7,13,22,34,52,84,128,198,293,433,639,937,1366,1987,
%T A394768 2876,4154,5975,8579,12295,17584,25129,35855,51106,72782,103573,
%U A394768 147278,209292,297261,421980,598796,849346,1204360,1707237,2419455,3427987,4855917,6877393
%N A394768 Number of Achilles numbers that do not exceed 2^n.
%H A394768 Michael De Vlieger, <a href="/A394768/b394768.txt">Table of n, a(n) for n = 0..127</a>
%F A394768 a(n) = A062762(n) - A070228(n).
%F A394768 a(n) = -1 + (Sum_{j=1..2^(n/3)} |mu(j)| * floor(sqrt(2^n/j^3))) + Sum_{k=2..n} mu(k) * floor(2^(n/k)-1), where mu = A008683.
%e A394768 a(0)..a(6) = 0 since 72 is the smallest Achilles number.
%e A394768 a(7) = 2 since both 72 and 108 are no larger than 2^7 = 128.
%e A394768 a(8) = 3 since a(7) = 2, and additionally, 200 is no larger than 2^8 = 256.
%e A394768 a(9) = 7 since a(8) = 3, and additionally, 4 more are no larger than 2^9 = 512, i.e., {288, 392, 432, 500}, etc.
%t A394768 Table[-1 + Sum[Abs[MoebiusMu[j]]*Floor[Sqrt[(2^n)/j^3]], {j, 2^(n/3)}] + Sum[MoebiusMu[j]*Floor[2^(n/j) - 1], {j, 2, n}], {n, 0, 45}]
%o A394768 (Python)
%o A394768 from math import isqrt
%o A394768 from sympy import integer_nthroot, mobius
%o A394768 from oeis_sequences.OEISsequences import squarefreepi
%o A394768 def A394768(n):
%o A394768     m = 1<<n
%o A394768     c, j, l = squarefreepi(integer_nthroot(m,3)[0])+sum(mobius(k)*(integer_nthroot(m, k)[0]-1) for k in range(2, n+1))-1, isqrt(m), 0
%o A394768     while j>1:
%o A394768         k2 = integer_nthroot(m//j**2,3)[0]+1
%o A394768         w = squarefreepi(k2-1)
%o A394768         c += j*(w-l)
%o A394768         l, j = w, isqrt(m//k2**3)
%o A394768     return c-l # _Chai Wah Wu_, Apr 08 2026
%Y A394768 Cf. A000079, A052486, A062762, A070228, A372403, A380431.
%K A394768 nonn
%O A394768 0,8
%A A394768 _Michael De Vlieger_, Apr 03 2026
