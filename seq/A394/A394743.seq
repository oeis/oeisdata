%S A394743 0,0,1,2,2,2,4,4,1,4,4,4,4,2,6,2,2,6,1,4,2,0,4,0,2,6,2,4,4,2,6,2,0,4,
%T A394743 2,6,0,0,4,0,4,4,0,6,2,0,4,0,2,4,1,4,0,0,0,0,2,0,0,4,0,0,0,0,6,4,4,6,
%U A394743 2,6,2,0,6,2,4,0,0,4,0,2,4,0,0,0,0,2
%N A394743 a(n) = number of triples (x, y, z) such that x^2 + y*z = n, where x,y,z are nonzero Fibonacci numbers.
%e A394743 a(6) = 4 counts these triples: (1,1,5), (1,5,1), (2,1,2), (2,2,1).
%e A394743 a(17) = 6 counts these triples: (1, 2, 8), (1, 8, 2), (2, 1, 13), (2, 13, 1), (3, 1, 8), (3, 8, 1).
%t A394743 t[n_, c_] := Module[{r}, r = Flatten[Table[If[n - x^2 <= 0, {},
%t A394743        Map[({x, #, Quotient[n - x^2, #]} &),
%t A394743        Select[Divisors[n - x^2], Divisible[n - x^2, #] &]]], {x, 1,
%t A394743        Floor[Sqrt[n - 1]]}], 1]; Select[r, Apply[c, #] &]];
%t A394743 fibonacciQ[n_] := IntegerQ[Sqrt[5 n^2 + 4]] || IntegerQ[Sqrt[5 n^2 - 4]];
%t A394743 c = (fibonacciQ[#1] && fibonacciQ[#2] && fibonacciQ[#3] &);
%t A394743 Table[{n, t[n, c]}, {n, 1, 30}]
%t A394743 Join[{0}, Table[Length[t[n, c]], {n, 1, 130}]]
