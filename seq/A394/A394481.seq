%S A394481 1,3,4,6,6,12,8,11,11,18,12,22,14,24,24,20,18,32,20,32,32,36,24,40,27,
%T A394481 42,30,42,30,72,32,37,48,54,48,55,38,60,56,58,42,96,44,62,62,72,48,74,
%U A394481 51,80,72,72,54,88,72,76,80,90,60,124,62,96,82,70,84,144,68,92,96,144,72,98,74,114,106,102,96,168,80,108,85,126,84,164,108
%N A394481 a(n) = usigma(n) + tau(n) - tau(rad(n)).
%C A394481 For each divisor d of n, add d if d is a unitary divisor of n, else add 1.
%F A394481 a(n) = Sum_{d|n} d^[GCD(d,n/d) = 1], where [ ] is the Iverson bracket.
%F A394481 a(n) = A034448(n) + A000005(n) - A034444(n).
%e A394481 a(24) = 1^1 + 2^0 + 3^1 + 4^0 + 6^0 + 8^1 + 12^0 + 24^1 = 40.
%t A394481 Table[Sum[d^KroneckerDelta[GCD[d, n/d], 1], {d, Divisors[n]}], {n, 100}]
