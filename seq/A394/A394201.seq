%N A394201 Expansion of Product_{k>=1} (1 + x^(k*(k+5)/2)) / (1 - x^(k*(k+5)/2)).
%C A394201 Convolution of A393989 and A393988.
%H A394201 Vaclav Kotesovec, <a href="/A394201/b394201.txt">Table of n, a(n) for n = 0..10000</a>
%F A394201 a(n) ~ Gamma(1 + b/d) * ((4-sqrt(2))*zeta(3/2))^(2/3 + b/(3*d)) * d^(1/6 + b/(3*d)) * exp(3*Pi^(1/3) * ((4-sqrt(2))*zeta(3/2))^(2/3) * (n/d)^(1/3) / 4) / (2^(7/2 + 3*b/(2*d)) * sqrt(3) * Pi^(7/6 - b/(6*d)) * n^(7/6 + b/(3*d))), where d = 1/2, b = 5/2.
%t A394201 nmax = 100; CoefficientList[Series[Product[(1 + x^(k*(k+5)/2)) / (1 - x^(k*(k+5)/2)), {k, 1, Floor[Sqrt[25 + 8*nmax]/2 + 1]}], {x, 0, nmax}], x]
