%N A394293 Number of induced cubes in the n X n white bishop graph.
%C A394293 Sequence extended to a(1) using the formula.
%H A394293 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/CubePolynomial.html">Cube Polynomial</a>.
%H A394293 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/WhiteBishopGraph.html">White Bishop Graph</a>.
%H A394293 <a href="/index/Rec#order_07">Index entries for linear recurrences with constant coefficients</a>, signature (3,-1,-5,5,1,-3,1).
%F A394293 a(n) = (n + 1)*(3*((-1)^n - 1) + n*(n + 1)*(n + 2))/24.
%F A394293 a(n) = 3*a(n-1)-a(n-2)-5*a(n-3)+5*a(n-4)+a(n-5)-3*a(n-6)+a(n-7).
%F A394293 G.f.: -x^2*(3+x^2)/((-1+x)^5*(1+x)^2).
%t A394293 Table[(n + 1)*(3*((-1)^n - 1) + n*(n + 1)*(n + 2))/24, {n, 20}]
%t A394293 Table[Piecewise[{{n (n + 1)^2 (n + 2)/24, Mod[n, 2] == 0}, {(n - 1) (n + 1) (n^2 + 4 n + 6)/24, Mod[n, 2] == 1}}], {n, 20}]
%t A394293 LinearRecurrence[{3, -1, -5, 5, 1, -3, 1}, {3, 9, 25, 51, 98, 166, 270}, 20]
%t A394293 CoefficientList[Series[-x (3 + x^2)/((-1 + x)^5 (1 + x)^2), {x, 0, 20}], x]
