%S A394080 1,1,2,1,3,6,1,5,14,30,1,8,31,85,190,1,13,70,246,671,1547,1,21,157,
%T A394080 707,2353,6405,15106,1,34,353,2037,8272,26585,72302,173502,1,55,793,
%U A394080 5864,29056,110254,345775,940005,2286648,1,89,1782,16886,102091,457379,1654092,5094220,13846117,34053437
%N A394080 Triangle read by rows. T(n, k) = T(n, k - 1) + Sum_{j=0..floor((n-1)/2)} T(2 * j, k - 1) * T(n - 1 - 2 * j, k) if n, k > 0, otherwise 1.
%C A394080 For references and comments see A050446 and A050447 which are the main entries. This triangle is the lower triangular matrix of A050446 and the transposed upper triangular matrix of A050447.
%e A394080 Table begins:
%e A394080   [0]  [1]
%e A394080   [1]  [1,  2]
%e A394080   [2]  [1,  3,   6]
%e A394080   [3]  [1,  5,  14,   30]
%e A394080   [4]  [1,  8,  31,   85,   190]
%e A394080   [5]  [1, 13,  70,  246,   671,   1547]
%e A394080   [6]  [1, 21, 157,  707,  2353,   6405,  15106]
%e A394080   [7]  [1, 34, 353, 2037,  8272,  26585,  72302, 173502]
%e A394080   [8]  [1, 55, 793, 5864, 29056, 110254, 345775, 940005, 2286648]
%p A394080 T := proc(n, k) option remember; local j; if k = 0 or n = 0 then 1 else
%p A394080 T(n, k - 1 ) + add(T(2 * j, k - 1) * T(n - 1 - 2 * j, k), j = 0..iquo(n-1, 2)) fi end:
%p A394080 seq(print(seq(T(n, k), k = 0..n)), n = 0..8);
%o A394080 (Python)
%o A394080 from functools import cache
%o A394080 from itertools import accumulate
%o A394080 @cache
%o A394080 def T(n: int, k: int) -> int:
%o A394080     return (T(n, k - 1) + sum(T(2 * j, k - 1) * T(n - 1 - 2 * j, k)
%o A394080            for j in range(1 + (n - 1) // 2)) if k > 0 else 1)
%o A394080 for n in range(9): print([T(n, k) for k in range(n + 1)])
%o A394080 # Alternative:
%o A394080 def Trow(n: int) -> list[int]:
%o A394080     ret = [0] * (n + 1)
%o A394080     for k in range(n + 1):
%o A394080         v = [1] * (k + 1)
%o A394080         for _ in range(n):
%o A394080             v = list(accumulate(reversed(v)))
%o A394080         ret[k] = v[-1]
%o A394080     return ret
%o A394080 for n in range(9): print(Trow(n))
%o A394080 (PARI)
%o A394080 M(k) = matrix(k+1, k+1, i, j, if(i+j > k+1, 1, 0));
%o A394080 V(k) = vector(k+1, i, 1);
%o A394080 P(n, k) = vecmax(V(k)*M(k)^n);
%o A394080 Trow(n) = vector(n+1, k, P(n, k-1));
%o A394080 for(n = 0, 8, print(Trow(n)))
