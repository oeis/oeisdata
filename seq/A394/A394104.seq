%N A394104 Decimal expansion of the mean distance between two points uniformly and independently selected at random in a regular icosahedron of unit volume.
%H A394104 Dominik Beck, <a href="https://arxiv.org/abs/2309.13177">Mean distance in polyhedra</a>, arXiv:2309.13177 [math.PR], 2023.
%H A394104 Dominik Beck, <a href="https://www2.karlin.mff.cuni.cz/~beckd/lectures/BONNMeanDistancePresentation_Final.pdf">Mean distance in polyhedra</a>, lecture, 2024.
%H A394104 Dominik Beck, <a href="https://www2.karlin.mff.cuni.cz/~beckd/lectures/DISSERTATION.pdf">Random polytopes</a>, doctoral thesis, Mathematical Institute of Charles University, Prague, 2025.
%F A394104 Equals (1/2) * (9/5 - 3/sqrt(5))^(1/3) * (197/525 + 239/(525*sqrt(5)) - 44/525*sqrt(2 + 2/sqrt(5)) - (17226 + 6269*sqrt(5))*Pi/157500 - (2186 + 1413*sqrt(5))*arccot(phi)/15750 + (82 - 75*sqrt(5))*arccot(phi^2)/5250 + 4*(2139 + 881*sqrt(5))*arccosech(phi)/7875 + (15969 + 7151*sqrt(5))*arccoth(phi)/12600 + (4449 - 1685*sqrt(5))*log(3)/42000 - (75783 + 37789*sqrt(5))*log(5)/252000), where phi is the golden ratio (A001622).
%e A394104 0.641312485510735885104521947992662588466399096164751...
%t A394104 With[{phi = GoldenRatio}, RealDigits[1/2*(9/5 - 3/Sqrt[5])^(1/3)*(197/525 + 239/(525*Sqrt[5]) - 44/525*Sqrt[2 + 2/Sqrt[5]] - ((17226 + 6269*Sqrt[5])*Pi)/157500 - ((2186 + 1413*Sqrt[5])*ArcCot[phi])/15750 + ((82 - 75*Sqrt[5])*ArcCot[phi^2])/5250 + (4*(2139 + 881*Sqrt[5])*ArcCsch[phi])/7875 + ((15969 + 7151*Sqrt[5])*ArcCoth[phi])/12600 + ((4449 - 1685*Sqrt[5])*Log[3])/42000 - ((75783 + 37789*Sqrt[5])*Log[5])/252000), 10, 120][[1]]]
%o A394104 (PARI) {my(phi = quadgen(5)); 1/2 * (9/5 - 3/sqrt(5))^(1/3) * (197/525 + 239/(525*sqrt(5)) - 44/525*sqrt(2 + 2/sqrt(5)) - (17226 + 6269*sqrt(5))*Pi/157500 - (2186 + 1413*sqrt(5))*atan(1/phi)/15750 + (82 - 75*sqrt(5))*atan(1/phi^2)/5250 + 4*(2139 + 881*sqrt(5))*asinh(1/phi)/7875 + (15969 + 7151*sqrt(5))*atanh(1/phi)/12600 + (4449 - 1685*sqrt(5))*log(3)/42000 - (75783 + 37789*sqrt(5))*log(5)/252000)}
