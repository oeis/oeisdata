%I A394341 #24 May 10 2026 16:46:51
%S A394341 1,2,4,3,8,4,4,27,5,44,50,8,11,36,529,13,1197,16,1378,11685,905,22,
%T A394341 10184,51488,119319
%N A394341 Minimum numerators corresponding to the denominators in A395144.
%e A394341 The smallest denominator with a valid fraction is 2 with 1/2 (maximum 2). 1 is the first entry.
%e A394341 The next denominator is 3 with 1/3 and 2/3 = 1/2 + 1/6 (maximum 6 > 2). Thus, 2 is the next entry as it generates the largest denominator.
%e A394341 The next denominator is 4 with 1/4, 2/4 = 1/2, and 3/4 = 1/2 + 1/4 (maximum 4 < 6). No terms will be added here.
%e A394341 The next denominator is 5 with 1/5, 2/5 = 1/3 + 1/15, 3/5 = 1/2 + 1/10, and 4/5 = 1/2 + 1/4 + 1/20 (maximum 20 > 6). Thus, 4 is the next entry as it generates the largest denominator.
%o A394341 (Julia)
%o A394341 function a(k)
%o A394341     global_max_num, global_max_den = 0, 0
%o A394341     i = 0
%o A394341     den = 1
%o A394341     while i < k
%o A394341         den += 1
%o A394341         local_max_num, local_max_den = 0, 0
%o A394341         for num in 1:den-1
%o A394341             frac = num // den
%o A394341             while numerator(frac) != 1
%o A394341                 frac -= 1 // big(denominator(frac) ÷ numerator(frac) + 1)
%o A394341             end
%o A394341             if denominator(frac) > local_max_den
%o A394341                 local_max_num, local_max_den = num, denominator(frac)
%o A394341             end
%o A394341         end
%o A394341         if local_max_den > global_max_den
%o A394341             global_max_num, global_max_den = local_max_num, local_max_den
%o A394341             i += 1
%o A394341         end
%o A394341     end
%o A394341     return global_max_num
%o A394341 end
%Y A394341 Cf. A395144 (denominators).
%K A394341 frac,nonn,more,new
%O A394341 1,2
%A A394341 _Hoang Nguyen_, Apr 21 2026
