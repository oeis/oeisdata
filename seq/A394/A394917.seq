%N A394917 Irregular triangle read by rows in which row n lists all k from [1..2^(n - 1)] with exactly n divisors.
%e A394917 Irregular triangle begins as:
%e A394917  1;
%e A394917  2;
%e A394917  4;
%e A394917  6, 8;
%e A394917  16;
%e A394917  12, 18, 20, 28, 32;
%e A394917  64;
%e A394917  24, 30, 40, 42, 54, 56, 66, 70, 78, 88, 102, 104, 105, 110, 114, 128;
%e A394917  36, 100, 196, 225, 256;
%e A394917  48, 80, 112, 162, 176, 208, 272, 304, 368, 405, 464, 496, 512;
%e A394917  1024.
%p A394917 T:= n-> select(k-> numtheory[tau](k)=n, [$1..2^(n-1)])[]:
%p A394917 seq(T(n), n=1..11);  # _Alois P. Heinz_, Apr 07 2026
%t A394917 row[n_] := Select[Range[2^(n-1)], DivisorSigma[0, #] == n &]; Array[row, 12] // Flatten (* _Amiram Eldar_, Apr 07 2026 *)
%o A394917 (Magma) [[k: k in [1..2^(n - 1)] | #Divisors(k) eq n]: n in [1..12]];
%o A394917 (PARI) row(n) = select(x->(numdiv(x)==n), [1..2^(n - 1)]); \\ _Michel Marcus_, Apr 07 2026
