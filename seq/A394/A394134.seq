%S A394134 0,1,2,8,39,210,1202,7173,44127,277836,1781679,11596192,76406492,
%T A394134 508658025,3416192088,23118277855,157486215649,1079088549500,
%U A394134 7432104030047,51423979655007,357284954509679,2491635829739516,17435125051758596,122378751686758714
%N A394134 G.f. A(x) satisfies A(x)^5-2A(x)^4+(2x+1)*A(x)^3-4x*A(x)^2+(x^2+x)*A(x)-x^2=0.
%C A394134 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with green root where red vertices can be followed by blue or green vertices, blue vertices can only be followed red vertices, and green vertices can be followed by red or green vertices.
%H A394134 Nathan Fox, <a href="/A394134/b394134.txt">Table of n, a(n) for n = 0..300</a>
%H A394134 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394134 (Python)
%o A394134 def A394134(n):
%o A394134     A = [[0, 1, 1], [1, 0, 0], [1, 0, 1]]
%o A394134     if n == 0:
%o A394134         return 0
%o A394134     m = len(A)
%o A394134     output = [[1] for i in range(m)]
%o A394134     for l in range(2, n + 1):
%o A394134         for i in range(m):
%o A394134             term = 0
%o A394134             for k in range(1, l):
%o A394134                 for j in range(m):
%o A394134                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394134             output[i].append(term)
%o A394134     return output[2][n - 1]
%Y A394134 Cf. A394132, A394133.
%K A394134 nonn,new
%O A394134 0,3
%A A394134 _Nathan Fox_, Mar 11 2026
