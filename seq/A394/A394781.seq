%S A394781 1,1,7,72,935,14341,250740,4891524,104980759,2454101307,62024200767,
%T A394781 1684938506736,48965936123556,1516158088359292,49844612759902184,
%U A394781 1734481808437302252,63707038283983544055,2463590323603526192263,100069576520048929553013
%N A394781 G.f. A(x) satisfies A(x) = 1 - x/3 * d/dx log(1 - 3*x*A(x)^2).
%H A394781 Vincenzo Librandi, <a href="/A394781/b394781.txt">Table of n, a(n) for n = 0..300</a>
%F A394781 G.f. A(x) satisfies A(x) = 1 - x*A(x)^2*(2 - 3*A(x)) + x^2*d/dx(A(x)^2).
%F A394781 a(0) = 1; a(n) = (n-3) * Sum_{k=0..n-1} a(k) * a(n-1-k) + 3 * Sum_{i, j, k>=0 and i+j+k=n-1} a(i)*a(j)*a(k).
%t A394781 a={1}; nmax=20; Do[s1=Sum[a[[k+1]] a[[n-k]],{k,0,n-1}]; s2=Sum[a[[i+1]] a[[j+1]] a[[n-1-i-j+1]],{i,0,n-1},{j,0,n-1-i}]; AppendTo[a,(n-3) s1+3 s2];,{n,1,nmax}]; a (* _Vincenzo Librandi_, Apr 02 2026 *)
%o A394781 (Magma) nmax := 20; a := [1]; for n in [1..nmax] do s1 := &+[ a[k+1]*a[n-k] : k in [0..n-1] ];
%o A394781 s2 := 0; for i in [0..n-1] do for j in [0..n-1-i] do s2 +:= a[i+1] * a[j+1] * a[n-1-i-j+1];
%o A394781 end for; end for; Append(~a, (n-3)*s1 + 3*s2); end for; a; // _Vincenzo Librandi_, Apr 02 2026
%Y A394781 Cf. A394772, A394780.
%K A394781 nonn,new
%O A394781 0,3
