%I A394504 #17 Mar 29 2026 16:22:14
%S A394504 0,10,110,200,210,1110,1210,2200,2210,3000,3010,3110,3200,3210,11110,
%T A394504 11210,12210,13110,13210,22200,22210,23200,23210,33000,33010,33110,
%U A394504 33200,33210,40000,40010,40110,40200,40210,41110,41210,42200,42210,43000,43010,43110,43200,43210
%N A394504 Numbers such that each digit d_i is equal to the number of digits to its right that are strictly less than d_i.
%C A394504 For a number with L digits d_1, d_2, ..., d_L, the rule is d_i = #{j > i : d_j < d_i}.
%C A394504 The last digit d_L is always 0 because there are no digits to its right.
%C A394504 The first digit d_1 is always between 1 and L-1.
%C A394504 Therefore, a number of length L is in the sequence if its digits d_i (for i=0..L-1) satisfy d_0 = L-1, d_{L-1} = 0, and d_i is either 0 or L-1-i for 0 < i < L-1.
%C A394504 Thus, each digit describes the 'downward slope' of the remaining digits to its right.
%e A394504 3210 is in the sequence because:
%e A394504   the first digit '3' is followed by three digits (2, 1, 0) all smaller than 3;
%e A394504   the second digit '2' is followed by two digits (1, 0) both smaller than 2;
%e A394504   the third digit '1' is followed by one digit (0) smaller than 1;
%e A394504   the last digit '0' is followed by zero digits.
%o A394504 (Python)
%o A394504 def a_list(max_digits):
%o A394504     results = []
%o A394504     def backtrack(current_suffix):
%o A394504         if len(current_suffix) == 1 or current_suffix[0] != 0:
%o A394504             results.append(int("".join(map(str, current_suffix))))
%o A394504         if len(current_suffix) == max_digits:
%o A394504             return
%o A394504         for d in range(10):
%o A394504             count_smaller = sum(1 for x in current_suffix if x < d)
%o A394504             if d == count_smaller:
%o A394504                 backtrack([d] + current_suffix)
%o A394504     backtrack([0])
%o A394504     return sorted(results)
%o A394504 print(a_list(5))
%Y A394504 Subsequence of A008592.
