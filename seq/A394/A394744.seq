%I A394744 #10 Apr 18 2026 16:44:06
%S A394744 0,0,0,0,0,0,0,2,0,1,0,2,1,0,1,0,1,3,0,2,0,0,1,0,0,3,0,2,2,0,1,1,0,1,
%T A394744 0,1,0,0,2,0,1,2,0,3,1,0,1,0,0,2,0,2,0,0,0,0,0,0,0,2,0,0,0,0,3,0,2,3,
%U A394744 0,3,1,0,0,0,2,0,0,2,0,1,1,0,0,0,0,1
%N A394744 a(n) = number of triples (x, y, z) such that x^2 + y*z = n, where x,y,z are distinct nonzero Fibonacci numbers and y < z.
%C A394744 a(17) = 3 counts these triples : (1, 2, 8), (2, 1, 13), (3, 1, 8).
%C A394744 The sequence is unbounded, because for any m, F(2*m-1-2*i)^2 + F(2*i)*F(4*m-2-2*i) = F(2*m-1)^2 is the same for 1 <= i < m, where F = A000045. - _Robert Israel_, Apr 13 2026
%p A394744 N:= 100: # for a(0) .. a(N)
%p A394744 V:= Array(0..N):
%p A394744 F:= [seq(combinat:-fibonacci(k),k=2..ceil(log[(1+sqrt(5))/2](sqrt(5)*N)))]:
%p A394744 nF:= nops(F):
%p A394744 for x in F do
%p A394744   for i from 2 to nF do
%p A394744     if x = F[i] then next fi;
%p A394744     for j from 1 to i-1 do
%p A394744       if x = F[j] then next fi;
%p A394744       v:= x^2 + F[i]*F[j];
%p A394744       if v > N then break fi;
%p A394744       V[v]:= V[v]+1
%p A394744 od od od:
%p A394744 convert(V,list); # _Robert Israel_, Apr 13 2026
%t A394744 t[n_, c_] := Module[{r}, r = Flatten[Table[If[n - x^2 <= 0, {},
%t A394744        Map[({x, #, Quotient[n - x^2, #]} &),
%t A394744        Select[Divisors[n - x^2], Divisible[n - x^2, #] &]]], {x, 1,
%t A394744        Floor[Sqrt[n - 1]]}], 1]; Select[r, Apply[c, #] &]];
%t A394744 fibonacciQ[n_] := IntegerQ[Sqrt[5 n^2 + 4]] || IntegerQ[Sqrt[5 n^2 - 4]];
%t A394744 c = (fibonacciQ[#1] && fibonacciQ[#2] && fibonacciQ[#3] && #2 < #3 && DuplicateFreeQ[{#1, #2, #3}] &);
%t A394744 Table[{n, t[n, c]}, {n, 1, 30}]
%t A394744 Join[{0}, Table[Length[t[n, c]], {n, 1, 130}]]
%t A394744 (* _Peter J. C. Moses_, Mar 29 2026 *)
%Y A394744 Cf. A000045, A393710, A394740, A394743.
%K A394744 nonn,new
%O A394744 0,8
