%T A394458 388,484,599,737,904,1113,1350,1655,2009,2430,2938,3555,4265,5131,
%U A394458 6148,7354,8777,10469,12435,14782,17517,20724,24483,28905,34014,40028,47008,55135,64568
%N A394458 Number of partitions p of n such that 2 * (the greatest multiplicity of the parts of p) is a part of p.
%F A394458 G.f.: Sum_{j>=1} Product_{k>=1} (-delta(2*j,k) + (1-q^((j+1)*k))/(1-q^k)) - Product_{k>=1} (-delta(2*j,k) + (1-q^(j*k))/(1-q^k)), where delta(j,k) is the Kronecker delta.
%e A394458 a(10) counts these 8 partitions: 82, 721, 532, 442, 4411, 433, 4321, 42211.
%o A394458 (PARI) my(N=60, q='q+O('q^N)); concat(0, Vec(sum(j=1, N, prod(k=1, 2*N, -(2*j==k)+(1-q^((j+1)*k))/(1-q^k))-prod(k=1, 2*N, -(2*j==k)+(1-q^(j*k))/(1-q^k)))))
%Y A394458 Cf. A365613, A394459.
%K A394458 nonn,new
%O A394458 1,6
