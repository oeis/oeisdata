%S A394726 1,0,1,5,0,4,4,9,8,3,2,8,4,4,6,2,1,7,5,1,1,7,4,7,6,0,2,9,4,9,5,4,3,6,
%T A394726 9,8,0,4,3,1,5,6,1,4,2,2,0,2,2,0,6,9,4,5,6,0,0,3,0,7,0,4,0,3,8,7,6,3,
%U A394726 7,5,6,1,3,2,0,6,8,2,1,5,0,9,0,7,1,4,8,3,2,1,5,7,4,4,0,4,9,8,7,2,9,5,0,3,9
%N A394726 Decimal expansion of Sum_{n>=2} moebius(n)*n^2*(2*zeta'(n)^3/zeta(n)^3-3*zeta'(n)*zeta''(n)/zeta(n)^2+zeta'''(n)/zeta(n)).
%H A394726 Artur Kawalec, <a href="https://arxiv.org/abs/2603.21535">On the series expansion of the prime zeta function about s = 1 and its coefficients</a>, arXiv:2603.21535 [math.NT], 2026, p. 3 eq. 16.
%F A394726 Equals Sum_{p prime} (4*p^2-3*p+1)*log(p)^3/(p*(p-1)^3).
%F A394726 Equals 3rd derivative of the function P(x)-log(zeta(x)) at x = 1, where P(x) is the prime zeta function.
%e A394726 10.15044983284462175117476...
%t A394726 $MaxExtraPrecision = 1000; f[p_] := (4*p^2 - 3*p + 1)/(p*(p-1)^3); elog = 3; Do[cc = Rest[CoefficientList[Series[f[1/x], {x, 0, m}], x, m+1]]; Print[Sum[Log[Prime[k]]^elog * f[Prime[k]], {k, 1, 100}] + N[Sum[Indexed[cc,n] * ((-1)^elog * Derivative[elog][PrimeZetaP][n] - Sum[Log[Prime[k]]^elog / Prime[k]^n, {k, 1, 100}]), {n, 2, m}], 110]], {m, 100, 200, 100}] (* _Vaclav Kotesovec_, Mar 30 2026 *)
%o A394726 (PARI) sum(n=2, 10000, moebius(n)*n^2*(2*zeta'(n)^3/zeta(n)^3-3*zeta'(n)*zeta''(n)/zeta(n)^2+zeta'''(n)/zeta(n)))
%Y A394726 Cf. A393690.
%K A394726 nonn,cons,new
%O A394726 2,4
%A A394726 _Artur Jasinski_, Mar 30 2026
