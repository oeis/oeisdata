%N A394709 Coefficient of x^(2*n) in the expansion of ( (1+x)^3 * (1+x^2) )^n.
%H A394709 Seiichi Manyama, <a href="/A394709/b394709.txt">Table of n, a(n) for n = 0..854</a>
%F A394709 a(n) = Sum_{k=0..n} binomial(n,k) * binomial(3*n,n+2*k).
%F A394709 6*n * (2*n - 1) * (3*n - 2) * (3*n - 1) * (19311*n^5 - 175055*n^4 + 623655*n^3 - 1091153*n^2 + 937882*n - 317040) * a(n) = 3 * (9558945*n^9 - 105770115*n^8 + 495805026*n^7 - 1286416230*n^6 + 2025696041*n^5 - 1995897067*n^4 + 1222150340*n^3 - 444987308*n^2 + 86609168*n - 6787200) * a(n-1) + 8 * (n - 1) * (4132554*n^8 - 43660601*n^7 + 191451062*n^6 - 451330786*n^5 + 619075602*n^4 - 499285629*n^3 + 227697742*n^2 - 52958664*n + 4737600) * a(n-2) + 192 * (n - 2) * (n - 1) * (3*n - 8) * (3*n - 7) * (19311*n^5 - 78500*n^4 + 116545*n^3 - 77408*n^2 + 22876*n - 2400) * a(n-3) for n > 2.
%o A394709 (PARI) a(n) = sum(k=0, n, binomial(n, k)*binomial(3*n, n+2*k));
