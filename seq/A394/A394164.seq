%I A394164 #14 Mar 29 2026 15:57:02
%S A394164 3,1,2,8,20,7,52,74,216,140,14,47,524,1316,287,432,167,56,3479,24911,
%T A394164 2324,86012,2399,276332,3176,63671,468284,1203296,1354664,19508,39476,
%U A394164 4629056,47522,874431,6227108,911336
%N A394164 a(n) is the least positive integer k such that the elliptic curve y^2 = x^3 + k*x + 1 has exactly n integer solutions with y >= 0.
%C A394164 a(37) > 10^7, a(39) = 8080292, a(44) = 639911.
%e A394164 a(8) = 74 because 74 is the least k such that the elliptic curve y^2 = x^3 + 74*x + 1 has 8 integral solutions with nonnegative y: {{0, 1}, {4, 19}, {21, 104}, {28, 155}, {336, 6161}, {1320, 47959}, {1369, 50654}, {219685, 102967604}}.
%o A394164 (Magma)
%o A394164 SetClassGroupBounds("GRH");
%o A394164 max_n := 8;
%o A394164 max_k := 100;
%o A394164 sols := [**];
%o A394164 for k in [1..max_k] do
%o A394164     Append(~sols, [k, #IntegralPoints(EllipticCurve([0, 0, 0, k, 1]))]);
%o A394164 end for;
%o A394164 for n in [1..max_n] do
%o A394164     for sol in sols do
%o A394164         if sol[2] eq n then
%o A394164             printf "%o, ",sol[1];
%o A394164             break;
%o A394164         end if;
%o A394164     end for;
%o A394164 end for;
%Y A394164 Cf. A392144, A392395, A393931.
%K A394164 nonn,more,new
%O A394164 1,1
%A A394164 _Zhining Yang_, Mar 11 2026
