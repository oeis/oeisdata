%T A394706 73,74,77,83,86,88,89,94,95,101,102,103,107,109,113,118,119,125,127,
%U A394706 128,131,134,137,143,146,148,149,151,155,161,163,164,167,172,173,178,179,181,183,185,191,193,194,197
%N A394706 Numbers k such that k*2^d - 1 is nonprime for any of its divisors d.
%e A394706 5 is a term because 5*2^1 - 1 = 9 and 5*2^5 - 1 = 157 are composites for divisors 1 and 5 of 5.
%t A394706 q[k_] := AllTrue[Divisors[k], !PrimeQ[k*2^# - 1] &]; Select[Range[200], q] (* _Amiram Eldar_, Mar 30 2026 *)
%o A394706 (Magma) [k: k in [1..200] | #[d: d in Divisors(k) | IsPrime(k*2^d - 1)] eq 0];
