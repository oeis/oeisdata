%U A394983 1236364897766949475200,597721267428855590414016,151563228737368559197951080,21359671726535570720328595200,12460413635269718600520991546560
%N A394983 G.f. A(x) satisfies [x^n] exp( n*x*(1+n^2*x+(n^2*x)^2) - n*A(x) ) = 0 for n >= 1.
%H A394983 Seiichi Manyama, <a href="/A394983/b394983.txt">Table of n, a(n) for n = 1..281</a>
%F A394983 a(n) = b_n(n) + (1/n) * Sum_{k=1..n-1} k * c_n(k) * e_n(n-k),
%F A394983 where b_n(k) = n^(2*(k-1)) for 1 <= k <= 3, and b_n(k) = 0 for k > 3,
%F A394983 c_n(k) = b_n(k) - a(k) for 1 <= k <= n-1,
%F A394983 and e_n(0) = 1, e_n(k) = (n/k) * Sum_{j=1..k} j * c_n(j) * e_n(k-j) for 1 <= k <= n-1.
%e A394983 The table of coefficients of x^k in exp( n*x*(1+n^2*x+(n^2*x)^2) - n*A(x) ) begins:
%e A394983 n\k | 0  1    2      3         4         5             6
%e A394983 ----+--------------------------------------------------------
%e A394983   1 | 1, 0,  -3,   -80,   -567/2,   -56880,   -9131855/2, ...
%e A394983   2 | 1, 0,   0,  -130,   -576,    -114240,   -9131524,   ...
%e A394983   3 | 1, 0,  15,     0,  -1503/2,  -171360,  -27444717/2, ...
%e A394983   4 | 1, 0,  48,   700,      0,    -194880,  -18071812,   ...
%e A394983   5 | 1, 0, 105,  2720,   8145/2,        0,  -38217995/2, ...
%e A394983   6 | 1, 0, 192,  7290,  16704,    1056960,          0,   ...
%e A394983   7 | 1, 0, 315, 16240,  95193/2,  4715760,  208906327/2, ...
%e A394983   8 | 1, 0, 480, 32120, 112896,   14960640,  496613384,   ...
%e A394983   9 | 1, 0, 693, 58320, 475065/2, 39901680, 3426307641/2, ...
%o A394983 (Ruby)
%o A394983 def A394983(n)
%o A394983   a = [0]
%o A394983   (1..n).each{|i|
%o A394983     b = [0] + (1..i).map{|k| k > 3 ? 0 : i ** (2 * (k - 1))}
%o A394983     c = [0] + (1..i - 1).map{|k| b[k] - a[k]}
%o A394983     e = [1]
%o A394983     (1..i - 1).each{|k| e << i / k.to_r * (1..k).inject(0){|s, j| s + j * c[j] * e[k - j]}}
%o A394983     a << b[i] + (1..i - 1).inject(0){|s, k| s + k * c[k] * e[i - k]}.to_i / i
%o A394983   }
%o A394983   a[1..-1]
%o A394983 end
%o A394983 p A394983(17)
