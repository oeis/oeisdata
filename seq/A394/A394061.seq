%N A394061 Prime number produced by summing the distinct prime factors of the numbers in A393096.
%F A394061 a(n) = A008472 (A393096(n)).
%e A394061 For n = 8, a(8) is 13, the sum of 2 and 11 which are the distinct prime factors of 44, given by a(8) in A393096.
%t A394061 sopf[k_]:=Total[First/@FactorInteger[k]];q[k_]:=PrimeQ[sopf[k]]&&PrimeQ[k-sopf[k]];sopf/@Select[Range[2850],q] (* _James C. McMahon_, Mar 16 2026 *)
%o A394061 (Python)
%o A394061 from sympy import isprime, primefactors
%o A394061 def ok(n):return isprime(sum(primefactors(n))) and isprime(n-sum(primefactors(n)))
%o A394061 print(list(map(lambda n: sum(primefactors(n)), filter(ok, range(1, 2000)))))
%o A394061 (PARI) sopf(k) = vecsum(factor(k)[,1]);
%o A394061 isok(k) = my(s=sopf(k)); isprime(s) && isprime(k-s);
%o A394061 apply(sopf, select(isok, [1..4000])) \\ _Michel Marcus_, Mar 09 2026
