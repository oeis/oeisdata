%U A394613 1873316,3031081,4904397,7935489,12839886,20775364,33615250,54390625,88005875,142396489,230402364,372798864
%N A394613 a(n) = a(n-1) + a(n-3) + a(n-4), a(0) = 1, a(1) = 4, a(2) = 16, a(3) = 20.
%H A394613 Tomás Guardia, Douglas Jiménez, and Alexander McCurdy, <a href="https://doi.org/10.2478/rmm-2024-0002">Fiboquadratic numbers and Rithmomachia</a>, Recreational Mathematics Magazine, Vol. 11, No. 18 (2024), pp. 17-29.
%H A394613 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (1,0,1,1).
%F A394613 a(n) = (4*F(n/2) + F((n/2)-1))^2 if n is even and (4*F((n-1)/2) + F(((n-1)/2)-1))*(4*F(((n-1)/2)+1) + F((n-1)/2)) if n is odd where F(n) = Fibonacci(n).
%F A394613 G.f.: (1 + 3*x + 12*x^2 + 3*x^3)/((1 + x^2)*(1 - x - x^2)). - _Stefano Spezia_, Apr 09 2026
%t A394613 LinearRecurrence[{1, 0, 1, 1}, {1, 4, 16, 20}, 40] (* _Amiram Eldar_, Apr 07 2026 *)
%t A394613 a[n_]:=If[EvenQ[n], (4*Fibonacci[n/2] + Fibonacci[(n/2)-1])^2, (4*Fibonacci[(n-1)/2] + Fibonacci[((n-1)/2)-1])*(4*Fibonacci[((n-1)/2)+1] + Fibonacci[(n-1)/2])]; Array[a,39,0] (* _Stefano Spezia_, Apr 09 2026 *)
