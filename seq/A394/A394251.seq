%T A394251 917,1151,1441,1797,2233,2767,3407,4193,5140,6289,7662,9323,11305,
%U A394251 13695,16527,19916,23929,28717,34377,41079,48980,58303,69273,82186,97330,115080
%N A394251 Number of partitions p of n such that (maximal multiplicity of the parts of p) <= 3 * (number of distinct parts of p).
%H A394251 Seiichi Manyama, <a href="/A394251/b394251.txt">Table of n, a(n) for n = 0..1000</a>
%F A394251 G.f.: Sum_{i>=0} [z^i] Product_{j>=1} (1 + z * Sum_{k=1..3*i} q^(j*k)).
%e A394251 a(6) counts these 10 partitions: 6, 51, 42, 411, 33, 321, 3111, 222, 2211, 21111.
%o A394251 (PARI) my(N=50, q='q+O('q^N)); Vec(sum(i=0, N, polcoef(prod(j=1, N, 1+z*sum(k=1, 3*i, q^(j*k))), i, z)))
%Y A394251 Cf. A000041, A240306, A394250.
%K A394251 nonn
%O A394251 0,3
