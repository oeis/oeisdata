%S A394163 0,1,2,9,54,377,2888,23540,200518,1764857,15929058,146658817,
%T A394163 1372189888,13010164892,124732806864,1207207388488,11779072626070,
%U A394163 115745779492793,1144421168042790,11377336184254571,113660074946123094,1140426486700350833,11487638357135472400
%N A394163 G.f. A(x) satisfies A(x)^4-2*A(x)^3+(4x+1)*A(x)^2-3x*A(x)+2x^2=0.
%C A394163 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with green root where green vertices cannot be followed by blue vertices.
%H A394163 Nathan Fox, <a href="/A394163/b394163.txt">Table of n, a(n) for n = 0..300</a>
%H A394163 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394163 (Python)
%o A394163 def A394163(n):
%o A394163     A = [[1, 1, 1], [1, 1, 1], [1, 0, 1]]
%o A394163     if n == 0:
%o A394163         return 0
%o A394163     m = len(A)
%o A394163     output = [[1] for i in range(m)]
%o A394163     for l in range(2, n + 1):
%o A394163         for i in range(m):
%o A394163             term = 0
%o A394163             for k in range(1, l):
%o A394163                 for j in range(m):
%o A394163                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394163             output[i].append(term)
%o A394163     return output[2][n - 1]
%Y A394163 Cf. A394162.
%K A394163 nonn
%O A394163 0,3
%A A394163 _Nathan Fox_, Mar 12 2026
