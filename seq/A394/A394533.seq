%S A394533 1,2,3,4,10,6,7,8,36,20,42,12,26,14,15,16,136,72,292,40,164,84,170,24,
%T A394533 100,52,106,28,58,30,31,32,528,272,2184,144,1160,584,2340,80,648,328,
%U A394533 1316,168,676,340,682,48,392,200,804,104,420,212,426,56,228,116,234
%N A394533 Binary expansion of a(n) obtained from binary expansion of n with increased number of zeros separated by every next 1 by total number of zeros lying from the left side of selected 1.
%C A394533 Permutation of A225620.
%e A394533 Binary expansion of n = 41 is 1(0)1(00)1(), then binary expansion of a(n) is 1(0)1(00,0)1(00,0).
%o A394533 (PARI) a(n) = my(A = 2*n+1, B = 0, C = 0); forstep(k=logint(n,2), 0, -1, if(bittest(A,k), B = (1+B<<1)<<C, C++)); B
%o A394533 (Python)
%o A394533 def a(n: int) -> int:
%o A394533     C, B, A = 0, 0, 2*n + 1
%o A394533     for k in range(n.bit_length() - 1, -1, -1):
%o A394533         if (A >> k) & 1: B = (1 + (B << 1)) << C
%o A394533         else: C += 1
%o A394533     return B
%o A394533 print([a(n) for n in range(1, 60)])  # _Peter Luschny_, Mar 28 2026
%Y A394533 Cf. A125106, A225620.
