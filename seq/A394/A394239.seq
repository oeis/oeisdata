%N A394239 Expansion of e.g.f. exp(-LambertW(LambertW(-LambertW(x)))).
%F A394239 E.g.f.: exp(B(x)), where B(x) is the e.g.f. of A396556.
%F A394239 a(0) = 1; a(n) = Sum_{i,j,k >= 0 and i+j+k=n-1} ((n-1)!/(i!*j!*k!)) * (-n)^i * (n-i)^j * (k+2)^k.
%F A394239 a(n) ~ exp(1+n*exp(-1)-n*exp(-1-exp(-1))) * n^(n-1) / (sqrt(1-exp(-1)) * sqrt(1+exp(-1-exp(-1)))). - _Vaclav Kotesovec_, Jun 01 2026
%o A394239 (PARI) my(N=20, x='x+O('x^N)); Vec(serlaplace(exp(-lambertw(lambertw(-lambertw(x))))))
%Y A394239 Cf. A268653, A340474, A395376.
%Y A394239 Cf. A396556.
