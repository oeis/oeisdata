%S A394162 0,1,3,17,118,909,7467,64084,567784,5153909,47683261,447999001,
%T A394162 4262819546,40995561164,397838709028,3891003431880,38314308209408,
%U A394162 379529894406725,3779369599554753,37812232790295907,379904588173225274,3831480471367427717,38775223353403702299
%N A394162 G.f. A(x) satisfies 2*A(x)^4-A(x)^3+4x*A(x)^2-x*A(x)+x^2=0.
%C A394162 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with red root (or blue root) where green vertices cannot be followed by blue vertices.
%H A394162 Nathan Fox, <a href="/A394162/b394162.txt">Table of n, a(n) for n = 0..300</a>
%H A394162 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394162 (Python)
%o A394162 def A394162(n):
%o A394162     A = [[1, 1, 1], [1, 1, 1], [1, 0, 1]]
%o A394162     if n == 0:
%o A394162         return 0
%o A394162     m = len(A)
%o A394162     output = [[1] for i in range(m)]
%o A394162     for l in range(2, n + 1):
%o A394162         for i in range(m):
%o A394162             term = 0
%o A394162             for k in range(1, l):
%o A394162                 for j in range(m):
%o A394162                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394162             output[i].append(term)
%o A394162     return output[0][n - 1]
%Y A394162 Cf. A394163.
%K A394162 nonn
%O A394162 0,3
