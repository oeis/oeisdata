%S A394896 1,170,4224,45760,307450,1508988,5923820,19669408,57323475,150471750,
%T A394896 362513580,812962800,1715604852,3436229720,6577276200,12098618752,
%U A394896 21485926085,36980543106,61887717320,100983229600,161042119854,251517242900,385399871220,580299501600,859785444375,1255038699486
%N A394896 a(n) = n*n*(n+1)*(n+2)*(n+3)*(2n+1)*(2n+3)*(2n+5)*(35*n^2-21*n+4)/45360.
%C A394896 From the recurrent form of Faulhaber's formula.
%C A394896 The odd-indexed terms a(2k-1) correspond to a diagonal of the central factorial triangle A036969.
%H A394896 Paolo Xausa, <a href="/A394896/b394896.txt">Table of n, a(n) for n = 1..10000</a>
%H A394896 <a href="/index/Rec#order_11">Index entries for linear recurrences with constant coefficients</a>, signature (11,-55,165,-330,462,-462,330,-165,55,-11,1).
%F A394896 a(n) = A394582(n, 8).
%F A394896 a(n) = n * A351105(n).
%F A394896 a(n) = n*binomial(2n+6,7)*(35*n^2-21*n+4)/144.
%F A394896 a(n) = 1/(2*n-1)! * Sum_{j = 1..n} (-1)^(n+j) * binomial(2*n, n-j) * j^(2*n+6).
%F A394896 G.f.: x*(1 + 159*x + 2409*x^2 + 8481*x^3 + 8690*x^4 + 2516*x^5 + 144*x^6)/(1 - x)^11. - _Stefano Spezia_, Apr 05 2026
%t A394896 A394896[n_] := n*(7*n*(5*n - 3) + 4)*Binomial[2*n + 6, 7]/144;
%t A394896 Array[A394896, 30] (* _Paolo Xausa_, Apr 09 2026 *)
%o A394896 (Python)
%o A394896 # Based on Python program for A351105
%o A394896 def A394896(n):
%o A394896     return n*n*(n*(n*(n*(n*(n*(n*(n*(280*n + 2772) + 10518) + 18711) + 14385) + 1323) - 2863) - 126) + 360)//45360
%o A394896 limit = 26; A = [A394896(n) for n in range(1, limit+1)]; print(A)
%Y A394896 Cf. A008957, A036969, A351105, A394582.
%K A394896 nonn,easy,new
%O A394896 1,2
