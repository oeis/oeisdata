%N A394217 Earliest monotonic sequence satisfying a(1)=1 and a(a(n)+a(n-1))=n for n>=1 (with a(k)=0 for k<=0).
%F A394217 a(2n) = a(n) + a(n+1) - 1 (n>=1), a(2n+1) = a(n) + a(n+1) (n>=2); for n = 2^k + r (0 <= r < 2^k, k>=2), a(n) = 3*2^(k-2) + ceiling(r/2) if r <= 2^(k-1), else a(n) = n - 2^(k-1).
%t A394217 a[n_] := a[n] = If[EvenQ[n], a[n/2] + a[n/2 + 1] - 1, a[(n - 1)/2] + a[(n + 1)/2]]; a[1] = 1; a[2] = a[3] = 2; Array[a, 120] (* _Amiram Eldar_, Mar 14 2026 *)
%Y A394217 Cf. A001462, A394218, A394219, A003605, A079000.
%K A394217 nonn,new
