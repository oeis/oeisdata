%S A394146 0,1,2,9,52,339,2374,17436,132500,1033047,8216974,66416217,543944328,
%T A394146 4504131540,37645894056,317177232840,2690949419268,22969669443903,
%U A394146 197124911532478,1699842261726507,14721062007498596,127981857614962635,1116549383447525494
%N A394146 G.f. A(x) satisfies 3*A(x)^3-4*A(x)^2+(2x+1)*A(x)-x=0.
%C A394146 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with red root where red vertices can be followed by red or blue vertices, blue vertices can be followed by vertices of any color, and green vertices can only be followed by red vertices.
%H A394146 Nathan Fox, <a href="/A394146/b394146.txt">Table of n, a(n) for n = 0..300</a>
%H A394146 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394146 (Python)
%o A394146 def A394146(n):
%o A394146     A = [[1, 1, 0], [1, 1, 1], [1, 0, 0]]
%o A394146     if n == 0:
%o A394146         return 0
%o A394146     m = len(A)
%o A394146     output = [[1] for i in range(m)]
%o A394146     for l in range(2, n + 1):
%o A394146         for i in range(m):
%o A394146             term = 0
%o A394146             for k in range(1, l):
%o A394146                 for j in range(m):
%o A394146                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394146             output[i].append(term)
%o A394146     return output[0][n - 1]
%Y A394146 Cf. A394147.
%K A394146 nonn
%O A394146 0,3
%A A394146 _Nathan Fox_, Mar 11 2026
