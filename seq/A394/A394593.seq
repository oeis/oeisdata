%T A394593 583,828,923,976,1043,1230,1231,1521,1433,1473,1754,1638,1780,1973,
%U A394593 2078,2128,2478,2434,2623,2530,2716,2882,3250,3357,3196,3351,3779,3915,3493,3751,3783,4463,4654,4640,4328,4646,5366
%N A394593 Sum of the distinct prime divisors of C(7*n, n).
%H A394593 Vincenzo Librandi, <a href="/A394593/b394593.txt">Table of n, a(n) for n = 1..1000</a>
%F A394593 a(n) = sopf(binomial(7*n,n)) = A008472(A004368(n)).
%e A394593 a(3) = 33 because binomial(21,3) = 1330 = 2*5*7*19 and 2+5+7+19 = 33.
%e A394593 a(4) = 28 because binomial(28,4) = 20475 = 3^2*5^2*7*13 and 3+5+7+13 = 28.
%p A394593 a:= n-> add(i[1], i=ifactors(binomial(7*n, n))[2]):
%p A394593 seq(a(n), n=1..55);  # _Alois P. Heinz_, Apr 27 2026
%t A394593 a[n_]:=Total[FactorInteger[Binomial[7*n,n]][[All,1]]];Table[a[n],{n,1,55}]
%o A394593 (Magma) a := func<n | &+PrimeDivisors(Binomial(7*n, n))>; N := 55; [a(n) : n in [1..N]];
%o A394593 (Python)
%o A394593 from collections import Counter
%o A394593 from sympy import factorint
%o A394593 def A394593(n):
%o A394593     c = Counter()
%o A394593     for i in range(6*n+1,7*n+1):
%o A394593         c += factorint(i)
%o A394593     for i in range(2,n+1):
%o A394593         c -= factorint(i)
%o A394593     return sum(c) # _Chai Wah Wu_, Apr 27 2026
%Y A394593 Cf. A008472, A004368, A394454, A394591, A394592.
%K A394593 nonn,new
