%I A394085 #12 Apr 26 2026 16:49:23
%S A394085 1,2,2,7,2,9,2,15,13,13,2,26,2,17,18,31,2,38,2,38,24,25,2,58,31,29,40,
%T A394085 50,2,65,2,63,36,37,38,91,2,41,42,86,2,87,2,74,74,49,2,122,57,92,54,
%U A394085 86,2,119,58,114,60,61,2,162,2,65,98,127,68,131,2,110,72,133,2,195,2,77
%N A394085 a(n) = sigma(n) - Sum_{p|n, p prime, gcd(p,n/p) = 1} (p-1).
%C A394085 For each divisor d of n, add 1 if d is a unitary prime divisor of n, else add d.
%F A394085 a(n) = Sum_{d|n} d^(1 - [gcd(d,n/d) = 1]*c(d)), where [ ] is the Iverson bracket and c = A010051.
%F A394085 a(n) = A000203(n) - A063956(n) + A056169(n).
%e A394085 a(12) = 1^1 + 2^1 + 3^0 + 4^1 + 6^1 + 12^1 = 26.
%t A394085 Table[Sum[d^(1 - KroneckerDelta[GCD[d, n/d], 1]*(PrimePi[d] - PrimePi[d - 1])), {d, Divisors[n]}], {n, 100}]
%Y A394085 Cf. A000203 (sigma), A010051, A056169, A063956.
%K A394085 nonn,easy,new
%O A394085 1,2
%A A394085 _Wesley Ivan Hurt_, Apr 26 2026
