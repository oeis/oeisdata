%U A394244 17,8,4,19,10,5,20,12,6,22,13,6,24,15,7,25,17,8
%N A394244 Expansion of Product_{k>=1} 1/(1 - x^(2*k^2 + 1)).
%H A394244 Vaclav Kotesovec, <a href="/A394244/b394244.txt">Table of n, a(n) for n = 0..10000</a>
%H A394244 Vaclav Kotesovec, <a href="/A394244/a394244.jpg">Graph - the asymptotic ratio (100000 terms)</a>
%F A394244 a(n) ~ sqrt(c) * zeta(3/2)^(2/3) * exp(3 * Pi^(1/3) * zeta(3/2)^(2/3) * n^(1/3) / (2^(4/3) * d^(1/3))) / (2^(7/3) * sqrt(3) * d^(1/3) * Pi^(1/6) * sinh(Pi*sqrt(c/d)) * n^(7/6)) * (1 - (c * Pi^(2/3) * zeta(1/2) * zeta(3/2)^(1/3) / (2^(5/3) * d^(2/3)) + 17*d^(1/3) / (9*Pi^(1/3) * (2*zeta(3/2))^(2/3))) / n^(1/3)), where d = 2, c = 1.
%t A394244 nmax = 200; CoefficientList[Series[1/Product[(1 - x^(2*k^2 + 1)), {k, 1, Sqrt[(nmax + 1)/2] + 1}], {x, 0, nmax}], x]
