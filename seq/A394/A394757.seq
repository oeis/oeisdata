%S A394757 18,72,1152,4050,5652,6948,15138,16452,20772,20808,27792,44532,46818,
%T A394757 65700,67428,126612,143568,176418,180288,194868,195732,206082,212868,
%U A394757 216900,218628,236772,276372,281250,299700,328788,362952,369828,377172,388962,390672,400068,402768
%N A394757 Numbers k in A014574 (averages of twin prime pairs) such that gcd(k, sigma(k)) is prime.
%C A394757 Conjecture: all terms are divisible by 18.
%C A394757 Conjecture: gcd(k, sigma(k)) is in {2,3}.
%e A394757 For k = 18: sigma(18) = 39 and gcd(18, 39) = 3, which is prime, so 18 is a term.
%e A394757 For k = 12: sigma(12) = 28 and gcd(12, 28) = 4, which is not prime, so 12 is not a term.
%t A394757 Select[Array[Prime[#] + 1 &, 35000], PrimeQ[# + 1] && PrimeQ[GCD[#, DivisorSigma[1, #]]] &] (* _Amiram Eldar_, Mar 31 2026 *)
%o A394757 (Python)
%o A394757 from sympy import divisor_sigma, gcd, isprime
%o A394757 def ok(k): return isprime(k-1) and isprime(k+1) and isprime(gcd(k, divisor_sigma(k)))
%o A394757 print([k for k in range(1, 500000) if ok(k)])
%Y A394757 Intersection of A014574 and A392199.
%K A394757 nonn,new
%O A394757 1,1
%A A394757 _Aied Sulaiman_, Mar 31 2026
