%N A394025 Number of partitions p of n into distinct parts such that max(p) = 1 + 3*min(p).
%H A394025 Vincenzo Librandi, <a href="/A394025/b394025.txt">Table of n, a(n) for n = 1..1000</a>
%F A394025 G.f.: Sum_{j>=1} q^(4*j+1) * Product_{k=j+1..3*j} (1+q^k).
%t A394025 Nmax=60; a=CoefficientList[Series[Sum[q^(4 j+1) Product[1+q^k,{k,j+1,3 j}],{j,1,Nmax}],{q,0,Nmax}],q][[2;;]] (* _Vincenzo Librandi_, Mar 07 2026 *)
%o A394025 (Magma) N := 60; R<q> := PowerSeriesRing(Integers(), N+1); gf := &+[ q^(4*j+1) * &*[1+q^k : k in [j+1..3*j]] : j in [1..N] ]; [Coefficient(gf,n) : n in [1..N]]; // _Vincenzo Librandi_, Mar 07 2026
