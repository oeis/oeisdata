%S A394092 0,0,0,0,0,1,0,0,0,2,0,1,0,0,0,0,0,3,1,2,0,0,1,1,0,1,0,0,0,1,0,0,0,4,
%T A394092 2,3,0,1,2,2,0,0,0,0,1,2,1,1,0,2,0,1,0,0,0,0,0,2,0,1,0,0,0,0,0,5,3,4,
%U A394092 1,2,3,3,0,0,1,1,2,3,2,2,0,1,0,0,0,1,0
%N A394092 Negated least part of the partial alternating sums of the n-th composition in standard order (row n of A391983).
%C A394092 All terms nonnegative.
%C A394092 The k-th composition in standard order (graded reverse-lexicographic, A066099) is obtained by taking the set of positions of 1's in the reversed binary expansion of k, prepending 0, taking first differences, and reversing again. This gives a bijective correspondence between nonnegative integers and integer compositions.
%C A394092 The partial alternating sums of a finite sequence q are given by pas(q)_j = Sum_{i=1..j} (-1)^(i+j) * q_i. For example, the partial alternating sums of q = (a,b,c,d,e) are:
%C A394092   pas(q)_0 =  0
%C A394092   pas(q)_1 =  a
%C A394092   pas(q)_2 = -a + b
%C A394092   pas(q)_3 =  a - b + c
%C A394092   pas(q)_4 = -a + b - c + d
%C A394092   pas(q)_5 =  a - b + c - d + e
%H A394092 Gus Wiseman, <a href="https://docs.google.com/document/d/e/2PACX-1vTCPiJVFUXN8IqfLlCXkgP15yrGWeRhFS4ozST5oA4Bl2PYS-XTA3sGsAEXvwW-B0ealpD8qnoxFqN3/pub">Statistics, classes, and transformations of standard compositions</a>
%F A394092 a(2^n + 1) = n - 1.
%e A394092 The 9th composition in standard order is (3,1), with partial alternating sums (0,3,-2), so a(9) = 2.
%t A394092 stc[n_]:=Differences[Prepend[Join@@Position[Reverse[IntegerDigits[n,2]],1],0]]//Reverse;
%t A394092 pas[y_]:=Table[Sum[(-1)^(i+j)*y[[i]],{i,j}],{j,0,Length[y]}];
%t A394092 Table[-Min@@pas[stc[n]],{n,0,100}]
%Y A394092 Without alternating sums see A333768, max A333766, first A065120, last A001511.
%Y A394092 For run-lengths instead of partial alternating sums we have A357138, opposite A357137.
%Y A394092 Negated minima of rows of A391983, reverse A391984.
%Y A394092 Without the leading zero we have A392713.
%Y A394092 For maximum instead of minimum we have A394091.
%Y A394092 For reversed prime indices we have A394095 (trimmed A394096), max A061395.
%Y A394092 All of the following pertain to compositions in standard order (A066099):
%Y A394092 - Length is A000120.
%Y A394092 - Sum is A029837.
%Y A394092 - Runs are counted by A124767.
%Y A394092 - Rotational period is given by A333632.
%Y A394092 - First differences are A358133.
%Y A394092 - Partial sums are A358134.
%Y A394092 - First sums are A390432, row ranks A390568.
%Y A394092 A003242 counts anti-run compositions, ranks A333489.
%Y A394092 A005811 counts runs in binary expansion.
%Y A394092 A011782 counts compositions.
%Y A394092 A097805 counts compositions by alternating sum.
%Y A394092 A344618 lists reverse-alternating sums of standard compositions.
