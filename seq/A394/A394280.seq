%I A394280 #12 Apr 18 2026 16:56:21
%S A394280 2,13,-1,4567,19172533,-1,14710131619,23456789,-1,45678910111213,
%T A394280 17131925313743495561,-1,567891011121314151617,
%U A394280 357911131517192123252729,-1,135791113151719212325272931,345678910111213141516171819,-1,57911131517192123252729313335373941,1417202326293235384144475053565962656871,-1
%N A394280 a(n) is the least prime that is the concatenation of an arithmetic progression of n numbers, or -1 if there is no such prime.
%C A394280 a(n) = -1 if n is divisible by 3, as then the concatenation of an arithmetic progression of n numbers is divisible by 3.
%H A394280 Robert Israel, <a href="/A394280/b394280.txt">Table of n, a(n) for n = 1..277</a>
%e A394280 a(5) = 19172533 because 19172533 is prime and is the concatenation of the arithmetic progression [1, 9, 17, 25, 33], and no smaller prime works.
%p A394280 lcat:= proc(L)
%p A394280   local t,i;
%p A394280   t:= L[1];
%p A394280   for i from 2 to nops(L) do t:= t*10^(ilog10(L[i])+1)+L[i] od;
%p A394280   t
%p A394280 end proc:
%p A394280 h:= proc(a,d,n) local i; [-lcat([seq(a+i*d,i=0..n-1)]),a,d] end proc:
%p A394280 f:= proc(n) uses priqueue;
%p A394280   local pq, t,count;
%p A394280   if n mod 3 = 0 then return -1 fi;
%p A394280   initialize(pq);
%p A394280   if n::even then insert(h(1,2,n),pq); insert(h(2,1,n),pq) else insert(h(1,1,n),pq) fi;
%p A394280   for count from 1 do
%p A394280     t:= extract(pq);
%p A394280     if isprime(-t[1]) then return -t[1] fi;
%p A394280     if n::odd then insert(h(t[2],t[3]+1,n),pq); if t[3]=1 then insert(h(t[2]+2,t[3],n),pq) fi
%p A394280     else insert(h(t[2],t[3]+2,n),pq); if t[3]<=2 then insert(h(t[2]+2,t[3],n),pq) fi
%p A394280     fi;
%p A394280    od;
%p A394280 end proc:
%p A394280 f(1):= 2:
%p A394280 map(f, [$1..30]);
%K A394280 sign,base,new
%O A394280 1,1
%A A394280 _Robert Israel_, Apr 13 2026
