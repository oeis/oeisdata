%T A394020 1,2,5,1,2,5,1,4,7,1,4,6,2,4,9,2,6,9,2,6,11,4,8,11,4,8,15,4,11,15,6,
%U A394020 11,17,6,14,21,8,15,23,8,18,24,11,20,29,11,22,31
%N A394020 Expansion of g.f.: Product_{k>=1} 1 / (1 - x^(k^2 + 5)).
%C A394020 In general, if b > 0 and g.f. is Product_{k>=1} 1/(1 - x^(k^2 + b)), then a(n) ~ sqrt(b) * zeta(3/2)^(2/3) * exp(3*Pi^(1/3) * zeta(3/2)^(2/3) * n^(1/3) / 2^(4/3)) / (2^(7/3) * sqrt(3) * Pi^(1/6) * sinh(Pi*sqrt(b)) * n^(7/6)) * (1 - (34 + 9*b*Pi * zeta(1/2) * zeta(3/2)) / (9*2^(5/3) * Pi^(1/3) * zeta(3/2)^(2/3) * n^(1/3))).
%C A394020 a(n) is the number of partitions of n into parts of the form k^2+5 (for k>=1).
%H A394020 Vaclav Kotesovec, <a href="/A394020/b394020.txt">Table of n, a(n) for n = 0..10000</a>
%F A394020 a(n) ~ sqrt(5) * zeta(3/2)^(2/3) * exp(3*Pi^(1/3) * zeta(3/2)^(2/3) * n^(1/3) / 2^(4/3)) / (2^(7/3) * sqrt(3) * Pi^(1/6) * sinh(Pi*sqrt(5)) * n^(7/6)) * (1 - (34 + 45*Pi * zeta(1/2) * zeta(3/2)) / (9*2^(5/3) * Pi^(1/3) * zeta(3/2)^(2/3) * n^(1/3))).
%t A394020 nmax = 150; CoefficientList[Series[1/Product[1 - x^(k^2 + 5), {k, 1, Floor[Sqrt[nmax]+1]}], {x, 0, nmax}], x]
%Y A394020 Cf. A001156, A393990, A394017, A394018, A394019.
%K A394020 nonn,new
%O A394020 0,19
