%I A394570 #70 Jun 11 2026 18:08:18
%S A394570 1,3,6,11,14,22,24,29,34,45,45,59,57,69,79,76,79,97,92,117,124,123,
%T A394570 114,147,131,156,144,175,160,231,176,183,212,206,234,229,219,240,263,
%U A394570 277,248,343,267,289,313,287,275,347,300,332,352,375,327,362,387,422,408,394,364,525
%N A394570 Number of integers of the form r^k (with 0 < r < n and k > 0) whose base n digital root is r, and whose number of digits in base n is k.
%C A394570 This includes both the trivial single-digit solutions where k = 1 (the numbers 1 through n-1) and the nontrivial solutions where k > 1.
%C A394570 The number of solutions for a given base n is finite and grows asymptotically on the order of n*log(n).
%e A394570 a(2) = 1: the only solution is 1 (base 2: "1", r=1, k=1).
%e A394570 a(3) = 3: the trivial solutions 1, 2 plus the nontrivial 4 (base 3: "11", r=2, k=2).
%e A394570 a(4) = 6: the trivial solutions 1, 2, 3 plus the nontrivial 9 (base 4: "21", r=3, k=2), 27 (base 4: "123", r=3, k=3), and 81 (base 4: "1101", r=3, k=4).
%e A394570 a(10) = 34: composed of 9 trivial numbers (1 through 9), 20 nontrivial powers of 9 (from 9^2 to 9^21), 2401 (7^4), and the isolated powers of 8: 512 (8^3), 32768 (8^5), 2097152 (8^7), and 134217728 (8^9).
%o A394570 (Python)
%o A394570 def run(m=94):
%o A394570     out = []
%o A394570     for b in range(2, m + 1):
%o A394570         c = 0
%o A394570         for r in range(1, b):
%o A394570             k = 1
%o A394570             while True:
%o A394570                 n = r**k
%o A394570                 temp, l = n, 0
%o A394570                 while temp > 0: temp //= b; l += 1
%o A394570                 if l < k: break
%o A394570                 if 1 + (n - 1) % (b - 1) == r: c += 1
%o A394570                 k += 1
%o A394570         out.append(str(c))
%o A394570     print(", ".join(out))
%o A394570 run()
%K A394570 nonn,base
%O A394570 2,2
%A A394570 _Ali Sidheek_, Jun 05 2026
