%T A394748 1161112014816551371140050304,504278939870282942821244356751540480,
%U A394748 3485923705290899145179275868843375823439743104,383790387521691807115938942836847455829111811842081133568
%N A394748 a(n) is the hafnian of the 2n X 2n symmetric matrix defined by M[i, j] = C(n, (j-i) mod n).
%H A394748 Wikipedia, <a href="https://en.wikipedia.org/wiki/Hafnian">Hafnian</a>.
%H A394748 Wikipedia, <a href="https://en.wikipedia.org/wiki/Symmetric_matrix">Symmetric matrix</a>.
%e A394748 a(2) = 68 because the hafnian of
%e A394748   [1, 4, 6, 4]
%e A394748   [4, 1, 4, 6]
%e A394748   [6, 4, 1, 4]
%e A394748   [4, 6, 4, 1]
%e A394748 equals M_{1,2}*M_{3,4} + M_{1,3}*M_{2,4} + M_{1,4}*M_{2,3} = 68.
%t A394748 M[i_, j_, n_]:=Part[Part[Table[Binomial[n,Mod[j-i,n]], {r, n}, {c, n}], i], j]; a[n_]:=Sum[Product[M[Part[PermutationList[s, 2n], 2i-1], Part[PermutationList[s, 2n], 2i], 2n], {i, n}], {s, SymmetricGroup[2n]//GroupElements}]/(n!*2^n); Array[a, 5, 0]
%o A394748 (PARI) tm(n) = matrix(n, n, i, j, binomial(n, (j-i) % n));
%o A394748 a(n) = my(m = tm(2*n), s=0); forperm([1..2*n], p, s += prod(j=1, n, m[p[2*j-1], p[2*j]]); ); s/(n!*2^n); \\ _Michel Marcus_, Apr 03 2026
