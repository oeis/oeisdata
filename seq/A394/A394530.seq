%N A394530 Square array A(n,k), n >= 0, k >= 1, read by antidiagonals downwards, where A(n,k) = k^(n*(k-1)) - Sum_{j=1..k-1} k^(n*(k-1-j)) * j^n * A(n,j).
%F A394530 Sum_{j=1..k} j^n * A(n,j)/k^(n*j) = 1.
%e A394530 Square array A(n,k) begins:
%e A394530   1,  0,     0,          0,              0, ...
%e A394530   1,  1,     4,         28,            278, ...
%e A394530   1,  3,    60,       3108,         304272, ...
