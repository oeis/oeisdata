%e A394530   1, 15,  6240,   16144800,   147801031200, ...
%e A394530   1, 31, 57814, 1057628638, 94200312330938, ...
%o A394530 (PARI) a(n, k) = k^(n*(k-1))-sum(j=1, k-1, k^(n*(k-1-j))*j^n*a(n, j));
