%T A394318 36097600,24344320,4732249,400905884,4986940816,20331927616,
%U A394318 32127455360,17041024000,901188997,109134331716,1991708993976,12548494230272,34098408664320,41078395438080,17961239296000
%N A394318 Triangle T(n,k), n >= 0, 0 <= k <= n, read by rows, where T(0,0) = 1 and T(n,k) = 2*(k+1)*(2*k+1) * T(n-1,k+1) + (4*(4*k + 1)*n + 8*k^2 - 8*k - 3) * T(n-1,k) + 2*(4*n + 2*k - 5)*(2*n + k - 1) * T(n-1,k-1), with T(n,k) = 0 if k < 0 or k >= n+1.
%H A394318 Seiichi Manyama, <a href="/A394318/b394318.txt">Rows n = 0..139, flattened</a>
%e A394318 n\k |     0        1         2         3         4
%e A394318 ----+----------------------------------------------
%e A394318   0 |     1;
%e A394318   1 |     1,       4;
%e A394318   2 |    13,     188,      280;
%e A394318   3 |   493,   15480,    62832,    58240;
%e A394318   4 | 37369, 2048488, 15791424, 36097600, 24344320;
%o A394318 (PARI) T(n, k) = if(k<0 || k>=n+1, 0, if(n==0 && k==0, 1, 2*(k+1)*(2*k+1)*T(n-1, k+1)+(4*(4*k+1)*n+8*k^2-8*k-3)*T(n-1, k)+2*(4*n+2*k-5)*(2*n+k-1)*T(n-1, k-1)));
%Y A394318 Columns k=0..1 give A281181, A394319.
%Y A394318 Cf. A394012.
%K A394318 nonn,tabl,new
%O A394318 0,3
