%T A394434 41,3,11,47,3,41,53,3,29,59,3,2791,17,3,101,41,3,7253,101,3,17,83,3,
%U A394434 173,11,3,47,6299,3,197,41,3,53,107,3,11,17,3,59,1889,3,733,101,3
%N A394434 a(n) is the smallest prime factor of Sum_{k=0..n} 10^2k
%H A394434 Michael S. Branicky, <a href="/A394434/b394434.txt">Table of n, a(n) for n = 1..344</a> (using factordb.com)
%H A394434 factordb.com, <a href="https://factordb.com/index.php?query=%2810%5E%282%2An%2B2%29-1%29%2F99">Status of (10^(2*n+2)-1)/99</a>.
%F A394434 a(n) = 3 if n mod 3 == 2.
%F A394434 a(n) = A020639((10^(2*n+2)-1)//99).
%F A394434 a(n) = A020639(A094028(n)). - _Michael S. Branicky_, Apr 18 2026
%e A394434 a(1) = 101 since 101 is prime.
%e A394434 a(2) = 3 since 10101 = 3*7*13*37.
%e A394434 a(3) = 73 since 1010101 = 73*101*137.
%e A394434 a(4) = 41 since 101010101 = 41*271*9091.
%o A394434 (Python)
%o A394434 from sympy import factorint
%o A394434 def a(n): return min(factorint((10**(2*n+2)-1)//99))
%o A394434 print([a(n) for n in range(1, 46)]) # _Michael S. Branicky_, Apr 18 2026
%o A394434 (Julia)
%o A394434 function a(n)
%o A394434     num = (big(10)^(2n + 2) - 1) ÷ 99
%o A394434     for i in 3:2:num
%o A394434         if num % i == 0
%o A394434             return i
%o A394434         end
%o A394434     end
%o A394434 end # _Hoang Nguyen_, Apr 21 2026
