%I A394546 #13 Apr 11 2026 16:25:32
%S A394546 252,272,323,343,414,434,444,464,494,525,555,575,585,595,616,636,646,
%T A394546 656,666,676,686,696,767,777,828,848,868,888,949,969,989,999,2002,
%U A394546 2112,2992,3003,3553,4004,4224,4554,4774,4884,5005,5115,5225,5445,6006,6336,6996
%N A394546 Base 10 palindromes greater than 1 such that division by their highest prime factor does not result in a palindrome.
%H A394546 James C. McMahon, <a href="/A394546/b394546.txt">Table of n, a(n) for n = 1..1000</a>
%H A394546 Mathematics Stack Exchange, <a href="https://math.stackexchange.com/questions/200835/are-there-infinitely-many-super-palindromes">Are there infinitely many "super-palindromes"?</a>.
%e A394546 252 is in this list since its highest prime factor is 7. 252/7=36 is not a palindrome.
%p A394546 ispal:=proc(n) local L;
%p A394546    L:= convert(n,base,10);
%p A394546    andmap(t -> L[-t]=L[t],[$1..nops(L)/2])
%p A394546 end proc:
%p A394546 rev:= proc(n) local L,i;
%p A394546   L:= convert(n,base,10);
%p A394546   add(L[-i]*10^(i-1),i=1..nops(L))
%p A394546 end proc:
%p A394546 F:= proc(m)
%p A394546    local x1, x2, x3;
%p A394546    if m::even then
%p A394546      [seq(seq(rev(x1) + 10^(m/2)*x1, x1 = 10^(m/2-1) .. 10^(m/2)-1))]
%p A394546    else
%p A394546      [seq(seq(rev(x1) + 10^((m-1)/2)*x2 + 10^((m+1)/2)*x1, x2=0..9), x1=10^((m-1)/2-1)..10^((m-1)/2)-1)];
%p A394546    fi
%p A394546 end proc:
%p A394546 filter:= proc(x) not ispal(x/max(NumberTheory:-PrimeFactors(x))) end proc:
%p A394546 seq(op(select(filter, F(d))),d=1..4); # _Robert Israel_, Mar 30 2026
%t A394546 q[k_]:=PalindromeQ[k]&&!PalindromeQ[k/FactorInteger[k][[-1,1]]];Select[Range[7000],q] (* _James C. McMahon_, Apr 07 2026 *)
%o A394546 (Python)
%o A394546 from itertools import islice
%o A394546 from sympy import primefactors
%o A394546 from oeis_sequences.OEISsequences import is_pal, pal10_gen
%o A394546 def A394546_gen(): # generator of terms
%o A394546     return filter(lambda m: m>1 and not is_pal(m//max(primefactors(m))), pal10_gen())
%o A394546 A394546_list = list(islice(A394546_gen(), 49)) # _Chai Wah Wu_, Apr 07 2026
%Y A394546 Cf. A002113, A394544, A394545.
%K A394546 nonn,base,easy
%O A394546 1,1
%A A394546 _Robin Jones_, Mar 30 2026
