%T A394746 6,2,6,7,2,5,7,6,3,5,6,6,7,2,5,9,4,6,8,5,5,6,6,7,7,4,7,10,2,4,11,8,5,
%U A394746 7,5,8,7,5,8,10,6,5,11,4,5,10,6,12,7,2
%N A394746 a(n) = number of triples (x, y, z) such that x^2 + y*z = n, where x,y,z are positive integers satisfying x <= y <= z.
%H A394746 Vincenzo Librandi, <a href="/A394746/b394746.txt">Table of n, a(n) for n = 0..10000</a>
%e A394746 a(10) = 3 counts these triples: (1, 1, 9), (1, 3, 3), (2, 2, 3).
%t A394746 t[n_, c_] := Module[{r}, r = Flatten[Table[If[n - x^2 <= 0, {},
%t A394746        Map[({x, #, Quotient[n - x^2, #]} &),
%t A394746        Select[Divisors[n - x^2], Divisible[n - x^2, #] &]]], {x, 1,
%t A394746        Floor[Sqrt[n - 1]]}], 1]; Select[r, Apply[c, #] &]];
%t A394746 c = (#1 <= #2 <= #3 &);
%t A394746 Join[{0}, Table[Length[t[n, c]], {n, 1, 130}]]
%t A394746 (* _Peter J. C. Moses_, Mar 29 2026 *)
%t A394746 (* Alternative: *)
%t A394746 Join[{0},Table[Sum[Length@Select[Divisors[n-x^2],x<=#<=(n-x^2)/#&],{x,1,Floor[Sqrt[n-1]]}],{n,1,100}]] (* _Vincenzo Librandi_, Apr 23 2026 *)
%o A394746 (Magma) a := function(n) c := 0; for x in [1..Floor(Sqrt(n))] do m := n - x^2; if m gt 0 then
%o A394746 c +:= #[d : d in Divisors(m) | d ge x and d le m div d]; end if; end for; return c; end function; [a(n) : n in [0..100]]; // _Vincenzo Librandi_, Apr 23 2026
