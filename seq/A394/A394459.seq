%T A394459 290,351,441,531,661,795,981,1174,1440,1722,2096,2497,3021,3594,4324,
%U A394459 5124,6137,7256,8652,10204,12115,14252,16863,19784,23325,27305,32086,37470,43904,51161,59771
%N A394459 Number of partitions p of n such that 3 * (the greatest multiplicity of the parts of p) is a part of p.
%F A394459 G.f.: Sum_{j>=1} Product_{k>=1} (-delta(3*j,k) + (1-q^((j+1)*k))/(1-q^k)) - Product_{k>=1} (-delta(3*j,k) + (1-q^(j*k))/(1-q^k)), where delta(j,k) is the Kronecker delta.
%e A394459 a(10) counts these 6 partitions: 73, 631, 622, 6211, 532, 4321.
%o A394459 (PARI) my(N=60, q='q+O('q^N)); concat([0, 0], Vec(sum(j=1, N, prod(k=1, 3*N, -(3*j==k)+(1-q^((j+1)*k))/(1-q^k))-prod(k=1, 3*N, -(3*j==k)+(1-q^(j*k))/(1-q^k)))))
%Y A394459 Cf. A365613, A394458.
%K A394459 nonn
%O A394459 1,8
