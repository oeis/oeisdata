%S A394668 1,0,1,4,14,52,197,744,2833,10776,40899,154709,582925,2186867,8166824,
%T A394668 30356317,112302573,413501182,1515404880,5528096761,20075018700,
%U A394668 72579401227,261273265048,936590133846,3343695225246,11889828821851,42115784612366,148621625010955,522556189965294
%N A394668 Number of partitions of n^2 into prime parts.
%H A394668 Alois P. Heinz, <a href="/A394668/b394668.txt">Table of n, a(n) for n = 0..200</a>
%F A394668 a(n) = A000607(n^2).
%e A394668 For n = 2, a(2) = 1 because n^2 = 4 can be partitioned into primes in exactly 1 way:
%e A394668   4 = 2 + 2.
%e A394668 For n = 3, a(3) = 4 because n^2 = 9 has exactly 4 partitions into prime parts:
%e A394668   9 = 7 + 2, 9 = 5 + 2 + 2, 9 = 3 + 3 + 3, 9 = 3 + 2 + 2 + 2.
%t A394668 a[n_]:=Length[IntegerPartitions[n^2,All,Prime[Range[PrimePi[n^2]]]]];Array[a,14,0] (* _James C. McMahon_, May 07 2026 *)
%o A394668 (PARI) my(N=1000, x='x+O('x^N), p=1/prod(k=1,N,1-x^prime(k))); vector(sqrtint(N), i, polcoeff(p,(i-1)^2)) \\ _Michel Marcus_, May 07 2026
%Y A394668 Subsequence of A000607.
%Y A394668 Cf. A000290.
%K A394668 nonn,new
