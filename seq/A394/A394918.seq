%I A394918 #20 Apr 14 2026 22:34:05
%S A394918 1,4,8,12,24,88,36,60,96,72,144,252,180,912,240,432,480,360,540,1152,
%T A394918 1008,1728,720,1080,1980,1440,2640,4560,7392,2880,4800,2160,3600,3780,
%U A394918 5760,4320,6048,10560,11520,6480,5040,8400,9360,11880,7560,19800,12960,17640,16800,10080,28800
%N A394918 Least integer k such that A394475(k) = n.
%C A394918 Except for a(1), all terms appear to be even.
%C A394918 This is true. If k is odd then adjacent primes must be a multiple of 2. There is only one such prime. So A394475(k) = 1 for odd k. - _David A. Corneth_, Apr 07 2026
%p A394918 f:= proc(n) local D;
%p A394918    D:= NumberTheory:-Divisors(n);
%p A394918    nops(select(isprime, (D +~ 1) union (D -~ 1) minus D))
%p A394918 end proc:
%p A394918 V:= Vector(100): count:= 0:
%p A394918 for n from 1 while count < 100 do
%p A394918   v:= f(n);
%p A394918   if v <= 100 and V[v] = 0 then V[v]:= n; count:= count+1 fi
%p A394918 od:
%p A394918 convert(V,list); # _Robert Israel_, Apr 10 2026
%t A394918 f[n_] := Block[{d = Divisors[n]}, Length[ Select[ Union[ Join[d -1, d +1]], PrimeQ@# && Mod[n, #] > 0 &]]]; t[_] := 0; t[1] = 1; k = 2; While[ k < 28801, If[ t[f[k]] == 0, t[f[k]] = k]; k+=2]; t /@ Range@ 51
%Y A394918 Cf. A394475.
%K A394918 nonn,new
%O A394918 1,2
%A A394918 _Robert G. Wilson v_, Apr 06 2026
