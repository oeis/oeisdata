%S A394161 0,1,1,4,22,139,951,6855,51272,394204,3096234,24736726,200395374,
%T A394161 1642308158,13591395172,113424043732,953433146448,8065360983795,
%U A394161 68608905310365,586529022954170,5036433199693944,43419795094441061,375679865662904821,3261148423057895137
%N A394161 G.f. A(x) satisfies A(x)^5-3x*A(x)^3+2x^2*A(x)^2+x^2*A(x)-x^3=0.
%C A394161 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with green root where red vertices can be followed by vertices of any colors, blue vertices can be followed red or green vertices, and green vertices can only be followed by red vertices.
%H A394161 Nathan Fox, <a href="/A394161/b394161.txt">Table of n, a(n) for n = 0..300</a>
%H A394161 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394161 (Python)
%o A394161 def A394161(n):
%o A394161     A = [[1, 1, 1], [1, 0, 1], [1, 0, 0]]
%o A394161     if n == 0:
%o A394161         return 0
%o A394161     m = len(A)
%o A394161     output = [[1] for i in range(m)]
%o A394161     for l in range(2, n + 1):
%o A394161         for i in range(m):
%o A394161             term = 0
%o A394161             for k in range(1, l):
%o A394161                 for j in range(m):
%o A394161                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394161             output[i].append(term)
%o A394161     return output[2][n - 1]
%Y A394161 Cf. A394159, A394160.
%K A394161 nonn
%O A394161 0,4
%A A394161 _Nathan Fox_, Mar 12 2026
