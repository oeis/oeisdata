%T A394938 12,12,12,12,12,13,13,13,13,13,13,13,13,13,13,13,13,13,13,13,13,14,14,
%U A394938 14,14,14,14,14,14,14,14,14,14,14,14,14,14,15,15,15,15,15,15,15,15,15,15,15,15,15,15,15,15,15,15,15,15,15,15,15,15,15,15,15,15,15,15,15,15,16
%N A394938 a(n) = floor(log_2(2*n - 1)) + floor(log_2(2*n - 1 - 2^(floor(log_2(2*n - 2)) - 1))) + 2.
%C A394938 For n >= 3, a(n) is the tree-depth of the n-antiprism graph.
%C A394938 The n-antiprism graph is isomorphic to the square of the cycle C_{2n}.
%H A394938 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/AntiprismGraph.html">Antiprism Graph</a>.
%H A394938 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/Tree-Depth.html">Tree-Depth</a>.
%F A394938 a(n) = floor(log_2(2*n - 1)) + floor(log_2(2*n - 1 - 2^(floor(log_2(2*n - 2)) - 1))) + 2 for n >= 2.
%e A394938 a(2) = 4 since floor(log_2(3)) + floor(log_2(2)) + 2 = 4.
%t A394938 Table[Floor[Log2[2 n - 1]] + Floor[Log2[2 n - 1 - 2^(Floor[Log2[2 n - 2]] - 1)]] + 2, {n, 2, 20}]
%Y A394938 Cf. A395540 (tree-depths of prism graphs).
%K A394938 nonn,easy
%O A394938 2,1
%A A394938 _Eric W. Weisstein_, Jul 01 2026
