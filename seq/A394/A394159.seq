%I A394159 #6 Mar 14 2026 14:59:53
%S A394159 0,1,3,15,90,596,4201,30914,234762,1826115,14475844,116519561,
%T A394159 949796170,7824502587,65041870260,544875042424,4595487488778,
%U A394159 38988813080412,332526805073245,2849339018582430,24517898025477326,211770540131237086,1835429075376595083
%N A394159 G.f. A(x) satisfies A(x)^5-4*A(x)^4+(6-2x)*A(x)^3+(3x-4)*A(x)^2+A(x)+x^2-x=0.
%C A394159 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with red root where red vertices can be followed by vertices of any colors, blue vertices can be followed red or green vertices, and green vertices can only be followed by red vertices.
%H A394159 Nathan Fox, <a href="/A394159/b394159.txt">Table of n, a(n) for n = 0..300</a>
%H A394159 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394159 (Python)
%o A394159 def A394159(n):
%o A394159     A = [[1, 1, 1], [1, 0, 1], [1, 0, 0]]
%o A394159     if n == 0:
%o A394159         return 0
%o A394159     m = len(A)
%o A394159     output = [[1] for i in range(m)]
%o A394159     for l in range(2, n + 1):
%o A394159         for i in range(m):
%o A394159             term = 0
%o A394159             for k in range(1, l):
%o A394159                 for j in range(m):
%o A394159                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394159             output[i].append(term)
%o A394159     return output[0][n - 1]
%Y A394159 Cf. A394160, A394161.
%K A394159 nonn
%O A394159 0,3
%A A394159 _Nathan Fox_, Mar 12 2026
