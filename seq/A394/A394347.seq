%I A394347 #34 Jul 23 2026 00:59:00
%S A394347 101,11,2,3,41,5,61,7,83,19,103,113,127,13,149,151,163,17,181,191,
%T A394347 1201,211,223,23,241,251,263,227,281,29,307,31,1321,233,347,353,367,
%U A394347 37,383,139,401,419,421,43,443,457,461,47,487,349,503,751,521,53,541,557,563,157,587,59,601,613,1621
%N A394347 a(n) is the least prime not previously used containing n as a substring.
%C A394347 First differs from A062584 at n = 10.
%C A394347 This sequence is a permutation of the primes. If a(prime(k)) = prime(m) then k >= m. prime(m) occurs at a(k) where k <= prime(m). - _David A. Corneth_, Jul 19 2026
%H A394347 Robert Israel, <a href="/A394347/b394347.txt">Table of n, a(n) for n = 0..10000</a>
%e A394347 a(10) = 103 because 103 is a prime and contains 10 as a substring, and smaller prime 101 that contains 10 as a substring has already been used as a(0).
%p A394347  f:= proc(n) local d,m,m1,i,j,Cands,y;
%p A394347   d:= 1 + ilog10(n);
%p A394347   if isprime(n) and not member(n,Used) then return n fi;
%p A394347   for m from 1 do
%p A394347     if member(n mod 10, [1,3,7,9]) then Cands:= seq(i*10^d+n, i=10^(m-1)..10^m-1)
%p A394347     else Cands:= NULL
%p A394347     fi;
%p A394347     Cands:= sort([Cands, seq(10^m*n+i, i=1..10^m-1,2),
%p A394347              seq(seq(seq(10^(m1+d)*i + 10^m1*n+j,i=10^(m-m1-1)..10^(m-m1)-1),j=1..10^m1-1,2),
%p A394347                m1=1..m-1) ]);
%p A394347     for y in Cands do if ListTools:-BinarySearch(Used,y) = 0 and isprime(y) then return y fi;
%p A394347   od od;
%p A394347 end proc:
%p A394347 Used:= [101]: R:= 101:
%p A394347 for n from 1 to 100 do
%p A394347   v:= f(n);
%p A394347   R:= R,v;
%p A394347   j:= ListTools:-BinaryPlace(Used,v);
%p A394347   Used:= [op(Used[1..j]),v,op(Used[j+1..-1])];
%p A394347 od:
%p A394347 R;
%Y A394347 Cf. A062584, A086887.
%K A394347 nonn,base,new
%O A394347 0,1
%A A394347 _Robert Israel_, Jul 19 2026
