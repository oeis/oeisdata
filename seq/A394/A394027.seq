%N A394027 Number of partitions p of n with multiplicity of each part at most 3, satisfying max(p) = 2 * min(p).
%H A394027 Vincenzo Librandi, <a href="/A394027/b394027.txt">Table of n, a(n) for n = 1..1000</a>
%F A394027 G.f.: Sum_{j>=1} q^(3*j)*(1-q^(3*j))*(1-q^(6*j))/((1-q^j)*(1-q^(2*j))) * Product_{k=j+1..2*j-1} (1-q^(4*k))/(1-q^k).
%t A394027 Nmax=60; a=CoefficientList[Series[Sum[q^(3*j)*(1-q^(3*j))*(1-q^(6*j))/((1-q^j)*(1-q^(2*j)))*Product[(1-q^(4*k))/(1-q^k),{k,j+1,2*j-1}],{j,1,Nmax}],{q,0,Nmax}],q][[2;;]] (* _Vincenzo Librandi_, Mar 08 2026 *)
%o A394027 (Magma) Nmax := 70; R<q> := PowerSeriesRing(Integers(), Nmax+1); S := &+[ q^(3*j)*(1-q^(3*j))*(1-q^(6*j))/((1-q^j)*(1-q^(2*j)))* (IsEmpty([j+1..2*j-1]) select 1 else &*[(1-q^(4*k))/(1-q^k) : k in [j+1..2*j-1]]) : j in [1..Nmax] ];a := [Coefficient(S,n) : n in [1..Nmax]];a; // _Vincenzo Librandi_, Mar 08 2026
