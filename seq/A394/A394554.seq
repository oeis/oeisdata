%I A394554 #23 May 05 2026 11:03:12
%S A394554 1,2,4,10,19,55,130,284,712,1768,5795,17017,68263,195545,545258,
%T A394554 1698179,11990404,28003819,99712613,370052707,1990586012,7319328937
%N A394554 Smallest number m such that m*(m+1)*(m+2)*(m+3) has at least n distinct prime factors.
%C A394554 a(24)>10^10.
%e A394554 For n = 9, a(9)*(a(9) + 1)*(a(9) + 2)*(a(9) + 3) = 284*285*286*287 = (2*2*71)*(3*5*19)*(2*11*13)*(7*41) with 9 distinct prime factors.
%t A394554 n=2; For[k=1, k<=100000, k++, If[PrimeNu[Times@@{k, k+1, k+2, k+3}]==n, Print[{n, k}]; n++]]
%o A394554 (Python)
%o A394554 from itertools import count, islice
%o A394554 from sympy import factorint
%o A394554 def agen(): # generator of terms
%o A394554     wlst, adict, n = [set(factorint(1+i)) for i in range(4)], dict(), 2
%o A394554     for m in count(1):
%o A394554         v = len(wlst[0] | wlst[1] | wlst[2] | wlst[3])
%o A394554         if v >= n and v not in adict:
%o A394554             adict[v] = m
%o A394554             for i in range(n, v+1):
%o A394554                 yield m
%o A394554             n = v+1
%o A394554         wlst = wlst[1:] + [set(factorint(m+4))]
%o A394554 print(list(islice(agen(), 15))) # _Michael S. Branicky_, May 05 2026
