%S A394483 1,14,123,868,5381,30618,163951,839216,4149561,19965862,93983459,
%T A394483 434539644,1979490541,8905610546,39644780247,174898055752,
%U A394483 765599756321,3328753681470,14387794339915,61865541045140,264792841394901,1128724202207434,4793829919712063,20293311558669408,85652274492374281
%N A394483 Expansion of 1/((1-3*x)^2*(1-4*x)^2).
%C A394483 Number of n length words consisting of parts p1, p2, p3, p4 (part i is to the left of part j iff i <= j), where p1 comes in 3 colors, p2 comes in 3 colors (different from those in p1), p3 comes in 4 colors, p4 comes in 4 colors (different from those in p3), and every part can be used any number of times (including 0).
%C A394483 Equivalently, sum of products 3^(p1)*3^(p2)*4^(p3)*4^(p4) where p1 + p2 + p3 + p4 = n, pi nonnegative integers.
%H A394483 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (14,-73,168,-144).
%F A394483 a(n) = (n-5)*4^(n+2) + (n+9)*3^(n+2).
%F A394483 a(n) = 14*a(n-1) - 73*a(n-2) + 168*a(n-3) - 144*a(n-4).
%F A394483 E.g.f.: (4*x-5)*16*exp(4*x) + (x+3)*27*exp(3*x).
%e A394483 For n=2: the 123 words of length 2 are the following (number of words in parentheses): p1p1 (9), p2p2 (9), p3p3 (16), p4p4 (16), p1p2 (9), p1p3 (12), p1p4 (12), p2p3 (12), p2p4 (12), p3p4 (16).
%t A394483 LinearRecurrence[{14,-73,168,-144},{1,14,123,868},25] (* _Stefano Spezia_, Mar 22 2026 *)
