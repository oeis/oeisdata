%S A394670 1,0,1,0,4,2,0,24,6,6,0,192,48,24,24,0,1920,360,120,120,120,0,23040,
%T A394670 3600,1440,720,720,720,0,322560,40320,15120,5040,5040,5040,5040,0,
%U A394670 5160960,524160,161280,80640,40320,40320,40320,40320,0,92897280,7620480,2177280,1088640,362880,362880,362880,362880,362880
%N A394670 Triangle read by rows: T(n,k) is the number of ways n students take an exam one by one on any number of consecutive days as long as there are at least k students for each day.
%D A394670 Miklos Bona, Introduction to Enumerative and Analytic Combinatorics, CRC Press, 2025, pp. 159-160.
%H A394670 Stefano Spezia, <a href="/A394670/b394670.txt">Table of n, a(n) for n = 0..5049</a> (first 100 rows of the triangle, flattened)
%F A394670 T(n,k) = n! * [x^n] 1/(1 - x^k/(1 - x)) with 0 <= k <= n.
%e A394670 The triangle begins as:
%e A394670   1;
%e A394670   0,     1;
%e A394670   0,     4,    2;
%e A394670   0,    24,    6,    6;
%e A394670   0,   192,   48,   24,  24;
%e A394670   0,  1920,  360,  120, 120, 120;
%e A394670   0, 23040, 3600, 1440, 720, 720, 720;
%e A394670   ...
%t A394670 T[n_,k_]:=n!SeriesCoefficient[1/(1-x^k/(1-x)),{x,0,n}]; Table[T[n,k],{n,0,9},{k,0,n}]//Flatten
%Y A394670 Columns k=0..3 give A000007, A002866, A052554, A052557.
%Y A394670 The right diagonal gives A000142.
%Y A394670 Row sums give A394677.
%K A394670 nonn,easy,tabl
%O A394670 0,5
%A A394670 _Stefano Spezia_, Mar 28 2026
