%S A394122 0,1,3,15,88,559,3727,25684,181356,1304943,9533281,70525735,527306688,
%T A394122 3978695364,30259861028,231753838504,1785987343876,13839947940591,
%U A394122 107783375048053,843182435156557,6623126530363016,52217812304976311,413095130594086831
%N A394122 G.f. A(x) satisfies A(x)^6-A(x)^5+5x*A(x)^4-(x^2+2x)*A(x)^3+5x^2*A(x)^2-x^2*A(x)+x^3=0.
%C A394122 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with red root where blue vertices cannot be followed by red vertices and where green vertices can only be followed by blue vertices.
%H A394122 Nathan Fox, <a href="/A394122/b394122.txt">Table of n, a(n) for n = 0..300</a>
%H A394122 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394122 (Python)
%o A394122 def A394122(n):
%o A394122     A = [[1, 1, 1], [0, 1, 1], [0, 1, 0]]
%o A394122     if n == 0:
%o A394122         return 0
%o A394122     m = len(A)
%o A394122     output = [[1] for i in range(m)]
%o A394122     for l in range(2, n + 1):
%o A394122         for i in range(m):
%o A394122             term = 0
%o A394122             for k in range(1, l):
%o A394122                 for j in range(m):
%o A394122                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394122             output[i].append(term)
%o A394122     return output[0][n - 1]
%K A394122 nonn,new
%O A394122 0,3
%A A394122 _Nathan Fox_, Mar 11 2026
