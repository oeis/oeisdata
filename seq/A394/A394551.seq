%I A394551 #21 Apr 07 2026 23:02:35
%S A394551 1,-1,-7,-31,-23,1819,31801,361157,2317841,-23148937,-1289039399,
%T A394551 -32199607991,-584580114887,-6788560141741,37473531962777,
%U A394551 5627376380303789,228995509692709921,6754317963563729647,151414585086564404281
%N A394551 a(n) = n! * [x^n] exp(-Li_{-2}(x)), where Li_{-2}(x) = x*(1+x)/(1-x)^3 is the polylogarithm of order -2.
%C A394551 By the Truncation-Exactness Theorem (Phalak 2026), if P_n(x) = [exp(-Li_{-2}(x))]_{deg<=n} has roots rho_1,...,rho_n, then Sum_{i=1..n} rho_i^{-k} = k^3 exactly for k = 1,...,n.
%H A394551 Yogesh G. Phalak, <a href="/A394551/b394551.txt">Table of n, a(n) for n = 0..400</a>
%H A394551 Yogesh Phalak, <a href="https://arxiv.org/abs/2603.28828">Truncated Plethystic Exponentials Preserve Power Sum Constraints</a>, arXiv:2603.28828 [math.NT], 2026.
%F A394551 a(0) = 1; a(n) = -(1/n) * Sum_{j=1..n} j^3 * a(n-j) for n >= 1.
%F A394551 [This follows from differentiating f = exp(-g) to get f' = -g'*f, with g(x) = Li_{-2}(x) = Sum_{k>=1} k^2 * x^k, so g'(x) = Sum_{k>=1} k^3 * x^{k-1}.]
%F A394551 E.g.f.: exp(-Li_{-2}(x)) = exp(-x*(1+x)/(1-x)^3).
%e A394551 For n=1: a(1) = -(1/1) * 1^3 * a(0) = -1.
%e A394551 For n=2: a(2) = -(1/2) * (1^3 * a(1) + 2^3 * a(0)) = -(1/2)*(-1 + 8) = -7/2, and 2! * (-7/2) = -7, confirming a(2) is an integer.
%e A394551 For n=4: the roots of P_4(x) = [exp(-Li_{-2}(x))]_{deg<=4} satisfy Sum rho_i^{-k} = k^3 exactly for k=1,2,3,4.
%t A394551 CoefficientList[Series[Exp[-x*(1+x)/(1-x)^3],{x,0,21}],x]*Range[0,21]! (* _Stefano Spezia_, Mar 31 2026 *)
%Y A394551 Cf. A318215 (same construction with s=-1, alpha_k=k^2).
%Y A394551 Cf. A293116 (same construction with s=0, alpha_k=k).
%K A394551 sign,easy,new
%O A394551 0,3
