%T A394408 17592186044416,2251799813685248,288230376151711744,
%U A394408 36893488147419103232,4656612873077392578125,173472347597680709441192448139190673828125,6427752177035961102167848369364650410088811975131171341205504
%N A394408 Lesser of two consecutive numbers of the form 2^i*5^j with i, j >= 0, that are coprime.
%H A394408 Michael De Vlieger, <a href="/A394408/b394408.txt">Table of n, a(n) for n = 1..23</a>
%H A394408 Michael De Vlieger, <a href="/A394408/a394408.txt">Extended table of n, s(i), a(n), b(n)</a> for n = 1..29, where b = A394452 and s = A003592.
%e A394408 Let s = A003592 and b = A394452.
%e A394408 Table of n, a(n) for n = 1..12:
%e A394408  n          a(n)     b(n)
%e A394408 ----------------------------
%e A394408  1     s(1) = 1        2
%e A394408  2     s(3) = 2^2      5
%e A394408  3     s(4) = 5        2^3
%e A394408  4     s(9) = 5^2      2^5
%e A394408  5    s(16) = 5^3      2^7
%e A394408  6    s(25) = 2^9      5^4
%e A394408  7    s(68) = 2^16     5^7
%e A394408  8   s(132) = 2^23     5^10
%e A394408  9   s(217) = 2^30     5^13
%e A394408 10   s(323) = 2^37     5^16
%e A394408 11   s(450) = 2^44     5^19
%e A394408 12   s(598) = 2^51     5^22
%p A394408 M:= 10^80: # for terms <= M
%p A394408 L:= sort([seq(seq(2^i*5^j,i=0..floor(log[2](M/5^j))),j=0..floor(log[5](M)))]):
%p A394408 L[select(t -> igcd(L[t],L[t+1])=1, [$1..nops(L)-1])]; # _Robert Israel_, Mar 23 2026
%t A394408 s = With[{nn = 10^80}, Union@ Flatten@ Table[2^i* 5^j, {i, 0, Log2[nn]}, {j, 0, Log[5, nn/2^i] } ] ]; Select[Partition[s, 2, 1], CoprimeQ @@ # &][[;; , 1]]
%Y A394408 Cf. A003592, A186927, A393164, A394452.
%K A394408 nonn,new
%O A394408 1,2
%A A394408 _Michael De Vlieger_, Mar 20 2026
