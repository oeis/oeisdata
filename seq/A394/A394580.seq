%N A394580 Largest prime(n)-smooth k < primorial(n+1), where primorial = A002110.
%C A394580 Largest k < primorial(n+1) such that rad(k) | primorial(n), where rad = A007947.
%C A394580 Largest k < primorial(n+1) such that gpf(k) <= prime(n), where gpf = A006530.
%H A394580 Michael De Vlieger, <a href="/A394580/a394580.txt">Notes on this sequence</a>.
%F A394580 a(n) >= A061720(n).
%e A394580 Table of n, a(n), primorial(n+1) for n = 1..7:
%e A394580   n                       a(n)                     primorial(n+1)
%e A394580   ---------------------------------------------------------------
%e A394580   1   A000079(3)     =       4 = 2^2                           6
%e A394580   2   A003586(12)    =      27 = 3^3                          30
%e A394580   3   A051037(46)    =     200 = 2^4 * 5^2                   210
%e A394580   4   A002473(199)   =    2304 = 2^8 * 3^2                  2310
%e A394580   5   A051038(788)   =   30000 = 2^4 * 3 * 5^4             30030
%e A394580   6   A080197(3287)  =  510300 = 2^2 * 3^6 * 5^2 * 7      510510
%e A394580   7   A080681(13257) = 9696375 = 3^3 * 5^3 * 13^2 * 17   9699690
%t A394580 MapIndexed[(k = 1; p = Prime[First[#2] ]; While[FactorInteger[#1 - k][[-1, 1]] > p, k++]; #1 - k) &, Rest@ FoldList[Times, Prime@ Range[10] ] ]
%o A394580 (Python)
%o A394580 from functools import lru_cache
%o A394580 from sympy import prime, integer_log, primorial
%o A394580 from oeis_sequences.OEISsequences import bisection
%o A394580 def A394580(n):
%o A394580     ps = tuple(prime(i) for i in range(1,n+1))
%o A394580     @lru_cache(maxsize=None)
%o A394580     def g(x,m): return sum(g(x//ps[m-1]**i,m-1) for i in range(integer_log(x,ps[m-1])[0]+1)) if m-1 else x.bit_length()
%o A394580     k = g(primorial(n+1)-1,n)
%o A394580     return bisection(lambda x:k+x-g(x,n),k,k) # _Chai Wah Wu_, Apr 05 2026
%Y A394580 Cf. A000079, A002110, A002473, A003586, A006530, A007947, A051037, A051038, A061720, A080197, A080681, A080682, A080683.
