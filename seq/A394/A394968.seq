%I A394968 #29 Apr 12 2026 08:40:18
%S A394968 1,2,9,72,865,13803,271789,6318840,168569145,5058300495,168251893645,
%T A394968 6134532696534,243013370253329,10384740636942483,475886186077784085,
%U A394968 23269228564681306208,1208855249378669543785,66476561813824749886071,3857014388643231030003397
%N A394968 G.f. A(x) satisfies [x^n] exp( n*x/(1-n*x) - n*A(x) ) = 0 for n >= 1.
%H A394968 Seiichi Manyama, <a href="/A394968/b394968.txt">Table of n, a(n) for n = 1..382</a>
%F A394968 a(n) = n^(n-1) + (1/n) * Sum_{k=1..n-1} k * c_n(k) * e_n(n-k),
%F A394968 where c_n(k) = n^(k-1) - a(k) for 1 <= k <= n-1,
%F A394968 and e_n(0) = 1, e_n(k) = (n/k) * Sum_{j=1..k} j * c_n(j) * e_n(k-j) for 1 <= k <= n-1.
%e A394968 The table of coefficients of x^k in exp( n*x/(1-n*x) - n*A(x) ) begins:
%e A394968 n\k | 0  1   2    3        4      5          6
%e A394968 ----+----------------------------------------------
%e A394968   1 | 1, 0, -1,  -8,  -141/2,  -856,  -82195/6, ...
%e A394968   2 | 1, 0,  0, -10,  -128,   -1698,  -27492,   ...
%e A394968   3 | 1, 0,  3,   0,  -261/2, -2352,  -82161/2, ...
%e A394968   4 | 1, 0,  8,  28,     0,   -2212, -152684/3, ...
%e A394968   5 | 1, 0, 15,  80,   755/2,     0,  -91305/2, ...
%e A394968   6 | 1, 0, 24, 162,  1152,    6474,       0,   ...
%e A394968   7 | 1, 0, 35, 280,  5019/2, 20552,  802613/6, ...
%e A394968   8 | 1, 0, 48, 440,  4672,   46968,  435912,   ...
%e A394968   9 | 1, 0, 63, 648, 15795/2, 92088, 2062719/2, ...
%o A394968 (Ruby)
%o A394968 def A394968(n)
%o A394968   a = [0]
%o A394968   (1..n).each{|i|
%o A394968     c = [0] + (1..i - 1).map{|k| i ** (k - 1) - a[k]}
%o A394968     e = [1]
%o A394968     (1..i - 1).each{|k| e << i / k.to_r * (1..k).inject(0){|s, j| s + j * c[j] * e[k - j]}}
%o A394968     a << i ** (i - 1) + (1..i - 1).inject(0){|s, k| s + k * c[k] * e[i - k]}.to_i / i
%o A394968   }
%o A394968   a[1..-1]
%o A394968 end
%o A394968 p A394968(20)
%Y A394968 Cf. A317344, A394969.
%K A394968 nonn
