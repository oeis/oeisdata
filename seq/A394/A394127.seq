%S A394127 0,1,2,8,38,198,1096,6330,37722,230248,1432230,9046382,57865712,
%T A394127 374084722,2440256850,16042605800,106181903430,706975917526,
%U A394127 4731960602456,31820872887146,214885891901898,1456631639356008,9907950315975622,67604709705143518,462607860107453920
%N A394127 G.f. A(x) satisfies A(x)^3+(x-2)*A(x)^2+(1-x)*A(x)+x^2-x=0.
%C A394127 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with red root where red vertices can be followed by red or blue vertices, blue vertices can be followed by red or green vertices, and green vertices can only occur as leaves.
%H A394127 Nathan Fox, <a href="/A394127/b394127.txt">Table of n, a(n) for n = 0..300</a>
%H A394127 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394127 (Python)
%o A394127 def A394127(n):
%o A394127     A = [[1, 1, 0], [1, 0, 1], [0, 0, 0]]
%o A394127     if n == 0:
%o A394127         return 0
%o A394127     m = len(A)
%o A394127     output = [[1] for i in range(m)]
%o A394127     for l in range(2, n + 1):
%o A394127         for i in range(m):
%o A394127             term = 0
%o A394127             for k in range(1, l):
%o A394127                 for j in range(m):
%o A394127                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394127             output[i].append(term)
%o A394127     return output[0][n - 1]
%K A394127 nonn,new
%O A394127 0,3
%A A394127 _Nathan Fox_, Mar 11 2026
