%N A394052 Irregular triangle read by rows: T(n,k) is the number of positive integers <= n with exactly k divisors.
%H A394052 Alois P. Heinz, <a href="/A394052/b394052.txt">Rows n = 1..2000, flattened</a>
%F A394052 From _Alois P. Heinz_, Mar 08 2026: (Start)
%F A394052 Sum_{k=1..A070319(n)} k * T(n,k) = A006218(n).
%F A394052 Sum_{k=1..A070319(n)} (k-1) * T(n,k) = A002541(n).
%F A394052 Sum_{k=1..A070319(n)} k^2 * T(n,k) = A061502(n).
%F A394052 Sum_{k=1..A070319(n)} k^3 * T(n,k) = A318755(n).
%F A394052 Sum_{k=1..A070319(n)} (-1)^k * T(n,k) = A065651(n) for n>=2.
%F A394052 T(n,A070319(n)) = A140225(n).
%F A394052 T(n,A000005(n)) = A067004(n) = 1 + A047983(n). (End)
