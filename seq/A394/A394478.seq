%N A394478 a(n) = (2*n)! * [x^(2*n)] cosh(x)^2 / cos(x).
%F A394478 a(n) = (0^n + 4^n)/2 - Sum_{k=0..n-1} (-1)^(n-k) * binomial(2*n,2*k) * a(k).
%F A394478 a(n) = (1/2) * Sum_{k=0..n} (0^(n-k) + 4^(n-k)) * binomial(2*n,2*k) * A000364(k).
%o A394478 (PARI) a_vector(n) = my(v=vector(n+1)); for(i=0, n, v[i+1]=(0^i+4^i)/2-sum(j=0, i-1, (-1)^(i-j)*binomial(2*i, 2*j)*v[j+1])); v;
