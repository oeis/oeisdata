%o A394385 (PARI) C_xy(N) = { my(x='x+O('x^(N+2)), h = (1 - x*y + (x - 1)*sqrt((x^2*(y^2 + 4) - 2*x*(y + 2) + 1)/(x - 1)^2))/(2*x)); vector(N-1, n, Vecrev(polcoeff(h, n-1)))}
