%S A394475 1,1,1,2,1,2,1,3,1,2,1,4,1,2,1,4,1,4,1,3,1,2,1,5,1,1,1,4,1,4,1,5,1,1,
%T A394475 1,7,1,2,1,5,1,4,1,4,1,2,1,7,1,2,1,3,1,5,1,4,1,2,1,8,1,2,1,5,1,4,1,3,
%U A394475 1,4,1,10,1,2,1,3,1,3,1,7,1,2,1,7,1,1,1,6,1,7,1,3,1,1,1,9
%N A394475 Number of distinct primes not dividing n that are adjacent to a divisor of n.
%H A394475 David A. Corneth, <a href="/A394475/b394475.txt">Table of n, a(n) for n = 1..10000</a>
%H A394475 David A. Corneth, <a href="/A394475/a394475.gp.txt">PARI program</a>
%F A394475 From _David A. Corneth_, Apr 07 2026: (Start)
%F A394475 a(n) <= 2*A000005(n).
%F A394475 a(2*k + 1) = 1 for k >= 0. (End)
%e A394475    ------------------------------------------------
%e A394475      n    Divisors      Adjacent Primes     a(n)
%e A394475    ------------------------------------------------
%e A394475      1      {1}              {2}             1
%e A394475      2      {1,2}            {3}             1
%e A394475      3      {1,3}            {2}             1
%e A394475      4      {1,2,4}          {3,5}           2
%e A394475      5      {1,5}            {2}             1
%e A394475      6      {1,2,3,6}        {5,7}           2
%e A394475      7      {1,7}            {2}             1
%e A394475      8      {1,2,4,8}        {3,5,7}         3
%e A394475      9      {1,3,9}          {2}             1
%e A394475     10      {1,2,5,10}       {3,11}          2
%e A394475     ...
%p A394475 f:= proc(n) local D;
%p A394475    D:= NumberTheory:-Divisors(n);
%p A394475    nops(select(isprime, (D +~ 1) union (D -~ 1) minus D))
%p A394475 end proc:
%p A394475 map(f, [$1..200]); # _Robert Israel_, Mar 22 2026
%t A394475 A394475[n_] := Count[Complement[Join[#+1, #-1], #], _?PrimeQ] & [Divisors[n]];
%t A394475 Array[A394475, 100] (* _Paolo Xausa_, May 03 2026 *)
%o A394475 (PARI) a(n) = my(nb=0); forprime(p=1, n+1, if ((!(n % (p-1)) || !(n % (p+1))) && (n % p), nb++)); nb; \\ _Michel Marcus_, Mar 22 2026
%o A394475 (PARI) \\ See Corneth link
%Y A394475 Cf. A000005, A395492.
%K A394475 nonn,changed
%O A394475 1,4
%A A394475 _Wesley Ivan Hurt_, Mar 21 2026
