%S A394592 5,8,25,44,51,57,95,105,169,179,170,205,269,316,390,415,441,512,504,
%T A394592 511,618,790,834,853,893,838,892,1055,1005,1179,1236,1409,1438,1598,
%U A394592 1563,1772,1893,1685,2102,2227,2214,2109,2456,2459,2422,2732,2875,3054,3060,2851
%N A394592 Sum of the distinct prime divisors of C(5*n, n).
%H A394592 Vincenzo Librandi, <a href="/A394592/b394592.txt">Table of n, a(n) for n = 1..1000</a>
%F A394592 a(n) = sopf(binomial(5*n,n)) = A008472(A001449(n)).
%e A394592 a(4) = 44 because binomial(20,4) = 4845 = 3*5*17*19 and 3+5+17+19 = 44.
%e A394592 a(5) = 51 because binomial(25,5) = 53130 = 2*3*5*7*11*23 and 2+3+5+7+11+23 = 51.
%p A394592 a:= n-> add(i[1], i=ifactors(binomial(5*n, n))[2]):
%p A394592 seq(a(n), n=1..50);  # _Alois P. Heinz_, Apr 27 2026
%t A394592 a[n_]:=Total[FactorInteger[Binomial[5*n,n]][[All,1]]]; Table[a[n],{n,1,50}]
%o A394592 (Magma) a := func<n | &+PrimeDivisors(Binomial(5*n, n))>; N := 50; [a(n) : n in [1..N]];
%o A394592 (Python)
%o A394592 from collections import Counter
%o A394592 from sympy import factorint
%o A394592 def A394592(n):
%o A394592     c = Counter()
%o A394592     for i in range(4*n+1,5*n+1):
%o A394592         c += factorint(i)
%o A394592     for i in range(2,n+1):
%o A394592         c -= factorint(i)
%o A394592     return sum(c) # _Chai Wah Wu_, Apr 27 2026
