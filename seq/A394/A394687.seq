%S A394687 0,0,1,1,2,2,3,4,5,5,6,7,8,8,10,11,12,12,13,14,16,16,17,19,20,20,22,
%T A394687 23,24,24,25,27,29,29,31,32,33,33,35,37,38,38,39,40,43,43,44,47,48,48,
%U A394687 50,51,52,52,54,56,58,58,59,61,62,62,65,67,69,69,70,71,73,73,74,77,78,78,81,82,84,84,85,88,90,90,91,93,95,95,97,99,100,100,102,103,105,105,107,111,112,112,115,116
%N A394687 Number of ordered pairs of positive integers (a,b) with a < b such that b^2 - a^2 <= n.
%F A394687 a(n) = Sum_{k=1..n} A100073(k).
%F A394687 a(n) = Sum_{k=1..floor((n-1)/2)} (floor(sqrt(k^2 + n)) - k).
%F A394687 a(n) = Sum_{k=1..floor((n-1)/2)} floor(d(2*k+1)/2) + Sum_{k=1..floor(n/4)} floor(d(k)/2) where d(k) is the number of divisors of k.
%F A394687 a(n) = Sum_{k=1..floor(sqrt(n+1))-1} floor(n/(2*k)-k/2). - _Chai Wah Wu_, Apr 09 2026
%e A394687 a(3) = 1: the only pair is (1,2), since 2^2 - 1^2 = 3 <= 3.
%e A394687 a(8) = 4: the pairs (a,b) with b^2 - a^2 <= 8 are (1,2), (2,3), (3,4), (1,3).
%t A394687 a[n_]:=Sum[Floor[Sqrt[k^2 + n]] - k,{k,Floor[(n-1)/2]}]; Array[a,70] (* _Stefano Spezia_, Mar 29 2026 *)
%o A394687 (Python)
%o A394687 from math import isqrt
%o A394687 def a(n):
%o A394687     return sum(isqrt(n + k*k) - k for k in range(1, (n-1)//2 + 1))
%o A394687 print([a(n) for n in range(1, 101)])
%o A394687 (Python)
%o A394687 from math import isqrt
%o A394687 def A394687(n):
%o A394687     c, m = 0, 0
%o A394687     for k in range(2,isqrt(n+1)<<1,2):
%o A394687         m += k-1
%o A394687         c += (n-m)//k
%o A394687     return c # _Chai Wah Wu_, Apr 09 2026
%Y A394687 Partial sums of A100073.
%K A394687 nonn,easy,new
%O A394687 1,5
%A A394687 _Rayhan Ahmed_, Mar 29 2026
