%T A394062 283,313,379,367,439,433,409,541,571,613,643,613,691,571,757,823,829,
%U A394062 859,883,967,1033,1069,1063,1063,1237,1291,1259,1039,1399,1399,1453,1453,1531,1663,1669
%N A394062 a(n) = A393096(n) - sopf(A393096(n)) where sopf(n) is the sum of distinct primes of n.
%C A394062 All terms are prime.
%F A394062 a(n) = A393096(n)-A008472(A393096(n)).
%e A394062 For n=8, a(8) = 31 which added to 13 gives 44.  The distinct primes of 44 are 2 and 11 which sum to 13.
%t A394062 sopf[k_]:=Total[First/@FactorInteger[k]];q[k_]:=PrimeQ[sopf[k]]&&PrimeQ[k-sopf[k]];Select[Range[1723],q]-sopf/@Select[Range[1723],q] (* _James C. McMahon_, Mar 16 2026 *)
%o A394062 (Python)
%o A394062 from sympy import isprime, primefactors
%o A394062 def ok(n):return isprime(sum(primefactors(n))) and isprime(n-sum(primefactors(n)))
%o A394062 print(list(map(lambda n: n-sum(primefactors(n)), filter(ok, range(1, 2000)))))
%o A394062 (PARI) sopf(k) = vecsum(factor(k)[,1]); \\ A008472
%o A394062 isok(k) = my(s=sopf(k)); isprime(s) && isprime(k-s); \\ A393096
%o A394062 apply(x->x-sopf(x), select(isok, [1..1000])) \\ _Michel Marcus_, Mar 09 2026
%Y A394062 Cf. A008472, A394061, A393096.
