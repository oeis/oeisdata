%N A394787 a(n) = number of triples (x, y, z) such that x^2 + y*z = n, where x,y,z are positive integers satisfying x^2 >= y*z.
%e A394787 a(17) = 5 counts these triples: (3, 1, 8), (3, 2, 4), (3, 4, 2), (3, 8, 1), (4, 1, 1).
%t A394787 t[n_, c_] := Module[{r}, r = Flatten[Table[If[n - x^2 <= 0, {},
%t A394787        Map[({x, #, Quotient[n - x^2, #]} &),
%t A394787        Select[Divisors[n - x^2], Divisible[n - x^2, #] &]]], {x, 1,
%t A394787        Floor[Sqrt[n - 1]]}], 1]; Select[r, Apply[c, #] &]];
%t A394787 c = ((#1)^2 >= #2*#3 &);
%t A394787 Join[{0}, Table[Length[t[n, c]], {n, 1, 130}]]
