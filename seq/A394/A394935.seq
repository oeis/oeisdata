%I A394935 #12 Apr 21 2026 17:07:39
%S A394935 4,12,24,56,80,108,140,176,255,352,408,468,598,667,744,825,910,1085,
%T A394935 1276,1380,1715,1833,1960,2214,2491,2632,2784,2928,3082,3404,3744,
%U A394935 3920,4466,4661,5056,5254,5673,5888,6106,6336,7029,7504,7752,8004,8520,9047,9317,9592
%N A394935 a(n) is the smallest k for which the number of parts of the symmetric representation of sigma of k, SRS(k), is odd and the lower Dyck path of SRS(k) touches the diagonal at the same point as A298856(k).
%C A394935 k=2 is the smallest index for which a(k) > A298856(k) + 1.
%e A394935 For n = 1, 2: A394934(1) = 2 and A394934(2) = 9 below A298856(1) = 3 and A298856(2) = 10 respectively, and a(1) = 4 and a(2) = 12 above the latter two.
%e A394935   _ _ _ _ _ _ _
%e A394935 12|_ _ _ _ _ _  |
%e A394935   ._ _ _ _ _ _| |_ _
%e A394935 10|_ _ _ _ _  |     |_
%e A394935   |_ _ _ _ _| |_      |
%e A394935   .         |_ _|_    |_ _
%e A394935   .         |_  | |_ _ _  |
%e A394935   .           |_|_ _  | | |
%e A394935   ._ _ _          | | | | |
%e A394935   |_ _  |_        | | | | |
%e A394935  3|_ _|_  |       | | | | |
%e A394935   |_  | | |       | | | | |
%e A394935   . |_|_|_|. . . .|_|_|.|_|
%e A394935      2 3 4        9 10  12
%t A394935 (* support functions restate functions in the respective sequences *)
%t A394935 row[n_] := Floor[(Sqrt[8 n+1]-1)/2]
%t A394935 a014105[n_] := n(2n+1)
%t A394935 a240542[n_] := Sum[(-1)^(k+1) Ceiling[(n+1)/k-(k+1)/2], {k, 1, row[n]}]
%t A394935 t249223[n_] := FoldList[#1+(-1)^(#2+1)KroneckerDelta[Mod[n-#2 (#2+1)/2, #2]]&, 1, Range[2, row[n]]]
%t A394935 a298856[b_] := Select[Map[a014105,Range[b]],a240542[#]==a240542[#-1]&] (* b bound of search *)
%t A394935 nextOddSRS[n_] := NestWhile[#+1&, n+1, t249223[#][[row[#]]]==0&]
%t A394935 a394935[b_] := Map[nextOddSRS, a298856[b]]
%t A394935 a394935[70]
%Y A394935 Cf. A014105, A071562, A237593, A240542, A249223, A298856, A394934.
%K A394935 nonn,new
%O A394935 1,1
