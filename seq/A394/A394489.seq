%N A394489 Expansion of e.g.f. (1/x) * Series_Reversion( x/(1 + 5*x)^(2/5) ).
%H A394489 Vincenzo Librandi, <a href="/A394489/b394489.txt">Table of n, a(n) for n = 0..300</a>
%F A394489 E.g.f. A(x) satisfies A(x) = (1 + 5*x*A(x))^(2/5).
%F A394489 a(n) = 5^n * n! * binomial(2*(n+1)/5,n)/(n+1).
%F A394489 a(5*n+4) = 0.
%t A394489 a[n_]:=5^n*n!*Binomial[2*( n+1)/5,n]/(n+1); Table[a[n],{n,0,18}] (* _Vincenzo Librandi_, Mar 31 2026 *)
%o A394489 (PARI) a(n) = 5^n*n!*binomial(2*(n+1)/5, n)/(n+1);
%o A394489 (Magma) [1] cat [5^n*Factorial(n)*&*[ (2*(n+1)/5-k): k in [0..n-1]]/Factorial(n)/(n+1): n in [1..20] ]; // _Vincenzo Librandi_, Mar 31 2026
