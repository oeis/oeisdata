%U A394152 128240279433798,1190149446927842,11098266531019376,103936732641443794,977145055584160740,9218642626113399492
%N A394152 G.f. A(x) satisfies 4*A(x)^4 - 2*A(x)^3 + 5*x*A(x)^2 - x*A(x) + x^2 = 0.
%C A394152 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with red root (or blue root) where green vertices can only be followed by green vertices.
%H A394152 Nathan Fox, <a href="/A394152/b394152.txt">Table of n, a(n) for n = 0..300</a>
%H A394152 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026, Entry 65.
%F A394152 D-finite with recurrence: 972*n*(2*n - 1)*(1 + 2*n)*a(n) - 12*(1 + 2*n)*(43*n^2 - 11*n - 78)*a(n + 1) - (341*n^3 + 2933*n^2 + 7338*n + 5544)*a(n + 2) + (n + 3)*(121*n^2 + 722*n + 1048)*a(n + 3) - 4*(n + 4)*(n + 3)*(2*n + 7)*a(n + 4) = 0. - _Robert Israel_, Jun 04 2026
%F A394152 a(n) ~ 3^(4*n-1) / (sqrt(7*Pi) * n^(3/2) * 2^(3*n)). - _Vaclav Kotesovec_, Jun 04 2026
%F A394152 From _Seiichi Manyama_, Jun 04 2026: (Start)
%F A394152 G.f.: ( 1 + sqrt(1-4*x) - 2*sqrt( (1 + sqrt(1-4*x) - 18*x)/2 ) )/8.
%F A394152 a(n) = (1/n) * (binomial(2*n-2,n-1) + 2 * Sum_{k=2..n} k * binomial(2*n-1-k,n-1) * A059231(k-1)) for n > 0. (End)
%p A394152 f:= gfun:-rectoproc({972*n*(2*n - 1)*(1 + 2*n)*a(n) - 12*(1 + 2*n)*(43*n^2 - 11*n - 78)*a(n + 1) - (341*n^3 + 2933*n^2 + 7338*n + 5544)*a(n + 2) + (n + 3)*(121*n^2 + 722*n + 1048)*a(n + 3) - 4*(n + 4)*(n + 3)*(2*n + 7)*a(n + 4), a(0) = 0, a(1) = 1, a(2) = 3, a(3) = 16}, a(n), remember):
%p A394152 map(f, [$0..30]); # _Robert Israel_, Jun 04 2026
%o A394152 (Python)
%o A394152 def A394152(n):
%o A394152     A = [[1, 1, 1], [1, 1, 1], [0, 0, 1]]
%o A394152     if n == 0:
%o A394152         return 0
%o A394152     m = len(A)
%o A394152     output = [[1] for i in range(m)]
%o A394152     for l in range(2, n + 1):
%o A394152         for i in range(m):
%o A394152             term = 0
%o A394152             for k in range(1, l):
%o A394152                 for j in range(m):
%o A394152                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394152             output[i].append(term)
%o A394152     return output[0][n - 1]
%o A394152 (PARI) my(N=30, x='x+O('x^N)); concat(0, Vec((1+sqrt(1-4*x)-2*sqrt((1+sqrt(1-4*x)-18*x)/2))/8)) \\ _Seiichi Manyama_, Jun 04 2026
%Y A394152 Cf. A059231.
