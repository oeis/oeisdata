%S A394152 0,1,3,16,103,734,5582,44414,365295,3081286,26511226,231770296,
%T A394152 2052958838,18384992612,166182559212,1514177390810,13892502597695,
%U A394152 128240279433798,1190149446927842,11098266531019376,103936732641443794,977145055584160740,9218642626113399492
%N A394152 G.f. A(x) satisfies 4*A(x)^4-2*A(x)^3+5x*A(x)^2-x*A(x)+x^2=0.
%C A394152 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with red root (or blue root) where green vertices can only be followed by green vertices.
%H A394152 Nathan Fox, <a href="/A394152/b394152.txt">Table of n, a(n) for n = 0..300</a>
%H A394152 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394152 (Python)
%o A394152 def A394152(n):
%o A394152     A = [[1, 1, 1], [1, 1, 1], [0, 0, 1]]
%o A394152     if n == 0:
%o A394152         return 0
%o A394152     m = len(A)
%o A394152     output = [[1] for i in range(m)]
%o A394152     for l in range(2, n + 1):
%o A394152         for i in range(m):
%o A394152             term = 0
%o A394152             for k in range(1, l):
%o A394152                 for j in range(m):
%o A394152                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394152             output[i].append(term)
%o A394152     return output[0][n - 1]
%K A394152 nonn
%O A394152 0,3
%A A394152 _Nathan Fox_, Mar 12 2026
