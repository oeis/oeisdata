%T A394817 8,1,1,8,0,2,5,3,3,4,0,2,4,0,4,4,1,1,8,9,2,3,0,8,2,3,5,7,3,3,3,6,7,3,
%U A394817 8,4,4,1,1,7,7,5,3,7,1,6,3,1,2,5,1,2,2,5,2
%N A394817 Decimal expansion of the spherical cap radius for a spherical cap with 1/3rd of the volume of the unit sphere.
%C A394817 The spherical cap height h for a cap with a third of the unit sphere volume is an algebraic number of degree 3, h=A220052. The apex angle of the cap's base (center to rim) is cos(alpha) = 1-h, and the radius of the base is sin(alpha) = sqrt(2*h-h^2) defined here.
%H A394817 <a href="/index/Al#algebraic_06">Index entries for algebraic numbers, degree 06</a>.
%F A394817 Equals sqrt(2*h-h^2) where h = A220052.
%F A394817 Minimal polynomial: 9*x^6 + 27*x^4 - 32. - _Amiram Eldar_, May 07 2026
%e A394817 0.97411019701754239911026638...
%p A394817 Digits :=100 ;
%p A394817 h^3-3*h^2+4/3 ;
%p A394817 hei:=fsolve(%,h=0.7..0.8) ;
%p A394817 sqrt(2*hei-hei^2) ;
%t A394817 RealDigits[Root[9*x^6 + 27*x^4 - 32, 2], 10, 120][[1]] (* _Amiram Eldar_, May 07 2026 *)
%Y A394817 Cf. A220052, A019699.
%K A394817 nonn,cons,new
