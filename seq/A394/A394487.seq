%N A394487 Expansion of e.g.f. (1/x) * Series_Reversion( x/(1 + 4*x)^(1/4) ).
%H A394487 Vincenzo Librandi, <a href="/A394487/b394487.txt">Table of n, a(n) for n = 0..300</a>
%F A394487 E.g.f. A(x) satisfies A(x) = (1 + 4*x*A(x))^(1/4).
%F A394487 a(n) = 4^n * n! * binomial((n+1)/4,n)/(n+1).
%F A394487 a(4*n+3) = 0.
%t A394487 a[n_]:=4^n*n!*Binomial[( n+1)/4,n]/(n+1); Table[a[n],{n,0,20}] (* _Vincenzo Librandi_, Apr 01 2026 *)
%o A394487 (PARI) a(n) = 4^n*n!*binomial((n+1)/4, n)/(n+1);
%o A394487 (Magma) [1] cat [4^n*Factorial(n)*&*[((n+1)/4-k): k in [0..n-1]]/Factorial(n)/(n+1): n in [1..20] ]; // _Vincenzo Librandi_, Apr 01 2026
