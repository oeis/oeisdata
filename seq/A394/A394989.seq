%I A394989 #25 Apr 12 2026 00:16:01
%S A394989 1,2,5,9,17,33,69,151,421,513,1341,2391,6563,10209,23061,42069,66225,
%T A394989 257503,296323,647089,1398151,2099863,5058487,10610063,17380867,
%U A394989 35443881,71112163,143998193,271915383,692072705,1085184831,2281422937,8587804415,10583453237,19576656067
%N A394989 a(n) is the smaller of the two factors whose product is A394987.
%C A394989 The factors may be equal, but no example for n>1 is known.
%e A394989 See A394987.
%o A394989 (Python)
%o A394989 from sympy.utilities.iterables import multiset_permutations
%o A394989 from sympy import divisors
%o A394989 def A394989(n):
%o A394989     a = 1<<n-1
%o A394989     b = a<<1
%o A394989     k = (n<<1)-1
%o A394989     for l in range(k,0,-1):
%o A394989         for s in multiset_permutations('0'*(k+1-l)+'1'*l):
%o A394989             m = int(''.join(s),2)
%o A394989             for d in divisors(m):
%o A394989                 if d**2>m:
%o A394989                     break
%o A394989                 if a<=d<b and a*d<=m<b*d:
%o A394989                     return d # _Chai Wah Wu_, Apr 11 2026
%Y A394989 A394990 is the larger factor.
%Y A394989 Cf. A053644, A394987, A395003, A395004.
%K A394989 nonn
%O A394989 1,2
%A A394989 _Hugo Pfoertner_, Apr 09 2026
%E A394989 a(24)-a(35) from _Chai Wah Wu_, Apr 10 2026
