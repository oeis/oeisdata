%N A394322 Number of partitions p of n such that (minimal multiplicity of the parts of p) >= (minimal part of p).
%F A394322 G.f.: Sum_{j>=1} q^(j^2)/(1-q^j) * Product_{k>=j+1} (1+q^(j*k)/(1-q^k)).
%e A394322 a(6) counts these 8 partitions: 51, 411, 321, 3111, 222, 2211, 21111, 111111.
%o A394322 (PARI) my(N=50, q='q+O('q^N)); Vec(sum(j=1, N, q^j^2/(1-q^j)*prod(k=j+1, N, 1+q^(j*k)/(1-q^k))))
