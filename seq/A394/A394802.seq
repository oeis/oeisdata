%N A394802 G.f. A(x) satisfies A(x) = 1 - x^4 * d/dx log(1 - x*A(x)).
%H A394802 Seiichi Manyama, <a href="/A394802/b394802.txt">Table of n, a(n) for n = 0..1000</a>
%F A394802 G.f. A(x) satisfies A(x) = 1 - x*A(x) + x*A(x)^2 + x^4*A(x) + x^5*d/dx A(x).
%F A394802 a(0) = 1, a(1) = a(2) = a(3) = 0; a(n) = (n-3)*a(n-4) + Sum_{k=1..n-1} a(k) * a(n-1-k).
%F A394802 a(n) = A394800(n) - Sum_{k=0..n-1} a(k) * A394800(n-1-k).
%F A394802 G.f.: B(x)/(1+x*B(x)), where B(x) is the g.f. of A394800.
%t A394802 terms = 37; A[_] = 1; Do[A[x_] = 1-x^4 * D[Log[1-x*A[x]],x]+O[x]^terms // Normal, terms]; CoefficientList[A[x], x] (* _Stefano Spezia_, Apr 02 2026 *)
