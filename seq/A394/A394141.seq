%I A394141 #6 Mar 14 2026 15:03:57
%S A394141 0,1,3,15,89,577,3954,28159,206344,1545851,11787445,91191974,
%T A394141 714062041,5648777429,45079529911,362495811596,2934348587956,
%U A394141 23892641086459,195557929860835,1608071398391111,13278516834574055,110060894070407408,915386559028780435
%N A394141 G.f. A(x) satisfies A(x)^5-2*A(x)^4+(2x+1)*A(x)^3-4x*A(x)^2+x*A(x)-x^2=0.
%C A394141 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with blue root where red vertices can only be followed by blue vertices, blue vertices can be followed by vertices of any colors, and green vertices can be followed by red or green vertices.
%H A394141 Nathan Fox, <a href="/A394141/b394141.txt">Table of n, a(n) for n = 0..300</a>
%H A394141 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394141 (Python)
%o A394141 def A394141(n):
%o A394141     A = [[0, 1, 0], [1, 1, 1], [1, 0, 1]]
%o A394141     if n == 0:
%o A394141         return 0
%o A394141     m = len(A)
%o A394141     output = [[1] for i in range(m)]
%o A394141     for l in range(2, n + 1):
%o A394141         for i in range(m):
%o A394141             term = 0
%o A394141             for k in range(1, l):
%o A394141                 for j in range(m):
%o A394141                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394141             output[i].append(term)
%o A394141     return output[1][n - 1]
%Y A394141 Cf. A394140, A394142.
%K A394141 nonn
%O A394141 0,3
%A A394141 _Nathan Fox_, Mar 11 2026
