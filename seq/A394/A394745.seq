%U A394745 3,4,4,2,2,3,3,0,4,0,2,4,1,0,3,2,4,6
%N A394745 a(n) = number of triples (x, y, z) such that x^2 + y*z = n, where x,y,z are positive integers satisfying x > max(y,z).
%e A394745 a(51) = 4 counts these triples : (6, 3, 5), (6, 5, 3), (7, 1, 2), (7, 2, 1).
%t A394745 t[n_, c_] := Module[{r}, r = Flatten[Table[If[n - x^2 <= 0, {},
%t A394745        Map[({x, #, Quotient[n - x^2, #]} &),
%t A394745        Select[Divisors[n - x^2], Divisible[n - x^2, #] &]]], {x, 1,
%t A394745        Floor[Sqrt[n - 1]]}], 1]; Select[r, Apply[c, #] &]];
%t A394745 c = (#1 > Max[#2, #3] &);Table[{n, t[n, c]}, {n, 1, 30}]
%t A394745 Join[{0}, Table[Length[t[n, c]], {n, 1, 130}]]
