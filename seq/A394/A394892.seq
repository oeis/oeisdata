%U A394892 389,394,397,406,410,433,437,444,461,473,477,483,511,517,524,526,528,545,553,559,574,576,594,602,609,612,649,657,662
%N A394892 Numbers k such that A143293(k) has a factor of the form p^p, where A143293 is the partial sums of the primorial numbers.
%C A394892 Numbers k such that A143293(k) is in A100716.
%H A394892 Antti Karttunen, <a href="/A394892/b394892.txt">Table of n, a(n) for n = 1..921</a>
%o A394892 (PARI)
%o A394892 A143293(n) = { if(n==0, return(1)); my(P=1, s=1); forprime(p=2, prime(n), s+=P*=p); s; };
%o A394892 A359550(n) = { my(pp); forprime(p=2, , pp = p^p; if(!(n%pp), return(0)); if(pp > n, return(1))); };
%o A394892 is_A394892(k) = !A359550(A143293(k));
%Y A394892 Cf. A048103, A100716, A143293, A359550, A394891 (complement).
%K A394892 nonn,new
%O A394892 1,1
