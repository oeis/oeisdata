%I A394470 #20 May 02 2026 20:43:46
%S A394470 1,3,4,12,6,14,8,32,27,22,12,61,14,30,32,80,18,91,20,101,44,46,24,169,
%T A394470 75,54,108,141,30,153,32,192,68,70,72,324,38,78,80,281,42,213,44,221,
%U A394470 226,94,48,433,147,251,104,261,54,379,112,393,116,118,60,602,62,126,316,448
%N A394470 a(n) = n*tau(n) - (n-1)*Sum_{p|n, p prime} [gcd(p,n/p) = 1], where [ ] is the Iverson bracket.
%C A394470 For each divisor d of n, add 1 if d is a unitary prime divisor of n, else add n.
%F A394470 a(n) = Sum_{d|n} n^(1 - [gcd(d,n/d) = 1]*c(d)), where [ ] is the Iverson bracket and c = A010051.
%F A394470 a(n) = n*A000005(n) - (n-1)*A056169(n).
%F A394470 a(p^k) = p^k*(k+1)-(p^k-1)*floor(1/k) for p prime and k>=1. - _Wesley Ivan Hurt_, May 02 2026
%e A394470 a(12) = 12^1 + 12^1 + 12^0 + 12^1 + 12^1 + 12^1 = 61.
%t A394470 Table[Sum[n^(1 - KroneckerDelta[GCD[d, n/d], 1]*(PrimePi[d] - PrimePi[d - 1])), {d, Divisors[n]}], {n, 100}]
%Y A394470 Cf. A000005 (tau), A010051, A038040, A056169.
%K A394470 nonn,easy,new
%O A394470 1,2
%A A394470 _Wesley Ivan Hurt_, Apr 26 2026
