%U A394692 32767,1782691,5607966,2963103,409838,18018,260,1,1,131071,16098830,92221039,81253965,18332171,1356056,36618,357,1
%N A394692 Triangle read by rows: T(n,k) = (1/(2k)!) * Sum_{j=0..2k} (-1)^j * binomial(2k,j) * (1+k-j)^(2n).
%D A394692 P. L. Butzer, K. Schmidt, E. L. Stark, and L. Vogt, Central factorial numbers; their main properties and some applications. Numerical Functional Analysis and Optimization, 10(5-6), (1989), 419-488.
%D A394692 J. Riordan, Combinatorial identities (Vol. 217), Wiley, New York, 1968.
%H A394692 José L. Cereceda, <a href="https://arxiv.org/abs/2211.11648">Sums of powers of integers and generalized Stirling numbers of the second kind</a>, arXiv:2211.11648 [math.NT], 2022.
%H A394692 M. W. Coffey and M. C. Lettington, <a href="https://arxiv.org/abs/1510.05402">On Fibonacci Polynomial Expressions for Sums of m-th Powers, their implications for Faulhaber's Formula and some Theorems of Fermat</a>, arXiv:1510.05402 [math.NT], 2015.
%H A394692 Donald E. Knuth, <a href="https://arxiv.org/abs/math/9207222">Johann Faulhaber and Sums of Powers</a>, arXiv:math/9207222 [math.CA], 1992.
%H A394692 Petro Kolosov, <a href="https://doi.org/10.5281/zenodo.18096789">Sums of powers via central finite differences and Newton's formula</a>, Zenodo, 2026.
%F A394692 Let F(t, n, k) be generalized central factorial numbers of the second kind: F(t,n,k) = (1/(2k)!) * Sum_{j=0..2k} (-1)^j * binomial(2k,j) * (t+k-j)^(2n), then:
%F A394692   F(0,2n,2k) = A269945(n,k) = A387597(n,k)/k!;
%F A394692   F(1,2n,2k) = A392337(n,k)/k! = T(n,k) (this sequence);
%F A394692   F(2,2n,2k) = A390029(n,k)/k! = A395456(n,k);
%F A394692   F(3,2n,2k) = A395457(n,k).
%F A394692 G.f. for T(n,k) is centered Newton's polynomial for f(s) = s^(2n): s^(2n) = Sum_{k=0..2n} T(2n,k) (s-1)^[k], where (s-1)^[k] are central factorials.
%e A394692 Triangle begins:
%e A394692   k=    0  1      2        3        4        5       6      7    8
%e A394692   ------------------------------------------------------------------
%e A394692   n=0:  1;
%e A394692   n=1:  1, 1;
%e A394692   n=2:  1, 7,     1;
%e A394692   n=3:  1, 31,    20,      1;
%e A394692   n=4:  1, 127,   231,     42,      1;
%e A394692   n=5:  1, 511,   2290,    987,     75,      1;
%e A394692   n=6:  1, 2047,  21461,   18964,   3102,    121,    1;
%e A394692   n=7:  1, 8191,  196560,  333333,  101530,  8008,   182,   1;
%e A394692   n=8:  1, 32767, 1782691, 5607966, 2963103, 409838, 18018, 260, 1;
%e A394692   ...
%t A394692 T[t_, n_, k_] := 1 / (2k)! * Sum[(-1)^j * Binomial[2k, j] * (t + k - j)^(2n), {j, 0, 2k}]; Column[Table[T[1, n, k], {n, 0, 9}, {k, 0, n}]]
%Y A394692 Cf. A036969, A269945, A008957, A390029, A392337, A387597, A395456, A395457.
