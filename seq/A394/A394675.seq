%I A394675 #17 Apr 06 2026 18:40:32
%S A394675 1,2,1,3,1,4,2,5,7,8,14,22,36,56,92,148,235,383,611,994,1605,2599,
%T A394675 4204,6803,11007,17802,28809,46611,75420,122031,197451,319482,516933,
%U A394675 836415,1353334,2189749,3543083,5732832,9275915,15008747,24284662,39293409,63578071,102871480
%N A394675 Start with a(1) = 1, a(2) = 2, followed by a stream of 0's. At any step, the value of a(n-1) is added to the positions from a(n+1) to a(n+a(n)).
%H A394675 Paolo P. Lava, <a href="/A394675/b394675.txt">Table of n, a(n) for n = 1..100</a>
%F A394675 Fibonacci(n-4) <= a(n) <= Fibonacci(n-3).
%F A394675 Limit_{n->oo} a(n+1)/a(n) = (1+sqrt(5))/2, as per Fibonacci numbers.
%e A394675 Sequence begins 1, 2, 0, 0, 0, 0, 0, 0, 0, ...
%e A394675 a(1) = 1 is added to the next a(2) = 2 positions: 1, 2, 1, 1, 0, 0, 0, 0, 0, ...
%e A394675 a(2) = 2 is added to the next a(3) = 1 position: 1, 2, 1, 3, 0, 0, 0, 0, 0, ...
%e A394675 a(3) = 1 is added to the next a(4) = 3 positions: 1, 2, 1, 3, 1, 1, 1, 0, 0, ...
%e A394675 a(4) = 3 is added to the next a(5) = 1 position: 1, 2, 1, 3, 1, 4, 1, 0, 0, ...
%p A394675 P:=proc(q) local k,n,t,v; v:=array(1..q); for n from 1 to q do v[n]:=0; od; v[1]:=1; v[2]:=2;
%p A394675 for n from 2 to q do if v[n]>q-n then t:=q-n; else t:=v[n]; fi;
%p A394675 for k from 1 to t do v[n+k]:=v[n+k]+v[n-1]; od; od; print(v); end: P(100);
%Y A394675 Cf. A000045, A001622.
%K A394675 nonn,easy,new
%O A394675 1,2
%A A394675 _Paolo P. Lava_, Mar 28 2026
