%N A394017 Expansion of g.f.: Product_{k>=1} 1 / (1 - x^(k^2 + 2)).
%C A394017 a(n) is the number of partitions of n into parts of the form k^2+2 (for k>=1).
%H A394017 Vaclav Kotesovec, <a href="/A394017/b394017.txt">Table of n, a(n) for n = 0..10000</a>
%F A394017 a(n) ~ zeta(3/2)^(2/3) * exp(3*Pi^(1/3) * zeta(3/2)^(2/3) * n^(1/3) / 2^(4/3)) / (2^(11/6) * sqrt(3) * Pi^(1/6) * sinh(Pi*sqrt(2)) * n^(7/6)) * (1 - (34 + 18*Pi * zeta(1/2) * zeta(3/2)) / (9*2^(5/3) * Pi^(1/3) * zeta(3/2)^(2/3) * n^(1/3))).
%t A394017 nmax = 150; CoefficientList[Series[1/Product[1 - x^(k^2 + 2), {k, 1, Floor[Sqrt[nmax]+1]}], {x, 0, nmax}], x]
