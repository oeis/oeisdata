%U A394479 745686410820671870950,395666957431781807246192,308649521313122750899881410,353674652432800724298111984055,595409917522562486496050260596601,1472974193810774390034577961745197521,5353962489774042038836766450068054443609
%N A394479 Number of tilings of an n X n square using 1 X 1 squares (monominoes) and stairs hexominoes.
%C A394479 The stairs hexomino is a 3 X 3 square with an L tromino in the upper right corner removed and no rotations are allowed (see the examples).
%H A394479 Wikipedia, <a href="https://en.wikipedia.org/wiki/Hexomino">Hexomino</a>
%H A394479 Wikipedia, <a href="https://en.wikipedia.org/wiki/Tromino">Tromino</a>
%e A394479 a(4) = 5:
%e A394479   ._______.  ._______.  ._______.  ._______.  ._______.
%e A394479   |_|_|_|_|  | |_|_|_|  |_| |_|_|  |_|_|_|_|  |_|_|_|_|
%e A394479   |_|_|_|_|  |   |_|_|  |_|   |_|  | |_|_|_|  |_| |_|_|
%e A394479   |_|_|_|_|  |_____|_|  |_|_____|  |   |_|_|  |_|   |_|
%e A394479   |_|_|_|_|  |_|_|_|_|  |_|_|_|_|  |_____|_|  |_|_____|  .
%p A394479 a:= proc(n) option remember; local b; b:=
%p A394479       proc(n, l) option remember; local k;
%p A394479         if n<2 then 1
%p A394479       elif min(l[])>0 then b(n-1, map(h->h-1, l))
%p A394479       else for k while l[k]>0 do od; b(n, subsop(k=1, l))+
%p A394479            `if`(n>2 and k<nops(l)-1 and l[k+1]=0 and l[k+2]=0,
%p A394479                 b(n, subsop(k=3, k+1=2, k+2=1, l)), 0)
%p A394479         fi
%p A394479       end: forget(b); b(n, [0$n])
%p A394479     end:
%p A394479 seq(a(n), n=0..16);
%Y A394479 Cf. A000930, A066864, A140304, A193147, A396311.
