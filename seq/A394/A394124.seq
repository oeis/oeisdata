%I A394124 #6 Mar 14 2026 15:01:59
%S A394124 0,1,2,8,39,209,1184,6957,41949,257864,1608948,10159335,64776023,
%T A394124 416373957,2694841856,17544509966,114807699105,754658064177,
%U A394124 4980296873102,32983762857180,219143686883727,1460188901936842,9754995076253640,65325868258682595
%N A394124 G.f. A(x) satisfies A(x)^6-A(x)^5+3x*A(x)^4-x*A(x)^3+3x^2*A(x)^2-x^2*A(x)+x^3=0.
%C A394124 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with green root where red vertices can only be followed by blue vertices, blue vertices can be followed by red or blue vertices, and green vertices can be followed by blue or green vertices.
%H A394124 Nathan Fox, <a href="/A394124/b394124.txt">Table of n, a(n) for n = 0..300</a>
%H A394124 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394124 (Python)
%o A394124 def A394124(n):
%o A394124     A = [[0, 1, 0], [1, 1, 0], [0, 1, 1]]
%o A394124     if n == 0:
%o A394124         return 0
%o A394124     m = len(A)
%o A394124     output = [[1] for i in range(m)]
%o A394124     for l in range(2, n + 1):
%o A394124         for i in range(m):
%o A394124             term = 0
%o A394124             for k in range(1, l):
%o A394124                 for j in range(m):
%o A394124                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394124             output[i].append(term)
%o A394124     return output[2][n - 1]
%K A394124 nonn
%O A394124 0,3
%A A394124 _Nathan Fox_, Mar 11 2026
