%N A394493 Expansion of e.g.f. (1/x) * Series_Reversion( x*(1 - 3*x)^(2/3) ).
%H A394493 Vincenzo Librandi, <a href="/A394493/b394493.txt">Table of n, a(n) for n = 0..300</a>
%F A394493 E.g.f. A(x) satisfies A(x) = 1/(1 - 3*x*A(x))^(2/3).
%F A394493 a(n) = 3^n * n! * binomial((5*n-1)/3,n)/(n+1).
%F A394493 a(n) ~ 2^(-2*n/3-1/6)*5^(5*n/3+1/6)*exp(-n)*n^(n-1). - _Stefano Spezia_, Mar 22 2026
%t A394493 a[n_]:=3^n*n!*Binomial[(5 n-1)/3,n]/(n+1); Table[a[n],{n,0,18}] (* _Vincenzo Librandi_, Mar 30 2026 *)
%o A394493 (PARI) a(n) = 3^n*n!*binomial((5*n-1)/3, n)/(n+1);
%o A394493 (Magma) [1] cat [3^n*Factorial(n)*&*[((5*n-1)/3-k): k in [0..n-1]]/Factorial(n)/(n+1): n in [1..20] ]; // _Vincenzo Librandi_, Mar 30 2026
