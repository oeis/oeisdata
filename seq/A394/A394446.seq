%S A394446 1,1,3,1,1,7,13,7,1,1,12,45,69,45,12,1,1,18,108,296,411,296,108,18,1,
%T A394446 1,25,215,890,2015,2633,2015,890,215,25,1,1,33,381,2180,7110,14148,
%U A394446 17739,14148,7110,2180,381,33,1,1,42,623,4662,20391,56238,101941,124029,101941,56238,20391,4662,623,42,1
%N A394446 Triangle T(n,k), where row n lists the coefficients of the n-th palindromic polynomial p(n) defined by a recurrence of order 2.
%C A394446 This should be the h^* vectors of some reflexive polytopes.
%H A394446 Alois P. Heinz, <a href="/A394446/b394446.txt">Rows n = 1..100, flattened</a>
%F A394446 T(n,k) = [x^k] p(n) with p(0) = 1; p(1) = 1+3*x+x^2; (n+2)*p(n) = p(1)*(2*n+1)*p(n-1)-(1+x+x^2)^2*(n-1)*p(n-2).
%e A394446 The first few polynomials are:
%e A394446   1,
%e A394446   x^2 + 3*x + 1,
%e A394446   x^4 + 7*x^3 + 13*x^2 + 7*x + 1,
%e A394446   x^6 + 12*x^5 + 45*x^4 + 69*x^3 + 45*x^2 + 12*x + 1.
%e A394446 Triangle T(n,k) begins:
%e A394446   1;
%e A394446   1,  3,   1;
%e A394446   1,  7,  13,   7,    1;
%e A394446   1, 12,  45,  69,   45,   12,    1;
%e A394446   1, 18, 108, 296,  411,  296,  108,  18,   1;
%e A394446   1, 25, 215, 890, 2015, 2633, 2015, 890, 215, 25, 1;
%e A394446   ...
%p A394446 b:= proc(n) option remember; `if`(n=0, 1, `if`(n=1, 1+3*x+x^2,
%p A394446       expand((b(1)*(2*n+1)*b(n-1)-(1+x+x^2)^2*(n-1)*b(n-2))/(n+2))))
%p A394446     end:
%p A394446 T:= n-> coeffs(b(n)):
%p A394446 seq(T(n), n=0..7);  # _Alois P. Heinz_, Mar 20 2026
%o A394446 (SageMath)
%o A394446 @cached_function
%o A394446 def a(n):
%o A394446     R = PolynomialRing(ZZ, 'x')
%o A394446     if n == 0:
%o A394446         return R.one()
%o A394446     p5 = R([1, 3, 1])
%o A394446     if n == 1:
%o A394446         return p5
%o A394446     p9 = R([1, 1, 1])**2
%o A394446     return (p5*(2*n+1)*a(n-1)-p9*(n-1)*a(n-2)) / (n + 2)
%Y A394446 Row sums give A059231(n+1).
%Y A394446 Main diagonal gives A128079.
%Y A394446 Columns k=0-1 give: A000012, A055998.
%K A394446 nonn,tabf,changed
%O A394446 0,3
%A A394446 _F. Chapoton_, Mar 20 2026
