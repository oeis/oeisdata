%I A394391 #26 Mar 23 2026 23:24:44
%S A394391 1,4,5,10,13,20,29,32,45,52,85,72,125,116,137,146,229,180,293,232,305,
%T A394391 340,445,320,493,500,545,520,733,548,845,712,857,916,977,810,1229,
%U A394391 1172,1241,1088,1525,1220,1685,1480,1557,1780,2029,1544,2125,1972,2225,2152
%N A394391 a(n) = tau(n)^2 + (n - tau(n))^2.
%C A394391 The first six terms coincide with A236283.
%C A394391 For large n, ratio A236283(n)/a(n) is asymptotic to 1/2.
%F A394391 a(n) = tau(n)^2 + (n - tau(n))^2 = n^2 - 2*n*tau(n) + 2*tau(n)^2.
%e A394391 a(6) = tau(6)^2 + (6 - tau(6))^2 = 4^2 + 2^2 = 20.
%p A394391 a:= n-> (t-> t^2+(n-t)^2)(numtheory[tau](n)):
%p A394391 seq(a(n), n=1..58);  # _Alois P. Heinz_, Mar 19 2026
%t A394391 Table[m = DivisorSigma[0, n]; m^2 + (n - m)^2, {n, 58}] (* _Michael De Vlieger_, Mar 19 2026 *)
%o A394391 (Python)
%o A394391 import sympy as sp
%o A394391 def a(n):
%o A394391     t = sp.divisor_count(n)
%o A394391     return t*t + (n - t)*(n - t)
%o A394391 (PARI) a(n) = my(t=numdiv(n)); n^2 - 2*n*t + 2*t^2; \\ _Michel Marcus_, Mar 19 2026
%Y A394391 Cf. A000005, A049820, A236283.
%K A394391 nonn,easy,new
%O A394391 1,2
