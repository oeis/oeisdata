%I A394120 #6 Mar 14 2026 15:01:42
%S A394120 0,1,3,14,77,460,2892,18838,125999,860410,5974998,42074616,299785646,
%T A394120 2157615484,15664666260,114596758656,843977389437,6252656070700,
%U A394120 46568577487040,348479403676142,2618857896150888,19756973221959766,149571500476890750,1135960161318209766
%N A394120 G.f. A(x) satisfies A(x)^4+(x-1)*A(x)^3+3x*A(x)^2+(x^2-x)*A(x)^2+x^2=0.
%C A394120 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with blue root where red vertices can only occur as leaves, blue vertices can be followed by vertices of any color, and green vertices can be followed by red or green vertices.
%H A394120 Nathan Fox, <a href="/A394120/b394120.txt">Table of n, a(n) for n = 0..300</a>
%H A394120 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394120 (Python)
%o A394120 def A394120(n):
%o A394120     A = [[0, 0, 0], [1, 1, 1], [1, 0, 1]]
%o A394120     if n == 0:
%o A394120         return 0
%o A394120     m = len(A)
%o A394120     output = [[1] for i in range(m)]
%o A394120     for l in range(2, n + 1):
%o A394120         for i in range(m):
%o A394120             term = 0
%o A394120             for k in range(1, l):
%o A394120                 for j in range(m):
%o A394120                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394120             output[i].append(term)
%o A394120     return output[1][n - 1]
%K A394120 nonn,new
%O A394120 0,3
%A A394120 _Nathan Fox_, Mar 11 2026
