%S A394086 1,2,2,4,3,6,5,9,8,12,11,20,16,24,26,36,33,50,47,68,70,88,90,129,125,
%T A394086 159,173,218,223,294,297,376,402,482,519,649,669,808,881,1055,1114,
%U A394086 1352,1427,1700,1848,2139,2305,2746,2915,3398,3692,4258,4583,5335,5731
%N A394086 Number of partitions of n where the smallest part divides all others, has multiplicity at most 2, and all larger parts are distinct.
%F A394086 G.f.: Sum_{k>=1} q^k * B(q^k), where B(q) is the g.f. of A000009.
%F A394086 a(n) = Sum_{d|n} A000009(d-1).
%e A394086 a(8) = 9 counts these partitions: 8, 71, 62, 611, 521, 44, 431, 422, 4211.
%o A394086 (PARI) my(N=60, q='q+O('q^N)); Vec(sum(k=1, N, q^k*prod(j=1, N\k, 1+q^(k*j))))
%Y A394086 Cf. A000009, A047966, A083710, A097986, A389719.
%K A394086 nonn,easy,new
%O A394086 1,2
