%I A394034 #6 Mar 16 2026 17:46:43
%S A394034 1,3,4,8,11,14,21,19,25,17,55,27,30,43,46,144,29,35,45,51,59,377,50,
%T A394034 37,82,53,61,67,987,71,66,95,98,114,69,77,2584,76,79,108,103,119,127,
%U A394034 140,85,6765,131,92,113,121,124,137,153,156,93,17711,186,97,118,134
%N A394034 Rectangular array, read by descending antidiagonals: numerators in the best lower approximating array to the golden ratio, phi (A001622). (See A394033.)
%e A394034 Corner of array of denominators:
%e A394034    1     2    5   13   34   89  233  610  1597  4181 10946 28657
%e A394034    3     7   12   17   18   31   44   47    81   115   123   212
%e A394034    9    16   19   22   23   41   49   57    60   107   128   149
%e A394034    11   27   28   51   59   67   70   73   133   154   157   280
%e A394034    29   32   33   61   64   75   83   86   159   167   175   183
%e A394034    37   38   71   74   77   80   96   99   185   191   301   322
%e A394034 Corner of array of numerators:
%e A394034     1    3    8   21   55  144  377  987  2584  6765 17711
%e A394034     4   11   19   27   29   50   71   76   131   186   199
%e A394034    14   25   30   35   37   66   79   92    97   173   207
%e A394034    17   43   45   82   95  108  113  118   215   249   254
%e A394034    46   51   53   98  103  121  134  139   257   270   283
%e A394034    59   61  114  119  124  129  155  160   299   309   487
%e A394034 Corner of array of approximations:
%e A394034     1.       1.5       1.6       1.61538   1.61765
%e A394034    1.33333   1.57143   1.58333   1.58824   1.61111
%e A394034    1.55556   1.5625    1.57895   1.59091   1.6087
%e A394034    1.54545   1.59259   1.60714   1.60784   1.61017
%e A394034    1.58621   1.59375   1.60606   1.60656   1.60938
%e A394034    1.59459   1.60526   1.60563   1.60811   1.61039
%t A394034 x = GoldenRatio; numRows = 6; numCols = 12;
%t A394034 usedValues = {}; lowerArray = Table[Null, {numRows}, {numCols}];
%t A394034 For[n = 1, n <= numRows, n++, b = 1;
%t A394034   foundStart = False;
%t A394034   While[! foundStart, a = Floor[b*x]; val = a/b;
%t A394034    If[val < x && GCD[a, b] == 1 && ! MemberQ[usedValues, val],
%t A394034     lowerArray[[n, 1]] = val;
%t A394034     AppendTo[usedValues, val]; foundStart = True, b++]];
%t A394034   For[k = 1, k < numCols, k++, currentVal = lowerArray[[n, k]];
%t A394034    currentB = Denominator[currentVal];
%t A394034    nextVal = Null; testB = currentB + 1;
%t A394034    While[nextVal === Null, testA = Floor[testB*x];
%t A394034     candidate = testA/testB;
%t A394034     If[GCD[testA, testB] == 1 && candidate > currentVal &&
%t A394034       candidate < x && ! MemberQ[usedValues, candidate],
%t A394034      nextVal = candidate;
%t A394034      AppendTo[usedValues, candidate];
%t A394034      lowerArray[[n, k + 1]] = nextVal, testB++]];];];
%t A394034 Grid[lowerArray]  (* Lower best approximating array to golden ratio *)
%t A394034 Grid[N[lowerArray]]  (* approximations *)
%t A394034 Grid[Denominator[lowerArray]]  (* A394033 *)
%t A394034 Grid[Numerator[lowerArray]]    (* A394034 *)
%Y A394034 Cf. A001622, A001519 (row 1), A394035, A394036, A394037.
%K A394034 nonn,tabl,frac,new
%O A394034 1,2
