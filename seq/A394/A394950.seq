%S A394950 1,1,5,25,135,755,4405,26385,161730,1008870,6385736,40905820,
%T A394950 264702649,1727746241,11361680045,75202434753,500621714851,
%U A394950 3349611709631,22513871456093,151941586538261,1029207072219367,6994892136510067,47685183644122575,325985511212217959
%N A394950 Number of equivalence classes of well-formed bracketed words of total length 2n built from the symbol * (of length 2) and four unary bracket types (), [], {}, and <>, with no empty bracket pair, modulo commutativity of concatenation.
%C A394950 a(0)=1 counts the empty word.
%C A394950 For n>=1, a(n)=b_{4,2}^m(2n) in the notation of Au and Bremner; see Section 4.1.
%C A394950 Here two bracketed words are equivalent if they differ only by permuting factors in any concatenation.
%C A394950 The four unary bracket types are distinguished and do not commute under nesting.
%C A394950 Equivalently, a(n) counts rooted unordered trees with n vertices in which each leaf represents *, each unary internal node is labeled 1, 2, 3, or 4, and every non-unary internal node has at least 2 unordered children.
%H A394950 Vincenzo Librandi, <a href="/A394950/b394950.txt">Table of n, a(n) for n = 0..1000</a>
%H A394950 Yu Hin Au and Murray R. Bremner, <a href="https://arxiv.org/abs/2604.25731">Enumerating Multi-Operator Monomials in Commutative and Noncommutative Settings</a>, arXiv:2604.25731 [math.CO], 2026. See pp. 4, 28 (Table 7).
%F A394950 G.f.: 1 + A(x) = exp(Sum_{k>=1} (x^k + 4*x^k*A(x^k))/k).
%F A394950 n*a(n) = c(n) + Sum_{k=1..n-1} c(k)*a(n-k) for n>1, with a(0)=a(1)=1, where c(n) = Sum_{m|n} m*b(m), b(1)=1, and b(n)=4*a(n-1) for n>=2.
%e A394950 a(3)=25 = 1 + 8 + 16: one class represented by ***, 8 classes represented by P_i(**) and P_i(*)* for i=1,2,3,4, and 16 classes represented by P_i(P_j(*)) for i,j in {1,2,3,4}.
%t A394950 nn=30; a={1,1}; Do[b[m_]:=If[m==1,1,4 a[[m]]]; c[t_]:=Sum[d b[d],{d,Divisors[t]}];
%t A394950 AppendTo[a,(c[n]+Sum[c[k] a[[n-k+1]],{k,1,n-1}])/n];,{n,2,nn}]; a (* _Vincenzo Librandi_, May 02 2026 *)
%o A394950 (Magma) N:=30; a:=[1,1]; for n in [2..N] do b:=func<m|m eq 1 select 1 else 4*a[m]>; c:=func<t|&+[d*b(d): d in Divisors(t)]>; Append(~a,(c(n)+&+[c(k)*a[n-k+1]: k in [1..n-1]]) div n); end for; a; // _Vincenzo Librandi_, May 02 2026
