%N A394484 Chebyshev distance between prime(n) and prime(n+1) on Ulam spiral.
%e A394484 For n = 2 we are concerned with 2nd prime and 3rd prime: 3 and 5. Chebyshev distance between 3 and 5 on Ulam spiral is 2.
%o A394484 (Python)
%o A394484 import math
%o A394484 from sympy import prime
%o A394484 def ulam_coords(n):
%o A394484     if n == 1:
%o A394484         return (0, 0)
%o A394484     k = math.ceil((math.sqrt(n) - 1) / 2)
%o A394484     t = 2 * k
%o A394484     m = (t + 1) ** 2
%o A394484     if n >= m - t:
%o A394484         return (k - (m - n), -k)
%o A394484     m -= t
%o A394484     if n >= m - t:
%o A394484         return (-k, -k + (m - n))
%o A394484     m -= t
%o A394484     if n >= m - t:
%o A394484         return (-k + (m - n), k)
%o A394484     m -= t
%o A394484     return (k, k - (m - n))
%o A394484 def seq(num):
%o A394484     sequence = []
%o A394484     for n in range(1, num + 1):
%o A394484         p1 = prime(n)
%o A394484         p2 = prime(n + 1)
%o A394484         x1, y1 = ulam_coords(p1)
%o A394484         x2, y2 = ulam_coords(p2)
%o A394484         dist = max(abs(x1 - x2), abs(y1 - y2))
%o A394484         sequence.append(dist)
%o A394484     return sequence
%o A394484 print(seq(50))
