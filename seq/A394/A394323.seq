%N A394323 Number of partitions p of n such that (minimal multiplicity of the parts of p) >= 2 * (minimal part of p).
%F A394323 G.f.: Sum_{j>=1} q^(2*j^2)/(1-q^j) * Product_{k>=j+1} (1+q^(2*j*k)/(1-q^k)).
%e A394323 a(8) counts these 5 partitions: 3311, 2222, 22211, 221111, 11111111.
%o A394323 (PARI) my(N=60, q='q+O('q^N)); concat(0, Vec(sum(j=1, N, q^(2*j^2)/(1-q^j)*prod(k=j+1, N, 1+q^(2*j*k)/(1-q^k)))))
