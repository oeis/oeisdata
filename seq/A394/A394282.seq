%U A394282 2,97,101,103,107,109,113,11,3,5,3,127,2,2,2,131,2,3,2,137,139
%N A394282 a(n) is the largest prime p such that A284665(n) = p^i + p^j with i, j > 0.
%o A394282 (PARI) lista(limit) = my(v=vector(limit), vp=vector(limit)); for(n=1, limit, forprime(p=2, n/2, for(k=1, logint(n\2, 2), for(j=k, logint(n, 2), if(n-p^k==p^j, v[n]++; vp[n]=p ))))); for(n=1, limit, if(v[n]>0, print1(vp[n], ", ")));
