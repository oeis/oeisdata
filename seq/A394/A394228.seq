%T A394228 556,1312,821,2350,274,666,879,282,453,3255,3394,548,3189,2264,1828,
%U A394228 2211,2653,7059,2914,1490,465,2624,1211,5615,1310,2963,4182,4182,4374,1268,1224
%N A394228 The exponent j of the first pair of powers of 2 (2^j, 2^k), j < k, where 2^k is the smallest power whose last n digits are a non-identical anagram (besides n=1), no leading zeros, of the last n digits of 2^j.
%H A394228 Michael S. Branicky, <a href="/A394228/b394228.txt">Table of n, a(n) for n = 1..1000</a> (terms 501..800 from David A. Corneth)
%e A394228 For a(1), k = 5, j = 1 since the last digit of 2^5 = 32 and 2^1 = 2 are the same.
%e A394228 For a(2), k = 14, j = 11 since the last two digits of 2^14 = 16384 and 2^11 = 2048 are anagrams (and not equal).
%e A394228 a(3) = 9. 2^9 and 2^21 have same last 3 digits but in different order and without leading 0. 21 is the smallest k for which there is such j. This sequence has the smallest such j. - _David A. Corneth_, May 28 2026
%o A394228 (Python)
%o A394228 def a(n):
%o A394228     if n == 1: return 1
%o A394228     seen, modder = dict(), 10**n
%o A394228     pow2mod = pow(2, 3*n, modder)
%o A394228     for k in range(3*n, modder+1):
%o A394228         s = str(pow2mod)
%o A394228         if len(s) == n:
%o A394228             key = "".join(sorted(s))
%o A394228             if key in seen and seen[key][0] != s:
%o A394228                 return seen[key][1]
%o A394228             else:
%o A394228                 seen[key] = (s, k)
%o A394228         pow2mod = 2*pow2mod%modder
%o A394228     return -1
%o A394228 print([a(n) for n in range(1, 51)]) # _Michael S. Branicky_, May 28 2026
%Y A394228 Cf. A395027 (exponent k).
%K A394228 nonn,base,new
