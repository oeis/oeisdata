%o A394299 (PARI) a394299_300(n) = my(n2=2^n, n22=n2+n2, s=0, k=0); forprime(p1=n2, precprime(precprime(n22)-1), forprime(p2=nextprime(p1+1), n22, s+=(p2-p1); k++)); s/k
%Y A394299 A394300 are the corresponding denominators.
