%N A394769 Number of transitive relations on an n-set with at most six ordered pairs.
%H A394769 <a href="/index/Rec#order_13">Index entries for linear recurrences with constant coefficients</a>, signature (13,-78,286,-715,1287,-1716,1716,-1287,715,-286,78,-13,1).
%F A394769 a(n) = 1 + A000290(n) + A349919(n) + A349927(n) + A349849(n) + A348634(n) + A393216(n).
%F A394769 a(n) = (720 - 598956*n + 2134012*n^2 - 3281559*n^3 + 2912954*n^4 - 1672444*n^5 + 657487*n^6 - 182176*n^7 + 35980*n^8 - 5035*n^9 + 486*n^10 - 30*n^11 + n^12)/720. - _Stefano Spezia_, Apr 02 2026
%e A394769 a(2) = 13, the same as the total number of transitive relations on a 2-set because every transitive relation on a 2-set has at most 6 (actually at most 4) ordered pairs.
%t A394769 a[n_]:=(720 - 598956n + 2134012n^2 - 3281559n^3 + 2912954n^4 - 1672444n^5 + 657487n^6 - 182176n^7 + 35980n^8 - 5035n^9 + 486n^10 - 30n^11 + n^12)/720; Array[a,27,0] (* _Stefano Spezia_, Apr 02 2026 *)
