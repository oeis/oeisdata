%T A394988 48,50,52,55,56,58,60,63,65,66,68,70,72,75,76,78,81,82,85,87,88,90,93,
%U A394988 95,96,99,100,102,105,106,108,111,113,115,117,119,120,122,125
%N A394988 a(n) is the maximum Hamming weight of the product x*y of two integers 2^(n-1) <= x <= y < 2^n.
%H A394988 Chai Wah Wu, <a href="/A394988/b394988.txt">Table of n, a(n) for n = 1..95</a>
%e A394988 See A384987 and A394991.
%o A394988 (Python)
%o A394988 from sympy.utilities.iterables import multiset_permutations
%o A394988 from sympy import divisors
%o A394988 def A394988(n):
%o A394988     a = 1<<n-1
%o A394988     b = a<<1
%o A394988     k = (n<<1)-1
%o A394988     for l in range(k,0,-1):
%o A394988         for s in multiset_permutations('0'*(k+1-l)+'1'*l):
%o A394988             m = int(''.join(s),2)
%o A394988             for d in divisors(m):
%o A394988                 if d**2>m:
%o A394988                     break
%o A394988                 if a<=d<b and a*d<=m<b*d:
%o A394988                     return l # _Chai Wah Wu_, Apr 09 2026
%Y A394988 Cf. A000120, A053644, A394987, A394991.
