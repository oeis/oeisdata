%I A394910 #8 Apr 09 2026 09:20:38
%S A394910 1,13,121,2186,39364,708584,12754576,229582496,4132485184,74384733824,
%T A394910 1338925209856,24100653779456,433811768034304,7808611824625664,
%U A394910 140555012843278336,2529990231179042816,45539824161222836224,819716834902011183104,14754903028236201558016,265588254508251628568576
%N A394910 a(n) = numerator( (2/3)^n*(1/8 - (1/24)*(1/9)^n) ).
%C A394910 a(n) is the numerator of the moment of inertia about its center (x = 1/2) of the set obtained at the n-th iteration of the Cantor set's construction.
%H A394910 Wikipedia, <a href="https://en.wikipedia.org/wiki/Cantor_set">Cantor set</a>.
%H A394910 <a href="/index/Rec#order_02">Index entries for linear recurrences with constant coefficients</a>, signature (20,-36).
%F A394910 a(n) = 2^(n-3)*(3^(2*n+1) - 1) for n > 1.
%F A394910 a(n) = 20*a(n-1) - 36*a(n-2) for n > 3.
%F A394910 G.f.: (1 - 7*x - 103*x^2 + 234*x^3)/((1 - 2*x)*(1 - 18*x)).
%F A394910 E.g.f.: (3*exp(18*x) - exp(2*x) + 6 + 52*x)/8.
%e A394910 The sequence of the moments of inertia begins as:
%e A394910 1/12, 13/162, 121/2187, 2186/59049, 39364/1594323, 708584/43046721, ...
%t A394910 a[n_]:=Numerator[(2/3)^n(1/8-1/24(1/9)^n)]; Array[a,20,0]
%Y A394910 Cf. A000079, A013708, A394911 (denominators).
%K A394910 nonn,easy,frac
%O A394910 0,2
%A A394910 _Stefano Spezia_, Apr 06 2026
