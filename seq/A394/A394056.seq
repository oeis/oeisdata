%N A394056 Number of positive integers <= n with 4 divisors.
%H A394056 Amiram Eldar, <a href="/A394056/b394056.txt">Table of n, a(n) for n = 1..10000</a>
%F A394056 a(n) = A394052(n,4), n >= 6.
%e A394056 6 is the smallest number with 4 divisors, they are [1, 2, 3, 6], so a(1) = a(2) = a(3) = a(4) = a(5) = 0 and a(6) = 1.
%p A394056 a:= proc(n) option remember; `if`(n=0, 0,
%p A394056       a(n-1)+`if`(4=numtheory[tau](n), 1, 0))
%p A394056     end:
%p A394056 seq(a(n), n=1..80);  # _Alois P. Heinz_, Mar 22 2026
%t A394056 a[n_]:=Length[Select[Range[n],DivisorSigma[0,#]==4 &]]; Array[a,80] (* _Stefano Spezia_, Mar 22 2026 *)
%t A394056 seq[n_] := Accumulate[Table[Boole[DivisorSigma[0, k] == 4], {k, 1, n}]]; seq[100] (* _Amiram Eldar_, Mar 22 2026 *)
%Y A394056 Column 4 of A394052.
%Y A394056 Partial sums of A354927, minus 1.
%Y A394056 Indices of records give A007422.
%Y A394056 Cf. A030513, A000720, A056811.
%K A394056 nonn,easy,new
%O A394056 1,8
