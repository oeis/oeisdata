%e A394975 Seen as a triangle, T(n,k) = A(n-k,k):
%e A394975   [0]  1;
%e A394975   [1]  0, 2;
%e A394975   [2]  0, 1,   5;
%e A394975   [3]  0, 1,  12,    16;
%e A394975   [4]  0, 1,  32,   114,    65;
%e A394975   [5]  0, 1,  80,   650,  1060,    326;
%e A394975   [6]  0, 1, 192,  3165, 11240,  10275,   1957;
%e A394975   [7]  0, 1, 448, 13965, 94010, 183715, 106176, 13700;
%p A394975 A := (n, k) -> local j; binomial(n + k, k) * add(binomial(k, j) * j^(n + j) * (1 - j)^(k - j), j = 0..k) / (n + 1): for n from 0 to 7 do seq(A(n, k), k = 0..7) od;  # _Peter Luschny_, Apr 09 2026
%o A394975 (PARI) A(n,k) = my(A = (n+k)!/k!); A*(n==0) + sum(j=1, k, (A *= (k-j+1)) * stirling(n+j,j,2) ) / (n+1)!
%o A394975 (PARI) A(n,k) = my(A = 1); binomial(n+k,k) * (A * (n==0) + sum(j=1, k, (A *= (k-j+1)/j) * j^(n+j) * (1-j)^(k-j))) / (n+1) \\ _Mikhail Kurkov_, Apr 16 2026
%o A394975 (SageMath)
%o A394975 def A394975(n: int, k: int) -> int:
%o A394975     if n < 0 or k < 0: return 0
%o A394975     factnk = falling_factorial(n + k, k - 1)
%o A394975     return sum((factnk * stirling_number2(n+j, j)) // factorial(k-j) for j in range(k+1))
%o A394975 for n in range(7): print([A394975(n, k) for k in range(7)])  # _Peter Luschny_, Apr 09 2026
