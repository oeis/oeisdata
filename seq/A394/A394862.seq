%I A394862 #12 Apr 05 2026 13:16:11
%S A394862 1,1,1,4,35,332,3766,45448,580203,7684838,104896691,1466542342,
%T A394862 20916173845,303351755482
%N A394862 Number of oriented polyominoes with n octagonal cells of the hyperbolic regular tiling with Schläfli symbol {8,8}.
%C A394862 The Mathematica program below is for any regular tiling with Schläfli symbol {p,q} and 1/p + 1/q <= 1/2.  It works for only n < 2q - 2. Another program for achiral polyominoes allows us to calculate the other two chirality classes. Note that for n <= q, the results are the same as for {p,oo}. For oriented polyominoes, chiral pairs are counted as two.
%F A394862 a(n) = A393744(n) + A394863(n) = 2*A393744(n) - A394864(n) = 2*A394863(n) + A394864(n).
%t A394862 p = 8; q = 8; nmax = 2q - 3;
%t A394862 Table[(Binomial[(p-1)n,n]/((p-2)n+1)+If[OddQ[n],0,Binomial[(p-1)n/2,n/2]]+DivisorSum[GCD[p,n-1],EulerPhi[#]Binomial[((p-1)n+1)/#-1,(n-1)/#]&,#>1&])/((p-2)n+2)-If[n<q-1,0,((p-2)(q-1)+1)Binomial[(p-1)n+1-q,n+1-q]/((p-2)n+1)-(((q-1))Binomial[(p-1)n-q,n+1-q]+DivisorSum[GCD[q,n-q],EulerPhi[#]Binomial[((p-1)n-q-#)/#,(n-q)/#]&])/n],{n,0,nmax}]
%Y A394862 Cf. A393744 (unoriented), A394863 (chiral), A394864 (achiral), A389936 {8,oo}.
%K A394862 nonn,hard,more,new
%O A394862 0,4
%A A394862 _Robert A. Russell_, Apr 04 2026
