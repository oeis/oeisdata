%S A394721 6,10,15,28,34,52,75,76,123,136,147,148,153,190,231,232,238,255,268,
%T A394721 292,315,328,375,388,418,425,496,514,555,568,584,585,592,610,645,664,
%U A394721 670,688,693,710,712,742,765,772,776,790,808,826,850,855,885,904,938,976
%N A394721 Numbers k such that the sum of its proper divisors, each to some power greater than zero, is equal to k itself.
%C A394721 Includes all the perfect numbers (A000396).
%C A394721 Excludes all abundant numbers (A005101).
%e A394721 10 is in this list, for the proper divisors of 10 are 1,2,5 and the sum 1+2^2+5 gives 10.
%e A394721 76 is in this list, for its proper divisors are 1, 2, 4, 19, 38, and with the exponent configuration 1, 1, 2, 1, 1, that is 1 + 2 + 4^2 + 19 + 38 the sum is equal to 76.
%t A394721 q[k_] := Module[{d = Most[Divisors[k]], e}, e = Join[{1}, Floor[Log[Rest[d], k]]]; AnyTrue[Tuples[Range /@ e], Total[d^#] == k &]]; Select[Range[2, 1000], q] (* _Amiram Eldar_, Mar 30 2026 *)
%Y A394721 Cf. A000396, A005101.
%K A394721 nonn
