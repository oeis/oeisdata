%I A394696 #33 Apr 08 2026 10:49:20
%S A394696 0,3,16,495,12063,1405369,142923452,52807371633,21999944586015,
%T A394696 29307773982747623
%N A394696 Number of social networks of n persons in which the statement "My friends have on average more friends than I have" is true for a majority of the persons.
%C A394696 This refers to the "friendship paradox" which goes back to S. L. Feld's 1991 article claiming that persons have fewer friends than their friends have. In contrast to Feld's results, which are based on mean values for the number of friends in the networks, this sequence considers majorities. a(n) stands for a weaker criterion than A394695.
%C A394696 The total numbers of social networks as defined by Feld are given by A006129. The proportion a(n)/A006129(n) is above 0.5 and supports Feld's claims for n>6.
%C A394696 a(n) can be defined in graph theoretic terms. The "network" is a labeled simple graph with n unisolated nodes, n>1.
%C A394696 If d_m(i) = degree of node i in the m-th graph, i = 1,..., n, m = 1,..., A006129(n), d_m(i,j) = degree of j-th node connected with node i, j = 1,..., d_m(i), and n_m = #{ i | Sum_j d_m(i,j)/d_m(i) > d_m(i)}, then a(n) = #{ m | n_m > n/2}.
%H A394696 Scott L. Feld, <a href="https://www.jstor.org/stable/2781907">Why Your Friends Have More Friends Than You Do</a>, Am. J. Sociol. 96(6) (1991), p. 1464-1477.
%e A394696 There are 41 networks with 4 nodes (=A006129(4)). 16 of them meet the requirement, making a(4)=16; the edges are:
%e A394696   1-2, 1-3, 1-4;
%e A394696   1-2, 1-3, 1-4, 2-3;
%e A394696   1-2, 1-3, 1-4, 2-4;
%e A394696   1-2, 1-3, 1-4, 3-4;
%e A394696   2-1, 2-3, 2-4;
%e A394696   2-1, 2-3, 2-4, 1-3;
%e A394696   2-1, 2-3, 2-4, 1-4;
%e A394696   2-1, 2-3, 2-4, 3-4;
%e A394696   3-1, 3-2, 3-4;
%e A394696   3-1, 3-2, 3-4, 1-2;
%e A394696   3-1, 3-2, 3-4, 1-4;
%e A394696   3-1, 3-2, 3-4, 2-4;
%e A394696   4-1, 4-2, 4-3;
%e A394696   4-1, 4-2, 4-3, 1-2;
%e A394696   4-1, 4-2, 4-3, 1-3;
%e A394696   4-1, 4-2, 4-3, 2-3.
%t A394696 nmax = 7; a = {};
%t A394696 Do[an = 0; t = Tuples[{0, 1}, n (n - 1)/2];
%t A394696   Do[v = t[[j]]; m = {ConstantArray[0, n]};
%t A394696     Do[la = Last[NestList[Append[#, 0] &, Take[v, i], n - i]];
%t A394696       m = Join[m, {la}]; v = Drop[v, i], {i, n - 1}];
%t A394696     m = m + Transpose[m]; pr = Product[Total[m[[i]]], {i, n}];
%t A394696     If[pr != 0, di = Table[Total[m[[j]]], {j, n}];
%t A394696   dij = Table[Sum[di[[i]] m[[j]][[i]], {i, n}], {j, n}]];
%t A394696   diff = dij/di - di; s = Sign[diff];
%t A394696   If[pr != 0 \[And] Count[s, 1] > n/2, an++], {j, 2^(n (n - 1)/2)}];
%t A394696   a = Join[a, {an}], {n, 2, nmax}]; a
%Y A394696 Cf. A393153, A394695, A006129.
%K A394696 nonn,more,hard,nice,new
%O A394696 2,2
%A A394696 _Manfred Boergens_, Mar 29 2026
%E A394696 a(8)-a(9) from _Sean A. Irvine_, Apr 05 2026
%E A394696 a(10) from _Bert Dobbelaere_, Apr 06 2026
%E A394696 a(11) from _Bert Dobbelaere_, Apr 08 2026
