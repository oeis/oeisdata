%S A394130 0,1,2,9,52,338,2353,17142,129024,995415,7829935,62561143,506346064,
%T A394130 4142669512,34205830042,284675780149,2385522869589,20110997111266,
%U A394130 170450435001697,1451523770936250,12413608227791646,106570655391661388,918092578105254345
%N A394130 G.f. A(x) satisfies A(x)^6-4*A(x)^5+(6x+4)*A(x)^4-(9x+1)*A(x)^3+(5x^2+3x)*A(x)^2-3x^2*A(x)+x^3=0.
%C A394130 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with red root where red vertices can be followed by red or blue vertices, blue vertices can be followed by vertices of any colors, and green vertices can only be followed by green vertices.
%H A394130 Nathan Fox, <a href="/A394130/b394130.txt">Table of n, a(n) for n = 0..300</a>
%H A394130 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394130 (Python)
%o A394130 def A394130(n):
%o A394130     A = [[1, 1, 0], [1, 1, 1], [0, 0, 1]]
%o A394130     if n == 0:
%o A394130         return 0
%o A394130     m = len(A)
%o A394130     output = [[1] for i in range(m)]
%o A394130     for l in range(2, n + 1):
%o A394130         for i in range(m):
%o A394130             term = 0
%o A394130             for k in range(1, l):
%o A394130                 for j in range(m):
%o A394130                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394130             output[i].append(term)
%o A394130     return output[0][n - 1]
%Y A394130 Cf. A394131.
%K A394130 nonn,new
%O A394130 0,3
%A A394130 _Nathan Fox_, Mar 11 2026
