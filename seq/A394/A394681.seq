%U A394681 105403520022709708800,20659089924538281216000,4648295233022420947968000,1189963579653760685469696000,343899474519937193788170240000
%N A394681 a(0) = 1 and a(n) = n^2*a(n-1) + n! for n > 0.
%D A394681 Miklos Bona, Introduction to Enumerative and Analytic Combinatorics, CRC Press, 2025, pp. 161-162.
%F A394681 Doubly e.g.f.: Sum_{n>=0} a(n)*x^n/(n!)^2 = exp(x)/(1 - x).
%F A394681 a(n) = (n!)^2*Sum_{i=0..n} 1/i!.
%F A394681 a(n) = n!*(1 + e*n*Gamma(n, 1)).
%F A394681 a(n) ~ 2*Pi*n^(2*n+1)*exp(-2*n+1).
%t A394681 a[n_]:=n!^2*Sum[1/i!,{i,0,n}]; Array[a,18,0]
%Y A394681 Cf. A000142, A000290, A000522, A001044, A001113.
