%I A394384 #26 Mar 30 2026 02:57:07
%S A394384 1,2,3,4,5,9,7,16,27,25,11,81,13,49,125,65536,17,19683,19,625,343,121,
%T A394384 23,43046721,3125,169,7625597484987,2401,29,1953125,31
%N A394384 Power tower of descending prime factors of n with multiplicity.
%C A394384 The base of the exponent tower is the largest prime factor of n, and the top exponent is the smallest.
%C A394384 a(32) = 2^2^2^2^2 = ~2.0035 * 10^19728 is too large to be included.
%e A394384 The prime factorization of 18 in descending order is 3*3*2; therefore, a(18) = 3^3^2 = 3^9 = 19683.
%p A394384 a:= proc(n) option remember; local i, p, l;
%p A394384       l, p:= sort([seq(i[1]$i[2], i=ifactors(n)[2])]), 1;
%p A394384       for i to nops(l) do p:= l[i]^p od; p
%p A394384     end:
%p A394384 seq(a(n), n=1..31);  # _Alois P. Heinz_, Mar 22 2026
%t A394384 pe[{p_,e_}]:=Table[p,e];a[n_]:=Module[{x=Reverse[Flatten[pe/@FactorInteger[n]]]},l=Length[x];y=First[x];z=x[[l]];If[l==1,y,Do[y=x[[l-i+1]]^z;z=y,{i,2,l}]];y];Array[a,31] (* _James C. McMahon_, Mar 28 2026 *)
%t A394384 A394384[n_] := Power @@ Reverse[Flatten[ConstantArray @@@ FactorInteger[n]]];
%t A394384 Array[A394384, 31] (* _Paolo Xausa_, Mar 29 2026 *)
%o A394384 (PARI) row(n) = if(n>1, concat(apply(t->vector(t[2], i, t[1]), Vec(factor(n)~))), o); \\ A027746
%o A394384 a(n) = if (n==1, 1, my(v=Vecrev(row(n)), s=""); for (i=1, #v, s = concat(s, Str(v[i])); if (i != #v, s = concat(s, "^"))); eval (s)); \\ _Michel Marcus_, Mar 19 2026
%Y A394384 Cf. A394383, A006530, A020639, A027746, A164339.
%K A394384 nonn,new
%O A394384 1,2
