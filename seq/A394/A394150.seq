%T A394150 2612398734,22077092393,188719794960,1628998231002,14179284797898,
%U A394150 124318338700597,1096901534455058,9732505350882469,86782729320998572,777255482221740826
%N A394150 G.f. A(x) satisfies A(x)^6-2*A(x)^5+(6x+1)*A(x)^4-8x*A(x)^3+(9x^2+2x)*A(x)^2-5x^2*A(x)+3x^3=0.
%C A394150 Number of n-vertex planar rooted trees with vertices colored red, blue, and green with green root where red vertices can be followed by red or blue vertices, blue vertices can be followed by vertices of any colors, and green vertices can be followed by red or green vertices.
%H A394150 Nathan Fox, <a href="/A394150/b394150.txt">Table of n, a(n) for n = 0..300</a>
%H A394150 S. Dimitrov, N. Fox, K. Hadaway, A. Tharp, and S. Wagner, <a href="https://arxiv.org/abs/2602.16055">Counting Colored Trees</a>, arXiv:2602.16055 [math.CO], 2026.
%o A394150 (Python)
%o A394150 def A394150(n):
%o A394150     A = [[1, 1, 0], [1, 1, 1], [1, 0, 1]]
%o A394150     if n == 0:
%o A394150         return 0
%o A394150     m = len(A)
%o A394150     output = [[1] for i in range(m)]
%o A394150     for l in range(2, n + 1):
%o A394150         for i in range(m):
%o A394150             term = 0
%o A394150             for k in range(1, l):
%o A394150                 for j in range(m):
%o A394150                     term += A[i][j] * output[i][k - 1] * output[j][l - k - 1]
%o A394150             output[i].append(term)
%o A394150     return output[2][n - 1]
%Y A394150 Cf. A394148, A394149.
%K A394150 nonn,new
%O A394150 0,3
%A A394150 _Nathan Fox_, Mar 11 2026
