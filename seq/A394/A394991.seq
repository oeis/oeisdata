%N A394991 a(n) is the greatest product x*y of two integers 2^(n-1) <= x <= y < 2^n maximizing the Hamming weight of this product.
%H A394991 Bert Dobbelaere, <a href="/A394991/b394991.txt">Table of n, a(n) for n = 1..100</a>
%e A394991 See A394987.
%o A394991 (Python)
%o A394991 from sympy.utilities.iterables import multiset_permutations
%o A394991 from sympy import divisors
%o A394991 def A394991(n):
%o A394991     a = 1<<n-1
%o A394991     b = a<<1
%o A394991     k = (n<<1)-1
%o A394991     c = (1<<k+1)-1
%o A394991     for l in range(k,0,-1):
%o A394991         for s in multiset_permutations('0'*l+'1'*(k+1-l)):
%o A394991             m = c-int(''.join(s),2)
%o A394991             for d in divisors(m):
%o A394991                 if d**2>m:
%o A394991                     break
%o A394991                 if a<=d<b and a*d<=m<b*d:
%o A394991                     return m # _Chai Wah Wu_, Apr 11 2026
