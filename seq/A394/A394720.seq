%I A394720 #38 Apr 08 2026 15:57:09
%S A394720 2,3,5,7,11,17,29,47,73,113,181,293,479,773,1249,2017,3271,5281,8543,
%T A394720 13829,22369,36191,58567,94747,153313,248057,401371,649427,1050811,
%U A394720 1700233,2751041,4451273,7202317,11653583,18855899,30509483,49365389,79874867,129240259
%N A394720 a(1)=2, a(2)=3; for n>=3, a(n) = prime nearest to a(n-1) + a(n-2), with ties broken by taking the smaller prime.
%C A394720 This sequence is generated by a rule similar to the Fibonacci recurrence but with the sum replaced by the nearest prime. The ratio of consecutive terms tends to the golden ratio phi = (1+sqrt(5))/2.
%H A394720 James C. McMahon, <a href="/A394720/b394720.txt">Table of n, a(n) for n = 1..1000</a>
%F A394720 a(1)=2, a(2)=3; for n>=3, a(n) = prime nearest to a(n-1)+a(n-2), with ties broken by taking the smaller prime.
%e A394720 a(3): 2+3=5, nearest prime is 5 (since 5 is prime), so a(3)=5.
%e A394720 a(4): 3+5=8, nearest prime is 7 (since 8-1=7), so a(4)=7.
%e A394720 a(5): 5+7=12, nearest prime is 11 (since 12-1=11), so a(5)=11.
%e A394720 a(6): 7+11=18, nearest prime is 17 (since 18-1=17), so a(6)=17.
%e A394720 a(7): 11+17=28, nearest prime is 29 (since 28+1=29), so a(7)=29.
%e A394720 a(8): 17+29=46, nearest prime is 47 (since 46+1=47), so a(8)=47.
%p A394720 a:= proc(n) option remember;
%p A394720       `if`(n<3, n+1, (s-> ((x, y)-> `if`(y-s<s-x, y, x))(
%p A394720           prevprime(s+1), nextprime(s-1)))(a(n-1)+a(n-2)))
%p A394720     end:
%p A394720 seq(a(n), n=1..39);  # _Alois P. Heinz_, Apr 01 2026
%t A394720 s={2,3};Do[sm=s[[-1]]+s[[-2]];If[PrimeQ[sm],AppendTo[s,sm],l=NextPrime[sm,-1];h=NextPrime[sm];If[h-sm<sm-l,AppendTo[s,NextPrime[sm]],AppendTo[s,NextPrime[sm,-1]]]],{i,37}];s (* _James C. McMahon_, Apr 08 2026 *)
%Y A394720 Cf. A000045, A000032, A005478, A001622, A055498, A055500.
%K A394720 nonn
%O A394720 1,1
