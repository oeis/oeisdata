%N A394030 a(0) = 1; a(n) = n * Sum_{j=0..n-1} Sum_{i=0..j} a(i) * a(j-i).
%F A394030 G.f. A(x) satisfies: A(x) = 1 + x * d/dx ( x * A(x)^2 / (1 - x) ).
%F A394030 a(n) ~ c * n * 2^n * n!, where c = 0.41609792938291784112194732217310... - _Vaclav Kotesovec_, Mar 07 2026
%t A394030 a[0] = 1; a[n_] := a[n] = n Sum[Sum[a[i] a[j - i], {i, 0, j}], {j, 0, n - 1}]; Table[a[n], {n, 0, 20}]
%t A394030 nmax = 20; A[_] = 0; Do[A[x_] = 1 + x D[x A[x]^2/(1 - x), x] + O[x]^(nmax + 1) // Normal, nmax + 1]; CoefficientList[A[x], x]
