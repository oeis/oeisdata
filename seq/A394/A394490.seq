%N A394490 Expansion of e.g.f. (1/x) * Series_Reversion( x/(1 + 5*x)^(3/5) ).
%H A394490 Vincenzo Librandi, <a href="/A394490/b394490.txt">Table of n, a(n) for n = 0..300</a>
%F A394490 E.g.f. A(x) satisfies A(x) = (1 + 5*x*A(x))^(3/5).
%F A394490 a(n) = 5^n * n! * binomial(3*(n+1)/5,n)/(n+1).
%F A394490 a(5*n+4) = 0.
%t A394490 a[n_]:=5^n*n!*Binomial[3*( n+1)/5,n]/(n+1); Table[a[n],{n,0,18}] (* _Vincenzo Librandi_, Mar 31 2026 *)
%o A394490 (PARI) a(n) = 5^n*n!*binomial(3*(n+1)/5, n)/(n+1);
%o A394490 (Magma) [1] cat [5^n*Factorial(n)*&*[(3*(n+1)/5-k): k in [0..n-1]]/Factorial(n)/(n+1): n in [1..20] ]; // _Vincenzo Librandi_, Mar 31 2026
