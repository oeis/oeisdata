%U A394821 279988159358293220715583000,4099716634680845097803737349958,85017531134644058262398146525170432,2428302814758720167093533317480679164772
%N A394821 G.f. A(x) satisfies A(x) = 1 - E^4(log(1 - x*A(x))), where E is the Euler operator x*d/dx.
%F A394821 G.f.: 1 + E^3(B(x)), where B(x) is the g.f. of A393775.
%F A394821 a(n) = n^3 * A393775(n) for n > 0.
%F A394821 a(0) = 1; a(n) = n^4 * a(n-1) + Sum_{k=1..n-1} (n/k)^3 * a(k) * a(n-1-k).
%e A394821      -E(log(1 - x*A(x))) =     x +  3*x^2 +   76*x^3 +   8311*x^4 + ...
%e A394821    -E^2(log(1 - x*A(x))) =     x +  6*x^2 +  228*x^3 +  33244*x^4 + ...
%e A394821    -E^3(log(1 - x*A(x))) =     x + 12*x^2 +  684*x^3 + 132976*x^4 + ...
%e A394821 1 - E^4(log(1 - x*A(x))) = 1 + x + 24*x^2 + 2052*x^3 + 531904*x^4 + ...
%o A394821 (PARI) E(f) = x*deriv(f);
%o A394821 my(A=1, N=20); for(k=1, N, A=1-E(E(E(E(log(1-x*A)))))+x*O(x^N)); Vec(A)
%Y A394821 Cf. A003319, A393959, A393977.
%Y A394821 Cf. A393775.
%K A394821 nonn
