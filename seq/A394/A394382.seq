%I A394382 #22 Apr 10 2026 00:48:28
%S A394382 110092211,112191011,1100091121,1100910121,1210091011,1210910011,
%T A394382 11009111021,11011009111,11011092011,11011109111,11019111011,
%U A394382 11091001121,11091011011,11091111011,12011091011,12110009111,101099110111,101110910011,102101009111,110009111101,110019101111
%N A394382 Primes p such that the reversal of p^2 is the square of a prime not equal to p nor the reversal of p.
%C A394382 Subsequence of A393520. a(1) and a(2) were found by _Robert Israel_ (see A393520).
%C A394382 The first decimal digit of a(n)^2 is either 1 or 9.
%C A394382 Conjecture 1: The first and last decimal digit of a(n) is 1.
%C A394382 Conjecture 2: The nonzero decimal digits of a(n) are either 1, 2 or 9.
%C A394382 Using Conjecture 2, larger terms such as 1001002109111, 1001011091011, 1001012009111, 1001100901111, 1001100911101, 1001199911111, 1002011091121, 1010109020111, 1010990110201, 1011010091111, ... are found.
%C A394382 If we remove the condition "nor the reversal of p", we get the sequence 13, 31, 113, 311, 1021, 1031, 1103, 1201, ...
%C A394382 If we remove the condition "not equal to p", we get the sequence 307, 30001253, 110092211, 111091111, 112191011, 1100091121, ...
%o A394382 (Python)
%o A394382 from math import isqrt
%o A394382 from itertools import count, islice
%o A394382 from sympy import primerange, integer_nthroot, isprime
%o A394382 def A394382_gen(): # generator of terms
%o A394382     for l in count(0):
%o A394382         for p in primerange(isqrt(m:=10**l)+1,isqrt((m<<1)-1)+1):
%o A394382             q, r = integer_nthroot(int(str(p**2)[::-1]),2)
%o A394382             if r and q!=p and q!=int(str(p)[::-1]) and isprime(q):
%o A394382                 yield p
%o A394382         for p in primerange(isqrt(9*m),isqrt(10*m-1)+1):
%o A394382             q, r = integer_nthroot(int(str(p**2)[::-1]),2)
%o A394382             if r and q!=p and q!=int(str(p)[::-1]) and isprime(q):
%o A394382                 yield p
%o A394382 A394382_list = list(islice(A394382_gen(),6))
%Y A394382 Cf. A393520.
%K A394382 nonn,base,new
%O A394382 1,1
