%N A394507 Triangle read by rows: T(n,k) = denominator(binomial(1/n, k)) with 1 <= k <= n.
%H A394507 Vincenzo Librandi, <a href="/A394507/b394507.txt">Table of n, a(n) for n = 1..11325</a> (rows 1..150, flattened).
%e A394507 The triangle of the fractions begins:
%e A394507   1/1;
%e A394507   1/2,  -1/8;
%e A394507   1/3,  -1/9,  5/81;
%e A394507   1/4, -3/32, 7/128, -77/2048;
%e A394507   1/5, -2/25, 6/125,  -21/625, 399/15625;
%e A394507   ...
%t A394507 T[n_,k_]:=Denominator[Binomial[1/n,k]]; Table[T[n,k],{n,9},{k,n}]//Flatten
%o A394507 (Magma) T:= function(n,k) r:= &*[(RationalField()!1/n-j):j in [0..k-1]] / Factorial(k);
%o A394507 return Denominator(r); end function; &cat[[T(n,k):k in [1..n]]:n in [1..9]]; // _Vincenzo Librandi_, Mar 23 2026
%Y A394507 Cf. A007318, A394506 (numerators).
%Y A394507 Columns k=1..2 give A000027, A181900.
%Y A394507 Right diagonal gives A145921.
