%U A394250 12225,14774,17784,21376,25635,30694,36656,43734,52040,61832,73329,86858,102664,121217
%N A394250 Number of partitions p of n such that (maximal multiplicity of the parts of p) <= 2 * (number of distinct parts of p).
%H A394250 Seiichi Manyama, <a href="/A394250/b394250.txt">Table of n, a(n) for n = 0..1000</a>
%F A394250 G.f.: Sum_{i>=0} [z^i] Product_{j>=1} (1 + z * Sum_{k=1..2*i} q^(j*k)).
%e A394250 a(6) counts these 9 partitions: 6, 51, 42, 411, 33, 321, 3111, 2211, 21111.
%o A394250 (PARI) my(N=50, q='q+O('q^N)); Vec(sum(i=0, N, polcoef(prod(j=1, N, 1+z*sum(k=1, 2*i, q^(j*k))), i, z)))
%Y A394250 Cf. A000041, A240306, A394251.
%K A394250 nonn
