%S A394255 1,3,4,5,6,12,8,7,10,18,12,20,14,24,24,17,18,30,20,30,32,36,24,28,26,
%T A394255 42,13,40,30,72,32,19,48,54,48,50,38,60,56,42,42,96,44,60,60,72,48,68,
%U A394255 50,78,72,70,54,39,72,56,80,90,60,120,62,96,80,21,84,144,68,90
%N A394255 The sum of infinitary divisors of n that are numbers whose prime factorization exponents are all powers of 2 (A138302).
%C A394255 The number of these divisors is A392451(n), and the largest of them is A353897(n).
%H A394255 Amiram Eldar, <a href="/A394255/b394255.txt">Table of n, a(n) for n = 1..10000</a>
%F A394255 Multiplicative with a(p^e) = (1 + Sum_{k>=0} p^(2^k)), where e = Sum_{k>=0} e_k * 2^k, i.e., e_k is k-th bit of e.
%t A394255 f[p_, e_] := 1 + Total[p^(2^(-1 + Position[Reverse@IntegerDigits[e, 2], 1] // Flatten))]; a[1] = 1; a[n_] := Times @@ f @@@ FactorInteger[n]; Array[a, 100]
%o A394255 (PARI) a(n) = {my(f = factor(n), e); prod(k = 1, #f~, e = binary(f[k, 2]); 1 + sum(i = 1, #e, if(e[i], f[k, 1]^(2^(#e-i)), 0)));}
%Y A394255 Cf. A049417, A077609, A138302, A353897, A392451.
%K A394255 nonn,mult,easy,new
%O A394255 1,2
%A A394255 _Amiram Eldar_, Mar 14 2026
