%I A394901 #13 Apr 06 2026 09:35:46
%S A394901 1,1,0,1,1,0,1,2,4,0,1,3,9,48,0,1,4,15,104,912,0,1,5,22,169,1936,
%T A394901 22784,0,1,6,30,244,3084,47776,690496,0,1,7,39,330,4369,75168,1436160,
%U A394901 24314624,0,1,8,49,428,5805,105168,2240944,50280064,969209152,0
%N A394901 Square array A(n,k), n >= 0, k >= 0, read by antidiagonals downwards, where column k is the expansion of B(x)^k, where B(x) is the g.f. of A393890.
%F A394901 A(n,0) = 0^n.
%F A394901 A(0,1) = A(1,1) = 1;   A(n,1) =     4 * Sum_{j=1..n-1} A(j,1) * A(n-j,j).
%F A394901 For k > 1, A(0,k) = 1; A(n,k) = (1/n) * Sum_{j=1..n} ((k+1)*j-n) * A(j,1) * A(n-j,k).
%e A394901 Square array begins:
%e A394901   1,     1,     1,     1,      1,      1, ...
%e A394901   0,     1,     2,     3,      4,      5, ...
%e A394901   0,     4,     9,    15,     22,     30, ...
%e A394901   0,    48,   104,   169,    244,    330, ...
%e A394901   0,   912,  1936,  3084,   4369,   5805, ...
%e A394901   0, 22784, 47776, 75168, 105168, 138001, ...
%o A394901 (PARI) a(n, k, m=4) = if(n*k<=1, k^n, if(k==1, m*sum(j=1, n-1, a(j, 1)*a(n-j, j)), sum(j=1, n, ((k+1)*j-n)*a(j, 1)*a(n-j, k))/n));
%Y A394901 Columns k=0..1 give A000007, A393890.
%Y A394901 Cf. A392378, A392379, A394047.
%K A394901 nonn,tabl
%O A394901 0,8
%A A394901 _Seiichi Manyama_, Apr 06 2026
