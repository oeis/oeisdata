%T A394624 0,0,11,0,0,0,22,14,0,0,0,5,21,0,63,28,65,0,0,0,29,7,56,18,0,0,0,136,
%U A394624 5,0,568,4,0,0,23,0,0,0,8,6,0,99,0,101,0,0,20,0,13,0,27,0,0,0,7,0,5,0
%N A394624 Largest x for which x^3 - n = y^2 is an integer solution to this Mordell's equation, 0 if no such x exists.
%e A394624 For n = 1, a(n) = 1 is the largest x for which x^3 - 1 = 0 is a square.
%e A394624 For n = 2, a(n) = 3 is the largest x for which x^3 - 2 = 25 is a square.
%e A394624 For n = 3, 5, 6, ... (cf. A081121) Mordell's equation y^2 = x^3 - n has no integer solution, so a(n) = 0.
%e A394624 For n = 4, a(n) = 5 is the largest x for which x^3 - 4 = 121 = y^2 for y = +-11, the other inequivalent solution being x = 2, y = +-2.
%o A394624 (PARI) apply( {A394624(n,L=20*n^2)=if(L=ellratpoints(ellinit([0, 0, 0, 0, -n]), [L, 1]),L[#L][1])}, [1..99]) \\ Search limit L corresponds to Hall's conjecture with over-estimate of the largest known ratio sqrt(x)/n ~ 4.26.
%Y A394624 Cf. A081120 (number of integral solutions to y^2 = x^3 - n), A134109 (only those with y >= 0), A081121 (n for which there are no integral solutions), A081119 (number of integral solutions to y^2 = x^3 + n).
%K A394624 nonn,changed
%O A394624 1,2
