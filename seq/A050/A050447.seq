%e A050447 Illustrating the reverse-accumulate procedure computing row 3 (see Python code).
%e A050447 ini[ 1, 1, 1, 1]                                           -> 1;
%e A050447 rev[ 1, 1, 1, 1] = [ 1, 1, 1, 1], accu -> [ 1,  2,  3,  4] -> 4;
%e A050447 rev[ 1, 2, 3, 4] = [ 4, 3, 2, 1], accu -> [ 4,  7,  9, 10] -> 10;
%e A050447 rev[ 4, 7, 9,10] = [10, 9, 7, 4], accu -> [10, 19, 26, 30] -> 30;
%e A050447 rev[10,19,26,30] = [30,26,19,10], accu -> [30, 56, 75, 85] -> 85;
%e A050447 rev[30,56,75,85] = [85,75,56,30], accu -> [85,160,216,246] -> 246;
%e A050447 Trow(3, 6) = [1, 4, 10, 30, 85, 246].
%p A050447 A := proc(n, k) option remember; local j;
%p A050447 ifelse(n = 0 or k = 0, 1, ifelse(n < 0 or k < 0, 0, A(n, k - 1 ) +
%p A050447 add(A(2 * j, k - 1) * A(n - 1 - 2 * j, k), j = 0..iquo(n-1, 2)))) end:
%p A050447 for n from 0 to 9 do seq(A(k, n), k = 0..9) od;  # _Peter Luschny_, Mar 15 2026
%t A050447 nmax = 12; t[n_, m_?Positive] := t[n, m] = t[n, m-1] + Sum[t[2k, m-1]*t[n-1-2k, m], {k, 0, (n-1)/2}]; t[n_, 0]=1; Flatten[ Table[ t[k-1, n-k], {n, 1, nmax}, {k, 1, n}]] (* _Jean-François Alcover_, Nov 14 2011 *)
%t A050447 nmax = 10; f[0, x_] := 1; f[1, x_] := 1/(1 - x); f[n_, x_] := (x + f[n - 2, x])/(1 - x^2 - x*f[n - 2, x]); t[n_, m_] := Coefficient[Series[f[n, x], {x, 0, m}], x, m]; Grid[Table[t[n, m], {n, nmax}, {m, 0, nmax - 1}]] (* _L. Edson Jeffery_, Oct 19 2017 *)
%o A050447 (PARI) M(n)=matrix(n,n,i,j,if(sign(i+j-n)-1,0,1)); V(n)=vector(n,i,1); P(r,n)=vecmax(V(r)*M(r)^n) \\ P(r,n) is T(n,k); _Benoit Cloitre_, Jan 27 2003
%o A050447 (Python)
%o A050447 from itertools import accumulate
%o A050447 def Arow(row: int, rowlen: int) -> list[int]:
%o A050447     acc = [1] * (row + 1)
%o A050447     vec = [1] * rowlen
%o A050447     for k in range(1, rowlen):
%o A050447         acc = list(accumulate(reversed(acc)))
%o A050447         vec[k] = acc[-1]
%o A050447     return vec
%o A050447 for n in range(10): print(Arow(n, 10))  # _Peter Luschny_, Mar 15 2026
%o A050447 # Alternative: matrix form and numpy based.
%o A050447 import numpy as np
%o A050447 def MatRow(n: int, rowlen: int) -> list[int]:
%o A050447     M = np.array([[1 if i + j >= n else 0
%o A050447     for j in range(n + 1)] for i in range(n + 1)], dtype=object)
%o A050447     ones = np.ones(n + 1, dtype=object)
%o A050447     v = ones.copy()
%o A050447     row = [int(v[n])]
%o A050447     for _ in range(rowlen - 1):
%o A050447         v = M @ v
%o A050447         row.append(int(v[n]))
%o A050447     return row
%o A050447 for n in range(10): print(MatRow(n, 10))  # _Peter Luschny_, Mar 15 2026
