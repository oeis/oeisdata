%N A086287 Greatest prime factor of 7-smooth numbers.
%H A086287 Amiram Eldar, <a href="/A086287/b086287.txt">Table of n, a(n) for n = 1..10000</a>
%F A086287 a(n) = A006530(A002473(n)).
%F A086287 A086286(n) <= a(n) <= 7.
%t A086287 Reap[Do[p = FactorInteger[n][[-1, 1]]; If[p < 11, Sow[p]], {n, 1, 500}] ][[2, 1]] (* _Jean-François Alcover_, Dec 17 2017 *)
%o A086287 (Python)
%o A086287 from sympy import integer_log
%o A086287 from oeis_sequences.OEISsequences import bisection
%o A086287 def A086287(n):
%o A086287     if n == 1: return 1
%o A086287     def f(x):
%o A086287         c = n+x
%o A086287         for i in range(integer_log(x,7)[0]+1):
%o A086287             for j in range(integer_log(m:=x//7**i,5)[0]+1):
%o A086287                 for k in range(integer_log(r:=m//5**j,3)[0]+1):
%o A086287                     c -= (r//3**k).bit_length()
%o A086287         return c
%o A086287     m = bisection(f,n,n)
%o A086287     if not (m&-m)^m:
%o A086287         return 2
%o A086287     elif not m%7:
%o A086287         return 7
%o A086287     elif not m%5:
%o A086287         return 5
%o A086287     else:
%o A086287         return 3 # _Chai Wah Wu_, Mar 13 2026
%Y A086287 Cf. A002473, A006530, A086286.
%K A086287 nonn,changed
%O A086287 1,2
%A A086287 _Reinhard Zumkeller_, Jul 15 2003
