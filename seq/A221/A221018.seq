%I A221018 #26 Jul 04 2026 01:08:02
%S A221018 108,2688,3528,4968,6480,15288,18048,20808,21000,25308,35448,47520,
%T A221018 62928,68208,81648,82008,97608,103968,108288,116928,137088,139968,
%U A221018 151848,162288,196560,197568,200928,235008,238728,253368,278208,363888,379008,400248,444528,449568,457608
%N A221018 Number k such that Fibonacci(k) is divisible by k, k + 1 and k - 1.
%C A221018 Numbers k such that Fibonacci(k) mod k = Fibonacci(k) mod (k-1) = Fibonacci(k) mod (k+1) = 0.
%C A221018 Subsequence of A023172.
%H A221018 Chai Wah Wu, <a href="/A221018/b221018.txt">Table of n, a(n) for n = 1..200</a>
%o A221018 (Python)
%o A221018 prpr, prev = 0, 1
%o A221018 for n in range(2, 100000):
%o A221018     prpr, prev = prev, prpr+prev
%o A221018     if n%2: continue
%o A221018     if (prev % n, prev % (n-1), prev % (n+1)) == (0, 0, 0):
%o A221018         print(n, end=", ")
%o A221018 (Python)
%o A221018 from itertools import count, islice
%o A221018 def A221018_gen(startvalue=2): # generator of terms >= startvalue
%o A221018     def fibonacci_mod(n,m): # fibonacci(n) mod m
%o A221018         a, b, c, d, a2, b2, c2, d2 = 1, 1, 1, 0, 1, 0, 0, 1
%o A221018         for x in bin(n)[2:]:
%o A221018             e, f = b2*c2%m, a2+d2
%o A221018             a2, b2, c2, d2 = (pow(a2,2,m)+e)%m, b2*f%m, c2*f%m, (pow(d2,2,m)+e)%m
%o A221018             if x=='1':
%o A221018                 a2, b2, c2, d2 = (a2*a+b2*c)%m, (a2*b+b2*d)%m, (c2*a+d2*c)%m, (c2*b+d2*d)%m
%o A221018         return c2
%o A221018     return filter(lambda m: not (fibonacci_mod(m,m-1) or fibonacci_mod(m,m) or fibonacci_mod(m,m+1)), count(max(startvalue,2)))
%o A221018 A221018_list = list(islice(A221018_gen(),20)) # _Chai Wah Wu_, Jul 03 2026
%Y A221018 Cf. A000045, A023172, A225219.
%K A221018 nonn
%O A221018 1,1
