%N A016042 Inverse of 2033rd cyclotomic polynomial.
%C A016042 Periodic with period length 2033. - _Ray Chandler_, Apr 07 2017
%H A016042 Ray Chandler, <a href="/A016042/b016042.txt">Table of n, a(n) for n = 0..3000</a>
%H A016042 <a href="/index/Per#periodic">Index entries for periodic sequences</a>, period 2033.
%H A016042 <a href="/index/Rec#order_1908">Index entries for linear recurrences with constant coefficients</a>, order 1908.
%H A016042 <a href="/index/Pol#poly_cyclo_inv">Index to sequences related to inverse of cyclotomic polynomials</a>
%p A016042 with(numtheory,cyclotomic); c := n->series(1/cyclotomic(n,x),x,80);
%t A016042 CoefficientList[Series[1/Cyclotomic[2033,x],{x,0,120}],x] (* _Harvey P. Dale_, Apr 11 2022 *)
%o A016042 (PARI) first(n)=Vec(1/polcyclo(2033)+O(x^(n+1))) \\ _Charles R Greathouse IV_, Jun 01 2026
%K A016042 sign,easy
%O A016042 0,1
%A A016042 _Simon Plouffe_
