%p A238344 b:= proc(n, i) option remember; `if`(n=0, 1, expand(
%p A238344        add(b(n-j, j)*`if`(j<i, x, 1), j=1..n)))
%p A238344     end:
%p A238344 T:= n-> (p-> seq(coeff(p, x, i), i=0..degree(p)))(b(n, 0)):
%p A238344 seq(T(n), n=0..20);
%t A238344 b[n_, i_] := b[n, i] = If[n == 0, 1, Expand[Sum[b[n-j, j]*If[j<i, x, 1], {j, 1, n} ]]]; T[n_] := Function[{p}, Table[Coefficient[p, x, i], {i, 0, Exponent[p, x]}]][b[n, 0]]; Table[T[n], {n, 0, 20}] // Flatten (* _Jean-François Alcover_, Feb 11 2015, after Maple *)
%o A238344 (SageMath)
%o A238344 from sage.combinat.q_analogues import q_factorial,q_int
%o A238344 def invDes(k):
%o A238344     R.<x,y> = PolynomialRing(ZZ)
%o A238344     Axy = 0;
%o A238344     for p in Partitions(k):
%o A238344         denominator=1;
%o A238344         numerator=q_factorial(k,x)*factorial(len(p));
%o A238344         expP = p.to_exp();
%o A238344         for i in range(0,len(expP)):
%o A238344             denominator=denominator*factorial(expP[i])*(q_factorial(i+1,x))^expP[i];
%o A238344         polx = numerator/denominator;
%o A238344         polx = polx.numerator();
%o A238344         poly = y^(len(p)-1)*(1-y)^(k-len(p));
%o A238344         Axy = Axy + polx*poly;
%o A238344     return Axy;
%o A238344 rows = 16;
%o A238344 cols = round(rows/3);
%o A238344 prec = rows+cols;
%o A238344 R.<x,y> = PowerSeriesRing(ZZ, default_prec=prec);
%o A238344 pol = sum([invDes(k)*x^k/prod([(1-x^i) for i in [1..k]]) for k in [1..rows]]);
%o A238344 mat = matrix(pol.monomial_coefficients());
%o A238344 mat[0,0]=1;
%o A238344 mat = mat[0:rows+1,0:cols+1];
%o A238344 print(mat) # _Eder G. Santos_, May 21 2026
