%U A296238 1,0,0,0,1,1,1,1,0,1,0,2,0,2,0,2,1,1,1,0
%N A296238 Expansion of Product_{k>0} (1 + x^(k*(3*k+1)/2)).
%H A296238 Vaclav Kotesovec, <a href="/A296238/b296238.txt">Table of n, a(n) for n = 0..20000</a>
%F A296238 a(n) ~ zeta(3/2)^(1/3) * (sqrt(2) - 1)^(1/3) * exp(3*Pi^(1/3) * zeta(3/2)^(2/3) * (sqrt(2) - 1)^(2/3) * n^(1/3) / (2^(5/3)*d^(1/3))) / (2^(4/3 + b/(2*d)) * sqrt(3) * d^(1/6) * Pi^(1/3) * n^(5/6)) * (1 - ((sqrt(2) - 1)^(4/3) * b^2 * Pi^(2/3) * zeta(1/2) * zeta(3/2)^(1/3) / (2^(23/6) * d^(5/3)) + 5*d^(1/3) / (9 * (2*Pi)^(1/3) * (sqrt(2) - 1)^(2/3) * zeta(3/2)^(2/3))) / n^(1/3)), where d = 3/2, b = 1/2. - _Vaclav Kotesovec_, Mar 11 2026
%t A296238 nmax = 100; CoefficientList[Series[Product[(1 + x^(k*(3*k+1)/2)), {k, 1, Floor[Sqrt[1 + 24*nmax]/6]+1}], {x, 0, nmax}], x] (* _Vaclav Kotesovec_, Dec 10 2017, updated Mar 11 2026 *)
%o A296238 (PARI) N=66; x='x+O('x^N); Vec(prod(k=1, N, (1+x^(k*(3*k+1)/2))))
%Y A296238 Cf. A218380, A290942, A296237.
%K A296238 nonn
