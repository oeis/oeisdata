%t A248802 PrimeFactors[n_]:= Flatten[Table[#[[1]], {1}]&/@FactorInteger[n]]; Table[PrimeFactors[2^(2^n + 2) + 3] [[1]], {n, 0, 7}] (* _Vincenzo Librandi_, Oct 15 2014 *)
