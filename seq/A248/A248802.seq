%o A248802 (PARI) for(n=1,19,my(x=2^(2^n+2)+3);forprime(k=3,oo,if(x%k==0,print1(k,", ");break))) \\ _Hugo Pfoertner_, Aug 08 2019
%o A248802 (Python)
%o A248802 from sympy import nextprime
%o A248802 def A248802(n):
%o A248802     if n == 0: return 11
%o A248802     if n>2 and n&1: return 13
%o A248802     m, p = (1<<n)+2, 13
%o A248802     while True:
%o A248802         if pow(2,m%(p-1),p)==p-3:
%o A248802             return p
%o A248802         p = nextprime(p) # _Chai Wah Wu_, May 25 2026
