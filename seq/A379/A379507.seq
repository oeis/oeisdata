%I A379507 #16 May 08 2026 08:14:31
%S A379507 1,3,5,35,21,21,3,15,5,1,21,7,35,15,15,15,15,105,105,105,15,15,15,15,
%T A379507 21,21,7,35,105,7,7,21,105,105,21,7,7,105,35,35,105,105,105,105,105,
%U A379507 105,105,105,15,3,3,3,105,105,21,3,3,15,15,21,21,21,15,15,15,15
%N A379507 For n >= 1, a(n) = GCD((2*n)! / (n!)^2, 105).
%C A379507 See the reference in the Links section, page 1747, Question. Is GCD(C(2*n, n), 105) = 1 for infinitely many positive integers n ? (is a(n) = 1 for infinitely many n >= 1 ?).
%H A379507 Daniel Berend and Jørgen E. Harmse, <a href="https://doi.org/10.1090/S0002-9947-05-03780-3">On polynomial-factorial diophantine equations</a>, Transactions of the American Mathematical Society, Volume 358, Issue 4 (2006), pages 1741-1779.
%e A379507 n = 3:  a(3) = GCD(6!/(3!)^2, 105) = 5.
%t A379507 a[n_] := GCD[Binomial[2*n, n], 105]; Array[a, 70] (* _Amiram Eldar_, Dec 23 2024 *)
%o A379507 (Python)
%o A379507 from math import prod
%o A379507 from sympy.ntheory.factor_ import digits
%o A379507 def A379507(n): return prod(p if (sum(digits(n,p)[1:])<<1)>sum(digits(n<<1,p)[1:]) else 1 for p in (3,5,7)) # _Chai Wah Wu_, May 07 2026
