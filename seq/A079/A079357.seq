%I A079357 #9 Mar 16 2026 12:12:03
%S A079357 1,5,9,13,12,16,20,24,23,27,31,30,29,33,37,36,40,44,48,47,51,55,54,53,
%T A079357 57,61,60,64,63,62,61,65,64,68,72,71,70,74,78,77,81,85,89,88,92,96,95,
%U A079357 94,98,102,101,105,104,103,102,106,105,109,113,112,111,110,109,108,107
%N A079357 a(1)=1; a(n)=a(n-1)-1 if n is already in the sequence, a(n)=a(n-1)+4 otherwise.
%C A079357 If, in the defining recurrence, the rule a(n)=a(n-1)+4 when n is not already in the sequence is generalized to a(n)=a(n-1)+k, then the resulting sequence ultimately becomes periodic with period 1,3,10,35 for k=1,2,3,4, respectively. - _John W. Layman_, Apr 15 2003
%F A079357 It appears that, for n >= 219, a(n)=n+b(n) where b(n) is the period-35 sequence (-1, 2, 5, 3, 6, 9, 7, 5, 8, 11, 9, 12, 10, 8, 6, 9, 7, 10, 13, 11, 9, 7, 5, 3, 1, -1, -3, -5, -7, -9, -11, -13, -10, -7, -4).
%p A079357 A079357 := proc(n)
%p A079357     option remember ;
%p A079357     if n =1 then
%p A079357         1;
%p A079357     else
%p A079357         fnd := false ;
%p A079357         for j from 1 to n-1 do
%p A079357             if procname(j) = n then
%p A079357                 fnd := true ;
%p A079357                 break ;
%p A079357             end if;
%p A079357         end do;
%p A079357         if fnd then
%p A079357             procname(n-1)-1 ;
%p A079357         else
%p A079357             procname(n-1)+4 ;
%p A079357         end if;
%p A079357     end if;
%p A079357 end proc:
%p A079357 seq(A079357(n),n=1..100) ; # _R. J. Mathar_, Mar 16 2026
