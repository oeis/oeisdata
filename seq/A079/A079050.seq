%T A079050 5,6,7,5,9,10,11,12,13,14,6,7,8,9,6,11,12,13,14,15,7,8,9,10,11,7,13,
%U A079050 14,15,16,8,9,10,11,12,13,8,15,16,17,9,10,11,12,13,14,15,9,17,18,10,11,12,13
%N A079050 Sum of the digits of LookAndSay(n).
%H A079050 Chris R. Rehmann, <a href="/A079050/b079050.txt">Table of n, a(n) for n = 0..10000</a>
%F A079050 a(n) = A007953(A045918(n)). - _Chris R. Rehmann_, Jul 16 2026
%e A079050 LookAndSay(23) = 1213, the sum of whose digits = 7, so a(23) = 7.
%t A079050 lookandsay[n_] := Module[{r, d, f, i, l, k}, r = ""; d = IntegerDigits[n]; While[d != {}, f = First[d]; i = 2; l = Length[d]; While[i <= l && d[[i]] == f, i = i + 1]; k = i - 1; r = r <> ToString[k]; r = r <> ToString[f]; d = Drop[d, k]]; ToExpression[r]]; t = Table[Apply[Plus, IntegerDigits[lookandsay[i]]], {i, 1, 100}]
%o A079050 (MATLAB)
%o A079050 N = 84; a = NaN(1,N); % N <= 2^53+1
%o A079050 for n = 0:min(N-1,flintmax)
%o A079050     d = num2str(n)-'0'; k = 1; a(n+1) = 0;
%o A079050     for i = [find(diff(d)) length(d)]
%o A079050         a(n+1) = a(n+1) + i-k+1 + d(k);
%o A079050         k = i+1;
%o A079050     end
%o A079050 end
%o A079050 disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Jul 16 2026
%o A079050 (Python)
%o A079050 from itertools import groupby
%o A079050 def a(n): return sum(map(int, ''.join(str(len(list(g)))+k for k, g in groupby(str(n)))))
%o A079050 print([a(n) for n in range(0,84)]) # _Michael S. Branicky_, Jul 16 2026
