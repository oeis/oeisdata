%I A079355 #17 Mar 25 2026 09:00:48
%S A079355 1,5,9,13,10,14,18,22,19,16,20,24,21,18,22,19,23,20,17,14,11,8,5,2,6,
%T A079355 10,14,18,22,26,30,34,38,35,32,36,40,37,41,38,35,39,43,47,51,55,52,56,
%U A079355 60,64,61,58,62,66,63,60,64,61,65,62,59,56,53,50,47,44,48,52,56,60,64,68
%N A079355 a(1) = 1; a(n) = a(n-1)-3 if n is already in the sequence, a(n) = a(n-1)+4 otherwise.
%H A079355 Paolo Xausa, <a href="/A079355/b079355.txt">Table of n, a(n) for n = 1..10000</a>
%H A079355 <a href="/index/Rec#order_43">Index entries for linear recurrences with constant coefficients</a>, order 43.
%F A079355 a(n) = n+b(n)-22 where b(n) is the 42-periodic sequence (22, 25, 28, 31, 27, 30, 33, 36, 32, 28, 31, 34, 30, 26, 29, 25, 28, 24, 20, 16, 12, 8, 4, 0, 3, 6, 9, 12, 15, 18, 21, 24, 27, 23, 19, 22, 25, 21, 24, 20, 16, 19)
%F A079355 a(n) = +a(n-1) +a(n-42) -a(n-43). - _R. J. Mathar_, Mar 16 2026
%p A079355 A079355 := proc(n)
%p A079355     option remember ;
%p A079355     if n =1 then
%p A079355         1;
%p A079355     else
%p A079355         fnd := false ;
%p A079355         for j from 1 to n-1 do
%p A079355             if procname(j) = n then
%p A079355                 fnd := true ;
%p A079355                 break ;
%p A079355             end if;
%p A079355         end do;
%p A079355         if fnd then
%p A079355             procname(n-1)-3 ;
%p A079355         else
%p A079355             procname(n-1)+4 ;
%p A079355         end if;
%p A079355     end if;
%p A079355 end proc:
%p A079355 seq(A079355(n),n=1..100) ; # _R. J. Mathar_, Mar 16 2026
%t A079355 A079355list[nmax_] := Module[{s, a}, s[_] := False; s[1] = True; FoldList[(s[a = # + If[s[#2], -3, 4]] = True; a) &, Range[nmax]]];
%t A079355 A079355list[100] (* or *)
%t A079355 A079355[n_] := n + {19,22, 25, 28, 31, 27, 30, 33, 36, 32, 28, 31, 34, 30, 26, 29, 25, 28, 24, 20, 16, 12, 8, 4, 0, 3, 6, 9, 12, 15, 18, 21, 24, 27, 23, 19, 22, 25, 21, 24, 20, 16}[[Mod[n, 42] + 1]] - 22;
%t A079355 Array[A079355, 100] (* _Paolo Xausa_, Mar 25 2026 *)
