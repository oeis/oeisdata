%N A386774 Expansion of (1/x) * Series_Reversion( x * (1-3*x)^3 / (1+2*x)^4 ).
%H A386774 Robert Israel, <a href="/A386774/b386774.txt">Table of n, a(n) for n = 0..596</a>
%H A386774 <a href="/index/Res#revert">Index entries for reversions of series</a>
%F A386774 a(n) = (1/(n+1)) * Sum_{k=0..n} 2^k * 3^(n-k) * binomial(4*(n+1),k) * binomial(4*n-k+2,n-k).
%F A386774 a(n) = (1/(n+1)) * [x^n] ( (1+2*x)^4 / (1-3*x)^3 )^(n+1).
%F A386774 D-finite with recurrence: (6973030400*n^3 + 31378636800*n^2 + 46632140800*n + 22880256000)*a(n) + (9779650560*n^3 + 36426792960*n^2 + 33279836160*n - 2647142400)*a(n + 1) + (-3299885568*n^3 - 27310556160*n^2 - 74594794752*n - 67228341120)*a(n + 2) + (90384336*n^3 + 965569248*n^2 + 3418228512*n + 4007721240)*a(3 + n) + (-531441*n^3 - 7440174*n^2 - 34661763*n - 53734590)*a(n + 4) = 0. - _Robert Israel_, Mar 12 2026
%p A386774 f:= gfun:-rectoproc({(6973030400*n^3 + 31378636800*n^2 + 46632140800*n + 22880256000)*a(n) + (9779650560*n^3 + 36426792960*n^2 + 33279836160*n - 2647142400)*a(n + 1) + (-3299885568*n^3 - 27310556160*n^2 - 74594794752*n - 67228341120)*a(n + 2) + (90384336*n^3 + 965569248*n^2 + 3418228512*n + 4007721240)*a(3 + n) + (-531441*n^3 - 7440174*n^2 - 34661763*n - 53734590)*a(n + 4), a(0) = 1, a(1) = 17, a(2) = 439, a(3) = 13513},a(n),remember):
%p A386774 map(f, [$0..20]); # _Robert Israel_, Mar 12 2026
%o A386774 (PARI) my(N=20, x='x+O('x^N)); Vec(serreverse(x*(1-3*x)^3/(1+2*x)^4)/x)
