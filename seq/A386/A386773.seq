%N A386773 Expansion of (1/x) * Series_Reversion( x * (1-3*x)^2 / (1+2*x)^3 ).
%H A386773 Robert Israel, <a href="/A386773/b386773.txt">Table of n, a(n) for n = 0..654</a>
%H A386773 <a href="/index/Res#revert">Index entries for reversions of series</a>
%F A386773 a(n) = (1/(n+1)) * Sum_{k=0..n} 2^k * 3^(n-k) * binomial(3*(n+1),k) * binomial(3*n-k+1,n-k).
%F A386773 a(n) = (1/(n+1)) * [x^n] ( (1+2*x)^3 / (1-3*x)^2 )^(n+1).
%F A386773 D-finite with recurrence: (11880*n^2 + 35640*n + 26400)*a(n) + (-14797*n^2 - 48159*n - 40964)*a(n + 1) + (1643*n^2 + 9312*n + 13120)*a(n + 2) + (-36*n^2 - 270*n - 504)*a(3 + n) = 0. - _Robert Israel_, Mar 12 2026
%p A386773 f:= gfun:-rectoproc({(11880*n^2 + 35640*n + 26400)*a(n) + (-14797*n^2 - 48159*n - 40964)*a(n + 1) + (1643*n^2 + 9312*n + 13120)*a(n + 2) + (-36*n^2 - 270*n - 504)*a(3 + n), a(0) = 1, a(1) = 12, a(2) = 219},a(n),remember):
%p A386773 map(f, [$0..30]); # _Robert Israel_, Mar 12 2026
%o A386773 (PARI) my(N=20, x='x+O('x^N)); Vec(serreverse(x*(1-3*x)^2/(1+2*x)^3)/x)
%o A386773 (PARI) a(n) = sum(k=0, n, 2^k*3^(n-k)*binomial(3*(n+1), k)*binomial(3*n-k+1, n-k))/(n+1);
