%I A386973 #74 Mar 16 2026 10:35:19
%S A386973 1,1,2,2,12,3,6,72,60,4,24,480,840,220,5,120,3600,10800,6360,690,6,
%T A386973 720,30240,138600,145320,38220,1974,7,5040,282240,1834560,3010560,
%U A386973 1468320,199248,5320,8,40320,2903040,25401600,60117120,47083680,12365136,944496,13752,9
%N A386973 Triangle read by rows: T(n, k) is the number of connected endofunctions on [n] with k preimageless nodes. (n >= 1, 0 <= k < n).
%C A386973 T(n, 0) = (n-1)! because 0 leaves means all nodes are part of a cycle.
%C A386973 T(n, 1) = n (1 node is chosen to be a leaf) * (n-1)! (the others are cyclically arranged) * (n-1) (the leaf's successor is chosen).
%C A386973 T(n, n-1) = n because all leaves must be mapped onto one chosen fixed point.
%H A386973 Andrei Z. Broder, <a href="https://doi.org/10.1016/0012-365X(84)90161-4">The r-Stirling numbers</a> Discrete Math., vol. 449, iss. 3 (1984), pp. 142-259.
%H A386973 Philippe Flajolet, Peter J. Grabner, Peter Kirschenhofer, and Helmut Prodinger, <a href="https://doi.org/10.1016/0377-0427(93)E0258-N">On Ramanujan's Q-function</a>, Journal of Computational and Applied Math., vol. 58, iss. 1 (1995-03-20), pp. 103-116.
%H A386973 Natalia L. Skirrow, <a href="https://oeis.org/wiki/User:Natalia_L._Skirrow/Euler%27s_tree_function">Euler's tree function</a>
%F A386973 E.g.f.: log(1/(1-T(x*e^((y-1)*x)))), where T(x) = -W(-x) is the e.g.f. of A000169.
%F A386973 D-finite with T(n,k) = n*((n/k-1)*T(n-1,k-1) + T(n-1,k)).
%F A386973 Let Q(n) = Sum_{k=1..n} n!/((n-k)!*n^k) ~ sqrt(Pi*n/2) be Ramanujan's Q function (see A393141/A036505).
%F A386973 T(n,k) = C(n,k)*Sum_{j=1..n-k} (-1)^(n-k-j)*C(n-k,j) * j^(n-1)*Q(j).
%F A386973 T(n,k) = (n!/k!) * Sum_{r=1..n-k} S(r; n-1, n-k) if k>0 else (n-1)!, with S(r; n, k) an r-Stirling number of the second kind.
%F A386973 Sum_{k=0..n-1} T(n,k)   = n^(n-1)*Q(n) = A001865(n).
%F A386973 Sum_{k=0..n-1} T(n,k)*k = n*(n-1)^(n-1)*Q(n-1).
%F A386973 For the m-th binomial moment:
%F A386973 Sum_{k=0..n-1} T(n,k)*C(k,m) = C(n,m)*(n-m)^(n-1)*Q(n-m).
%F A386973 n-th row has expectation ~ n/e and variance ~ n*(1-1/e)/e.
%F A386973 Sum_{k=1..n-1} T(n,k)*k!/n! = A350589(n-1).
%e A386973 Triangle starts:
%e A386973   n\k|   0      1       2       3       4      5    6 7
%e A386973   ---+-------------------------------------------------
%e A386973    1 |   1
%e A386973    2 |   1      2
%e A386973    3 |   2     12       3
%e A386973    4 |   6     72      60       4
%e A386973    5 |  24    480     840     220       5
%e A386973    6 | 120   3600   10800    6360     690      6
%e A386973    7 | 720  30240  138600  145320   38220   1974    7
%e A386973    8 |5040 282240 1834560 3010560 1468320 199248 5320 8
%p A386973 T := (n, k) -> local j; binomial(n, k)*add((-1)^(n-k-j)*j^(n-1)*binomial(n-k, j)*hypergeom([1, 1-j], [], -1/j), j = 1..n-k): seq(print(seq(simplify(T(n, k)), k = 0..n-1)), n = 1..8); # _Peter Luschny_, Mar 08 2026
%p A386973 T := proc(n, k) option remember; if k < 0 or k > n-1 or n < 0 then return 0 fi; if n = 1 then return 1 fi; if k = 0 then return (n-1)*T(n-1, 0) fi; n*((n/k-1)*T(n-1,k-1) + T(n-1,k)) end: seq(print(seq(T(n, k), k = 0..n-1)), n = 1..8); # _Peter Luschny_, Mar 16 2026
%t A386973 l=7; T[x_]:=-LambertW[-x]
%t A386973 CoefficientList[CoefficientList[Normal[Series[Log[1/(1-T[x*E^((u-1)*x)])],{x,0,l}]],x][[2;;]],u]*Range[1,l]! // MatrixForm
%t A386973 (* For individual terms: *)
%t A386973 Q[n_]=Gamma[n,n]*E^n/n^(n-1)
%t A386973 T[n_,k_]=Binomial[n,k]*Sum[(-1)^(n-k-j)*Binomial[n-k,j]*j^(n-1)*Q[j],{j,1,n-k}]
%o A386973 (Python)
%o A386973 from math import comb,factorial as fact,perm
%o A386973 rsubset=lambda r,n,k: sum((-1)**(k-r-i)*comb(k-r,i)*(i+r)**(n-r) for i in range(k-r+1))//fact(k-r)
%o A386973 T=lambda n,k: perm(n,n-k)*sum(rsubset(r,n-1,n-k) for r in range(1,n-k+1)) if k else fact(n-1)
%o A386973 (Python)
%o A386973 from math import comb,factorial as fact,perm
%o A386973 from fractions import Fraction as frac
%o A386973 Q=lambda n: sum(frac(perm(n,k),n**k) for k in range(1,n+1))
%o A386973 T=lambda n,k: comb(n,k)*sum((-1)**(n-k-j)*comb(n-k,j)*j**(n-1)*Q(j) for j in range(1,n-k+1))
%o A386973 (Python)
%o A386973 from math import comb, perm
%o A386973 def T(n: int, k: int) -> int: return comb(n, k) * sum((-1) ** (n - k - j) * comb(n - k, j) * sum(j ** (n - i) * perm(j - 1, i - 1) for i in range(1, j + 1)) for j in range(1, n - k + 1))  # _Peter Luschny_, Mar 08 2026
%Y A386973 Cf. A001865 (row sums), A000169, A350589, A393141/A036505.
%Y A386973 There is also the convention that only nonrecurrent preimages disqualify nodes' leafhood (ie. allowing members of cycles to be leaves). Table of triangles for connected and unrestricted endofunctions by convention:
%Y A386973   predecs | nonrec. |   any
%Y A386973   --------+---------+---------
%Y A386973   connect | A387632 | this seq
%Y A386973   unrest. | A231536 | A219859
%K A386973 nonn,tabl
%O A386973 1,3
%A A386973 _Natalia L. Skirrow_, Mar 08 2026
