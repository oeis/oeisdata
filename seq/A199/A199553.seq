%U A199553 175921860444161,1407374883553281,11258999068426241,90071992547409921,720575940379279361,5764607523034234881,46116860184273879041
%N A199553 a(n) = 5*8^n+1.
%H A199553 Vincenzo Librandi, <a href="/A199553/b199553.txt">Table of n, a(n) for n = 0..1000</a>
%H A199553 <a href="/index/Rec#order_02">Index entries for linear recurrences with constant coefficients</a>, signature (9,-8).
%F A199553 a(n) = 8*a(n-1)-7.
%F A199553 a(n) = 9*a(n-1)-8*a(n-2).
%F A199553 G.f.: (6-13*x)/((1-x)*(1-8*x)).
%F A199553 E.g.f.: exp(x) + 5*exp(8*x). - _Stefano Spezia_, Jul 15 2026
%t A199553 5*8^Range[0, 25] + 1 (* _Paolo Xausa_, Jul 15 2026 *)
%o A199553 (Magma) [5*8^n+1: n in [0..30]];
