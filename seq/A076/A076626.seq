%T A076626 -6,0,38,0,-64,0,32,1,0,-25,0,104,0,-144,0,64,0,8,0,-88,0,272,0,-320,
%U A076626 0,128,-1,0,41,0,-280,0,688,0,-704,0,256,0,-10,0,170,0,-832,0,1696,0,-1536,0,512,1,0,-61,0,620,0,-2352,0,4096,0,-3328,0,1024
%N A076626 Array of coefficients of polynomials p(n,x) = 2^(n-1)*Product_{i=0..n} (x - cos(i*Pi/n)) of degree (n+1) with P(-1,x) = 1, P(0,x) = 0.
%C A076626 Mirror image of triangle in A201863. - _Philippe Deléham_, Dec 07 2011
%C A076626 From _Natalia L. Skirrow_, Mar 16 2026: (Start)
%C A076626 Up to the 2^(n-1) factor, for n>=1 the n-th row o.g.f. is the characteristic polynomial of the adjacency matrix of the (n+1)-path graph [0..n], with edges outgoing from the end nodes weighted 1 and others weighted 1/2.
%C A076626 For each eigenvalue cos(Pi*i/n), the eigenvector has amplitude cos(Pi*k*i/n)*2^[0<k<n] on the k-th node.
%C A076626 For the n-path with all weights 1/2 the analogous polynomials are Chebyshev's U(n,x) (A053117), and with weight 1 on a single end, Chebyshev's T(n,x) (A053120).
%C A076626 (End)
%F A076626 For n >= 2, T(n,k) = 2*T(n-1,k-1) - T(n-2,k). - _Philippe Deléham_, Dec 07 2011
%F A076626 From _Natalia L. Skirrow_, Mar 16 2026: (Start)
%F A076626 O.g.f.: (1-x*y)^2/(1-2*y*x+x^2)
%F A076626 For n >= 1, sgn(T(n,k)) = cos((n+1-k)*Pi/2).
%F A076626 Let m = (n-1+k)/2.
%F A076626 For n >= 2, abs(T(n,k))/2^(k-2) = 4*C(m,k) + C(m-1,k-2).
%F A076626 For n >= 1, T(n,k) = A053117(n-1,k-2) - A053117(n-1,k).
%F A076626 (End)
%e A076626 p(4,x) = 8*x^5 - 12*x^3 + 4*x hence 0,4,0,-12,0,8 are terms in the sequence.
%e A076626 From _Philippe Deléham_, Dec 07 2011: (Start)
%e A076626 Triangle begins:
%e A076626 n\k| 0  1   2   3   4   5    6   7   8
%e A076626 ---+----------------------------------
%e A076626 -1 | 1
%e A076626  0 | 0  0
%e A076626  1 |-1  0   1
%e A076626  2 | 0 -2   0   2
%e A076626  3 | 1  0  -5   0   4
%e A076626  4 | 0  4   0 -12   0   8
%e A076626  5 |-1  0  13   0 -28   0   16
%e A076626  6 | 0 -6   0  38   0 -64    0  32
%e A076626  7 | 1  0 -25   0 104   0 -144   0  64
%e A076626 (End)
%t A076626 CoefficientList[CoefficientList[Normal[Series[(1-x*y)^2/(1-2*y*x+x^2),{x,0,8}]],x],y]//MatrixForm (* _Natalia L. Skirrow_, Mar 16 2026 *)
%o A076626 (Python)
%o A076626 from math import comb
%o A076626 A076626=lambda n,k: (0,-1,0,1)[n-k&3]*(n&~k&1 if n<2 else 4*comb(m:=n-1+k>>1,k)+comb(m-1,k-2)<<k>>2) # _Natalia L. Skirrow_, Mar 16 2026
