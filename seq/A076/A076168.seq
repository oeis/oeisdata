%I A076168 #15 Mar 18 2026 09:57:43
%S A076168 11,1487,4871,7841,15413,20231,22453,23201,25423,28657,29867,41351,
%T A076168 43597,44453,45377,45553,47513,48017,48479,49537,49801,51473,53891,
%U A076168 57413,65287,67421,80491,83591,86297,87041,89797,102023,104089,105389
%N A076168 Primes p such that sum of squares of even-position digits equals the sum of squares of odd-position digits of p.
%C A076168 There are 266 such primes < 10^6, the largest being 994871 -> 9^2+4^2+7^2 = 9^2+8^2+1^2 = 146.
%H A076168 Robert Israel, <a href="/A076168/b076168.txt">Table of n, a(n) for n = 1..10000</a>
%e A076168 1487 is in the sequence because 1^2+8^2 = 4^2+7^4 = 65.
%p A076168 filter:= proc(n) local L,i;
%p A076168   L:= convert(n,base,10);
%p A076168   add(L[i]^2*(-1)^i, i=1..nops(L)) = 0 and isprime(n)
%p A076168 end proc:
%p A076168 select(filter, [seq(i,i=3..2*10^5,2)]); # _Robert Israel_, Mar 18 2026
%Y A076168 Cf. A257588. Subsequence of A352535.
%K A076168 nonn,base
%O A076168 1,1
%A A076168 _Zak Seidov_, Nov 01 2002
