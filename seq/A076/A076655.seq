%N A076655 a(n) = numerator(b(n)) where b(1)=1, b(2)=2 and for n > 2, b(n) = 1/b(n-2) - 1/b(n-1).
%F A076655 b(n) -> -(-1)^n * sqrt(2).
%e A076655 b(3) = 1/b(1) - 1/b(2) = 1 - 1/2 = 1/2, therefore a(3) = 1.
%o A076655 (PARI) b(n) = if (n<=2, n, 1/b(n-2) - 1/b(n-1));
%o A076655 a(n) = numerator(b(n)); \\ _Michel Marcus_, Mar 04 2026
