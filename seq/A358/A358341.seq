%S A358341 0,1,3,7,31,96,314,1072,3693,12556,41800,136236,435923,1374088,
%T A358341 4280358,13211704,40492633,123440724,374774660,1134346228,3425446335,
%U A358341 10326139696,31088511778,93507747360,281053811141,844319049436,2535473717184,7611873731452,22847398782763,68567563479576
%N A358341 Expansion of e.g.f. (exp(x)-1)*(exp(x)-x)*(exp(x)-x^2/2).
%C A358341 a(n) is the number of ordered set partitions of an n-set into 3 sets such that the first set is not empty, the second set cannot have a single element, and the third set cannot have two elements.
%H A358341 <a href="/index/Rec#order_08">Index entries for linear recurrences with constant coefficients</a>, signature (13,-72,222,-417,489,-350,140,-24).
%F A358341 a(n) = 3^n - 2^n - n*(2^(n-1)-1) - binomial(n,2)*(2^(n-2)-1) +  3*binomial(n,3) except at n=3.
%F A358341 From _Elmo R. Oliveira_, Jul 22 2026: (Start)
%F A358341 G.f.: x*(1 - 10*x + 40*x^2 - 66*x^3 - 52*x^4 + 506*x^5 - 1178*x^6 + 1467*x^7 - 1050*x^8 + 420*x^9 - 72*x^10) / ((1 - x)^4*(1 - 2*x)^3*(1 - 3*x)).
%F A358341 a(n) = 13*a(n-1) - 72*a(n-2) + 222*a(n-3) - 417*a(n-4) + 489*a(n-5) - 350*a(n-6) + 140*a(n-7) - 24*a(n-8). (End)
%e A358341 The 31 set partitions for n=4 are the following:
%e A358341   {1,2,3,4}, { }, { } (1 of these);
%e A358341   {1,2,3}, { }, {4};  (4 of these);
%e A358341   {1,2}, {3,4}, { };  (6 of these);
%e A358341   {1}, {2,3,4}, { };  (4 of these);
%e A358341   {1}, {2,3}, {4};   (12 of these);
%e A358341   {1}, { }, {2,3,4};  (4 of these).
%Y A358341 Cf. A360586.
