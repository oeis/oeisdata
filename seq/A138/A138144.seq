%I A138144 #18 Jul 19 2026 09:43:05
%S A138144 1,11,111,1111,11011,110011,1100011,11000011,110000011,1100000011,
%T A138144 11000000011,110000000011,1100000000011,11000000000011,
%U A138144 110000000000011,1100000000000011,11000000000000011,110000000000000011,1100000000000000011,11000000000000000011,110000000000000000011
%N A138144 Palindromes formed from the reflected decimal expansion of the concatenation of 1, 1 and infinite 0's.
%C A138144 a(n) is also A147595(n) written in base 2. - _Omar E. Pol_, Nov 08 2008
%H A138144 <a href="/index/Rec#order_02">Index entries for linear recurrences with constant coefficients</a>, signature (11,-10).
%F A138144 From _Colin Barker_, Sep 15 2013: (Start)
%F A138144 a(n) = 11 + 11*10^(n-2) for n > 3.
%F A138144 a(n) = 11*a(n-1) - 10*a(n-2) for n > 5.
%F A138144 G.f.: -x*(10*x^2-1)*(10*x^2+1) / ((x-1)*(10*x-1)). (End)
%F A138144 E.g.f.: (1/300)*(exp(x)*(33*exp(9*x) + 3300) - (3333 + 3330*x + 1650*x^2 + 500*x^3)). - _Elmo R. Oliveira_, Jul 17 2026
%e A138144 n .... a(n)
%e A138144 1 .... 1
%e A138144 2 .... 11
%e A138144 3 .... 111
%e A138144 4 .... 1111
%e A138144 5 .... 11011
%e A138144 6 .... 110011
%e A138144 7 .... 1100011
%e A138144 8 .... 11000011
%e A138144 9 .... 110000011
%e A138144 10 ... 1100000011
%t A138144 LinearRecurrence[{11,-10},{1,11,111,1111,11011},20] (* _Harvey P. Dale_, Aug 21 2016 *)
%o A138144 (PARI) Vec(-x*(10*x^2-1)*(10*x^2+1)/((x-1)*(10*x-1)) + O(x^100)) \\ _Colin Barker_, Sep 15 2013
