%U A354762 6,28,28,1,28,1,1,28,3,28,3,1,28,3,1,1,28,6,28,6,1
%N A354762 Irregular triangle read by rows in which the row n lists the partition of n into the minimum number of triangular parts.
%C A354762 The representation of the partitions (for fixed n) is as (weakly) decreasing list of the parts.
%e A354762 The irregular triangle begins:
%e A354762      0;
%e A354762      1;
%e A354762      1, 1;
%e A354762      3;
%e A354762      3, 1;
%e A354762      3, 1, 1;
%e A354762      6;
%e A354762      6, 1;
%e A354762      6, 1, 1;
%e A354762      6, 3;
%e A354762     10;
%e A354762     10, 1;
%e A354762     10, 1, 1;
%e A354762     10, 3;
%e A354762     10, 3, 1;
%e A354762     15;
%e A354762     15, 1;
%e A354762     15, 1, 1;
%e A354762     15, 3;
%e A354762     15, 3, 1;
%e A354762     15, 3, 1, 1;
%e A354762     ...
%t A354762 nmax=35; With[{triangulars = Table[k(k+1)/2,{k,(Sqrt[1+8*nmax]-1)/2}]}, Flatten[Join[{0},Flatten[Table[First[IntegerPartitions[n, All, triangulars, 1]], {n, nmax}]]]]] (* improved by _Stefano Spezia_, May 10 2026 *)
