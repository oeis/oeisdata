%I A354794 #94 May 11 2026 09:23:12
%S A354794 1,0,1,0,1,1,0,4,3,1,0,27,19,6,1,0,256,175,55,10,1,0,3125,2101,660,
%T A354794 125,15,1,0,46656,31031,9751,1890,245,21,1,0,823543,543607,170898,
%U A354794 33621,4550,434,28,1,0,16777216,11012415,3463615,688506,95781,9702,714,36,1
%N A354794 Triangle read by rows. The Bell transform of the sequence {m^m | m >= 0}.
%C A354794 For the definition of the Bell transform see A264428. The Bell transform of {(-m)^m | m >= 0} is A039621. The numbers A039621(n, k) are known as the Lehmer-Comtet numbers of 2nd kind. We think it is more natural to use Bell_{n, k}({m^m}) as the basis for the definition (and let the triangle start at (0, 0)).
%C A354794 T(n+1, k) is the number of partitions of 2*n-k labeled balls into a set of n subsets, by allocating the first n-k into their own subsets, then distributing the n remaining balls such that the n-k remaining subsets are nonempty. - _Natalia L. Skirrow_, Jan 03 2026
%D A354794 Louis Comtet, Advanced Combinatorics. Reidel, Dordrecht, 1974, p. 139-140.
%H A354794 Andrei Z. Broder, <a href="https://doi.org/10.1016/0012-365X(84)90161-4">The r-Stirling numbers</a>, Discrete Mathematics vol. 49 iss. 3 pp. 241-259, 1984.
%H A354794 D. H. Lehmer, <a href="https://doi.org/10.1216/RMJ-1985-15-2-461">Numbers Associated with Stirling Numbers and x^x</a>, Rocky Mountain J. Math., 15(2) 1985, pp. 461-475.
%H A354794 Peter Luschny, <a href="https://oeis.org/wiki/User:Peter_Luschny/BellTransform">The Bell transform</a>.
%H A354794 Peter Luschny, <a href="https://github.com/PeterLuschny/Gists/blob/main/BellTransformation.ipynb">Examples of the Bell transform, a SageMath notebook</a>.
%H A354794 Math StackExchange, <a href="https://math.stackexchange.com/q/5088310">Is there a way to simplify this closed form for Stirling numbers of the second kind?</a>, 2025.
%H A354794 Wikipedia, <a href="https://en.wikipedia.org/wiki/Bell_polynomials">Bell polynomials</a>.
%F A354794 T(n, k) = Bell_{n, k}(A000312), where Bell_{n, k} is the partial Bell polynomial evaluated over the powers m^m (with 0^0 = 1). See the Mathematica program.
%F A354794 T(n, k) = Sum_{j=0..k-1} (-1)^j*(n-j-1)^(n - 1)/(j! * (k-1-j)!) for 0 <= k < n and T(n, n) = 1.
%F A354794 T(n, k) = r(k-1, n-k, n-k) for n,k >= 1 and T(0, 0) = 1, where r(n, k, m) = m*r(n, k-1, m) + r(n-1, k, m+1) and r(n, 0, m) = 1. (see _Vladimir Kruchinin_'s formula in A039621).
%F A354794 Sum_{k=1..n} binomial(k + x - 1, k-1)*(k-1)!*T(n, k) = (n + x)^(n - 1) for n >= 1.
%F A354794 Sum_{k=1..n} (-1)^(k + j)*Stirling1(k, j)*T(n, k) = n^(n-j)*binomial(n-1, j-1) for n >= 1, which are, up to sign, the coefficients of the Abel polynomials (A137452).
%F A354794 From _Werner Schulte_, Jun 14 2022 and Jun 19 2022: (Start)
%F A354794 E.g.f. of column k >= 0: (Sum_{i>0} (i-1)^(i-1) * t^i / i!)^k / k!.
%F A354794 Conjecture: T(n, k) = Sum_{i=0..n-k} A048994(n-k, i) * A048993(n+i-1, n-1) for 0 < k <= n and T(n, 0) = 0^n for n >= 0; proved by Mike Earnest, see link at A354797. (End)
%F A354794 From _Natalia L. Skirrow_, Jan 03 2026: (Start)
%F A354794 As an r-subset number, T(n+1, k) = Stirling2(n-k; 2*n-k, n).
%F A354794 Sum_{i=0..m} Stirling2(n+i, k+m)*Stirling1(m, i) = Sum_{j=0..n-k} C(n-m-k, j) * C(k+j, j) * j! * T(n+1, k+j) * (-1)^j.
%F A354794 Special case: Stirling2(n, k) = Sum_{j=0..n-k} C(n-k, j)*C(k+j, j)*j!*T(n+1, k+j)*(-1)^j. (End)
%F A354794 Conjectures from _Mikhail Kurkov_, Apr 20 2026: (Start)
%F A354794 T(n, k) = k * T(n, k+1) + T(n-1, k-1) + (n-k-1) * T(n-1, k) with T(n, 0) = 0^n, T(n, k) = 0 for k < 0 or k > n.
%F A354794 T(n, k) = Sum_{j=0..n-k} binomial(n+j-1, k-1) * A075856(n-k, j).
%F A354794 T(n+1, k+1) = Sum_{j=k..n} T(n, j) * A291978(j, k). (End)
%F A354794 From _Peter Luschny_, May 08 2026: (Start)
%F A354794 T(n, k) = (n!/k!) * [z^n] (1 - exp(-T(z)))^k where T(z) is the Cayley tree EGF (A000169).
%F A354794 The row polynomials P(n, x) are given by Sum_{n>=0} P(n, x) * z^n/n! = exp(x*(1 - exp(W(-z)))) where W denotes Lambert's W function.
%F A354794 P(n + 1, x) = x * Sum_{k=0..n} binomial(n, k) * k^k * P(n - k, x) = x * Sum_{k=0..n} A395701(n, k) * P(n - k, x) is a recurrence for the row polynomials starting with P(0, x) = 1. From this recurrence the recurrence of the coefficients given above by _Mikhail Kurkov_ can be derived. (End)
%F A354794 From _Peter Luschny_, May 10 2026: (Start)
%F A354794 The rows of the array T(n + k, k) are given by linear recurrences with recurrence coefficients RCrow(n) = [(-1)^(j + 1)*binomial(2*n + 1, j), j = 1..2*n+1].
%F A354794 (Sum_{k=0..n} A395929(n, k) * x^k) / (1 - x)^(2*n + 1) is the generating function of the n-th row of the array A. (See A395908 for the case n = 3.) (End)
%e A354794 Triangle T(n, k) begins:
%e A354794   [0] 1;
%e A354794   [1] 0,        1;
%e A354794   [2] 0,        1,        1;
%e A354794   [3] 0,        4,        3,       1;
%e A354794   [4] 0,       27,       19,       6,      1;
%e A354794   [5] 0,      256,      175,      55,     10,     1;
%e A354794   [6] 0,     3125,     2101,     660,    125,    15,    1;
%e A354794   [7] 0,    46656,    31031,    9751,   1890,   245,   21,   1;
%e A354794   [8] 0,   823543,   543607,  170898,  33621,  4550,  434,  28,  1;
%e A354794   [9] 0, 16777216, 11012415, 3463615, 688506, 95781, 9702, 714, 36, 1;
%e A354794 .
%e A354794 Seen as an array A(n, k) = T(n + k, k):
%e A354794   [0]  1,     1,      1,       1,        1,        1, ... A000012
%e A354794   [1]  0,     1,      3,       6,       10,       15, ... A000217
%e A354794   [2]  0,     4,     19,      55,      125,      245, ... A215862
%e A354794   [3]  0,    27,    175,     660,     1890,     4550, ... A395908
%e A354794   [4]  0,   256,   2101,    9751,    33621,    95781, ...
%e A354794   [5]  0,  3125,  31031,  170898,   688506,  2263065, ...
%e A354794   [6]  0, 46656, 543607, 3463615, 15958405, 59411605, ...
%e A354794         A000312,A045531, A281596,  A281595
%p A354794 T := (n, k) -> if n = k then 1 else
%p A354794 add((-1)^j*(n-j-1)^(n-1)/(j!*(k-1-j)!), j = 0.. k-1) fi:
%p A354794 seq(seq(T(n, k), k = 0..n), n = 0..9);
%p A354794 # Alternative: using the function BellMatrix from A264428:
%p A354794 BellMatrix(n -> n^n, 9);
%p A354794 # Alternative:
%p A354794 R := proc(n, k, m) option remember;
%p A354794    if k < 0 or n < 0 then 0 elif k = 0 then 1 else
%p A354794    m*R(n, k-1, m) + R(n-1, k, m+1) fi end:
%p A354794 A039621 := (n, k) -> ifelse(n = 0, 1, R(k-1, n-k, n-k)):
%p A354794 # Alternative: using the EGF.
%p A354794 N := 9: x := 'x': z := 'z': T := series(-LambertW(-z), z, N + 1):
%p A354794 F := exp(x*(1 - exp(-T))): EGF := series(F, z, N+1):
%p A354794 A354794row := n -> local k; seq(coeff(simplify(coeff(EGF, z, n) * n!), x, k), k = 0..n):
%p A354794 seq(A354794row(n), n = 0..N);  # _Peter Luschny_, May 08 2026
%t A354794 Unprotect[Power]; Power[0, 0] = 1; pow[n_] := n^n;
%t A354794 R = Range[0, 9]; T[n_, k_] := BellY[n, k, pow[R]];
%t A354794 Table[T[n, k], {n, R}, {k, 0, n}] // Flatten
%o A354794 (Python)
%o A354794 from functools import cache
%o A354794 @cache
%o A354794 def t(n, k, m):
%o A354794     if k < 0 or n < 0: return 0
%o A354794     if k == 0: return n ** k
%o A354794     return m * t(n, k - 1, m) + t(n - 1, k, m + 1)
%o A354794 def A354794(n, k): return t(k - 1, n - k, n - k) if n != k else 1
%o A354794 for n in range(9): print([A354794(n, k) for k in range(n + 1)])
%o A354794 (Python)
%o A354794 from math import factorial
%o A354794 def ArrayRow(n: int, size: int) -> list[int]:
%o A354794     if size <= 0: return []
%o A354794     row = [1 if n == 0 else 0]
%o A354794     for k in range(1, size):
%o A354794         total = 0; comb = 1
%o A354794         for j in range(k):
%o A354794             term = comb * pow(n + k - j - 1, n + k - 1)
%o A354794             total += term if j % 2 == 0 else -term
%o A354794             comb = comb * (k - 1 - j) // (j + 1)
%o A354794         row.append(total // factorial(k - 1))
%o A354794     return row
%o A354794 for n in range(8): print([n], ArrayRow(n, 9))  # _Peter Luschny_, May 10 2026
%o A354794 (PARI)  \\ using function bell_matrix from A264428
%o A354794 bell_matrix(n -> n^n, 9) \\ _Peter Luschny_, May 07 2026
%o A354794 (PARI) inverse_bell_matrix_row(n,f) = { my(A, v1 = vector(n-1, i, f(i)), v2 = vector(n, i, 0)); v2[1] = 1; for(i=2, n, A = 1; v2[i] = sum(j=1, i-1, A *= -(i-n-j)/j; ((1-n)*A - (i-n)*A/(j+1)) * v2[i-j] * v1[j]) / (i-1)); Vecrev(v2) }
%o A354794 row(n) = if(n==0, [1], concat(0, inverse_bell_matrix_row(n,x->-(x-1)!))) \\ _Mikhail Kurkov_, May 08 2026
%o A354794 (PARI) bell_matrix_column(n, k, f) = { my(A, v1 = vector(n-1, i, f(i)), v2 = vector(n, i, 0)); v2[1] = 1; for(i=2, n, A = 1; v2[i] = sum(j=1, i-1, A *= (i+k-j)/j; ((k+1)*A - (i+k)*A/(j+1)) * v2[i-j] * v1[j]) / (i-1)); v2 } \\ computes first n elements of the k-th column starting from the first nonzero element (equals 1)
%o A354794 column(n,k) = bell_matrix_column(n, k, x->x^x) \\ _Mikhail Kurkov_, May 09 2026
%o A354794 (SageMath)
%o A354794 def A354794triangle(size: int) -> list[list[int]]:
%o A354794     R.<x> = PolynomialRing(ZZ)
%o A354794     mm = [1] + [m^m for m in range(1, size+1)]
%o A354794     P = [R(1)]
%o A354794     for n in range(size):
%o A354794         Qrow = [0]*(n + 1)  # A395701
%o A354794         binom = 1
%o A354794         for m in range(n+1):
%o A354794             if m > 0: binom = binom * (n - m + 1) // m
%o A354794             Qrow[m] = binom * mm[m]
%o A354794         P.append(x * sum(Qrow[m] * P[n-m] for m in range(n+1)))
%o A354794     return [p.list() for p in P]
%o A354794 for row in A354794triangle(9): print(row)  # _Peter Luschny_, May 08 2026
