%T A374626 5381559,16144947,48434841,145304523,435914388,1307743164,3923229492,
%U A374626 11769690933,35309072799,105927218397,317781662562,953344987686,2860034963058,8580104911317
%N A374626 Expansion of Product_{k>=0} 1 / (1 - 3*x^(3^k)).
%F A374626 G.f. A(x) satisfies A(x) = A(x^3)/(1 - 3*x).
%F A374626 a(n) is divisible by 3 for n > 0.
%F A374626 From _Seiichi Manyama_, Jul 18 2026: (Start)
%F A374626 G.f.: 1 + 3 * Sum_{j>=0} x^(3^j) / Product_{k=0..j} (1 - 3*x^(3^k)).
%F A374626 a(0) = 1; for n >= 1, a(n) = 3*a(n-1) + a(n/3) if 3|n, and a(n) = 3*a(n-1) otherwise.
%F A374626 a(n) = Sum_{k=0..floor(n/3)} 3^(n-3*k) * a(k) for n >= 1. (End)
%o A374626 (PARI) my(N=30, x='x+O('x^N)); Vec(1/prod(k=0, logint(N,3), 1-3*x^3^k))
%Y A374626 For generating functions Product_{k>=0} 1 / (1 - a*x^(b^k)) for the following values of (a,b) see: (1,2) A018819, (1,3) A062051, (2,2) A309728.
%Y A374626 Cf. A117940.
%K A374626 nonn,changed
%O A374626 0,2
%A A374626 _Seiichi Manyama_, Jul 14 2024
