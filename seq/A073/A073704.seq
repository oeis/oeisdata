%I A073704 #8 Jul 03 2026 01:32:04
%S A073704 7,11,13,17,29,29,37,41,53,61,67,79,89,89,97,109,131,127,137,149,149,
%T A073704 163,173,181,197,233,211,227,223,229,257,269,277,281,311,307,317,331,
%U A073704 337,349,389,367,389,389,397,401,433,449,457,461,479,491,487,509,521,557,541,547,557,569,569,593,617
%N A073704 Smallest prime p such that also p-prime(n)*2 is a prime.
%H A073704 Robert Israel, <a href="/A073704/b073704.txt">Table of n, a(n) for n = 1..10000</a>
%p A073704 f:= proc(n) local p,r;
%p A073704   r:= ithprime(n)*2;
%p A073704   p:= prevprime(r);
%p A073704   do
%p A073704     p:= nextprime(p)
%p A073704   until isprime(p-r);
%p A073704   p
%p A073704 end proc:
%p A073704 map(f, [$1..100]); # _Robert Israel_, Jul 02 2026
%Y A073704 Cf. A073703, A001747, A000040, A020484.
%K A073704 nonn
%O A073704 1,1
%A A073704 _Reinhard Zumkeller_, Aug 04 2002
