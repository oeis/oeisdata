%T A387923 9,1,4,4,1,1,1,1,27,1,1,1,16,1,1,36,1,1,4,4,8,1,9,9,4,1,1,27,1,1,1,1,
%U A387923 4,1,1,32,1,1,36,36,1,1,8,8,25,1,4,1,1,1,1
%N A387923 Greatest common divisor of consecutive powerful numbers.
%H A387923 Michael De Vlieger, <a href="/A387923/b387923.txt">Table of n, a(n) for n = 1..10000</a>
%H A387923 Michael De Vlieger, <a href="/A387923/a387923.png">Log log scatterplot of a(n)</a>, n = 1..2^20.
%H A387923 <a href="/index/Pow#powerful">Index entries for sequences related to powerful numbers</a>.
%F A387923 a(n) = gcd(A001694(n), A001694(n+1)).
%t A387923 nn = 3000; s = Union@ Flatten@ Table[a^2*b^3, {b, Surd[nn, 3]}, {a, Sqrt[nn/b^3] } ]; MapApply[GCD, Partition[s, 2, 1] ]
%o A387923 (Python)
%o A387923 from math import isqrt, gcd
%o A387923 from sympy import integer_nthroot
%o A387923 from oeis_sequences.OEISsequences import bisection, squarefreepi
%o A387923 def A387923(n):
%o A387923     def f(x):
%o A387923         c, l = n+x, 0
%o A387923         j = isqrt(x)
%o A387923         while j>1:
%o A387923             k2 = integer_nthroot(x//j**2,3)[0]+1
%o A387923             w = squarefreepi(k2-1)
%o A387923             c -= j*(w-l)
%o A387923             l, j = w, isqrt(x//k2**3)
%o A387923         c -= squarefreepi(integer_nthroot(x,3)[0])-l
%o A387923         return c
%o A387923     return gcd(m:=bisection(f,n,n),bisection(lambda x:f(x)+1,m,m)) # _Chai Wah Wu_, Mar 12 2026
%Y A387923 Cf. A001694.
%K A387923 nonn,easy,new
%O A387923 1,2
%A A387923 _Michael De Vlieger_, Mar 04 2026
