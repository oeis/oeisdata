%S A387632 1,2,1,6,9,2,24,72,40,6,120,600,620,205,24,720,5400,9000,5100,1236,
%T A387632 120,5040,52920,130200,113400,44142,8659,720,40320,564480,1928640,
%U A387632 2410800,1371216,415520,69280,5040,362880,6531840,29635200,50591520,39859344,16941456,4283064,623529,40320
%N A387632 Triangle read by rows: T(n,k) is the number of connected endofunctions on [n] in which k nodes have no nonrecurrent preimages, n >= 1, 1 <= k <= n.
%C A387632 T(n,1) = n! counts endofunctions whose digraph representation is a single fixed point with a tail of preimages.
%C A387632 T(n,n) = (n-1)! counts endofunctions comprised of a single cycle.
%H A387632 Philippe Flajolet, Peter J. Grabner, Peter Kirschenhofer, and Helmut Prodinger, <a href="https://doi.org/10.1016/0377-0427(93)E0258-N">On Ramanujan's Q-function</a>, Journal of Computational and Applied Math., vol. 58, iss. 1 (1995-03-20), pp. 103-116.
%H A387632 Natalia L. Skirrow, <a href="https://oeis.org/wiki/User:Natalia_L._Skirrow/Euler%27s_tree_function">Euler's tree function</a>
%F A387632 E.g.f.: log( 1/(1-( (u-1)*x + T(x*E^((u-1)*x)) )) ), where T(x) = -W(-x) is the e.g.f. of A000169.
%F A387632 Let Q(n) = Sum_{k=1..n} n! / ((n-k)!*n^k) = Gamma(n,n) * e^n/n^(n-1) ~ sqrt(Pi*n/2) be Ramanujan's Q function.
%F A387632 T(n,k) = C(n,k) * Sum_{r=0..n-k} (-1)^(n-k-r) * C(n-k,r) * Sum_{j=0..n-1} r^j * (n-1)!/j!.
%F A387632 T(n,k) = (n!/k!) * Sum_{j=n-k..n-1} Stirling2(j,n-k) * (n-1)!/j!.
%F A387632 Sum_{k=1..n} T(n,k) = n^(n-1) * Q(n) = A001865(n).
%F A387632 Sum_{k=1..n} T(n,k)*k = n * (n-1)^(n-1) * (Q(n-1)+1) = n * A063170(n-1).
%F A387632 m-th binomial moment:
%F A387632 Sum_{k=1..n} T(n,k) * C(k,m) = C(n,m) * Gamma(n,n-m) * e^(n-m) = C(n,m) * (n-m)^(n-1) * hypergeometric([1-n,1],[],1/(m-n)).
%F A387632 n-th row has expectation ~ n/e and variance ~ n*(1-1/e)/e.
%F A387632 These are asymptotically the same as A386973, since only Theta(sqrt(n)) nodes are in the cycle.
%e A387632 n\k|   1     2      3      4     5    6   7
%e A387632 ---+---------------------------------------
%e A387632  1 |   1     .      .      .     .    .   .
%e A387632  2 |   2     1      .      .     .    .   .
%e A387632  3 |   6     9      2      .     .    .   .
%e A387632  4 |  24    72     40      6     .    .   .
%e A387632  5 | 120   600    620    205    24    .   .
%e A387632  6 | 720  5400   9000   5100  1236  120   .
%e A387632  7 |5040 52920 130200 113400 44142 8659 720
%t A387632 T[x_]=-LambertW[-x]
%t A387632 l=7
%t A387632 CoefficientList[CoefficientList[Normal[Series[Log[1/(1-((u-1)*x-LambertW[-x*E^((u-1)*x)]))],{x,0,l}]],x][[2;;]]/u,u]*Range[1,l]! // MatrixForm
%o A387632 (Python)
%o A387632 from math import factorial as fact
%o A387632 from sympy.functions.combinatorial.numbers import stirling
%o A387632 T=lambda n,k: fact(n)//fact(k)*sum(fact(n-1)//fact(j)*stirling(j,n-k,2) for j in range(n-k,n))
%o A387632 (Python)
%o A387632 from math import comb,factorial as fact
%o A387632 T=lambda n,k: comb(n,k)*sum((-1)**(n-k-r)*comb(n-k,r)*sum(fact(n-1)//fact(j)*r**j for j in range(n)) for r in range(n-k+1))
%Y A387632 Cf. A001865 (row sums).
%Y A387632 Here we stipulate nonrecurrent preimages prevent leafhood; another convention loosens this to any preimages.
%Y A387632 Table of triangles for connected and unrestricted endofunctions by convention:
%Y A387632   predecs|  any  |nonrec.
%Y A387632   -------+-------+-------
%Y A387632   connect|A386973|this seq.
%Y A387632   unrest.|A219859|A231536
%K A387632 nonn,tabl
%O A387632 1,2
