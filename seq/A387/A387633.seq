%I A387633 #42 Apr 20 2026 22:55:57
%S A387633 1,4,6,9,10,24,14,18,19,40,22,50,26,56,60,35,34,74,38,82,84,88,46,100,
%T A387633 51,104,56,114,58,240,62,68,132,136,140,149,74,152,156,164,82,336,86,
%U A387633 178,182,184,94,198,99,202,204,210,106,220,220,228,228,232,118,484,122,248,254,133,260,528,134,274,276,560,142
%N A387633 a(n) = tau(n) + (n-1) * tau(rad(n)).
%C A387633 For each divisor d of n, add n if gcd(d,n/d) = 1, else add 1.
%F A387633 a(n) = Sum_{d|n} n^[gcd(d,n/d) = 1], where [ ] is the Iverson bracket.
%e A387633 a(24) = 24^1 + 24^0 + 24^1 + 24^0 + 24^0 + 24^1 + 24^0 + 24^1 = 100.
%t A387633 Table[DivisorSigma[0, n] + (n - 1) DivisorSigma[0, Product[d^(PrimePi[d] - PrimePi[d - 1]), {d, Divisors[n]}]], {n, 100}]
%t A387633 (* Alternative: *)
%t A387633 Table[Sum[n^KroneckerDelta[GCD[d, n/d], 1], {d, Divisors[n]}], {n, 100}]
%Y A387633 Cf. A000005 (tau), A007947 (rad), A034444, A394481.
%K A387633 nonn,easy,new
%O A387633 1,2
%A A387633 _Wesley Ivan Hurt_, Apr 20 2026
