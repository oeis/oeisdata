%I A307579 #29 May 22 2026 01:05:00
%S A307579 9,18,25,27,45,49,50,54,63,75,81,90,98,99,100,108,117,121,125,126,135,
%T A307579 147,150,153,162,169,171,175,189,196,198,207,225,234,242,243,245,250,
%U A307579 261,270,275,279,289,294,297,300,306,315,324,325,333,338,342,343,350,351,361,363
%N A307579 Numbers k such that A003958(k) does not divide phi(k).
%H A307579 Robert Israel, <a href="/A307579/b307579.txt">Table of n, a(n) for n = 1..10000</a>
%e A307579 For n = 1 the a(1) = 9 because A003958(9) = 4 does not divide A000010(9) = 6.
%p A307579 filter:= proc(k) local F,i,s,t;
%p A307579   F:= ifactors(k)[2];
%p A307579   s:= `*`(k, seq(1-1/F[i,1],i=1..nops(F)));
%p A307579   t:= `*`(seq((F[i,1]-1)^F[i,2],i=1..nops(F)));
%p A307579   s mod t <> 0
%p A307579 end proc:
%p A307579 select(filter, [$1..1000]); # _Robert Israel_, May 21 2026
%t A307579 Select[Range[2, 363], Mod[EulerPhi@ #, Times @@ Map[# /. {p_, e_} :> (p - 1)^e &, FactorInteger[#]]] != 0 &] (* _Michael De Vlieger_, Apr 21 2019 *)
