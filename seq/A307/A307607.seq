%T A307607 362,3562,1382,1578,530,13082,1276,2202,3088,6946,842,12822,962,18725,
%U A307607 3398,3762,3750,37756,1370,4698,4742,35818,1682,25014,1850,17098,17072,6882
%N A307607 a(n) = 1 + Sum_{d|n, d > 1} d^2*a(n/d).
%H A307607 Seiichi Manyama, <a href="/A307607/b307607.txt">Table of n, a(n) for n = 1..10000</a>
%H A307607 Vaclav Kotesovec, <a href="/A307607/a307607.jpg">Graph - the asymptotic ratio (10000 terms)</a>
%F A307607 L.g.f.: -log(Product_{k>=1} (1 - x^k)^(k*A074206(k))) = Sum_{n>=1} a(n)*x^n/n.
%F A307607 From _Vaclav Kotesovec_, Jul 09 2026: (Start)
%F A307607 Dirichlet g.f.: zeta(s)/(2 - zeta(s-2)).
%F A307607 Sum_{k=1..n} a(k) ~ zeta(r)^2 * n^r / (r*((zeta(r-2) - 2)*zeta'(r) - zeta(r)*zeta'(r-2))), where r = A107311 + 2 = 3.728647238998183618135103010297691464234109849335... is the root of the equation zeta(r-2) = 2. (End)
%t A307607 a[n_] := a[n] = 1 + DivisorSum[n, #^2 a[n/#] &, # > 1 &]; Table[a[n], {n, 1, 46}]
%o A307607 (PARI) a(n) = 1 + sumdiv(n, d, if (d>1, d^2*a(n/d))); \\ _Michel Marcus_, Apr 20 2019
