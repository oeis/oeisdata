%N A164019 Irregular table read by rows: row n contains the primes between n and 2n.
%C A164019 See A108954 and A060715 for the row lengths.
%H A164019 Stefano Spezia, <a href="/A164019/b164019.txt">Table of n, a(n) for n = 2..10436</a> (first 350 rows of the table)
%e A164019 The table starts at row n=2 as:
%e A164019   3; (between 2 and 4)
%e A164019   5; (between 3 and 6)
%e A164019   5,7; (between 4 and 8)
%e A164019   7; (between 5 and 10)
%e A164019   ...
%t A164019 row[n_]:=Select[Range[n+1,2n-1],PrimeQ]; Array[row,22,2]//Flatten (* _Stefano Spezia_, Jun 23 2026 *)
%Y A164019 Cf. A060715, A108954.
%Y A164019 Row sums give A341700.
