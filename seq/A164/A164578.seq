%I A164578 #30 Apr 28 2026 00:48:33
%S A164578 10,23,65,94,168,213,319,380,518,595,765,858,1060,1169,1403,1528,1794,
%T A164578 1935,2233,2390,2720,2893,3255,3444,3838,4043,4469,4690,5148,5385,
%U A164578 5875,6128,6650,6919,7473,7758,8344,8645,9263,9580,10230,10563,11245,11594,12308,12673
%N A164578 Integers of the form (k+1)*(2*k+1)/12.
%C A164578 This sequence can also be defined as integer averages of the first k halved squares, 1^2/2, 2^2/2, 3^2/2,... , 3^k/2, because Sum_{j=1..k} j^2/2 = k*(k+1)*(2k+1)/12. The generating k are in A168489.
%H A164578 Colin Barker, <a href="/A164578/b164578.txt">Table of n, a(n) for n = 1..1000</a>
%H A164578 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (1,2,-2,-1,1).
%F A164578 From _R. J. Mathar_, Jan 25 2011: (Start)
%F A164578 a(n) = a(n-1) + 2*a(n-2) - 2*a(n-3) - a(n-4) + a(n-5).
%F A164578 G.f.: x*(-10-13*x-22*x^2-3*x^3) / ((1+x)^2*(x-1)^3). (End)
%F A164578 From _Colin Barker_, Jan 26 2016: (Start)
%F A164578 a(n) = (24*n^2+6*n-(-1)^n*(8*n+1)+1)/4.
%F A164578 a(n) = (12*n^2-n)/2 for n even.
%F A164578 a(n) = (12*n^2+7*n+1)/2 for n odd. (End)
%F A164578 E.g.f.: (x*(19 + 12*x)*cosh(x) + (1 + 11*x + 12*x^2)*sinh(x))/2. - _Stefano Spezia_, Apr 27 2026
%t A164578 s=0;lst={};Do[a=(s+=(n^2)/2)/n;If[Mod[a,1]==0,AppendTo[lst,a]],{n,2*6!}];lst
%t A164578 (* Alternative: *)
%t A164578 Select[Table[((n+1)(2n+1))/12,{n,300}],IntegerQ] (* _Harvey P. Dale_, Jun 14 2017 *)
%t A164578 (* Alternative: *)
%t A164578 LinearRecurrence[ {1,2,-2,-1,1},{10,23,65,94,168},60] (* _Harvey P. Dale_, Jun 14 2017 *)
%o A164578 (PARI) Vec(x*(10+13*x+22*x^2+3*x^3)/((1-x)^3*(1+x)^2) + O(x^47)) \\ _Colin Barker_, Jan 26 2016
%o A164578 (PARI) for(n=1, 275, k=(n+1)*(2*n+1)/12;if(n%12==7| |n%12==11, print1(k", "))) \\ _Bruce Nye_, Apr 27 2026
