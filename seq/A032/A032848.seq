%I A032848 #14 Jul 22 2026 15:26:15
%S A032848 1,2,3,4,5,6,7,8,9,12,13,14,15,16,17,18,19,23,24,25,26,27,28,29,34,35,
%T A032848 36,37,38,39,45,46,47,48,49,56,57,58,59,67,68,69,78,79,89,120,121,130,
%U A032848 131,132,140,141,142,143,150,151,152,153,154
%N A032848 Numbers whose base-10 representation Sum_{i=0..m} d(i)*10^i has d(m) < d(m-1) > d(m-2) < ...
%H A032848 Robert Israel, <a href="/A032848/b032848.txt">Table of n, a(n) for n = 1..10000</a>
%p A032848 filter:= proc(n) local L,d,i;
%p A032848   L:= convert(n,base,10);
%p A032848   d:= nops(L);
%p A032848   L:= L[2..-1]-L[1..-2];
%p A032848   min(seq(L[i]*(-1)^(d-i),i=1..d-1))>0
%p A032848 end proc:
%p A032848 select(filter, [$1..2000]); # _Robert Israel_, Jul 21 2026
%K A032848 nonn,base,look,changed
%O A032848 1,2
%A A032848 _Clark Kimberling_
