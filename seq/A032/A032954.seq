%I A032954 #16 Jun 03 2026 00:54:33
%S A032954 1,2,3,4,6,8,10,12,14,16,17,18,19,24,25,26,27,32,33,34,35,40,41,42,43,
%T A032954 48,49,50,51,56,57,58,59,64,66,68,70,72,74,76,78,96,98,100,102,104,
%U A032954 106,108,110,128,130,132,134,136,138,140,142,160
%N A032954 Numbers whose base-4 representation Sum_{i=0..m} d(i)*4^(m-i) has even d(i) for all odd i.
%H A032954 Robert Israel, <a href="/A032954/b032954.txt">Table of n, a(n) for n = 1..10000</a>
%p A032954 filter:= proc(n) local L,i; L:= convert(n,base,4);
%p A032954   andmap(t -> type(L[t],even), [seq(i,i=nops(L)-1 .. 1,-2)])
%p A032954 end proc:
%p A032954 select(filter, [seq(i,i=1..200)]); # _Robert Israel_, Jun 02 2026
%K A032954 nonn,base
%O A032954 1,2
