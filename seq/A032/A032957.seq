%I A032957 #16 Jun 02 2026 20:59:22
%S A032957 1,2,3,4,5,6,7,9,11,13,14,16,18,20,21,23,25,27,28,30,32,34,35,37,39,
%T A032957 41,42,44,46,48,49,50,51,52,53,54,55,63,64,65,66,67,68,69,77,78,79,80,
%U A032957 81,82,83,91,92,93,94,95,96,97,98,99,100,101,102
%N A032957 Numbers whose base-7 representation Sum_{i=0..m} d(i)*7^(m-i) has even d(i) for all odd i.
%H A032957 Robert Israel, <a href="/A032957/b032957.txt">Table of n, a(n) for n = 1..10000</a>
%p A032957 filter:= proc(n) local L,i;
%p A032957   L:= convert(n,base,7);
%p A032957   andmap(t -> type(L[t],even), [seq(i,i=nops(L)-1 .. 1,-2)])
%p A032957 end proc:
%p A032957 select(filter, [$1..200]); # _Robert Israel_, Jun 02 2026
%K A032957 nonn,base,changed
%O A032957 1,2
