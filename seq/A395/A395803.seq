%I A395803 #6 May 15 2026 22:23:50
%S A395803 1,2,4,8,16,27,60,44,65,261,11,221,641,958,1197,16,3201,6386,1378,
%T A395803 7723,11685,22,885,28523,56161,51488,119319
%N A395803 Minimum numerators corresponding to the denominators in A395231.
%C A395803 Since the greedy algorithm always reduces the numerator by at least 1 for every step, a(n) >= n.
%e A395803 The fraction with the smallest denominator so that its Egyptian fraction representation has 1 term is 1/2.
%e A395803 The fraction with the smallest denominator so that its Egyptian fraction representation has 2 terms is 2/3 = 1/2 + 1/6.
%e A395803 The fraction with the smallest denominator so that its Egyptian fraction representation has 3 terms is 4/5 = 1/2 + 1/4 + 1/20.
%e A395803 The fraction with the smallest denominator so that its Egyptian fraction representation has 4 terms is 8/11 = 1/2 + 1/5 + 1/37 + 1/4070.
%o A395803 (Julia)
%o A395803 function a(n)
%o A395803     den = 1
%o A395803     while true
%o A395803         den += 1
%o A395803         for num in 1:den-1
%o A395803             frac = num // den
%o A395803             length = 1
%o A395803             while numerator(frac) != 1
%o A395803                 frac -= 1 // big(denominator(frac) ÷ numerator(frac) + 1)
%o A395803                 length += 1
%o A395803             end
%o A395803             if length == n
%o A395803                 return num
%o A395803             end
%o A395803         end
%o A395803     end
%o A395803 end
%Y A395803 Cf. A395231 (denominators), A394341, A100678, A097049.
%K A395803 frac,nonn,more,new
%O A395803 1,2
%A A395803 _Hoang Nguyen_, May 07 2026
