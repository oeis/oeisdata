%I A395372 #5 Apr 22 2026 23:23:29
%S A395372 1,1,2,2,4,4,4,4,4,8,16,16,4,4,2,2,8,8,8,8
%N A395372 Number of weakly consecutive sequences of length n.
%H A395372 Thomas Garrison, Chris Seiler, and Andrew Knowles, <a href="https://arxiv.org/abs/2401.09497">Weakly Consecutive Sequences</a>, arXiv preprint (2024). arXiv:2401.09497 [math.CO]
%o A395372 (PARI) countWCS_rec(m)=if(m==0, return(1)); my(q=WCS_n\m, r=WCS_n%m, s,p,rr,miss,holes,t,j); if(q==1, s=0; for(p=WCS_n-m+1,m,if(!WCS_occ[p], WCS_occ[p]=1; WCS_pos[m]=p; s+=countWCS_rec(m-1); WCS_occ[p]=0; WCS_pos[m]=0)); return(s)); forstep(j=2*m,q*m,m, t=(WCS_pos[j]-1)%m+1; if(!rr, rr=t, if(t!=rr, return(0)))); if(rr<=r, return(0)); miss=holes=0; for(t=0,q-1, p=rr+t*m; if(!WCS_occ[p], holes++; if(holes>1,return(0)); miss=p)); if(holes!=1, return(0)); WCS_occ[miss]=1; WCS_pos[m]=miss; s=countWCS_rec(m-1); WCS_occ[miss]=0; WCS_pos[m]=0; s
%o A395372 a(n)=local(WCS_n=n, WCS_pos=Vecsmall(vector(n,i,0)), WCS_occ=Vecsmall(vector(n,i,0))); countWCS_rec(n)
%K A395372 nonn,new
%O A395372 0,3
%A A395372 _Charles R Greathouse IV_, Apr 20 2026
