%I A395144 #32 May 10 2026 16:47:16
%S A395144 2,3,5,7,11,17,25,29,31,53,89,97,199,457,1013,1769,2273,3169,4967,
%T A395144 13697,26063,26753,92003,128311,141619
%N A395144 Indices of records in A100140.
%C A395144 This sequence gives the denominators of fractions with minimum k so that when all fractions of form i/k (i < k) are expressed as unit fractions using the greedy algorithm, the largest denominator from that set successively increases.
%C A395144 It looks like most entries are odd (except for 2) and prime (except for 25, 1769, 26063, and 26753).
%e A395144 The smallest denominator with a valid fraction is 2 with 1/2 (maximum 2). 2 is the first entry.
%e A395144 The next denominator is 3 with 1/3 and 2/3 = 1/2 + 1/6 (maximum 6 > 2). Thus, 3 is the next entry.
%e A395144 The next denominator is 4 with 1/4, 2/4 = 1/2, and 3/4 = 1/2 + 1/4 (maximum 4 < 6). 4 is not a part of the list.
%e A395144 The next denominator is 5 with 1/5, 2/5 = 1/3 + 1/15, 3/5 = 1/2 + 1/10, and 4/5 = 1/2 + 1/4 + 1/20 (maximum 20 > 6). Thus, 5 is the next entry.
%o A395144 (Julia)
%o A395144 function a(k)
%o A395144     global_max = 0
%o A395144     i = 0
%o A395144     den = 1
%o A395144     while i < k
%o A395144         den += 1
%o A395144         local_max = 0
%o A395144         for num in 1:den-1
%o A395144             frac = num // den
%o A395144             while numerator(frac) != 1
%o A395144                 frac -= 1 // big(denominator(frac) ÷ numerator(frac) + 1)
%o A395144             end
%o A395144             if denominator(frac) > local_max
%o A395144                 local_max = denominator(frac)
%o A395144             end
%o A395144         end
%o A395144         if local_max > global_max
%o A395144             global_max = local_max
%o A395144             i += 1
%o A395144         end
%o A395144     end
%o A395144     return den
%o A395144 end
%Y A395144 Cf. A394341 (numerators), A100140, A050210.
%K A395144 frac,nonn,more,new
%O A395144 1,1
