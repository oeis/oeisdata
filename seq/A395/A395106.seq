%I A395106 #14 Apr 12 2026 08:39:32
%S A395106 1,2,27,952,68605,8581845,1662067729,460552560376,172739391669405,
%T A395106 84218407819716325,51757131105165217204,39136402281611488898466,
%U A395106 35707155001567718462137955,38680050052145933834517644187,49078058643246990849287036123940
%N A395106 G.f. A(x) satisfies [x^n] exp( n*A(x) ) * (1-n^2*x)^(1/n) = 0, for n >= 1.
%H A395106 Seiichi Manyama, <a href="/A395106/b395106.txt">Table of n, a(n) for n = 1..215</a>
%F A395106 a(n) = n^(2*n-3) - (1/n) * Sum_{k=1..n-1} k * c_n(k) * e_n(n-k),
%F A395106 where c_n(k) = a(k) - n^(2*k-2)/k for 1 <= k <= n-1,
%F A395106 and e_n(0) = 1, e_n(k) = (n/k) * Sum_{j=1..k} j * c_n(j) * e_n(k-j) for 1 <= k <= n-1.
%o A395106 (Ruby)
%o A395106 def A395106(n)
%o A395106   a = [0]
%o A395106   (1..n).each{|i|
%o A395106     c = [0] + (1..i - 1).map{|k| a[k] - i ** (2 * k - 2) / k.to_r}
%o A395106     e = [1]
%o A395106     (1..i - 1).each{|k| e << i / k.to_r * (1..k).inject(0){|s, j| s + j * c[j] * e[k - j]}}
%o A395106     a << i ** (2 * i - 3) - (1..i - 1).inject(0){|s, k| s + k * c[k] * e[i - k]}.to_i / i
%o A395106   }
%o A395106   a[1..-1]
%o A395106 end
%o A395106 p A395106(20)
%Y A395106 Cf. A088716, A395107.
%Y A395106 Cf. A300617, A395074.
%K A395106 nonn
%O A395106 1,2
