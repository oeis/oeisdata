%S A395064 1,999,666666,88888888,167777788899,36668889999999,44888888888888888,
%T A395064 23688999999999999999,346666777777777888888899,
%U A395064 18888888888999999999999999,33399999999999999999999999999,88888888888888888888888888888888,66888888888888888888888999999999999,36888888888999999999999999999999999999
%N A395064 a(1) = 1. For n >= 2, a(n) is the smallest positive integer > 1 such that s^n = p where s is the sum of digits of a(n) (cf. A007953) and p is the product of digits of a(n) (cf. A007954).
%e A395064 a(3) = 666666 as the digital sum of 666666 is 36 and the product of digits of 666666 is 36^3 and 666666 is the smallest number with this property.
%o A395064 (Python)
%o A395064 from math import prod
%o A395064 from itertools import count, combinations_with_replacement as mc
%o A395064 def nd(): yield from (t for d in count(1) for t in mc(range(1, 10), d))
%o A395064 def a(n): return 1 if n == 1 else next(int("".join(map(str, t))) for t in nd() if sum(t)**n == prod(t) > 1)
%o A395064 # _Michael S. Branicky_, May 25 2026
%Y A395064 Cf. A002473, A007953, A007954, A009994, A117720, A274124, A379834.
%K A395064 base,nonn
%O A395064 1,2
