%S A395239 1,22,1456,202672,48361216,17630351872,9114999832576,6343764407375872,
%T A395239 5718564661248065536,6481629887083387420672,9022037023809985598980096,
%U A395239 15129556865351957511402422272,30084898082515645117519422816256,69993344009202014291156894243356672
%N A395239 a(n) = (2*n)! * [x^(2*n)] (f(x)^2 + f(-x)^2)/2 and f(x) = 1/(cosh(x) - 2 * sinh(x)).
%F A395239 a(n) = (2*n)! * [x^(2*n)] (1 + 5*sinh(x)^2)/(1 - 3*sinh(x)^2)^2.
%F A395239 Let A(n,k) = (2*n)! * [x^(2*n)] (f(x)^k + f(-x)^k)/2. A(0,k) = 1 and A(0,k) = 1 and A(n,k) = 3*k*(k+1) * A(n-1,k+2) + k^2 * A(n-1,k) for n > 0. a(n) = A(n,2).
%o A395239 (PARI) a(n) = my(x='x+O('x^(2*n+1))); (2*n)!*polcoef((1+5*sinh(x)^2)/(1-3*sinh(x)^2)^2, 2*n);
%Y A395239 Column k=2 of A395236.
%K A395239 nonn
%O A395239 0,2
%A A395239 _Seiichi Manyama_, Apr 17 2026
