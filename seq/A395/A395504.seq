%I A395504 #59 May 06 2026 19:27:40
%S A395504 8,15,21,24,35,48,55,56,63,80,99,115,120,143,144,168,195,204,209,224,
%T A395504 255,288,323,329,360,377,399,440,483,496,528,551,575,624,675,711,728,
%U A395504 780,783,840,899,960,980,987,1023,1088,1155,1189,1224,1295,1309,1368,1443
%N A395504 Integers m such that there are more than 2 integers k, 1 <= k < m, such that m divides k^2-1 and k divides m^2-1.
%H A395504 Srikanth Cherukupally, <a href="/A395504/b395504.txt">Table of n, a(n) for n = 1..1162</a>
%H A395504 Srikanth Cherukupally, <a href="https://arxiv.org/abs/2603.17434">On the size of {a : 1 <= a < n, n|a^2 - 1, a|n^2 - 1} for number n</a>, arXiv:2603.17434 [math.NT], 2026.
%e A395504 8 is the first term in the sequence: a(1) = 8. Because, for m=8, there are 3 values of k such that m divides k^2-1 and k divides m^2-1. The values of k are 1,3,7.
%p A395504 q:= n-> nops(select(m-> 0=irem(n^2-1, m), {numtheory[rootsunity](2, n)}))>=3:
%p A395504 select(q, [$1..1500])[];  # _Alois P. Heinz_, Apr 26 2026
%o A395504 (PARI) isok(k) = sum(x=1, k-1, !((k^2-1) % x) && ! ((x^2-1) % k)) >= 3; \\ _Michel Marcus_, Apr 26 2026
%o A395504 (Python)
%o A395504 from itertools import count, islice
%o A395504 from sympy import sqrt_mod
%o A395504 def A395504_gen(startvalue=2): # generator of terms >= startvalue
%o A395504     return filter(lambda m:sum(1 for d in sqrt_mod(1, m, all_roots=True) if not (m**2-1)%d) > 2, count(max(startvalue,2)))
%o A395504 A395504_list = list(islice(A395504_gen(),50)) # _Chai Wah Wu_, Apr 30 2026
%Y A395504 Cf. A394398.
%K A395504 nonn,new
%O A395504 1,1
%A A395504 _Srikanth Cherukupally_, Apr 26 2026
