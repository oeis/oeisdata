%I A395895 #9 May 15 2026 23:22:21
%S A395895 1,3,7,19,49,137,388,1134,3323,9893,29471,88285,264603,794177,2383396,
%T A395895 7155808,21479338,64472940
%N A395895 Number of nonperiodic autocorrelation functions of length n {-1,0,1} sequences.
%C A395895 The nonperiodic autocorrelation function of a length n sequence A = (a_0,a_1,a_2,...,a_{n-1}) is defined as NPAF(A) = (b_1,b_2,...,b_{n-1}) where b_k = Sum_{i=0..n-k-1} a_i * a_{i+k}.
%e A395895 The length 4 {-1,0,1} sequence A = (0,1,1,-1) has the nonperiodic autocorrelation function NPAF(A) = (0,-1,0), so this is one distinct NPAF counted under a(4) = 19.
%e A395895 a(3) = 7 counts the following NPAFs: (0,1), (2,1), (0,0), (-2,1), (-1,0), (1,0), (0,-1).
%o A395895 (Python)
%o A395895 from itertools import product
%o A395895 def NPAC(w):
%o A395895     f,n = [],len(w)
%o A395895     for k in range(1,n):
%o A395895         x = sum(w[i]*w[i+k] for i in range(n-k))
%o A395895         f.append(x)
%o A395895     return tuple(f)
%o A395895 def A395895(n):
%o A395895     S,R = set(),set()
%o A395895     for i in product([-1,0,1],repeat=n):
%o A395895         x = i[::-1]
%o A395895         if x not in R:
%o A395895             R.add(x)
%o A395895             R.add(i)
%o A395895             S.add(NPAC(i))
%o A395895     return len(S)
%Y A395895 Cf. A000244, A006606.
%K A395895 nonn,more,new
