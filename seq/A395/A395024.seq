%U A395024 1451019795226044583939161675,4833040079652570412931114352522,19192370042391531000441950190742764,89595675606598689931615051679687288042
%N A395024 G.f. A(x) satisfies [x^n] exp( -n*A(x) ) / (1-n^2*x)^n = 0, for n >= 1.
%H A395024 Seiichi Manyama, <a href="/A395024/b395024.txt">Table of n, a(n) for n = 1..194</a>
%F A395024 a(n) = n^(2*n-1) + (1/n) * Sum_{k=1..n-1} k * c_n(k) * e_n(n-k),
%F A395024 where c_n(k) = n^(2*k)/k - a(k) for 1 <= k <= n-1,
%F A395024 and e_n(0) = 1, e_n(k) = (n/k) * Sum_{j=1..k} j * c_n(j) * e_n(k-j) for 1 <= k <= n-1.
%e A395024 The table of coefficients of x^k in exp( -n*A(x) ) / (1-n^2*x)^n begins:
%e A395024 n\k | 0    1         2           3               4                 5
%e A395024 ----+--------------------------------------------------------------------
%e A395024   1 | 1,   0,    -33/2,    -4724/3,     -2904877/8,     -771783489/5, ...
%e A395024   2 | 1,   6,      0,      -9538/3,      -745116,      -1565613728/5, ...
%e A395024   3 | 1,  24,    717/2,        0,       -9152865/8,    -2451461802/5, ...
%e A395024   4 | 1,  60,   2244,     185404/3,            0,      -3367213136/5, ...
%e A395024   5 | 1, 120,  17355/2,  1450400/3,    169772435/8,              0,   ...
%e A395024   6 | 1, 210,  25836,    2422422,      189632916,      60682340616/5, ...
%e A395024   7 | 1, 336, 129465/2, 28107772/3,   9032806447/8,   592501391867/5, ...
%e A395024   8 | 1, 504, 143256,   90638360/3,   5260749680,    3992429015168/5, ...
%e A395024   9 | 1, 720, 577143/2, 84935628,   163785342195/8, 21391972683669/5, ...
%o A395024 (Ruby)
%o A395024 def A395024(n)
%o A395024   a = [0]
%o A395024   (1..n).each{|i|
%o A395024     c = [0] + (1..i - 1).map{|k| i ** (2 * k) / k.to_r - a[k]}
%o A395024     e = [1]
%o A395024     (1..i - 1).each{|k| e << i / k.to_r * (1..k).inject(0){|s, j| s + j * c[j] * e[k - j]}}
%o A395024     a << i ** (2 * i - 1) + (1..i - 1).inject(0){|s, k| s + k * c[k] * e[i - k]}.to_i / i
%o A395024   }
%o A395024   a[1..-1]
%o A395024 end
%o A395024 p A395024(20)
