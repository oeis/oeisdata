%I A395605 #22 May 09 2026 18:15:09
%S A395605 1,1,2,4,7,1,6,17,3,7,16,14,36,33,40,17,25,59,51,31,72,4,11,57,44,91,
%T A395605 55,60,65,37,96,29,8,84,2,150,110,74,110,152,77,56,44,174,57,112,69,
%U A395605 119,158,45,189,132,214,123,5,131,8,229,19,106,54,81,284,225
%N A395605 a(n) = ((Lucas(prime(n)) - 1) / prime(n)) mod prime(n).
%C A395605 For every prime q, q divides Lucas(q) - 1 (a consequence of the Frobenius endomorphism on F_q[x]/(x^2-x-1)), so the quotient (Lucas(q)-1)/q is always an integer.
%C A395605 If B(m) = Sum_{d|m} mu(d)*Lucas(m/d) is the additive Mobius transform of the Lucas sequence, then B(q) = Lucas(q) - 1 for prime q, and a(n) = B(prime(n))/prime(n) mod prime(n).
%C A395605 Conjecturally, for prime(n) != 2, 5, a(n) is the leading base-prime(n) digit of a p-adic invariant lambda(prime(n)) in Z_{prime(n)}, defined as the limit of the sequence u_k(p) = B(p^k)/p^k as k -> infinity. This p-adic interpretation is conjectural; the definition of a(n) is not.
%H A395605 Alois P. Heinz, <a href="/A395605/b395605.txt">Table of n, a(n) for n = 1..10000</a>
%F A395605 a(n) = ((Lucas(prime(n)) - 1) / prime(n)) mod prime(n).
%F A395605 a(n) = A064723(n) mod prime(n).
%F A395605 If B(m) = Sum_{d|m} mu(d)*Lucas(m/d), then a(n) = B(prime(n))/prime(n) mod prime(n).
%e A395605 a(4) = 4: prime(4) = 7, Lucas(7) = 29, so a(4) = ((29-1)/7) mod 7 = 4 mod 7 = 4.
%e A395605 a(5) = 7: prime(5) = 11, Lucas(11) = 199, so a(5) = ((199-1)/11) mod 11 = 18 mod 11 = 7.
%e A395605 a(6) = 1: prime(6) = 13, Lucas(13) = 521, so a(6) = ((521-1)/13) mod 13 = 40 mod 13 = 1.
%p A395605 with(numtheory):
%p A395605 L := proc(n) option remember;
%p A395605     if n = 0 then 2
%p A395605     elif n = 1 then 1
%p A395605     else L(n-1) + L(n-2)
%p A395605     end if;
%p A395605 end proc:
%p A395605 a := proc(n) local q;
%p A395605     q := ithprime(n);
%p A395605     irem(iquo(L(q)-1, q), q);
%p A395605 end proc:
%p A395605 seq(a(n), n=1..64);
%t A395605 Table[Mod[(LucasL[Prime[n]] - 1)/Prime[n], Prime[n]], {n, 1, 64}]
%o A395605 (Python)
%o A395605 from sympy import prime
%o A395605 def A395605(n):
%o A395605     a, b, p = 2, 1, prime(n)
%o A395605     p2 = p**2
%o A395605     for _ in range(p-1):
%o A395605         a, b = b, (a+b)%p2
%o A395605     return (b-1)//p # _Chai Wah Wu_, May 09 2026
%Y A395605 Cf. A000032 (Lucas numbers), A000040 (primes), A008683 (Mobius function), A064723.
