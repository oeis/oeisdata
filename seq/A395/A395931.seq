%I A395931 #12 May 13 2026 10:26:47
%S A395931 3,7,23,31,47,127,167,223,233,263,359,383,431,439,479,503,647,719,839,
%T A395931 863,887,983,1223,1319,1327,1367,1399,1439,1487,1559,1823,1847,2039,
%U A395931 2063,2207,2351,2383,2447,2543,2687,2767,2879,2903,2999,3023,3119,3167,3343,3391,3463,3607,3623,3863,4007
%N A395931 Primes p that are the least prime factor of 2^k - 1 for some k >= 1.
%C A395931 Solutions of p = A020639(2^(A002326((p-1)/2)-1).
%C A395931 Odd primes p such that for all odd primes q < p, A002326((p-1)/2) is not a multiple of A002326((q-1)/2).
%H A395931 Robert Israel, <a href="/A395931/b395931.txt">Table of n, a(n) for n = 1..10000</a>
%e A395931 a(3) = 23 is a term because 2^11 - 1 = 23 * 89 whose least prime factor is 23.
%p A395931 A:= NULL: V:= {}:
%p A395931 p:= 2: count:= 0:
%p A395931 while count < 100 do
%p A395931   p:= nextprime(p); v:= NumberTheory:-MultiplicativeOrder(2,p);
%p A395931   if andmap(w -> v mod w <> 0, V) then
%p A395931     A:= A,p; V:= V union {v}; count:= count+1
%p A395931   fi
%p A395931 od:
%p A395931 A;
%Y A395931 Includes A000668. Cf. A002326, A020639, A394313, A395945.
%K A395931 nonn,new
%O A395931 1,1
%A A395931 _Robert Israel_, May 10 2026
