%I A395100 #14 Apr 16 2026 12:36:13
%S A395100 19,37,73,127,163,181,271,433,523,541,613,631,811,1117,1153,1171,1423,
%T A395100 1531,1621,2143,2161,2251,2341,2521,3313,3331,3511,4231,5113,6121,
%U A395100 6211,11161,11251,12241,12421,12511,13411,14221,15121,16111,21313,22123,23131,23311
%N A395100 Zeroless primes having digit sum 10.
%H A395100 Alois P. Heinz, <a href="/A395100/b395100.txt">Table of n, a(n) for n = 1..90</a>
%p A395100 b:= proc(n, i, l) option remember; `if`(n=0, select(isprime,
%p A395100       map(x-> parse(cat(x[])), combinat[permute](l))),
%p A395100      `if`(i<1, [], [seq(b(n-i*j, i-1, [l[], i$j])[], j=0..n/i)]))
%p A395100     end:
%p A395100 sort(b(10, 9, []))[];
%t A395100 Select[Prime[Range[2599]],ContainsNone[IntegerDigits[#],{0}]&&Total[IntegerDigits[#]]==10&] (* _James C. McMahon_, Apr 14 2026 *)
%Y A395100 Intersection of A052382 and A107579.
%Y A395100 Intersection of A000040 and A179955.
%Y A395100 Row n=10 of A113625.
%K A395100 nonn,base,fini,full,new
%O A395100 1,1
%A A395100 _Alois P. Heinz_, Apr 11 2026
