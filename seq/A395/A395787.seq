%T A395787 146847849924,1556921472048,16349883332892,170311933199520,
%U A395787 1761808145009364,18115797341622400,185297428490567508,1886535510872105952,19128021424652193840,193230176794729333272
%N A395787 Expansion of (Sum_{k>=0} binomial(4*k+2,k) * x^k)^4.
%H A395787 Vincenzo Librandi, <a href="/A395787/b395787.txt">Table of n, a(n) for n = 0..1000</a>
%F A395787 a(n) = Sum_{i,j,k,l >= 0 and i+j+k+l=n} binomial(4*i+2,i) * binomial(4*j+2,j) * binomial(4*k+2,k) * binomial(4*l+2,l).
%F A395787 G.f.: B(x)^4 where B(x) is the g.f. of A257633.
%F A395787 a(n) = Sum_{k=0..n} 3^k * binomial(k+2,2) * binomial(4*n+11,n-k).
%F A395787 a(n) = Sum_{k=0..n} 4^k * binomial(k+2,2) * binomial(4*n+8-k,n-k).
%F A395787 a(0) = 1; a(n) = (1/n) * Sum_{k=0..n-1} (4*k+24) * 3^k * binomial(k+3,3) * binomial(4*n+11,n-1-k).
%F A395787 a(0) = 1; a(n) = (1/n) * Sum_{k=0..n-1} (3*k+24) * 4^k * binomial(k+3,3) * binomial(4*n+7-k,n-1-k).
%t A395787 a[n_]:=Sum[3^k*Binomial[k+2,2]*Binomial[4*n+11,n-k],{k,0,n}]; Table[a[n],{n,0,20}] (* _Vincenzo Librandi_, May 06 2026 *)
%o A395787 (PARI) a(n) = sum(k=0, n, 3^k*binomial(k+2, 2)*binomial(4*n+11, n-k));
%o A395787 (Magma) a:= function(n) return &+[3^k*Binomial(k+2,2)*Binomial(4*n+11, n-k): k in [0..n] ];
%o A395787 end function; [ a(n) : n in [0..20] ]; // _Vincenzo Librandi_, May 06 2026
%Y A395787 Cf. A257633, A386611, A395786.
%Y A395787 Cf. A378484.
