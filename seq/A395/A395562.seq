%I A395562 #6 May 06 2026 16:48:50
%S A395562 1,2,2,3,6,5,3,2,6,7,14,12,10,11,5,2,12,13,14,6,15,3,22,17,18,7,19,20,
%T A395562 21,22,10,23,24,30,26,39,28,29,30,31,10,38,33,34,35,42,11,37,38,39,40,
%U A395562 41,12,42,43,44,45,2,46,3,13,47,48,56,50,51,52,14,53,54
%N A395562 Sum of roots r such that A001597(n) = r^m for some m > 1.
%C A395562 Let s = A001597.
%C A395562 In scatterplot, terms arrange on trajectories associated with the greatest common divisor of prime power factor exponents of s(n).
%C A395562 Records in this sequence are set by certain square s(n).
%C A395562 a(n) is not in A246547, that is, a(1) = 1, and for n > 1, a(n) is in A085971.
%C A395562 a(n) rarely exceeds n.
%C A395562 Fixed points are {1, 2, 12} for n <= 1059097 (i.e., s(n) <= 2^40), are there any more?
%H A395562 Michael De Vlieger, <a href="/A395562/b395562.txt">Table of n, a(n) for n = 1..10000</a>
%H A395562 Michael De Vlieger, <a href="/A395562/a395562.png">Log log scatterplot of a(n)</a>, n = 1..266351.
%F A395562 a(n) = sum of row n of A392986.
%F A395562 a(n) = 2 for s(n) = 2^q, with prime q.
%F A395562 a(n) = p for s(n) = p^q, with primes p and q.
%F A395562 a(n) = k for s(n) = k^q, with prime q and k in A024619, yet there exist some a(n) = k where s(n) is not of this form. Example: a(n) = 6 for s(n) = 6^q (i.e., with n in {9, 20, 110, 602, 19797, 116718, ...}), but also for s(5) = 16, since 16 is a perfect power of 2 and 4; thus a(5) = 2+4 = 6.
%e A395562 Table of n, s(n), a(n), and row n of A392986 for select n:
%e A395562     n      s(n)  a(n)  row n of A392986
%e A395562   ---------------------------------------
%e A395562     1        1     1   {1}
%e A395562     2        4     2   {2}
%e A395562     3        8     2   {2}
%e A395562     4        9     3   {3}
%e A395562     5       16     6   {2, 4}
%e A395562    11       64    14   {2, 4, 8}
%e A395562    12       81    12   {3, 9}
%e A395562    23      256    22   {2, 4, 16}
%e A395562    36      729    39   {3, 9, 27}
%e A395562    42     1024    38   {2, 4, 32}
%e A395562    82     4096    94   {2, 4, 8, 16, 64}
%e A395562   153    15625   155   {5, 25, 125}
%e A395562   255    46656   258   {6, 36, 216}
%e A395562   396   117649   399   {7, 49, 343}
%e A395562   583   262144   590   {2, 4, 8, 64, 512}
%t A395562 nn = 2^12; {1}~Join~Map[Module[{k = #, m = Floor@ Log2[#]}, While[! IntegerQ[Surd[k, m] ], m--]; Total@ Map[Surd[k, #] &, Reverse@ Rest@ Divisors[m] ] ] &, Union@ Flatten[Table[k^m, {m, 2, Log2[nn]}, {k, 2, Surd[nn, m] } ] ] ]
%Y A395562 Cf. A001597, A085971, A392986.
%K A395562 nonn,easy,new
%O A395562 1,2
%A A395562 _Michael De Vlieger_, Apr 28 2026
