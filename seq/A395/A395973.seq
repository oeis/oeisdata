%S A395973 1,6,3,2,0,5,1,6,6,9,8,4,7,5,7,7,4,8,7,6,7,4,0,6,2,6,1,7,2,1,3,5,7,7,
%T A395973 3,9,9,0,6,1,8,5,9,0,6,7,5,4,2,3,3,0,3,4,6,3,0,9,1,0,9,5,4,1,3,5,8,0,
%U A395973 2,4,2,8,7,4,0,2,5,2,2,2,9,8,2,7,0,8,5,0
%N A395973 Decimal expansion of the solution of phi^(2*x)*cos(Pi*x) = (27 + 7*sqrt(5))/22, where phi = (1 + sqrt(5)) / 2.
%C A395973 The first real root of the function defining A396201. See the illustration given there. The root is almost certainly transcendental.
%e A395973 1.632051669847577487674062617213577399061859...
%o A395973 (Python)
%o A395973 import mpmath
%o A395973 mpmath.mp.dps = 105
%o A395973 root = guess = 1.63
%o A395973 phi = (1 + mpmath.sqrt(5)) / 2
%o A395973 rhs = (27 + 7 * mpmath.sqrt(5)) / 22
%o A395973 f = lambda x: phi**(2*x) * mpmath.cos(mpmath.pi * x) - rhs
%o A395973 try:
%o A395973     root = mpmath.findroot(f, guess)
%o A395973 except ValueError as e:
%o A395973     root = 0
%o A395973 root_str = str(root)
%o A395973 ",".join(char for char in root_str if char.isdigit())
%Y A395973 Cf. A001622, A396201.
%K A395973 nonn,cons,new
%O A395973 1,2
%A A395973 _Peter Luschny_, May 27 2026
