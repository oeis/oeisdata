%S A395681 1,1,2,2,4,2,6,3,3,3,10,4,12,5,7,7,16,6,18,7,11,9,22,8,9,10,17,10,28,
%T A395681 8,30,12,19,14,23,11,36,16,23,10,40,11,42,18,12,19,46,15,18,18,30,20,
%U A395681 52,16,39,15,33,24,58,15,60,26,17,19,47,18,66,27,40,23
%N A395681 a(n) is the number of positive integers m <= n such that the set of primes dividing m or dividing an exponent in the prime factorization of m is disjoint from the corresponding set for n.
%H A395681 K. Bildhauser, J. Erickson, C. Tacoma, and R. Gillman, <a href="https://doi.org/10.2140/involve.2009.2.65">Divisor concepts for mosaics of integers</a>, Involve 2 (2009), 65-78.
%H A395681 T. A. Dao, T. Kasian, and M. Mirabi, <a href="https://doi.org/10.48550/arXiv.2606.22842">Level Totients for Integer Mosaics</a>, arXiv:2606.22842 [math.NT], Jun 22 2026.
%F A395681 a(prime(k)) = prime(k) - 1.
%F A395681 a(n) <= A000010(n).
%e A395681 For n = 8 = 2^3, the corresponding set is {2, 3}. The positive integers m <= 8 for which the condition holds are 1, 5, and 7. Hence a(8) = 3.
%o A395681 (Python)
%o A395681 from sympy import factorint
%o A395681 def prime_set(k):
%o A395681     f = factorint(k)
%o A395681     s = set(f)
%o A395681     for e in f.values():
%o A395681         s |= set(factorint(e))
%o A395681     return s
%o A395681 def a(n):
%o A395681     Pn = prime_set(n)
%o A395681     return sum(1 for m in range(1, n+1) if prime_set(m).isdisjoint(Pn))
%o A395681 print([a(n) for n in range(1, 71)])
%o A395681 (PARI) sp(n) = my(f=factor(n), v=f[,1]~); for (i=1, #f~, v=setunion(v, sp(f[i,2]))); v;
%o A395681 a(n) = my(spn = sp(n)); sum(i=1, n, #setintersect(spn, sp(i)) == 0); \\ _Michel Marcus_, Jul 18 2026
%Y A395681 Cf. A000010 (Euler totient), A001221 (number of distinct primes dividing n), A000026 (mosaic numbers).
