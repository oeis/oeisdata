%N A395576 1 = Sum_{n>=0} a(n) * x^n * (1 - (3*n+1)*x)^3.
%F A395576 a(n) = 3*(3*n - 2)*a(n-1) - 3*(3*n - 5)^2*a(n-2) + (3*n - 8)^3*a(n-3).
%F A395576 a(n) ~ c * 3^n * exp(2*sqrt(3*n) - n) * n^(n - 3/4) * (1 - 17/(48*sqrt(3*n))), where c = 0.09541706761752758924431440444540171658283838925257296686... - _Vaclav Kotesovec_, May 11 2026
%t A395576 RecurrenceTable[{-(-8+3*n)^3*a[n-3] + 3*(-5+3*n)^2*a[n-2] - 3*(-2+3*n)*a[n-1] + a[n]==0,a[1]==3,a[2]==33,a[3]==550}, a, {n, 0, 20}]
%o A395576 (PARI) {a(n)=polcoeff(1-sum(m=0, n-1, a(m)*x^m*(1-(3*m+1)*x+x*O(x^n))^3), n)}
%o A395576 for(n=0, 25, print1(a(n), ", "))
