%I A395966 #11 May 19 2026 23:13:21
%S A395966 1,3,4,7,9,12,13,14,16,19,21,23,24,25,26,31,33,34,37,38,41,42,44,47,
%T A395966 51,52,53,54,55,59,61,63,64,68,69,70,72,76,77,78,80,84,85,86,89,90,93,
%U A395966 94,96,98,99,106,108,109,110,111,112,113,114,118
%N A395966 Numbers k such that A395964(k) = 1.
%C A395966 Complement of A395965.
%H A395966 Benoit Cloitre, <a href="https://arxiv.org/abs/2604.06243">The Thue-Morse Transform</a>, arXiv:2604.06243 [math.NT], 2026.
%o A395966 (Python)
%o A395966 def fib_word(L):
%o A395966     s = [0]
%o A395966     while len(s) < L:
%o A395966         s = sum(([0, 1] if c == 0 else [0] for c in s), [])
%o A395966     return s[:L]
%o A395966 def T(w):
%o A395966     N = len(w)
%o A395966     v = [i for i, b in enumerate(w) if b == 0]
%o A395966     u = [i for i, b in enumerate(w) if b == 1]
%o A395966     wp = [None] * N
%o A395966     wp[0] = 0
%o A395966     for k in range(N):
%o A395966         if wp[k] is None: break
%o A395966         if k < len(v) and v[k] < N: wp[v[k]] = wp[k]
%o A395966         if k < len(u) and u[k] < N: wp[u[k]] = 1 - wp[k]
%o A395966     return wp
%o A395966 T2f = T(T(fib_word(300)))
%o A395966 print([k for k, b in enumerate(T2f) if b == 1][:60])
