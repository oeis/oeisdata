%I A395071 #43 May 10 2026 22:47:25
%S A395071 7,74,135,818,1129,18938,35954,244647,334799,5995730,11448871,
%T A395071 78439682,107528977,1929108530,3684200834,25251313255,34614832471,
%U A395071 621134108570,1186259960295,1238420918199,8130736409714,11145780010489,200002771707050,381971282645042
%N A395071 Numbers k such that both k and k+1 are in A010342.
%C A395071 There are infinitely many such k.
%C A395071 k+1 is never prime.
%C A395071 k is never a multiple of 4 or 2p, where p is a 3 mod 4 prime.
%C A395071 If k is even then its continued fraction has an even length of 1's. This implies that k+1's continued fraction will have an odd length of 1's.
%C A395071 Given a pair of twins (k,k+1), if the minimum of the length of 1's among them is m, then k > 1/4 * F(m+1)^2 * F(m+2)^2 where F(n)=A000045(n).
%C A395071 Given k having a length of m1 and k+1 having a length of m2, then (m2-m1) divides m1+1 with the exception of m2-m1=2.
%H A395071 Asher Shmidov, <a href="/A395071/b395071.txt">Table of n, a(n) for n = 1..2661</a>
%e A395071 The second twin pair (corresponding to n = 2) is (74, 75).
%e A395071 For k = 74, sqrt(74) = [8; 1, 1, 1, 1, 16]. The periodic part is (1, 1, 1, 1, 16), which consists of 1's and a final partial quotient of 16.
%e A395071 For k = 75, sqrt(75) = [8; 1, 1, 1, 16]. The periodic part is (1, 1, 1, 16), which consists of 1's and a final partial quotient of 16.
%e A395071 Since 74 and 75 are consecutive, 74 belongs to this sequence.
%o A395071 (Python)
%o A395071 def twin_list(term_count=24):
%o A395071     f = [0, 1, 1]
%o A395071     def fib(n):
%o A395071         while len(f) <= n:
%o A395071             f.append(f[-1] + f[-2])
%o A395071         return f[n]
%o A395071     k_set = set()
%o A395071     m1 = 1
%o A395071     while True:
%o A395071         least_k = (fib(m1+1) * fib(m1+2))**2 // 4
%o A395071         if len(k_set) >= term_count:
%o A395071             if sorted(list(k_set))[term_count-1] < least_k:
%o A395071                 break
%o A395071         for d in range(1, m1+2):
%o A395071             if (m1+1) % d != 0 and d != 2:
%o A395071                 continue
%o A395071             m2 = m1 + d
%o A395071             F_d = fib(d)
%o A395071             if m1 % 3 == 2 or m2 % 3 == 2:
%o A395071                 continue
%o A395071             num = fib(m1+1) * fib(m2+1)
%o A395071             two_q_minus1 = num // F_d
%o A395071             if two_q_minus1 % 2 == 1:
%o A395071                 q = two_q_minus1 // 2 + 1
%o A395071                 k1 = q**2 + 1 + two_q_minus1 * fib(m1) // fib(m1+1)
%o A395071                 k2 = q**2 + 1 + two_q_minus1 * fib(m2) // fib(m2+1)
%o A395071                 k_set.add(min(k1, k2)) # least of the pair. k2 could be least as m2>m1 doesn't necessarily imply k2>k1.
%o A395071         m1 += 1
%o A395071     k_sorted = sorted(list(k_set))
%o A395071     k_trunc = k_sorted[:term_count]
%o A395071     return k_trunc
%Y A395071 Subsequence of A010342.
%Y A395071 Cf. A000045 (Fibonacci).
%K A395071 nonn,new
%O A395071 1,1
%A A395071 _Asher Shmidov_, Apr 10 2026
