%N A395796 Expansion of -1/(Sum_{k>=0} binomial(4*k+1,k) * x^k).
%F A395796 G.f.: -1/B(x) where B(x) is the g.f. of A052203.
%F A395796 G.f.: (3*g-4)/g^2 where g = 1+x*g^4 is the g.f. of A002293.
%F A395796 a(n) = (1/n) * (5*binomial(4*n-3,n-1) - 3*binomial(4*n-3,n-2)) for n > 0.
%F A395796 a(n) = (1/n) * (8*binomial(4*n-3,n-1) - 3*binomial(4*n-2,n-1)) for n > 0.
%o A395796 (PARI) my(N=30, x='x+O('x^N)); Vec(-1/sum(k=0, N, binomial(4*k+1, k)*x^k))
