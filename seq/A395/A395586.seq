%S A395586 0,1,4,21,105,533,2702,13703,69492,352419,1787243,9063753,45965556,
%T A395586 233107893,1182174100,5995230729,30403974757,154189508765,
%U A395586 781950544402,3965552901675,20110747320996,101988844389927,517222170512439,2623019951543057,13302279094835272
%N A395586 a(n) = floor(r*(a(n-1)+a(n-2))), a(0) = 0, a(1) = 1 and r = 2 + sqrt(5).
%C A395586 r is the 4th metallic ratio, the copper ratio, A098317.
%C A395586 In general, for r is the m-th metallic ratio, the linear recurrence has signature (m+1, 1, 1-m, -1, -1).
%H A395586 Wikipedia, <a href="https://en.wikipedia.org/wiki/Metallic_mean">Metallic mean</a>.
%H A395586 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (5,1,-3,-1,-1).
%F A395586 a(n) = A004976(a(n-1) + a(n-2)).
%F A395586 Limit_{n -> oo} a(n)/a(n-1) = A394046.
%F A395586 Limit_{n -> oo} a(n)/a(n+1) = A298752-1.
%F A395586 G.f.: -x * (x^3 + x - 1) / ((x - 1) * (x^4 + 2*x^3 + 5*x^2 + 4*x - 1)). - _Amiram Eldar_, May 08 2026
%t A395586 LinearRecurrence[{5, 1, -3, -1, -1}, {0, 1, 4, 21, 105}, 25] (* _Amiram Eldar_, May 08 2026 *)
