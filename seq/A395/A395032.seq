%p A395032 T := (n, k) -> ifelse(k = 0, 1, binomial(n, k) * binomial(2*n + 2, k) * 2^(k - 2) / (k + 1)):
%p A395032 seq(seq(T(n, k), k = 0..n), n = 0..8);
