%I A395070 #18 Apr 27 2026 22:47:43
%S A395070 3,3,2,3,6,4,10,6,4,5,6,4,3,6,2,4,3,5,3,4,4,6,2,6,2,8,3,3,8,8,6,3,5,3,
%T A395070 4,4,3,3,3,2,4,4,2,2,4,2,3,4,4,3,5,6,3,3,2,4,2,3,3,6,4,4,15,2,4,2
%N A395070 a(n) is the exponent of the highest power of 2 dividing e(n), where e(n) is the n-th even term of A000927.
%H A395070 Gilbert Fung, Andrew Granville, and Hugh C. Williams, <a href="https://dms.umontreal.ca/~andrew/PDF/Compute1stFactor.pdf">Computation of the First Factor of the Class Number of Cyclotomic Fields</a>, Journal of Number Theory, Vol. 42, No. 3 (1992), pp. 297-312.
%H A395070 Wikipedia, <a href="https://en.wikipedia.org/wiki/Maillet%27s_determinant">Maillet's determinant</a>.
%o A395070 (PARI)
%o A395070 allocatemem(10^9);
%o A395070 b(k) = {if(k > 1, my(p = prime(k), detM = abs(matdet(matrix((p-1)/2, (p-1)/2, i, j, i/j%p)))); if(!(detM%2), print1(valuation(detM, 2), ", ")))};
%o A395070 for(i = 2, 100, b(i));
%Y A395070 Cf. A000927, A338023.
%K A395070 nonn,more,new
%O A395070 1,1
%A A395070 _Arkadiusz Wesolowski_, Apr 10 2026
