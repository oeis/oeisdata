%U A395840 5380606395475135306,314154363629879389571,19419136023851828265243,1267143128006296225753950,87054423336761709723543841,6281881918029069985404053243
%N A395840 Expansion of g.f. A(x) satisfying a(n) = [x^(n-1)] A(x)^(2*n+1) for n >= 1.
%H A395840 Paul D. Hanna, <a href="/A395840/b395840.txt">Table of n, a(n) for n = 0..300</a>
%F A395840 Given g.f. A(x) = Sum_{n>=0} a(n)*x^n, let B(x) be the g.f. of A395841, then the following formulas hold.
%F A395840 (1) a(n) = [x^(n-1)] A(x)^(2*n+1) for n >= 1.
%F A395840 (2) a(n) = (2*n+1)/3 * [x^(n-1)] B(x)^3 for n >= 1.
%F A395840 (3) A(x) = 1 + x*B(x)^3 + 2*x^2*B(x)^2*B'(x).
%F A395840 (4) A(x) = B(x/A(x)^2).
%F A395840 (5) A(x) = sqrt( x / Series_Reversion(x*B(x)^2) ).
%F A395840 (6) B(x) = A(x*B(x)^2).
%F A395840 (7) B(x) = sqrt( (1/x) * Series_Reversion(x/A(x)^2) ).
%e A395840 G.f.: A(x) = 1 + x + 5*x^2 + 56*x^3 + 948*x^4 + 20768*x^5 + 546637*x^6 + 16591400*x^7 + 566264968*x^8 + 21374222995*x^9 + ...
%e A395840 The table of coefficients of x^k in A(x)^(2*n+1) begins
%e A395840   n = 1: [1,  3,  18,  199,  3270,  69915, ...];
%e A395840   n = 2: [1,  5,  35,  390,  6265, 130931, ...];
%e A395840   n = 3: [1,  7,  56,  637, 10073, 206178, ...];
%e A395840   n = 4: [1,  9,  81,  948, 14850, 298386, ...];
%e A395840   n = 5: [1, 11, 110, 1331, 20768, 410685, ...];
%e A395840   n = 6: [1, 13, 143, 1794, 28015, 546637, ...]; ...
%e A395840 in which the main diagonal equals this sequence shift left.
%e A395840 RELATED SERIES.
%e A395840 The g.f. of A395841 begins
%e A395840 B(x) = 1 + x + 7*x^2 + 91*x^3 + 1650*x^4 + 37335*x^5 + 997004*x^6 + 30419531*x^7 + 1038685706*x^8 + ...
%e A395840 where A(x) = B(x/A(x)^2).
%o A395840 (PARI) {a(n) = my(A=[1]); for(i=1, n, A = concat(A, 0);
%o A395840 A[#A] = -polcoeff( Ser(A) - x*Ser(A)^(2*#A-1), #A-1)); GF=Ser(A); A[n+1]}
%o A395840 {upto(n) = a(n); Vec(GF)}
%o A395840 upto(20)
%Y A395840 Cf. A395841, A361048.
%K A395840 nonn,new
%O A395840 0,3
