%I A395002 #25 Apr 22 2026 16:30:53
%S A395002 1,8,22,32,205,608,1414,8192,26122,78848,435292,1490432,5297149,
%T A395002 28633088,104775430,416448512,2237912062,8699445248,37537384276,
%U A395002 202331389952,830599212946,3819834441728,20761206768412,89520879828992,433503401086900,2383252716781568
%N A395002 Number of index 4*n subgroups of SL_2(Z) not containing the negative identity matrix.
%C A395002 Recall that SL_2(Z) is generated by the matrices S and T, where S = [[0, -1], [1, 0]] and T = [[1, 1], [0, 1]] (read by columns); and S^2 = (ST)^3 = -I.
%C A395002 The number of subgroups for 4*n+{1,2,3} is 0, hence sequence is only for 4*n.
%H A395002 Paolo Xausa, <a href="/A395002/b395002.txt">Table of n, a(n) for n = 1..949</a>
%H A395002 Wilfried Imrich, <a href="https://doi.org/10.1007/BF01226441">On the number of subgroups of given index in SL_2(Z)</a>, Archiv der Mathematik, vol. 31, 1978, pp. 224-231.
%F A395002 a(n) = 2*a(n-2) + 4*n*a(n-3) + Sum_{i = 1 .. n-4} a(i)*a(n-3-i) (Theorem 1 from Imrich).
%F A395002 a(n) ~ sqrt((8/3)*Pi)*exp((n/3)*log(4*n)-n/3+(n/2)^(1/3)+(1/2)*log(n)) (Theorem 5 from Imrich).
%p A395002 a := proc(n) option remember: local i: if n < 4 then [1, 8, 22][n]:
%p A395002 else 2*a(n-2)+4*n*a(n-3)+add(a(i)*a(n-3-i), i = 1 .. n-4): fi: end:
%p A395002 seq(a(n), n = 1 .. 26);
%t A395002 A395002[n_] := A395002[n] = If[n <= 3, {1, 8, 22}[[n]], 2*A395002[n-2] + 4*n*A395002[n-3] + Sum[A395002[i]*A395002[n-3-i], {i, n-4}]];
%t A395002 Array[A395002, 30] (* _Paolo Xausa_, Apr 22 2026 *)
%Y A395002 Cf. A005133.
%K A395002 nonn,new
%O A395002 1,2
%A A395002 _Lorenzo Sauras Altuzarra_, Apr 09 2026
