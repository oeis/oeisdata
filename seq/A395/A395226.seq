%I A395226 #16 May 02 2026 16:10:31
%S A395226 0,0,1,2,3,4,5,6,5,6,7,8,7,6,8,6,7,8,9,8,5,6,6,6,6,8,9,8,8,10,9,8,5,4,
%T A395226 8,6,6,6,4,6,8,8,9,8,8,8,6,8,7,8,9,4,5,2,2,8,4,4,6,4,6,4,0,6,8,10,10,
%U A395226 8,11,8,8,8,6,10,8,2,8,4,7,8,7,8,2,2,5
%N A395226 a(n) = number of 4-tuples (w, x, y, z) such that w*x + y*z = n, where w, x, y, z are positive Fibonacci numbers satisfying w <= x and y <= z.
%H A395226 Vincenzo Librandi, <a href="/A395226/b395226.txt">Table of n, a(n) for n = 0..10000</a>
%e A395226 a(8) = 5 counts these 4-tuples: (1, 2, 2, 3), (1, 3, 1, 5), (2, 2, 2, 2), (1, 5, 1, 3), (2, 3, 1, 2).
%t A395226 fQ[n_] := fQ[n] = IntegerQ[Sqrt[5 n^2 + 4]] || IntegerQ[Sqrt[5 n^2 - 4]];
%t A395226 f[n_] := f[n] = Map[{#, n/#} &, Select[Divisors[n], # <= n/# &]];
%t A395226 s[n_] := Cases[Flatten[Table[Tuples[{f[k], f[n - k]}], {k, 1, n - 1}], 1], {{w_, x_}, {y_, z_}} :> {w, x, y, z}];
%t A395226 t = Join[{0},Table[Select[s[n], AllTrue[#, fQ] && #[[1]] <= #[[2]] && #[[3]] <= #[[4]] &], {n, 1, 160}]];
%t A395226 Map[Length, t]
%t A395226 (* _Peter J. C. Moses_, Apr 02 2026 *)
%t A395226 (* Alternative: *)
%t A395226 fibQ[n_]:=IntegerQ[Sqrt[5 n^2+4]]||IntegerQ[Sqrt[5 n^2-4]]; f[n_]:=Count[Select[Divisors[n],fibQ],d_/;fibQ[n/d]&&d<=n/d]; a[n_]:=Sum[f[k] f[n-k],{k,1,n-1}]; Table[a[n],{n,1,100}] (* _Vincenzo Librandi_, Apr 26 2026 *)
%o A395226 (Magma) F := func<m | IsSquare(5*m^2+4) or IsSquare(5*m^2-4)>; a := function(n) c := 0;
%o A395226 for k in [1..n-1] do for d in Divisors(k) do for e in Divisors(n-k) do if d le k
%o A395226 div d and e le (n-k) div e and F(d) and F(k div d) and F(e) and F((n-k) div e) then
%o A395226 c +:= 1; end if; end for; end for; end for; return c; end function; [a(n):n in [1..100]]; // _Vincenzo Librandi_, Apr 26 2026
%Y A395226 Cf. A395227, A395228, A395229, A395230.
%K A395226 nonn,new
%O A395226 0,4
