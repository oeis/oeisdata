%N A395343 a(n) = (2*n)! * [x^(2*n)] (cosh(x/2) / cos(x/2))^2.
%F A395343 a(n) = (2*n)! * [x^(2*n)] (1 + cosh(x)) / (1 + cos(x)).
%F A395343 a(n) = (1/2) * (0^n + 1 - Sum_{k=0..n-1} (-1)^(n-k) * binomial(2*n,2*k) * a(k)).
%F A395343 a(n) = (1/(2*4^n)) * Sum_{k=0..n} (0^(n-k) + 4^(n-k)) * binomial(2*n,2*k) * A000182(k+1).
%o A395343 (PARI) a000182(k) = 2^(2*k)*(2^(2*k)-1)*abs(bernfrac(2*k))/(2*k);
%o A395343 a(n) = sum(k=0, n, (0^(n-k)+4^(n-k))*binomial(2*n, 2*k)*a000182(k+1))/(2*4^n);
