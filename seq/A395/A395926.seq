%I A395926 #26 May 14 2026 00:07:30
%S A395926 1125000,1625000,2125000,2625000,3125000,3375000,3625000,4125000,
%T A395926 4625000,5125000,5625000,6125000,6375000,6625000,7125000,7625000,
%U A395926 8125000,8625000,9125000,9225000,9375000,9625000,10125000,10625000,11250000,13125000,16250000,20125000
%N A395926 Grand-grand-kangaroo numbers: kangaroo numbers whose inner number is a grand-kangaroo number (A395761).
%C A395926 If k is a term then 10*k is a term. - _David A. Corneth_, May 10 2026
%H A395926 Mickaël Launay, <a href="https://www.lemonde.fr/sciences/article/2026/04/18/nombres-kangourous-l-enigme-maths-du-monde-n-97_6681126_1650684.html">Nombres kangourous, l’énigme maths du « Monde » nᵒ 97</a>
%e A395926 1125000 is a term since it is a multiple of 12500 (115000 = 12500 * 90), 12500 (grand-kangaroo number) is itself a multiple of 250 (12500 = 250 * 50) and 250 (kangaroo number) is itself a multiple of 5 (250 = 5 * 50).
%t A395926 joey[k_] := FromDigits@ IntegerDigits[k][[2 ;; -2]];
%t A395926 kangQ[k_] := k > 99 && With[{m = joey[k]}, m > 0 && Divisible[k, m]];
%t A395926 q[k_] := k > 10^6 && kangQ[k] && kangQ[joey[k]] && kangQ[joey[joey[k]]]; Select[Range[10^6, 10^7], q] (* _Amiram Eldar_, May 10 2026 *)
%o A395926 (Python)
%o A395926 def joey(n): return int(str(n)[1:-1]) if n > 99 else 0
%o A395926 def kangaroo(n): return n > 99 and (j:=joey(n)) > 0 and n%j == 0
%o A395926 def ok(n): return n > 99999 and kangaroo(n) and kangaroo(joey(n)) and kangaroo(joey(joey(n)))
%o A395926 print([k for k in range(2*10**7) if ok(k)]) # _Michael S. Branicky_, May 10 2026
%Y A395926 Cf. A395720, A395761.
%K A395926 nonn,base,new
%O A395926 1,1
%A A395926 _Carole Dubois_, May 10 2026
