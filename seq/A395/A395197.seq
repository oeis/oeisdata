%e A395197   2799   10672200 = 2^3 * 3^2 * 5^2 * 7^2 * 11^2
%t A395197 nn = 2^15; s = Union@ Flatten@ Table[a^2*b^3, {b, Surd[nn, 3]}, {a, Sqrt[nn/b^3]}]; Select[s, And[Length[#] > 2, AnyTrue[#, # > 2 &]] &@ FactorInteger[#][[;; , -1]] &]
