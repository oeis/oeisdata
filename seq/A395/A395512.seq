%S A395512 1,2,4,6,10,12,20,22,30,34,42,44,72,74,82,90,106,108,136,138,166,174,
%T A395512 182,184,276,280,288,296,324,326,416,418,450,458,466,474,626,628,636,
%U A395512 644,736,738,828,830,858,886,894,896,1188,1192,1220,1228,1256,1258,1350
%N A395512 Number of lcm-closed subsets of [n].
%C A395512 A set S is lcm-closed if for all x,y in S also lcm(x,y) is in S.
%H A395512 Alois P. Heinz, <a href="/A395512/b395512.txt">Table of n, a(n) for n = 0..1000</a>
%F A395512 a(p) = a(p-1) + 2 for prime p.
%F A395512 a(s) = a(s-1) + 4 for s in { A001248 }.
%e A395512 a(5) = 12: {}, {1}, {2}, {3}, {4}, {5}, {1,2}, {1,3}, {1,4}, {1,5}, {2,4}, {1,2,4}.
%p A395512 b:= proc(n, s) option remember; `if`(n=0, {s}, b(n-1, s) union
%p A395512      `if`(andmap(x-> ilcm(x, n) in s, s), b(n-1, s union {n}), {}))
%p A395512     end:
%p A395512 a:= proc(n) option remember; `if`(n=0, 1, a(n-1)+nops(b(n-1, {n}))) end:
%p A395512 seq(a(n), n=0..54);
%o A395512 (Python)
%o A395512 from functools import cache
%o A395512 from math import lcm
%o A395512 def b(n, s):
%o A395512     if n==0: return {s}
%o A395512     return b(n-1, s) | (b(n-1, s+(n,)) if all(lcm(x, n) in s for x in s) else set())
%o A395512 @cache
%o A395512 def a(n): return 1 if n==0 else a(n-1)+len(b(n-1, (n,)))
%o A395512 print([a(n) for n in range(55)]) # _Michael S. Branicky_, Apr 26 2026 after _Alois P. Heinz_
%Y A395512 Cf. A000040, A001248, A003990, A051173, A109042, A395489.
%K A395512 nonn,new
%O A395512 0,2
