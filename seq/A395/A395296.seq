%N A395296 a(n) = (2*n)! * [x^(2*n)] cosh(x)^3 / cos(x).
%F A395296 a(n) = (3 + 9^n)/4 - Sum_{k=0..n-1} (-1)^(n-k) * binomial(2*n,2*k) * a(k).
%o A395296 (PARI) a_vector(n) = my(v=vector(n+1)); for(i=0, n, v[i+1]=(3+9^i)/4-sum(j=0, i-1, (-1)^(i-j)*binomial(2*i, 2*j)*v[j+1])); v;
