%U A395206 3301392542765404011724800000,9753450102655318719886786560000,34158406495145697860977486725120000,139935446125707791138289350344704000000
%N A395206 a(n) = (2*n)! * [x^(2*n)] (f(x)^4 + f(-x)^4)/2 and f(x) = 1/sqrt(1 + 2*sqrt(2)*x + x^2).
%F A395206 a(n) = (2*n)! * [x^(2*n)] (1 + 10*x^2 + x^4)/(1 - 6*x^2 + x^4)^2.
%F A395206 Let A(n,k) = (2*n)! * [x^(2*n)] (f(x)^k + f(-x)^k)/2. A(0,k) = 1 and A(n,k) = k*(k+2) * A(n-1,k+4) + k*(k+1) * A(n-1,k+2) for n > 0. a(n) = A(n,4).
%o A395206 (PARI) a(n) = my(x='x+O('x^(2*n+1))); (2*n)!*polcoef((1+10*x^2+x^4)/(1-6*x^2+x^4)^2, 2*n);
%Y A395206 Column k=4 of A395201.
%K A395206 nonn
%O A395206 0,2
