%I A395824 #24 May 11 2026 14:53:14
%S A395824 1,2,3,4,5,7,9,12,13,15,17,18,19,20,24,28,33,34,35,37,38,41,44
%N A395824 Record lengths of runs of consecutive integers k such that Omega(k) is even.
%C A395824 Equivalently, record lengths of runs where the Liouville function A008836(k) is 1.
%C A395824 For m >= 1, let r(m) be the largest k >= 0 such that A001222(m), ..., A001222(m+k-1) are even. This sequence lists the successive record values of r(m).
%e A395824 The first record runs have lengths 1, 2, 3, 4, 5 and occur at 1..1, 9..10, 14..16, 33..36, 54..58.
%o A395824 (Python)
%o A395824 from sympy import factorint
%o A395824 A001222 = []
%o A395824 for i in range(1, 10**7 + 1):
%o A395824     A001222.append(sum(factorint(i).values()))
%o A395824 seq_record_length_even = []
%o A395824 even_record = 0
%o A395824 counter = 0
%o A395824 for i in A001222:
%o A395824     if i%2==0:
%o A395824         counter += 1
%o A395824     else:
%o A395824         if counter > even_record:
%o A395824             even_record = counter
%o A395824             seq_record_length_even.append(counter)
%o A395824         counter = 0
%o A395824 print(seq_record_length_even)
%Y A395824 Cf. A001222, A395823, A066829, A028260, A066793.
%K A395824 nonn,more,new
%O A395824 1,2
%A A395824 _Anselm Hudde_, May 07 2026
