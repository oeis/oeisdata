%N A395924 Number of rectangular plane partitions of n with exactly 2 rows.
%F A395924 G.f.: Sum_{k>=1} q^(2*k) * Product_{i=1..2} Product_{j=1..k} 1/(1 - q^(i+j-1)).
%e A395924 The a(5) = 3 matrices:
%e A395924   [4] [3] [2 1]
%e A395924   [1] [2] [1 1]
%o A395924 (PARI) my(N=50, q='q+O('q^N)); concat([0, 0], Vec(sum(k=1, N, q^(2*k)*prod(i=1, 2, prod(j=1, k, 1/(1-q^(i+j-1)))))))
