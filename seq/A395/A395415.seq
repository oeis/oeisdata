%N A395415 a(n) is the smallest n-simplex number that has exactly n prime factors, counted with multiplicity.
%C A395415 Also smallest m of the form binomial(n+k-1, n), where k > 0, so that A001222(m) = n.
%H A395415 Hoang Nguyen, <a href="/A395415/b395415.txt">Table of n, a(n) for n = 1..100</a>
%F A395415 a(n) = binomial(n+A396215(n)-1, n).
%e A395415 For n = 1, the smallest 1-simplex number (positive integer) with 1 prime factor is 2, so a(1) = 2.
%e A395415 For n = 3, the smallest 3-simplex number (tetrahedral number) with 3 prime factors is 20, so a(3) = 20.
%t A395415 a[n_] := Module[{k = 1}, While[PrimeOmega[Binomial[n + k - 1, n]] != n, k++]; Binomial[n + k - 1, n]]; Array[a, 21] (* _Amiram Eldar_, May 21 2026 *)
%o A395415 (Julia)
%o A395415 using Primes
%o A395415 function a(n)
%o A395415     x = big(1)
%o A395415     while true
%o A395415         num = prod(x + i for i in 0:n-1) ÷ factorial(big(n))
%o A395415         if length(factor(Vector, num)) == n
%o A395415             return num
%o A395415         end
%o A395415         x += 1
%o A395415     end
%o A395415 end
%o A395415 (Python)
%o A395415 from math import comb
%o A395415 from itertools import count
%o A395415 from collections import deque
%o A395415 from sympy import factorint
%o A395415 def A395415(n):
%o A395415     a = deque([sum(factorint(i).values()) for i in range(1,n+1)])
%o A395415     b = n+sum(a)
%o A395415     for k in count(n+1):
%o A395415         if sum(a)==b:
%o A395415             return comb(k-1,n)
%o A395415         a.popleft()
%o A395415         a.append(sum(factorint(k).values())) # _Chai Wah Wu_, May 21 2026
