%N A395665 Expansion of g^6/(5-4*g)^4, where g = 1+x*g^5 is the g.f. of A002294.
%F A395665 G.f.: (Sum_{k>=0} binomial(5*k+2,k) * x^k) * (Sum_{k>=0} binomial(5*k,k) * x^k)^3.
%F A395665 Sum_{k>=1} a(k-1) * x^k/k^2 = (1/10) * log( Sum_{k>=0} binomial(5*k+5,k) * x^k ).
%F A395665 a(n) = ((n+1)/10) * (binomial(5*n+4,n) + Sum_{k=0..n+1} 4^(n+1-k) * binomial(5*n+5,k)).
%o A395665 (PARI) a(n) = (n+1)*(binomial(5*n+4, n)+sum(k=0, n+1, 4^(n+1-k)*binomial(5*n+5, k)))/10;
