%I A395302 #7 Apr 20 2026 00:44:50
%S A395302 1799820,32623271698080,13128936616100760,259392069521711280,
%T A395302 36315529922787340800,117461585894352834420,126565331933222396760,
%U A395302 1151453682528533014800,2361939147567479394720,3414380885231627520000,4145418481480794015300,7503058097835894835200,16606374863882117957280
%N A395302 Numbers k that are a*b*c*r for some primitive Pythagorean triple (a,b,c) with inradius r such that 2*k +- 1 and 5*k +- 1 are twin prime pairs.
%H A395302 Robert Israel, <a href="/A395302/b395302.txt">Table of n, a(n) for n = 1..315</a>
%e A395302 a(1) = 1799820 is a term because it is the product of the sides (99, 20, 101) and inradius 9 of a primitive Pythagorean triple and 2*1799820+-1 = 3599639 and 3599641 and 3*1799820+-1 = 8999099 and 8999101 are all prime.
%p A395302 N:= 10^23: # for terms <= N
%p A395302 R:= {}:
%p A395302 for m from 1 while 2*(m-1)^2*(m+1)*m*(m^2+1) <= N do
%p A395302   for n from 1 + (m mod 2) to m-1 by 2 do
%p A395302     v:= 2*(m-n)^2 * (m+n)*m*n^2*(m^2+n^2);
%p A395302     if v/(m-n)^2 > N then break fi;
%p A395302     if v <= N and igcd(m,n) = 1 and andmap(isprime,[2*v-1,2*v+1,5*v-1,5*v+1]) then
%p A395302        R:= R union {v};
%p A395302 fi od od:
%p A395302 sort(convert(R,list));
%Y A395302 Intersection of A393526 and A395198.
%K A395302 nonn,new
%O A395302 1,1
%A A395302 _Will Gosnell_ and _Robert Israel_, Apr 19 2026
