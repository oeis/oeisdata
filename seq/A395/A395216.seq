%U A395216 1311161072449806104077175625,5197766162779913140792304555625,24721993179513170562351592437800625,138944861938899421852917299018079515625
%N A395216 a(n) = (2*n)! * [x^(2*n)] 1/sqrt((1 - x)*(1 - 3*x)).
%F A395216 Let A(n,k) = (2*n)! * [x^(2*n)] 1/((1 - x)*(1 - 3*x))^(k/2). A(0,k) = 1 and A(n,k) = k*(k+2) * A(n-1,k+4) + 3*k*(k+1) * A(n-1,k+2) for n > 0. a(n) = A(n,1).
%F A395216 a(n) = (2*n)! * Sum_{k=0..n} 16^k * (-3)^(n-k) * binomial(n+k-1/2,n+k) * binomial(n+k,2*k).
%o A395216 (PARI) a(n) = my(x='x+O('x^(2*n+1))); (2*n)!*polcoef(1/sqrt((1-x)*(1-3*x)), 2*n);
%Y A395216 Column k=1 of A395215.
%K A395216 nonn,new
%O A395216 0,2
