%I A395604 #63 Jul 08 2026 23:07:18
%S A395604 1,4,1,16,7,2,64,37,18,6,256,175,110,60,24,1024,781,570,390,240,120,
%T A395604 4096,3367,2702,2100,1560,1080,720,16384,14197,12138,10206,8400,6720,
%U A395604 5040,5040,65536,58975,52670,46620,40824,35280,30240,20160,40320
%N A395604 Triangle read by rows: T(n,k) = Sum_{j=0..k} (-1)^j * binomial(k,j) * (4-j)^n.
%H A395604 Donald E. Knuth, <a href="https://arxiv.org/abs/math/9207222">Johann Faulhaber and Sums of Powers</a>, arXiv:9207222 [math.CA], 1992.
%H A395604 Petro Kolosov, <a href="https://github.com/kolosovpetro/SumsOfPowersViaBackwardFiniteDifferencesAndNewtonFormula/tree/main/mathematica">Mathematica programs</a>, GitHub, 2026.
%H A395604 Petro Kolosov, <a href="https://doi.org/10.5281/zenodo.21046515">Sums of powers via backward finite differences and Newton's formula</a>, Zenodo, 2026. See p. 7.
%F A395604 T(n,k) = Sum_{j=k..n} binomial(4-k, j-k) * Stirling2(n, j) * j!.
%F A395604 T(n,k) = Sum_{j=0..n} E(n,j) * binomial(4+j-k, n-k), where E(n,j) are Eulerian numbers (Cf. A173018).
%F A395604 Let F(t, n, k) = Sum_{j=0..k} (-1)^j * binomial(k,j) * (t-j)^n, then
%F A395604 F(0, n, k) = A278075(n,k),
%F A395604 F(1, n, k) = A389570(n,k),
%F A395604 F(2, n, k) = A391068(n,k),
%F A395604 F(3, n, k) = A391210(n,k),
%F A395604 F(4, n, k) = T(n,k) (this sequence).
%F A395604 Let S_m(n) be a sum of powers: S_m(n) = 1^m + 2^m + 3^m + ... + n^m, then
%F A395604 S_m(n) = Sum_{j=0..m} T(m,j) * ( (-1)^j*binomial(4,j+1) + binomial(n+j-4,j+1) ).
%e A395604 Triangle begins:
%e A395604   [0]     1;
%e A395604   [1]     4,     1;
%e A395604   [2]    16,     7,     2;
%e A395604   [3]    64,    37,    18,     6;
%e A395604   [4]   256,   175,   110,    60,   24;
%e A395604   [5]  1024,   781,   570,   390,  240,  120;
%e A395604   [6]  4096,  3367,  2702,  2100, 1560, 1080,  720;
%e A395604   [7] 16384, 14197, 12138, 10206, 8400, 6720, 5040, 5040;...
%t A395604 (* Prints T(n,k) as triangle *)
%t A395604 T1[t_,n_, k_] := Sum[(-1)^j*Binomial[k, j]*(t - j)^n, {j, 0, k}];Table[T1[4, n, k], {n, 0, 10}, {k, 0, n}] // Flatten
%t A395604 (* Alternative: T(n,k) in Stirling form *)
%t A395604 T2[t_, n_, k_] := Sum[Binomial[t - k, j - k]*StirlingS2[n, j]*j!, {j, k, n}];Table[T2[4, n, k], {n, 0, 10}, {k, 0, n}] // Flatten
%t A395604 (* Alternative: T(n,k) in Eulerian form *)
%t A395604 Eulerian[n_, k_] := Sum[(-1)^s*Binomial[n + 1, s]*(k + 1 - s)^n, {s, 0, k}];
%t A395604 T3[t_, n_, k_] := Sum[Eulerian[n, j]*Binomial[t + j - k, n - k], {j, 0, n}];Table[T3[4, n, k], {n, 0, 10}, {k, 0, n}] // Flatten
%Y A395604 Row sums give A000351.
%Y A395604 Main diagonal gives A000142.
%Y A395604 Columns k=0..1 give: A000302, A005061.
%Y A395604 Cf. A278075, A131689, A389570, A391068, A391210, A173018.
%K A395604 sign,tabl
%O A395604 0,2
