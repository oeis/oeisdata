%U A395289 220687547812422836917500651379553,15764564819948344309471420859821580227,1398454409757517775020864823322035690277113
%N A395289 a(n) = (2*n)! * [x^(2*n)] cos(2*x) * cos(3*x) * cos(4*x) / cos(24*x).
%F A395289 a(n) = (-1)^n * (1 + 9^n + 25^n + 81^n)/4 - Sum_{k=0..n-1} (-576)^(n-k) * binomial(2*n,2*k) * a(k).
%o A395289 (PARI) a_vector(n, s=2, t=3, u=4) = my(v=vector(n+1)); for(i=0, n, v[i+1]=(-1)^i*((s+t+u)^(2*i)+(s+t-u)^(2*i)+(s-t+u)^(2*i)+(s-t-u)^(2*i))/4-sum(j=0, i-1, (-(s*t*u)^2)^(i-j)*binomial(2*i, 2*j)*v[j+1])); v;
