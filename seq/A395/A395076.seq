%T A395076 6,4,1,4,7,8,8,7,5,7,9,9,8,9,10,10,9,7,4,0,5,2,5,8,6,8,10,11,11,10,8,
%U A395076 5,1,5,9,11,12,12,11,9,6,3,6,9,12,13,13,12
%N A395076 Lexicographically earliest nonnegative sequence, where all subsequences longer than 1 term are unique and |a(n)-a(n+1)| is minimal.
%C A395076 After a 0 there is the number of 0 so far minus 1. - _David A. Corneth_, May 15 2026
%e A395076 a(0) = 0, because it is the earliest nonnegative term.
%e A395076 a(1) = 0, because difference |a(n)-a(n+1)| is minimal.
%e A395076 a(2) = 1, because for 0,0,0 the subsequence "0,0" already appeared.
%e A395076 a(3) = 1, because difference |a(n)-a(n+1)| is minimal.
%e A395076 a(4) = 0, because 1,1 already appeared and |a(n)-a(n+1)| is minimal and lexicographically earliest value.
%o A395076 (Python)
%o A395076 def generate_sequence(n):
%o A395076   seq = [0]
%o A395076   seen_pairs = set()
%o A395076   for _ in range(n):
%o A395076     current = seq[-1]
%o A395076     d = 0
%o A395076     while True:
%o A395076       if current - d >= 0 and (current, current - d) not in seen_pairs:
%o A395076         next_term = current - d
%o A395076         break
%o A395076       if current + d >= 0 and (current, current + d) not in seen_pairs:
%o A395076         next_term = current + d
%o A395076         break
%o A395076       d += 1
%o A395076     seen_pairs.add((current, next_term))
%o A395076     seq.append(next_term)
%o A395076   return seq
%o A395076 print(generate_sequence(90))
%K A395076 nonn,new
%O A395076 0,6
