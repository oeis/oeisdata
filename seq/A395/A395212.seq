%S A395212 5,1925,8721,1784066921,394420000,373939020120748797,
%T A395212 326830530482421875,7747677348354274898150511341447,
%U A395212 566526949763995730335480704,1727769626708874444344994079974959642034384025,365749502814777542464206874203812471808,1005851201123717631911518346060459180689297947065534402023735625
%N A395212 Denominator of the probability that the unique (n-1)-sphere passing through n+1 points, selected independently and uniformly at random in an n-ball, is entirely contained within that n-ball.
%C A395212 The probability that the n+1 points lie on the same (n-1)-hyperplane and do not define an (n-1)-sphere is 0.
%H A395212 Amiram Eldar, <a href="/A395212/b395212.txt">Table of n, a(n) for n = 2..56</a>
%H A395212 Fernando Affentranger, <a href="https://doi.org/10.1007/BF01199118">Random spheres in a convex body</a>, Archiv der Mathematik, Vol. 55 (1990), pp. 74-81.
%e A395212 Fractions begin with 2/5, 24*Pi^2/1925, 286/8721, 144000*Pi^4/1784066921, 682341/394420000, 137682944000*Pi^6/373939020120748797, 22222514956802/326830530482421875, 10083790436267520000000*Pi^8/7747677348354274898150511341447, ...
%t A395212 a[n_] := Denominator[2^(n^2) * n^(n+1) * Pi^(n/2-1) * Gamma[n/2]^n * Gamma[n] * Gamma[(n^2+1)/2]^2 / (Gamma[(n+1)/2]^n * Gamma[n^2+n+1])]; Array[a, 12, 2]
%o A395212 (PARI) gamma_my(n) = if(denominator(n) == 1, (n-1)!, my(m = n - 1/2); (2*m)! / (4^m * m!)); \\ gamma for integers, gamma(n)/sqrt(Pi) for half-integers
%o A395212 a(n) = denominator(2^(n^2) * n^(n+1) * gamma_my(n/2)^n * gamma_my(n) * gamma_my((n^2+1)/2)^2 / (gamma_my((n+1)/2)^n * gamma_my(n^2+n+1)));
%Y A395212 Cf. A395211 (numerators), A395207, A395208, A395209, A395210, A395213, A395214.
%K A395212 nonn,frac,easy
%O A395212 2,1
