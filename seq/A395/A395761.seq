%I A395761 #21 May 13 2026 23:55:10
%S A395761 11155,11224,12444,12500,14178,14355,18348,21131,21177,21228,22448,
%T A395761 22500,23288,23391,24888,25137,31200,31248,31500,32193,32400,32488,
%U A395761 32500,34113,37500,38117,41132,41182,42262,42500,43155,43200,43392,45484,52117,52377,52500
%N A395761 Grand-kangaroo numbers: kangaroo numbes whose inner number is itself a kangaroo number (A395720).
%H A395761 Mickaël Launay, <a href="https://www.lemonde.fr/sciences/article/2026/04/18/nombres-kangourous-l-enigme-maths-du-monde-n-97_6681126_1650684.html">Nombres kangourous, l’énigme maths du « Monde » nᵒ 97</a>.
%e A395761 701622 is a term since it is a multiple of 162 (701622 = 162 * 4331) and 162 (kangaroo number) is itself a multiple of 6 (162 = 6 * 27).
%t A395761 kangQ[k_] := k > 99 && With[{m = FromDigits@ IntegerDigits[k][[2 ;; -2]]}, m > 0 && Divisible[k, m]];
%t A395761 q[k_] := k > 9999 && kangQ[k] && kangQ[FromDigits@ IntegerDigits[k][[2 ;; -2]]];
%t A395761 Select[Range[10000, 52500], q] (* _Amiram Eldar_, May 05 2026 *)
%o A395761 (Python)
%o A395761 def kangaroo(n): return n > 99 and (joey:=int(str(n)[1:-1])) and n%joey == 0
%o A395761 def ok(n): return n > 9999 and kangaroo(n) and kangaroo(joey:=int(str(n)[1:-1]))
%o A395761 print([k for k in range(10**5) if ok(k)]) # _Michael S. Branicky_, May 05 2026
%Y A395761 Cf. A395720.
%K A395761 nonn,base,new
%O A395761 1,1
%A A395761 _Carole Dubois_, May 05 2026
