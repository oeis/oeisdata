%N A395147 a(n) = (2*n)! * [x^(2*n)] C(x)^3, where C(x) satisfies C(x) = cosh( Integral C(x)^4 dx ).
%F A395147 Let A(n,k) = (2*n)! * [x^(2*n)] C(x)^k. A(0,k) = 1 and A(n,k) = k*(k+4) * A(n-1,k+8) - k*(k+3) * A(n-1,k+6) for n > 0. a(n) = A(n,3).
%o A395147 (PARI) a(n, k=3) = if(n==0, 1, k*(k+4)*a(n-1, k+8)-k*(k+3)*a(n-1, k+6));
%Y A395147 Column k=3 of A395146.
%Y A395147 Cf. A079484, A281184, A326328, A395174.
