%I A395408 #26 May 24 2026 19:31:27
%S A395408 2,23,839,28559,58451683124983302023,67453191674820837076799,
%T A395408 89828359697991704817001174223,
%U A395408 434183963760614910481440382013610344704609670485152062564927159
%N A395408 Primes of the form P(k)^2 - 2, where P(k) is the k-th Pell number.
%C A395408 a(n) = P_{k_n}^2 - 2 where k_n is the n-th odd index (starting from k=2, 3, 5, ...) such that the result is prime. It is proved that D_k can be prime only if k is odd, with the sole exception D_2 = 2.
%H A395408 Samuel Moulin, <a href="https://zenodo.org/records/20271558">Norm Forms of Pell Numbers: The Sequence P_k^2 - 2</a>
%e A395408 For n = 1, k = 2, P_2 = 2, a(1) = 2^2 - 2 = 2.
%e A395408 For n = 2, k = 3, P_3 = 5, a(2) = 5^2 - 2 = 23.
%e A395408 For n = 3, k = 5, P_5 = 29, a(3) = 29^2 - 2 = 839.
%o A395408 (Python)
%o A395408 from sympy import isprime
%o A395408 def pell(n):
%o A395408     if n == 0: return 0
%o A395408     a, b = 0, 1
%o A395408     for _ in range(2, n + 1):
%o A395408         a, b = b, 2*b + a
%o A395408     return b
%o A395408 print([pell(k)**2 - 2 for k in range(1, 100)
%o A395408        if (k % 2 == 1 or k == 2) and isprime(pell(k)**2 - 2)])
%Y A395408 Cf. A000040, A000129 (Pell numbers), A079291.
%K A395408 nonn,new
%O A395408 1,1
%A A395408 _Samuel Moulin_, May 19 2026
