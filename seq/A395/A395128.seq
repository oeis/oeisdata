%I A395128 #9 Apr 18 2026 17:36:49
%S A395128 111,112,115,122,124,126,128,132,135,144,155,162,168,175,184,212,216,
%T A395128 222,224,244,248,264,288,312,315,324,333,336,366,384,396,412,424,432,
%U A395128 444,448,488,515,555,612,624,636,648,666,672,728,735,777,784,816,824,848,864,888,936,999,1110,1111,1120
%N A395128 Numbers k that are the concatenation of three divisors of k.
%C A395128 Initial zeros are not allowed.
%H A395128 Robert Israel, <a href="/A395128/b395128.txt">Table of n, a(n) for n = 1..10000</a>
%e A395128 a(5) = 124 is a term because it is the concatenation of 1, 2 and 4, each of which divides 124.
%p A395128 filter:= proc(n) local i,j,a,b,c;
%p A395128    for i from 1 to ilog10(n)-1 do
%p A395128      a:= n mod 10^i;
%p A395128      if a < 10^(i-1) or n mod a <> 0 then next fi;
%p A395128      b:= (n-a)/10^i;
%p A395128      for j from 1 to ilog10(b) do
%p A395128        c:= b mod 10^j;
%p A395128        if c < 10^(j-1) or n mod c <> 0 then next fi;
%p A395128        b:= (b-c)/10^j;
%p A395128        if n mod b = 0 then return true fi;
%p A395128    od od;
%p A395128    false
%p A395128 end proc:
%p A395128 select(filter, [$111 .. 10^4]);
%t A395128 f[{a_,b_,c_}]:=FromDigits[Flatten[IntegerDigits/@{a,b,c}]];q[k_]:=ContainsAny[f/@Permutations[Flatten[Table[Drop[Divisors[k],-1],3]],{3}],{k}];Select[Range[1120],q] (* _James C. McMahon_, Apr 17 2026 *)
%Y A395128 Cf. A034838, A392961.
%K A395128 nonn,base
%O A395128 1,1
%A A395128 _Robert Israel_, Apr 12 2026
