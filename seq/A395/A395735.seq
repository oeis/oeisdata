%N A395735 Expansion of (Sum_{k>=0} binomial(5*k,k) * x^k)^4.
%F A395735 a(n) = Sum_{i,j,k,l >= 0 and i+j+k+l=n} binomial(5*i,i) * binomial(5*j,j) * binomial(5*k,k) * binomial(5*l,l).
%F A395735 G.f.: B(x)^4 where B(x) is the g.f. of A001449.
%F A395735 a(n) = Sum_{k=0..n} 4^k * binomial(k+2,2) * binomial(5*n+3,n-k).
%F A395735 a(n) = Sum_{k=0..n} 5^k * binomial(k+2,2) * binomial(5*n-k,n-k).
%F A395735 a(0) = 1; a(n) = (20/n) * Sum_{k=0..n-1} 4^k * binomial(k+4,4) * binomial(5*n+3,n-1-k).
%F A395735 a(0) = 1; a(n) = (20/n) * Sum_{k=0..n-1} 5^k * binomial(k+4,4) * binomial(5*n-2-k,n-1-k).
%o A395735 (PARI) a(n) = sum(k=0, n, 4^k*binomial(k+2, 2)*binomial(5*n+3, n-k));
