%I A395746 #12 May 11 2026 22:48:44
%S A395746 2,3,4,5,7,9,13,15,16,19,25,27,31,37,41,49,61,64,79,97,121,139,157,
%T A395746 169,181,199,211,229,271,289,307,313,331,337,367,379,421,439,499,547,
%U A395746 577,601,607,619,625,661,691,727,811,829,841,877,937,967,997,1009,1069
%N A395746 Numbers m such that A265388(m) = A007947(m*(2*m-1)).
%C A395746 For m>1, A265388(m) <= A007947(m*(2*m-1)). This sequence lists the indices where this inequality is tight.
%H A395746 Vincenzo Librandi, <a href="/A395746/b395746.txt">Table of n, a(n) for n = 1..226</a>
%t A395746 f[n_]:=Times@@(First/@FactorInteger[n]); g[n_]:=If[n==1,0,GCD@@Table[Binomial[2 n,2 k],{k,1,n-1}]]; Select[Range[1100],g[#]==f[# (2 #-1)]&] (* _Vincenzo Librandi_, May 07 2026 *)
%o A395746 (Python)
%o A395746 from math import prod
%o A395746 from itertools import count, islice
%o A395746 from sympy.ntheory.factor_ import digits
%o A395746 from sympy import primefactors
%o A395746 def A395746_gen(startvalue=1): # generator of terms >= startvalue
%o A395746     for n in count(max(startvalue,1)):
%o A395746         m = n*((k:=n<<1)-1)
%o A395746         l = (~m & m-1).bit_length()
%o A395746         ps = primefactors(m>>l)
%o A395746         if (prod(ps)<<bool(l))==(prod((p if sum(digits(k,p)[1:])==2 else 1) for p in ps)<<(not(n&-n)^n) if n>1 else 0):
%o A395746             yield n
%o A395746 A395746_list = list(islice(A395746_gen(),50))
%o A395746 (Magma) rad := function(n) return &*PrimeDivisors(n); end function; h := function(n)
%o A395746 return n eq 1 select 0 else GCD([Binomial(2*n,2*k) : k in [1..n-1]]); end function;
%o A395746 [m : m in [1..1100] | h(m) eq rad(m*(2*m-1))]; // _Vincenzo Librandi_, May 07 2026
%Y A395746 Cf. A007947, A265388.
%K A395746 nonn,new
%O A395746 1,1
%A A395746 _Chai Wah Wu_, May 05 2026
