%I A395962 #14 May 19 2026 19:44:59
%S A395962 0,2,4,6,8,10,12,14,17,19,21,23,25,27,29,31,32,34,36,38,40,42,44,46,
%T A395962 49,51,53,55,57,59,61,63,64,66,68,70,72,74,76,78,81,83,85,87,89,91,93,
%U A395962 95,96,98,100,102,104,106,108,110,113,115,117,119
%N A395962 Numbers k such that A395961(k) = 0.
%C A395962 The partition of {0, 1, ..., 2^M - 1} into this sequence and A395963 is a solution of the Prouhet-Tarry-Escott problem of degree |S_M| - 1, where S_M = { 0 <= p < M : p AND 3 = 0 }. The analogs at previous levels are A001969 and A000069 (classical evil/odious, for A010060 = T(a_0)), A158704 and A158705 (for A341389 = T^2(a_0)), and A395959 and A395960 (for A395958 = T^3(a_0)).
%H A395962 Benoit Cloitre, <a href="https://arxiv.org/abs/2604.06243">The Thue-Morse Transform</a>, arXiv:2604.06243 [math.NT], 2026.
%F A395962 a(n) = 2*(n-1) + A395961(2*(n-1)) for n >= 1.
%o A395962 (Python)
%o A395962 def A395961(n):
%o A395962     s, p = 0, 0
%o A395962     while (1 << p) <= n:
%o A395962         if (p & 3) == 0:
%o A395962             s ^= (n >> p) & 1
%o A395962         p += 1
%o A395962     return s
%o A395962 print([k for k in range(120) if A395961(k) == 0])
%Y A395962 Cf. A000035, A000069, A001969, A010060, A158704, A158705, A341389, A395958, A395959, A395960, A395961, A395963, A395964, A395965, A395966.
%K A395962 nonn,base,easy
%O A395962 1,2
