%I A395508 #22 May 04 2026 22:49:58
%S A395508 3,4,6,7,8,12,13,15,16,18,21,24,26,33,42,43,47,53,54,60,65,66,80,91,
%T A395508 98,100,120,128,131,138,153,174,177,201,208,236,244,256,268,288
%N A395508 Record lengths of runs of consecutive numbers whose numbers of Collatz steps to reach 1 are weakly increasing.
%C A395508 For m >= 1, let r(m) be the largest k >= 1 such that A006577(m) <= A006577(m+1) <= ... <= A006577(m+k-1).
%C A395508 This sequence lists the successive record values of r(m).
%H A395508 <a href="/index/3#3x1">Index entries for sequences related to 3x+1 (or Collatz) problem</a>
%e A395508 The starting terms of T = A006577 are: 0, 1, 7, 2, 5, 8, 16, 3, 19, 6, 14, 9, 9, 17, 17, 4, 12, 20, 20, 7, 7, 15, 15, 10, 23, 10, 111, 18, 18, 18, 106, 5, 26, 13, 13, 21, 21, 21, 34, 8, ...
%e A395508 a(1) = 3 because T(1), T(2), T(3) = 0, 1, 7 is a weakly increasing run, while T(4) = 2.
%e A395508 a(2) = 4 because T(4), T(5), T(6), T(7) = 2, 5, 8, 16 is a weakly increasing run, while T(8) = 3.
%e A395508 a(3) = 6 because T(34), ..., T(39) = 13, 13, 21, 21, 21, 34 is a weakly increasing run, while T(40) = 8.
%o A395508 (Python)
%o A395508 Collatz_dict = dict()
%o A395508 Collatz_dict[1] = 0
%o A395508 def Collatz(n):
%o A395508     if n%2 == 0:
%o A395508         return n//2
%o A395508     return 3*n + 1
%o A395508 def Collatz_length(n):
%o A395508     if n in Collatz_dict:
%o A395508         return Collatz_dict[n]
%o A395508     Collatz_dict[n] = 1 + Collatz_length(Collatz(n))
%o A395508     return Collatz_dict[n]
%o A395508 sequence = []
%o A395508 previous_record = 0
%o A395508 ascent = 1
%o A395508 for i in range(1, 10**7):
%o A395508     if Collatz_length(i+1) >= Collatz_length(i):
%o A395508         ascent += 1
%o A395508     else:
%o A395508         if ascent > previous_record:
%o A395508             sequence.append(ascent)
%o A395508             previous_record = ascent
%o A395508         ascent = 1
%o A395508 print(sequence)
%Y A395508 Cf. A006577, A351224.
%K A395508 nonn,more,new
%O A395508 1,1
%A A395508 _Anselm Hudde_, Apr 26 2026
%E A395508 a(34)-a(40) from _Sean A. Irvine_, May 04 2026
