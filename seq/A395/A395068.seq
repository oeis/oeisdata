%U A395068 211826647081882741957608738816,4395184566236744372801084458008576,125587835130278556488970621523524059136,4826209411020170992897885511210394584088576
%N A395068 a(n) = Sum_{1 <= i < j <= n} ( n!/(i*j) )^4.
%H A395068 Seiichi Manyama, <a href="/A395068/b395068.txt">Table of n, a(n) for n = 0..144</a>
%F A395068 a(n) = (n!)^4 * (H(n,4)^2 - H(n,8))/2 where H(n,r) = Sum_{k=1..n} 1/k^r.
%F A395068 a(n) = A395066(n,n-2) = [x^(n-2)] Product_{k=0..n} (1 + k^4*x).
%F A395068 a(n) = (n^4 + (n-1)^4) * a(n-1) - (n-1)^8 * a(n-2) + ((n-2)!)^4 for n > 1.
%o A395068 (PARI) a(n) = polcoef(prod(k=0, n, 1+k^4*x), n-2);
