%S A395448 294,3704778,257432175,112024529867250,1881063815762259253125,
%T A395448 6948173623016040171631875,42344185423359347502790906715625,
%U A395448 17162190941764356274316709924901406250,94071512263798420200697610245686328125,12967172230363787667401358845511389649052092451171875
%N A395448 Denominators of the coefficient of Pi^(4n+1) in Plouffe's formula for zeta(4n+1).
%H A395448 Jwalin Bhatt, <a href="/A395448/b395448.txt">Table of n, a(n) for n = 1..112</a>
%H A395448 Simon Plouffe, <a href="http://www.plouffe.fr/simon/inspired2.pdf">Identities inspired by Ramanujan Notebooks (part 2)</a>, April 2006.
%H A395448 Linas Vepštas, <a href="https://doi.org/10.1007/s11139-011-9335-9">On Plouffe's Ramanujan identities</a>, The Ramanujan Journal, Vol. 27 (2012), pp. 387-408; <a href="https://arxiv.org/abs/math/0609775">arXiv preprint</a>, arXiv:math/0609775 [math.NT], 2006-2010.
%H A395448 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/RiemannZetaFunction.html">Riemann Zeta Function</a>.
%F A395448 a(n) = A394977(2n).
%F A395448 A395447(n)/a(n) = (2^(4n+1) / ((4n+2)! * (1 + (-4)^n - 2^(4n+1)))) * (Sum_{j=0..n} (-4)^(n+j) * binomial(4n+2, 4j) * B_{4j} * B_{4n-4j+2} + (1/2) * Sum_{j=0..2n+1} (-4)^j * binomial(4n+2, 2j) * B_{2j} * B_{4n-2j+2}), where B_k are the Bernoulli numbers (A027641/A027642).
%F A395448 Limit_{n->oo} (Pi^(4n+1)*A395447(n)/a(n)-coth(Pi)) / (zeta(4n+1)-1) = 2*coth(Pi)-coth(2*Pi).
%t A395448 Denominator[Table[2^(4n+1) (Sum[(-4)^(n+j) Binomial[4n+2, 4j] BernoulliB[4n-4j+2] BernoulliB[4j], {j, 0, n}] + 1/2 Sum[(-4)^j Binomial[4n+2, 2j] BernoulliB[4n-2j+2] BernoulliB[2j], {j, 0, 2n+1}]) / ((4n+2)! (1 + (-4)^n - 2^(4n+1))), {n, 1, 10}]]
%o A395448 (Python)
%o A395448 from sympy import binomial, bernoulli, factorial
%o A395448 def a(n):
%o A395448     s1 = sum(
%o A395448         (-4)**(n+j) * binomial(4*n+2, 4*j) * bernoulli(4*n-4*j+2) * bernoulli(4*j)
%o A395448         for j in range(n+1)
%o A395448     )
%o A395448     s2 = sum(
%o A395448         (-4)**j * binomial(4*n+2, 2*j) * bernoulli(4*n-2*j+2) * bernoulli(2*j)
%o A395448         for j in range(2*n+2)
%o A395448     )
%o A395448     frac = 2**(4*n+1) * (s1+s2/2) / factorial(4*n+2) / (1 + (-4)**n - 2**(4*n+1))
%o A395448     return frac.denominator
%Y A395448 Cf. A057867, A394977, A395447.
%K A395448 nonn,frac,new
%O A395448 1,1
%A A395448 _Jwalin Bhatt_, Apr 23 2026
