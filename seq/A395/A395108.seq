%U A395108 50319361,100646913,201302017,402620417,805257217,1610547201,3221127169,6442319873,12884705281,25769541633,51539214337,103078690817
%N A395108 Number of points covered by a minimal level n H-Tree on a square lattice.
%C A395108 A minimal H-Tree covers the fewest possible points on a square lattice. This results in a smaller bounding box, 2^(n-2)-1 by 2^(n-3)-1, than a regular H-Tree, 2^(n-2)-1 by 2^(n-2)-3, at odd n > 1.
%H A395108 David Cleaver, <a href="/A395108/b395108.txt">Table of n, a(n) for n = 0..1000</a>
%H A395108 David Cleaver, <a href="/A395108/a395108.png">Illustration of a(0)-a(6)</a>
%H A395108 Neil Robertson and P. D. Seymour, <a href="https://doi.org/10.1016/0095-8956(83)90079-5">Graph Minors. I. Excluding a Forest</a>, Journal of Combinatorial Theory, Series B, Volume 35, Issue 1, August 1983, Pages 39-61 (see H6 in Fig. 3 on p. 52).
%H A395108 Wikipedia, <a href="https://en.wikipedia.org/wiki/H_tree">H tree</a>.
%H A395108 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (3,0,-6,4).
%F A395108 a(2n) = A169726(n).
%F A395108 G.f.: -(2*x^3-2*x^2+1)/((x-1)*(2*x-1)*(2*x^2-1)). - _Joerg Arndt_, Apr 12 2026
%F A395108 a(n) = 1 + 3*2^n - 2^((n-3)/2)*(4 + 3*sqrt(2) + (-1)^n*(3*sqrt(2) - 4)). - _Stefano Spezia_, Apr 15 2026
%t A395108 a[n_]:=1+3*2^n-2^((n-3)/2)*(4+3Sqrt[2]+(-1)^n*(3*Sqrt[2]-4)); Array[a,36,0] (* _Stefano Spezia_, Apr 15 2026 *)
%o A395108 (PARI) a(n)={my(T=1);for(i=1,n,T=T+2^floor((n-i)/2)*2^i);T};
%Y A395108 Cf. A169726, A395109.
%K A395108 nonn,easy,new
%O A395108 0,2
%A A395108 _David Cleaver_, Apr 11 2026
