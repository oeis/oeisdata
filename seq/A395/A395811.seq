%S A395811 1,1,1,2,1,2,1,2,2,2,1,3,1,2,2,2,1,3,1,2,2,2,1,3,2,2,2,2,1,4,1,2,2,2,
%T A395811 2,3,1,2,2,3,1,3,1,2,3,2,1,3,1,3,2,2,1,3,2,2,2,2,1,4,1,2,2,3,2,3,1,2,
%U A395811 2,3,1,4,1,2,3,2,1,3,1,4,2,2,1,3,2,2,2
%N A395811 Number of Fibonacci divisors of n that are at most sqrt(n).
%C A395811 Counts the inferior Fibonacci divisors of n. The complementary divisors do not need to be Fibonacci.
%C A395811 Starts to differ from A333749 at n=36.
%F A395811 a(n) <= A038548(n).
%e A395811 a(36)=3 counts the factorizations 1*36, 2*18 and 3*12 where 1, 2 and 3 are Fibonacci numbers. Factorizations 4*9 and 6*6 are not counted because 4 and 6 are not Fibonacci numbers.
%p A395811 A395811 := proc(n)
%p A395811     local a,d;
%p A395811     a := 0 ;
%p A395811     for d in numtheory[divisors](n) do
%p A395811         if d^2 <= n and isFib(d) then # isFib coded in A000045
%p A395811             a := a+1 ;
%p A395811         end if;
%p A395811     end do:
%p A395811     a ;
%p A395811 end proc:
%p A395811 seq(A395811(n),n=1..120) ;
%o A395811 (Python)
%o A395811 from sympy import divisors
%o A395811 from sympy.ntheory.primetest import is_square
%o A395811 isFib = lambda n: (lambda t: is_square(t + 4) or is_square(t - 4))(5 * (n ** 2))
%o A395811 def A395811(n):
%o A395811   a = 0
%o A395811   for i in divisors(n):
%o A395811     if i ** 2 <= n and isFib(i):
%o A395811       a += 1
%o A395811   return a
%o A395811 print([A395811(x) for x in range(1, 88)]) # _Aitzaz Imtiaz_, May 13 2026, following the Maple program.
%Y A395811 Cf. A005086, A010056, A038548, A333749.
