%N A395585 a(n) = floor(r*(a(n-1) + a(n-2))), a(0) = 0, a(1) = 1 and r = (3 + sqrt(13))/2.
%C A395585 r is the bronze ratio A098316.
%H A395585 Wikipedia, <a href="https://en.wikipedia.org/wiki/Metallic_mean">Metallic mean</a>.
%H A395585 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (4,1,-2,-1,-1).
%F A395585 Limit_{n -> oo} a(n)/a(n-1) = A395592.
%F A395585 a(n) = A080081(a(n-1) + a(n-2)).
%F A395585 G.f.: x*(1 - x - x^3)/((1 - x)*(1 - 3*x - 4*x^2 - 2*x^3 - x^4)). - _Stefano Spezia_, May 01 2026
%t A395585 a[0]=0; a[1]=1; a[n_]:=a[n]=Floor[(3+Sqrt[13])*(a[n-1] + a[n-2])/2]; Array[a,27,0] (* _Stefano Spezia_, May 01 2026 *)
