%N A395664 Expansion of g^5/(4-3*g)^4, where g = 1+x*g^4 is the g.f. of A002293.
%F A395664 G.f.: (Sum_{k>=0} binomial(4*k+1,k) * x^k) * (Sum_{k>=0} binomial(4*k,k) * x^k)^3.
%F A395664 Sum_{k>=1} a(k-1) * x^k/k^2 = (1/8) * log( Sum_{k>=0} binomial(4*k+4,k) * x^k ).
%F A395664 a(n) = ((n+1)/8) * (binomial(4*n+3,n) + Sum_{k=0..n+1} 3^(n+1-k) * binomial(4*n+4,k)).
%o A395664 (PARI) a(n) = (n+1)*(binomial(4*n+3, n)+sum(k=0, n+1, 3^(n+1-k)*binomial(4*n+4, k)))/8;
