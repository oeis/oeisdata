%T A395930 76800,192000,168000,30240,4096,73728,691200,3072000,6048000,4354560,
%U A395930 665280,16384,401408,5419008,37632000,131712000,213373440,130394880,17297280
%N A395930 Triangle read by rows: T(n, k) = 4^n * [x^k] hypergeom([-n, -n, 1/2], [1], x).
%F A395930 T(n, k) = [x^k] Sum_{k=0..n} 4^(n-k)*binomial(n, k)^2*binomial(2*k, k)*k!*x^k, see A393915.
%e A395930 Triangle starts:
%e A395930   [0]     1;
%e A395930   [1]     4,     2;
%e A395930   [2]    16,    32,     12;
%e A395930   [3]    64,   288,    432,     120;
%e A395930   [4]   256,  2048,   6912,    7680,    1680;
%e A395930   [5]  1024, 12800,  76800,  192000,  168000,   30240;
%e A395930   [6]  4096, 73728, 691200, 3072000, 6048000, 4354560, 665280;
%p A395930 p := (n, x) -> 4^n * hypergeom([-n, -n, 1/2], [1], x):
%p A395930 T := (n, k) -> coeff(simplify(p(n, x)), x, k):
%p A395930 for n from 0 to 6 do seq(T(n, k), k = 0..n) od;
%o A395930 (SageMath)
%o A395930 def P(n):
%o A395930     x = SR.var('x')
%o A395930     poly = c = SR(1)
%o A395930     for k in range(n):
%o A395930         c = (c * (k - n)^2 * (2*k + 1) / 2) / (k + 1)^2
%o A395930         poly += c * x^(k + 1)
%o A395930     return 4^n * poly
%o A395930 for n in range(7): print(n, P(n).list())
%o A395930 (PARI) T(n, k) = 4^n * polcoef(hypergeom([-n, -n, 1/2], [1], x), k); \\ _Michel Marcus_, May 12 2026
%Y A395930 Cf. A393915, A001813 (main diagonal).
