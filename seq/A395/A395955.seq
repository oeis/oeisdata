%I A395955 #9 May 12 2026 08:52:12
%S A395955 1,16,1,32,1,128,1,256,7,2048,3,4096,33,16384,143,32768,143,524288,
%T A395955 221,1048576,4199,4194304,2261,8388608,7429,67108864,37145,134217728,
%U A395955 334305,536870912,570285,1073741824,1964315,34359738368,3411705,68719476736,23881935,274877906944
%N A395955 Numerator of the n-th moment of the probability distribution of distances from the center of a unit disk to a line passing through two points independently and uniformly selected at random in the disk.
%C A395955 The moments of the probability distributed function f(x) = (16/(3*Pi))*(1-x^2)^(3/2) for 0 <= x <= 1, and 0 otherwise.
%D A395955 A. M. Mathai, An Introduction to Geometrical Probability: Distributional Aspects with Applications, Amsterdam: Gordon and Breach, 1999, p. 205, eq. (2.3.66).
%H A395955 Amiram Eldar, <a href="/A395955/b395955.txt">Table of n, a(n) for n = 0..1000</a>
%F A395955 Let f(n) = a(n)/(A395956(n)*Pi^(n mod 2)) be the n-th moment. Then:
%F A395955 f(n) = 2*Gamma((n + 1)/2)/(sqrt(Pi)*Gamma(n/2 + 3)).
%F A395955 f(n) ~ 8*sqrt(2/Pi)/n^(5/2).
%F A395955 Sum_{n>=0} f(n) = (4/9)*(3+4/Pi).
%e A395955 Fractions begin with 1, 16/(15*Pi), 1/6, 32/(105*Pi), 1/16, 128/(945*Pi), 1/32, 256/(3465*Pi), 7/384, 2048/(45045*Pi), 3/256, 4096/(135135*Pi), ...
%t A395955 a[n_] := Numerator[2/Sqrt[Pi]*Gamma[(n + 1)/2]/Gamma[n/2 + 3]]; Array[a, 38, 0]
%o A395955 (PARI) gamma_my(n) = if(denominator(n) == 1, (n-1)!, my(m = n - 1/2); (2*m)! / (4^m * m!)); \\ gamma for integers, gamma(n)/sqrt(Pi) for half-integers
%o A395955 a(n) = numerator(2 * gamma_my((n + 1)/2) / gamma_my(n/2 + 3));
%Y A395955 Cf. A395953, A395954, A395956 (denominators).
%K A395955 nonn,frac,easy,new
%O A395955 0,2
%A A395955 _Amiram Eldar_, May 12 2026
