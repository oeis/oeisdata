%S A395457 1,9,1,81,55,1,729,1351,140,1,6561,26335,6951,266,1,59049,465751,
%T A395457 246730,22827,435,1,531441,7859215,7508501,1323652,58542,649,1,
%U A395457 4782969,129442951,210766920,63436373,5146570,128128,910,1,43046721,2104469695,5652751651,2734926558,364558623,16169582,250978,1220,1
%N A395457 Triangle read by rows: T(n,k) = (1/(2k)!) * Sum_{j=0..2k} (-1)^j * binomial(2k,j) * (3+k-j)^(2n).
%D A395457 P. L. Butzer, K. Schmidt, E. L. Stark, and L. Vogt, Central factorial numbers; their main properties and some applications. Numerical Functional Analysis and Optimization, 10(5-6), (1989), 419-488.
%D A395457 J. Riordan, Combinatorial identities (Vol. 217), Wiley, New York, 1968.
%H A395457 José L. Cereceda, <a href="https://arxiv.org/abs/2211.11648">Sums of powers of integers and generalized Stirling numbers of the second kind</a>, arXiv:2211.11648 [math.NT], 2022.
%H A395457 M. W. Coffey and M. C. Lettington, <a href="https://arxiv.org/abs/1510.05402">On Fibonacci Polynomial Expressions for Sums of m-th Powers, their implications for Faulhaber's Formula and some Theorems of Fermat</a>, arXiv:1510.05402 [math.NT], 2015.
%H A395457 Donald E. Knuth, <a href="https://arxiv.org/abs/math/9207222">Johann Faulhaber and Sums of Powers</a>, arXiv:math/9207222 [math.CA], 1992.
%H A395457 Petro Kolosov, <a href="https://doi.org/10.5281/zenodo.18096789">Sums of powers via central finite differences and Newton's formula</a>, Zenodo, 2026.
%F A395457 Let F(t, n, k) be generalized central factorial numbers of the second kind: F(t,n,k) = (1/(2k)!) * Sum_{j=0..2k} (-1)^j * binomial(2k,j) * (t+k-j)^(2n), then:
%F A395457   F(0,2n,2k) = A387597(n,k)/k! = A269945(n,k);
%F A395457   F(1,2n,2k) = A392337(n,k)/k! = A394692(n,k);
%F A395457   F(2,2n,2k) = A390029(n,k)/k! = A395456(n,k);
%F A395457   F(3,2n,2k) = T(n,k) (this sequence).
%F A395457 G.f. for T(n,k) is centered Newton's polynomial for f(s) = s^(2n): s^(2n) = Sum_{k=0..2n} T(2n,k) (s-3)^[k], where (s-3)^[k] are central factorials.
%e A395457 Triangle begins:
%e A395457   k=    0        1         2         3         4      5      6
%e A395457   ----------------------------------------------------------------
%e A395457   n=0:  1;
%e A395457   n=1:  9,       1;
%e A395457   n=2:  81,      55,       1;
%e A395457   n=3:  729,     1351,     140,      1;
%e A395457   n=4:  6561,    26335,    6951,     266,     1;
%e A395457   n=5:  59049,   465751,   246730,   22827,   435,   1;
%e A395457   n=6:  531441,  7859215,  7508501,  1323652, 58542, 649,   1;
%e A395457   ...
%t A395457 T[t_, n_, k_] := 1/ k!* Sum[(-1)^j * Binomial[k, j] * (t + k/2 - j)^n, {j, 0, k}]; Column[Table[T[3, 2 n, 2 k], {n, 0, 10}, {k, 0, n}]]
%Y A395457 Cf. A036969, A269945, A008957, A390029, A392337, A387597, A394692, A395456.
