%T A395269 7710132048400,622342364799875,56914610070416925,5840747950246941200,
%U A395269 667216684038723886425,84264849101138358291100,11696222862477631614890825,1775132042879489872026289950,293246294566669557714559409325
%N A395269 E.g.f. A(x) satisfies A'(x) = 1 + A^5(x), where A^l(x) denotes the l-th iterate of A, with A(0) = 0.
%H A395269 Seiichi Manyama, <a href="/A395269/b395269.txt">Table of n, a(n) for n = 1..286</a>
%F A395269 E.g.f. A(x) satisfies A'(x) = 1 + A^l(x), where A^l(x) denotes the l-th iterate of A, with A(0) = 0.
%F A395269 A(x) = Series_Reversion( Integral 1/(1 + A^{l-1}(x)) dx ). for l > 0.
%F A395269 Let a(n,k,l) = n! * [x^n] A^k(x), where A^k(x) is the k-th iterate of A.
%F A395269 a(n,0,l) = 0^(n-1) and a(n,k,l) = a(n,k-1,l) + Sum_{j=1..n-1} binomial(n-1,j) * a(j,k+l-1,l) * a(n-j,k-1,l) for k > 0.
%o A395269 (PARI)
%o A395269 a_vector(n, k=1, l=5) = {
%o A395269   my(k_limit(row)=k+(n-row)*l, A=vector(n, row, vector(k_limit(row)+1)));
%o A395269   for(col=0, k_limit(1), A[1][col+1]=1);
%o A395269   for(row=2, n, A[row][1]=0);
%o A395269   for(row=2, n,
%o A395269     for(col=1, k_limit(row),
%o A395269       A[row][col+1]=A[row][col]+sum(j=1, row-1, binomial(row-1, j)*A[j][col+l]*A[row-j][col]);
%o A395269     );
%o A395269   );
%o A395269   vector(n, row, A[row][k+1])
%o A395269 };
%Y A395269 Column k=1 of A396973.
%Y A395269 Cf. A001028, A193098, A193099.
%K A395269 nonn,new
%O A395269 1,3
%A A395269 _Seiichi Manyama_, Jun 11 2026
