%I A395310 #13 Apr 27 2026 16:38:02
%S A395310 83,107,179,491,563,1091,1259,1283,1307,1619,1787,1907,1979,2003,2099,
%T A395310 2267,2531,2843,3011,3083,3323,3491,3803,3851,3923,4091,4139,4451,
%U A395310 4643,4787,4931,5051,5171,5843,5939,5987,6011,6659,6827,6899,7019,7211,7331,7883,7907
%N A395310 Prime numbers of the form 11*x^2 - 4*x*y + 20*y^2 where x and y are positive integers.
%C A395310 The discriminant is -864.
%C A395310 All terms are congruent to 11 modulo 24.
%H A395310 Steven Lu, <a href="/A395310/b395310.txt">Table of n, a(n) for n = 1..10000</a>
%e A395310 83 = 11 * 1^2 - 4 * 1 * 2 + 20 * 2^2.
%e A395310 107 = 11 * 3^2 - 4 * 3 * 1 + 20 * 1^2.
%e A395310 179 = 11 * 1^2 - 4 * 1 * 3 + 20 * 3^2.
%t A395310 With[{limit = 8000},
%t A395310  Sort[DeleteDuplicates[
%t A395310    Select[Flatten[
%t A395310      Table[11 x^2 - 4 x y + 20 y^2, {x,
%t A395310        Floor[Sqrt[20 limit/216]]}, {y, Floor[Sqrt[11 limit/216]]}]],
%t A395310     PrimeQ[#] && # < limit &]]]]
%Y A395310 Cf. A379881, this sequence, A395311 and {3, 11} is a partition of A107007.
%K A395310 nonn,new
%O A395310 1,1
%A A395310 _Steven Lu_, Apr 19 2026
