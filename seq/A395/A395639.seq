%I A395639 #8 May 15 2026 17:44:31
%S A395639 1,0,0,1,1,1,0,0,1,1,1,0,1,1,0,2,0,0,2,0,2,1,0,1,1,0,1,0,0,0,0,1,0,1,
%T A395639 2,0,2,0,0,1,1,0,0,0,2,1,0,0,1,0,2,0,1,0,0,2,0,1,1,1,0,0,1,2,0,2,1,0,
%U A395639 1,0,0,0,0,0,0,1,1,0,1,0,0,1,0,0,1,0
%N A395639 a(n) = number of triples (x, y, z) such that 2*x^2 + y*z = n, where x, y, z are distinct Fibonacci numbers with y < z.
%e A395639 a(8) = 1 counts this triple: (1,2,3).
%e A395639 a(58) = 2 counts these triples: (3,5,8), (5,1,8).
%t A395639 t[n_, c_] := Module[{r}, r = Flatten[Table[If[n - 2 x^2 <= 0, {},
%t A395639 Map[({x, #, Quotient[n - 2 x^2, #]} &),
%t A395639 Select[Divisors[n - 2 x^2], Divisible[n - 2 x^2, #] &]]],
%t A395639 {x, 1, Floor[Sqrt[n - 1]]}], 1]; Select[r, Apply[c, #] &]];
%t A395639 fibonacciQ[n_] := IntegerQ[Sqrt[5 n^2 + 4]] || IntegerQ[Sqrt[5 n^2 - 4]];
%t A395639 c = (fibonacciQ[#1] && fibonacciQ[#2] && fibonacciQ[#3] && #2 < #3 && DuplicateFreeQ[{#1, #2, #3}] &);
%t A395639 Table[Length[t[n, c]], {n, 8, 130}]
%t A395639 (* _Peter J. C. Moses_, Mar 29 2026 *)
