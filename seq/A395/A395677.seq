%T A395677 49,50,51,52,54,56,57,60,63,64,65,66,72,78,80,81,84,91,96,98,99,100,
%U A395677 102,104,105,108,112,114,117,120,126,128,130,132,133,135,143,144,147,148,150
%N A395677 Numbers which are divisible by the sum of their base-7 digits.
%C A395677 Also called 7-Harshad or 7-Niven numbers.
%H A395677 Paolo Xausa, <a href="/A395677/b395677.txt">Table of n, a(n) for n = 1..10000</a>
%H A395677 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/HarshadNumber.html">Harshad Number</a>.
%H A395677 Wikipedia, <a href="https://en.wikipedia.org/wiki/Harshad_number">Harshad number</a>.
%t A395677 A395677Q[k_] := Divisible[k, DigitSum[k, 7]];
%t A395677 Select[Range[200], A395677Q]
%o A395677 (PARI) isok(k) = (k % sumdigits(k, 7)) == 0; \\ _Michel Marcus_, May 04 2026
%Y A395677 Cf. A053828.
