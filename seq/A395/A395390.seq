%N A395390 a(n) = (2*n)! * [x^(2*n)] cosh(x) / cos(x)^7.
%F A395390 a(n) = 1 - (1/64) * Sum_{k=0..n-1} (-1)^(n-k) * (35 + 21*9^(n-k) + 7*25^(n-k) + 49^(n-k)) * binomial(2*n,2*k) * a(k).
%F A395390 a(n) = (1/720) * Sum_{k=0..n} binomial(2*n,2*k) * (225*A000364(k) + 259*A000364(k+1) + 35*A000364(k+2) + A000364(k+3)).
%o A395390 (PARI) a(n) = my(x='x+O('x^(2*n+1))); (2*n)!*polcoef(cosh(x)/cos(x)^7, 2*n);
