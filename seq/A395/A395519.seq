%I A395519 #19 May 13 2026 21:48:07
%S A395519 3,9,13,31,32,46,47,113,47,140,98
%N A395519 a(n) is the smallest number k such that k^n is the sum of 2n distinct positive n-th powers.
%C A395519 a(12) >= 154.
%e A395519 3^1 = 1^1 + 2^1;
%e A395519 9^2 = 2^2 + 4^2 + 5^2 + 6^2;
%e A395519 13^3 = 1^3 + 5^3 + 6^3 + 7^3 + 8^3 + 10^3;
%e A395519 31^4 = 8^4 + 10^4 + 14^4 + 16^4 + 17^4 + 18^4 + 20^4 + 26^4;
%e A395519 32^5 = 2^5 + 3^5 + 7^5 + 8^5 + 9^5 + 11^5 + 15^5 + 17^5 + 19^5 + 31^5;
%e A395519 46^6 = 1^6 + 3^6 + 5^6 + 7^6 + 10^6 + 13^6 + 14^6 + 19^6 + 21^6 + 28^6 + 40^6 + 41^6;
%e A395519 47^7 = 2^7 + 4^7 + 7^7 + 8^7 + 9^7 + 11^7 + 17^7 + 18^7 + 20^7 + 21^7 + 22^7 + 35^7 + 40^7 + 43^7;
%e A395519 113^8 = 108^8 + 86^8 + 84^8 + 79^8 + 74^8 + 56^8 + 52^8 + 48^8 + 38^8 + 36^8 + 34^8 + 28^8 + 26^8 + 12^8 + 8^8 + 6^8;
%e A395519 47^9 = 1^9 + 2^9 + 4^9 + 7^9 + 11^9 + 14^9 + 15^9 + 18^9 + 26^9 + 27^9 + 30^9 + 31^9 + 32^9 + 33^9 + 36^9 + 38^9 + 39^9 + 43^9;
%e A395519 140^10 = 132^10 + 121^10 + 110^10 + 103^10 + 102^10 + 96^10 + 86^10 + 77^10 + 66^10 + 55^10 + 54^10 + 52^10 + 44^10 + 38^10 + 34^10 + 33^10 + 24^10 + 19^10 + 13^10 + 7^10;
%e A395519 98^11 = 91^11 + 87^11 + 79^11 + 78^11 + 74^11 + 72^11 + 66^11 + 63^11 + 62^11 + 61^11 + 51^11 + 47^11 + 41^11 + 29^11 + 26^11 + 23^11 + 21^11 + 19^11 + 13^11 + 8^11 + 7^11 + 4^11;
%e A395519 ...
%t A395519 a[n_] := FirstCase[Range[n, 50],k_ /; Length[Select[IntegerPartitions[k^n, {2 n}, Range[k - 1]^n], DuplicateFreeQ]] > 0]; Array[a, 7]
