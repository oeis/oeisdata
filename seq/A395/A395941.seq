%T A395941 446634,2790246,5228831,32849241,63172839,118285288,216048937,
%U A395941 1389019151,2597508627,4752887314,8521006425,14986211764,25885275427,172796271571,305289220115,2029750359569
%N A395941 Number of partitions of n^2 into prime parts not exceeding n.
%C A395941 This is a restricted version of A000607(n^2), allowing only prime parts p <= n.
%e A395941 a(1) = 0 since 1 has no partitions into prime parts.
%e A395941 a(2) = 1 since 4 = (2 + 2).
%e A395941 a(3) = 2 since 9 = (2 + 2 + 2 + 3) or (3 + 3 + 3).
%e A395941 a(4) = 3 since 16 = (2 + 2 + 2 + 2 + 2 + 2 + 2 + 2) or (2 + 2 + 2 + 2 + 2 + 3 + 3) or (2 + 2 + 3 + 3 + 3 + 3).
%o A395941 (Python)
%o A395941 from sympy import primerange
%o A395941 def a(n):
%o A395941     # Count partitions of n^2 into prime parts not exceeding n.
%o A395941     # b[k] stores the number of ways to make total k using the prime parts processed so far.
%o A395941     # Processing one prime at a time ensures that order is ignored, so 2+2+3 and 2+3+2 are not counted separately.
%o A395941     s=n*n; b=[1]+[0]*s
%o A395941     for p in primerange(n+1):
%o A395941         for k in range(p,s+1): b[k]+=b[k-p]
%o A395941     return b[s]
%o A395941 print([a(n) for n in range(32)])
%Y A395941 Cf. A000607, A394668, A395942, A395943.
%K A395941 nonn
%O A395941 0,4
