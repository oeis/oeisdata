%S A395626 0,1,2,4,5,6,9,10,12,16,17,20,21,22,25,26,30,32,36,37,42,45,49,50,52,
%T A395626 54,56,57,60,64,65,70,72,76,77,80,81,82,84,90,96,100,101,102,105,110,
%U A395626 112,116,117,121,122,132,136,140,144,145,150,156,160,161,162,165,166
%N A395626 Numbers x*y such that |x-y| is a square, with nonnegative integers x and y.
%C A395626 Contains A000290 (the squares) and A000290 + 1.
%H A395626 Žiga Pirc, <a href="/A395626/b395626.txt">Table of n, a(n) for n = 1..10000</a>
%o A395626 (PARI) select( {is_A395626(n)=fordiv(n+=!n, d, d*d>n&&break; issquare(n/d-d)&&return(1))}, [0..166])
%o A395626 (Python)
%o A395626 from itertools import count, islice
%o A395626 from sympy import divisors
%o A395626 from sympy.ntheory.primetest import is_square
%o A395626 def A395626_gen(startvalue=0): # generator of terms >= startvalue
%o A395626     for k in count(max(startvalue,0)):
%o A395626         if k == 0:
%o A395626             yield k
%o A395626         else:
%o A395626             for d in divisors(k):
%o A395626                 if d**2>k:
%o A395626                     break
%o A395626                 if is_square(k//d-d):
%o A395626                     yield k
%o A395626                     break
%o A395626 A395626_list = list(islice(A395626_gen(),30)) # _Chai Wah Wu_, Jun 24 2026
%Y A395626 Cf. A000290, A218381 (same with + instead of -), A394904 (union of this and A218381), A397224.
