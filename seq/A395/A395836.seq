%I A395836 #23 Jun 10 2026 11:01:52
%S A395836 1,3,382,15596,428751,1390598,1036726902,59595779523,374973153024631,
%T A395836 390927908309636208,287315311734503241860,144479928997809087241170,
%U A395836 783078130263953707885969214,86783826953710133179485700584,28300905706048462234112872097712,16491215013305141268915597516911007570
%N A395836 Define F(n,x) as the power series in x satisfying F(n,x) = 1 + x*F(n,x)^2 - x^n*F(n,x)^(2*n), then for n >= 2, a(n) = abs( [x^M] F(n,x) ) where x^M is the first power of x with a negative coefficient in F(n,x). Should no such M exist for some n, then there are no further terms and this sequence would be finite.
%C A395836 Conjecture: this sequence is infinite.
%H A395836 Paul D. Hanna, <a href="/A395836/b395836.txt">Table of n, a(n) for n = 2..92</a>
%F A395836 Given F(n,x) = 1 + x*F(n,x)^2 - x^n*F(n,x)^(2*n), then we have the following.
%F A395836 (1) a(n) = abs( [x^A395835(n)] F(n,x) ) for n >= 2.
%F A395836 (2) F(n,x) = sqrt( (1/x)*Series_Reversion( x/(1 + x - x^n)^2 ) ).
%F A395836 (3) lim_{n->oo} F(n,x) = C(x) where C(x) = 1 + x*C(x)^2 is the g.f. of the Catalan numbers (A000108).
%F A395836 (4) lim_{n->oo} a(n)^(1/A395835(n)) = 4 (conjectural, if sequence is infinite).
%e A395836 The first few power series F(n,x) satisfying
%e A395836 F(n,x) = 1 + x*F(n,x)^2 - x^n*F(n,x)^(2*n)
%e A395836 begin
%e A395836 F(2,x) = 1 + x + x^2 + (-1*x^3) - 10*x^4 - 33*x^5 - 55*x^6 + 65*x^7 + 842*x^8 + ...
%e A395836 F(3,x) = 1 + x + 2*x^2 + 4*x^3 + 6*x^4 + (-3*x^5) - 82*x^6 - 481*x^7 - 2098*x^8 + ...
%e A395836 F(4,x) = 1 + x + 2*x^2 + 5*x^3 + 13*x^4 + 32*x^5 + 66*x^6 + 65*x^7 + (-382*x^8) - 3553*x^9 - 20254*x^10 + ...
%e A395836 F(5,x) = 1 + x + 2*x^2 + 5*x^3 + 14*x^4 + 41*x^5 + 120*x^6 + 338*x^7 + 870*x^8 + 1802*x^9 + 1302*x^10 + (-15596*x^11) - 135056*x^12 + ...
%e A395836 F(6,x) = 1 + x + 2*x^2 + 5*x^3 + 14*x^4 + 42*x^5 + 131*x^6 + 415*x^7 + 1310*x^8 + 4046*x^9 + 11951*x^10 + 32452*x^11 + 73428*x^12 + 85425*x^13 + (-428751*x^14) - 4557495*x^15 + ...
%e A395836 From the above examples we can see that a(n) equals the absolute value of the first negative coefficient found in F(n,x):
%e A395836 a(2) = 1 since first negative term in F(2,x) is -1*x^3,
%e A395836 a(3) = 3 since first negative term in F(3,x) is -3*x^5,
%e A395836 a(4) = 382 since first negative term in F(4,x) is -382*x^8,
%e A395836 a(5) = 15596 since first negative term in F(5,x) is -15596*x^11, and
%e A395836 a(6) = 428751 since first negative term in F(6,x) is -428751*x^14.
%e A395836 The exponents of x at which these values occur is given by A395835.
%o A395836 (PARI) \\ Print absolute value of first negative coefficient in F(n,x)
%o A395836 \\ Routine FNEG(F) finds the first negative coefficient in F,
%o A395836 \\ but returns "?" if none are found:
%o A395836 {FNEG(F) = my(N="?"); for(n=1,#F-1, if(polcoef(F,n)<0, N=polcoef(F,n); break)); N}
%o A395836 \\ The following code prints the initial 70 terms in 2 minutes,
%o A395836 \\ the last 5 terms of which take about 30 seconds to compute.
%o A395836 \\ MAX(n) = 2*n^(3/2) is an approximation of growth for A395835(n)
%o A395836 \\ used to reduce run-time and may need correction for larger n.
%o A395836 {MAX(n) = ceil(2*n^(3/2))}
%o A395836 {for(n=2,20, F = sqrt((1/x)*serreverse(x/(1 + x - x^n +O(x^MAX(n)) )^2 )); print1(abs(FNEG(F)),", "))}
%Y A395836 Cf. A395835, A395837, A000108.
%K A395836 nonn,changed
%O A395836 2,2
%A A395836 _Paul D. Hanna_, May 14 2026
