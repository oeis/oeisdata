%S A395151 1,2,3,3,4,5,5,4,5,7,7,7,7,8,7,5,6,9,10,10,10,11,10,9,9,12,11,11,10,
%T A395151 11,9,6,7,11,13,13,13,16,14,13,13,17,15,15,14,15,13,11,11,16,17,17,16,
%U A395151 17,15,14,13,17,15,15,13,14,11,7,8,13,16,16,17,21,18,17
%N A395151 Number of compositions covered by the n-th composition in standard order.
%C A395151 The standard order of compositions is given by A066099. Here a composition A = (a_1,a_2,...a_m) covers B = (b_1,b_2,...b_m) iff a_i >= b_{i+k} for all b_i in B and some k >= 0.
%H A395151 John Tyler Rascoe, <a href="/A395151/b395151.txt">Table of n, a(n) for n = 0..16384</a>
%e A395151 The 14th composition in standard order is (1,1,2) which covers compositions: (1,1,2), (1,1,1), (1,2), (1,1), (2), (1) and () so a(14) = 7.
%o A395151 (Python)
%o A395151 def comp(n): #see A357625
%o A395151     return
%o A395151 def covers(c):
%o A395151     A,d = [[c]],2
%o A395151     for n in range(sum(c)-1):
%o A395151         A.append([])
%o A395151         S = set()
%o A395151         for i in A[n]:
%o A395151             for j in range(len(i)):
%o A395151                 y = i.copy()
%o A395151                 f = 0
%o A395151                 if i[j] > 1:
%o A395151                     y[j] -= 1
%o A395151                     f += 1
%o A395151                 elif j == 0 or j == len(i)-1:
%o A395151                     y.pop(j)
%o A395151                     f += 1
%o A395151                 z = tuple(y)
%o A395151                 if f > 0:
%o A395151                     if z not in S:
%o A395151                         A[n+1].append(y)
%o A395151                         d += 1
%o A395151                         S.add(z)
%o A395151     return d
%o A395151 def A395151(n):
%o A395151     if n < 1: return 1
%o A395151     return covers(comp(n))
%Y A395151 Cf. A066099, A124767, A333381, A357625.
%K A395151 nonn,easy
%O A395151 0,2
