%N A395633 a(n) = number of triples (x, y, z) such that 2*x^2 + y*z = n, where x, y, z are positive integers satisfying y < x < z.
%e A395633 a(28) = 3 counts these triples: (2, 1, 20), (3, 1, 10), (3, 2, 5).
%t A395633 t[n_, c_] := Module[{r}, r = Flatten[Table[If[n - 2 x^2 <= 0, {},
%t A395633 Map[({x, #, Quotient[n - 2 x^2, #]} &),
%t A395633 Select[Divisors[n - 2 x^2], Divisible[n - 2 x^2, #] &]]],
%t A395633 {x, 1, Floor[Sqrt[n - 1]]}], 1]; Select[r, Apply[c, #] &]];
%t A395633 c = (#2 < #1 < #3 &);
%t A395633 Table[Length[t[n, c]], {n, 11, 130}]
