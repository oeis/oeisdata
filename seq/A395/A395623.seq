%I A395623 #21 May 14 2026 17:23:12
%S A395623 2,3,523,5,1069,22193,7,1259,25373,1442173,11,1759,69539,2288509,
%T A395623 5521819,13,1913,107509,2660183,33014273,354963229,17,2503,111373,
%U A395623 2805773,36183593,448024483,881160173,19,3803,167917,3830891,39874273,467739719,881160191,881160173
%N A395623 Infinite square array where the n-th row lists the starting points of runs of n consecutive primes with same digit sum; read by antidiagonals.
%e A395623 The array starts:
%e A395623    n | primes starting a run of n consecutive primes with same digit sum
%e A395623   ---+----------------------------------------------------------------------
%e A395623    1 |     2,         3,          5,          7,        11,    ... = A000040
%e A395623    2 |    523,      1069,       1259,       1759,      1913,   ... = A066540
%e A395623    3 |   22193,     25373,      69539,     107509,    111373,  ... = A209396
%e A395623    4 |  1442173,   2288509,    2660183,    2805773,   3830891, ... = A210629
%e A395623    5 |  5521819,  33014273,   36183593,   39874273,   47143739,... = A227931
%e A395623    6 | 354963229, 448024483,  467739719,  475313609, 525523709,... = A227933
%e A395623    7 | 881160173, 881160191, 1914032047, 4044901709,    ...
%e A395623    8 | 881160173,    ...         ...        ...         ...
%e A395623 In row n = 1, we have all primes.
%e A395623 In row n = 2, we have (among others) the primes followed by a gap of 18 (A031936) which don't end in a digit 1 and don't have 9 as the tens digit: In that case, p+18 has the last digit decreased by 2 and the tens digit increased by 2.
%e A395623 The subsequent rows n > 2 always consist of the members of the previous row which are immediately followed by the next larger prime, T(n-1,k) = precprime(T(n-1,k+1)), where 'precprime' is the preceding prime.
%o A395623 (PARI) A395623_row(n, first=1)={n>1 || return(primes(first)); my(s=2, L=[0], q=2, r=List()); forprime(p=3,oo, s==(s=sumdigits(p))&& L = if(n==2, listput(r,q); first==#r && break, L[#L] != q, [q,p], #L == n-1, listput(r, L[1]); first==#r && break; concat(L[^1], p), concat(L, p)); q=p); Vec(r)}
%Y A395623 Rows are 1: A000040, 2: A066540, 3: A209396, 4: A210629, 5: A227931, 6: A227933.
%Y A395623 Column 1 is A071613.
%Y A395623 See also A031936 (primes followed by a gap of 18), A209663 (primes p, p+18 with equal digit sum).
%K A395623 nonn,base,new
%O A395623 1,1
%A A395623 _M. F. Hasler_, May 07 2026
