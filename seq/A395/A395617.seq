%I A395617 #12 May 05 2026 21:47:11
%S A395617 1,1,2,3,4,6,10,12,18,24,36,48,60,90,120,168,240,300,360,480,660,840,
%T A395617 1080,1440,1800,2400,3120,3780,5040,6300,7560,10080,12600,15120,20160,
%U A395617 25200,30240,39600,50400,60480,75600,95760,110880,147840,180180,221760,277200
%N A395617 Start with a(1) = 1. Thereafter, a(n) is the least integer with a set of divisors whose sum add to the sum of all previous terms.
%C A395617 A divisor-subset-sum greedy sequence.
%C A395617 Only a(4) = 3, a(5) = 4 and a(9) = 18 need all their divisors to be equal to the sum of the previous terms.
%H A395617 Paolo P. Lava, <a href="/A395617/b395617.txt">Table of n, a(n) for n = 1..50</a>
%e A395617 a(5) = 4 -> sum of previous terms: 1 + 1 + 2 + 3 = 7 and divisors 1, 2, 4 of 4 add to 7;
%e A395617 a(6) = 6 -> sum of previous terms: 1 + 1 + 2 + 3 + 4 = 11 and divisors 2, 3, 6 of 6 add to 11;
%e A395617 a(7) = 10 -> sum of previous terms: 1 + 1+ 2 + 3 + 4 + 6 = 17 and divisors 2, 5, 10 of 10 add to 17; etc.
%p A395617 with(numtheory): P:=proc(n) local a,b,c,d,i,j,k,r,t,u;
%p A395617 a:=array(1..n); b:=array(1..n); a[1]:=1; b[1]:=1;
%p A395617 for j from 2 to n do c:=b[j-1]; k:=1; do t:=divisors(k); u:={0};
%p A395617 for d in t do u:=u union map(r->r+d,u); od;
%p A395617 if member(c,u) then a[j]:=k; b[j]:=b[j-1]+k; break; fi;
%p A395617 k:=k+1; od; od; seq(a[i],i=1..n); end: P(30);
%Y A395617 Cf. A002182, A005101, A005153, A070172.
%K A395617 nonn,hard,new
%O A395617 1,3
%A A395617 _Paolo P. Lava_, May 01 2026
