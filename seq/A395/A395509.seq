%N A395509 a(n) is the permanent of the symmetric tau(n) X tau(n) matrix M(n) defined by M(i,j) = sigma(d_i*d_j), where d_i, d_j run through the divisors of n.
%e A395509 a(4) = 1694:
%e A395509   [1,  3,  7]
%e A395509   [3,  7, 15]
%e A395509   [7, 15, 31]
%t A395509 a[n_]:=Permanent[Table[DivisorSigma[1,Part[d=Divisors[n],i]*Part[d,j]],{i,DivisorSigma[0,n]},{j,DivisorSigma[0,n]}]]; Array[a,30]
%o A395509 (PARI) a(n) = my(f=factor(n), d=divisors(f)); matpermanent(matrix(#d, #d, i, j, sigma(d[i]*d[j]))); \\ _Michel Marcus_, Apr 26 2026
