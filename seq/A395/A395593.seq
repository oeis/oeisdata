%N A395593 a(n) = a(n-1) + a(n-3) + a(n-4), a(0)=1, a(1)=8, a(2)=64, a(3)=72.
%H A395593 Tomás Guardia, Douglas Jiménez, and Alexander McCurdy, <a href="https://doi.org/10.2478/rmm-2024-0002">Fiboquadratic Numbers and Rithmomachia</a>, Recreational Mathematics Magazine, Vol. 11, No. 18 (2024), pp. 17-29.
%H A395593 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (1,0,1,1).
%F A395593 a(n) = (8*F(n/2) + F((n/2)-1))^2 if n is even and (8*F((n-1)/2) + F(((n-1)/2)-1))*(8*F((n-1)/2+1)+F((n-1)/2)) if n is odd where F(n) = Fibonacci(n).
%F A395593 G.f.: (1 + 7*x + 56*x^2 + 7*x^3)/((1 + x^2)*(1 - x - x^2)). - _Stefano Spezia_, May 03 2026
%t A395593 LinearRecurrence[{1,0,1,1},{1,8,64,72},39] (* or *)
%t A395593 CoefficientList[Series[(1 + 7*x + 56*x^2 + 7*x^3)/((1 + x^2)*(1 - x - x^2)),{x,0,38}],x] (* _James C. McMahon_, May 07 2026 *)
