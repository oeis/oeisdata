%I A395547 #27 May 03 2026 21:12:50
%S A395547 3,5,11,19,47,47,107,131,191,223,257,293,431,479,587,643,701,761,971,
%T A395547 971,1117,1279,1451,1451,1583,1823,2027,2131,2351,2351,2699,2819,2879,
%U A395547 2939,3467,3467,3671,3881,4177,4483,4799,4799,5039,5119,5807,5807,6163,6163,6911,7103
%N A395547 Largest prime of the form x*y + y*z + z*x for integers 0 <= x <= y <= z <= n.
%H A395547 David A. Corneth, <a href="/A395547/b395547.txt">Table of n, a(n) for n = 1..10000</a>
%H A395547 David A. Corneth, <a href="/A395547/a395547_1.gp.txt">PARI program</a>
%F A395547 a(n) <= 3*n^2.
%e A395547 For n = 1, the largest prime obtained is 1*1 + 1*1 + 1*1 = 3. So a(1) = 3.
%e A395547 For n = 2, the largest prime obtained is 1*1 + 1*2 + 2*1 = 5. So a(2) = 5.
%e A395547 For n = 3, the largest prime obtained is 1*2 + 2*3 + 3*1 = 11. So a(3) = 11.
%p A395547 f:= proc(n) option remember;
%p A395547    local t,x,y0,y,w;
%p A395547    t:= procname(n-1);
%p A395547    for x from 0 to n do
%p A395547      if igcd(n,x) > 1 then next fi;
%p A395547      for y from n by -1 to x do
%p A395547        w:= (x+n)*y+x*n;
%p A395547        if w <= t then break fi;
%p A395547        if isprime(w) then t:= w; break fi;
%p A395547      od
%p A395547    od;
%p A395547    t
%p A395547 end proc;
%p A395547 f(1):= 3:
%p A395547 map(f, [$1..100]); # _Robert Israel_, Apr 28 2026
%o A395547 (PARI) a(n) = my(list = List()); for (x=0, n, for (y=x, n, for (z=y, n, if (isprime(p=x*y + y*z + z*x), listput(list, p));););); vecmax(Vec(list)); \\ _Michel Marcus_, Apr 28 2026
