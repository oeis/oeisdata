%I A395579 #23 May 13 2026 22:35:26
%S A395579 1,2,3,8,5,12,7,32,27,20,11,144,13,28,45,512,17,216,19,320,63,44,23,
%T A395579 4608,125,52,243,448,29,1800,31,4096,99,68,175,124416,37,76,117,12800,
%U A395579 41,3024,43,704,2025,92,47,1327104,343,1000,153,832,53,23328,275,25088,171,116,59,2073600
%N A395579 Product of the least factors in all factorizations of n, up to permutation of factors, into factors > 1, a(1) = 1 by convention.
%C A395579 a(n) is divisible by n.
%H A395579 Bartlomiej Pawlik, <a href="/A395579/b395579.txt">Table of n, a(n) for n = 1..1000</a>
%F A395579 a(n) = Product_{f in F(n)} min(f), where F(n) is the set of factorizations of n into factors > 1.
%F A395579 a(p^k) = p^A046746(k-1), p prime.
%F A395579 a(n) = n iff n = 1 or n is prime.
%F A395579 If n = p*q with p <= q primes, then a(n) = p^2*q.
%e A395579 The factorizations of 12 are 12, 2*6, 3*4, 2*2*3, so a(12) = 12*2*3*2 = 144.
%t A395579 mp[n_Integer?Positive,m_Integer?Positive]:=mp[n,m]=
%t A395579  Join[{{n}},Flatten[Table[
%t A395579   If[Mod[n,d]==0,Prepend[#,d]&/@ mp[n/d,d],Nothing],
%t A395579   {d, m, Floor[Sqrt[n]]}],1
%t A395579   ]];
%t A395579 a[1] = 1;
%t A395579 a[n_Integer?Positive]:=Times@@(First/@ mp[n,2]);
%t A395579 Table[a[n], {n, 1, 60}]
%Y A395579 Cf. A001055, A046746.
%K A395579 nonn,easy,new
%O A395579 1,2
%A A395579 _Bartlomiej Pawlik_, Apr 29 2026
