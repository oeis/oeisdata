%S A395572 1,0,1,0,4,1,0,4,8,1,0,4,40,12,1,0,4,104,108,16,1,0,4,232,684,208,20,
%T A395572 1,0,4,488,2988,2128,340,24,1,0,4,1000,11052,16720,4820,504,28,1,0,4,
%U A395572 2024,37548,102736,56020,9144,700,32,1
%N A395572 Array read by ascending antidiagonals: A(n, k) = Sum_{j=0..n} Stirling2(n, j)*4^j*(k)_j.
%C A395572 Base 4 polynomial collapse array for the iterated inverse Pascal operator.
%C A395572 As a triangle: T(n, k) = A(n - k, k).
%C A395572 For base 2, analogous to the one inverse Pascal iteration array in A394444.
%F A395572 Let D be the inverse Pascal operator: [D(f)]_m = Sum_{i=0..m} (-1)^(m - i)*binomial(m, i)*f(i). Then A(n, k) = [D^3(i^n*4^i)]_k = Sum_{j=0..n} Stirling2(n, j)*4^j*(k)_j.
%F A395572 For fixed k, the e.g.f. of A(n, k) in n is Sum_{n>=0} A(n, k)*u^n/n! = (1 + 4*(exp(u) - 1))^k.
%e A395572   k |    0    1      2       3        4        5
%e A395572   n |-----------------------------------------------
%e A395572   0 |    1    1      1       1        1        1
%e A395572   1 |    0    4      8      12       16       20
%e A395572   2 |    0    4     40     108      208      340
%e A395572   3 |    0    4    104     684     2128     4820
%e A395572   4 |    0    4    232    2988    16720    56020
%e A395572   5 |    0    4    488   11052   102736   530900
%e A395572 A(2, 2) = Stirling2(2, 1)*4*(2)_1 + Stirling2(2, 2)*16*(2)_2 = 40.
%Y A395572 Cf. A394444, A008277.
