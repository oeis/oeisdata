%I A395119 #6 May 11 2026 01:15:33
%S A395119 1,1,3,22,383,13696,849022,80744770,10902956129,1987104003664,
%T A395119 471900042879746,142295320119175774,53405343347962222729,
%U A395119 24551697708148322999704,13642156860624790521534162,9057058216074026352765958566,7111517875519725944146024396353,6543525622035743298161572728814208
%N A395119 E.g.f. satisfies A(x) = G(x*A(x)), where G(x) is the e.g.f. of A395118.
%C A395119 Let G(x) be the e.g.f. of A395118, then the coefficients of x^n in the n-th power of G(x) and in the n-th iteration of x*G(x) are equal for n >= 1.
%H A395119 Paul D. Hanna, <a href="/A395119/b395119.txt">Table of n, a(n) for n = 0..120</a>
%F A395119 E.g.f. A(x) = Sum_{n>=0} a(n)*x^n/n! satisfies the following formulas.
%F A395119 (1) A(x) = G(x*A(x)), where G(x) is the e.g.f. of A395118.
%F A395119 (2) G(x) = A(x/G(x)), where G(x) is the e.g.f. of A395118.
%e A395119 E.g.f.: A(x) = 1 + x + 3*x^2/2! + 22*x^3/3! + 383*x^4/4! + 13696*x^5/5! + 849022*x^6/6! + 80744770*x^7/7! + ...
%e A395119 where A(x) = G(x*A(x)) = (1/x)*Series_Reversion(x/G(x)) where G(x) is the e.g.f. of A395118:
%e A395119 G(x) = 1 + x + x^2/2! + 7*x^3/3! + 163*x^4/4! + 6851*x^5/5! + 470056*x^6/6! + 47608282*x^7/7! + ... + A395118(n)*x^n/n! + ...
%o A395119 (PARI) \\ Routine to get the n-th iteration of function F
%o A395119 {IT(n, F) = my(G=x); for(i=1, n, G = subst(F, x, G)); G}
%o A395119 \\ Obtain e.g.f. using the definition
%o A395119 {a(n) = my(V=[1], m); for(i=1, n, V = concat(V, 0); m = #V-1;
%o A395119 V[#V] = (Vec(IT(m, x*Ser(V)))[m] - Vec(Ser(V)^m)[m+1])/m );
%o A395119 EGF = (1/x)*serreverse(x/Ser(V)); n!*polcoef(EGF,n)}
%o A395119 \\ Display the terms a(0) - a(n):
%o A395119 {upto(n) = a(n); Vec(serlaplace(EGF))}
%o A395119 upto(20)
%Y A395119 Cf. A395118.
%K A395119 nonn,new
%O A395119 0,3
%A A395119 _Paul D. Hanna_, May 09 2026
