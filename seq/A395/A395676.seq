%T A395676 72,75,77,78,80,84,85,88,90,96,99,100,108,110,112,115,120,126,128,130,
%U A395676 140,143,144,145,147,150,156,160,168,170,176,180,182,186,189,190,200,208,210
%N A395676 Numbers which are divisible by the sum of their base-6 digits.
%C A395676 Also called 6-Harshad or 6-Niven numbers.
%H A395676 Paolo Xausa, <a href="/A395676/b395676.txt">Table of n, a(n) for n = 1..10000</a>
%H A395676 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/HarshadNumber.html">Harshad Number</a>.
%H A395676 Wikipedia, <a href="https://en.wikipedia.org/wiki/Harshad_number">Harshad number</a>.
%t A395676 A395676Q[k_] := Divisible[k, DigitSum[k, 6]];
%t A395676 Select[Range[250], A395676Q]
%o A395676 (PARI) isok(k) = (k % sumdigits(k, 6)) == 0; \\ _Michel Marcus_, May 04 2026
