%S A395700 1,4,9,12,21,25,27,49,55,56,57,65,75,81,115,119,121,125,132,133,169,
%T A395700 171,183,203,217,219,237,243,253,265,275,280,289,301,305,319,329,341,
%U A395700 343,355,361,365,377,403,481,489,505,507,515,517,529,543,549,552,565,583
%N A395700 k is term if and only if k = gcd(k^2, k!) / gcd(k^2, k!/floor(k/2)!^2).
%F A395700 k is term <=> A181859(k) = k.
%p A395700 aList := len -> select(n -> A181859(n) = n, [seq(1..len)]): aList(600);
%o A395700 (SageMath)  # Legendre's point of view
%o A395700 def is_a(n: int) -> bool:
%o A395700     if n == 1: return True
%o A395700     if is_prime(n): return False
%o A395700     def vp(num: int, p: int) -> int:
%o A395700         count = 0
%o A395700         while num >= p:
%o A395700             num //= p
%o A395700             count += num
%o A395700         return count
%o A395700     m = n // 2
%o A395700     for p, k in factor(n):
%o A395700         vn = vp(n, p); vm = vp(m, p)
%o A395700         if k != min(2*k, vn) - min(2*k, vn - 2*vm):
%o A395700             return False
%o A395700     return True
%o A395700 L = [n for n in range(1, 584) if is_a(n)]; print(L)
%o A395700 (SageMath)  # Kummer's point of view
%o A395700 def is_a(n: int) -> bool:
%o A395700     if n == 1: return True
%o A395700     if is_prime(n): return False
%o A395700     def s(x, p) -> int:
%o A395700         return sum(ZZ(x).digits(base=p))
%o A395700     m = n // 2
%o A395700     is_odd = (n % 2 != 0)
%o A395700     for p, k in factor(n):
%o A395700         vn = (n - s(n, p)) // (p - 1)
%o A395700         carries = (2 * s(m, p) - s(2 * m, p)) // (p - 1)
%o A395700         v_cb = carries + (k if is_odd else 0)
%o A395700         if k != min(2 * k, vn) - min(2 * k, v_cb):
%o A395700             return False
%o A395700     return True
%o A395700 L = [n for n in range(1, 584) if is_a(n)]; print(L)
%Y A395700 Cf. A001405, A181859.
