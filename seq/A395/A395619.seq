%T A395619 4,6,6,6,36,2,6,6,12,2,30,2,12,12,6,2,48,4,18,6,12,2,18,6,12,6,6,2,60,
%U A395619 2,6,12,64,6,30,2,12,6,30,2,36,2,6,18,12,6,30
%N A395619 For any n > 0 with prime factorization Prod_{i = 1..k} p_i^e_i where p_1 < ... < p_k and e_1, ..., e_k > 0, a(n) = Prod_{i = 1..k} prime(i)^a(e_i) (where prime(i) denotes the i-th prime numbers).
%C A395619 A recursive variant of A071364 with fixed points A309096.
%H A395619 Rémy Sigrist, <a href="/A395619/b395619.txt">Table of n, a(n) for n = 1..10000</a>
%F A395619 a(a(n)) = a(n).
%e A395619 a(10) = a(2^1 * 5^1) = 2^a(1) * 3^a(1) = 2 * 3 = 6.
%e A395619 a(413343) = a(3^10 * 7^1) = 2^a(10) * 3^a(1) = 2^6 * 3 = 192.
%o A395619 (PARI) a(n) = { my (f = factor(n)); prod (k = 1, #f~, prime(k)^a(f[k, 2])); }
%Y A395619 Cf. A071364, A284476, A309096.
%K A395619 nonn,new
%O A395619 1,2
%A A395619 _Rémy Sigrist_, May 01 2026
