%I A395414 #10 May 03 2026 23:10:36
%S A395414 36,100,192,196,216,225,441,484,676,750,900,960,1000,1080,1089,1152,
%T A395414 1156,1225,1280,1296,1444,1458,1521,1764,2116,2601,2688,2744,3024,
%U A395414 3025,3249,3364,3375,3402,3430,3844,4225,4356,4761,4900,5476,5929,6084,6144,6724,6912
%N A395414 Numbers k in A024619 such that A008472(k) is a proper divisor of A001414(k).
%C A395414 Numbers k that are not powers of primes, such that the sum of distinct prime factors of k divides the sum of prime factors with multiplicity, yet these sums are not equal.
%C A395414 Let s = A008472 and let t = A001414.
%C A395414 Primes p are such that s(p) = t(p) = p. Perfect prime powers p^m (in A246547), with m > 1, are such that s(p^m) = p and t(p^m) = m*p = m*s(p^m), thus s(p^m) | t(p^m), yet s(p^m) < t(p^m), m > 1. This sequence does not include these trivial cases.
%C A395414 Proper subset of A013929, since squarefree k implies s(k) = t(k).
%C A395414 Proper subset of A126706 = A013929 \ A000961.
%C A395414 Superset of A303606, since for k^m, m > 1 for squarefree composite k (in A120944), s(k^m) = s(k) and t(k^m) = t(m*k) = m*s(k).
%H A395414 Michael De Vlieger, <a href="/A395414/b395414.txt">Table of n, a(n) for n = 1..5000</a>
%e A395414 Table of n, a(n) = k, s(k), and t(k) for select n:
%e A395414     n      a(n) = k                      s(k)   t(k)
%e A395414   --------------------------------------------------
%e A395414     1        36 = 2^2 * 3^2                5     10
%e A395414     2       100 = 2^2 * 5^2                7     14
%e A395414     3       192 = 2^6 * 3                  5     15
%e A395414     4       196 = 2^2 * 7^2                9     18
%e A395414     5       216 = 2^3 * 3^3                5     15
%e A395414     6       225 = 3^2 * 5^2                8     16
%e A395414    10       750 = 2 * 3 * 5^3             10     20
%e A395414    16      1152 = 2^7 * 3^2                5     20
%e A395414    90     22500 = 2^2 * 3^2 * 5^4         10     30
%e A395414   105     30870 = 2 * 3^2 * 5 * 7^3       17     34
%e A395414   691   1031730 = 2 * 3 * 5 * 7 * 17^3    34     68
%e A395414   793   1327104 = 2^14 * 3^4               5     40
%t A395414 r = Select[Range[2^13], Nor[SquareFreeQ[#], PrimePowerQ[#] ] &]; s[x_] := If[x == 1, 0, Total[FactorInteger[x][[All, 1]] ] ]; t[x_] := If[x == 1, 0, Total[Join @@ ConstantArray @@@ FactorInteger[x] ] ]; Select[r, Divisible[t[#], s[#] ] &]
%Y A395414 Cf. A000961, A001414, A008472, A013929, A024619, A027746, A027748, A126706, A246547, A303606.
%K A395414 nonn,easy,new
%O A395414 1,1
