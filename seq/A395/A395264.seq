%S A395264 5,13,37,53,61,109,149,151,157,173,197,269,277,293,317,373,389,397,
%T A395264 421,557,613,653,661,677,701,733,757,773,797,821,829,853,877,997,1013,
%U A395264 1069,1093,1117,1181,1213,1237,1277,1301,1373,1381,1429,1453,1493,1597,1613,1637,1693,1733,1877
%N A395264 Primes p such that the number of quadratic residues in the Lucas sequence A000032 modulo p over a full Lucas sequence period A106291(p) equals the number of nonresidues plus the number of terms divisible by p.
%C A395264 Primes p such that N(1)=N(-1)+N(0) where N(j) is the number of i with 0<=i<A106291(p) such that (L(i)/p)=j.
%C A395264 See A394870 for Fibonacci sequence case.
%H A395264 Jason D. Andoyo, <a href="/A395264/b395264.txt">Table of n, a(n) for n = 1..1814</a>
%e A395264 p=5: A106291(5)=4: Legendre symbols (L(i)/5), 0 <= i < 4: -1, 1, -1, 1: N(0)=0, N(-1)=2, N(1)=2. 2=2+0.
%o A395264 (Python)
%o A395264 from sympy import legendre_symbol, primerange
%o A395264 def check(p):
%o A395264     N, a, b = [], 2, 1
%o A395264     while True:
%o A395264         N.append(legendre_symbol(a, p))
%o A395264         a, b = b, (a + b) % p
%o A395264         if (a, b) == (2, 1): break
%o A395264     return N.count(1) == N.count(-1) + N.count(0)
%o A395264 print([p for p in primerange(3, 3000) if check(p)])
%Y A395264 Cf. A394870, A000032, A106291.
%K A395264 nonn,new
%O A395264 1,1
%A A395264 _Jason D. Andoyo_, Apr 17 2026
