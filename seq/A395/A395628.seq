%S A395628 1,2,3,16,45,384,1575,18432,99225,1474560,9823275,176947200,
%T A395628 1404728325,29727129600,273922023375,6658877030400,69850115960625,
%U A395628 1917756584755200,22561587455281875,690392370511872000,9002073394657468125,303772643025223680000,4348001449619557104375,160391955517318103040000,2500100833531245335015625
%N A395628 a(n) = f(n+1) * n! where f(n) = n/f(n-1), f(1) = 1.
%C A395628 Also, the inverse of the fraction where the numerator is (...(1/2)/3...)/n = 1/n! and the denominator is (n+1)/(n/(.../(2/1)...)), sometimes written in a diamond shape with each of the numbers as 1+...+1, cf. EXAMPLE.
%H A395628 Paolo Xausa, <a href="/A395628/b395628.txt">Table of n, a(n) for n = 0..449</a>
%F A395628 a(n) = (n+1)!*(n-1)! / a(n-1) for n > 0.
%F A395628 a(2n+1) = A002474(n).
%e A395628 For n >= 1, the terms are the inverse of the fractions
%e A395628   1      1        1                        1
%e A395628 ----- = ---  ;   ---                      ---
%e A395628  1+1     2       1+1      1/2     1       1+1
%e A395628  ---           ------- = ----- = --- ;   -----
%e A395628   1             1+1+1     3/2     3      1+1+1      (1/2)/3     1/6
%e A395628                 -----                  --------- = --------- = ----- = 1/16, etc.
%e A395628                  1+1                    1+1+1+1     4/(3/2)     8/3
%e A395628                  ---                    -------
%e A395628                   1                      1+1+1
%e A395628                                          -----
%e A395628                                           1+1
%e A395628                                           ---
%e A395628                                            1
%t A395628 FoldList[(#2+1)!*(#2-1)!/# &, 1, Range[25]] (* _Paolo Xausa_, Jun 11 2026 *)
%o A395628 (PARI) apply( {A395628(n)=if(n<3,n+1,(n+1)!*(n-1)!/A395628(n-1))}, [0..20])
%Y A395628 Cf. A002474.
%K A395628 nonn,new
%O A395628 0,2
%A A395628 _M. F. Hasler_, Jun 05 2026
