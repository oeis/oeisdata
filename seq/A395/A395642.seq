%N A395642 Triangular array: row n shows the coefficients of the polynomial - n!*L(n, x), where L(n, x) is the Lagrange interpolating polynomial that passes through (0,-1) and (k,(-1)^(k+1)) for k = 1..n.
%e A395642 First eight rows:
%e A395642      1
%e A395642      1       -2
%e A395642      2       -8        4
%e A395642      6      -40       36       -8
%e A395642     24     -256      320     -128       16
%e A395642    120    -2048     3200    -1760      400     -32
%e A395642    720   -19968    36736   -24960     7840   -1152     64
%e A395642   5040  -231936   482944  -382592   148960  -30464   3136  -128
%e A395642 Row 4 represents the polynomial 24 - 256*x + 320*x^2 - 128*x^3 + 16*x^4.
%t A395642 s[n_] := Join[{{0, -1}}, Table[{k, (-1)^(k + 1)}, {k, 1, n}]];
%t A395642 p[n_, x_] := Expand[InterpolatingPolynomial[s[n], x]];
%t A395642 Column[Table[CoefficientList[-n!*p[n, x], x], {n, 0, 10}]]
%t A395642 Flatten[Table[CoefficientList[-n!*p[n, x], x], {n, 0, 10}]]
%t A395642 Labeled[Plot[{p[1, x], p[2, x], p[3, x], p[4, x], p[5, x]}, {x, -1, 7}], "Plot of p[n,x] for n=1..5."]
