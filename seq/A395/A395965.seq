%I A395965 #13 May 19 2026 23:12:50
%S A395965 0,2,5,6,8,10,11,15,17,18,20,22,27,28,29,30,32,35,36,39,40,43,45,46,
%T A395965 48,49,50,56,57,58,60,62,65,66,67,71,73,74,75,79,81,82,83,87,88,91,92,
%U A395965 95,97,100,101,102,103,104,105,107,115,116,117,119
%N A395965 Numbers k such that A395964(k) = 0.
%C A395965 Complement of A395966.
%H A395965 Benoit Cloitre, <a href="https://arxiv.org/abs/2604.06243">The Thue-Morse Transform</a>, arXiv:2604.06243 [math.NT], 2026.
%o A395965 (Python)
%o A395965 def fib_word(L):
%o A395965     s = [0]
%o A395965     while len(s) < L:
%o A395965         s = sum(([0, 1] if c == 0 else [0] for c in s), [])
%o A395965     return s[:L]
%o A395965 def T(w):
%o A395965     N = len(w)
%o A395965     v = [i for i, b in enumerate(w) if b == 0]
%o A395965     u = [i for i, b in enumerate(w) if b == 1]
%o A395965     wp = [None] * N
%o A395965     wp[0] = 0
%o A395965     for k in range(N):
%o A395965         if wp[k] is None: break
%o A395965         if k < len(v) and v[k] < N: wp[v[k]] = wp[k]
%o A395965         if k < len(u) and u[k] < N: wp[u[k]] = 1 - wp[k]
%o A395965     return wp
%o A395965 T2f = T(T(fib_word(300)))
%o A395965 print([k for k, b in enumerate(T2f) if b == 0][:60])
%Y A395965 Cf. A395964, A395966.
%K A395965 nonn,new
%O A395965 1,2
%A A395965 _Benoit Cloitre_, May 12 2026
