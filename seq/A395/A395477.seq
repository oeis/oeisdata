%I A395477 #25 Jun 02 2026 01:15:53
%S A395477 4,25,39,69,55,111,91,115,159,143,187,262,253,215,235,274,287,327,323,
%T A395477 335,407,395,533,511,502,535,515,527,538,611,635,674,614,707,802,746,
%U A395477 706,895,838,886,818,926,914,995,922,958,998,1149,1007,1082,1126,1067
%N A395477 a(n) is the smallest semiprime that can be partitioned in exactly n unique ways into two coprime semiprimes.
%C A395477 Also smallest semiprime k where A088183(k) = n.
%C A395477 a(542) is conjectured to not exist; if it does, its lower bound is 5600000.
%C A395477 a(542), if it exists, exceeds 11000000. - _Sean A. Irvine_, Jun 02 2026
%H A395477 Hoang Nguyen, <a href="/A395477/b395477.txt">Table of n, a(n) for n = 0..541</a>
%e A395477 4 = 2*2 is the smallest semiprime without a partition into two coprime semiprimes, so a(0) = 4.
%e A395477 25 = 5*5 = 2*2 + 3*7 is the smallest semiprime with a unique partition, so a(1) = 25.
%e A395477 39 = 3*13 = 2*2 + 5*7 = 2*7 + 5*5 is the smallest semiprime with two unique partitions, so a(2) = 39.
%e A395477 55 = 5*11 = 2*2 + 3*17 = 2*3 + 7*7 = 3*3 + 2*23 = 3*7 + 2*17 is the smallest semiprime with four unique partitions, so a(4) = 55.
%o A395477 (Julia)
%o A395477 using Primes
%o A395477 function a(n)
%o A395477     num = 1
%o A395477     while true
%o A395477         num += 1
%o A395477         if length(factor(Vector, num)) == 2
%o A395477             i = 0
%o A395477             for j in 4:num÷2
%o A395477                 k = num - j
%o A395477                 if length(factor(Vector, j)) == 2 && length(factor(Vector, k)) == 2 && gcd(j, k) == 1
%o A395477                     i += 1
%o A395477                 end
%o A395477             end
%o A395477             if i == n
%o A395477                 return num
%o A395477             end
%o A395477         end
%o A395477     end
%o A395477 end
%Y A395477 Cf. A001358, A088183.
%K A395477 nonn
%O A395477 0,1
%A A395477 _Hoang Nguyen_, May 27 2026
