%I A395418 #12 Apr 23 2026 15:08:30
%S A395418 0,1,2,3,4,10,9,7,8,6,5,38,12,37,35,15,16,34,33,22,40,21,19,142,36,52,
%T A395418 50,141,49,139,135,31,32,18,17,14,24,13,11,78,20,44,42,77,41,75,71,
%U A395418 542,48,28,26,204,25,202,198,541,56,201,197,539,195,535,527,63
%N A395418 For any n with Hamming weight h > 0, reverse each chunk of h bits in the binary expansion of n (possibly with leading 0's); a(0) = 0.
%C A395418 A self-inverse permutation of the nonnegative integers preserving the Hamming weight.
%H A395418 Rémy Sigrist, <a href="/A395418/b395418.txt">Table of n, a(n) for n = 0..8192</a>
%H A395418 Rémy Sigrist, <a href="/A395418/a395418.png">Colored scatterplot of the sequence such that n, a(n) < 2^26</a> (where the color is function of A000120(n))
%H A395418 <a href="/index/Bi#binary">Index entries for sequences related to binary expansion of n</a>
%H A395418 <a href="/index/Per#IntegerPermutation">Index entries for sequences that are permutations of the natural numbers</a>
%F A395418 a(n) = Sum_{k >= 0} b_k * 2^A210635(A000120(n), k) for any n with binary expansion Sum_{k >= 0} b_k * 2^k.
%F A395418 a(2^k) = 2^k for any k >= 0.
%F A395418 a(2^k-1) = 2^k-1 for any k >= 0.
%F A395418 a(n * A001316(n)) = a(n) * A001316(n).
%e A395418 The first terms, in decimal and in binary, are:
%e A395418   n   a(n)  bin(n)   bin(a(n))
%e A395418   --  ----  -------  ---------
%e A395418    0     0        0          0
%e A395418    1     1        1          1
%e A395418    2     2      1|0        1|0
%e A395418    3     3       11         11
%e A395418    4     4    1|0|0      1|0|0
%e A395418    5    10    01|01      10|10
%e A395418    6     9    01|10      10|01
%e A395418    7     7      111        111
%e A395418    8     8  1|0|0|0    1|0|0|0
%e A395418    9     6    10|01      01|10
%e A395418   10     5    10|10      01|01
%e A395418   11    38  001|011    100|110
%e A395418   12    12    11|00      11|00
%e A395418   13    37  001|101    100|101
%e A395418   14    35  001|110    100|011
%e A395418   15    15     1111       1111
%o A395418 (PARI) a(n, h = hammingweight(n)) = { my (v = 0, e); while (n, n -= 2^e = exponent(n); v += 2^(h*(e\h) + h-1-(e%h));); return (v); }
%Y A395418 Cf. A000120, A001316, A057300, A210635, A344531, A373038.
%K A395418 nonn,base,easy,new
%O A395418 0,3
%A A395418 _Rémy Sigrist_, Apr 21 2026
