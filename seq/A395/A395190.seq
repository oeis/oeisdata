%I A395190 #9 May 14 2026 18:22:34
%S A395190 1,1,1,1,1,2,1,1,1,2,1,4,1,3,4,3,1,8,1,12,8,6,1,35,1,8,15,31,1,75,1,
%T A395190 47,31,17,55,153,1,23,59,277,1,319,1,174,286,45,1,979,1,367,192,388,1,
%U A395190 1123,517,1600,331,111,1,4836,1,147,1889,2045,1374,3533,1,1638
%N A395190 a(n) is the number of partitions of n into distinct parts that contain a subset whose product is n.
%H A395190 Felix Huber, <a href="/A395190/b395190.txt">Table of n, a(n) for n = 1..2143</a>
%F A395190 a(n) = 1  <=>  n is in A000961.
%F A395190 1 <= a(n) <= A000009(n) for n >= 1.
%e A395190 a(12) = 4: [12], [3, 4, 5], [2, 4, 6], [1, 2, 3, 6], since in each case a subset of the parts has product 12 (namely 12; 3*4; 2*6; and 2*6, respectively).
%p A395190 f := proc(r, l) option remember;
%p A395190     local d, s, t;
%p A395190     if r = 1 then return [[]] end if;
%p A395190     s := []:
%p A395190     for d in NumberTheory:-Divisors(r) do
%p A395190         if d >= l and d > 1 then
%p A395190             for t in f(r/d, d + 1) do
%p A395190                 s := [op(s), [d, op(t)]]
%p A395190             end do
%p A395190         end if
%p A395190     end do;
%p A395190     s
%p A395190 end:
%p A395190 p := n -> f(n, 2):
%p A395190 A395190 := proc(n)
%p A395190     local a, b, i, j, l;
%p A395190     a := 0:
%p A395190     for j in p(n) do
%p A395190         l := remove(x -> member(x, j), [seq(i, i = 1 .. n)]):
%p A395190         b := proc(m, i, l) option remember;
%p A395190             `if`(m = 0, 1, `if`(i = 0, 0, b(m, i - 1, l) + `if`(l[i] > m, 0, b(m - l[i], i - 1, l))))
%p A395190         end proc:
%p A395190         a := a + b(n - add(j), nops(l), l)
%p A395190     end do;
%p A395190     a
%p A395190 end proc:
%p A395190 seq(A395190(n), n = 1 .. 68);
%Y A395190 Cf. A000009, A000961, A045778.
%K A395190 nonn,new
%O A395190 1,6
%A A395190 _Felix Huber_, May 10 2026
