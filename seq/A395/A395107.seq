%S A395107 1,4,243,63968,47375765,76135612293,226732270453710,
%T A395107 1127347866701008744,8691297687096561198801,
%U A395107 98302504995185961418083775,1562564628371859275712788433304,33728075328950831587033886682997662,961242723766682152920895527173133386150,35335379721830786696290720595355738390791158
%N A395107 G.f. A(x) satisfies [x^n] exp( n*A(x) ) * (1-n^3*x)^(1/n^2) = 0, for n >= 1.
%H A395107 Seiichi Manyama, <a href="/A395107/b395107.txt">Table of n, a(n) for n = 1..153</a>
%F A395107 a(n) = n^(3*n-4) - (1/n) * Sum_{k=1..n-1} k * c_n(k) * e_n(n-k),
%F A395107 where c_n(k) = a(k) - n^(3*k-3)/k for 1 <= k <= n-1,
%F A395107 and e_n(0) = 1, e_n(k) = (n/k) * Sum_{j=1..k} j * c_n(j) * e_n(k-j) for 1 <= k <= n-1.
%o A395107 (Ruby)
%o A395107 def A395107(n)
%o A395107   a = [0]
%o A395107   (1..n).each{|i|
%o A395107     c = [0] + (1..i - 1).map{|k| a[k] - i ** (3 * k - 3) / k.to_r}
%o A395107     e = [1]
%o A395107     (1..i - 1).each{|k| e << i / k.to_r * (1..k).inject(0){|s, j| s + j * c[j] * e[k - j]}}
%o A395107     a << i ** (3 * i - 4) - (1..i - 1).inject(0){|s, k| s + k * c[k] * e[i - k]}.to_i / i
%o A395107   }
%o A395107   a[1..-1]
%o A395107 end
%o A395107 p A395107(20)
%Y A395107 Cf. A088716, A395106.
%Y A395107 Cf. A300619, A395075.
%K A395107 nonn,new
%O A395107 1,2
%A A395107 _Seiichi Manyama_, Apr 11 2026
