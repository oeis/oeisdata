%I A395028 #48 May 19 2026 19:01:17
%S A395028 1,2,3,4,5,8,9,10,13,14,15,22,29,34,35,52,61,66,71,84,97,98,99,104,
%T A395028 105,106,109,110,111,112,117,124,131,136,139,152,165,184,185,196,199,
%U A395028 204,205,214,217,218,219,230,231,236,255,274,277,302,303,304,309,310
%N A395028 a(1) = 1; a(n) is the smallest integer so that a(n) > a(n-1) and a(n)^4+a(n-1)^4 is prime.
%C A395028 A third-power counterpart (sum of cubes) does not exist as a^3 + b^3 = (a + b)*(a^2 - ab + b^2). For the product to be prime, either factor must be 1, but the only nonnegative solution where a < b is a = 0 and b = 1, which gives the nonprime 1. This also applies to any higher odd powers.
%C A395028 The list alternates between odd and even, as there would be an even sum otherwise.
%H A395028 Michael S. Branicky, <a href="/A395028/b395028.txt">Table of n, a(n) for n = 1..10000</a> (terms 1..1090 from Hoang Nguyen)
%F A395028 a(n) = A158979(a(n-1)) for n >= 2. - _Jason Yuen_, May 15 2026
%e A395028 a(2) = 2 as 1^4 + 2^4 = 17 is prime.
%e A395028 a(6) = 8 as 5^4 + 6^4 = 1921 = 17 * 113, 5^4 + 7^4 is even, and 5^4 + 8^4 = 4721 is prime.
%t A395028 a[n_] := a[n] = Module[{k = a[n-1] + 1}, While[! PrimeQ[k^4 + a[n-1]^4], k++]; k]; a[1] = 1; Array[a, 60] (* _Amiram Eldar_, May 16 2026 *)
%o A395028 (Julia)
%o A395028 using Primes
%o A395028 function aupto(n)
%o A395028     num = 1
%o A395028     for _ in 1:n
%o A395028         print("$num, ")
%o A395028         next = num + 1
%o A395028         while !isprime(num^4 + next^4)
%o A395028             next += 2
%o A395028         end
%o A395028         num = next
%o A395028     end
%o A395028 end
%o A395028 aupto(60)
%o A395028 (PARI) lista(nn) = my(v=vector(nn)); v[1] = 1; for (n=2, nn, my(k=v[n-1]+1); while (!isprime(k^4+v[n-1]^4), k++); v[n]=k;); v; \\ _Michel Marcus_, May 16 2026
%o A395028 (Python)
%o A395028 from itertools import count, islice
%o A395028 from sympy import isprime
%o A395028 def agen(): # generator of terms
%o A395028     an = 1
%o A395028     while True:
%o A395028         yield an
%o A395028         b = an**4
%o A395028         an = next(k for k in count(an+1, 2) if isprime(k**4+b))
%o A395028 print(list(islice(agen(), 60))) # _Michael S. Branicky_, May 16 2026
