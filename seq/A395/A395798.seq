%N A395798 Expansion of -1/(Sum_{k>=0} binomial(5*k+1,k) * x^k).
%F A395798 G.f.: -1/B(x) where B(x) is the g.f. of A079589.
%F A395798 G.f.: (4*g-5)/g^2 where g = 1+x*g^5 is the g.f. of A002294.
%F A395798 a(n) = (1/n) * (6*binomial(5*n-3,n-1) - 4*binomial(5*n-3,n-2)) for n > 0.
%F A395798 a(n) = (1/n) * (10*binomial(5*n-3,n-1) - 4*binomial(5*n-2,n-1)) for n > 0.
%o A395798 (PARI) my(N=30, x='x+O('x^N)); Vec(-1/sum(k=0, N, binomial(5*k+1, k)*x^k))
