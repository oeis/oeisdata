%U A395040 614889782588491424,20,2328,30048,78,231,32589158477190044750,0,4,7,7420738134810,30032,218,4,32589158477190044730,7858321551080267055879090,512820
%N A395040 a(n) = A276085(A003415(A276086(n))).
%H A395040 Antti Karttunen, <a href="/A395040/b395040.txt">Table of n, a(n) for n = 1..248</a>
%H A395040 <a href="/index/Pri#primorialbase">Index entries for sequences related to primorial base</a>.
%F A395040 a(n) = A276085(A327860(n)).
%F A395040 a(n) = A395041(A276086(n)).
%o A395040 (PARI)
%o A395040 A003415(n) = if(n<=1, 0, my(f=factor(n)); n*sum(i=1, #f~, f[i, 2]/f[i, 1]));
%o A395040 A276085(n) = { my(f=factor(n)); sum(k=1, #f~, f[k, 2]*prod(i=1,primepi(f[k, 1]-1),prime(i))); };
%o A395040 A276086(n) = { my(m=1, p=2); while(n, m *= (p^(n%p)); n = n\p; p = nextprime(1+p)); (m); };
%o A395040 A395040(n) = A276085(A003415(A276086(n)));
%Y A395040 Cf. A002110 (indices of 0's), A003415, A276085, A276086, A327860, A395041.
%K A395040 nonn,base,easy,new
