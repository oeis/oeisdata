%T A395277 20,23,26,24,31,27,30,32,41,34,37,40,43,43,49,40,55,53,57,49,62,57,66,
%U A395277 63,70,60,74,69,85,76,81,76,99,78,94,82,103,91,111,96
%N A395277 a(n) = number of 4-tuples (w, x, y, z) of distinct positive integers w, x, y, z such that w*x + y*z = n, where w*x <= y*z, w < x, and y < z.
%e A395277 a(17) = 7 counts these 4-tuples: (1, 2, 3, 5), (1, 3, 2, 7), (1, 5, 2, 6), (1, 5, 3, 4), (2, 3, 1, 11), (1, 7, 2, 4), (2, 4, 1, 9).
%t A395277 a[n_] := Module[{count = 0, p, q, w, x, y, z},
%t A395277 Do[q = n - p; Do[x = p/w; Do[z = q/y;
%t A395277 If[Length[Union[{w, x, y, z}]] == 4, count++], {y, Select[Divisors[q], # < Sqrt[q] &]}],
%t A395277 {w, Select[Divisors[p], # < Sqrt[p] &]}], {p, 1, Floor[n/2]}]; count];
%t A395277 Table[a[n], {n, 0, 80}]
%Y A395277 Cf. A393710, A394740, A394743, A394786, A394787.
