%S A395009 0,0,2,2,0,5,5,7,7,5,10,10,0,13,13,15,15,13,18,18,20,20,18,23,23,13,
%T A395009 26,26,28,28,26,31,31,0,34,34,36,36,34,39,39,41,41,39,44,44,34,47,47,
%U A395009 49,49,47,52,52,54,54,52,57,57,47,60,60,62,62,60,65,65,34
%N A395009 a(n) is the greatest k < n such that {phi*k} < {phi*n}, where {} denotes the fractional part and phi = A001622.
%H A395009 Rémy Sigrist, <a href="/A395009/b395009.txt">Table of n, a(n) for n = 1..10000</a>
%F A395009 Empirically: a(n) = 0 iff n belongs to A001519.
%e A395009 The first terms are:
%e A395009   n   {phi*n}  a(n)
%e A395009   --  -------  ----
%e A395009    0  0.       N/A
%e A395009    1  0.61...     0
%e A395009    2  0.23...     0
%e A395009    3  0.85...     2
%e A395009    4  0.47...     2
%e A395009    5  0.09...     0
%e A395009    6  0.70...     5
%e A395009    7  0.32...     5
%e A395009    8  0.94...     7
%e A395009    9  0.56...     7
%e A395009   10  0.18...     5
%t A395009 A395009[n_] := Module[{k = n, f = FractionalPart[GoldenRatio*n]}, While[FractionalPart[--k*GoldenRatio] >= f]; k];
%t A395009 Array[A395009, 100] (* _Paolo Xausa_, Apr 13 2026 *)
%o A395009 (PARI) a(n, phi = (1+sqrt(5))/2) = { my (f = frac(phi * n)); forstep (k = n-1, -oo, -1, if (frac(phi * k) < f, return (k););); }
%Y A395009 Cf. A001519, A001622, A019587, A393813.
%K A395009 nonn,new
%O A395009 1,3
%A A395009 _Rémy Sigrist_, Apr 09 2026
