%I A395505 #12 Apr 26 2026 17:56:10
%S A395505 1,1,1,1,4,2,1,9,21,9,1,16,84,160,64,1,25,230,950,1625,625,1,36,510,
%T A395505 3600,12960,20736,7776,1,49,987,10535,63455,208887,319333,117649,1,64,
%U A395505 1736,25984,232960,1261568,3899392,5767168,2097152
%N A395505 Triangle of polynomials refining A367255.
%C A395505 The cases when n=0,1 are a bit special, involving some cancellations.
%F A395505 The n-th row is given by the polynomial (1+x*n)^(n-2)*(1+2*n*x+n*x^2).
%e A395505 The first few rows are:
%e A395505   1;
%e A395505   1, 1;
%e A395505   1, 4, 2;
%e A395505   1, 9, 21, 9;
%e A395505   1, 16, 84, 160, 64;
%e A395505   1, 25, 230, 950, 1625, 625;
%e A395505   ...
%t A395505 row[n_]:=CoefficientList[(1+x*n)^(n-2)*(1+2*n*x+n*x^2),x]; Array[row,9,0]//Flatten (* _Stefano Spezia_, Apr 26 2026 *)
%o A395505 (SageMath)
%o A395505 x = polygen(QQ, 'x')
%o A395505 def row(n):
%o A395505     return (1+x*n)**(n-2)*(1+2*n*x+n*x**2)
%o A395505 (PARI) row(n) = Vecrev((1+x*n)^(n-2)*(1+2*n*x+n*x^2)); \\ _Michel Marcus_, Apr 26 2026
%Y A395505 Cf. A000169, A367255.
%K A395505 nonn,tabl,new
%O A395505 0,5
