%I A395856 #5 May 11 2026 23:52:34
%S A395856 27,457,12069,449439,22145671
%N A395856 Number of intervals in the weak order on the Coxeter group B_n.
%D A395856 Anders Björner and Francesco Brenti, Combinatorics of Coxeter groups. Graduate Texts in Mathematics, 231. Springer, New York, 2005.
%o A395856 (SageMath)
%o A395856 def WeakOrder(W):
%o A395856     L = [CoxeterGroup(W).one()]
%o A395856     G = {}
%o A395856     while len(L)>0:
%o A395856         L2 = set()
%o A395856         for w in L:
%o A395856             G[w] = w.upper_covers()
%o A395856             L2 = L2.union(G[w])
%o A395856         L = L2
%o A395856     return DiGraph(G)
%o A395856 print([Poset(WeakOrder(['B',n])).intervals_number() for n in range(2,6)])
%Y A395856 Cf. A000165, A007767 (type A), A395857 (type D).
%K A395856 nonn,more,new
%O A395856 2,1
%A A395856 _Ludovic Schwob_, May 08 2026
