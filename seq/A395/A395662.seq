%S A395662 180,1470,56700,18523890,425675250,257432175,390769879500,
%T A395662 1904417007743250,21438612514068750,1881063815762259253125,
%U A395662 1211517431782539131250,6948173623016040171631875,3952575621190533915703125,42344185423359347502790906715625
%N A395662 Coefficient of zeta(n) in the linear equality by Plouffe for the odd values of the Riemann zeta function.
%H A395662 Jwalin Bhatt, <a href="/A395662/b395662.txt">Table of n, a(n) for n = 1..225</a>
%H A395662 Simon Plouffe, <a href="http://www.plouffe.fr/simon/inspired2.pdf">Identities inspired by Ramanujan Notebooks (part 2)</a>, April 2006.
%H A395662 Linas Vepštas, <a href="https://doi.org/10.1007/s11139-011-9335-9">On Plouffe's Ramanujan identities</a>, The Ramanujan Journal, Vol. 27 (2012), pp. 387-408; <a href="https://arxiv.org/abs/math/0609775">arXiv preprint</a>, arXiv:math/0609775 [math.NT], 2006-2010.
%H A395662 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/RiemannZetaFunction.html">Riemann Zeta Function</a>.
%H A395662 Wikipedia, <a href="https://en.wikipedia.org/wiki/Particular_values_of_the_Riemann_zeta_function#%CE%B6(2n_+_1)">zeta(2n+1)</a>.
%F A395662 a(n)*zeta(2n+1) - A395663(n)*Pi^(2n+1) + (2*a(n)+d(n))*S_m(2n+1) + d(n)*S_p(2n+1) = 0, where d(n) = A395748(n/2) if n is even else 0, S_p(n) = Sum_{k>=1} 1/((k^n)*(exp(2*Pi*k)+1)) and S_m(n) = Sum_{k>=1} 1/((k^n)*(exp(2*Pi*k)-1)).
%F A395662 For odd n:
%F A395662   a(n) = A394977(n).
%F A395662   a(n) = A057867((n+1)/2).
%e A395662 180*zeta(3) - 7*Pi^(3) + 360*S_m(3) + 0*S_p(3) = 0.
%e A395662 1470*zeta(5) - 5*Pi^(5) + 3024*S_m(5) + 84*S_p(5) = 0.
%e A395662 56700*zeta(7) - 19*Pi^(7) + 113400*S_m(7) + 0*S_p(7) = 0.
%e A395662 18523890*zeta(9) - 625*Pi^(9) + 37122624*S_m(9) + 74844*S_p(9) = 0.
%t A395662 a[n_] := Module[{n0, s, s1, s2, f, sVal, frac},
%t A395662   If[OddQ[n], (* 4n - 1 case *)
%t A395662    n0 = Floor[n/2] + 1;
%t A395662    s = Sum[
%t A395662      (-1)^j * Binomial[4*n0, 2*j] * BernoulliB[4*n0 - 2*j] * BernoulliB[2*j],
%t A395662      {j, 0, 2*n0}
%t A395662    ];
%t A395662    Denominator[-2^(4*n0 - 2) * s / Factorial[4*n0]]
%t A395662    ,
%t A395662    (* 4n + 1 case *)
%t A395662    n0 = n/2;
%t A395662    s1 = Sum[
%t A395662      (-4)^(n0 + j) * Binomial[4*n0 + 2, 4*j] * BernoulliB[4*n0 - 4*j + 2] * BernoulliB[4*j],
%t A395662      {j, 0, n0}
%t A395662    ];
%t A395662    s2 = Sum[
%t A395662      (-4)^j * Binomial[4*n0 + 2, 2*j] * BernoulliB[4*n0 - 2*j + 2] * BernoulliB[2*j],
%t A395662      {j, 0, 2*n0 + 1}
%t A395662    ];
%t A395662    sVal = 1 + (-4)^n0 - 2^(4*n0 + 1);
%t A395662    f = 2^(4*n0 + 1) * (s1 + s2/2) / Factorial[4*n0 + 2];
%t A395662    -Denominator[f] * sVal
%t A395662   ]
%t A395662 ]
%o A395662 (Python)
%o A395662 from sympy import binomial, bernoulli, factorial
%o A395662 def a(n):
%o A395662     if n%2 == 1: # 4n - 1
%o A395662         n = n//2 + 1
%o A395662         s = sum(
%o A395662             (-1)**j * binomial(4*n, 2*j) * bernoulli(4*n-2*j) * bernoulli(2*j)
%o A395662             for j in range(2*n + 1)
%o A395662         )
%o A395662         return (-2**(4*n-2) * s / factorial(4*n)).denominator
%o A395662     else: # 4n + 1
%o A395662         n //= 2
%o A395662         s1 = sum(
%o A395662             (-4)**(n+j) * binomial(4*n+2, 4*j) * bernoulli(4*n-4*j+2) * bernoulli(4*j)
%o A395662             for j in range(n+1)
%o A395662         )
%o A395662         s2 = sum(
%o A395662             (-4)**j * binomial(4*n+2, 2*j) * bernoulli(4*n-2*j+2) * bernoulli(2*j)
%o A395662             for j in range(2*n+2)
%o A395662         )
%o A395662         s = 1 + (-4)**n - 2**(4*n+1)
%o A395662         f = 2**(4*n+1) * (s1+s2/2) / factorial(4*n+2)
%o A395662         return -f.denominator * s
%Y A395662 Cf. A057867, A394977, A395663, A395748.
%K A395662 nonn,new
%O A395662 1,1
%A A395662 _Jwalin Bhatt_, May 03 2026
