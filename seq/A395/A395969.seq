%I A395969 #31 Jun 03 2026 22:44:46
%S A395969 2,8,10,32,110,116,142,230,258,272,332,406,428,480,692,776,818,1110,
%T A395969 1506,2408,3332,4520,7372,11110,27272,33332,101100,108910,111110,
%U A395969 123320,128712,129986,145742,207920,235430,287748,303302,326732,333332,340066,366336,369962
%N A395969 Numbers k such that 3*(k+1) divides the decimal concatenation [k, k+1, k+2].
%C A395969 If we consider the concatenation [k+2, k+1, k], we get the same terms apart from 8.
%C A395969 Also k+1 divides the concatenation.
%C A395969 If k+1 has d > 1 digits, then k is a term if and only if k+1 divides (10^(2*d)-1)/3. - _Robert Israel_, May 31 2026
%H A395969 Robert Israel, <a href="/A395969/b395969.txt">Table of n, a(n) for n = 1..10000</a> (first 100 terms from Paolo P. Lava)
%e A395969 a(1) = 2 -> 234/(2 + 3 + 4) = 234/9 = 26;
%e A395969 a(2) = 8 -> 8910/(8 + 9 + 10) = 8910/27 = 330; etc.
%p A395969 P:=proc(q) local n,v; v:=[]; for n from 1 to q do
%p A395969 if frac(parse(cat(n,n+1,n+2))/(3*n+3))=0 then v:=[op(v),n]; fi;
%p A395969 od; op(v); end: P(10^6);
%p A395969 # Alternative:
%p A395969 Q:= proc(d) select(t -> t >= 10^(d-1)-1 and t < 10^d - 1, NumberTheory:-Divisors((10^(2*d)-1)/3) -~ 1) end proc:
%p A395969 R:= {2,8}:
%p A395969 for d from 1 to 20 do R:= R union Q(d) od:
%p A395969 sort(convert(R,list)); # _Robert Israel_, May 31 2026
%o A395969 (Python)
%o A395969 from itertools import count, islice
%o A395969 from sympy import sympify
%o A395969 from sympy.abc import x,y
%o A395969 from sympy.solvers.diophantine.diophantine import diop_quadratic
%o A395969 def A395969_gen(): # generator of terms
%o A395969     for l in count(1):
%o A395969         c = []
%o A395969         for l2 in (l,l+1):
%o A395969             for p in diop_quadratic(sympify(x*(10**(l+l2)+10**l2+1-3*y)+10**l2+2-3*y)):
%o A395969                 k = int(p[0])
%o A395969                 if k>0 and len(str(k+1))==l and len(str(k+2))==l2:
%o A395969                     c.append(k)
%o A395969         yield from sorted(c)
%o A395969 A395969_list = list(islice(A395969_gen(),30)) # _Chai Wah Wu_, May 25 2026
%Y A395969 Cf. A001703, A173712, A375728.
%K A395969 nonn,base,easy,new
%O A395969 1,1
