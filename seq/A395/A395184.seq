%I A395184 #21 Apr 22 2026 00:53:10
%S A395184 1,3,9,43,177,803,3481,15451,67777,299091,1315881,5798155,25528785,
%T A395184 112444547,495178681,2180862139,9604459489,42298846131,186285317193,
%U A395184 820411044715,3613124902641,15912380528099,70078852447705,308630602346779,1359223582397185,5986084746384147,26362998079555689
%N A395184 Totals of the base-3 run-length transform of the Jacobsthal numbers.
%C A395184 Here J(k) = (2^k - (-1)^k)/3 are the Jacobsthal numbers.
%C A395184 a(n) is the total Jacobsthal weight of all base-3 words of length n, where each maximal block of nonzero digits of length k contributes a factor J(k).
%C A395184 Equivalently, if a base-3 word is replaced by its zero-support pattern in {0,1}^n, then a pattern with w 1's lifts to 2^w ternary words; a(n) is the resulting weighted sum over binary support patterns.
%C A395184 The classical binary Jacobsthal run-length-transform sequence is A071053.
%C A395184 More generally, a(n) is the total mass of the base-3 Jacobsthal run-length transform on the interval {0, ..., 3^n - 1}.
%D A395184 N. J. A. Sloane, "On the Number of ON Cells in Cellular Automata", in Connections in Discrete Mathematics: A Celebration of the Work of Ron Graham, Cambridge Univ. Press, 2018, pp. 13-38.
%H A395184 Ahmet Caglar Saygili, <a href="/A395184/b395184.txt">Table of n, a(n) for n = 0..1000</a>
%H A395184 D. Brod and A. Michalski, <a href="https://doi.org/10.2478/amsil-2022-0011">On Generalized Jacobsthal and Jacobsthal-Lucas Numbers</a>, Ann. Math. Siles. 36 (2022), no. 2, 115-128.
%H A395184 S. Kropf and S. Wagner, <a href="https://doi.org/10.37236/6373">On q-Quasiadditive and q-Quasimultiplicative Functions</a>, Electron. J. Combin. 24 (2017), no. 1, Paper P1.60.
%H A395184 <a href="/index/Rec#order_03">Index entries for linear recurrences with constant coefficients</a>, signature (3,8,-8).
%F A395184 a(0) = 1, a(1) = 3, a(2) = 9; for n >= 3, a(n) = 3*a(n-1) + 8*a(n-2) - 8*a(n-3).
%F A395184 G.f.: (1 - 8*x^2)/(1 - 3*x - 8*x^2 + 8*x^3).
%e A395184 There are 27 base-3 words of length 3. The totals recurrence gives a(3) = a(2) + 2*J(1)*a(1) + 2^2*J(2)*a(0) + 2^3*J(3) = 9 + 2*1*3 + 4*1*1 + 8*3 = 43.
%t A395184 LinearRecurrence[{3, 8, -8}, {1, 3, 9}, 30]
%o A395184 (Julia)
%o A395184 a(n) = begin
%o A395184     vals = BigInt[1, 3, 9]
%o A395184     while length(vals) <= n + 1
%o A395184         push!(vals, 3*vals[end] + 8*vals[end-1] - 8*vals[end-2])
%o A395184     end
%o A395184     vals[n + 1]
%o A395184 end
%o A395184 (Python)
%o A395184 def a(n):
%o A395184     vals = [1, 3, 9]
%o A395184     while len(vals) <= n:
%o A395184         vals.append(3*vals[-1] + 8*vals[-2] - 8*vals[-3])
%o A395184     return vals[n]
%Y A395184 Cf. A001045, A071053.
%K A395184 nonn,easy,new
%O A395184 0,2
%A A395184 _Ahmet Caglar Saygili_, Apr 15 2026
