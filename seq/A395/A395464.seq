%I A395464 #27 Jun 03 2026 13:39:35
%S A395464 19,27,32,38,54,57,76,96,108,114,133,152,160,171,189,216,228,266,342,
%T A395464 378,399,456,480,513,532,684,756,798,1026,1064,1197,1368,1512,1596,
%U A395464 2052,2394,3192,3591,4104,4788,7182,9576,14364,28728
%N A395464 Indices of 3 in A395473: Number k such that Q(chi) takes 3 different fields for chi running through the Dirichlet characters modulo k, where Q(chi) is the field generated by the values of chi.
%C A395464 Numbers k such that psi(k) = 8 or 18, where psi = A002322 is the reduced totient function. The three fields Q(chi) are either Q(zeta_2) = Q, Q(zeta_4), Q(zeta_8) or Q(zeta_2) = Q, Q(zeta_6), Q(zeta_18).
%C A395464 Each odd prime p occurs only finitely many times in A395473, since this implies psi(n) = 2^p or 2*3^(p-1). See A395473 for more details.
%C A395464 Union of {k: 32 | k | 480} and {k: 19 or 27 | k | 28728}.
%H A395464 Jianing Song, <a href="/A395464/a395464.txt">Number of characters generating each of the three fields</a>.
%H A395464 Wikipedia, <a href="https://en.wikipedia.org/wiki/Dirichlet_character">Dirichlet character</a>.
%t A395464 PositionIndex[DivisorSigma[0, CarmichaelLambda[Range[28728]]/2]][3] (* _Paolo Xausa_, Jun 03 2026 *)
%t A395464 (* Alternative, after PARI: *)
%t A395464 Union[Select[Divisors[480], Divisible[#, 32] &], Select[Divisors[28728], Divisible[#, 19] || Divisible[#, 27] &]] (* _Paolo Xausa_, Jun 03 2026 *)
%o A395464 (PARI) A395464_list = setunion(select(x->(x%32==0), divisors(480)), select(x->(x%19==0||x%27==0), divisors(28728)))
%Y A395464 Cf. A395473, A018253, A395563.
%K A395464 nonn,easy,fini,full
%O A395464 1,1
%A A395464 _Jianing Song_, May 28 2026
