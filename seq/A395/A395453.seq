%e A395453 Triangle starts:
%e A395453   [0] [1]
%e A395453   [1] [0, -1]
%e A395453   [2] [0, -1, 2]
%e A395453   [3] [0, -1, 5, -5]
%e A395453   [4] [0, -1, 6,  3, -21,  14]
%e A395453   [5] [0, -1, 7,  7, -28, -28,  84, -42]
%e A395453   [6] [0, -1, 8,  8,   4, -36, -72, -12, 120, 180, -330, 132]
%e A395453   [7] [0, -1, 9,  9,   9, -45, -90, -45, -45, 165,  495, 165, -495, -990, 1287, -429]
%t A395453 Trow[n_] := Module[{F, row, sign, numer, denom, j},
%t A395453   If[n == 0, Return[{1}]];
%t A395453   F = FoldList[Times, 1, Range[2 n]];
%t A395453   row = {0}; (* Convention *)
%t A395453   Do[
%t A395453     sign = If[OddQ[j], -1, 1];
%t A395453     numer = F[[n + j + 1]]; (* This is (n+j)! *)
%t A395453     Do[
%t A395453       denom = F[[n + 2]] * Times @@ (F[[#[[2]] + 1]] & /@ Tally[p]);
%t A395453       AppendTo[row, sign * (numer/denom)],
%t A395453       {p, IntegerPartitions[n, {j}]}
%t A395453     ],
%t A395453     {j, 1, n}
%t A395453   ];
%t A395453 row ];
%t A395453 Do[Print[Trow[n]], {n, 0, 9}];
%o A395453 (Python) # See the Links.
%Y A395453 A111785 is a variant without column 0 and a different order of partitions.
%Y A395453 Cf. A395450 (exponential series), A334439 (partition order), A000108 (main diagonal), A002054 (subdiagonal), A033999 (row sums), A001003 (alternating row sums), A000041 (row length).
%Y A395453 Cf. A086810 (Schröder trees), A001003.
%K A395453 sign,tabf,new
%O A395453 0,6
