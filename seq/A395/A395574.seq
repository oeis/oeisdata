%N A395574 1 = Sum_{n>=0} a(n) * x^n * (1 - (2*n+1)*x)^(n+1).
%H A395574 Seiichi Manyama, <a href="/A395574/b395574.txt">Table of n, a(n) for n = 0..314</a>
%F A395574 a(0) = 1; a(n) = Sum_{k=1..floor((n+1)/2)} (-1)^(k-1) * (2*n-2*k+1)^k * binomial(n-k+1,k) * a(n-k).
%o A395574 (PARI) a(n) = if(n==0, 1, sum(k=1, (n+1)\2, (-1)^(k-1)*(2*n-2*k+1)^k*binomial(n-k+1, k)*a(n-k)));
