%N A395175 a(n) = (2*n)! * [x^(2*n)] C(x)^4, where C(x) satisfies C(x) = cosh( Integral C(x)^5 dx ).
%F A395175 Let A(n,k) = (2*n)! * [x^(2*n)] C(x)^k. A(0,k) = 1 and A(n,k) = k*(k+5) * A(n-1,k+10) - k*(k+4) * A(n-1,k+8) for n > 0. a(n) = A(n,4).
%o A395175 (PARI) a(n, k=4) = if(n==0, 1, k*(k+5)*a(n-1, k+10)-k*(k+4)*a(n-1, k+8));
%Y A395175 Column k=4 of A395172.
%K A395175 nonn,new
%O A395175 0,2
