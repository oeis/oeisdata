%I A395918 #12 Jun 27 2026 13:55:46
%S A395918 0,1,1,3,2,2,4,5,2,6,5,4,10,8,8,10,10,12,7,2,8,14,6,8,16,21,3,4,16,26,
%T A395918 2,10,18,6,16,32,29,2,12,28,11,2,14,11,4,36,19,2,16,50,10,26,4,46,2,
%U A395918 18,10,30,20,66,8,55,6,26,6,28,27,2,20,74,2,22,24,59
%N A395918 a(0) = 0, and then a(n) is the numbers of ways to write a(n-1) as a(i) * a(j) with i <= j < n.
%C A395918 This sequence is unbounded:
%C A395918 - by contradiction, suppose that a(n) <= M for any n >= 0,
%C A395918 - by necessity, some value m <= M appears infinitely many times,
%C A395918 - this value m is necessarily positive (the value 0 occurs only once),
%C A395918 - so we have a(k_1) = ... = a(k_{M+1}) = m with 0 < k_1 < ... < k_{M+1},
%C A395918 - as a(1) * a(k_1) = ... = a(1) * a(k_{M+1}) = m, a(k_{M+1}+1) > M, a contradiction.
%H A395918 Rémy Sigrist, <a href="/A395918/b395918.txt">Table of n, a(n) for n = 0..10000</a>
%H A395918 Rémy Sigrist, <a href="/A395918/a395918.txt">C++ program</a>
%F A395918 a(n) <= A000217(n).
%e A395918 The first terms, alongside the corresponding products, are:
%e A395918   n   a(n)  Products
%e A395918   --  ----  ----------------------------------------------------------
%e A395918    0     0
%e A395918    1     1  a(0)*(0)
%e A395918    2     1  a(1)*(1)
%e A395918    3     3  a(1)*(1), a(1)*(2), a(2)*(2)
%e A395918    4     2  a(1)*(3), a(2)*(3)
%e A395918    5     2  a(1)*(4), a(2)*(4)
%e A395918    6     4  a(1)*(4), a(1)*(5), a(2)*(4), a(2)*(5)
%e A395918    7     5  a(1)*(6), a(2)*(6), a(4)*(4), a(4)*(5), a(5)*(5)
%e A395918    8     2  a(1)*(7), a(2)*(7)
%e A395918    9     6  a(1)*(4), a(1)*(5), a(1)*(8), a(2)*(4), a(2)*(5), a(2)*(8)
%e A395918   10     5  a(1)*(9), a(2)*(9), a(3)*(4), a(3)*(5), a(3)*(8)
%o A395918 (C++) // See Links section.
%o A395918 (Python)
%o A395918 from itertools import islice
%o A395918 from collections import Counter
%o A395918 def agen(): # generator of terms
%o A395918     alst, ways = [0], Counter()
%o A395918     while True:
%o A395918         yield alst[-1]
%o A395918         ways.update(alst[i]*alst[-1] for i in range(len(alst)))
%o A395918         alst.append(ways[alst[-1]])
%o A395918 print(list(islice(agen(), 75))) # _Michael S. Branicky_, May 13 2026
%o A395918 (PARI) ListA(max_n) = {my(M=Map(), v=[0], c=0, p=0);  while(#v<max_n, for(k=1, #v, c=0; p=v[#v]*v[k]; mapisdefined(M,p,&c); mapput(~M, p, c+1)); c=0; mapisdefined(M, v[#v], &c); v=concat(v, c)); v} \\ _Thomas Scheuerle_, Jun 27 2026
%Y A395918 Cf. A000217, A395907, A395917.
%K A395918 nonn,changed
%O A395918 0,4
