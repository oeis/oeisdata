%I A395311 #10 Apr 27 2026 16:40:47
%S A395311 131,347,467,587,659,947,971,1019,1163,1427,1499,1571,1667,1931,2411,
%T A395311 2459,2819,2939,2963,3203,3251,3347,3947,4019,4283,5003,5099,5147,
%U A395311 5483,5507,5867,6491,6563,6779,6803,7283,7307,7523,7547,7691,8147,8291,8699,9059,9323,9803
%N A395311 Prime numbers of the form 11*x^2 + 4*x*y + 20*y^2 where x and y are positive integers.
%C A395311 The discriminant is -864.
%C A395311 All terms are congruent to 11 modulo 24.
%H A395311 Steven Lu, <a href="/A395311/b395311.txt">Table of n, a(n) for n = 1..10000</a>
%e A395311 131 = 11 * 3^2 + 4 * 3 * 1 + 20 * 1^2.
%e A395311 347 = 11 * 1^2 + 4 * 1 * 4 + 20 * 4^2.
%e A395311 467 = 11 * 3^2 + 4 * 3 * 4 + 20 * 4^2.
%t A395311 With[{limit = 10000},
%t A395311  Sort[DeleteDuplicates[
%t A395311    Select[Flatten[
%t A395311      Table[11 x^2 + 4 x y + 20 y^2, {x,
%t A395311        Floor[Sqrt[20 limit/216]]}, {y, Floor[Sqrt[11 limit/216]]}]],
%t A395311     PrimeQ[#] && # < limit &]]]]
%Y A395311 Cf. A379881, A395310, this sequence and {3, 11} is a partition of A107007.
%K A395311 nonn,new
%O A395311 1,1
%A A395311 _Steven Lu_, Apr 19 2026
