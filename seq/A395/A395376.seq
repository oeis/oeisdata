%N A395376 Expansion of e.g.f. exp(LambertW(-LambertW(LambertW(-x)))).
%F A395376 E.g.f.: exp(B(x)), where B(x) is the e.g.f. of A396558.
%F A395376 a(0) = 1; a(n) = Sum_{i,j,k >= 0 and i+j+k=n-1} ((n-1)!/(i!*j!*k!)) * n^i * (n-i)^j * (-k)^k.
%F A395376 a(n) ~ n^(n-1) * exp(n*exp(-1)) / (sqrt(1-exp(-1)) * (1 + LambertW(1))). - _Vaclav Kotesovec_, Jun 01 2026
%o A395376 (PARI) my(N=20, x='x+O('x^N)); Vec(serlaplace(exp(lambertw(-lambertw(lambertw(-x))))))
%Y A395376 Cf. A268653, A340474, A394239.
%Y A395376 Cf. A396558.
%K A395376 nonn
%O A395376 0,3
