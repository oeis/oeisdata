%I A395271 #7 May 17 2026 19:34:57
%S A395271 12,20,56,88,104,30,272,304,42,368,464,992,66,70,1184,78,1312,1376,
%T A395271 1504,102,945,1696,220,114,1888,1952,260,4288,138,4544,4672,308,5056,
%U A395271 7425,5312,340,174,5696,364,186,380,6208,131625,6464,6592,210,6848,6976,222,7232
%N A395271 a(n) is the smallest abundant number with radical A395270(n).
%C A395271 Nonprimitive terms can occur only for radicals of the form 2*q, where q is an odd prime.
%H A395271 Felix Huber, <a href="/A395271/b395271.txt">Table of n, a(n) for n = 1..10000</a>
%e A395271 a(1) = 12, since A395270(1) = 6 and 12 is the smallest abundant number with radical 6.
%e A395271 a(3) = 56, since A395270(3) = 14 and 56 is the smallest abundant number with radical 14.
%e A395271 a(21) = 945, since A395270(21) = 105 = 3*5*7 and 945 is the smallest abundant number with radical 105.
%p A395271 b := proc(l)
%p A395271     local c, f, i, m, p, r, x;
%p A395271     p := sort(l); r := nops(p);
%p A395271     f := (q, e) -> (q^(e + 1) - 1)/(q^e*(q - 1));
%p A395271     x := mul(p[i]/(p[i] - 1), i = 1 .. r);
%p A395271     m := [seq(max(1, ceil(log(1/(1 - 2/x))/log(p[i]))), i = 1 .. r)];
%p A395271     c := proc(k, u, v, g)
%p A395271         local e, i, t, w;
%p A395271         if k > r then if u > 2 then return v else return infinity end if end if;
%p A395271         t := g;
%p A395271         for e to m[k] do
%p A395271             w := v*p[k]^e;
%p A395271             if w >= t then break end if;
%p A395271             i := c(k + 1, u*f(p[k], e), w, t);
%p A395271             if i < t then t := i end if;
%p A395271         end do;
%p A395271         t;
%p A395271     end proc;
%p A395271     c(1, 1, 1, infinity)
%p A395271 end proc:
%p A395271 A395271 := proc(n) option remember;
%p A395271     global t; local r;
%p A395271     r := A395270(n);
%p A395271     b(t[r]);
%p A395271 end proc:
%p A395271 seq(A395271(n), n = 1 .. 50);
%Y A395271 Cf. A000203, A001221, A005101, A006038, A007947, A091191, A100484, A395270.
%K A395271 nonn,easy,new
%O A395271 1,1
%A A395271 _Felix Huber_, May 12 2026
