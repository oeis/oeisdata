%N A395632 a(n) = number of triples (x, y, z) such that 2*x^2 + y*z = n, where x, y, z are positive integers satisfying x < y <= z.
%e A395632 a(26) = 4 counts these triples: (1, 2, 12), (1, 3, 8), (1, 4, 6), (2, 3, 6).
%t A395632 t[n_, c_] := Module[{r}, r = Flatten[Table[If[n - 2 x^2 <= 0, {},
%t A395632 Map[({x, #, Quotient[n - 2 x^2, #]} &),
%t A395632 Select[Divisors[n - 2 x^2], Divisible[n - 2 x^2, #] &]]],
%t A395632 {x, 1, Floor[Sqrt[n - 1]]}], 1]; Select[r, Apply[c, #] &]];
%t A395632 c = (#1 < #2 <= #3 &);
%t A395632 Join[{0},Table[Length[t[n, c]], {n, 1, 130}]]
