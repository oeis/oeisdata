%S A395974 0,1,-2,5,-17,84,-612,6369,-90365,1676378,-39337952,1137850636,
%T A395974 -39741466492,1648141592200,-80033496955752,4497237376599309,
%U A395974 -289478855184462837,21157626632021909934,-1742407935675923361780,160585876557339360547266,-16462838969412613173858330
%N A395974 a(n) = A395975(n, 1), and a(0) = 0.
%t A395974 h[n_] := SeriesCoefficient[ 1/Hypergeometric0F1[2, x], {x, 0, n - 1} ];
%t A395974 A[0] := 0; A[n_] := (n - 1)! * Sum[(-1)^(n - j) * j!/(n - j)! * h[j], {j, 1, n} ];
%t A395974 Table[A[n], {n, 0, 20}]
%o A395974 (Python)
%o A395974 from functools import cache
%o A395974 def A395974(n: int) -> int:
%o A395974     if n == 1: return 1
%o A395974     @cache
%o A395974     def h(m: int) -> int:  # A103365
%o A395974         if m == 1: return 1
%o A395974         return -sum(A090181(m, j) * h(j) for j in range(1, m))
%o A395974     s = 0; cnj = 1
%o A395974     sgn = 1 if n & 1 else -1
%o A395974     for j in range(1, n + 1):
%o A395974         s += sgn * cnj * h(j)
%o A395974         if j < n: cnj = cnj * (n - j) // j
%o A395974         sgn = -sgn
%o A395974     return s
%o A395974 print([A395974(n) for n in range(21)])
