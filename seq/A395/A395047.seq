%N A395047 a(n) = A241917(A003415(n)).
%H A395047 Antti Karttunen, <a href="/A395047/b395047.txt">Table of n, a(n) for n = 2..10000</a>
%o A395047 (PARI)
%o A395047 A003415(n) = if(n<=1, 0, my(f=factor(n)); n*sum(i=1, #f~, f[i, 2]/f[i, 1]));
%o A395047 A241917(n) = if(isprime(n), primepi(n), if(1>=omega(n), 0, my(f=factor(n)); if(f[#f~, 2]>1, 0, primepi(f[#f~, 1])-primepi(f[(#f~)-1, 1]))))
%o A395047 A395047(n) = A241917(A003415(n));
%Y A395047 Cf. A003415, A241917.
%Y A395047 Cf. also A395057.
