%T A395022 1877593,6346119,32888637,121159373,666757418,2655174768,15442626557,
%U A395022 66028903633,404271491249,1845579100993,11855277004330,57506847262162,386411610169757,1983312152411351,13904155500245141
%N A395022 Expansion of 1 + Sum_{k >= 1} (x^(2k-1) + (k + 1) * x^(2k)) / Product_{j=1..k} (1 - j^2 * x^2).
%C A395022 For odd n = 2*k-1: a(n) is equal to the number of partitions of the set {1,1',2,2',...,k,k'} into disjoint nonempty subsets V1,...,Vk (1 <= k <= n) such that, for each 1 <= j <= k, if i is the least integer such that either i or i' belongs to Vj then {i,i'} is a subset of Vj (this matches A135920).
%C A395022 For even n = 2*k: a(n) is equal to the sum of the number of such partitions (A135920), and the total number of blocks (nonempty subsets V_j) across all such partitions (A394822).
%C A395022 Also generated by iterated binomial transforms in the following way:
%C A395022 a = BINOMIAL([1, 1, 2, 2, 5, 7, 21, 37, 126, ...]);
%C A395022 a = BINOMIAL^3([1, -1, 2, -6, 21, -75, 269, ...]);
%C A395022 a = BINOMIAL^5([1, -3, 10, -38, 165, -797, 4125, ...]);
%C A395022 a = BINOMIAL^7([1, -5, 26, -142, 821, -5039, 32709, ...]);
%C A395022 a = BINOMIAL^9([1, -7, 50, -366, 2757, -21441, 172421, ...]).
%F A395022 If n is odd (n = 2*k-1): a(n) = A135920(k).
%F A395022 If n is even (n = 2*k): a(n) = A135920(k) + A394822(k).
%F A395022 a(n) = A135920((n+1)/2) if n is odd; a(n) = A135920(n/2) + A394822(n/2) if n is even.
%F A395022 a(n) = (2*k)! * [x^(2*k)] (cosh(2*s) + (1 - (n mod 2)) * s * sinh(2*s)) where k = floor((n+1)/2) and s = sinh(x/2).
%F A395022 O.g.f.: A(x) = (x+2*x^2)/(1-x^2) + (x^3+3*x^4)/((1-x^2)*(1-4*x^2)) + (x^5+4*x^6)/((1-x^2)*(1-4*x^2)*(1-9*x^2)) + (x^7+5*x^8)/((1-x^2)*(1-4*x^2)*(1-9*x^2)*(1-16*x^2)) + ...
%o A395022 (Python)
%o A395022 from functools import cache
%o A395022 @cache
%o A395022 def T(n, k):
%o A395022     if k == 1 or k == n: return 1
%o A395022     if k < 1 or k > n: return 0
%o A395022     if k % 2 == 0:
%o A395022         if n % 2 != 0:
%o A395022             return 0
%o A395022         else:
%o A395022             return (2 * T(n, k-1)) // k
%o A395022     else:
%o A395022         if n % 2 == 0:
%o A395022             return T(n-1, k) * (k + 1) // 2
%o A395022         else:
%o A395022             term1 = T(n-1, k) * (k + 1) // 2
%o A395022             term2 = T(n-1, k-2) * 2 // (k - 1)
%o A395022             return term1 + term2
%o A395022 def a(n):
%o A395022     if n == 0: return 1
%o A395022     return sum(T(n, k) for k in range(1, n + 1))
%o A395022 print([a(n) for n in range(0, 31)])
%Y A395022 Cf. A394813, A394582, A008957.
