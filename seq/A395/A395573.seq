%N A395573 a(n) is the permanent of the symmetric n X n matrix M defined by M(i,j) = min(i!,j!) for 1 <= i,j <= n.
%e A395573 a(3) = 28:
%e A395573   [1, 1, 1]
%e A395573   [1, 2, 2]
%e A395573   [1, 2, 6]
%p A395573 a:= n-> `if`(n=0, 1, LinearAlgebra[Permanent](Matrix(n, (i, j)-> min(i!, j!)))):
%p A395573 seq(a(n), n=0..13);  # _Alois P. Heinz_, Apr 28 2026
%t A395573 a[0]:=1; a[n_]:=Permanent[Table[Min[i!,j!],{i,n},{j,n}]]; Array[a,14,0]
