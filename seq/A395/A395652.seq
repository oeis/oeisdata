%I A395652 #20 May 03 2026 11:11:27
%S A395652 1,0,0,0,3,13,0,828,6364,73312,0,9393172,137910936,1657361304,
%T A395652 25306310568,418509282600,7401431236896,123183948152448,
%U A395652 2338344747441216,47478533220036864,1006328018528687232,20917151484073672320,434695886449471779840,10694787392361904214400
%N A395652 Number of permutations p of [n] whose positive prefix sums Sum_{i=1..k} p(i) avoid Fibonacci numbers.
%H A395652 Wikipedia, <a href="https://en.wikipedia.org/wiki/Permutation">Permutation</a>
%F A395652 a(n) = 0 <=> n in {1, 2, 3, 6, 10}.
%e A395652 a(4) = 3: 4213, 4231, 4321.
%e A395652 a(5) = 13: 42135, 42153, 42315, 42351, 42513, 42531, 43215, 43251, 43521, 45123, 45213, 45231, 45321.
%e A395652 a(7) = 828: 4213576, 4213675, 4213756, 4213765, ..., 7564213, 7564231, 7564312, 7564321.
%e A395652 a(8) = 6364: 42135768, 42135786, 42135867, 42135876, ..., 78564123, 78564213, 78564231, 78564321.
%e A395652 a(6) = 0 because 6*7/2 = 21 is Fibonacci number.
%e A395652 a(10) = 0 because 10*11/2 = 55 is Fibonacci number.
%p A395652 q:= proc(n) option remember; (t-> issqr(t+4) or issqr(t-4))(5*n^2) end:
%p A395652 b:= proc(s, p) option remember; `if`(s={}, 1, add(
%p A395652       `if`(q(p+j), 0, b(s minus {j}, p+j)), j=s))
%p A395652     end:
%p A395652 a:= n-> b({$1..n},0):
%p A395652 seq(a(n), n=0..17);
%Y A395652 Cf. A000045, A000217, A039595, A291504, A395620.
%K A395652 nonn,new
%O A395652 0,5
%A A395652 _Alois P. Heinz_, May 02 2026
