%T A395672 720663872500,24332866501372,887558454336372,34810380537375170,
%U A395672 1460425852562219760,65255195022227232480,3093688414572173306128,155103564618621456778168,8198969255720346583303380
%N A395672 Number of endofunctions f:{1,2,...,n}-> {1,2,...,n} whose smallest weakly connected component has exactly 3 nodes.
%C A395672 a(n) is always divisible by A001865(3) = 17.
%F A395672 E.g.f.: exp(-x-3*x^2/2)*(1-exp(-17*x^3/6)) / (1+LambertW(-x)).
%F A395672 Limit_{n->oo} a(n) / n^n = exp(-1/e - 3/(2*e^2)) * (1 - exp(-17/(6*e^3))).
%F A395672 a(n) = 17*Sum_{k=0..n} binomial(n,k)*(-1)^(k+1)*(n-k)^(n-k)*Sum_{j=1..floor(k/3)} binomial(k,3*j)*A362278(k-3*j)*17^(j-1)*(3*j)!/(6^j*j!) for n >= 3.
%p A395672 a := exp(-x-3*x^2/2)*(1-exp(-17*x^3/6)) / (1+LambertW(-x)):
%p A395672 ser := series(a, x = 0, 21): seq(n!*coeff(ser, x, n), n = 0 .. 20);
%o A395672 (Python)
%o A395672 from functools import lru_cache
%o A395672 from math import comb, factorial as fl
%o A395672 @lru_cache(None)
%o A395672 def b(n): return 1 if n < 2 else b(n-1) - 3*(n-1)*b(n-2)
%o A395672 def a(n):
%o A395672     return 17*sum(comb(n,k)*(-1)**(k+1)*(n-k)**(n-k)*
%o A395672         sum(comb(k,3*j)*b(k-3*j)*17**(j-1)*fl(3*j)//(6**j*fl(j))
%o A395672             for j in range(1,k//3+1))
%o A395672         for k in range(n+1))
%o A395672 print([a(n) for n in range(21)])
%Y A395672 Column k=3 of triangle A347999.
%Y A395672 Cf. A000169, A001865, A209324, A350134, A362278, A394928.
%K A395672 nonn,easy,new
