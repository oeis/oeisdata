%N A395065 Triangle read by rows: coefficients of (1+(2*n-1)*x)*(1+(n-1)*x)^(n-1).
%e A395065 The first few rows are:
%e A395065   1;
%e A395065   1,  1;
%e A395065   1,  4,  3;
%e A395065   1,  9, 24,  20;
%e A395065   1, 16, 90, 216, 189;
%e A395065   ...
%t A395065 T[n_]:=CoefficientList[ (1 + (2 n - 1) x) * (1 + (n - 1) x)^(n - 1),x];Array[T,9,0]//Flatten (* _James C. McMahon_, May 12 2026 *)
%o A395065 (SageMath)
%o A395065 x = polygen(ZZ, 'x')
%o A395065 def row(n):
%o A395065     if n == 0: return [1]
%o A395065     return list((1+(2*n-1)*x)*(1+(n-1)*x)**(n-1))
%o A395065 (PARI) row(n) = Vec((1+(2*n-1)*x)*(1+(n-1)*x)^(n-1)); \\ _Michel Marcus_, May 09 2026
%Y A395065 Row sums are A013499.
%Y A395065 Main diagonal gives A176043.
%Y A395065 Columns k=0-1 give: A000012, A000290.
