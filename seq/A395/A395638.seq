%I A395638 #7 May 16 2026 22:38:29
%S A395638 0,0,0,1,2,2,1,2,2,1,4,3,3,2,2,2,2,3,4,1,2,4,1,6,4,0,4,2,4,2,0,2,2,3,
%T A395638 4,0,2,0,0,2,0,2,6,1,4,0,0,2,2,0,2,1,4,2,1,2,2,4,4,1,4,0,0,4,0,4,3,2,
%U A395638 0,0,2,4,1,4,2,1,4,0,0,0,0,2,1,2,2,0
%N A395638 a(n) = number of triples (x, y, z) such that 2*x^2 + y*z = n, where x, y, z are positive Fibonacci numbers.
%e A395638 a(4) = 1 counts this triple: (1,1,1).
%e A395638 a(23) = 6 counts these triples: (1,1,21), (1,21,1), (1,21,1), (2,3,5), (2,5,3), (3,1,5).
%t A395638 t[n_, c_] := Module[{r}, r = Flatten[Table[If[n - 2 x^2 <= 0, {},
%t A395638 Map[({x, #, Quotient[n - 2 x^2, #]} &),
%t A395638 Select[Divisors[n - 2 x^2], Divisible[n - 2 x^2, #] &]]],
%t A395638 {x, 1, Floor[Sqrt[n - 1]]}], 1]; Select[r, Apply[c, #] &]];
%t A395638 fibonacciQ[n_] := IntegerQ[Sqrt[5 n^2 + 4]] || IntegerQ[Sqrt[5 n^2 - 4]];
%t A395638 c = (fibonacciQ[#1] && fibonacciQ[#2] && fibonacciQ[#3] &);
%t A395638 Table[{n, t[n, c]}, {n, 1, 60}]
%t A395638 Join[{0}, Table[Length[t[n, c]], {n, 1, 130}]]
%t A395638 (* _Peter J. C. Moses_, Mar 29 2026 *)
%Y A395638 Cf. A393710, A395639.
