%T A395492 78,2,63,2,3,2,109,2,40,2,81,2,102,2,74,2,50,2,123,2,14,2,61,2,101,2,
%U A395492 50,2,62,2,230,2,64,2,63,2,102,2,75,2,98,2,276,2,76,2,45,2,91,2,177
%N A395492 Sum of the distinct primes not dividing n that are adjacent to a divisor of n.
%H A395492 Vincenzo Librandi, <a href="/A395492/b395492.txt">Table of n, a(n) for n = 1..10000</a>
%e A395492    ------------------------------------------------
%e A395492      n    Divisors      Adjacent Primes     a(n)
%e A395492    ------------------------------------------------
%e A395492      1      {1}              {2}             2
%e A395492      2      {1,2}            {3}             3
%e A395492      3      {1,3}            {2}             2
%e A395492      4      {1,2,4}          {3,5}           8
%e A395492      5      {1,5}            {2}             2
%e A395492      6      {1,2,3,6}        {5,7}          12
%e A395492      7      {1,7}            {2}             2
%e A395492      8      {1,2,4,8}        {3,5,7}        15
%e A395492      9      {1,3,9}          {2}             2
%e A395492     10      {1,2,5,10}       {3,11}         14
%e A395492      ...
%t A395492 a[n_] := Module[{d = Divisors[n]}, Total[Select[Union[d-1, d+1], # > 0 && !Divisible[n, #] && PrimeQ[#] &]]]; Array[a, 100] (* _Amiram Eldar_, Apr 30 2026 *)
%o A395492 (Magma) a:=function(n) S:={}; for d in Divisors(n) do for x in [d-1, d+1] do if x gt 0 and
%o A395492 IsPrime(x) and n mod x ne 0 then Include(~S,x); end if; end for; end for; return &+Setseq(S);
%o A395492 end function; [a(n) : n in [1..100]]; // _Vincenzo Librandi_, May 01 2026
%Y A395492 Cf. A000005, A394475.
%K A395492 nonn,new
