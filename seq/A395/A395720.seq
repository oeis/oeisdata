%I A395720 #32 May 13 2026 23:28:29
%S A395720 110,111,112,113,114,115,116,117,118,119,120,122,124,126,128,132,135,
%T A395720 138,140,144,148,150,155,162,168,175,184,198,210,211,212,213,214,215,
%U A395720 216,217,218,219,220,222,224,226,228,231,234,237,240,244,248,250,255,264
%N A395720 Kangaroo numbers are numbers that are multiples of their inner number; that is, the number obtained by removing its first and last digits.
%C A395720 If k is a divisor of a*10^d + b where 1 <= a <= 9, 0 <= b <= 9 and k < 10^(d-1), then a*10^d + 10*k + b is a term. - _Robert Israel_, May 04 2026
%H A395720 Robert Israel, <a href="/A395720/b395720.txt">Table of n, a(n) for n = 1..10000</a>
%H A395720 Carole Dubois, <a href="/A395720/a395720.jpg">Semi-logarithmic graph</a>
%H A395720 Mickaël Launay, <a href="https://www.lemonde.fr/sciences/article/2026/04/18/nombres-kangourous-l-enigme-maths-du-monde-n-97_6681126_1650684.html">Nombres kangourous, l’énigme maths du « Monde » nᵒ 97</a>.
%e A395720 The inner number of 1248 is 24, and since 1248 is a multiple of 24 (1248 = 24 * 52), it is a kangaroo number.
%e A395720 The number 2026 is also a kangaroo number because it is even, and therefore a multiple of 2.
%p A395720 g:= proc(d) local a,b,R,K;
%p A395720   R:= NULL;
%p A395720   for a from 1 to 9 do
%p A395720     for b from 0 to 9 do
%p A395720       K:= select(`<`,NumberTheory:-Divisors(a*10^(d-1)+b),10^(d-2));
%p A395720       R:= R, op(map(k ->a*10^(d-1) + 10*k + b, K));
%p A395720   od od;
%p A395720   op(sort([R]))
%p A395720 end proc:
%p A395720 g(3), g(4); # _Robert Israel_, May 04 2026
%t A395720 q[k_] := With[{m = FromDigits@ IntegerDigits[k][[2 ;; -2]]}, m > 0 && Divisible[k, m]]; Select[Range[100, 270], q] (* _Amiram Eldar_, May 04 2026 *)
%o A395720 (Python)
%o A395720 def ok(n): return n > 99 and (joey:=int(str(n)[1:-1])) and n%joey == 0
%o A395720 print([k for k in range(265) if ok(k)]) # _Michael S. Branicky_, May 04 2026
