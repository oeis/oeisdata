%U A395561 8,1,8,11,4,5,2,1,2,5,4,7,6,1,10,3,4,1,2,7,4,5,6,1,2,3,22,5,16,23
%N A395561 Smallest positive integer k such that n - k is prime and n + k is composite.
%H A395561 Aradhya Haldikar, <a href="https://doi.org/10.5281/zenodo.19853346">A Technical Note on an Apparently Unlisted Integer Sequence from Asymmetric Prime-Composite Neighborhoods</a>, 2026.
%F A395561 a(n) >= A049711(n). - _Michel Marcus_, Apr 28 2026
%e A395561 For n = 3, we look for the smallest positive integer k such that 3 - k is prime and 3 + k is composite:
%e A395561   k = 1: 2 is prime, 4 is composite -> a(3) = 1.
%e A395561 For n = 4:
%e A395561   k = 1: 3 is prime, 5 is prime (not valid);
%e A395561   k = 2: 2 is prime, 6 is composite -> a(4) = 2.
%e A395561 For n = 5:
%e A395561   k = 1: 4 is composite (fails condition on n-k);
%e A395561   k = 2: 3 is prime, 7 is prime (not valid);
%e A395561   k = 3: 2 is prime, 8 is composite -> a(5) = 3.
%p A395561 a := proc(n)
%p A395561     local k;
%p A395561     for k from 1 do
%p A395561         if isprime(n - k) and not isprime(n + k) then
%p A395561             return k;
%p A395561         end if;
%p A395561     end do;
%p A395561 end proc:
%p A395561 seq(a(n), n = 3..100);
%o A395561 (PARI) a(n) = for (k=1, n-1, if (isprime(n-k) && !isprime(n+k), return(k))); \\ _Michel Marcus_, Apr 28 2026
%o A395561 (Python)
%o A395561 from sympy import isprime
%o A395561 def a(n): return next(k for k in range(1, n) if isprime(n-k) and not isprime(n+k))
%o A395561 print([a(n) for n in range(3, 97)]) # _Michael S. Branicky_, Apr 28 2026
%Y A395561 Cf. A049711.
%K A395561 nonn,new
%O A395561 3,2
%A A395561 _Aradhya Haldikar_, Apr 28 2026
