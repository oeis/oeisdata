%I A395959 #16 May 19 2026 19:40:58
%S A395959 0,3,4,7,8,11,12,15,17,18,21,22,25,26,29,30,33,34,37,38,41,42,45,46,
%T A395959 48,51,52,55,56,59,60,63,64,67,68,71,72,75,76,79,81,82,85,86,89,90,93,
%U A395959 94,97,98,101,102,105,106,109,110,112,115,116,119
%N A395959 Numbers k such that A395958(k) = 0.
%C A395959 The partition of {0, 1, ..., 2^M - 1} into this sequence and A395960 is a solution of the Prouhet-Tarry-Escott problem of degree |S_M| - 1, where S_M = { 0 <= p < M : p AND 2 = 0 }. The analogs at previous levels are A001969 and A000069 (classical evil/odious, for A010060 = T(a_0)), and A158704 and A158705 (for A341389 = T^2(a_0)).
%H A395959 Benoit Cloitre, <a href="https://arxiv.org/abs/2604.06243">The Thue-Morse Transform</a>, arXiv:2604.06243 [math.NT], 2026.
%F A395959 a(n) = 2*(n-1) + A395958(2*(n-1)) for n >= 1.
%o A395959 (Python)
%o A395959 def A395958(n):
%o A395959     s, p = 0, 0
%o A395959     while (1 << p) <= n:
%o A395959         if (p & 2) == 0:
%o A395959             s ^= (n >> p) & 1
%o A395959         p += 1
%o A395959     return s
%o A395959 print([k for k in range(120) if A395958(k) == 0])
%Y A395959 Cf. A000069, A001969, A010060, A158704, A158705, A341389, A395958, A395960, A395962, A395963, A395965, A395966.
%K A395959 nonn,base,easy
%O A395959 1,2
%A A395959 _Benoit Cloitre_, May 12 2026
