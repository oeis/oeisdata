%N A395575 1 = Sum_{n>=0} a(n) * x^n * (1 - (n+1)*x)^(2*n+1).
%H A395575 Seiichi Manyama, <a href="/A395575/b395575.txt">Table of n, a(n) for n = 0..319</a>
%F A395575 a(0) = 1; a(n) = Sum_{k=1..floor((2*n+1)/3)} (-1)^(k-1) * (n-k+1)^k * binomial(2*n-2*k+1,k) * a(n-k).
%o A395575 (PARI) a(n) = if(n==0, 1, sum(k=1, (2*n+1)\3, (-1)^(k-1)*(n-k+1)^k*binomial(2*n-2*k+1, k)*a(n-k)));
