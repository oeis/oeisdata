%I A395368 #13 Apr 30 2026 21:44:58
%S A395368 11,-1,351,-1,-1,-1,731,-1,931,-1,1092,22,322,432,-1,6032,702,812,
%T A395368 9222,-1,1023,-1,33,-1,-1,-1,703,-1,9243,-1,164,294,344,44,-1,644,
%U A395368 7144,864,9114,-1,1275,-1,3445,-1,55,-1,7125,-1,9145,-1,1586,2046,3276,4096,-1,66,7236,816,966,-1,1207,-1
%N A395368 a(n) is the least multiple of n that starts with y and ends with x, where n is the concatenation of x and y, or -1 if there is no such multiple.
%C A395368 Leading zeros are not allowed.
%C A395368 a(n) = -1 if n is even and only its last digit is even, or if n is divisible by 5 and only its last digit is divisible by 5.
%H A395368 Robert Israel, <a href="/A395368/b395368.txt">Table of n, a(n) for n = 11..10000</a>
%e A395368 a(124) = 4712 because 4712 = 38 * 124 starts with 4, ends with 12, and is the smallest number that works.
%p A395368 f:= proc(n) local x,da,db,a,b,K,m,k,r,v;
%p A395368     r:= infinity;
%p A395368     for db from 1 to ilog10(n) do
%p A395368       b:= n mod 10^db; a:= (n-b)/10^db;
%p A395368       da:= ilog10(a)+1;
%p A395368       if b < 10^(db-1) then next fi;
%p A395368       K:= map(t -> rhs(op(t)),[msolve(x*n=a,10^da)]);
%p A395368       for k in K do
%p A395368          for m from k by 10^da do
%p A395368            v:= m*n;
%p A395368            if v >= r then break fi;
%p A395368            if floor(v/10^(ilog10(v)+1-db)) = b then r:= v; break fi;
%p A395368        od od;
%p A395368      od;
%p A395368      if r = infinity then -1 else r fi
%p A395368 end proc:
%p A395368 map(f, [$11 .. 1000]);
%K A395368 sign,base,look,new
%O A395368 11,1
%A A395368 _Robert Israel_, Apr 20 2026
