%I A395945 #12 Jul 21 2026 00:52:36
%S A395945 3,5,7,13,17,31,41,73,89,109,127,151,241,257,331,337,673,683,1321,
%T A395945 1801,2089,2113,4051,5419,8191,14449,23311,38737,61681,65537,121369,
%U A395945 122921,131071,152041,178481,201961,262657,268501,279073,524287,525313
%N A395945 Primes p that are the greatest prime factor of 2^k - 1 for some k >= 1.
%C A395945 Solutions of p = A006530(2^(A002326((p-1)/2))-1).
%C A395945 Odd primes p such that if k is the multiplicative order of 2 mod p, 2^k - 1 is p-smooth.
%e A395945 a(9) = 89 is a term because 2^11 - 1 = 23 * 89 whose greatest prime factor is 89.
%p A395945 A:= NULL: count:= 0: P:= {}: p:= 2:
%p A395945 while count < 40 do
%p A395945   p:= nextprime(p);
%p A395945   m:= NumberTheory:-MultiplicativeOrder(2,p);
%p A395945   t:= 2^m-1;
%p A395945   t:= t/p^padic:-ordp(t,p);
%p A395945   for q in P do if t mod q = 0 then
%p A395945     t:= t/q^padic:-ordp(t,q);
%p A395945     if t = 1 then break fi;
%p A395945   fi od;
%p A395945   if t = 1 then count:= count+1; A:= A,p fi;
%p A395945   P:= P union {p};
%p A395945 od:
%p A395945 A;
%o A395945 (Python)
%o A395945 from itertools import islice
%o A395945 from sympy import nextprime, primerange, n_order, multiplicity
%o A395945 def A395945_gen(startvalue=3): # generator of terms >= startvalue
%o A395945     p = max(3,nextprime(startvalue-1))
%o A395945     plist = list(primerange(3,p+1))
%o A395945     while True:
%o A395945         f = (1<<n_order(2,p))-1
%o A395945         for q in plist:
%o A395945             f //= q**multiplicity(q,f)
%o A395945         if f == 1:
%o A395945             yield p
%o A395945         p = nextprime(p)
%o A395945         plist.append(p)
%o A395945 A395945_list = list(islice(A395945_gen(),20)) # _Chai Wah Wu_, Jul 20 2026
%Y A395945 Includes A000668.  Cf. A002326, A006530, A395931.
