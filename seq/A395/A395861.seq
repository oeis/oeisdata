%S A395861 1,1,1,1,1,1,1,4,1,1,1,1,1,1,1,1,16,1,2,1,1,1,8,1,1,1,1,1,1,64,1,16,1,
%T A395861 4,1,1,1,8,1,2,1,1,1,1,1,1,256,1,16,1,8,1,1,1,1,1,128,1,8,1,4,1,1,1,1,
%U A395861 1,1,1024,1,256,1,32,1,8,1,4,1,1,1,256,1,64,1,8,1,2,1,1,1,1,1
%N A395861 Triangle read by rows: T(n,k) = denominator(CF(n,k)), where CF(n,k) = (1/k!) * Sum_{j=0..k} (-1)^j * binomial(k,j) * (1+k/2-j)^n.
%D A395861 P. L. Butzer, K. Schmidt, E. L. Stark, and L. Vogt, Central factorial numbers; their main properties and some applications. Numerical Functional Analysis and Optimization, 10(5-6), (1989), 419-488.
%D A395861 J. Riordan, Combinatorial identities (Vol. 217), Wiley, New York, 1968.
%H A395861 José L. Cereceda, <a href="https://arxiv.org/abs/2211.11648">Sums of powers of integers and generalized Stirling numbers of the second kind</a>, arXiv:2211.11648 [math.NT], 2022.
%H A395861 M. W. Coffey and M. C. Lettington, <a href="https://arxiv.org/abs/1510.05402">On Fibonacci Polynomial Expressions for Sums of m-th Powers, their implications for Faulhaber's Formula and some Theorems of Fermat</a>, arXiv:1510.05402 [math.NT], 2015.
%H A395861 Donald E. Knuth, <a href="https://arxiv.org/abs/math/9207222">Johann Faulhaber and Sums of Powers</a>, arXiv:math/9207222 [math.CA], 1992.
%H A395861 Petro Kolosov, <a href="https://doi.org/10.5281/zenodo.18096789">Sums of powers via central finite differences and Newton's formula</a>, Zenodo, 2026.
%H A395861 Petro Kolosov, <a href="https://doi.org/10.5281/zenodo.20802514">Sums of powers of integers: A complete framework for closed formulas</a>, Zenodo, 2026. See pp. 12-13.
%F A395861 Let F(t, n, k) be generalized central factorial numbers of the second kind: F(t,n,k) = (1/(2k)!) * Sum_{j=0..2k} (-1)^j * binomial(2k,j) * (t+k-j)^(2n), then:
%F A395861   F(0,n,k) = A387597(n,k)/k! = A269945(n,k);
%F A395861   F(1,n,k) = A392337(n,k)/k! = A394692(n,k);
%F A395861   F(2,n,k) = A390029(n,k)/k! = A395456(n,k);
%F A395861   F(3,n,k) = A395457(n,k);
%F A395861   numerators(F(0,n,k)) = A395862(n,k);
%F A395861   denominators(F(0,n,k)) = A370703(n,k);
%F A395861   numerators(F(1,n,k)) = A395860(n,k);
%F A395861   denominators(F(1,n,k)) = T(n,k) (this sequence).
%F A395861 G.f. for CF(n,k) is centered Newton's polynomial for f(s) = s^n: s^n = Sum_{k=0..n} CF(n,k) (s-1)^[k], where (s-1)^[k] are central factorials.
%e A395861 Triangle begins:
%e A395861   [0]  1;
%e A395861   [1]  1,   1;
%e A395861   [2]  1,   1, 1;
%e A395861   [3]  1,   4, 1,  1;
%e A395861   [4]  1,   1, 1,  1, 1;
%e A395861   [5]  1,  16, 1,  2, 1, 1;
%e A395861   [6]  1,   8, 1,  1, 1, 1, 1;
%e A395861   [7]  1,  64, 1, 16, 1, 4, 1, 1;
%e A395861   [8]  1,   8, 1,  2, 1, 1, 1, 1, 1;
%e A395861   [9]  1, 256, 1, 16, 1, 8, 1, 1, 1, 1;
%e A395861   [10] 1, 128, 1,  8, 1, 4, 1, 1, 1, 1, 1;
%t A395861 T[t_, n_, k_] := 1/k!* Sum[(-1)^j * Binomial[k, j] * (t + k/2 - j)^n, {j, 0, k}]; Column[Table[Denominator[T[1, n, k]], {n, 0, 12}, {k, 0, n}]]
