%S A395409 0,0,1,0,2,0,4,1,0,1,7,0,9,3,1,0,12,1,14,0,2,6,18,1,0,7,3,1,23,0,25,2,
%T A395409 5,11,1,0,30,12,6,1,34,0,36,4,2,16,40,1,0,2,9,5,45,1,3,0,11,21,51,2,
%U A395409 53,23,1,0,4,2,58,8,14,1,62,0,64,28,6,10,2,4,70,1,0,31,73,2,7
%N A395409 a(n) = A033677(n) - A135034(n); excess of the smallest divisor of n >= sqrt(n) over ceiling(sqrt(n)).
%C A395409 This measures the gap between the square-root threshold and the least k such that n appears in the k X k multiplication table.
%C A395409 Equivalently, a(n) measures how far the smallest divisor of n that is >= sqrt(n) lies above ceiling(sqrt(n)).
%C A395409 Zeros occur when n has a divisor equal to ceiling(sqrt(n)); in particular, a(m^2) = 0 for all m >= 1.
%C A395409 For primes p, a(p) = p - ceiling(sqrt(p)).
%H A395409 Paolo Xausa, <a href="/A395409/b395409.txt">Table of n, a(n) for n = 1..10000</a>
%H A395409 Frédéric D. W. Heidenthal-König, <a href="https://doi.org/10.5281/zenodo.19390886">On the Motion of Numbers</a>, Zenodo, 2026.
%F A395409 a(n) = min_{d|n} max(d, n/d) - ceiling(sqrt(n)).
%F A395409 Equivalently, a(n) = A033677(n) - A135034(n).
%e A395409 a(12) = 0 because A033677(12) = 4 and A135034(12) = 4.
%e A395409 a(18) = 1 because A033677(18) = 6 and A135034(18) = 5.
%e A395409 a(19) = 14 because A033677(19) = 19 and A135034(19) = 5.
%e A395409 a(20) = 0 because A033677(20) = 5 and A135034(20) = 5.
%t A395409 A395409[n_] := #[[-Ceiling[Length[#]/2]]] - Ceiling[Sqrt[n]] & [Divisors[n]];
%t A395409 Array[A395409,100] (* _Paolo Xausa_, May 03 2026 *)
%o A395409 (Python)
%o A395409 from math import isqrt
%o A395409 def a(n):
%o A395409     s = isqrt(n)
%o A395409     if s*s < n:
%o A395409         s += 1
%o A395409     for d in range(s, n+1):
%o A395409         if n % d == 0:
%o A395409             return d - s
%o A395409 print([a(n) for n in range(1, 86)])
%Y A395409 Cf. A033677, A135034, A000290.
%K A395409 nonn,new
%O A395409 1,5
%A A395409 _Frédéric D. W. Heidenthal-König_, Apr 21 2026
