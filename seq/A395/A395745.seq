%I A395745 #22 May 13 2026 01:19:11
%S A395745 2,7,1,1,1,1,1,8,6,1,1,2,1,1,5,6,1,1,2
%N A395745 Initial digit of the decimal expansion of 3^(3^(3^n)).
%C A395745 The initial terms show a strong prevalence of the digit 1. In fact, among the first 19 values (n >= 0), 11 are equal to 1 (about 57.9 percent), which is higher than the prediction given by Benford's law.
%H A395745 Googology, <a href="https://googology.fandom.com/wiki/Tetration">Tetration</a>.
%H A395745 Googology, <a href="https://googology.fandom.com/wiki/User:Allam948736">Googology User Allam948736</a>.
%H A395745 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/BenfordsLaw.html">Benford's Law</a>.
%H A395745 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/PowerTower.html">Power Tower</a>.
%F A395745 For n >= 0, a(n) = A000030(3^(3^(3^n))).
%e A395745 a(0) = 2, since 3^(3^(3^0)) = 3^3 = 27.
%e A395745 a(1) = 7, since 3^(3^(3^1)) = 3^27 = 7625597484987.
%o A395745 (Python)
%o A395745 import mpmath as mp
%o A395745 def a(n):
%o A395745     if n==0:return 2
%o A395745     e=3**n
%o A395745     E=3**e
%o A395745     mp.mp.dps=int(e*mp.log10(3))+40
%o A395745     x=mp.mpf(E)*mp.log10(3)
%o A395745     f=x-mp.floor(x)
%o A395745     return int(mp.floor(mp.power(10,f)))
%o A395745 n=0
%o A395745 while True:
%o A395745     print(f"a({n}) = {a(n)}")
%o A395745     n+=1
%Y A395745 Cf. A000030, A241299, A244059, A395747.
%K A395745 nonn,base,hard,more,new
%O A395745 0,1
%A A395745 _Marco Ripà_, May 05 2026
