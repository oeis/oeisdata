%I A395055 #12 Apr 15 2026 13:36:10
%S A395055 2,3,4,5,6,7,9,11,12,13,15,16,17,19,20,21,23,25,27,28,29,30,31,35,36,
%T A395055 37,40,41,43,45,47,48,49,53,55,59,60,61,67,71,73,77,79,80,81,83,89,91,
%U A395055 97,101,103,107,108,109,113,121,125,126,127,131,135,137,139,143,144,149,150,151,157,162,163,167,168,169
%N A395055 Numbers k such that the greatest prime dividing A276085(k) is not larger than the greatest prime dividing k, where A276085 is fully additive with a(p) = p#/p.
%H A395055 Antti Karttunen, <a href="/A395055/b395055.txt">Table of n, a(n) for n = 1..10000</a>
%F A395055 {k>1 such that A395052(k) <= A006530(k)}.
%o A395055 (PARI)
%o A395055 A276085(n) = { my(f=factor(n)); sum(k=1, #f~, f[k, 2]*prod(i=1,primepi(f[k, 1]-1),prime(i))); };
%o A395055 A395053(n) = if(n<=1 || isprime(n), 0, my(f = factor(n), gpf = vecmax(f[, 1]), x = A276085(n)); forprime(p=2, gpf, x /= (p^valuation(x,p))); (x>1));
%o A395055 is_A395055(k) = (k>1 && !A395053(k));
%Y A395055 Cf. A000040 (subsequence), A006530, A276085, A395052, A395053, A395054 (complement \ {1}).
%Y A395055 Cf. also A395045.
%K A395055 nonn
%O A395055 1,1
%A A395055 _Antti Karttunen_, Apr 15 2026
