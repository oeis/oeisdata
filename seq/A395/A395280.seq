%e A395280   ------------------------------------------------------------------------
%e A395280     a(n)      (1)      (1)        5     6*7*10*11 = 4620     6399679104
%t A395280 Table[Product[(n*k + n - 1)!/(n*k + 1)!, {k, n - 2}], {n, 12}]
%t A395280 (* Alternative: *)
%t A395280 Table[(n^2 - n + 1)*(n^2 - n)!/(n^(2 n - 4)*(n!)^2*Pochhammer[1 + 1/n, n - 1]), {n, 12}]
