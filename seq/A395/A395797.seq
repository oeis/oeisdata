%N A395797 Expansion of -1/(Sum_{k>=0} binomial(4*k+2,k) * x^k).
%F A395797 G.f.: -1/B(x) where B(x) is the g.f. of A257633.
%F A395797 G.f.: (3*g-4)/g^3 where g = 1+x*g^4 is the g.f. of A002293.
%F A395797 a(n) = (1/n) * (6*binomial(4*n-4,n-1) - 6*binomial(4*n-4,n-2)) for n > 0.
%F A395797 a(n) = (1/n) * (12*binomial(4*n-4,n-1) - 6*binomial(4*n-3,n-1)) for n > 0.
%o A395797 (PARI) my(N=30, x='x+O('x^N)); Vec(-1/sum(k=0, N, binomial(4*k+2, k)*x^k))
