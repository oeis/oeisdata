%I A395123 #16 Apr 23 2026 10:03:48
%S A395123 1,1,32,3089,620736,213240597,111749732697,82979325688104,
%T A395123 82897463323932012,107224712655222252442,174336047786713661104180,
%U A395123 348029186482296966482554628,836911661917934678728195149426,2386126339407063836639351039544134,7958898122383939799829497667347054642
%N A395123 O.g.f. Sum_{n>=0} n^(3*n) * exp(-n^3*C(x)) * C(x)^n / n!, where C(x) = x + C(x)^2 is the g.f. of the Catalan numbers (A000108).
%C A395123 Compare to C(x) = x*Sum_{n>=0} n^n * exp(-n*C(x)) * C(x)^n / n!, where C(x) = x + C(x)^2 is the g.f. of the Catalan numbers (A000108).
%C A395123 Compare to 1/(1 - G(x)) = Sum_{n>=0} n^n * G(x)^n / n! * exp(-n*G(x)) for all G(x) such that G(0) = 0.
%C A395123 In general, for m > 1, Sum_{k=0..n} Stirling2(m*k,k) * binomial(2*n-k-1,n-k) * k/n ~ c * m^(m*n) * n^((m-1)*n - 1/2) / (sqrt(2*Pi*(1-w)) * exp((m-1)*n) * w^n * (m-w)^((m-1)*n)), where w = -LambertW(-m*exp(-m)) and c = 1 for m > 2 and c = exp(w*(2-w)/4) for m = 2. - _Vaclav Kotesovec_, Apr 23 2026
%H A395123 Paul D. Hanna, <a href="/A395123/b395123.txt">Table of n, a(n) for n = 0..400</a>
%F A395123 O.g.f. A(x) = Sum_{n>=0} a(n)*x^n satisfies the following formulas.
%F A395123 (1) A(x) = Sum_{n>=0} n^(3*n) * exp(-n^3*C(x)) * C(x)^n / n!, where C(x) = x + C(x)^2.
%F A395123 (2) A(x) = Sum_{n>=0} Stirling2(3*n,n) * C(x)^n, where C(x) = x + C(x)^2.
%F A395123 (3) A(x-x^2) = Sum_{n>=0} A217913(n)*x^n, where A217913(n) = A008277(3*n,n) for n >= 1 and A008277 equals the Stirling numbers of second kind.
%F A395123 (4) a(n) = Sum_{k=0..n} Stirling2(3*k,k) * binomial(2*n-k-1,n-k) * k/n, for n > 0 with a(0) = 1.
%F A395123 a(n) ~ 3^(3*n) * n^(2*n - 1/2) / (sqrt(2*Pi*(1-w)) * exp(2*n) * w^n * (3-w)^(2*n)), where w = -A226750 = -LambertW(-3*exp(-3)). - _Vaclav Kotesovec_, Apr 23 2026
%e A395123 O.g.f.: A(x) = 1 + x + 32*x^2 + 3089*x^3 + 620736*x^4 + 213240597*x^5 + 111749732697*x^6 + 82979325688104*x^7 + 82897463323932012*x^8 + ...
%e A395123 where
%e A395123 A(x) = 1 + exp(-C(x))*C(x) + 2^6*exp(-2^3*C(x))*C(x)^2/2! + 3^9*exp(-3^3*C(x))*C(x)^3/3! + 4^12*exp(-4^3*C(x))*C(x)^4/4! + ... + n^(3*n)*exp(-n^3*C(x))*C(x)^n/n! + ...
%e A395123 and C(x) = x + C(x)^2, which starts as
%e A395123 C(x) = x + x^2 + 2*x^3 + 5*x^4 + 14*x^5 + 42*x^6 + 132*x^7 + 429*x^8 + 1430*x^9 + ... + A000108(n)*x^(n+1) + ...
%e A395123 Therefore, we have
%e A395123 A(x-x^2) = 1 + x + 31*x^2 + 3025*x^3 + 611501*x^4 + 210766920*x^5 + 110687251039*x^6 + ... + A217913(n)*x^n + ...
%o A395123 (PARI) \\ Formula (1)
%o A395123 {a(n) = my(A=1,C=serreverse(x-x^2 + x*O(x^n)));
%o A395123 A = 1 + sum(m=1,n, m^(3*m) * exp(-m^3*C) * C^m/m!); polcoef(GF=A,n)}
%o A395123 {upto(n) = a(n); Vec(GF)}
%o A395123 upto(20)
%o A395123 (PARI) \\ Formula (2)
%o A395123 {a(n) = my(A=1,C=serreverse(x-x^2 + x*O(x^n)));
%o A395123 A = sum(m=0,n, stirling(3*m,m,2) * C^m); polcoef(GF=A,n)}
%o A395123 {upto(n) = a(n); Vec(GF)}
%o A395123 upto(20)
%o A395123 (PARI) \\ Formula (4)
%o A395123 {a(n) = if(n==0,1, sum(k=0,n, stirling(3*k,k,2) * binomial(2*n-k-1,n-k) * k/n ) )}
%o A395123 for(n=0,20,print1(a(n),", "))
%Y A395123 Cf. A395122, A219228, A217913, A008277, A000108.
%K A395123 nonn,new
%O A395123 0,3
%A A395123 _Paul D. Hanna_, Apr 22 2026
