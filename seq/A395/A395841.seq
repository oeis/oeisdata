%I A395841 #11 May 20 2026 07:58:43
%S A395841 1,1,7,91,1650,37335,997004,30419531,1038685706,39130443099,
%T A395841 1609748271420,71745932982093,3442889222459565,176974268421800156,
%U A395841 9702361690069336355,565193460933783605669,34868581115778949369645,2271467970730206740343711,155831929109503414949890633,11231316501072390426919894167
%N A395841 G.f. satisfies A(x) = sqrt( (1/x)*Series_Reversion( x/(1 + x*A(x)^3 + 2*x^2*A(x)^2*A'(x))^2 ) ).
%H A395841 Paul D. Hanna, <a href="/A395841/b395841.txt">Table of n, a(n) for n = 0..300</a>
%F A395841 Given g.f. A(x) = Sum_{n>=0} a(n)*x^n, let G(x) be the g.f. of A395840, then the following formulas hold.
%F A395841 (1) A(x) = sqrt( (1/x)*Series_Reversion( x/(1 + x*A(x)^3 + 2*x^2*A(x)^2*A'(x))^2 ) ).
%F A395841 (2) A(x) = G(x*A(x)^2).
%F A395841 (3) A(x) = sqrt( (1/x)*Series_Reversion(x/G(x)^2) ).
%F A395841 (4) G(x) = A(x/G(x)^2).
%F A395841 (5) G(x) = 1 + x*A(x)^3 + 2*x^2*A(x)^2*A'(x).
%F A395841 (6) [x^n] A(x)^3 = 3/(2*n+3) * [x^(n+1)] G(x) for n >= 0.
%F A395841 a(n) ~ c * 2^n * n^(n + (11*LambertW(1) - 5 + 9/(1 + LambertW(1)))/4) / (exp(n) * LambertW(1)^n), where c = 0.25489426281963501264... - _Vaclav Kotesovec_, May 20 2026
%e A395841 G.f.: A(x) = 1 + x + 7*x^2 + 91*x^3 + 1650*x^4 + 37335*x^5 + 997004*x^6 + 30419531*x^7 + 1038685706*x^8 + 39130443099*x^9 + ...
%e A395841 RELATED SERIES.
%e A395841 The related g.f. for A395840 begins
%e A395841 G(x) = 1 + x + 5*x^2 + 56*x^3 + 948*x^4 + 20768*x^5 + 546637*x^6 + 16591400*x^7 + 566264968*x^8 + ...
%e A395841 where A(x) = G(x*A(x)^2).
%e A395841 The coefficients in G(x) may be derived from A(x)^3, which begins
%e A395841 A(x)^3 = 1 + 3*x + 24*x^2 + 316*x^3 + 5664*x^4 + 126147*x^5 + 3318280*x^6 + 99929112*x^7 + 3374877315*x^8 + ...
%e A395841 by [x^(n+1)] G(x) = (2*n+3)/3 * [x^n] A(x)^3, for example
%e A395841   1 = (3/3)*1, 5 = (5/3)*3, 56 = (7/3)*24, 948 = (9/3)*316, ...
%o A395841 (PARI) {a(n) = my(A=1); for(i=1, n,
%o A395841 A = sqrt( (1/x)*serreverse( x/(1 + x*A^3 + 2*x^2*A^2*A')^2 +x^2*O(x^n) ))); polcoef(GF=A, n)}
%o A395841 {upto(n) = a(n); Vec(GF)}
%o A395841 upto(20)
%Y A395841 Cf. A395840, A361049.
%K A395841 nonn,new
%O A395841 0,3
%A A395841 _Paul D. Hanna_, May 16 2026
