%S A395596 1,1,2,3,3,5,4,5,5,7,7,7,8,9,8,9,11,11,12,13,13,13,14,13,16,17,17,17,
%T A395596 18,19,19,19,20,21,22,23,23,23,25,23,25,25,27,27,28,29,29,29,30,31,32,
%U A395596 33,33,35,34,33,35,35,36,37,38,39,38,39,41,41,41,43,43
%N A395596 Nearest integer to n*(phi-1) which is coprime with n, where phi is the golden ratio.
%C A395596 Numbers with an even index must be odd because the number and its index must be coprime.
%C A395596 There are more odd numbers than even numbers in this sequence. Every other number must be odd, and at least some of the other half of the values are also odd.
%H A395596 James C. McMahon, <a href="/A395596/b395596.txt">Table of n, a(n) for n = 1..10000</a>
%e A395596 To find a(15): 15*(phi-1) = 9.2705... The nearest integer is 9, but 9 and 15 share the factor 3. The next nearest integer is 10, but 10 and 15 share the factor 5. The next nearest integer is 8, which does not share any factors with 15, so a(15) = 8.
%t A395596 a[n_]:=Module[{ i=n*(GoldenRatio-1)},k=Round[i];If[k<i,p=1,p=0];m=0;While[!CoprimeQ[k,n],m++;k=k+m*(-1)^(m+p)];k];Array[a,69] (* _James C. McMahon_, Jul 07 2026 *)
%Y A395596 Cf. A001622, A101803, A116921.
%K A395596 nonn,new
%O A395596 1,3
