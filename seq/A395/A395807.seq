%F A395807 Equals sqrt(4 + csc(Pi/20)^2)/4.
%F A395807 Equals sqrt((3 - 2*cos(Pi/10))/(8 - 8*cos(Pi/10))) = sqrt((3 - A188593)/(8 - 8*A019881)).
%F A395807 Equals sqrt(1 + (2*sqrt(5) + sqrt(50 + 22*sqrt(5)))/8) = sqrt(1 + (A010476 + sqrt(50 + 22*A002163))/8).
%F A395807 Equals the largest root of 256*x^8 - 1024*x^6 + 976*x^4 - 344*x^2 + 41.
%e A395807 1.6745047437425603067556345281467845735161384284804...
%t A395807 First[RealDigits[Sqrt[4 + Csc[Pi/20]^2]/4, 10, 100]]
