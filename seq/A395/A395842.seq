%I A395842 #9 May 23 2026 00:29:55
%S A395842 1,2,-6,66,-1100,24430,-679756,22919008,-917372412,42968761980,
%T A395842 -2328826695580,144666751591956,-10213907729550616,813399640045310292,
%U A395842 -72560696609091997320,7205276746285946245956,-791889562981577906932880,95825396415982132480946520,-12706859489651304100910985244
%N A395842 a(n) = [x^n] G^{n}(x) for n >= 1, i.e., a(n) equals the coefficient of x^n in the n-th iteration of G(x), the g.f. of A177775, which satisfies [x^n] G^{n}(x) = [x^n] G^{n-1}(x) for n > 2.
%C A395842 It appears that all terms are even after the initial term.
%H A395842 Paul D. Hanna, <a href="/A395842/b395842.txt">Table of n, a(n) for n = 1..256</a>
%e A395842 The g.f. of A177775 begins
%e A395842 G(x) = x + x^2 - 4*x^3 + 39*x^4 - 580*x^5 + 11480*x^6 - 285116*x^7 + 8617217*x^8 - 311138320*x^9 + ... + A177775(n)*x^n + ...
%e A395842 Coefficients in the initial iterations of G(x) begin:
%e A395842   [1, 1, -4,  39,   -580,  11480,  -285116, ...];
%e A395842   [1, 2,(-6), 59,   -898,  18228,  -463816, ...];
%e A395842   [1, 3,(-6),(66), -1048,  21932,  -572180, ...];
%e A395842   [1, 4, -4, (66),(-1100), 23750,  -634548, ...];
%e A395842   [1, 5,  0,  65, (-1100),(24430), -666940, ...];
%e A395842   [1, 6,  6,  69,  -1070, (24430),(-679756), ...];
%e A395842   [1, 7, 14,  84,  -1008,  24038, (-679756), ...]; ...
%e A395842 where the above coefficients in parenthesis illustrate the property that the coefficients of x^n in G^{n}(x) and in G^{n-1}(x) are equal for n > 2.
%e A395842 The main diagonal in the above table equals this sequence.
%o A395842 (PARI) \\ Routine returns the n-th iteration of a function F
%o A395842 {IT(n, F) = my(G=x); for(i=1, n, G = subst(F, x, G)); G}
%o A395842 \\ Calculate and print the terms
%o A395842 {a(n) = my(V=[0, 1, 1],D=vector(n,i,i),G,H,m); for(i=2, n, V=concat(V, 0); m = #V-1; G=Ser(V); H = IT(m-1, G); D[m-1] = polcoef(H,m-1);
%o A395842 V[#V] = -polcoef(subst(G,x,H) - H, m) ); DIAG=D; DIAG[n]}
%o A395842 {upto(n) = a(n); DIAG}
%o A395842 upto(20)
%Y A395842 Cf. A177775.
%K A395842 sign,new
%O A395842 1,2
%A A395842 _Paul D. Hanna_, May 20 2026
