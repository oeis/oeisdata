%I A395307 #20 Apr 30 2026 18:58:12
%S A395307 3,2,31,233,211,2861,10711,99611,513053,5486807,184700947,1002002467,
%T A395307 1232268241,143042268079,844598501179,9899150975347,18197101446031
%N A395307 Let p1 and p2 be two consecutive primes. Take the sums p1*10^j+p2, with 0<=j<=(number of digits of p2), and p2*10^j+p1, with 1<=j<=(number of digits of p1). Sequence lists the least prime p1 that together with its successor p2 generates exactly n distinct primes through the described process.
%H A395307 Paolo P. Lava, <a href="/A395307/a395307.pdf">Terms and generated primes</a>
%H A395307 Carlos Rivera, <a href="https://www.primepuzzles.net/puzzles/puzz_1265.htm">Puzzle 1265 A sort of "convolution" between a prime P1 and its successor P2</a>, The Prime Puzzles and Problems Connection.
%e A395307 a(1) = 3 -> p1 = 3, p2 = 5; 3 + 5 = 8 (not prime), 30 + 5 = 35 (not prime), 50 + 3 = 53 (prime).
%e A395307 a(2) = 2 -> p1 = 2, p2 = 3; 2 + 3 = 5 (prime), 20 + 3 = 23 (prime), 30 + 2 = 32 (not prime).
%e A395307 a(3) = 31 -> p1 = 31, p2= 37; 31 + 37 = 68 (not prime), 310 + 37 = 347 (prime), 3100 + 37 = 3137 (not prime), 370 + 31 = 401 (prime), 3700 + 31 = 3731 (prime).
%o A395307 (PARI) isok(p, q, n) = my(vnp = vector(#digits(q)+1, j, p*10^(j-1)+q), vnq = vector(#digits(p), j, q*10^j+p)); #setunion(Set(select(isprime, vnp)), Set(select(isprime, vnq))) == n;
%o A395307 a(n) = my(p=2, q=nextprime(p+1)); while (!isok(p, q, n), p=q; q=nextprime(p+1)); p; \\ _Michel Marcus_, Apr 25 2026
%Y A395307 Cf. A000040, A394773.
%K A395307 nonn,hard,more,new
%O A395307 1,1
%A A395307 _Paolo P. Lava_, Apr 19 2026
