%U A395288 1660706236063213755,71283400206012142352,3251398785082833082220,157053037777429545619812,8009094380807115541992983
%N A395288 Number of partitions of [2n] where exactly n blocks contain their own index element.
%C A395288 Exactly the first n blocks contain their own index element.
%C A395288 This sequence contains no primes.
%H A395288 Alois P. Heinz, <a href="/A395288/b395288.txt">Table of n, a(n) for n = 0..386</a>
%H A395288 Wikipedia, <a href="https://en.wikipedia.org/wiki/Partition_of_a_set">Partition of a set</a>
%F A395288 a(n) = A259691(2*n-1,n) for n>=1, a(0) = 1.
%F A395288 a(n) = n * Sum_{j=0..n-1} binomial(n-1,j) * n^j * Bell(n-1-j) for n>=1, a(0) = 1.
%F A395288 a(n) mod 2 = A120325(n+1) for n >= 1.
%F A395288 a(n) mod n = 0 for n >= 1.
%F A395288 a(n) ~ exp(exp(1) - 1) * n^n. - _Vaclav Kotesovec_, Jun 20 2026
%F A395288 a(n)/n = A397332(n-1) for n>=1. - _Alois P. Heinz_, Jun 24 2026
%e A395288 a(0) = 1: the empty partition.
%e A395288 a(1) = 1: 12.
%e A395288 a(2) = 6: 134|2, 13|24, 13|2|4, 14|23, 1|234, 1|23|4.
%e A395288 a(3) = 51: 1456|2|3, 145|26|3, 145|2|36, 145|2|3|6, 146|25|3, 14|256|3, 14|25|36, 14|25|3|6, 146|2|35, 14|26|35, 14|2|356, 14|2|35|6, 146|2|3|5, 14|26|3|5, 14|2|36|5, 14|2|3|56, 14|2|3|5|6, 156|24|3, 15|246|3, 15|24|36, 15|24|3|6, 16|245|3, 1|2456|3, 1|245|36, 1|245|3|6, 16|24|35, 1|246|35, 1|24|356, 1|24|35|6, 16|24|3|5, 1|246|3|5, 1|24|36|5, 1|24|3|56, 1|24|3|5|6, 156|2|34, 15|26|34, 15|2|346, 15|2|34|6, 16|25|34, 1|256|34, 1|25|346, 1|25|34|6, 16|2|345, 1|26|345, 1|2|3456, 1|2|345|6, 16|2|34|5, 1|26|34|5, 1|2|346|5, 1|2|34|56, 1|2|34|5|6.
%p A395288 b:= proc(n, m) option remember;
%p A395288      `if`(n=0, 1, m*b(n-1, m)+b(n-1, m+1))
%p A395288     end:
%p A395288 a:= n-> `if`(n=0, 1, n*b(n-1, n)):
%p A395288 seq(a(n), n=0..19);
%t A395288 b[n_, m_] := b[n, m] = If[n == 0, 1, m*b[n-1, m] + b[n-1, m+1]];
%t A395288 A395288[n_] := If[n == 0, 1, n*b[n-1, n]];
%t A395288 Array[A395288, 20, 0] (* _Paolo Xausa_, Jun 22 2026, after _Alois P. Heinz_ *)
