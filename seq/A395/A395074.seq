%I A395074 #15 Apr 12 2026 08:39:44
%S A395074 1,2,27,1096,87645,11608875,2307990937,645109279976,241799029322733,
%T A395074 117241707547221835,71486133614550081108,53573200081342168344558,
%U A395074 48426916459853818483874355,51975838954942798940189090421,65357002420292681969354903368740,95187921673935668103039463244580560
%N A395074 G.f. A(x) satisfies [x^n] exp( -n*A(x) ) / (1-n^2*x)^(1/n) = 0, for n >= 1.
%H A395074 Seiichi Manyama, <a href="/A395074/b395074.txt">Table of n, a(n) for n = 1..215</a>
%F A395074 a(n) = n^(2*n-3) + (1/n) * Sum_{k=1..n-1} k * c_n(k) * e_n(n-k),
%F A395074 where c_n(k) = n^(2*k-2)/k - a(k) for 1 <= k <= n-1,
%F A395074 and e_n(0) = 1, e_n(k) = (n/k) * Sum_{j=1..k} j * c_n(j) * e_n(k-j) for 1 <= k <= n-1.
%o A395074 (Ruby)
%o A395074 def A395074(n)
%o A395074   a = [0]
%o A395074   (1..n).each{|i|
%o A395074     c = [0] + (1..i - 1).map{|k| i ** (2 * k - 2) / k.to_r - a[k]}
%o A395074     e = [1]
%o A395074     (1..i - 1).each{|k| e << i / k.to_r * (1..k).inject(0){|s, j| s + j * c[j] * e[k - j]}}
%o A395074     a << i ** (2 * i - 3) + (1..i - 1).inject(0){|s, k| s + k * c[k] * e[i - k]}.to_i / i
%o A395074   }
%o A395074   a[1..-1]
%o A395074 end
%o A395074 p A395074(20)
%Y A395074 Cf. A320414, A395024.
%Y A395074 Cf. A319938, A395075.
%K A395074 nonn,changed
%O A395074 1,2
%A A395074 _Seiichi Manyama_, Apr 10 2026
