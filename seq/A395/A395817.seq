%I A395817 #19 May 22 2026 17:56:16
%S A395817 1,2,3,4,5,10,11,12,13,14,15,20,21,22,23,24,25,30,31,32,33,34,35,40,
%T A395817 41,42,43,44,45,50,100,101,102,103,104,105,110,111,112,113,114,115,
%U A395817 120,121,122,123,124,125,130,131,132,133,134,135,140,141,142,143,144
%N A395817 Strictly increasing minimal sequence where consecutive terms can be added digit-by-digit without carrying in base 10.
%C A395817 Many integers (e.g., 6, 7, 8, 9, 15, 16...) are never present because the greedy behavior and the strictly increasing condition bypass them to avoid carries.
%C A395817 A subset of nonnegative integers with no decimal digits > 5 (A007092).
%H A395817 Vincenzo Manto, <a href="/A395817/b395817.txt">Table of n, a(n) for n = 1..10000</a>
%F A395817 a(1)=1; a(n) = min { x > a(n-1) | d_i(x) + d_i(a(n-1)) <= 9 }.
%e A395817 a(5) = 5 because a(4) = 4 and 4 is the smallest k such that 4 + k doesn't carry: 4 + 5 = 9 (no carry).
%e A395817 a(15) = 24 because a(14) = 23 and 24 is the smallest k such that 23 + k doesn't carry: 23 + 24 = 47 (no carry).
%e A395817 a(56) = 150 because a(55) = 144 and 150 is the smallest k such that 144 + k doesn't carry: 144 + 150 = 294 (no carry).
%t A395817 s={1};k=2;Do[While[Max[IntegerDigits[k]]>5||Max[IntegerDigits[s[[-1]]]+Take[IntegerDigits[k],-IntegerLength[s[[-1]]]]]> 9,k++];AppendTo[s,k];k++,{i,58}];s
%o A395817 (Python)
%o A395817 def has_carry(a, b):
%o A395817     while a or b:
%o A395817         if (a % 10) + (b % 10) > 9:
%o A395817             return True
%o A395817         a //= 10; b //= 10
%o A395817     return False
%o A395817 def sequence(n):
%o A395817     terms = [1]
%o A395817     while len(terms) < n:
%o A395817         k = terms[-1] + 1
%o A395817         while has_carry(terms[-1], k):
%o A395817             k += 1
%o A395817         terms.append(k)
%o A395817     return terms
%Y A395817 Cf. A052413, A007092.
%K A395817 nonn,base
%O A395817 1,2
%A A395817 _Vincenzo Manto_ and _James C. McMahon_, May 07 2026
