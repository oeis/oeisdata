%N A395172 Square array A(n,k), n>=0, k>=0, read by antidiagonals downwards, where A(n,k) = (2*n)! * [x^(2*n)] C(x)^k and C(x) satisfies C(x) = cosh( Integral C(x)^5 dx ).
%H A395172 Paolo Xausa, <a href="/A395172/b395172.txt">Table of n, a(n) for n = 0..11324</a> (first 150 antidiagonals, flattened).
%F A395172 A(0,k) = 1 and A(n,k) = k*(k+5) * A(n-1,k+10) - k*(k+4) * A(n-1,k+8) for n > 0.
%e A395172 Square array begins:
%e A395172   1,        1,         1,         1,         1,         1,         1, ...
%e A395172   0,        1,         2,         3,         4,         5,         6, ...
%e A395172   0,       21,        48,        81,       120,       165,       216, ...
%e A395172   0,     1341,      3312,      6003,      9504,     13905,     19296, ...
%e A395172   0,   173961,    453888,    866241,   1440000,   2206665,   3200256, ...
%e A395172   0, 38032281, 103548672, 205785603, 355567104, 565418205, 849678336, ...
%t A395172 A395172[n_, k_] := A395172[n, k] = If[n == 0, 1, k*(k+5)*A395172[n-1, k+10] - k*(k+4)*A395172[n-1, k+8]];
%t A395172 Table[A395172[k, n-k], {n, 0, 10}, {k, 0, n}] (* _Paolo Xausa_, Apr 15 2026 *)
%o A395172 (PARI) a(n, k) = if(n==0, 1, k*(k+5)*a(n-1, k+10)-k*(k+4)*a(n-1, k+8));
%Y A395172 Columns k=0..6 give A000007, A281432, A395173, A395174, A395175, A395176, A281431(n+1).
%Y A395172 Cf. A341268, A395141, A395146, A395148.
%K A395172 nonn,tabl,new
%O A395172 0,8
%A A395172 _Seiichi Manyama_, Apr 15 2026
