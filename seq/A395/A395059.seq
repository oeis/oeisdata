%T A395059 12,1,6,32,223092870,1,6469693230,1,4,1,36,6,200560490130,1,8,1,
%U A395059 7420738134810,1,304250263527210,4,2,1,13082761331670030,6,60,1,16,8,614889782588491410,1,216,1,16,1,32589158477190044730,2
%N A395059 a(n) = A328479(A276085(n)).
%H A395059 Antti Karttunen, <a href="/A395059/b395059.txt">Table of n, a(n) for n = 2..2370</a>
%H A395059 <a href="/index/Pri#primorial_numbers">Index entries for sequences related to primorial numbers</a>.
%F A395059 a(n) = A276085(n) / A395058(n).
%o A395059 (PARI)
%o A395059 A276085(n) = { my(f=factor(n)); sum(k=1, #f~, f[k, 2]*prod(i=1,primepi(f[k, 1]-1),prime(i))); };
%o A395059 A111701(n) = forprime(p=2, , if(n%p, return(n), n /= p));
%o A395059 A328478(n) = { my(u=A111701(n)); if(u==n, return(n), return(A328478(u))); };
%o A395059 A328479(n) = (n/A328478(n));
%o A395059 A395059(n) =  A328479(A276085(n));
%Y A395059 Cf. A276085, A328479, A395058.
%K A395059 nonn,new
%O A395059 2,2
