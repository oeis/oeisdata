%T A395901 10985,12032,12167,14641,15625,16384,16807,16875,18225,19683,28561,
%U A395901 32768,34391,35721,40625,43923,50625,50653,53125,55566,59049,60025,64009,65536,66049,69984
%N A395901 Numbers c that appear in more than one abc triple with rad(a*b*c) < c and gcd(a,b)=1.
%C A395901 These are c-values that appear in at least two distinct abc triples with rad(a*b*c) < c and gcd(a,b)=1.
%H A395901 Andrey Drozdov, <a href="https://github.com/nup654321/abc-algorithm">Source code and data (GitHub)</a>
%e A395901 a(1) = 81 because 32+49=81 and 1+80=81 both satisfy rad(abc) < c.
%e A395901 a(4) = 2401 has four representations: 1+2400, 1024+1377, 1344+1057, 1681+720.
%e A395901 a(14) = 15625 has 15 representations: 1+15624, 9+15616, 16+15609, 19+15606, 73+15552, 137+15488, 162+15463, 729+14896, 984+14641, 1369+14256, 1701+13924, 1936+13689, 4096+11529, 5041+10584, 6877+8748.
%o A395901 (Python)
%o A395901 from functools import lru_cache
%o A395901 import math
%o A395901 @lru_cache(maxsize=None)
%o A395901 def rad(n):
%o A395901     r = 1
%o A395901     p = 2
%o A395901     while p * p <= n:
%o A395901         if n % p == 0:
%o A395901             r *= p
%o A395901             while n % p == 0:
%o A395901                 n //= p
%o A395901         p += 1 if p == 2 else 2
%o A395901     if n > 1:
%o A395901         r *= n
%o A395901     return r
%o A395901 def is_fertile(c):
%o A395901     pairs = set()
%o A395901     for a in range(1, c//2 + 1):
%o A395901         b = c - a
%o A395901         if math.gcd(a, b) != 1:
%o A395901             continue
%o A395901         if rad(a) * rad(b) * rad(c) < c:
%o A395901             pairs.add((a, b))
%o A395901             if len(pairs) == 2:
%o A395901                 return True
%o A395901     return False
%o A395901 res = [c for c in range(2, 10000) if is_fertile(c)]
%o A395901 print(res[:50])
%Y A395901 Cf. A007947, A130510, A120498, A272242.
