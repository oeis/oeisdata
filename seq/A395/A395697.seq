%I A395697 #14 May 09 2026 11:12:31
%S A395697 2,2,129,28,5,6870,28,160,639,10,77,22548,4888,28,6870,160,17,31734,
%T A395697 874,100,3087,440,874,23592,100,4888,1161,28,58,6870,2914,160,13101,
%U A395697 238,88585,35568,1480,874,35568,160,41,281064,129,440,169605,874,2914,35568,3087,100,87516,4888,1060,96282,440
%N A395697 a(n) is the least multiple of n that is a partial sum of the primes.
%C A395697 a(n) = n if and only if n is in A007504.
%H A395697 Robert Israel, <a href="/A395697/b395697.txt">Table of n, a(n) for n = 1..10000</a>
%F A395697 a(n) = n * A308749(n).
%e A395697 a(4) = 28 because 28 = 2+3+5+7+11 is the first partial sum of primes that is a multiple of 4.
%p A395697 N:= 100: # for a(1) .. a(N)
%p A395697 count:= 0: V:= Vector(N):
%p A395697 p:= 1: s:= 0:
%p A395697 while count < N do
%p A395697   p:= nextprime(p); s:= s + p;
%p A395697   J:= select(t -> t <= N and V[t]=0, numtheory:-divisors(s));
%p A395697   for j in J do V[j]:= s od;
%p A395697   count:= count + nops(J);
%p A395697 od:
%p A395697 convert(V,list);
%t A395697 a[n_]:=Module[{sm=2,p=2},While[Mod[sm,n]!=0,p=NextPrime[p];sm=sm+p];sm];Array[a,55] (* _James C. McMahon_, May 09 2026 *)
%Y A395697 Cf. A007504, A308749.
%K A395697 nonn,new
%O A395697 1,1
%A A395697 _Robert Israel_, May 03 2026
