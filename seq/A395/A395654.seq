%I A395654 #8 Jun 03 2026 17:14:49
%S A395654 6,36,60,66,90,96,126,132,150,156,162,180,186,192,216,222,246,252,270,
%T A395654 276,306,336,342,366,372,390,396,402,426,432,438,456,480,486,492,510,
%U A395654 516,522,546,552,576,582,594,600,606,612,636,642,660,666,672,690,696,702,726,732,750,756,762,774,780
%N A395654 Numbers divisible by 6 that are not the sum of a member of A022004 and a member of A022005.
%C A395654 Numbers k divisible by 6 such that there do not exist p and q such that p + q = k and p, p + 2, p + 6, q, q + 4 and q + 6 are all prime.
%H A395654 Robert Israel, <a href="/A395654/b395654.txt">Table of n, a(n) for n = 1..10000</a>
%e A395654 54 is not a term because 54 = 17 + 37 where 17 is in A022004 and 37 is in A022005.
%e A395654 a(3) = 60 is a term because the members of A022004 less than 60 are 5, 11, 17, and 41, and none of 60 - 5 = 55, 60 - 11 = 49, 60 - 17 = 43 and 60 - 41 = 19 are in A022005.
%p A395654 N:= 1000: # for terms <= N
%p A395654 A4:= select(p -> isprime(p) and isprime(p+2) and isprime(p+6), [seq(i,i=5..N,6)]):
%p A395654 A5:= select(p -> isprime(p) and isprime(p+4) and isprime(p+6), [seq(i,i=1..N,6)]):
%p A395654 f:= proc(n) local p,q,v;
%p A395654 for p in A4 do
%p A395654         q:= n-p;
%p A395654         if q < 0 then return true fi;
%p A395654         v:= ListTools:-BinarySearch(A5,q);
%p A395654         if v <> 0 then return false fi;
%p A395654       od;
%p A395654  true
%p A395654 end proc:
%p A395654 select(f, [seq(i,i=6..N,6)]);
%Y A395654 Cf. A022004, A022005, A396570.
%K A395654 nonn,new
%O A395654 1,1
%A A395654 _Robert Israel_, May 30 2026
