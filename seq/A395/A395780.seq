%U A395780 84377281155168,611551322732687,4413481365001680,31730521183547172,227349945847349952,1623986957273609304
%N A395780 Expansion of (Sum_{k>=0} binomial(3*k+1,k) * x^k)^4.
%F A395780 a(n) = Sum_{i,j,k,l >= 0 and i+j+k+l=n} binomial(3*i+1,i) * binomial(3*j+1,j) * binomial(3*k+1,k) * binomial(3*l+1,l).
%F A395780 G.f.: B(x)^4 where B(x) is the g.f. of A045721.
%F A395780 a(n) = Sum_{k=0..n} 2^k * binomial(k+2,2) * binomial(3*n+7,n-k).
%F A395780 a(n) = Sum_{k=0..n} 3^k * binomial(k+2,2) * binomial(3*n+4-k,n-k).
%F A395780 a(0) = 1; a(n) = (1/n) * Sum_{k=0..n-1} (3*k+16) * 2^k * binomial(k+3,3) * binomial(3*n+7,n-1-k).
%F A395780 a(0) = 1; a(n) = (1/n) * Sum_{k=0..n-1} (2*k+16) * 3^k * binomial(k+3,3) * binomial(3*n+3-k,n-1-k).
%o A395780 (PARI) a(n) = sum(k=0, n, 2^k*binomial(k+2, 2)*binomial(3*n+7, n-k));
