%S A395148 1,1,0,1,1,0,1,2,9,0,1,3,24,225,0,1,4,45,720,11025,0,1,5,72,1575,
%T A395148 40320,893025,0,1,6,105,2880,99225,3628800,108056025,0,1,7,144,4725,
%U A395148 201600,9823275,479001600,18261468225,0,1,8,189,7200,363825,21772800,1404728325,87178291200,4108830350625,0
%N A395148 Square array A(n,k), n>=0, k>=0, read by antidiagonals downwards, where A(n,k) = (2*n)! * [x^(2*n)] 1/(1 - x^2)^(k/2).
%H A395148 Paolo Xausa, <a href="/A395148/b395148.txt">Table of n, a(n) for n = 0..11324</a> (first 150 antidiagonals, flattened).
%F A395148 A(0,k) = 1 and A(n,k) = k*(k+2) * A(n-1,k+4) - k*(k+1) * A(n-1,k+2) for n > 0.
%e A395148 Square array begins:
%e A395148   1,      1,       1,       1,        1,        1, ...
%e A395148   0,      1,       2,       3,        4,        5, ...
%e A395148   0,      9,      24,      45,       72,      105, ...
%e A395148   0,    225,     720,    1575,     2880,     4725, ...
%e A395148   0,  11025,   40320,   99225,   201600,   363825, ...
%e A395148   0, 893025, 3628800, 9823275, 21772800, 42567525, ...
%t A395148 A395148[n_, k_] := A395148[n, k] = If[n == 0, 1, k*(k+2)*A395148[n-1, k+4] - k*(k+1)*A395148[n-1, k+2]];
%t A395148 Table[A395148[k,n-k],{n,0,10},{k,0,n}] (* _Paolo Xausa_, Apr 15 2026 *)
%o A395148 (PARI) a(n, k) = if(n==0, 1, k*(k+2)*a(n-1, k+4)-k*(k+1)*a(n-1, k+2));
%Y A395148 Columns k=0..4 give A000007, A001818, A010050, A079484, A327882(n+1).
%Y A395148 Cf. A341268, A395141, A395146.
%K A395148 nonn,tabl,new
%O A395148 0,8
%A A395148 _Seiichi Manyama_, Apr 14 2026
