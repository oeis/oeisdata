%N A395298 a(n) = (2*n)! * [x^(2*n)] cosh(x)^5 / cos(x).
%F A395298 a(n) = (10 + 5*9^n + 25^n)/16 - Sum_{k=0..n-1} (-1)^(n-k) * binomial(2*n,2*k) * a(k).
%F A395298 a(n) = (1/16) * Sum_{k=0..n} (10 + 5*9^(n-k) + 25^(n-k)) * binomial(2*n,2*k) * A000364(k).
%o A395298 (PARI) a_vector(n) = my(v=vector(n+1)); for(i=0, n, v[i+1]=(10+5*9^i+25^i)/16-sum(j=0, i-1, (-1)^(i-j)*binomial(2*i, 2*j)*v[j+1])); v;
