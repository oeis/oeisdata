%N A395641 Triangular array: row n shows the coefficients of the polynomial - n!*L(n, x), where L(n, x) is the Lagrange interpolating polynomial that passes through (0,-1) and (k,1) for k = 1..n.
%e A395641 First eight rows:
%e A395641       1
%e A395641       1    -2
%e A395641       2    -6       2
%e A395641       6    -22     12     -2
%e A395641      24   -100     70    -20     2
%e A395641     120   -548    450   -170    30   -2
%e A395641     720  -3528   3248  -1470   350  -42   2
%e A395641    5040 -26136  26264 -13538  3920 -644  56  -2
%e A395641 Row 4 represents the polynomial 24 - 100*x + 70*x^2 - 20*x^3 + 2*x^4.
%t A395641 s[n_] := Join[{{0, -1}}, Table[{k, 1}, {k, 1, n}]];
%t A395641 p[n_, x_] := Expand[InterpolatingPolynomial[s[n], x]];
%t A395641 Column[Table[CoefficientList[-n!*p[n, x], x], {n, 0, 10}]]
%t A395641 Flatten[Table[CoefficientList[-n!*p[n, x], x], {n, 0, 10}]]
%t A395641 Labeled[Plot[{p[1, x], p[2, x], p[3, x], p[4, x], p[5, x]}, {x, -1, 7}], "Plot of p[n,x]for n=1..5."]
