%T A395301 4,12,2,4,4,9,2,8,2,7,8,4,2,11,9,10,4,7,2,10,4,9,4,4,2,13,2,4,8,8,4,8,
%U A395301 2,7,4,8,2,15,2,4,10,7,4,8,2,11,7,4,2,13,4,4,4,9,2,14,4,7,4,4,4,13,2,12,8,14
%N A395301 a(n) = tau(n) - omega(n) + Sum_{p|n, p prime} gcd(p,n/p).
%C A395301 For each divisor d of n, add gcd(d,n/d) if d is prime, else add 1.
%F A395301 a(n) = Sum_{d|n} gcd(d,n/d)^c(d), where c is the prime characteristic (A010051).
%F A395301 a(n) = A033273(n) + A345266(n).
%t A395301 Table[Sum[GCD[d, n/d]^(PrimePi[d] - PrimePi[d - 1]), {d, Divisors[n]}], {n, 100}]
%Y A395301 Cf. A000005 (tau), A001221 (omega), A010051, A033273, A345266.
%K A395301 nonn,easy
%O A395301 1,2
%A A395301 _Wesley Ivan Hurt_, Apr 18 2026
