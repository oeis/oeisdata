%I A395770 #15 May 14 2026 23:18:36
%S A395770 0,2,6,18,44,112,256,608,1344,3072,6656,14848,31744,69632,147456,
%T A395770 319488,671744,1441792,3014656,6422528,13369344,28311552,58720256,
%U A395770 123731968,255852544,536870912,1107296256,2315255808,4764729344,9932111872
%N A395770 Minimal value of Sum_{i=1..n-1} p(i)*p(i+1), as p ranges over all permutations of powers of 2 {1,2,4,...,2^(n-1)}.
%C A395770 The question originated from generalization of the first puzzle, 'Low Budget', in the book Mathematical Puzzles and Curiosities.
%D A395770 I. David, T. Khovanova, and Y. Shpilman, Mathematical Puzzles and Curiosities, World Scientific, 2026, p.2.
%H A395770 Vincenzo Librandi, <a href="/A395770/b395770.txt">Table of n, a(n) for n = 1..1000</a>
%F A395770 a(n) = 2^(n-5)*(10*n - 5 + (-1)^n) for n>=2.
%F A395770 a(n) = A395767(n) - 2^(n-2) for n>=2.
%e A395770 For n=4, the permutation that realizes the minimum value is 4,2,1,8. So a(4) = 4*2 + 2*1 + 1*8 = 18.
%t A395770 a[1]=0; a[n_]:=2^(n-5)*(10*n-5+(-1)^n);Table[a[n],{n,1,35}] (* _Vincenzo Librandi_, May 11 2026 *)
%o A395770 (Magma) [0] cat [2^(n-5)*(10*n - 5 + (-1)^n): n in [2..39]]; // _Vincenzo Librandi_, May 11 2026
%Y A395770 Cf. A101986, A110610, A110611, A026035, A229278, A395767.
%K A395770 nonn,easy,new
