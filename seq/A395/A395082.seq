%I A395082 #13 May 03 2026 23:21:31
%S A395082 1,1,1,2,1,1,1,1,1,2,2,1,1,1,3,6,3,1,2,1,4,10,6,1,2,10,13,13,10,1,1,1,
%T A395082 39,36,37,44,4,1,60,61,20,1,2,1,85,133,131,1,8,40,50,242,195,1,14,223,
%U A395082 159,417,383,1,1,1,533,758,686,495,7,1,786,1150,41,1
%N A395082 a(n) is the number of partitions of n into distinct parts with sum of phi values equals phi(n).
%C A395082 Any valid partition of n has at most n - phi(n) + 1 parts (with equality only possible if 1 is a part). If we exclude 1 as a part, then at most n - phi(n) parts.
%C A395082 Equivalently, valid partitions S satisfy Sum_{k in S} A051953(k) = A051953(n).
%C A395082 We define A000010(0) = 0.
%H A395082 Felix Huber, <a href="/A395082/b395082.txt">Table of n, a(n) for n = 0..500</a>
%F A395082 Any valid partition of n has at most n - phi(n) + 1 parts (with equality only possible if 1 is a part).
%F A395082 Equivalently, valid partitions S satisfy Sum_{k in S} A051953(k) = A051953(n).
%F A395082 We define A000010(0) = 0.
%e A395082 a(3) = 2: [3], [1,2], since phi(3) = 2 and phi(1) + phi(2) = 1 + 1 = 2.
%e A395082 a(16) = 3: [16], [1,2,3,10], [1,2,3,4,6], since phi(16) = 8 and each listed partition has phi sum 8.
%p A395082 A395082 := proc(n)
%p A395082     local h, g, f;
%p A395082     h := proc(k) option remember; `if`(k <= 0, 0, NumberTheory:-phi(k)) end proc:
%p A395082     g := proc(k) option remember; `if`(k <= 0, 0, g(k - 1) + h(k)) end proc:
%p A395082     f := proc(i, j, k) option remember;
%p A395082         `if`(i = 0 and j = 0, 1,`if`(i < 0 or j < 0 or k = 0 or j > g(k), 0,
%p A395082         f(i, j, k - 1) + f(i - k, j - h(k), k - 1)))
%p A395082     end proc:
%p A395082     `if`(n = 0, 1, f(n, h(n), n))
%p A395082 end proc:
%p A395082 seq(A395082(n), n = 0 .. 71);
%Y A395082 Cf. A000009, A000010, A051953, A394248, A395091, A395096, A395097, A395111.
%K A395082 nonn,new
%O A395082 0,4
