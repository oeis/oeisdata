%I A395741 #32 May 16 2026 16:45:05
%S A395741 1,2,4,4,12,12,36,72,72,72,192,192,1080,1080,1080,3360,27120,28800,
%T A395741 65520,65520,65520,65520,306000,306000,306000,306000,306000,388080,
%U A395741 388080,388080,3109680,11592000,14313600,14313600,14313600,14313600,14313600,57002400
%N A395741 a(n) is the smallest positive integer m such that m mod k < k/2 for each 1 <= k <= n.
%C A395741 Define the following operation: For a nonnegative integer V, pick an integer 1 <= j <= n, and replace V with j * round(V/j). a(n) is the largest integer that can be reached by a finite number of operations, starting from 1.
%C A395741 Problem 2 of the 2026 European Girls' Mathematical Olympiad (EGMO) proves that for any m >= 2, there exists an integer N such that for any n >= N, a(n) is divisible by m. In fact, N = m*(m - 1) satisfies the condition.
%H A395741 Michael S. Branicky, <a href="/A395741/b395741.txt">Table of n, a(n) for n = 1..65</a>
%H A395741 Art of Problem Solving, <a href="https://artofproblemsolving.com/community/c6h3813854p37794785">European Girls' Mathematical Olympiad 2026 Problem 2</a>
%H A395741 Yifan Xie, <a href="/A395741/a395741.py.txt">Python program</a>
%F A395741 A003418(A000194(n+1)) <= a(n) <= A003418(n).
%F A395741 a(n+1) >= a(n). - _Michael S. Branicky_, May 11 2026
%e A395741 For n = 5, a(5) = 12 because 12 mod 1 = 0 < 1/2, 12 mod 2 = 0 < 2/2, 12 mod 3 = 0 < 3/2, 12 mod 4 = 0 < 4/2, 12 mod 5 = 2 < 5/2, and numbers less than 12 do not satisfy the conditions.
%t A395741 a[n_]:=Module[{m=1},While[!AllTrue[Range[n],Mod[m,#]<#/2 &],m++]; m]; Array[a,30] (* _Stefano Spezia_, May 09 2026 *)
%o A395741 (Python) # See links.
%o A395741 (Python)
%o A395741 from itertools import count
%o A395741 def a(n): return next(m for m in count(1) if all(m%k < (k+1)>>1 for k in range(1, n+1)))
%o A395741 print([a(n) for n in range(1, 31)]) # _Michael S. Branicky_, May 09 2026
%o A395741 (Python) # faster for initial segment of sequence
%o A395741 from itertools import count, islice
%o A395741 def agen(): # generator of terms
%o A395741     an = 1
%o A395741     for n in count(2):
%o A395741         yield an
%o A395741         an = next(m for m in count(an) if all(m%k < (k+1)>>1 for k in range(1, n+1)))
%o A395741 print(list(islice(agen(), 30))) # _Michael S. Branicky_, May 09 2026
%o A395741 (PARI) isok(m, n) = if (#select(x->x>=0, vector(n, k, (m % k) - k/2)), 0, 1);
%o A395741 a(n) = my(m=1); while(!isok(m, n), m++); m; \\ _Michel Marcus_, May 09 2026
%Y A395741 Cf. A003418.
%K A395741 nonn
%O A395741 1,2
%A A395741 _Yifan Xie_, May 05 2026
