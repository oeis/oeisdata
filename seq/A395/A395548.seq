%N A395548 Numbers k such that sigma(k) = psi(k) + tau(k)^6 + Omega(k)^6.
%C A395548 Contains 2840557*p^2 for prime p where gcd(2840557, p) = 1. Hence the sequence is infinite. - _David A. Corneth_, Apr 28 2026
%e A395548 11362228 is a term since sigma(11362228) = 20930560 = 17940480 + 12^6 + 4^6 = psi(11362228) + tau(11362228)^6 + Omega(11362228)^6.
%o A395548 (PARI) isok(k) = {my(f = factor(k)); sigma(f) == prod(i=1, #f~, (f[i, 1]+1) * f[i, 1]^(f[i, 2]-1)) + numdiv(f)^6 + bigomega(f)^6; } \\ _Amiram Eldar_, Apr 28 2026
