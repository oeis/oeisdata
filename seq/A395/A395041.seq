%T A395041 6469693230,0,10,31,510510,4,10,0,32,4,30032,0,7420738134810,0,6,2312,
%U A395041 12,0,34,31,10,8,33,0,8,4,9699692,211,6469693230,0,9699692,0,212,30032,8,5,1922760350154212639070,0,7,2311,32589158477190044730
%N A395041 a(n) = A276085(A003415(n)), where A003415 is the arithmetic derivative and A276085 is fully additive with a(p) = p#/p.
%H A395041 Antti Karttunen, <a href="/A395041/b395041.txt">Table of n, a(n) for n = 2..2309</a>
%o A395041 (PARI)
%o A395041 A003415(n) = if(n<=1, 0, my(f=factor(n)); n*sum(i=1, #f~, f[i, 2]/f[i, 1]));
%o A395041 A276085(n) = { my(f=factor(n)); sum(k=1, #f~, f[k, 2]*prod(i=1,primepi(f[k, 1]-1),prime(i))); };
%o A395041 A395041(n) = A276085(A003415(n));
%Y A395041 Cf. A003415, A276085, A393048, A393049, A395040.
%K A395041 nonn,new
%O A395041 2,3
