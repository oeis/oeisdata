%N A395146 Square array A(n,k), n>=0, k>=0, read by antidiagonals downwards, where A(n,k) = (2*n)! * [x^(2*n)] C(x)^k and C(x) satisfies C(x) = cosh( Integral C(x)^4 dx ).
%F A395146 A(0,k) = 1 and A(n,k) = k*(k+4) * A(n-1,k+8) - k*(k+3) * A(n-1,k+6) for n > 0.
%e A395146 Square array begins:
%e A395146   1,        1,        1,        1,         1,         1, ...
%e A395146   0,        1,        2,        3,         4,         5, ...
%e A395146   0,       17,       40,       69,       104,       145, ...
%e A395146   0,      865,     2240,     4215,      6880,     10325, ...
%e A395146   0,    88865,   246400,   494025,    855680,   1357825, ...
%e A395146   0, 15335425, 44844800, 94528875, 171673600, 284963525, ...
%o A395146 (PARI) a(n, k) = if(n==0, 1, k*(k+4)*a(n-1, k+8)-k*(k+3)*a(n-1, k+6));
%Y A395146 Columns k=0..5 give A000007, A281428, A052502, A395147, A281430, A281427(n+1).
%Y A395146 Cf. A395141, A395148.
%K A395146 nonn,tabl,new
%O A395146 0,8
