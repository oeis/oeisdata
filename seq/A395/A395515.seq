%T A395515 480,508,573,575,594,594,772,850,888,954,938,984,1053,1133,1111,1287,
%U A395515 1255,1218,1386,1369,1582,1658,1883,1767,1827,2068,2133,2043,2171,2352,2568,2585,2703,2667,2855,2855,2875,3171,3196
%N A395515 Sum of the distinct prime divisors of C(4*n, n).
%H A395515 Vincenzo Librandi, <a href="/A395515/b395515.txt">Table of n, a(n) for n = 1..1000</a>
%F A395515 a(n) = sopf(binomial(4*n,n)) = A008472(A005810(n)).
%e A395515 a(2) = 9 because binomial(8,2) = 28 = 2^2*7 and 2+7 = 9.
%e A395515 a(3) = 18 because binomial(12,3) = 220 = 2^2*5*11 and 2+5+11 = 18.
%p A395515 a:= n-> add(i[1], i=ifactors(binomial(4*n, n))[2]):
%p A395515 seq(a(n), n=1..58);  # _Alois P. Heinz_, Apr 27 2026
%t A395515 a[n_]:=Total[FactorInteger[Binomial[4 n,n]][[All,1]]]; Table[a[n],{n,1,80}]
%o A395515 (Magma) a := func<n | &+PrimeDivisors(Binomial(4*n, n))>; N := 70; [a(n) : n in [1..N]];
%o A395515 (PARI) a(n)=vecsum(factor(binomial(4*n,n))[,1]) \\ _Charles R Greathouse IV_, Apr 27 2026
%o A395515 (Python)
%o A395515 from collections import Counter
%o A395515 from sympy import factorint
%o A395515 def A395515(n):
%o A395515     c = Counter()
%o A395515     for i in range(3*n+1,4*n+1):
%o A395515         c += factorint(i)
%o A395515     for i in range(2,n+1):
%o A395515         c -= factorint(i)
%o A395515     return sum(c) # _Chai Wah Wu_, Apr 30 2026
%Y A395515 Cf. A008472, A005810, A394454, A394591, A394592, A394593, A034387.
%K A395515 nonn,new
