%I A395345 #10 Apr 20 2026 07:03:24
%S A395345 1,0,1,0,1,1,0,2,3,1,0,7,11,6,1,0,34,55,35,10,1,0,213,349,240,85,15,1,
%T A395345 0,1630,2695,1939,770,175,21,1,0,14747,24527,18186,7749,2030,322,28,1,
%U A395345 0,153946,257175,194795,87066,24969,4662,546,36,1,0,1821473,3053041,2349660,1087085,331905,68943,9660,870,45,1
%N A395345 Triangle read by rows: T(n, k) = k * T(n, k+1) + T(n-1, k-1) - (n-k-1) * T(n-1, k) with T(n, 0) = 0^n, T(n, k) = 0 for k < 0 or k > n.
%H A395345 Tomasz Kania, <a href="https://mathoverflow.net/a/510473">Closed form for certain integer coefficients based on A075856 using A291980</a>, answer to question on MathOverflow, 2026.
%F A395345 Due to Tomasz Kania: (Start)
%F A395345 T(n,k) = Sum_{j=0..n-k} (-1)^(n+k+j) * binomial(n+j-1, k-1) * A075856(n-k,j).
%F A395345 T(n+1, k+1) = Sum_{j=k..n} T(n, j) * A291980(j, k).
%F A395345 E.g.f. for column k: A(x)^k / k! where A(x) = Sum_{n>=0} A074059(n) * x^n / n! such that x = 2 * A(x) - (1 + A(x)) * log(1 + A(x)). (End)
%e A395345 Triangle begins:
%e A395345   1;
%e A395345   0,      1;
%e A395345   0,      1,      1;
%e A395345   0,      2,      3,      1;
%e A395345   0,      7,     11,      6,     1;
%e A395345   0,     34,     55,     35,    10,     1;
%e A395345   0,    213,    349,    240,    85,    15,    1;
%e A395345   0,   1630,   2695,   1939,   770,   175,   21,   1;
%e A395345   0,  14747,  24527,  18186,  7749,  2030,  322,  28,  1;
%e A395345   0, 153946, 257175, 194795, 87066, 24969, 4662, 546, 36, 1;
%p A395345 T := proc(n, k) option remember; if n = k then 1 elif k <= 0 or k > n then 0 else
%p A395345 k * T(n, k+1) + T(n-1, k-1) - (n-k-1) * T(n-1, k) fi end:
%p A395345 for n from 0 to 9 do seq(T(n, k), k = 0..n) od;  # _Peter Luschny_, Apr 20 2026
%o A395345 (PARI) rows(n) = my(v1 = vector(n+1, i, vector(i, j, 0))); for(i=0, n, v1[i+1][i+1] = 1; forstep(j=i-1, 1, -1, v1[i+1][j+1] = j*v1[i+1][j+2] + v1[i][j] - (i-j-1)*v1[i][j+1])); v1
%Y A395345 Cf. A074059, A075856, A291980.
%K A395345 nonn,tabl,easy,new
%O A395345 0,8
%A A395345 _Mikhail Kurkov_, Apr 20 2026
