%N A395332 Smallest n-digit base-3 deletable prime.
%C A395332 A base-3 deletable prime is a prime whose base-3 representation can be reduced to the single-digit prime 2 by deleting one digit at a time, without ever creating a leading zero, so that every intermediate value is prime. a(n) is the smallest such prime with exactly n digits in base 3. This is the base-3 analog of A125589 (base 10).
%H A395332 Daniel Okwor, <a href="/A395332/b395332.txt">Table of n, a(n) for n = 1..35</a>
%e A395332 a(2) = 5: in base 3, 5 is written 12; deleting the digit 1 leaves 2, which is prime.
%e A395332 a(5) = 83: in base 3, 83 is written 10002; the deletions 10002 -> 1002 -> 102 -> 12 -> 2 (base 3) correspond to the primes 83, 29, 11, 5, 2.
%o A395332 (Python)
%o A395332 from sympy import isprime
%o A395332 def to3(n):
%o A395332     s=""
%o A395332     while n: s=str(n%3)+s; n//=3
%o A395332     return s
%o A395332 def deletable(p):
%o A395332     s=to3(p)
%o A395332     if len(s)==1: return isprime(p)
%o A395332     for i in range(len(s)):
%o A395332         t=s[:i]+s[i+1:]
%o A395332         if t[0]=="0": continue
%o A395332         v=int(t,3)
%o A395332         if isprime(v) and deletable(v): return True
%o A395332     return False
%o A395332 def a(n):
%o A395332     for p in range(3**(n-1), 3**n):
%o A395332         if isprime(p) and deletable(p): return p
%o A395332 print([a(n) for n in range(1,12)])
%Y A395332 Cf. A096236, A125589, A125590, A305352, A395333.
