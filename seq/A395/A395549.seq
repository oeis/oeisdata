%I A395549 #33 May 03 2026 19:16:42
%S A395549 2,3,0,8,1,8,10,7,12,6,20,40,21,41,10,56,8,65,38,64,66,61,7,57,4,86,
%T A395549 12,105,7,34,5,21,4,90,148,129,100,110,7,72,57,170,83,28,136,34,93,10,
%U A395549 161,130,66,84,58,140,85,177,198,196,31,16,92
%N A395549 a(n) = E_p mod p, where p = prime(n) and E_p = [z^(p-1)] exp(Sum_{j=1..p-2} z^j/(j*(j+1))).
%C A395549 The coefficient E_p := [z^(p-1)] exp(Sum_{j=1..p-2} z^j/(j*(j+1))) belongs to Z_(p) (p-adic integers) for any odd prime p. This sequence gives its reduction modulo p.
%C A395549 E_p arises in the p-adic expansion of S_{p^k - 1}, where S_r := [z^r] f(z) and f(z) = e * (1-z)^(1/z - 1) = exp(Sum_{n>=1} z^n / (n*(n+1))). For all k >= 1 and all odd primes p, the closed-form p^(D_k*) * S_{p^k - 1} == (-1)^(k(3-k)/2) * (1 + p*((k-1)*W_p - (k-2) - E_p)) (mod p^2) holds, where D_k* = Sum_{j=0..k-1} (k-j)*p^j and W_p is the Wilson quotient.
%C A395549 The only prime p <= 200 with E_p == 0 (mod p), an "E-prime" by analogy with Wilson primes, is p = 7.
%H A395549 David Niedbala Giraudin, <a href="https://doi.org/10.5281/zenodo.19796004">The p-adic expansion of S_{p^k-1}: theorems mod p^2 and mod p^3, combinatorial invariants E_p and F_p</a>, Zenodo (2026).
%F A395549 a(n) = E_{prime(n)} mod prime(n), where E_p = [z^(p-1)] exp(Sum_{j=1..p-2} z^j/(j*(j+1))).
%e A395549 For n=2, prime(2) = 3 and E_3 = [z^2] exp(z/2) = 1/8. Since 1/8 == 8^(-1) == 2 (mod 3), a(2) = 2.
%e A395549 For n=3, prime(3) = 5 and E_5 = [z^4] exp(z/2 + z^2/6 + z^3/12) = 79/192. Since 79*192^(-1) == 4*2 == 3 (mod 5), a(3) = 3.
%o A395549 (PARI) a(n) = my(p=prime(n), s=sum(j=1, p-2, z^j/(j*(j+1)) + O(z^p))); polcoef(exp(s), p-1) % p;
%o A395549 (Python)
%o A395549 from fractions import Fraction
%o A395549 from sympy import prime
%o A395549 def A395549(n):
%o A395549     p = prime(n)
%o A395549     if p == 2: return None
%o A395549     h = [Fraction(0)]*p
%o A395549     for j in range(1, p-1):
%o A395549         h[j] = Fraction(1, j*(j+1))
%o A395549     E = [Fraction(0)]*p
%o A395549     E[0] = Fraction(1)
%o A395549     for m in range(1, p):
%o A395549         s = Fraction(0)
%o A395549         for k in range(1, m+1):
%o A395549             s += k*h[k]*E[m-k]
%o A395549         E[m] = s/m
%o A395549     Ep = E[p-1]
%o A395549     return (Ep.numerator * pow(Ep.denominator, -1, p)) % p
%Y A395549 Cf. A007540 (Wilson primes), A007619 (Wilson quotients).
%K A395549 nonn,new
%O A395549 2,1
%A A395549 _David Niedbala Giraudin_, Apr 28 2026
