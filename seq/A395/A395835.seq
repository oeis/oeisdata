%I A395835 #48 May 18 2026 10:18:28
%S A395835 3,5,8,11,14,17,21,25,30,35,40,45,51,56,62,69,76,82,90,97,105,113,121,
%T A395835 129,138,147,156,165,175,185,195,205,216,227,238,249,260,272,284,296,
%U A395835 309,321,334,347,360,374,388,401,416,430,444,459,474,489,505,520,536,552,569,585,602,619,636,653,670
%N A395835 Define F(n,x) as the power series in x satisfying F(n,x) = 1 + x*F(n,x)^2 - x^n*F(n,x)^(2*n), then for n >= 2, a(n) = M where x^M is the first power of x with a negative coefficient in F(n,x). Should no such M exist for some n, then there are no further terms and this sequence would be finite.
%C A395835 Conjecture: this sequence is infinite.
%C A395835 Compare to A060432, the partial sums of A002024.
%H A395835 Paul D. Hanna, <a href="/A395835/b395835.txt">Table of n, a(n) for n = 2..153</a>
%F A395835 Given F(n,x) = 1 + x*F(n,x)^2 - x^n*F(n,x)^(2*n), then we have the following.
%F A395835 (1) [x^a(n)] F(n,x) = -A395836(n) for n >= 2.
%F A395835 (2) [x^(a(n)-1)] F(n,x) = A395837(n) for n >= 2.
%F A395835 (3) a(n+1) - a(n) = A395838(n) for n >= 2.
%F A395835 (4) F(n,x) = sqrt( (1/x)*Series_Reversion( x/(1 + x - x^n)^2 ) ).
%F A395835 (5) lim_{n->oo} F(n,x) = C(x) where C(x) = 1 + x*C(x)^2 is the g.f. of the Catalan numbers (A000108).
%e A395835 The first few power series F(n,x) satisfying
%e A395835 F(n,x) = 1 + x*F(n,x)^2 - x^n*F(n,x)^(2*n)
%e A395835 begin
%e A395835 F(2,x) = 1 + x + x^2 + (-1*x^3) - 10*x^4 - 33*x^5 - 55*x^6 + 65*x^7 + 842*x^8 + ...
%e A395835 F(3,x) = 1 + x + 2*x^2 + 4*x^3 + 6*x^4 + (-3*x^5) - 82*x^6 - 481*x^7 - 2098*x^8 + ...
%e A395835 F(4,x) = 1 + x + 2*x^2 + 5*x^3 + 13*x^4 + 32*x^5 + 66*x^6 + 65*x^7 + (-382*x^8) - 3553*x^9 - 20254*x^10 + ...
%e A395835 F(5,x) = 1 + x + 2*x^2 + 5*x^3 + 14*x^4 + 41*x^5 + 120*x^6 + 338*x^7 + 870*x^8 + 1802*x^9 + 1302*x^10 + (-15596*x^11) - 135056*x^12 + ...
%e A395835 F(6,x) = 1 + x + 2*x^2 + 5*x^3 + 14*x^4 + 42*x^5 + 131*x^6 + 415*x^7 + 1310*x^8 + 4046*x^9 + 11951*x^10 + 32452*x^11 + 73428*x^12 + 85425*x^13 + (-428751*x^14) - 4557495*x^15 + ...
%e A395835 From the above examples we can see that a(n) gives the power of x at which the first negative coefficient is found in F(n,x):
%e A395835 a(2) = 3 since first negative term in F(2,x) is -1*x^3,
%e A395835 a(3) = 5 since first negative term in F(3,x) is -3*x^5,
%e A395835 a(4) = 8 since first negative term in F(4,x) is -382*x^8,
%e A395835 a(5) = 11 since first negative term in F(5,x) is -15596*x^11, and
%e A395835 a(6) = 14 since first negative term in F(6,x) is -428751*x^14.
%e A395835 RELATED SEQUENCES.
%e A395835 The absolute value of the first negative coefficient in F(n,x) is given by A395836(n), and the coefficient of x^(a(n)-1) in F(n,x) is given by A395837(n).
%e A395835 The first differences of this sequence are
%e A395835 A395838 = [3, 2, 3, 3, 3, 3, 4, 4, 5, 5, 5, 5, 6, 5, 6, 7, 7, 6, 8, 7, 8, 8, 8, 8, 9, 9, 9, 9, 10, 10, 10, 10, 11, 11, 11, 11, 11, 12, 12, 12, 13, 12, 13, 13, 13, 14, 14, 13, 15, 14, 14, 15, 15, 15, 16, 15, 16, 16, 17, 16, 17, 17, 17, 17, 17, 18, 18, 18, 18, 19, 19, 18, 20, 19, 19, 20, 20, 20, 20, 21, ...].
%o A395835 (PARI) \\ Print power of x with first negative coefficient in F(n,x).
%o A395835 \\ Routine FNEG(F) finds the first negative coefficient in F,
%o A395835 \\ but returns "?" if none are found:
%o A395835 {FNEG(F) = my(N="?"); for(n=1,#F-1, if(polcoef(F,n)<0, N=n; break)); N}
%o A395835 \\ The following code prints the initial 70 terms in 2 minutes,
%o A395835 \\ the last 5 terms of which take about 30 seconds to compute.
%o A395835 \\ For more terms, a more efficient process is needed; e.g.,
%o A395835 \\ a(200) = 4729 took an hour to compute using this code.
%o A395835 \\ MAX(n) = 2*n^(3/2) is an approximation of growth for a(n)
%o A395835 \\ used to reduce run-time and may need correction for larger n.
%o A395835 {MAX(n) = ceil(2*n^(3/2))}
%o A395835 {for(n=2,70, F = sqrt((1/x)*serreverse(x/(1 + x - x^n  +O(x^MAX(n)) )^2 )); print1(FNEG(F),", "))}
%Y A395835 Cf. A395836, A395837, A395838, A000108, A060432.
%K A395835 nonn,new
%O A395835 2,1
%A A395835 _Paul D. Hanna_, May 14 2026
