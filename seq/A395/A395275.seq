%N A395275 a(n) = (2*n)! * [x^(2*n)] cos(x) * cos(sqrt(2)*x) / cos(2*x).
%F A395275 a(n) = (-1)^n * A001541(n) - Sum_{k=0..n-1} (-4)^(n-k) * binomial(2*n,2*k) * a(k).
%F A395275 a(n) ~ cos(Pi/2^(3/2)) * 2^(6*n + 5/2) * n^(2*n + 1/2) / (sqrt(Pi) * exp(2*n) * Pi^(2*n)). - _Vaclav Kotesovec_, Apr 18 2026
%t A395275 nmax = 20; CoefficientList[Series[Cos[Sqrt[x]] * Cos[Sqrt[2*x]] / Cos[2*Sqrt[x]], {x, 0, nmax}], x] * (2*Range[0, nmax])! (* _Vaclav Kotesovec_, Apr 18 2026 *)
%o A395275 (PARI) a001541(n) = polchebyshev(n, 1, 3);
%o A395275 a_vector(n) = my(v=vector(n+1)); for(i=0, n, v[i+1]=(-1)^i*a001541(i)-sum(j=0, i-1, (-4)^(i-j)*binomial(2*i, 2*j)*v[j+1])); v;
%Y A395275 Cf. A001541, A395276.
