%I A395143 #41 May 15 2026 17:12:50
%S A395143 3,6,7,11,12,14,15,19,22,23,24,27,28,30,31,35,38,39,43,44,45,46,47,48,
%T A395143 51,54,55,56,59,60,62,63,67,70,71,75,76,78,79,83,86,87,88,89,90,91,92,
%U A395143 93,94,95,96,99,102,103,107,108,110,111,112,115,118,119,120
%N A395143 Numbers with no representation as the quotient of two fibbinary numbers (A003714).
%C A395143 For each individual n, it is easy to check whether n has a representation using Walnut.
%C A395143 For example, for n = 99 one can write
%C A395143   reg has11 msd_2 "(0|1)*11(0|1)*":
%C A395143   def no11 "~$has11(n)":
%C A395143   eval test99 "Ea,b $no11(a) & $no11(b) & b>=1 & a=99*b":
%C A395143 To test other numbers, just replace 99 with n in two places.  Walnut returns TRUE if there is a representation and FALSE otherwise.
%C A395143 Meleshko has a conjectured characterization of the members of this sequence, but as of 2026 it has not been proved.
%H A395143 J. V. F. Meleshko, <a href="http://hdl.handle.net/10012/18952">Automata and ratio sets</a>, Master's thesis, University of Waterloo, 2022.
%Y A395143 Cf. A003714, A396006, A396007, A396008.
%K A395143 nonn,new
%O A395143 1,1
%A A395143 _Jeffrey Shallit_, May 13 2026
