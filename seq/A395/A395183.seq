%T A395183 42,4,4,11,7,34,13,19,91,3,3,3,11,8,13,26,5,12,7,7,9,11,15,21,41,21,2,
%U A395183 2,2,2,11,9,158,7,12,17,5,13,8,11,16,91,3,3,3,15
%N A395183 a(n) is the least positive integer k such that k*n has a decimal expansion with exactly two nonzero digits with one or more zeros between them and any number of trailing zeros. If no such number exists, then a(n) = 0.
%C A395183 a(111) is the first unproven term (see zeros in linked a-file). - _Michael S. Branicky_, Apr 15 2026
%H A395183 Michael S. Branicky, <a href="/A395183/b395183.txt">Table of n, a(n) for n = 0..110</a>
%H A395183 Michael S. Branicky, <a href="/A395183/a395183_1.txt">Table of n, a(n) for n = 0..10000</a> (terms where a(n) has more than 1000 digits, if it exists, are entered as 0)
%e A395183 a(9) = 12 because 12*9 = 108 where we have a zero between two nonzero digits.
%o A395183 (Python)
%o A395183 from itertools import count
%o A395183 def bgen():
%o A395183     for L in count(3):
%o A395183         for d1 in range(1, 10):
%o A395183             base = d1*10**(L-1)
%o A395183             for i in range(L-2):
%o A395183                 for d2 in range(1, 10):
%o A395183                     yield base + d2*10**i
%o A395183 def a(n):
%o A395183     return next(m//n for m in bgen() if m%n == 0) if n else 0
%o A395183 print([a(n) for n in range(111)])
%K A395183 nonn,base,new
%O A395183 0,2
%A A395183 _Michael S. Branicky_ and _Ali Sada_, Apr 15 2026
