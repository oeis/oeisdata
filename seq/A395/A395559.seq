%N A395559 1 = Sum_{n>=0} a(n) * x^n * (1 - (2*n+1)*x)^3.
%F A395559 a(n) = 3*(2*n - 1)*a(n-1) - 3*(2*n - 3)^2*a(n-2) + (2*n - 5)^3*a(n-3).
%t A395559 RecurrenceTable[{-(2*n-5)^3*a[n-3] + 3*(2*n-3)^2*a[n-2] - 3*(2*n-1)*a[n-1] + a[n] == 0, a[1]==3, a[2]==24, a[3]==280}, a, {n, 0, 20}]
%o A395559 (PARI) {a(n)=polcoeff(1-sum(m=0, n-1, a(m)*x^m*(1-(2*m+1)*x+x*O(x^n))^3), n)}
%o A395559 for(n=0, 25, print1(a(n), ", "))
