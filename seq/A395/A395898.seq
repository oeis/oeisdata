%U A395898 5142500,5142500,5142500,80061344,80061344,80061344,80061344,80061344,80061344,3463199999,3463199999
%N A395898 Largest k such that k*(k+1)/2 divide n!.
%e A395898 a(4) = 3, as A000217(3) = 6 is the largest term of A000217 dividing 4! = 24.
%t A395898 a[n_] := Module[{d = Divisors[n!], i}, i = Length[d]; While[!IntegerQ[Sqrt[8*d[[i]] + 1]], i--]; (Sqrt[8*d[[i]] + 1] - 1)/2]; Array[a, 20] (* _Amiram Eldar_, May 09 2026 *)
%o A395898 (PARI) a(n)=my(u=[],f=n!,t=1,k=1,kmax=1);while(t<=f,if(f%t==0,kmax=k);k++;t=k*(k+1) /2);kmax
%o A395898 (PARI) a(n) = my(f = n!, dd); fordiv(f, d, dd = f/d; if(issquare(8*dd + 1), return((sqrtint(8*dd + 1) - 1)/2))); \\ _Amiram Eldar_, May 09 2026
%o A395898 (Python)
%o A395898 from math import isqrt, factorial
%o A395898 from sympy import divisors
%o A395898 from sympy.ntheory.primetest import is_square
%o A395898 def A395898(n): return next(isqrt((d<<3)+1)>>1 for d in reversed(divisors(factorial(n))) if is_square((d<<3)+1)) # _Chai Wah Wu_, May 09 2026
