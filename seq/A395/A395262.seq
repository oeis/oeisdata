%o A395262 A_xy(N) = {my(x='x+O('x^(N+1)), A=1); for(i=1, N, A = sum(j=0,N, (x^tri(j) * y^j * A^j)/prod(k=1,j, (1 - x^k*y*A)))); vector(N, n, Vecrev(polcoeff(A, n-1)))}
