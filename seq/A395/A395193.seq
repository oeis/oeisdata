%S A395193 1,3,6,10,66,253,703,1176,2016,12880,49141,136503,228150,391170,
%T A395193 2498730,9533161,26481003,44259936,75885040,484740816,1849384153,
%U A395193 5137178203,8586199446,14721306666,94037219650,358770992581,996586090503,1665678432600,2855857608240,18242735871360,69599723176621
%N A395193 Area of the n-th convex polyiamond formed by winding spirals of incrementing strips of polyiamonds.
%C A395193 In a regular triangular grid, begin with a single central triangle. Wrap strips (polyiamonds) of incrementally more triangles (strip of 2, then 3, etc.) tightly around the center such that they are connected at their start and end to the previous and subsequent strips. If a strip's endpoint completes a convex aggregate of triangles with all of those before it (i.e., the boundary of the construction is its own convex hull), the number of triangles in the construction is a term of this sequence.
%C A395193 Intersection of the triangular numbers (A000217) and A069813. The latter is the maximal areas of polyiamonds of a given perimeter and represent the convex bounding boxes in our geometric construction.
%H A395193 Brandan Williams, <a href="https://achromath.substack.com/p/pelliamonds">Pelliamonds</a>
%H A395193 <a href="/index/Rec#order_15">Index entries for linear recurrences with constant coefficients</a>, signature (0,0,0,0,195,0,0,0,0,-195,0,0,0,0,1).
%F A395193 a(n) = 195*(a(n-5) - a(n-10)) + a(n-15). - _Brandan Williams_, May 27 2026
%e A395193 The first term is trivial, as it represents a single triangle. So a(1) = 1.
%e A395193 Adding a strip of two triangles forms half of a regular hexagon (a trapezoid containing three regular triangles) which is convex, with 3 total triangles included. a(2) = 3.
%e A395193 Adding a strip of three triangles completes the regular hexagon, which is convex. a(3) = 6.
%e A395193 Adding a strip of four triangles effectively attaches a chevron shaped polyiamond to the regular hexagon, which retains convexity. a(4) = 10.
%e A395193 Adding a strip of five triangles effectively forms the first concave shape in this construction, as it exceeds the next smallest concave boundary (13) by two triangles and falls short of the next largest concave boundary (16) by one triangle.
%e A395193 The next concave polyiamond construction does not occur until the strip of length 11 is added. a(5) = 66.
%o A395193 (R)
%o A395193 # This generates and displays the first 20 examples
%o A395193 # along with the index of A000217 and A069813
%o A395193 generate_triangular_number <- function(n){
%o A395193     return((n^2+n)/2)
%o A395193 }
%o A395193 generate_maximalpolyiamond_number <- function(n){
%o A395193     return(round((n+2)^2/6) - as.numeric(((n+2) %% 6) != 0))
%o A395193 }
%o A395193 tri_i <- 1
%o A395193 poly_i <- 1
%o A395193 n_matches <- 0
%o A395193 while(n_matches < 20){
%o A395193     if(generate_triangular_number(tri_i) == generate_maximalpolyiamond_number (poly_i)){
%o A395193         n_matches <- n_matches + 1
%o A395193         print(c(n_matches, tri_i, poly_i, generate_triangular_number(tri_i)))
%o A395193         tri_i <- tri_i + 1
%o A395193         poly_i <- poly_i + 1
%o A395193     } else{
%o A395193         if(generate_triangular_number(tri_i) > generate_maximalpolyiamond_number (poly_i)){
%o A395193             poly_i <- poly_i + 1
%o A395193         } else{
%o A395193             tri_i <- tri_i + 1
%o A395193         }
%o A395193     }
%o A395193 }
%o A395193 (PARI) select(x->ispolygonal(x,3), Vec(x^3*(x^2-x-1)*(x^2+1)/((x-1)^3*(x+1)*(x^2+x+1)) + O(x^10^8))) \\ _Michel Marcus_, May 16 2026
%Y A395193 Cf. A000217, A069813.
%K A395193 nonn,easy,changed
%O A395193 1,2
%A A395193 _Brandan Williams_, May 14 2026
%E A395193 More terms from _Michel Marcus_, May 16 2026
