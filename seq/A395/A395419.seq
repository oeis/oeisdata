%S A395419 12,17,23,26,30,34,37,43,51,55,56,61,66,67,69,75,77,78,79,84,87,91,93,
%T A395419 99,100,102,106,107,108,110,111,114,115,118,122,123,127,130,132,138,
%U A395419 142,147,151,154,155,156,157,159,164,177,178,180,183,186,187,190,198,199,202,205
%N A395419 Numbers k = x + y, such that sigma(x) + sigma(y) = 2*(x+y).
%C A395419 It appears that the even terms are twice A383268. - _Michel Marcus_, Apr 23 2026
%e A395419 12 can be split into two parts, 6 + 6, and sigma(6) and sigma(6) give 12 + 12 = 24, which is 2*(6 + 6). Thus 12 is in this list.
%e A395419 467 can be split into two parts, 3 and 464, sigma(3) and sigma(464) give 4 + 930 = 934, which is 2*(3 + 464). Thus 467 is in this list.
%t A395419 s[k_] := s[k] = DivisorSigma[1, k]; q[k_] := AnyTrue[Range[1, k-1], s[#] + s[k-#] == 2*k &]; Select[Range[205], q] (* _Amiram Eldar_, Apr 22 2026 *)
%o A395419 (PARI) isok(k) = sum(x=1, k-1, sigma(x) + sigma(k-x) == 2*k) >= 1; \\ _Michel Marcus_, Apr 22 2026
%Y A395419 Cf. A000203, A383268, A395420.
%K A395419 nonn,new
