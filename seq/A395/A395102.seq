%S A395102 3,5,7,17,11,13,29,19,41,23,53,31,67,37,79,43,89,47,97,59,61,127,71,
%T A395102 73,149,83,173,101,103,211,107,109,223,113,229,131,269,137,139,281,
%U A395102 151,307,157,317,163,331,167,337,179,181,367,191,193,389,197,199,401
%N A395102 a(1) = 3; a(n) is the smallest odd prime not occurring earlier so that a(n) mod a(n-1) is prime.
%C A395102 2 cannot be on the list as all numbers are 0 or 1 mod 2, neither of which is prime.
%C A395102 There are three ways that the next term may be generated. If there is at least an odd prime < a(n) not on the list, a(n+1) is the smallest among them. Otherwise, if a(n)+2 is prime and not on the list, a(n+1) = a(n)+2. Otherwise, a(n+1) takes the form 2*k*a(n)+p with prime p. It is conjectured that k is always 1, which has been confirmed until n = 10000.
%C A395102 Because of the first generation step, this is a permutation of A065091.
%H A395102 Hoang Nguyen, <a href="/A395102/b395102.txt">Table of n, a(n) for n = 1..10000</a>
%e A395102 a(2) = 5 as 5 is prime and 5 mod 3 = 2 is prime.
%e A395102 a(4) = 17 as 17 is prime and 17 mod 7 = 3 is prime.
%e A395102 a(5) = 11 as 11 is prime and 11 mod 17 = 11 is prime.
%t A395102 a[n_] := a[n] = Module[{ps = Array[a, n - 1], p = 5}, While[MemberQ[ps, p] || !PrimeQ[Mod[p, a[n - 1]]], p = NextPrime[p]]; p]; a[1] = 3; Array[a, 57] (* _Amiram Eldar_, May 21 2026 *)
%o A395102 (Julia)
%o A395102 using Primes
%o A395102 function a(n)
%o A395102     prime = [3]
%o A395102     print("3, ")
%o A395102     for _ in 1:n-1
%o A395102         num = 3
%o A395102         while true
%o A395102             num += 2
%o A395102             if isprime(num) && isprime(num % prime[end]) && !(num in prime)
%o A395102                 push!(prime, num)
%o A395102                 print("$num, ")
%o A395102                 break
%o A395102             end
%o A395102         end
%o A395102     end
%o A395102 end
%o A395102 (Python)
%o A395102 from itertools import count, islice
%o A395102 from sympy import isprime, nextprime, sieve
%o A395102 def agen(): # generator of terms
%o A395102     an, nextp, seen = 3, 5, set()
%o A395102     while True:
%o A395102         yield an
%o A395102         seen.add(an)
%o A395102         while nextp in seen: nextp = nextprime(nextp)
%o A395102         if nextp < an: an = nextp
%o A395102         elif an+2 not in seen and isprime(an+2): an += 2
%o A395102         else: an = next(m for k in count(1) for p in sieve.primerange(3, an) if (m:=2*k*an+p) not in seen and isprime(m))
%o A395102 print(list(islice(agen(), 57))) # _Michael S. Branicky_, May 21 2026
%Y A395102 Cf. A065091, A001097, A020484.
