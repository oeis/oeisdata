%I A395529 #28 May 17 2026 20:04:47
%S A395529 1,479,958,1559,1679,1916,2297,2419,2927,2971,2999,3071,3118,3358,
%T A395529 3499,3733,3832,4309,4594,4677,4793,4838,5037,5461,5539,5683,5711,
%U A395529 5854,5942,5998,6043,6142,6236,6998,7321,7466,7531,7619,7669,7795,7981,8191,8399,8618,8711,8909
%N A395529 Numbers k such that k cannot be written as m + t where m*t belongs to A055932.
%C A395529 Also numbers k such that k^2 - 4*t is never a square for any t in A055932. - _David A. Corneth_, May 12 2026
%H A395529 David A. Corneth, <a href="/A395529/b395529.txt">Table of n, a(n) for n = 1..10000</a> (first 267 terms from Zhicheng Wei)
%p A395529 filter:= proc(k) local m,v,F;
%p A395529   for m from 1 to k/2 do
%p A395529     v:= m*(k-m);
%p A395529     F:= NumberTheory:-PrimeFactors(v);
%p A395529     if NumberTheory:-pi(max(F)) = nops(F) then return false fi;
%p A395529   od;
%p A395529 true
%p A395529 end proc:
%p A395529 filter(2):= false:
%p A395529 select(filter, [$1..10000]); # _Robert Israel_, Apr 27 2026
%o A395529 (PARI)
%o A395529 A055932(n)=my(f=factor(n)[, 1]~); f==primes(#f)
%o A395529 is(n)=sum(k=1,n/2,A055932(k*(n-k)))==0
%o A395529 select(is, [1..4000])
%o A395529 (Python)
%o A395529 from itertools import count, islice
%o A395529 from sympy import primefactors, prime
%o A395529 def A395529_gen(startvalue=1): # generator of terms >= startvalue
%o A395529     for k in count(max(startvalue,1)):
%o A395529         for m in range(1,k):
%o A395529             p = set(primefactors(m))|set(primefactors(k-m))
%o A395529             if (l:=len(p)) == 0 or prime(l) == max(p):
%o A395529                 break
%o A395529         else:
%o A395529             yield k
%o A395529 A395529_list = list(islice(A395529_gen(),50)) # _Chai Wah Wu_, Apr 27 2026
%Y A395529 Cf. A055932.
%K A395529 nonn,easy
%O A395529 1,2
%A A395529 _Zhicheng Wei_, Apr 27 2026
