%S A395542 0,1,2,4,6,9,12,17,18,24,37,38,40,41,42,44,49,56,65,67,69,73,74,80,81,
%T A395542 82,84,88,97,98,112,129,130,131,133,134,137,138,146,148,152,156,163,
%U A395542 166,169,172,176,184,197,198,209,212,216,232,259,260,261,262,266,268
%N A395542 Numbers whose number of nonzero digits is identical in base 2 and 5.
%C A395542 Numbers k such that A000120(k) = A276134(k).
%H A395542 Vincenzo Manto, <a href="/A395542/b395542.txt">Table of n, a(n) for n = 1..10000</a>
%p A395542 q:= n-> (f-> f(n, 2)=f(n, 5))((k, b)-> nops(subs(0=[][], convert(k, base, b)))):
%p A395542 select(q, [$0..230])[];
%t A395542 q[k_] := DigitCount[k, 2, 1] == Total[DigitCount[k, 5, {1, 2, 3, 4}]]; Select[Range[0, 230], q]
%o A395542 (Python)
%o A395542 def nonzero_digits(n, b):
%o A395542     count = 0
%o A395542     while n > 0:
%o A395542         if n % b: count += 1
%o A395542         n //= b
%o A395542     return count
%o A395542 def ok(n):
%o A395542     return nonzero_digits(n, 2) == nonzero_digits(n, 5)
%o A395542 print([k for k in range(270) if ok(k)])
%o A395542 (PARI) isok(k) = #select(x->x>0, digits(k,2)) == #select(x->x>0, digits(k,5)); \\ _Michel Marcus_, Apr 28 2026
%Y A395542 Cf. A393803, A000120, A276134.
%K A395542 nonn,base,new
%O A395542 1,3
%A A395542 _Vincenzo Manto_, Apr 28 2026
