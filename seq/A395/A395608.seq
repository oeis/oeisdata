%I A395608 #26 Jun 07 2026 19:08:13
%S A395608 7,2,101,37,89,1009,73,58049,17,23417,15193,7057,4481,92563129,2089,
%T A395608 76033889,14704649,7150249,4251817,3543193,11228689,3193361
%N A395608 a(n) = least prime p such that Mordell's equation y^2 = x^3 + p has exactly n integral solutions with y >= 0.
%C A395608 a(31) = 3120110801, a(32) = 10438333993.
%H A395608 Helmut Richter, <a href="https://hhr-m.de/mordell/big_table.txt">Solutions of Mordell's equation y^2 = x^3 + k</a>.
%H A395608 XiaoYang Zhang, <a href="https://www.zhihu.com/question/2043507678396274680">k is a prime number. The Mordell equation y^2=x^3-K has 11 sets of integer solutions for k=7057. For what value of k will there be 15 to 30 sets of solutions?</a> (in Chinese).
%e A395608 a(4) = 89 because 89 is the least prime p such that y^2 = x^3 + p has 4 integral solutions with nonnegative y: {{-4, 5}, {-2, 9}, {10, 33}, {55, 408}}.
%e A395608 a(5) = 1009 because 1009 is the least prime p such that y^2 = x^3 + p has 5 integral solutions with nonnegative y: {{-10, 3}, {6, 35}, {8, 39}, {1355, 49878}, {2520, 126503}}.
%o A395608 (Magma)
%o A395608 SetClassGroupBounds ("GRH");
%o A395608 sols := [**];
%o A395608 primes := [p : p in [2..2000] | IsPrime(p)];
%o A395608 for k in primes do
%o A395608     Append(~sols, [k, #IntegralPoints(EllipticCurve([0, 0, 0, 0, k]))]);
%o A395608 end for;
%o A395608 for n in [0..6] do
%o A395608     for sol in sols do
%o A395608         if sol[2] eq n then
%o A395608             printf "a(%o) = %o\n", n, sol[1];
%o A395608             break;
%o A395608         end if;
%o A395608     end for;
%o A395608 end for;
%Y A395608 Cf. A081121, A179162, A392144.
%K A395608 nonn,hard,more
%O A395608 0,1
%A A395608 _Zhining Yang_, Jun 02 2026
