%I A395004 #21 Apr 12 2026 00:16:13
%S A395004 1,3,6,14,30,62,117,217,467,979,1845,3897,7793,15985,31943,64711,
%T A395004 129265,258529,520673,849583,2082753,4151813,8357825,13264529,
%U A395004 33528945,66985857,134090689,268181377,536616833,1073496033,2146467585,4042815511,8587869953,17178943969
%N A395004 a(n) is the larger of the two factors whose product is A394991.
%C A395004 The factors may be equal, but no example for n>2 is known.
%e A395004 See A394987.
%o A395004 (Python)
%o A395004 from sympy.utilities.iterables import multiset_permutations
%o A395004 from sympy import divisors
%o A395004 def A395004(n):
%o A395004     a = 1<<n-1
%o A395004     b = a<<1
%o A395004     k = (n<<1)-1
%o A395004     c = (1<<k+1)-1
%o A395004     for l in range(k,0,-1):
%o A395004         for s in multiset_permutations('0'*l+'1'*(k+1-l)):
%o A395004             m = c-int(''.join(s),2)
%o A395004             for d in divisors(m):
%o A395004                 if d**2>m:
%o A395004                     break
%o A395004                 if a<=d<b and a*d<=m<b*d:
%o A395004                     return m//d # _Chai Wah Wu_, Apr 11 2026
%Y A395004 A395003 is the smaller factor.
%Y A395004 Cf. A029837, A394987, A394989, A394990, A394991.
%K A395004 nonn,new
%O A395004 1,2
%A A395004 _Hugo Pfoertner_, Apr 09 2026
%E A395004 a(24)-a(34) from _Chai Wah Wu_, Apr 09 2026
