%I A395517 #4 Apr 30 2026 23:47:35
%S A395517 7,19,89,129,337,1693,2311,6051,17299,30247,37025,41473,61799,70643,
%T A395517 108577,202663,272735,297991,332929,350169,364951,485981,523711,
%U A395517 744199,800889,1451033,1948339,4935475,5470191,9122471,11244967,13060711,13354113,15407495,15601699,17451491,19782049,23442299
%N A395517 Numbers k such that k^2 = (a+b+c)*b + 1 for some primitive Pythagorean triple (a,b,c).
%C A395517 Here b can be either of the legs of the Pythagorean triple.
%F A395517 Numbers k such that k^2 = 4*x^3*y + 4*x^2*y^2 + 1 or 2*x^4 + 2*x^3*y - 2*x^2*y^2 - 2*x*y^3 + 1 for some x,y with 0 < y < x, x and y coprime and one of them even.
%e A395517 a(4) = 129 is a term because (39+80+89)*80+1 = 129^2 where (39, 80, 89) is a primitive Pythagorean triple.
%p A395517 N:= 10^8: # for terms <= N
%p A395517 R:= NULL:
%p A395517 for x from 1 while 4*x^3+4*x^2+1 <= N^2 do
%p A395517   for y from (x mod 2)+1 to x-1 by 2 do
%p A395517     if igcd(x,y) > 1 then next fi;
%p A395517     Q:= 4*x^3*y + 4*x^2*y^2 + 1;
%p A395517     if Q > N^2 then break fi;
%p A395517     if issqr(Q) then
%p A395517        a:= x^2 - y^2; b:= 2*x*y; c:= x^2 + y^2;
%p A395517        R:= R, sqrt(Q);
%p A395517     fi
%p A395517 od od:
%p A395517 for x from 1 while 8*x^3 - 8*x^2 + 2*x + 1 <= N^2 do
%p A395517     y0:= (x mod 2) + 1;
%p A395517     S:= sort(select(t -> t >= y0 and t <= x-1, [y0, fsolve((2*x^2 + 2*x*z)*(x^2-z^2)+1 = N^2),x-1]));
%p A395517     for i from 1 to nops(S)-1 do
%p A395517        ym:= (S[i]+S[i+1])/2;
%p A395517        if (2*x^2 + 2*x*ym)*(x^2-ym^2)+1 <= N^2 then
%p A395517          y1:= ceil(S[i]);
%p A395517          if y1 + x mod 2 = 0 then y1:= y1+1 fi;
%p A395517          for y from y1 to S[i+1] by 2 do
%p A395517            if igcd(x,y) > 1 then next fi;
%p A395517            Q2:= (2*x^2 + 2*x*y)*(x^2 - y^2) + 1;
%p A395517            if issqr(Q2) then
%p A395517               a:= x^2 - y^2; b:= 2*x*y; c:= x^2 + y^2;
%p A395517               R:= R, sqrt(Q2);
%p A395517   fi od fi od od:
%p A395517 sort([R]);
%Y A395517 Cf. A393809.
%K A395517 nonn,new
%O A395517 1,1
%A A395517 _Will Gosnell_ and _Robert Israel_, Apr 26 2026
