%I A395231 #13 Apr 30 2026 19:34:36
%S A395231 2,3,5,11,17,29,67,53,131,262,199,398,796,1819,2273,3169,6338,9507,
%T A395231 4967,9934,13697,26753,26753,53506,80259,128311,141619
%N A395231 a(n) is the minimum k so that at least one greedy Egyptian fraction representation of i/k (i < k) has n terms.
%C A395231 A proper fraction with numerator i has at most i terms in its representation. Here, 1/2, 2/3, 11/199, 16/3169, and 22/26753 are examples of when that bound is reached.
%C A395231 A loose upper bound for a(n) is A000058(n) as (A000058(n)-1)/A000058(n) always need at least n unit fractions.
%e A395231 The fraction with the smallest denominator so that its Egyptian fraction representation has 1 term is 1/2.
%e A395231 The fraction with the smallest denominator so that its Egyptian fraction representation has 2 terms is 2/3 = 1/2 + 1/6.
%e A395231 The fraction with the smallest denominator so that its Egyptian fraction representation has 3 terms is 4/5 = 1/2 + 1/4 + 1/20.
%e A395231 The fraction with the smallest denominator so that its Egyptian fraction representation has 4 terms is 8/11 = 1/2 + 1/5 + 1/37 + 1/4070.
%o A395231 (Julia)
%o A395231 function a(n)
%o A395231     den = 1
%o A395231     while true
%o A395231         den += 1
%o A395231         for num in 1:den-1
%o A395231             frac = num // den
%o A395231             length = 1
%o A395231             while numerator(frac) != 1
%o A395231                 frac -= 1 // big(denominator(frac) ÷ numerator(frac) + 1)
%o A395231                 length += 1
%o A395231             end
%o A395231             if length == n
%o A395231                 return den
%o A395231             end
%o A395231         end
%o A395231     end
%o A395231 end
%Y A395231 Cf. A395144, A100678, A000058, A048860.
%K A395231 frac,nonn,more,new
%O A395231 1,1
%A A395231 _Hoang Nguyen_, Apr 16 2026
