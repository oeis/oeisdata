%S A395977 1,24,1152,414720,7962624,6688604160,4815794995200,23115815976960,
%T A395977 3170169048268800,263631258054033408000,1610547321930095001600,
%U A395977 27636992044320430227456000,516847643426252201656320000,14694376077718677979398144000,9169290672496455059144441856000
%N A395977 Denominators of rational coefficients related to asymptotic of A336293.
%H A395977 Vaclav Kotesovec, <a href="/A395977/b395977.txt">Table of n, a(n) for n = 0..40</a>
%e A395977 A336293(n) / (n^n*exp(4*sqrt(n)-n-2)/sqrt(8*Pi)) ~ (1 + 55/(24*n^(1/2)) + 2581/(1152*n) + 255893/(414720*n^(3/2)) - 4579919/(7962624*n^2) - 1075995491/(6688604160*n^(5/2)) + 2191041054791/(4815794995200*n^3) + ...)
%t A395977 nterms = 10; Clear[d]; Do[Clear[f]; f[n_] := (E^(-2 + 4*Sqrt[n] - n) * n^n / (2*Sqrt[2*Pi])) * (1 + Sum[d[j]/n^(j/2), {j, 1, k}]); ser = Series[Simplify[(((-(-2 + n)^2)*(-1 + n)^2*f[-3 + n] + (-1 + n)^2*(1 + 3*n)*f[-2 + n] + (1 - n - 3*n^2)*f[-1 + n] + n*f[n]) / (E^(-2 + 4*Sqrt[n] - n) * n^n / (2*Sqrt[2*Pi]))) * n^(k/2 + 2)], {n, Infinity, 1}]; sol = Solve[Normal[ser] == 0, d[k]][[1]]; d[k] = Limit[d[k] /. sol, n -> Infinity]; PrintTemporary[k]; , {k, 1, nterms}]; Join[{1}, Denominator[Table[d[k], {k, 1, nterms}]]]
%Y A395977 Cf. A336293, A395976 (numerators).
%K A395977 nonn,frac,new
%O A395977 0,2
%A A395977 _Vaclav Kotesovec_, May 12 2026
