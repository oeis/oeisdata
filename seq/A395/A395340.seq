%N A395340 a(n) = (2*n)! * [x^(2*n)] cosh(x) / cos(x)^2.
%F A395340 a(n) = 1 - (1/2) * Sum_{k=0..n-1} (-4)^(n-k) * binomial(2*n,2*k) * a(k).
%F A395340 a(n) = Sum_{k=0..n} binomial(2*n,2*k) * A000182(k+1).
%o A395340 (PARI) a000182(k) = 2^(2*k)*(2^(2*k)-1)*abs(bernfrac(2*k))/(2*k);
%o A395340 a(n) = sum(k=0, n, binomial(2*n, 2*k)*a000182(k+1));
