%N A395274 a(n) = (2*n)! * [x^(2*n)] cos(3*x) * cos(4*x) / cos(12*x).
%F A395274 a(n) = (-1)^n * (49^n + 1)/2 - Sum_{k=0..n-1} (-144)^(n-k) * binomial(2*n,2*k) * a(k).
%o A395274 (PARI) a_vector(n, s=3, t=4) = my(v=vector(n+1)); for(i=0, n, v[i+1]=(-1)^i*((s+t)^(2*i)+(s-t)^(2*i))/2-sum(j=0, i-1, (-(s*t)^2)^(i-j)*binomial(2*i, 2*j)*v[j+1])); v;
