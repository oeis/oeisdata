%I A395122 #19 Apr 23 2026 09:59:06
%S A395122 1,1,8,106,2011,50251,1562947,58212496,2526307819,125194403576,
%T A395122 6975612021313,431671067732866,29375024504113224,2180148399591058494,
%U A395122 175255942193255488338,15169721489604763310744,1406668228851105781017170,139120146905496528994077569,14617742264152918252999945853,1626158985979286692827410393980
%N A395122 O.g.f. Sum_{n>=0} n^(2*n) * exp(-n^2*C(x)) * C(x)^n / n!, where C(x) = x + C(x)^2 is the g.f. of the Catalan numbers (A000108).
%C A395122 Compare to C(x) = x*Sum_{n>=0} n^n * exp(-n*C(x)) * C(x)^n / n!, where C(x) = x + C(x)^2 is the g.f. of the Catalan numbers (A000108).
%C A395122 Compare to 1/(1 - G(x)) = Sum_{n>=0} n^n * G(x)^n / n! * exp(-n*G(x)) for all G(x) such that G(0) = 0.
%H A395122 Paul D. Hanna, <a href="/A395122/b395122.txt">Table of n, a(n) for n = 0..500</a>
%F A395122 O.g.f. A(x) = Sum_{n>=0} a(n)*x^n satisfies the following formulas.
%F A395122 (1) A(x) = Sum_{n>=0} n^(2*n) * exp(-n^2*C(x)) * C(x)^n / n!, where C(x) = x + C(x)^2.
%F A395122 (2) A(x) = Sum_{n>=0} Stirling2(2*n,n) * C(x)^n, where C(x) = x + C(x)^2.
%F A395122 (3) A(x-x^2) = Sum_{n>=0} A007820(n)*x^n, where A007820(n) = A008277(2*n,n) for n >= 1 and A008277 equals the Stirling numbers of second kind.
%F A395122 (4) a(n) = Sum_{k=0..n} Stirling2(2*k,k) * binomial(2*n-k-1,n-k) * k/n, for n > 0 with a(0) = 1.
%F A395122 a(n) ~ c * 2^(2*n) * n^(n - 1/2) / (exp(n) * w^n * (2-w)^n), where w = -LambertW(-2*exp(-2)) = -A226775 and c = exp(w*(2-w)/4) / sqrt(2*Pi*(1-w)) = 0.608790172838950278847057756902431435962473435569889599136257458313677... - _Vaclav Kotesovec_, Apr 23 2026
%e A395122 O.g.f.: A(x) = 1 + x + 8*x^2 + 106*x^3 + 2011*x^4 + 50251*x^5 + 1562947*x^6 + 58212496*x^7 + 2526307819*x^8 + ...
%e A395122 where
%e A395122 A(x) = 1 + exp(-C(x))*C(x) + 2^4*exp(-2^2*C(x))*C(x)^2/2! + 3^6*exp(-3^2*C(x))*C(x)^3/3! + 4^8*exp(-4^2*C(x))*C(x)^4/4! + ... + n^(2*n)*exp(-n^2*C(x))*C(x)^n/n! + ...
%e A395122 and C(x) = x + C(x)^2, which starts as
%e A395122 C(x) = x + x^2 + 2*x^3 + 5*x^4 + 14*x^5 + 42*x^6 + 132*x^7 + 429*x^8 + 1430*x^9 + ... + A000108(n)*x^(n+1) + ...
%e A395122 Therefore, we have
%e A395122 A(x-x^2) = 1 + x + 7*x^2 + 90*x^3 + 1701*x^4 + 42525*x^5 + 1323652*x^6 + ... + A007820(n)*x^n + ...
%o A395122 (PARI) \\ Formula (1)
%o A395122 {a(n) = my(A=1,C=serreverse(x-x^2 + x*O(x^n)));
%o A395122 A = 1 + sum(m=1,n, m^(2*m) * exp(-m^2*C) * C^m/m!); polcoef(GF=A,n)}
%o A395122 {upto(n) = a(n); Vec(GF)}
%o A395122 upto(20)
%o A395122 (PARI) \\ Formula (2)
%o A395122 {a(n) = my(A=1,C=serreverse(x-x^2 + x*O(x^n)));
%o A395122 A = sum(m=0,n, stirling(2*m,m,2) * C^m); polcoef(GF=A,n)}
%o A395122 {upto(n) = a(n); Vec(GF)}
%o A395122 upto(20)
%o A395122 (PARI) \\ Formula (4)
%o A395122 {a(n) = if(n==0,1, sum(k=0,n, stirling(2*k,k,2) * binomial(2*n-k-1,n-k) * k/n ) )}
%o A395122 for(n=0,20,print1(a(n),", "))
%Y A395122 Cf. A395123, A219184, A007820, A008277, A000108.
%K A395122 nonn,new
%O A395122 0,3
%A A395122 _Paul D. Hanna_, Apr 22 2026
