%I A395837 #9 Jun 10 2026 11:01:03
%S A395837 1,6,65,1302,85425,7316310,978911960,196901769732,55193621225743,
%T A395837 11189954978322600,10087627980546480826,26791549795221415615580,
%U A395837 1343026219489938132656481,134516049370090208389365126747,496520746161771547927510217314512,2488082740706962234924700258811769650
%N A395837 Define F(n,x) as the power series in x satisfying F(n,x) = 1 + x*F(n,x)^2 - x^n*F(n,x)^(2*n), then for n >= 2, a(n) = [x^(M-1)] F(n,x) where x^M is the first power of x with a negative coefficient in F(n,x). Should no such M exist for some n, then there are no further terms and this sequence would be finite.
%C A395837 Conjecture: this sequence is infinite.
%H A395837 Paul D. Hanna, <a href="/A395837/b395837.txt">Table of n, a(n) for n = 2..92</a>
%F A395837 a(n) = [x^(A395835(n)-1)] F(n,x) where F(n,x) = sqrt( (1/x)*Series_Reversion( x/(1 + x - x^n)^2 ) ) for n >= 2.
%e A395837 The first few power series F(n,x) satisfying
%e A395837 F(n,x) = 1 + x*F(n,x)^2 - x^n*F(n,x)^(2*n)
%e A395837 begin
%e A395837 F(2,x) = 1 + x + (1*x^2) - 1*x^3 - 10*x^4 - 33*x^5 - 55*x^6 + 65*x^7 + 842*x^8 + ...
%e A395837 F(3,x) = 1 + x + 2*x^2 + 4*x^3 + (6*x^4) - 3*x^5 - 82*x^6 - 481*x^7 - 2098*x^8 + ...
%e A395837 F(4,x) = 1 + x + 2*x^2 + 5*x^3 + 13*x^4 + 32*x^5 + 66*x^6 + (65*x^7) - 382*x^8 - 3553*x^9 - 20254*x^10 + ...
%e A395837 F(5,x) = 1 + x + 2*x^2 + 5*x^3 + 14*x^4 + 41*x^5 + 120*x^6 + 338*x^7 + 870*x^8 + 1802*x^9 + (1302*x^10) - 15596*x^11 - 135056*x^12 + ...
%e A395837 F(6,x) = 1 + x + 2*x^2 + 5*x^3 + 14*x^4 + 42*x^5 + 131*x^6 + 415*x^7 + 1310*x^8 + 4046*x^9 + 11951*x^10 + 32452*x^11 + 73428*x^12 + (85425*x^13) - 428751*x^14 - 4557495*x^15 + ...
%e A395837 From the above examples we can see that a(n) equals the coefficient immediately prior to the first negative coefficient found in F(n,x). The exponents of x at which these values occur is given by A395835(n) - 1.
%o A395837 (PARI) \\ Print coefficient prior to first negative coefficient in F(n, x)
%o A395837 \\ Routine FNEG(F) finds the first negative coefficient in F,
%o A395837 \\ and returns the prior coefficient (or a "?" if not found):
%o A395837 {PNEG(F) = my(N="?"); for(n=1, #F-1, if(polcoef(F, n)<0, N=polcoef(F, n-1); break)); N}
%o A395837 \\ The following code prints the initial 70 terms in 2 minutes,
%o A395837 \\ the last 5 terms of which take about 30 seconds to compute.
%o A395837 \\ MAX(n) = 2*n^(3/2) is an approximation of growth for A395835(n)
%o A395837 \\ used to reduce run-time and may need correction for larger n.
%o A395837 {MAX(n) = ceil(2*n^(3/2))}
%o A395837 {for(n=2, 20, F = sqrt((1/x)*serreverse(x/(1 + x - x^n +O(x^MAX(n)) )^2 )); print1(PNEG(F), ", "))}
%Y A395837 Cf. A395835, A395836, A000108.
%K A395837 nonn
%O A395837 2,2
%A A395837 _Paul D. Hanna_, Jun 07 2026
