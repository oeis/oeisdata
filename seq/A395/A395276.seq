%U A395276 1161322007832830769749776925,2338269093856162961392809427921,5543838898972990706687919633426965
%N A395276 a(n) = (2*n)! * [x^(2*n)] cos(x) * cos(sqrt(3)*x) / cos(3*x).
%F A395276 a(n) = (-1)^n * A090965(n) - Sum_{k=0..n-1} (-9)^(n-k) * binomial(2*n,2*k) * a(k).
%o A395276 (PARI) a090965(n) = 2^n*polchebyshev(n, 1, 2);
%o A395276 a_vector(n) = my(v=vector(n+1)); for(i=0, n, v[i+1]=(-1)^i*a090965(i)-sum(j=0, i-1, (-9)^(i-j)*binomial(2*i, 2*j)*v[j+1])); v;
