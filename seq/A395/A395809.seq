%I A395809 #14 Jun 17 2026 18:07:18
%S A395809 3,2,73,103,641,3167,10903
%N A395809 a(n) is the least prime p such that there are exactly n numbers k with p^2 = A075254(k).
%C A395809 a(n) is the least prime p such that k + sopfr(k) = p^2 has exactly n solutions, where sopfr(k) = A001414(k) is the sum of prime factors of k with multiplicity.
%e A395809 a(1) = 2 with 2 + 2 = 4 = 2^2.
%e A395809 a(2) = 73 with 5008 + 4 * 2 + 313 (as 5008 = 2^4 * 313)
%e A395809              = 5278 + 2 + 7 + 13 + 29 (as 5278 = 2 * 7 * 13 * 29) = 5329 = 73^2.
%e A395809 a(3) = 103 with 10486 + 2 + 2 * 7 + 107
%e A395809               = 10545 + 3 + 5 + 19 + 37
%e A395809               = 10556 + 2 * 2 + 7 + 13 + 29 = 10609 = 103^2.
%e A395809 a(4) = 641 with 386704 + 4 * 2 + 24169
%e A395809               = 410494 + 2 + 7 + 109 + 269
%e A395809               = 410501 + 7 + 2 * 13 + 347
%e A395809               = 410515 + 5 + 7 + 37 + 317 = 410881 = 641^2.
%e A395809 a(5) = 3167 with 9439888 + 4 * 2 + 589993
%e A395809                = 9964737 + 2 * 3 + 17 + 65129
%e A395809                = 10025457 + 3 + 13 + 59 + 4357
%e A395809                = 10028086 + 2 + 19 + 163 + 1619
%e A395809                = 10029720 + 3 * 2 + 3 + 5 + 19 + 53 + 83 = 10029889 = 3167^2.
%p A395809 N:= 10000: # for terms before the first term > N
%p A395809 V:= 'V':
%p A395809 for k from 1 to N^2 do
%p A395809    v:= k + add(t[1]*t[2],t=ifactors(k)[2]);
%p A395809    if v <= N^2 and issqr(v) then
%p A395809      p:= sqrt(v);
%p A395809      if isprime(p) then
%p A395809        if assigned(V[p]) then V[p]:= V[p] union {k}
%p A395809        else V[p]:= {k}
%p A395809   fi fi fi od:
%p A395809 J:= sort(map(op,[indices(J)])):
%p A395809 R:= 'R': R[0]:= 3:
%p A395809 m:= 0:
%p A395809 for p in J do v:= nops(V[p]); if not assigned(R[v]) then R[v]:= p; m:= max(m,v) fi od:
%p A395809 seq(R[v],v=0..m);
%Y A395809 Cf. A001414, A075254, A396408, A396455.
%K A395809 nonn,more
%O A395809 0,1
%A A395809 _Will Gosnell_ and _Robert Israel_, Jun 04 2026
