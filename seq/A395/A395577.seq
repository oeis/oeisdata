%N A395577 1 = Sum_{n>=0} a(n) * x^n * (1 - (4*n+1)*x)^2.
%F A395577 a(n) = 2*(4*n - 3)*a(n-1) - (4*n - 7)^2*a(n-2).
%F A395577 a(n) ~ c * 2^(2*n) * exp(2*sqrt(n) - n) *  n^(n - 1/2) * (1 - 5/(48*sqrt(n))), where c = 0.1931408318743114767472954651005984550581402157927430919...
%t A395577 RecurrenceTable[{(-7+4*n)^2*a[n-2] - 2*(-3+4*n)*a[n-1] + a[n] == 0,a[1]==2,a[2]==19}, a, {n, 0, 20}]
%o A395577 (PARI) {a(n)=polcoeff(1-sum(m=0, n-1, a(m)*x^m*(1-(4*m+1)*x+x*O(x^n))^2), n)}
%o A395577 for(n=0, 25, print1(a(n), ", "))
