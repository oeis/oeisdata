%S A395990 1,3,4,6,6,9,8,12,11,13,12,19,14,17,18,23,18,24,20,29,24,25,24,36,27,
%T A395990 29,32,39,30,37,32,45,36,37,38,55,38,41,42,56,42,49,44,59,54,49,48,70,
%U A395990 51,56,54,69,54,66,58,76,60,61,60,85,62,65,74,88,68,73,68,89,72,77,72,108,74,77,82,99,80,85,80,112
%N A395990 a(n) = Sum_{d|n} d^(tau(n/d) mod 2).
%C A395990 For each divisor d of n, add d if n/d is a square, else add 1.
%F A395990 a(n) = tau(n) + Sum_{d|n} (d-1) * (tau(n/d) mod 2).
%F A395990 a(n) = A000005(n) + A076752(n) - A046951(n).
%e A395990 a(8) = 1^0 + 2^1 + 4^0 + 8^1 = 12.
%t A395990 Table[DivisorSigma[0, n] + Sum[(d - 1)*Mod[DivisorSigma[0, n/d], 2], {d, Divisors[n]}], {n, 100}]
%o A395990 (Python)
%o A395990 from math import prod
%o A395990 from sympy import factorint
%o A395990 def A395990(n):
%o A395990     f = factorint(n)
%o A395990     return prod(e+1 for e in f.values())+prod((p if (k:=e&1) else 1)*(p**(e+2-k)-1)//(p**2-1) for p,e in f.items())-prod((e>>1)+1 for e in f.values()) # _Chai Wah Wu_, Jun 25 2026
%Y A395990 Cf. A000005 (tau), A046951, A076752.
%K A395990 nonn,easy,changed
%O A395990 1,2
