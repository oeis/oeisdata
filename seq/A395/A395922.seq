%T A395922 5479404,5479404,5479404,5479404,62296465,221669902,221669902,
%U A395922 7746395146,7746395146,7746395146,7746395146,26219293646,1079415718589,1079415718589,1079415718589,4964993283354
%N A395922 Largest k such that k*(k+1)/2 divides A002110(n).
%e A395922 a(3) = 5, as A000217(5) = 15 is the largest term of A000217 dividing A002110(3) = 30.
%t A395922 a[n_] := Module[{d = Divisors[Product[Prime[k], {k, 1, n}]], i}, i = Length[d]; While[! IntegerQ[Sqrt[8*d[[i]] + 1]], i--]; (Sqrt[8*d[[i]] + 1] - 1)/2]; Array[a, 17] (* _Amiram Eldar_, May 10 2026 *)
%o A395922 (Python)
%o A395922 from math import prod, isqrt
%o A395922 from itertools import combinations
%o A395922 from sympy.ntheory.primetest import is_square
%o A395922 from sympy import prime
%o A395922 def A395922(n):
%o A395922     if n == 1: return 1
%o A395922     ps = tuple(prime(i) for i in range(1,n+1))
%o A395922     c = 0
%o A395922     for l in range(2,n+1):
%o A395922         for p in combinations(ps,l):
%o A395922             q = (prod(p)<<3)+1
%o A395922             if is_square(q):
%o A395922                 c = max(c, isqrt(q)>>1)
%o A395922     if c:
%o A395922         return c # _Chai Wah Wu_, May 10 2026
%Y A395922 Cf. A000217, A002110, A395898.
%K A395922 nonn,new
%O A395922 1,2
%A A395922 _Jean-Marc Rebert_, May 10 2026
