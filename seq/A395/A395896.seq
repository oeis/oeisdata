%I A395896 #7 May 18 2026 23:53:21
%S A395896 0,1,0,4,0,2,0,10,0,2,0,9,0,4,0,23,0,1,0,7,0,3,0,18,0,2,0,14,0,7,0,40,
%T A395896 0,1,0,6,0,4,0,18,0,3,0,14,0,7,0,39,0,1,0,11,0,6,0,31,0,3,0,24,0,12,0,
%U A395896 68,0,2,0,7,0,3,0,16,0,3,0,13,0,6,0,36,0,2
%N A395896 Number of k < m^2 such that both rad(k) and rad(k+1) divide m, where rad = A007947 and m = A019565(n).
%C A395896 Number of k < A019565(n)^2 such that both A007947(k) and A007947(k+1) divide A019565(n).
%C A395896 Conjecture: a(n) = 0 for even n (that is, for odd numbers in A019565).
%H A395896 Michael De Vlieger, <a href="/A395896/b395896.txt">Table of n, a(n) for n = 0..2048</a>
%H A395896 Michael De Vlieger, <a href="/A395896/a395896_1.png">Log log scatterplot of a((n+1)/2)</a>, n = 1..2^11 (eliminating zeros), with axis x = (n+1)/2.
%H A395896 Michael De Vlieger, <a href="/A395896/a395896_2.png">Fan style binary tree</a>, n = 0..2^11-1, using a color function where gray = 0, blue = 1, ..., magenta = 487.
%F A395896 a(2^i-1) = A002071(i).
%e A395896 Let r(n) be the reversal of the binary expansion of n (replacing 0 with "." for clarity).
%e A395896 Let s(n) = A019565(n) and b(n) is the largest term in the list of k < A019565(n)^2 such that both rad(k) and rad(k+1) divide A019565(n).
%e A395896 Table of n, r(n), s(n), a(n), b(n) for select n:
%e A395896    n   r(n)     s(n)   b(n)  a(n)  List of k.
%e A395896   ----------------------------------------------------------------
%e A395896    0   .    ->    1      -     -   {}
%e A395896    1   1    ->    2      1     1   {1}
%e A395896    2   .1   ->    3      -     -   {}
%e A395896    3   11   ->    6      8     4   {1, 2, 3, 8}
%e A395896    4   ..1  ->    5      -     -   {}
%e A395896    5   1.1  ->   10      4     2   {1, 4}
%e A395896    6   .11  ->   15      -     -   {}
%e A395896    7   111  ->   30     80    10   {1, 2, 3, ..., 15, 24, 80}
%e A395896    9   1..1 ->   14      7     2   {1, 7}
%e A395896   11   11.1 ->   42     63     9   {1, 2, 3, ..., 27, 48, 63}
%e A395896   13   1.11 ->   70     49     4   {1, 4, 7, 49}
%e A395896   15   1111 ->  210   4374    23   {1, 2, 3, ..., 224, 2400, 4374}
%e A395896   17   1... ->   22      1     1   {1}
%e A395896   19   11.. ->   66    242     7   {1, 2, 3, 8, 11, 32, 242}
%e A395896   21   1.1. ->  110     10     3   {1, 4, 10}
%e A395896   23   111. ->  330    242    18   {1, 2, 3, ..., 99, 120, 242}
%e A395896   25   1..1 ->  154      7     2   {1, 7}
%e A395896   27   11.1 ->  462    242    14   {1, 2, 3, ..., 63, 98, 242}
%e A395896   29   1.11 ->  770    175     7   {1, 4, 7, 10, 49, 55, 175}
%e A395896   31   1111 -> 2310   9800    40   {1, 2, 3, ..., 3024, 4374, 9800}
%t A395896 rad[x_] := Times @@ FactorInteger[x][[All, 1]]; f[x_] := Select[Range[x^2, 1, -1], Divisible[x, rad[#] ] &]; Monitor[Table[k = Times @@ MapIndexed[Prime[First[#2] ]^#1 &, Reverse@ IntegerDigits[n, 2] ]; Count[Partition[f[k], 2, 1], _?(#1 - #2 == 1 & @@ # &)], {n, 0, 31}], n]
%Y A395896 Cf. A002071, A005117, A019565, A395754.
%K A395896 nonn,new
%O A395896 0,4
%A A395896 _Michael De Vlieger_, May 12 2026
