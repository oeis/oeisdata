%I A395456 #21 May 02 2026 23:21:24
%S A395456 1,4,1,16,25,1,64,301,65,1,256,3025,1701,126,1,1024,28501,34105,6027,
%T A395456 210,1,4096,261625,611501,210232,16467,319,1,16384,2375101,10391745,
%U A395456 6339333,912340,38038,455,1,65536,21457825,171798901,177031218,42615573,3136562,78078,620,1
%N A395456 Triangle read by rows: T(n,k) = (1/(2k)!) * Sum_{j=0..2k} (-1)^j * binomial(2k,j) * (2+k-j)^(2n).
%D A395456 P. L. Butzer, K. Schmidt, E. L. Stark, and L. Vogt, Central factorial numbers; their main properties and some applications. Numerical Functional Analysis and Optimization, 10(5-6), (1989), 419-488.
%D A395456 J. Riordan, Combinatorial identities (Vol. 217), Wiley, New York, 1968.
%H A395456 José L. Cereceda, <a href="https://arxiv.org/abs/2211.11648">Sums of powers of integers and generalized Stirling numbers of the second kind</a>, arXiv:2211.11648 [math.NT], 2022.
%H A395456 M. W. Coffey and M. C. Lettington, <a href="https://arxiv.org/abs/1510.05402">On Fibonacci Polynomial Expressions for Sums of m-th Powers, their implications for Faulhaber's Formula and some Theorems of Fermat</a>, arXiv:1510.05402 [math.NT], 2015.
%H A395456 Donald E. Knuth, <a href="https://arxiv.org/abs/math/9207222">Johann Faulhaber and Sums of Powers</a>, arXiv:math/9207222 [math.CA], 1992.
%H A395456 Petro Kolosov, <a href="https://doi.org/10.5281/zenodo.18096789">Sums of powers via central finite differences and Newton's formula</a>, Zenodo, 2026.
%F A395456 Let F(t, n, k) be generalized central factorial numbers of the second kind: F(t,n,k) = (1/(2k)!) * Sum_{j=0..2k} (-1)^j * binomial(2k,j) * (t+k-j)^(2n), then:
%F A395456   F(0,2n,2k) = A387597(n,k)/k! = A269945(n,k);
%F A395456   F(1,2n,2k) = A392337(n,k)/k! = A394692(n,k);
%F A395456   F(2,2n,2k) = A390029(n,k)/k! = T(n,k) (this sequence);
%F A395456   F(3,2n,2k) = A395457(n,k).
%F A395456 G.f. for T(n,k) is centered Newton's polynomial for f(s) = s^(2n): s^(2n) = Sum_{k=0..2n} T(2n,k) (s-2)^[k], where (s-2)^[k] are central factorials.
%e A395456 Triangle begins:
%e A395456   k=   0      1         2          3          4         5        6      7    8
%e A395456   -----------------------------------------------------------------------------
%e A395456   n=0: 1;
%e A395456   n=1: 4,     1;
%e A395456   n=2: 16,    25,       1;
%e A395456   n=3: 64,    301,      65,        1;
%e A395456   n=4: 256,   3025,     1701,      126,       1;
%e A395456   n=5: 1024,  28501,    34105,     6027,      210,      1;
%e A395456   n=6: 4096,  261625,   611501,    210232,    16467,    319,     1;
%e A395456   n=7: 16384, 2375101,  10391745,  6339333,   912340,   38038,   455,   1;
%e A395456   n=8: 65536, 21457825, 171798901, 177031218, 42615573, 3136562, 78078, 620, 1;
%e A395456   ...
%t A395456 T[t_, n_, k_] := 1/ k!* Sum[(-1)^j * Binomial[k, j] * (t + k/2 - j)^n, {j, 0, k}]; Column[Table[T[2, 2 n, 2 k], {n, 0, 10}, {k, 0, n}]]
%o A395456 (PARI) T(n,k) = sum(j=0, 2*k, (-1)^j * binomial(2*k,j) * (2+k-j)^(2*n))/(2*k)!; \\ _Michel Marcus_, Apr 28 2026
