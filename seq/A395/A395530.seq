%S A395530 1,1,1,1,1,1,2,1,1,1,2,1,2,2,1,1,2,1,2,1,2,2,2,1,1,2,1,2,2,1,2,1,2,2,
%T A395530 2,1,2,2,2,1,2,2,2,2,1,2,2,1,2,1,2,2,2,1,2,2,2,2,2,1,2,2,2,1,2,2,2,2,
%U A395530 2,2,3,1,2,2,1,2,2,2,2,1,1,2,2,2,2,2,2,2,2,1,2,2,2,2,2,1,2,2,2,1
%N A395530 a(n) is the least number of 5-smooth numbers that add up to n.
%H A395530 Robert Israel, <a href="/A395530/b395530.txt">Table of n, a(n) for n = 1..10000</a>
%p A395530 N:= 100: # for a(1)..a(N)
%p A395530 S:= {1}:
%p A395530 for p in [2,3,5] do
%p A395530   S:= S union map(proc(t) local i; seq(p^i*t, i=1..floor(log[p](N/t))) end proc,S)
%p A395530 od:
%p A395530 f:= proc(n) option remember; if member(n,S) then 1 else min(map(k -> f(n-k) + 1, select(`<`,S,n))) fi end proc:
%p A395530 map(f, [$1..N]); # _Robert Israel_, Apr 28 2026
%Y A395530 Cf. A051037, A237442.
%K A395530 nonn,new
%O A395530 1,7
%A A395530 _Zhicheng Wei_, Apr 27 2026
