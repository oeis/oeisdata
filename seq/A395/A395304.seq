%e A395304   n=8 [0, 0, 0, 0,  2, 50, 300, 1287, 1430]
%e A395304   n=9 [0, 0, 0, 0,  1, 24, 285, 1485, 5005, 4862]
%e A395304   ...
%e A395304 The tree 1(1)2(121), with shape shown below has three groups of sibling edges. Reading the edge weights left to right gives the sibling groups [1,2], [1], and [1,2,1]. All of these groups have weights in standard order so this tree is counted under T(8,6) = 300.
%e A395304              _o_
%e A395304 		  /   \
%e A395304 		 o    _o_
%e A395304 		 |   / | \
%e A395304 		 o  o  o  o
%o A395304 (PARI)
%o A395304 tri(n) = {n*(n+1)/2}
%o A395304 A_xy(N) = {my(x='x+O('x^(N+1)), A=1); for(i=1, N, A = sum(j=0,N, (x^tri(j) * y^j * A^j)/prod(k=1,j, (1 - y * A * (x - x^(k+1))/(1-x))  ))); vector(N, n, Vecrev(polcoeff(A, n-1)))}
