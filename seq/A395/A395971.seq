%U A395971 479001600,1,-189,16037,-832687,29733438,-737885624,11606255424,-87178291200,1,-268,32550,-2444164,129168337,-5013881208,138791607312,-2458658914560,20922789888000
%N A395971 Triangular array T(n, k) read by rows: Row n gives the even coefficients of the polynomial P_n(x) = Sum_{k=0..n} x^(2*(n-k))*T(n, k), this is the polynomial of order 2*n that satisfies (-1)^n*P_n(k-n)/(n!)^2 = binomial(2*n, k) for integers k = 0..2*n.
%C A395971 If we define mockbinomial(2*n, k) = (-1)^n*P_n(k-n)/(n!)^2, then this function will imitate binomial(2*n, k) for nonnegative integers n and 0 <= k <= 2*n, for general constant integer k-2*n we can say that mockbinomial(2*n, k) = Catalan(n)*SomePolynomial(n).
%F A395971 T(n, 0) = 1.
%F A395971 T(n, 1) = -A101986(n) = -n*(2*n^2 + 9*n + 1)/6.
%F A395971 T(n, 2) = n*(n-1)*(20*n^4 + 164*n^3 + 679*n^2 - 11*n - 6)/(6*60).
%F A395971 T(n, 3) = -n*(n-1)*(n-2)*(280*n^6 + 3108*n^5 + 25330*n^4 + 105243*n^3 - 45626*n^2 + 333*n + 180)/(6*60*126).
%F A395971 T(n, 4) = n*(n-1)*(n-2)*(n-3)*(2800*n^8 + 36960*n^7 + 453816*n^6 + 3820656*n^5 + 14420175*n^4 - 18664890*n^3 + 5462309*n^2 - 15186*n - 7560)/(6*60*126*120).
%F A395971 T(n, k) = Sum_{m=0..3*k} (-1)^m*binomial(3*k+1, m+1)*T(n-1-m, k), for n > 3*k.
%F A395971 T(n, n) = A001044(n)*(-1)^n = (2*n)!*(-1)^n.
%F A395971 Sum_{k=0..n} T(n, k) = (-1)^n*n*(2*n)!/(n+1).
%F A395971 (-1)^n*P_n(0)/(n!)^2 = A000984(n).
%F A395971 (-1)^n*P_n(n+1)/(n!)^2 = -A000984(n).
%F A395971 (-1)^n*P_n(n+2)/(n!)^2 = -(2*n^2 + 4*n + 1)*binomial(2*n, n)/(n+1) = -(2*(n+1)^2 + 1)*A000108(n).
%F A395971 (-1)^n*P_n(n+3)/(n!)^2 = -(2*(n+2)^3 + 5*(n+2)^2 + 5)*A000108(n).
%e A395971 Triangle T(n, k) begins:
%e A395971   [0]  1;
%e A395971   [1]  1,    -2;
%e A395971   [2]  1,    -9,    24;
%e A395971   [3]  1,   -23,   202,    -720;
%e A395971   [4]  1,   -46,   881,   -8900,   40320;
%e A395971   [5]  1,   -80,  2773,  -55470,  657576,  -3628800;
%e A395971   [6]  1,  -127,  7143, -241141, 5342956, -73537632, 479001600;
%o A395971 (PARI) T(n,k) = (-1)^n*polcoeff(polinterpolate(vector(2*n+1, m, m-n-1), vector(2*n+1, m, binomial(2*n, m-1)))*(n!)^2, 2*(n-k))
%Y A395971 Cf. A000108, A000984, A007318, A101986, A010050.
%Y A395971 Cf. A274136 (row sums).
