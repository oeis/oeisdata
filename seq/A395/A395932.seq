%o A395932 a(n) = my(v1 = vector(A002024(n+1), i, 0), v2 = vector(n+1, i, 0), v3); v1[1] = n; v2[1] = 1; for(i=2, #v1, v1[i] = v1[i-1] - A002024(v1[i-1])); v1 = Vecrev(v1); for(i=2, #v1, v3 = vector(n+1, i, 0); v3[1] = 1; A = v1[i] - v1[i-1]; for(j=1, n, v3[j+1] = v2[j+1] + (j+A-1)*v3[j]); v2 = v3); v2[n+1]
