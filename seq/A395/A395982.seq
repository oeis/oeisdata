%S A395982 7,11,13,19,31,71,127,379,491,2633,2659,8191,13249,26893,70687,74597,
%T A395982 87211,131071,184511,524287,642581,1897121,2676301,2703739,15456151,
%U A395982 52368101,102785339,126233057,193481677,856645921,1552107133,2147483647,2935442621,3668158729
%N A395982 Primes p such that the Fermat quotient q = (2^(p-1) - 1)/p mod p satisfies 1 < q < p and q divides p - 1.
%C A395982 All known Mersenne primes (A000668) > 3 are terms of this sequence.
%F A395982 { p prime : q = (2^(p-1) - 1)/p mod p, 1 < q < p and (p-1) mod q = 0 }.
%t A395982 Select[Prime[Range[10000]], 1 < (q = Mod[(2^(# - 1) - 1)/#, #]) && Divisible[# - 1, q] &] (* _Amiram Eldar_, May 21 2026 *)
%o A395982 (Python)
%o A395982 from sympy import primerange
%o A395982 def sequence(limit):
%o A395982     results = []
%o A395982     for p in primerange(3, limit):
%o A395982         q = ((pow(2, p - 1, p**2) - 1) // p) % p
%o A395982         if q > 1 and (p - 1) % q == 0:
%o A395982             results.append(p)
%o A395982     return results
%o A395982 print(sequence(3000000))
%o A395982 (PARI) isok(p) = if (isprime(p) && (p>2), my(q=((2^(p-1)-1)/p) % p); (q>1) && (q<p) && !((p-1) % q)); \\ _Michel Marcus_, May 13 2026
