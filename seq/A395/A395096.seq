%I A395096 #14 Apr 27 2026 00:39:36
%S A395096 1,1,1,2,2,2,3,1,2,2,5,1,7,1,6,7,1,2,6,1,8,10,9,1,7,1,7,1,9,1,38,1,2,
%T A395096 10,12,12,13,1,7,10,12,1,60,1,9,12,12,1,10,1,10,12,12,1,10,12,12,13,
%U A395096 11,1,89,1,9,11,1,9,92,1,10,14,94,1,12,1,10,14,15,12
%N A395096 a(n) is the number of partitions of n into distinct parts such that the sum of A001221 over the parts equals A001221(n).
%C A395096 We define A001221(0) = 0.
%H A395096 Felix Huber, <a href="/A395096/b395096.txt">Table of n, a(n) for n = 0..10000</a>
%F A395096 a(n) = [x^n*y^A001221(n)] Product_{k>=1} (1 + x^k*y^A001221(k)), where A001221(0) = 0.
%F A395096 For m = p^k a prime power, a(m) = 2 if A001221(m-1) = 1, and 1 otherwise.
%F A395096 1 <= a(n) <= A000009(n).
%e A395096 a(6) = 3: [6], [2, 4], [1, 2, 3], since A001221(6) = 2 and these are exactly the three distinct partitions with A001221 sum 2.
%p A395096 A := proc(f, N)
%p A395096     local d, i, k, m, n, s, v;
%p A395096     v := [0, seq(f(i), i = 1 .. N)];
%p A395096     m := max(op(v));
%p A395096     d := Array(0 .. N, 0 .. m, 'fill = 0');
%p A395096     d[0, 0] := 1;
%p A395096     for k from 1 to N do
%p A395096         for n from N by -1 to k do
%p A395096             for s from m by -1 to v[k + 1] do
%p A395096                 d[n, s] := d[n, s] + d[n - k, s - v[k + 1]]
%p A395096             od
%p A395096         od
%p A395096     od;
%p A395096     [seq(d[n, v[n + 1]], n = 0 .. N)]
%p A395096 end proc:
%p A395096 N := 77: # Enlarge if you want more terms
%p A395096 w := n -> NumberTheory:-Omega(n, 'distinct'):
%p A395096 A395096 := A(w, N):
%p A395096 A395096(N);
%t A395096 {1}~Join~Table[With[{r = PrimeNu[n]}, Count[Select[IntegerPartitions[n], DuplicateFreeQ], _?(Total[PrimeNu /@ #] == r &)]], {n, 60}] (* _Michael De Vlieger_, Apr 15 2026 *)
%Y A395096 Cf. A000009, A001221, A395097, A395111.
%K A395096 nonn,new
%O A395096 0,4
%A A395096 _Felix Huber_, Apr 15 2026
