%S A395243 1,1,1,1,2,1,1,4,4,1,1,8,16,8,1,1,16,36,36,16,1,1,32,81,94,81,32,1,1,
%T A395243 64,225,278,278,225,64,1,1,128,625,1062,1365,1062,625,128,1,1,256,
%U A395243 1600,3650,7164,7164,3650,1600,256,1,1,512,4096,11856,33858,55213,33858,11856,4096,512,1
%N A395243 Number A(n,k) of ways to place nonattacking knights on a k X n board; square array A(n,k), n>=0, k>=0, read by antidiagonals.
%H A395243 Alois P. Heinz, <a href="/A395243/b395243.txt">Antidiagonals n = 0..30, flattened</a>
%H A395243 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/KnightGraph.html">Knight Graph</a>
%H A395243 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/KnightsProblem.html">Knights Problem</a>
%H A395243 Wikipedia, <a href="https://en.wikipedia.org/wiki/Knight_(chess)">Knight (chess)</a>
%F A395243 A(n,k) = A(k,n).
%e A395243 Square array A(n,k) begins:
%e A395243   1,   1,    1,     1,      1,       1,        1,         1, ...
%e A395243   1,   2,    4,     8,     16,      32,       64,       128, ...
%e A395243   1,   4,   16,    36,     81,     225,      625,      1600, ...
%e A395243   1,   8,   36,    94,    278,    1062,     3650,     11856, ...
%e A395243   1,  16,   81,   278,   1365,    7164,    33858,    161307, ...
%e A395243   1,  32,  225,  1062,   7164,   55213,   367869,   2451527, ...
%e A395243   1,  64,  625,  3650,  33858,  367869,  3368146,  30601998, ...
%e A395243   1, 128, 1600, 11856, 161307, 2451527, 30601998, 394631712, ...
%p A395243 b:= proc(n, l) option remember; local d, f, g, k;
%p A395243       d:= nops(l)/3; f:=false; if n=0 then 1
%p A395243     elif l[1..d]=[f$d] then b(n-1, [l[d+1..3*d][], true$d])
%p A395243     else for k while not l[k] do od; g:= subsop(k=f, l);
%p A395243          if k>1 then g:=subsop(2*d-1+k=f, g) fi;
%p A395243          if k<d then g:=subsop(2*d+1+k=f, g) fi;
%p A395243          if k>2 then g:=subsop(  d-2+k=f, g) fi;
%p A395243          if k<d-1 then g:=subsop(d+2+k=f, g) fi;
%p A395243          b(n, subsop(k=f, l))+b(n, g)
%p A395243       fi
%p A395243     end:
%p A395243 A:= (n, k)->(b(max(k,n), [true$(min(k,n)*3)])):
%p A395243 seq(seq(A(n, d-n), n=0..d), d=0..10);
%Y A395243 Rows (or columns) n=0-5 give: A000012, A000079, A189145(k+2), A321251, A392323, A394505.
%Y A395243 Main diagonal gives A141243.
%Y A395243 Cf. A244081.
%K A395243 nonn,tabl,new
%O A395243 0,5
%A A395243 _Alois P. Heinz_, Jul 12 2026
