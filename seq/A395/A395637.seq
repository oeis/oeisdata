%S A395637 1,0,2,0,0,1,2,0,0,0,3,2,2,0,0,1,2,2,2,0,2,3,2,0,0,0,0,2,2,2,2,3,2,0,
%T A395637 2,2,0,0,0,2,2,2,3,0,4,3,0,3,2,0,0,2,4,4,2,1,0,2,2,2,2,4,0,3,4,2,0,0,
%U A395637 2,0,2,4,2,4,0,2,2,2,2,0,2,2,2,4,2,0
%N A395637 a(n) = number of triples (x, y, z) such that 2*x^2 + y*z = n, where x, y, z are primes, not necessarily distinct.
%e A395637 a(12) = 1 counts this triple: (2,2,2).
%e A395637 a(22) = 3 counts these triples: (2,2,7), (2,7,2), (3,2,2).
%t A395637 t[n_, c_] := Module[{r}, r = Flatten[Table[If[n - 2 x^2 <= 0, {},
%t A395637 Map[({x, #, Quotient[n - 2 x^2, #]} &),
%t A395637 Select[Divisors[n - 2 x^2], Divisible[n - 2 x^2, #] &]]],
%t A395637 {x, 1, Floor[Sqrt[n - 1]]}], 1]; Select[r, Apply[c, #] &]];
%t A395637 c = (PrimeQ[#1] && PrimeQ[#2] && PrimeQ[#3] &);
%t A395637 Table[Length[t[n, c]], {n, 12, 130}]
