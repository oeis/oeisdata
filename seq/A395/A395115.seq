%I A395115 #26 May 27 2026 16:21:47
%S A395115 2283,5,17,3,9,5,41,3,17,5,4,3,15,5,9,3,54,5,569,3,17,4,69,3,9,5,17,3,
%T A395115 29,5,756,3,4,5,9,3,25,5,15,3,41,5,64,3,9,5,141,3,41,5,17,3,53,5,4,3,
%U A395115 17,5,617,3,2283,5,17,3,9,4,1005,3,17,5,267,3,663,5
%N A395115 Smallest integer m > 1 such that gcd(m^(3*n) - 1, m! - 1) > 1.
%C A395115 For all n >= 1, 3 <= a(n) <= a(1) = 2283.
%C A395115 The number of integers 1 < m < 10000 satisfying gcd(m^(3*n) - 1, m! - 1) > 1 does not grow monotonically as n increases. Indeed, there is 1 solution for n = 1, 4 solutions for n = 2, 4 solutions for n = 3, 7 solutions for n = 4, 5 solutions for n = 5, 8 solutions for n = 6, 4 solutions for n = 7, and so forth (nevertheless, computations for large values of n strongly suggest a substantial long-term growth trend).
%C A395115 Moreover, the author observes that m = 2283 and m = 138645 satisfy gcd(m^(3*n) - 1, m! - 1) > 1 for each integer n >= 1.
%H A395115 MathOverflow, <a href="https://mathoverflow.net/questions/510302/if-gcdn3-1-n-11-must-it-be-equal-to-140929">If gcd(n^3-1, n!-1)>1, must it be equal to 140929?</a>.
%H A395115 MathOverflow, <a href="https://mathoverflow.net/questions/510656/can-gcdnk-pm-1-hspace2mm-n-pm-11-have-arbitrarily-many-but-finitel">Can gcd(n^k +- 1, n !+- 1) > 1 have arbitrarily many but finitely many solutions?</a>.
%e A395115 a(1) = 2283 since 1 < gcd(2283^(3*1) - 1, 2283! - 1) = 140929.
%t A395115 a[n_]:=Module[{m=2},While[GCD[m^(3*n)-1,m!-1]<=1, m++]; m]; Array[a,74] (* _Stefano Spezia_, May 12 2026 *)
%o A395115 (Python)
%o A395115 import math
%o A395115 def a(n):
%o A395115     k = 3*n
%o A395115     f = 1
%o A395115     for m in range(1, 2284):
%o A395115         f *= m
%o A395115         if m >= 2 and math.gcd(m**k - 1, f - 1) > 1:
%o A395115             return m
%o A395115 print([a(n) for n in range(1, 75)])
%o A395115 (PARI) a(n) = my(m=2); while (gcd(m^(3*n) - 1, m! - 1) == 1, m++); m; \\ _Michel Marcus_, May 13 2026
%Y A395115 Cf. A033312, A395171, A395286.
%K A395115 nonn
