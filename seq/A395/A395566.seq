%N A395566 Sum of the distinct prime divisors of C(6*n, n).
%H A395566 Vincenzo Librandi, <a href="/A395566/b395566.txt">Table of n, a(n) for n = 1..1000</a>
%F A395566 a(n) = sopf(binomial(6*n,n)) = A008472(A004355(n)).
%e A395566 a(2) = 16 because binomial(12,2) = 132 = 2^2*3*11 and 2+3+11 = 16.
%e A395566 a(3) = 22 because binomial(18,3) = 306 = 2*3^2*17 and 2+3+17 = 22.
%t A395566 a[n_]:=Total[FactorInteger[Binomial[6*n,n]][[All,1]]];Table[a[n],{n,1,80}]
%o A395566 (Magma) a := func<n | &+PrimeDivisors(Binomial(6*n, n))>; N := 70; [a(n) : n in [1..N]];
%Y A395566 Cf. A008472, A004355, A034387, A394454, A394591, A394592, A394593, A395515.
%K A395566 nonn,new
%O A395566 1,1
