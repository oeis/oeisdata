%e A395726   [5] 0, 1,  32,  63,  364,   665,   966,   2667,   4368,   6069, ...
%e A395726   [6] 0, 1,  64, 127, 1093,  2059,  3025,  10795,  18565,  26335, ...
%e A395726   [7] 0, 1, 128, 255, 3280,  6305,  9330,  43435,  77540, 111645, ...
%e A395726   [8] 0, 1, 256, 511, 9841, 19171, 28501, 174251, 320001, 465751, ...
%e A395726   [A000007,A000012,A000079,A000225,A003462,A001047,A000392,A006095,A016208,A016269,...]
%o A395726 (PARI) A002024(n) = (sqrtint(8*n-7)+1)\2
%o A395726 list_column(n, k) = my(v1 = vector(A002024(k+1), i, 0), v2 = vector(n+1, i, 0), v3); v1[1] = k; v2[1] = 1; for(i=2, #v1, v1[i] = v1[i-1] - A002024(v1[i-1])); v1 = Vecrev(v1); for(i=2, #v1, v3 = vector(n+1, i, 0); v3[1] = 1; A = v1[i] - v1[i-1]; for(j=1, n, v3[j+1] = v2[j+1] + A*v3[j]); v2 = v3); v2
%Y A395726 Cf. A000007, A000012, A000027, A000079, A000225, A000392, A001047, A002024, A002260, A003462, A006095, A016208, A016269.
