%I A395516 #9 May 05 2026 00:07:28
%S A395516 336,378,624,702,880,2064,2322,3280,7296,7888,8208,8500,9234,10880,
%T A395516 11904,13392,13888,14500,15066,18560,32384,43065,44500,52080,52728,
%U A395516 52785,56960,58590,61054,87880,92169,92625,95232,97461,100464,101430,103968,107136,108528,113022
%N A395516 Numbers k such that A008472(k) and A001414(k) share the same squarefree kernel but neither divides the other.
%C A395516 Numbers k such that both the sum of distinct prime factors of k (i.e., s(k) = A008472(k)) and the sum of prime factors with multiplicity (i.e., t(k) = A001414(k)) have the same squarefree kernel, yet neither divides the other.
%C A395516 Proper subset of A013929, since squarefree k implies s(k) = t(k).
%C A395516 Proper subset of A126706, since perfect prime powers p^m (in A246547), with m > 1, are such that s(p^m) = p and t(p^m) = m*p = m*s(p^m), thus s(p^m) | t(p^m), yet s(p^m) < t(p^m), m > 1.
%C A395516 Proper subset of A059404, since since for perfect powers k^m, m > 1 in A303606, with squarefree composite k (in A120944), s(k^m) = s(k) and t(k^m) = t(m*k) = m*s(k), thus s(k^m) | t(k^m).
%H A395516 Michael De Vlieger, <a href="/A395516/b395516.txt">Table of n, a(n) for n = 1..1835</a>
%e A395516 Let m = rad(s(k)) = rad(t(k)), where rad = A007947.
%e A395516      n       a(n) = k                      s(k)  t(k)    m
%e A395516   --------------------------------------------------------
%e A395516      1        336 = 2^4 * 3 * 7             12    18     6
%e A395516      2        378 = 2 * 3^3 * 7             12    18     6
%e A395516      3        624 = 2^4 * 3 * 13            18    24     6
%e A395516      4        702 = 2 * 3^3 * 13            18    24     6
%e A395516     17      13888 = 2^6 * 7 * 31            40    50    10
%e A395516     22      43065 = 3^3 * 5 * 11 * 29       48    54     6
%e A395516     24      52080 = 2^4 * 3 * 5 * 7 * 31    48    54     6
%e A395516     29      61054 = 2 * 7^3 * 89            98   112    14
%e A395516     37     103968 = 2^5 * 3^2 * 19^2        24    54     6
%e A395516     43     116964 = 2^2 * 3^4 * 19^2        24    54     6
%e A395516    120     647496 = 2^3 * 3^2 * 17 * 23^2   45    75    15
%e A395516   1148   28005264 = 2^4 * 3^6 * 7^4         12    54     6
%t A395516 nn = 2^17; facs[x_] := facs[x] = FactorInteger[x];
%t A395516 rad[x_] := Times @@ facs[x][[All, 1]];
%t A395516 s[x_] := If[x == 1, 0, Total@facs[x][[All, 1]] ];
%t A395516 t[x_] := If[x == 1, 0, Total[Join @@ ConstantArray @@@ facs[x] ] ];
%t A395516 r = Select[Range[nn], Nor[SquareFreeQ[#], PrimePowerQ[#] ] &];
%t A395516 Select[r, And[! Divisible[#2, #1], rad[#1] == rad[#2] ] & @@ {s[#], t[#]} &]
%Y A395516 Cf. A001414, A007947, A008472, A013929, A027746, A027748, A126706, A246547, A303606.
%K A395516 nonn,new
%O A395516 1,1
%A A395516 _Michael De Vlieger_, Apr 26 2026
