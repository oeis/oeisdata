%I A395425 #12 Apr 22 2026 10:14:24
%S A395425 0,1,2,3,4,5,6,7,8,12,10,14,9,13,11,15,16,17,24,25,20,21,28,29,18,19,
%T A395425 26,27,22,23,30,31,32,48,34,50,36,52,38,54,40,56,42,58,44,60,46,62,33,
%U A395425 49,35,51,37,53,39,55,41,57,43,59,45,61,47,63,64,65,96,97
%N A395425 In the binary expansion of n without leading zeros, say (b_1, b_2, ..., b_w), reverse even-indexed bits.
%C A395425 A self-inverse permutation of the nonnegative integers.
%H A395425 Rémy Sigrist, <a href="/A395425/b395425.txt">Table of n, a(n) for n = 0..8192</a>
%H A395425 <a href="/index/Bi#binary">Index entries for sequences related to binary expansion of n</a>
%H A395425 <a href="/index/Per#IntegerPermutation">Index entries for sequences that are permutations of the natural numbers</a>
%F A395425 A000120(a(n)) = A000120(n).
%e A395425 The binary expansion of 67 is "1000011" and yields "1100001", so a(67) = 97.
%e A395425                                 | | |                | | |
%e A395425                                 | | +----------------+ | |
%e A395425                                 | +--------------------+ |
%e A395425                                 +------------------------+
%o A395425 (PARI) a(n, base = 2) = { my (d = digits(n, base), u = 2, v = (#d\2)*2); while (u < v, [d[u], d[v]] = [d[v], d[u]]; u += 2; v -= 2;); fromdigits(d, base); }
%Y A395425 Cf. A000120, A371459.
%K A395425 nonn,base,easy,look,new
%O A395425 0,3
%A A395425 _Rémy Sigrist_, Apr 22 2026
