%I A395346 #24 Apr 27 2026 01:19:48
%S A395346 19,23,37,41,43,47,61,79,131,137,193,223,227,229,263,277,281,311,313,
%T A395346 317,353,397,409,421,443,457,463,499,601,643,677,691,809,811,821,823,
%U A395346 827,829,863,877,881,883,971,1013,1031,1033,1093,1103,1153,1163,1171,1181
%N A395346 Primes that begin a pair of consecutive primes with the same number of digits and a prime-valued digit dot product.
%e A395346 19 is included because it is followed by the prime 23, both are two-digit numbers, and their digit dot product 1*2 + 9*3 = 29 which is prime.
%p A395346 q:= 2: Lq:= [2]: nq:= 1: count:= 0: R:= NULL:
%p A395346 while count < 100 do
%p A395346   p:= q; Lp:= Lq; np:= nq;
%p A395346   q:= nextprime(p); Lq:= convert(q,base,10); nq:= nops(Lq);
%p A395346   if np = nq and isprime(add(Lp[i]*Lq[i],i=1..np)) then R:= R,p; count:= count+1 fi
%p A395346 od:
%p A395346 R; # _Robert Israel_, Apr 20 2026
%t A395346 q[p_] := IntegerLength[p[[1]]] == IntegerLength[p[[2]]] && PrimeQ[IntegerDigits[p[[1]]].IntegerDigits[p[[2]]]]; Select[Partition[Prime[Range[200]], 2, 1], q][[;; , 1]] (* _Amiram Eldar_, Apr 20 2026 *)
%o A395346 (PARI) is(p)=my(q=nextprime(p+1),u=digits(p),v=digits(q));if(#u==#v,my(r=u*v~);return(ispseudoprime(r)));0
%Y A395346 Cf. A000040, A033994, A337574.
%K A395346 nonn,base,new
%O A395346 1,1
%A A395346 _Jean-Marc Rebert_, Apr 20 2026
