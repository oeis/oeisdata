%p A395701 T := (n, k) -> binomial(n, k) * k^k: seq(print(seq(T(n, k), k = 0..n)), n = 0..9);
%t A395701 A395701[n_, k_] := If[k == 0, 1, Binomial[n, k]*k^k];
%t A395701 Table[A395701[n, k], {n, 0, 10}, {k, 0, n}] (* _Paolo Xausa_, May 10 2026 *)
%o A395701 (Python)
%o A395701 def A395701triangle(size: int) -> list[list[int]]:
%o A395701     tri = []
%o A395701     mm = [1] + [m ** m for m in range(1, size+1)]
%o A395701     for n in range(size):
%o A395701         Qrow = [0]*(n+1)
%o A395701         binom = 1
%o A395701         for m in range(n+1):
%o A395701             if m > 0: binom = binom * (n - m + 1) // m
%o A395701             Qrow[m] = binom * mm[m]
%o A395701         tri.append(Qrow)
%o A395701     return tri
%o A395701 for row in A395701triangle(9): print(row)
