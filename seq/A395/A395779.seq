%U A395779 148048546150899,1035347613355212,7225423763357031,50330772078599808,350009710750032624,2430378171200375472
%N A395779 Expansion of (Sum_{k>=0} binomial(3*k+1,k) * x^k)^3.
%F A395779 a(n) = Sum_{i,j,k >= 0 and i+j+k=n} binomial(3*i+1,i) * binomial(3*j+1,j) * binomial(3*k+1,k).
%F A395779 G.f.: B(x)^3 where B(x) is the g.f. of A045721.
%F A395779 a(n) = Sum_{k=0..n} (k+1) * 2^k * binomial(3*n+5,n-k).
%F A395779 a(n) = Sum_{k=0..n} (k+1) * 3^k * binomial(3*n+3-k,n-k).
%F A395779 a(0) = 1; a(n) = (1/n) * Sum_{k=0..n-1} (3*k+12) * 2^k * binomial(k+2,2) * binomial(3*n+5,n-1-k).
%F A395779 a(0) = 1; a(n) = (1/n) * Sum_{k=0..n-1} (2*k+12) * 3^k * binomial(k+2,2) * binomial(3*n+2-k,n-1-k).
%o A395779 (PARI) a(n) = sum(k=0, n, (k+1)*2^k*binomial(3*n+5, n-k));
