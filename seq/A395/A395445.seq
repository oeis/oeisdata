%N A395445 Numbers k such that sigma(k) = psi(k) + tau(k)^5 + Omega(k)^5.
%C A395445 From _David A. Corneth_, Apr 28 2026: (Start)
%C A395445 Contains 218617*p^2 where p is prime and gcd(218617, p) = 1.
%C A395445 Contains 247777*p^2 where p is prime and gcd(247777, p) = 1.
%C A395445 Hence the sequence is infinite. (End)
%e A395445 228069 is a term since sigma(228069) = 337920 = 304128 + 8^5 + 4^5 = psi(228069) + tau(228069)^5 + Omega(228069)^5.
%o A395445 (PARI) isok(k) = {my(f = factor(k)); sigma(f) == prod(i=1, #f~, (f[i, 1]+1) * f[i, 1]^(f[i, 2]-1)) + numdiv(f)^5 + bigomega(f)^5; } \\ _Amiram Eldar_, Apr 23 2026
