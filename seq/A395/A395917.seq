%I A395917 #10 May 20 2026 10:46:10
%S A395917 0,1,1,2,1,3,4,1,5,5,6,4,11,1,10,6,6,7,20,1,15,5,20,2,17,7,28,1,22,8,
%T A395917 8,9,21,19,14,21,23,20,27,11,19,24,11,22,27,15,34,1,37,3,47,2,46,12,
%U A395917 30,29,37,8,40,7,63,4,57,12,40,11,45,23,54,16,55,16,56
%N A395917 a(0) = 0, and then a(n) is the numbers of ways to write a(n-1) as a(i) XOR a(j) with i <= j < n (where XOR denotes the bitwise XOR operator).
%C A395917 This sequence is unbounded (the proof is similar to that for A395907).
%C A395917 The sequence contains infinitely many 1's: if a(n) >= 2^k while a(0), ..., a(n-1) < 2^k for some k >= 0, then a(n+1) = 1.
%H A395917 Rémy Sigrist, <a href="/A395917/b395917.txt">Table of n, a(n) for n = 0..10000</a>
%H A395917 Rémy Sigrist, <a href="/A395917/a395917.txt">C++ program</a>
%F A395917 a(n) <= A000217(n).
%e A395917 The first terms are:
%e A395917   n   a(n)  a(n-1)
%e A395917   --  ----  ----------------------------------------------------------
%e A395917    0     0  N/A
%e A395917    1     1  a(0) XOR a(0)
%e A395917    2     1  a(0) XOR a(1)
%e A395917    3     2  a(0) XOR a(1), a(0) XOR a(2)
%e A395917    4     1  a(0) XOR a(3)
%e A395917    5     3  a(0) XOR a(1), a(0) XOR a(2), a(0) XOR a(4)
%e A395917    6     4  a(0) XOR a(5), a(1) XOR a(3), a(2) XOR a(3), a(3) XOR a(4)
%e A395917    7     1  a(0) XOR a(6)
%o A395917 (C++) // See Links section.
%o A395917 (Python)
%o A395917 from itertools import islice
%o A395917 from collections import Counter
%o A395917 def agen(): # generator of terms
%o A395917     alst, ways = [0], Counter()
%o A395917     while True:
%o A395917         yield alst[-1]
%o A395917         ways.update(alst[i]^alst[-1] for i in range(len(alst)))
%o A395917         alst.append(ways[alst[-1]])
%o A395917 print(list(islice(agen(), 75))) # _Michael S. Branicky_, May 13 2026
%Y A395917 Cf. A000217, A358799, A395907, A395918.
%K A395917 nonn,base
%O A395917 0,4
%A A395917 _Rémy Sigrist_, May 10 2026
