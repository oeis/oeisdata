%I A395120 #15 Apr 12 2026 08:41:15
%S A395120 1,2,9,64,685,10476,215509,5666312,183543273,7137049240,326782329841,
%T A395120 17352063114948,1055369076070621,72766763396638052,
%U A395120 5638364385224554845,487334952125900755696,46681937581428100321521,4927781674483709948617968,570356723889408395906505433,72056606726025233419552410620
%N A395120 E.g.f. satisfies A(x) = Sum_{n>=0}  A^n(x) * x^n/n!, where A^n(x) denotes the n-th iteration of A(x) with A^0(x) = x.
%H A395120 Paul D. Hanna, <a href="/A395120/b395120.txt">Table of n, a(n) for n = 1..100</a>
%F A395120 E.g.f. A(x) = Sum_{n>=1} a(n)*x^n/n! satisfies the following formulas.
%F A395120 (1) A(x) = Sum_{n>=0} A^n(x) * x^n / n!.
%F A395120 (2) A(A(x)) = Sum_{n>=0} A^(n+1)(x) * A(x)^n / n!.
%F A395120 (3) A^(k+1)(x) = Sum_{n>=0} A^(n+k)(x) * A^k(x)^n / n!.
%F A395120 a(n) = Sum_{k=1..n-1} binomial(n,k) * [x^k/k!] A^(n-k)(x) for n > 1 with a(1) = 1.
%e A395120 E.g.f.: A(x) = x + 2*x^2/2! + 9*x^3/3! + 64*x^4/4! + 685*x^5/5! + 10476*x^6/6! + 215509*x^7/7! + 5666312*x^8/8! + 183543273*x^9/9! + ...
%e A395120 where
%e A395120 A(x) = x + x*A(x) + x^2*A(A(x))/2! + x^3*A(A(A(x)))/3! + x^4*A(A(A(A(x))))/4! + ... + x^n*A^n(x)/n! + ....
%e A395120 The table of coefficients of x^k/k! in the n-th iteration of A(x) begins
%e A395120   n = 1: [1,  2,   9,   64,    685,    10476,     215509, ...];
%e A395120   n = 2: [1,  4,  30,  332,   5000,    97662,    2393524, ...];
%e A395120   n = 3: [1,  6,  63,  948,  18825,   469818,   14270655, ...];
%e A395120   n = 4: [1,  8, 108, 2056,  50920,  1563444,   57640072, ...];
%e A395120   n = 5: [1, 10, 165, 3800, 112925,  4129680,  180054385, ...];
%e A395120   n = 6: [1, 12, 234, 6324, 219360,  9320706,  470157324, ...];
%e A395120   n = 7: [1, 14, 315, 9772, 387625, 18776142, 1076644219, ...];
%e A395120   ...
%e A395120 From the table above we may calculate the terms of this sequence
%e A395120   a(2) = 2*1 = 2 ;
%e A395120   a(3) = 3*1 + 3*2 = 9 ;
%e A395120   a(4) = 4*1 + 6*4 + 4*9 = 64 ;
%e A395120   a(5) = 5*1 + 10*6 + 10*30 + 5*64 = 685 ;
%e A395120   a(6) = 6*1 + 15*8 + 20*63 + 15*332 + 6*685 = 10476 ;
%e A395120   a(7) = 7*1 + 21*10 + 35*108 + 35*948 + 21*5000 + 7*10476 = 215509 ;
%e A395120   ...
%e A395120 illustrating the recurrence
%e A395120   a(n) = Sum_{k=1..n-1} binomial(n,k) * [x^k/k!] A^(n-k)(x) for n > 1 with a(1) = 1.
%e A395120 The recurrence follows from the explicit expansions shown by
%e A395120 A(x) = x + x*(x + 2*x^2/2! + 9*x^3/3! + 64*x^4/4! + ...)
%e A395120  + x^2/2!*(x + 4*x^2/2! + 30*x^3/3! + 332*x^4/4! + ...)
%e A395120  + x^3/3!*(x + 6*x^2/2! + 63*x^3/3! + 948*x^4/4! + ...)
%e A395120  + x^4/4!*(x + 8*x^2/2! + 108*x^3/3! + 2056*x^4/4! + ...)
%e A395120  + x^5/5!*(x + 10*x^2/2! + 165*x^3/3! + 3800*x^4/4! + ...)
%e A395120  + ...
%o A395120 (PARI) \\ Routine to calculate the n-th iteration
%o A395120 {IT(n,F) = my(G=x); for(i=1,n, G = subst(F,x,G)); G}
%o A395120 \\ Calculate A(x) from iterations of A(x)
%o A395120 {a(n) = my(A=x); for(k=1,n, A = truncate(A) + x*O(x^k);
%o A395120 A = sum(m=0,k, x^m/m! * IT(m,A) ) ); polcoef(EGF=A,n)}
%o A395120 {upto(n) = a(n); Vec(serlaplace(EGF))}
%o A395120 upto(20)
%Y A395120 Cf. A120567, A395121.
%K A395120 nonn
%O A395120 1,2
