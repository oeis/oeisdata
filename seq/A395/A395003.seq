%S A395003 1,3,5,9,17,33,105,151,421,933,1705,3767,7535,15727,31497,64265,
%T A395003 128751,257503,519647,647089,2078655,3972403,8353727,10610063,
%U A395003 33512303,66969471,134082495,268164991,536600447,1073462239,2146402047,2281422937,8587804415,17178680799
%N A395003 a(n) is the smaller of the two factors whose product is A394991.
%C A395003 The factors may be equal, but no example for n>2 is known.
%e A395003 See A394987.
%o A395003 (Python)
%o A395003 from sympy.utilities.iterables import multiset_permutations
%o A395003 from sympy import divisors
%o A395003 def A395003(n):
%o A395003     a = 1<<n-1
%o A395003     b = a<<1
%o A395003     k = (n<<1)-1
%o A395003     c = (1<<k+1)-1
%o A395003     for l in range(k,0,-1):
%o A395003         for s in multiset_permutations('0'*l+'1'*(k+1-l)):
%o A395003             m = c-int(''.join(s),2)
%o A395003             for d in divisors(m):
%o A395003                 if d**2>m:
%o A395003                     break
%o A395003                 if a<=d<b and a*d<=m<b*d:
%o A395003                     return d # _Chai Wah Wu_, Apr 11 2026
%Y A395003 A395004 is the larger factor.
%Y A395003 Cf. A029837, A394987, A394989, A394990, A394991.
%K A395003 nonn,new
%O A395003 1,2
%A A395003 _Hugo Pfoertner_, Apr 09 2026
%E A395003 a(24)-a(34) from _Chai Wah Wu_, Apr 09 2026
