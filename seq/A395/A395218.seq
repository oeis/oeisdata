%U A395218 2,2,1,7,9,3,1,4,8,2,9,6,9,0,6,6,3,5,0,2,5,4,5,5,9,3,7,2,8,4,8,2,4,7,7,8,1
%N A395218 Entropy of the zeta probability distribution with parameter s=2.
%C A395218 Entropy (in 'nats') of a discrete probability distribution on natural numbers is defined as Sum_{k>=1} (-m(k)*log(m(k))), where m(k) is the mass distribution function.
%C A395218 For zeta distribution with parameter s, m(k) = 1/k^s/zeta(s).
%C A395218 This constant corresponds to s = 2.
%H A395218 Stanislav Sykora, <a href="/A395218/b395218.txt">Table of n, a(n) for n = 1..1000</a>
%H A395218 Wikipedia, <a href="https://en.wikipedia.org/wiki/Zeta_distribution">Zeta distribution</a>.
%H A395218 Wikipedia, <a href="https://en.wikipedia.org/wiki/Entropy_(information_theory)">Entropy (information theory)</a>.
%F A395218 Equals -Sum_{k>=1} (log(1/k^2/zeta(2))/k^2/zeta(2)).
%F A395218 Equals log(zeta(2))-2*zeta'(2)/zeta(2).
%F A395218 Equals 24*log(A074962) - 2*A001620 - log(24). - _Vaclav Kotesovec_, Apr 22 2026
%e A395218 1.63762228865981096...
%t A395218 RealDigits[24*Log[Glaisher] - 2*EulerGamma - Log[24], 10, 105][[1]] (* _Vaclav Kotesovec_, Apr 22 2026 *)
%o A395218 (PARI) \p200
%o A395218 s=2;zs=zeta(s);
%o A395218 a=log(zs)-(s/zs)*zeta'(s);
%o A395218 precision(a,105)
%Y A395218 Cf. A395219 (s=3), A395220 (s=4).
%Y A395218 Cf. A013661, A073002.
%Y A395218 Cf. A001620, A074962.
%K A395218 nonn,cons,new
%O A395218 1,2
%A A395218 _Stanislav Sykora_, Apr 17 2026
