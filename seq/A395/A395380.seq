%N A395380 a(1) = 4; for n > 1, a(n) is the number of integers k in [prime(n-1)^8..prime(n)^8 - 1] with exactly 9 divisors.
%H A395380 Chai Wah Wu, <a href="/A395380/b395380.txt">Table of n, a(n) for n = 1..412</a>
%e A395380 a(1) = 4 because [1..255] contains 4 numbers 36, 100, 196, 225 with exactly 9 divisors;
%e A395380 a(2) = 19 because [256..6560] contains 19 numbers 256, 441, 484, 676, 1089, 1156, 12225, 1444, 1521, 2116, 2601, 3025, 3249, 3364, 3844, 4225, 4761, 5476, 5929 with exactly 9 divisors;
%e A395380 a(3) = 160 because [6561..390624] contains 160 numbers 6561, 6524, 7225, ..., 388129 with exactly 9 divisors.
%o A395380 (Magma) [4] cat [#[k: k in [NthPrime(n-1)^8..NthPrime(n)^8-1] | #Divisors(k) eq 9]: n in [2..4]];
%o A395380 (Python)
%o A395380 from math import comb
%o A395380 from sympy import prime, primepi, primerange
%o A395380 def A395380(n):
%o A395380     if n == 1: return 4
%o A395380     def f(x):
%o A395380         s = prime(x)**2
%o A395380         y = s**2
%o A395380         return int(-(t:=primepi(s))-comb(t,2)+sum(primepi(y//k) for k in primerange(1, s+1)))
%o A395380     return 1+f(n)-f(n-1) # _Chai Wah Wu_, Apr 23 2026
