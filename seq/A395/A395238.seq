%U A395238 625854611007356458243774507,1144942351310268783206394481177,2466425847371810687519551253553247
%N A395238 a(n) = (2*n)! * [x^(2*n)] (f(x) + f(-x))/2 and f(x) = 1/(cosh(x) - 2 * sinh(x)).
%F A395238 a(n) = (2*n)! * [x^(2*n)] cosh(x)/(1 - 3*sinh(x)^2).
%F A395238 Let A(n,k) = (2*n)! * [x^(2*n)] (f(x)^k + f(-x)^k)/2. A(0,k) = 1 and A(0,k) = 1 and A(n,k) = 3*k*(k+1) * A(n-1,k+2) + k^2 * A(n-1,k) for n > 0. a(n) = A(n,1).
%o A395238 (PARI) a(n) = my(x='x+O('x^(2*n+1))); (2*n)!*polcoef(cosh(x)/(1-3*sinh(x)^2), 2*n);
