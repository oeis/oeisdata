%S A395381 12,254,14555,220397,10251887,32883544,386214098,686526363,4665218030,
%T A395381 37045468979,33464687016,277535584514,509216235683,442678008025,
%U A395381 1525098385911,5228913860475,12469865414304,6929152649967,34817529046730,41065452601877,28387924629796
%N A395381 a(1) = 12; for n > 1, a(n) is the number of integers k from [prime(n-1)^9..prime(n)^9 - 1] with exactly 10 divisors.
%e A395381 a(1) = 12 because [1..511] contains 12 numbers 48, 80, 112, 162, 176, 208, 272, 304, 368, 405, 464, 496 with exactly 10 divisors;
%e A395381 a(2) = 254 because [512..19682] contains 254 numbers 512, 567, 592, 676, ..., 19664 with exactly 10 divisors;
%e A395381 a(3) = 14555 because [19683..1953124] contains 14555 numbers 19683, 19696, 19792, ..., 1953104 with exactly 10 divisors.
%o A395381 (Magma) [12] cat [#[k: k in [NthPrime(n-1)^9..NthPrime(n)^9-1] | #Divisors(k) eq 10]: n in [2..3]];
%o A395381 (Python)
%o A395381 from sympy import prime, primepi, primerange, integer_nthroot
%o A395381 def A395381(n):
%o A395381     if n == 1: return 12
%o A395381     def f(x):
%o A395381         p = prime(x)**9
%o A395381         return sum(primepi(p//k**4) for k in primerange(integer_nthroot(p,4)[0]+1))-primepi(integer_nthroot(p,5)[0])
%o A395381     return 1+f(n)-f(n-1) # _Chai Wah Wu_, Apr 21 2026
