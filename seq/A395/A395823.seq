%I A395823 #29 May 11 2026 14:53:46
%S A395823 2,3,4,6,7,8,9,11,14,15,16,18,19,20,21,23,24,25,33,36,38,40,43
%N A395823 Record lengths of runs of consecutive integers k such that Omega(k) is odd.
%C A395823 Equivalently, record lengths of runs where the Liouville function A008836(k) is -1.
%C A395823 For m >= 1, let r(m) be the largest k >= 0 such that A001222(m), ..., A001222(m+k-1) are odd. This sequence lists the successive record values of r(m).
%e A395823 A001222(2) = A001222(3) = 1 and A001222(4) = 2, so the first record run has length 2.
%e A395823 The first record runs have lengths 2, 3, 4, 6 and occur at 2..3, 11..13, 17..20, 27..32.
%o A395823 (Python)
%o A395823 from sympy import factorint
%o A395823 A001222 = []
%o A395823 for i in range(2, 10**8 + 1):
%o A395823     A001222.append(sum(factorint(i).values()))
%o A395823 seq_record_length_odd = []
%o A395823 odd_record = 0
%o A395823 counter = 0
%o A395823 for i in A001222:
%o A395823     if i%2:
%o A395823         counter += 1
%o A395823     else:
%o A395823         if counter > odd_record:
%o A395823             odd_record = counter
%o A395823             seq_record_length_odd.append(counter)
%o A395823         counter = 0
%o A395823 print(seq_record_length_odd)
%Y A395823 Cf. A001222, A008836, A395824, A066829, A026424, A066794.
%K A395823 nonn,more,new
%O A395823 1,1
%A A395823 _Anselm Hudde_, May 07 2026
