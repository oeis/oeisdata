%S A395031 1,55,249,667,1393,2511,4105,6259,9057,12583,16921,22155,28369,35647,
%T A395031 44073,53731,64705,77079,90937,106363,123441,142255,162889,185427,
%U A395031 209953,236551,265305,296299,329617,365343,403561,444355,487809,534007,583033,634971,689905
%N A395031 a(n) = 14*n^3 + 28*n^2 + 12*n + 1.
%C A395031 This polynomial is a member of a family of polynomials whose coefficients are given in A108767. These polynomials can be viewed as a generalization of the Narayana polynomials, which extend the analysis from the binary case to the ternary case, taking into account the specific color structure described in A395080 and generate the column structure of that array. The present polynomial corresponds to column k = 3 there.
%H A395031 Paolo Xausa, <a href="/A395031/b395031.txt">Table of n, a(n) for n = 0..10000</a>
%H A395031 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (4,-6,4,-1).
%F A395031 a(n) = A395080(n, 3).
%F A395031 From _Stefano Spezia_, Apr 11 2026: (Start)
%F A395031 G.f.: (1 + 51*x + 35*x^2 - 3*x^3)/(1 - x)^4.
%F A395031 E.g.f.: exp(x)*(1 + 54*x + 70*x^2 + 14*x^3). (End)
%p A395031 a := n -> 14*n^3 + 28*n^2 + 12*n + 1: seq(a(n), n = 0..36);
%t A395031 A395031[n_] := 2*n*(7*n*(n + 2) + 6) + 1; Array[A395031, 50, 0] (* or *)
%t A395031 LinearRecurrence[{4, -6, 4, -1}, {1, 55, 249, 667}, 50] (* _Paolo Xausa_, Apr 12 2026 *)
%Y A395031 Cf. A395080, A108767.
