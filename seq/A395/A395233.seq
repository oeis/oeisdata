%S A395233 1,1,0,1,7,0,1,20,305,0,1,39,1456,33367,0,1,64,4209,223040,6815585,0,
%T A395233 1,95,9536,856119,58575616,2237423527,0,1,132,18625,2477824,280529889,
%U A395233 23502402560,1077270776465,0,1,175,32880,6004895,989029376,134938524999,13373331582976,715153093789687,0
%N A395233 Square array A(n,k), n>=0, k>=0, read by antidiagonals downwards, where A(n,k) = (2*n)! * [x^(2*n)] (f(x)^k + f(-x)^k)/2 and f(x) = 1/(cos(x) + sqrt(3) * sin(x)).
%H A395233 Paolo Xausa, <a href="/A395233/b395233.txt">Table of n, a(n) for n = 0..11324</a> (first 150 antidiagonals, flattened).
%F A395233 A(0,k) = 1 and A(n,k) = 4*k*(k+1) * A(n-1,k+2) - k^2 * A(n-1,k) for n > 0.
%e A395233 Square array begins:
%e A395233   1,       1,        1,         1,         1, ...
%e A395233   0,       7,       20,        39,        64, ...
%e A395233   0,     305,     1456,      4209,      9536, ...
%e A395233   0,   33367,   223040,    856119,   2477824, ...
%e A395233   0, 6815585, 58575616, 280529889, 989029376, ...
%t A395233 A395233[n_, k_] := A395233[n, k] = If[n == 0, 1, 4*k*(k+1)*A395233[n-1, k+2] - k^2*A395233[n-1, k]];
%t A395233 Table[A395233[k, n-k], {n, 0, 10}, {k, 0, n}] (* _Paolo Xausa_, Apr 17 2026 *)
%o A395233 (PARI) a(n, k) = if(n==0, 1, 4*k*(k+1)*a(n-1, k+2)-k^2*a(n-1, k));
%Y A395233 Columns k=0..2 give A000007, A002437, A390232.
%Y A395233 Cf. A341268, A394320, A395232.
%K A395233 nonn,tabl,new
%O A395233 0,5
