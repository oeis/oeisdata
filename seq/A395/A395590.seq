%o A395590 (Magma)
%o A395590 SetClassGroupBounds("GRH");
%o A395590 primes := [p : p in [2..400] | IsPrime(p)];
%o A395590 for k in primes do
%o A395590     a := #IntegralPoints(EllipticCurve([0,0,0,0,-k^3]));
%o A395590     if a gt 1 then
%o A395590         print k;
%o A395590     end if;
%o A395590 end for;
