%F A395535 a(2^k-1) = 2^k, for k > 0.
%t A395535 a[n_]:=BitXor[n,If[Mod[n,2]==1,2*n+1,n/2]]; Array[a,65,0] (* _Stefano Spezia_, Apr 28 2026 *)
%o A395535 (PARI) a(n)= bitxor(n, if(n%2, n*2+1, n/2))
