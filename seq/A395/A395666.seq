%U A395666 121213348563055522620,13451291464272198318000,1661491487654861837825792,227034344378937593407940658,34132920425796903289772447628
%N A395666 E.g.f. A(x) satisfies A(x) = 1 + x * A(x * exp(x)).
%F A395666 a(0) = 1; a(n) = n * Sum_{k=0..n-1} k^(n-k-1) * binomial(n-1,k) * a(k).
%e A395666 A(x)      = 1 + x + x^2 + 2*x^3 + 9/2*x^4 + 38/3*x^5 + 985/24*x^6 + ...
%e A395666 A(x * exp(x)) = 1 + x   + 2*x^2 + 9/2*x^3 + 38/3*x^4 + 985/24*x^5 + ...
%o A395666 (PARI) a_vector(n, s=1, t=0) = my(v=vector(n+1)); v[1]=1; for(i=1, n, v[i+1]=i*sum(k=0, i-1, (s*k+t)^(i-k-1)*binomial(i-1, k)*v[k+1])); v;
%Y A395666 Cf. A000142, A396965.
%Y A395666 Cf. A127782.
%K A395666 nonn,new
%O A395666 0,3
