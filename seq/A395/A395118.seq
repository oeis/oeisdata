%I A395118 #18 Apr 25 2026 02:56:39
%S A395118 1,1,1,7,163,6851,470056,47608282,6710089289,1262414423209,
%T A395118 307492387364056,94725963740310266,36227857754899760269,
%U A395118 16940599431076402326181,9560975202270156320667012,6439485615044285186230893606,5123820404393788686543710824401,4772737934616863815634746488961873
%N A395118 Given e.g.f. A(x), the coefficients of x^n in the n-th power of A(x) and in the n-th iteration of x*A(x) are equal for n >= 1.
%H A395118 Paul D. Hanna, <a href="/A395118/b395118.txt">Table of n, a(n) for n = 0..120</a>
%F A395118 E.g.f. A(x) = Sum_{n>=0} a(n)*x^n/n! satisfies the following formulas.
%F A395118 (1) [x^n] A(x)^n = [x^n] B^n(x) for n > 0 where B(x) = x*A(x) and B^n(x) is the n-th iteration of B(x) with B^0(x) = x.
%F A395118 (2) [x^n] A(x)^n = n * [x^n] log(F(x)) for n >= 1 where F(x) = A(x*F(x)) and F(x) = (1/x)*Series_Reversion(x/A(x)) is the e.g.f. of A395119.
%e A395118 E.g.f.: A(x) = 1 + x + x^2/2! + 7*x^3/3! + 163*x^4/4! + 6851*x^5/5! + 470056*x^6/6! + 47608282*x^7/7! + 6710089289*x^8/8! + ...
%e A395118 RELATED TABLES.
%e A395118 The table of coefficients of x^k/k! in A(x)^n begins
%e A395118   n = 1: [1, 1,  1,   7,  163,   6851,  470056,  47608282, ...];
%e A395118   n = 2: [1, 2,  4,  20,  388,  15472, 1028194, 102164960, ...];
%e A395118   n = 3: [1, 3,  9,  45,  711,  26373, 1691694, 164660940, ...];
%e A395118   n = 4: [1, 4, 16,  88, 1192,  40304, 2482276, 236261848, ...];
%e A395118   n = 5: [1, 5, 25, 155, 1915,  58375, 3427900, 318350030, ...];
%e A395118   n = 6: [1, 6, 36, 252, 2988,  82176, 4565286, 412581672, ...];
%e A395118   n = 7: [1, 7, 49, 385, 4543, 113897, 5943154, 520964080, ...]; ...
%e A395118 Let B(x) = x*A(x) so that
%e A395118 B(x) = x + 2*x^2/2! + 3*x^3/3! + 28*x^4/4! + 815*x^5/5! + 41106*x^6/6! + 3290392*x^7/7! + ...
%e A395118 then the table of coefficients of x^k/k! in B^n(x), the n-th iteration of B(x), begins
%e A395118   n = 1: [0, 1,  2,   3,   28,    815,   41106,   3290392, ...];
%e A395118   n = 2: [0, 1,  4,  18,  140,   2860,  127722,   9545830, ...];
%e A395118   n = 3: [0, 1,  6,  45,  480,   8895,  327708,  21880824, ...];
%e A395118   n = 4: [0, 1,  8,  84, 1192,  24560,  826284,  48152524, ...];
%e A395118   n = 5: [0, 1, 10, 135, 2420,  58375, 2012430, 107401840, ...];
%e A395118   n = 6: [0, 1, 12, 198, 4308, 121740, 4565286, 239923362, ...];
%e A395118   n = 7: [0, 1, 14, 273, 7000, 228935, 9540552, 520964080, ...]; ...
%e A395118 Notice that the following diagonal is found in both tables
%e A395118 D = [1, 4, 45, 1192, 58375, 4565286, 520964080, ...],
%e A395118 illustrating that
%e A395118 D(n) = [x^n/n!] A(x)^n = [x^n/n!] B^n(x) for n >= 1.
%e A395118 RELATED SERIES.
%e A395118 Let F(x) = A(x*F(x)) = (1/x)*Series_Reversion(x/A(x)), then
%e A395118 F(x) = 1 + x + 3*x^2/2! + 22*x^3/3! + 383*x^4/4! + 13696*x^5/5! + 849022*x^6/6! + 80744770*x^7/7! + ... + A395119(n)*x^n/n! + ...
%e A395118 Compare the diagonal D given above with the coefficients in the series
%e A395118 log(F(x)) = x + 2*x^2/2! + 15*x^3/3! + 298*x^4/4! + 11675*x^5/5! + 760881*x^6/6! + 74423440*x^7/7! + ...
%e A395118 to see that
%e A395118 [x^n/n!] log(F(x)) = D(n)/n for n >= 1.
%o A395118 (PARI) \\ Routine to get the n-th iteration of function F
%o A395118 {IT(n,F) = my(G=x); for(i=1,n, G = subst(F,x,G));G}
%o A395118 \\ Obtain e.g.f. A(x) using the definition:
%o A395118 {a(n) = my(A=[1],m); for(i=1,n, A = concat(A,0); m = #A-1;
%o A395118 A[#A] = (Vec(IT(m,x*Ser(A)))[m] - Vec(Ser(A)^m)[m+1])/m ); EGF=Ser(A); n!*A[n+1]}
%o A395118 \\ Display the terms a(0) - a(n):
%o A395118 {upto(n) = a(n); Vec(serlaplace(EGF))}
%o A395118 upto(20)
%Y A395118 Cf. A395119.
