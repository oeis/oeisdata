%N A395667 Expansion of g^8/(7-6*g)^4, where g = 1+x*g^7 is the g.f. of A002296.
%F A395667 G.f.: (Sum_{k>=0} binomial(7*k+4,k) * x^k) * (Sum_{k>=0} binomial(7*k,k) * x^k)^3.
%F A395667 Sum_{k>=1} a(k-1) * x^k/k^2 = (1/14) * log( Sum_{k>=0} binomial(7*k+7,k) * x^k ).
%F A395667 a(n) = ((n+1)/14) * (binomial(7*n+6,n) + Sum_{k=0..n+1} 6^(n+1-k) * binomial(7*n+7,k)).
%o A395667 (PARI) a(n) = (n+1)*(binomial(7*n+6, n)+sum(k=0, n+1, 6^(n+1-k)*binomial(7*n+7, k)))/14;
%Y A395667 Cf. A002296, A004369, A395669.
