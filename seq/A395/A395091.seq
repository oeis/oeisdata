%I A395091 #6 May 01 2026 01:04:20
%S A395091 1,1,1,1,2,1,1,1,2,1,3,1,5,1,2,2,4,1,5,1,4,2,3,1,14,1,4,1,8,1,20,1,7,
%T A395091 2,4,1,37,1,2,2,33,1,33,1,10,14,4,1,94,1,10,1,12,1,50,2,56,1,4,1,323,
%U A395091 1,3,22,32,1,70,1,15,2,85,1,546,1,5,23,14,1,88,1
%N A395091 a(n) is the number of partitions of n into distinct parts such that the sum of tau(k) over the parts k equals tau(n).
%C A395091 We define A000005(0) = 0.
%H A395091 Felix Huber, <a href="/A395091/b395091.txt">Table of n, a(n) for n = 0..10000</a>
%F A395091 a(n) = [x^n*y^A000005(n)] Product_{k>=1} (1 + x^k*y^A000005(k)), where A000005(0) = 0.
%F A395091 a(p) = 1 for primes p.
%F A395091 1 <= a(n) <= A000009(n).
%e A395091 a(4) = 2: [4], [1, 3], since tau(4) = 3 and tau(1) + tau(3) = 1 + 2 = 3.
%e A395091 a(12) = 5: [12], [2, 10], [1, 4, 7], [2, 3, 7], [1, 2, 9], since tau(12) = 6 and each listed partition has tau-sum 6.
%p A395091 A395091 := proc(n)
%p A395091     local h, g, f;
%p A395091     h := proc(k) option remember; `if`(k <= 0, 0, NumberTheory:-tau(k)) end proc:
%p A395091     g := proc(k) option remember; `if`(k <= 0, 0, g(k - 1) + h(k)) end proc:
%p A395091     f := proc(i, j, k) option remember;
%p A395091         `if`(i = 0 and j = 0, 1,`if`(i < 0 or j < 0 or k = 0 or j > g(k), 0,
%p A395091         f(i, j, k - 1) + f(i - k, j - h(k), k - 1)))
%p A395091     end proc:
%p A395091     `if`(n = 0, 1, f(n, h(n), n))
%p A395091 end proc:
%p A395091 seq(A395091(n), n = 0 .. 79);
%Y A395091 Cf. A000005, A000009, A394248, A395082, A395096, A395097, A395111.
%K A395091 nonn,new
%O A395091 0,5
%A A395091 _Felix Huber_, Apr 27 2026
