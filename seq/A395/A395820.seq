%U A395820 1,25,242,1,16,2,49,1,8,1,1,9,1,1,26,1,4,2,1,1,63
%N A395820 a(n) is the largest k such that k*(k+1)/2 | n^n.
%C A395820 From _David A. Corneth_, May 13 2026: (Start)
%C A395820 Equivalent to a(n) is the largest k such that k*(k + 1) | 2*n^n.
%C A395820 The advantage over this sequence is we can exploit k, k+1 being coprime and so not go over all divisors of n^n. (End)
%H A395820 David A. Corneth, <a href="/A395820/b395820.txt">Table of n, a(n) for n = 1..1544</a> (first 389 terms from Chai Wah Wu)
%F A395820 If p != 3 and p is prime, then a(p) = 1. - _Chai Wah Wu_, May 08 2026
%o A395820 (Python)
%o A395820 from math import isqrt
%o A395820 from sympy import divisors
%o A395820 from sympy.ntheory.primetest import is_square
%o A395820 def A395820(n): return next(isqrt((d<<3)+1)>>1 for d in reversed(divisors(n**n)) if is_square((d<<3)+1)) # _Chai Wah Wu_, May 08 2026
