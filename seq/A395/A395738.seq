%N A395738 Index of first occurrence of n in A057853.
%e A395738 #du = 2, #nul = 3, #kvar = 4, #dudek = 5 (with # meaning length-of).
%o A395738 (PARI) first(nn)= nn>0 || return([]); my(r=vector(nn, i, -1), s=0); for(i=0, oo, my(n=a(i)-1); if(n<=#r && -1==r[n], r[n]=i; s++<nn || break)); r; \\ with a(n) as in A057853.
