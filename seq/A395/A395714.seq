%I A395714 #8 May 07 2026 23:57:46
%S A395714 2,20,37,148,1200000,371865600
%N A395714 Integers x>0 such that there exists an integer y>0 such that sigma(x)*psi(x)*phi(x) = x^3 + y^3.
%C A395714 The numbers x and y form a sigma*psi*phi-cubic pair.
%e A395714 20 is a term since sigma(20) * psi(20) * phi(20) = 42 * 36 * 8 = 20^3 + 16^3.
%o A395714 (PARI) isok(k) = {my(f = factor(k), d = sigma(f) * eulerphi(f) * prod(i=1, #f~, (f[i, 1]+1) * f[i, 1]^(f[i, 2]-1)) - k^3);  d > 0 && ispower(d, 3);} \\ _Amiram Eldar_, May 04 2026
%Y A395714 Cf. A000010, A000203, A001615, A004999, A395670.
%K A395714 nonn,hard,more,new
%O A395714 1,1
%A A395714 _S. I. Dimitrov_, May 04 2026
