%S A395611 1,1,1,1,4,3,1,9,24,16,1,16,90,200,125,1,25,240,1080,2160,1296,1,36,
%T A395611 525,3920,15435,28812,16807,1,49,1008,11200,71680,258048,458752,
%U A395611 262144,1,64,1764,27216,255150,1469664,4960116,8503056,4782969
%N A395611 Triangle read by rows: coefficients of (1+x)*(1+(n+1)*x)^(n-1).
%F A395611 T(n, k) = (n+1-k) * binomial(n, k) * (n+1)^(k-1).
%e A395611 The first few rows are:
%e A395611   1;
%e A395611   1,  1;
%e A395611   1,  4,   3;
%e A395611   1,  9,  24,   16;
%e A395611   1, 16,  90,  200,  125;
%e A395611   1, 25, 240, 1080, 2160, 1296;
%e A395611   ...
%t A395611 row[n_]:=CoefficientList[Series[(1+x)*(1+(n+1)*x)^(n-1),{x,0,n}],x]; Array[row,9,0]//Flatten (* _Stefano Spezia_, May 01 2026 *)
%o A395611 (SageMath)
%o A395611 def T1(n):
%o A395611     return [(n+1-k) * binomial(n, k) * (n+1)**(k-1) for k in range(n+1)]
%o A395611 (SageMath)
%o A395611 def T2(n):
%o A395611     if n == 0: return [1]
%o A395611     return list((1+x)*(1+(n+1)*x)**(n-1))
%o A395611 (PARI) row(n) = Vecrev((1+x)*(1+(n+1)*x)^(n-1)); \\ _Michel Marcus_, May 01 2026
%Y A395611 Closely related to A122525 and A259334.
%Y A395611 Similar to A243594, A395505.
%Y A395611 Row sums are A007334(n+2).
%Y A395611 Main diagonal gives A000272(n+1).
%K A395611 nonn,tabl,easy,new
%O A395611 0,5
%A A395611 _F. Chapoton_, May 01 2026
