%S A395564 1,0,1,0,0,2,0,0,-1,6,0,0,0,-9,24,0,0,0,5,-72,120,0,0,0,-1,98,-600,
%T A395564 720,0,0,0,0,-76,1450,-5400,5040,0,0,0,0,35,-2200,20100,-52920,40320,
%U A395564 0,0,0,0,-9,2299,-48750,279300,-564480,362880,0,0,0,0,1,-1717,85514,-977550,3998400,-6531840,3628800
%N A395564 Triangle read by rows: T(n,k) = [x^n] Product_{i=1..k} (1 - (1-x)^i).
%H A395564 Alois P. Heinz, <a href="/A395564/b395564.txt">Rows n = 0..150, flattened</a>
%H A395564 Peter J. Taylor, <a href="https://mathoverflow.net/a/510763">Recurrence leading to simple closed form for Fishburn numbers</a>, answer to question on MathOverflow, 2026.
%F A395564 T(n,k) = Sum_{j=1..min(n-k+1, k)} (-1)^(j+1) * binomial(k,j) * T(n-j,k-1) with T(n,0) = 0^n, T(n,k) = 0 for k < 0 or k > n.
%F A395564 From _Alois P. Heinz_, Apr 28 2026: (Start)
%F A395564 Sum_{k=0..n} abs(T(n,k)) = A179525(n).
%F A395564 Sum_{k=n..n*(n+1)/2} abs(T(k,n)) = A005329(n). (End)
%e A395564 Triangle begins:
%e A395564   1;
%e A395564   0, 1;
%e A395564   0, 0,  2;
%e A395564   0, 0, -1,  6;
%e A395564   0, 0,  0, -9,  24;
%e A395564   0, 0,  0,  5, -72,   120;
%e A395564   0, 0,  0, -1,  98,  -600,    720;
%e A395564   0, 0,  0,  0, -76,  1450,  -5400,    5040;
%e A395564   0, 0,  0,  0,  35, -2200,  20100,  -52920,   40320;
%e A395564   0, 0,  0,  0,  -9,  2299, -48750,  279300, -564480,   362880;
%e A395564   ...
%p A395564 T:= proc(n, k) option remember; `if`(k=0, `if`(n=0, 1, 0),
%p A395564       -add((-1)^j*binomial(k, j)*T(n-j, k-1), j=1..min(n-k+1, k)))
%p A395564     end:
%p A395564 seq(seq(T(n,k), k=0..n), n=0..10);  # _Alois P. Heinz_, Apr 28 2026
%o A395564 (PARI) rows(n) = { my(v1 = vector(n+1, i, vector(i, j, 0)), v2 = vector(n+1, i, vector(i, j, 0))); v1[1][1] = 1; v2[1][1] = 1; for(i=2, n+1, v2[i][1] = 1; v2[i][i] = 1); for(i=3, n+1, for(j=2, i-1, v2[i][j] = v2[i-1][j] + v2[i-1][j-1])); for(i=2, n+1, for(j=2, i, v1[i][j] = sum(k=1, min(i-j+1,j-1), (-1)^(k+1) * v1[i-k][j-1] * v2[j][k+1]))); v1 }
%Y A395564 Cf. A000012 (column sums), A000142 (main diagonal), A000217, A005329, A022493 (row sums), A179525.
%K A395564 sign,tabl,new
%O A395564 0,6
