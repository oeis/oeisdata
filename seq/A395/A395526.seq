%U A395526 8,3,8,8,3,2,0,4,8,9,8,5,3,9,4,8,1,8,0,8,5,7,6,9,0,3,1,0,7,0,8,0,0,0,2,8,7,2
%N A395526 Decimal expansion of the median of the probability distribution of areas of triangles formed by independently and uniformly selecting three points at random in the interior of a given triangle of unit area.
%C A395526 The mode of the distribution is 0 and its mean is 1/12.
%C A395526 The least real root of -(16/3)*Pi^2*x^3 - (8*Pi^2 + 57/5)*x^2 + 62*x/5 - (54*x^2 + 6*x - 1/5)*log(x) - 18*x^2*log(x)^2 + (48*x^3 + 72*x^2)*arctanh(sqrt(1 - 4*x))^2 - (2/5)*(324*x^2 + 28*x - 1)*sqrt(1 - 4*x)*arctanh(sqrt(1 - 4*x)) - 1/2 = 0.
%H A395526 Vangalur S. Alagar, <a href="https://www.jstor.org/stable/3212999">On the Distribution of a Random Triangle</a>, Journal of Applied Probability, Vol. 14, No. 2 (1977), pp. 284-297.
%H A395526 Norbert Henze, <a href="https://www.jstor.org/stable/3213725">Random Triangles in Convex Regions</a>, Journal of Applied Probability, Vol. 20, No. 1 (1983), pp. 111-125.
%H A395526 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/TriangleTrianglePicking.html">Triangle Triangle Picking</a>.
%e A395526 0.0578515194085186090746293264926231634985292137305847...
%t A395526 RealDigits[x /. FindRoot[-(16/3)*Pi^2*x^3 - (8*Pi^2 + 57/5)*x^2 + 62*x/5 - (54*x^2 + 6*x - 1/5)*Log[x] - 18*x^2*Log[x]^2 + (48*x^3 + 72*x^2)*ArcTanh[Sqrt[1 - 4*x]]^2 - (2/5)*(324*x^2 + 28*x - 1)*Sqrt[1 - 4*x]*ArcTanh[Sqrt[1 - 4*x]] - 1/2, {x, 1/20}, WorkingPrecision -> 120], 10, Automatic, -1][[1]]
%o A395526 (PARI) solve(x = 1/20, 1/10, -(16/3)*Pi^2*x^3 - (8*Pi^2 + 57/5)*x^2 + 62*x/5 - (54*x^2 + 6*x - 1/5)*log(x) - 18*x^2*log(x)^2 + (48*x^3 + 72*x^2)*atanh(sqrt(1 - 4*x))^2 - (2/5)*(324*x^2 + 28*x - 1)*sqrt(1 - 4*x)*atanh(sqrt(1 - 4*x)) - 1/2)
