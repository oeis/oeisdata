%I A395067 #21 Jun 13 2026 04:52:52
%S A395067 72,108,144,200,288,324,392,400,432,500,576,648,784,800,864,968,972,
%T A395067 1152,1352,1372,1568,1600,1728,1800,1936,1944,2000,2304,2312,2500,
%U A395067 2592,2700,2704,2888,2916,3136,3200,3456,3528,3600,3872,3888,4000,4232,4500,4608,4624
%N A395067 Even powerful numbers that are not powers of squarefree numbers.
%C A395067 Intersection of A005843 and A359280, where the latter sequence is A001694 \ A072777.
%C A395067 Smallest term with k distinct prime factors is 2*A061742(k) = 2*A002110(k)^2, with k > 1.
%H A395067 Michael De Vlieger, <a href="/A395067/b395067.txt">Table of n, a(n) for n = 1..10000</a>
%e A395067 Table of n, a(n) for select n:
%e A395067      n        a(n)
%e A395067 ------------------------------------------------
%e A395067      1         72 = 2^3 * 3^2
%e A395067      2        108 = 2^2 * 3^3
%e A395067      3        144 = 2^4 * 3^2
%e A395067      4        200 = 2^3 * 5^2
%e A395067      5        288 = 2^5 * 3^2
%e A395067      6        324 = 2^2 * 3^4
%e A395067      7        392 = 2^3 * 7^2
%e A395067      8        400 = 2^4 * 5^2
%e A395067      9        432 = 2^4 * 3^3
%e A395067     24       1800 = 2^3 * 3^2 * 5^2
%e A395067    270      88200 = 2^3 * 3^2 * 5^2 * 7^2
%e A395067   3481   10672200 = 2^3 * 3^2 * 5^2 * 7^2 * 11^2
%t A395067 Select[Range[2, 5000, 2], (powers = FactorInteger[#][[All, -1]]; And[AllTrue[powers, # > 1 &], CountDistinct[powers] > 1]) &]
%Y A395067 Cf. A001694, A002110, A005843, A061742, A072777, A359280.
%K A395067 nonn,easy,new
%O A395067 1,1
