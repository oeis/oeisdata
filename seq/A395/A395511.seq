%N A395511 a(n) is the permanent of the symmetric tau(n) X tau(n) matrix M(n) defined by M(i,j) = gcd(d_i,d_j), where d_i, d_j run through the divisors of n.
%e A395511 a(4) = 22:
%e A395511   [1, 1, 1]
%e A395511   [1, 2, 2]
%e A395511   [1, 2, 4]
%t A395511 a[n_]:=Permanent[Table[GCD[Part[d=Divisors[n],i],Part[d,j]],{i,DivisorSigma[0,n]},{j,DivisorSigma[0,n]}]]; Array[a,45]
%o A395511 (PARI) a(n) = my(f=factor(n), d=divisors(f)); matpermanent(matrix(#d, #d, i, j, gcd(d[i],d[j]))); \\ _Michel Marcus_, Apr 26 2026
