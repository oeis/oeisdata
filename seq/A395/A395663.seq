%S A395663 7,5,19,625,1453,89,13687,6758333,7708537,68529640373,4472029801,
%T A395663 2598638688071,149780635937,162580897794660958,11231299844779783,
%U A395663 676470671886391879633,3688053840923281541,1408434329374922032349,2659842854283579394387
%N A395663 Coefficient of Pi^n in the linear equality by Plouffe for the odd values of the Riemann zeta function.
%H A395663 Jwalin Bhatt, <a href="/A395663/b395663.txt">Table of n, a(n) for n = 1..273</a>
%H A395663 Simon Plouffe, <a href="http://www.plouffe.fr/simon/inspired2.pdf">Identities inspired by Ramanujan Notebooks (part 2)</a>, April 2006.
%H A395663 Linas Vepštas, <a href="https://doi.org/10.1007/s11139-011-9335-9">On Plouffe's Ramanujan identities</a>, The Ramanujan Journal, Vol. 27 (2012), pp. 387-408; <a href="https://arxiv.org/abs/math/0609775">arXiv preprint</a>, arXiv:math/0609775 [math.NT], 2006-2010.
%H A395663 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/RiemannZetaFunction.html">Riemann Zeta Function</a>.
%H A395663 Wikipedia, <a href="https://en.wikipedia.org/wiki/Particular_values_of_the_Riemann_zeta_function#%CE%B6(2n_+_1)">zeta(2n+1)</a>.
%F A395663 A395662(n)*zeta(2n+1) - a(n)*Pi^(2n+1) + (2*A395662(n)+d(n))*S_m(2n+1) + d(n)*S_p(2n+1) = 0, where d(n) = A395748(n/2) if n is even else 0, S_p(n) = Sum_{k>=1} 1/((k^n)*(exp(2*Pi*k)+1)) and S_m(n) = Sum_{k>=1} 1/((k^n)*(exp(2*Pi*k)-1)).
%F A395663 For odd n:
%F A395663   a(n) = A394976(n).
%F A395663   a(n) = A057866((n+1)/2).
%e A395663 180*zeta(3) - 7*Pi^(3) + 360*S_m(3) + 0*S_p(3) = 0.
%e A395663 1470*zeta(5) - 5*Pi^(5) + 3024*S_m(5) + 84*S_p(5) = 0.
%e A395663 56700*zeta(7) - 19*Pi^(7) + 113400*S_m(7) + 0*S_p(7) = 0.
%e A395663 18523890*zeta(9) - 625*Pi^(9) + 37122624*S_m(9) + 74844*S_p(9) = 0.
%t A395663 a[n_] := Module[{n0, s, s1, s2, f},
%t A395663   If[OddQ[n], (* 4n - 1 case *)
%t A395663    n0 = Floor[n/2] + 1;
%t A395663    s = Sum[
%t A395663      (-1)^j * Binomial[4*n0, 2*j] * BernoulliB[4*n0 - 2*j] * BernoulliB[2*j],
%t A395663      {j, 0, 2*n0}
%t A395663    ];
%t A395663    Numerator[-2^(4*n0 - 2) * s / Factorial[4*n0]]
%t A395663    ,
%t A395663    (* 4n + 1 case *)
%t A395663    n0 = n/2;
%t A395663    s1 = Sum[
%t A395663      (-4)^(n0 + j) * Binomial[4*n0 + 2, 4*j] * BernoulliB[4*n0 - 4*j + 2] * BernoulliB[4*j],
%t A395663      {j, 0, n0}
%t A395663    ];
%t A395663    s2 = Sum[
%t A395663      (-4)^j * Binomial[4*n0 + 2, 2*j] * BernoulliB[4*n0 - 2*j + 2] * BernoulliB[2*j],
%t A395663      {j, 0, 2*n0 + 1}
%t A395663    ];
%t A395663    f = 2^(4*n0 + 1) * (s1 + s2/2) / Factorial[4*n0 + 2];
%t A395663    -Numerator[f]
%t A395663   ]
%t A395663 ]
%o A395663 (Python)
%o A395663 from sympy import binomial, bernoulli, factorial
%o A395663 def a(n):
%o A395663     if n%2 == 1: # 4n - 1
%o A395663         n = n//2 + 1
%o A395663         s = sum(
%o A395663             (-1)**j * binomial(4*n, 2*j) * bernoulli(4*n-2*j) * bernoulli(2*j)
%o A395663             for j in range(2*n + 1)
%o A395663         )
%o A395663         return (-2**(4*n-2) * s / factorial(4*n)).numerator
%o A395663     else: # 4n + 1
%o A395663         n //= 2
%o A395663         s1 = sum(
%o A395663             (-4)**(n+j) * binomial(4*n+2, 4*j) * bernoulli(4*n-4*j+2) * bernoulli(4*j)
%o A395663             for j in range(n+1)
%o A395663         )
%o A395663         s2 = sum(
%o A395663             (-4)**j * binomial(4*n+2, 2*j) * bernoulli(4*n-2*j+2) * bernoulli(2*j)
%o A395663             for j in range(2*n+2)
%o A395663         )
%o A395663         f = 2**(4*n+1) * (s1+s2/2) / factorial(4*n+2)
%o A395663         return -f.numerator
%Y A395663 Cf. A057866, A394976, A395662, A395748.
%K A395663 nonn,new
%O A395663 1,1
%A A395663 _Jwalin Bhatt_, May 03 2026
