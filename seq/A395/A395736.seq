%N A395736 Expansion of (Sum_{k>=0} binomial(5*k,k) * x^k)^5.
%H A395736 Seiichi Manyama, <a href="/A395736/b395736.txt">Table of n, a(n) for n = 0..916</a>
%F A395736 a(n) = Sum_{i,j,k,l,m >= 0 and i+j+k+l+m=n} binomial(5*i,i) * binomial(5*j,j) * binomial(5*k,k) * binomial(5*l,l) * binomial(5*m,m).
%F A395736 G.f.: B(x)^5 where B(x) is the g.f. of A001449.
%F A395736 a(n) = Sum_{k=0..n} 4^k * binomial(k+3,3) * binomial(5*n+4,n-k).
%F A395736 a(n) = Sum_{k=0..n} 5^k * binomial(k+3,3) * binomial(5*n-k,n-k).
%F A395736 a(0) = 1; a(n) = (25/n) * Sum_{k=0..n-1} 4^k * binomial(k+5,5) * binomial(5*n+4,n-1-k).
%F A395736 a(0) = 1; a(n) = (25/n) * Sum_{k=0..n-1} 5^k * binomial(k+5,5) * binomial(5*n-2-k,n-1-k).
%o A395736 (PARI) a(n) = sum(k=0, n, 4^k*binomial(k+3, 3)*binomial(5*n+4, n-k));
