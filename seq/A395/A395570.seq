%S A395570 1,0,1,0,3,1,0,3,6,1,0,3,24,9,1,0,3,60,63,12,1,0,3,132,333,120,15,1,0,
%T A395570 3,276,1359,984,195,18,1,0,3,564,4869,6600,2175,288,21,1,0,3,1140,
%U A395570 16263,37272,20715,4068,399,24,1
%N A395570 Array read by ascending antidiagonals: A(n, k) = Sum_{j=0..n} Stirling2(n, j)*3^j*(k)_j.
%C A395570 Base 3 polynomial collapse array for the iterated inverse Pascal operator.
%C A395570 For base 2, the analogous one-step array is A394444.
%F A395570 Let D be the inverse Pascal operator: [D(f)]_m = Sum_{i=0..m} (-1)^(m-i)*binomial(m, i)*f(i). Then A(n, k) = [D^2(i^n*3^i)]_k = Sum_{j=0..n} Stirling2(n, j) *3^j*(k)_j.
%F A395570 Seen as a triangle, T(n, k) = A(n - k, k).
%F A395570 For fixed k, the e.g.f. of A(n, k) in n is Sum_{n>=0} A(n, k)*u^n/n! = (1 + 3*(exp(u) - 1))^k.
%e A395570   k |    0    1      2       3        4        5
%e A395570   n |------------------------------------------------
%e A395570   0 |    1    1      1       1        1        1
%e A395570   1 |    0    3      6       9       12       15
%e A395570   2 |    0    3     24      63      120      195
%e A395570   3 |    0    3     60     333      984     2175
%e A395570   4 |    0    3    132    1359     6600    20715
%e A395570   5 |    0    3    276    4869    37272   169575
%e A395570 A(2, 2) = Stirling2(2, 1)*3*(2)_1 + Stirling2(2, 2)*9*(2)_2 = 24.
%Y A395570 Cf. A394444, A008277, A152751, A182464.
