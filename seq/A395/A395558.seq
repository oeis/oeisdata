%S A395558 2,3,11,83,191,227,443,1091,1163,1523,1811,2027,2063,2927,3251,4943,
%T A395558 6491,6563,7643,8291,9803,10163,10883,11027,11243,12323,13691,14051,
%U A395558 14591,14771,15131,16427,18371,18803,21503,21611,22691,24203,24527,25391
%N A395558 Primes of the form (x^2 + y^2 + z^2) / (x*y - x*z + y*z) with integer x, y, z.
%C A395558 All primes of the form k^2 + 2 are terms trivially: x = k, y = 1, z = 1.
%C A395558 Any prime of the form 6*k + 1 is never a term since it fails to satisfy the criterion in A392201.
%F A395558 a(n) == -1 (mod 6), n > 2.
%e A395558 191 is term since 191 = (61^2 + 11^2 + 13^2) / (61*11 - 61*13 + 11*13).
%Y A395558 Intersection of A000040 and A392201.
%K A395558 nonn,new
%O A395558 1,1
