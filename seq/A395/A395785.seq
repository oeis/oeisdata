%N A395785 Expansion of (Sum_{k>=0} binomial(3*k+2,k) * x^k)^4.
%F A395785 a(n) = Sum_{i,j,k,l >= 0 and i+j+k+l=n} binomial(3*i+2,i) * binomial(3*j+2,j) * binomial(3*k+2,k) * binomial(3*l+2,l).
%F A395785 G.f.: (B(x)/x)^4 where B(x) is the g.f. of A025174.
%F A395785 a(n) = Sum_{k=0..n} 2^k * binomial(k+2,2) * binomial(3*n+11,n-k).
%F A395785 a(n) = Sum_{k=0..n} 3^k * binomial(k+2,2) * binomial(3*n+8-k,n-k).
%F A395785 a(0) = 1; a(n) = (1/n) * Sum_{k=0..n-1} (3*k+20) * 2^k * binomial(k+3,3) * binomial(3*n+11,n-1-k).
%F A395785 a(0) = 1; a(n) = (1/n) * Sum_{k=0..n-1} (2*k+20) * 3^k * binomial(k+3,3) * binomial(3*n+7-k,n-1-k).
%o A395785 (PARI) a(n) = sum(k=0, n, 2^k*binomial(k+2, 2)*binomial(3*n+11, n-k));
