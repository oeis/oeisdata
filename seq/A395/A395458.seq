%U A395458 228,4,4,2,248,2,4,130,322,4,8,2,140,4,8,2,580,2,4,154,156,4,8,2,484,245,4,2,344,4,4,4,356
%N A395458 a(n) = n*tau(n) - (n-1)*tau(rad(n)).
%C A395458 For each divisor d of n add 1 if gcd(d,n/d) = 1, else add n.
%F A395458 a(n) = Sum_{d|n} n^(1 - [gcd(d,n/d) = 1]), where [ ] is the Iverson bracket.
%e A395458 a(12) = 12^0 + 12^1 + 12^0 + 12^0 + 12^1 + 12^0 = 28.
%t A395458 Table[Sum[n^(1 - KroneckerDelta[GCD[d, n/d], 1]), {d, Divisors[n]}], {n, 100}]
