%S A395179 1,2,1,3,3,2,1,4,3,4,3,3,3,2,1,4,5,4,3,5,5,4,3,4,3,4,3,3,3,2,1,4,5,6,
%T A395179 5,5,5,4,3,6,5,6,5,5,5,4,3,4,5,4,3,5,5,4,3,4,3,4,3,3,3,2,1,4,5,6,5,6,
%U A395179 7,6,5,6,5,6,5,5,5,4,3,6,7,6,5,7,7,6,5,6,5,6
%N A395179 Maximum number of runs in the binary expansion of integers obtained by changing a single 0-bit to 1 in the binary representation of n considering bits up to and including the first leading 0.
%C A395179 The bit-flip is allowed on any 0-bit within the standard binary representation of n, or on the first implicit leading zero (at position floor(log_2(n)) + 1). This identifies the maximum disruption to the run-length encoding (A005811) caused by a single-bit increment at Hamming distance 1. Therefore, this sequence provides a measure of how a single-bit change at Hamming distance 1 can disrupt the compression efficiency (RLE) of the binary representation of n.
%H A395179 Vincenzo Manto, <a href="/A395179/b395179.txt">Table of n, a(n) for n = 1..9999</a>
%F A395179 a(n) = max { A005811(n + 2^k) : (n AND 2^k) == 0 and 0 <= k <= floor(log_2(n)) + 1 }.
%F A395179 a(n) = A005811(n) + max { 2*[n in A004779], [n mod 4 == 0] }, where [.] is the Iverson bracket. - _Michael S. Branicky_, Apr 18 2026
%t A395179 A395179[n_] := DigitSum[BitXor[n, Quotient[n, 2]], 2] + If[StringContainsQ[IntegerString[n, 2], "000"], 2, Boole[Divisible[n, 4]]];
%t A395179 Array[A395179, 100] (* _Paolo Xausa_, May 04 2026 *)
%o A395179 (Python)
%o A395179 def count_runs(n):
%o A395179     if n == 0: return 0
%o A395179     s = bin(n)[2:]
%o A395179     runs = 1
%o A395179     for i in range(1, len(s)):
%o A395179         if s[i] != s[i-1]:
%o A395179             runs += 1
%o A395179     return runs
%o A395179 def a(n):
%o A395179     max_r = 0
%o A395179     binary_n = bin(n)[2:]
%o A395179     num_bits = len(binary_n)
%o A395179     for i in range(num_bits):
%o A395179         k = n ^ (1 << i)
%o A395179         if k > n:
%o A395179             max_r = max(max_r, count_runs(k))
%o A395179     k_upper = n ^ (1 << num_bits)
%o A395179     max_r = max(max_r, count_runs(k_upper))
%o A395179     return max_r
%o A395179 print([a(n) for n in range(1, 91)])
%o A395179 (Python)
%o A395179 def a(n): return (n^(n>>1)).bit_count() + max(2*int("000" in bin(n)), int(n&3==0))
%o A395179 print([a(n) for n in range(1, 91)]) # _Michael S. Branicky_, Apr 18 2026
