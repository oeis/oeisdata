%I A395344 #28 Apr 26 2026 00:03:21
%S A395344 1,2,3,4,5,6,7,8,9,110,121,132,143,154,165,176,187,198,109,220,231,
%T A395344 242,253,264,275,286,297,208,219,330,341,352,363,374,385,396,307,318,
%U A395344 329,440,451,462,473,484,495,406,417,428,439,550,561,572,583,594
%N A395344 a(n) is the integer obtained by inserting the sum (modulo 10) of adjacent digits of n between them.
%H A395344 Vincenzo Manto, <a href="/A395344/b395344.txt">Table of n, a(n) for n = 1..10000</a>
%e A395344 Letting | denote the concatenation of digits:
%e A395344    a(10) = 1 | (1 + 0) | 0 = 110,
%e A395344    a(36) = 3 | (3 + 6) | 6 = 396,
%e A395344    a(47) = 4 | (4 + 7) mod 10 | 7 = 4 | 1 | 7 = 417,
%e A395344   a(159) = 1 | (1 + 5) | 5 | (5 + 9) mod 10 | 9 = 16549.
%t A395344 a[n_]:=Module[{d=IntegerDigits[n]},l=Length[d];If[l==1,n,Do[j=2i;d=Insert[d,Mod[d[[j-1]]+d[[j]],10],j],{i,l-1}];FromDigits[d]]];Array[a,54] (* _James C. McMahon_, Apr 25 2026 *)
%o A395344 (Python)
%o A395344 def a(n):
%o A395344     s = str(n)
%o A395344     if len(s) < 2: return n
%o A395344     res = []
%o A395344     for i in range(len(s) - 1):
%o A395344         d1, d2 = int(s[i]), int(s[i+1])
%o A395344         res.append(s[i])
%o A395344         res.append(str((d1 + d2) % 10))
%o A395344     res.append(s[-1])
%o A395344     return int("".join(res))
%o A395344 print([a(n) for n in range(1, 55)])
%Y A395344 Cf. A007953, A053837.
