%U A395220 7,7,0,1,2,3,2,8,7,8,7,7,4,5,0,4,5,1,2,9,1,5,4,5,9,9,3,7,0,7,7,4,0,7,6,6,1
%N A395220 Entropy of the zeta probability distribution with parameter s=4.
%C A395220 Sum_{k>=1} (-m(k)*log(m(k))), where m(k) is the mass distribution function for zeta distribution, m(k) = 1/k^s/zeta(s), with s = 4.
%H A395220 Stanislav Sykora, <a href="/A395220/b395220.txt">Table of n, a(n) for n = 0..999</a>
%H A395220 Wikipedia, <a href="https://en.wikipedia.org/wiki/Zeta_distribution">Zeta distribution</a>.
%H A395220 Wikipedia, <a href="https://en.wikipedia.org/wiki/Entropy_(information_theory)">Entropy (information theory)</a>.
%F A395220 Equals -Sum_{k>=1} (log(1/k^4/zeta(4))/k^4/zeta(4)).
%F A395220 Equals log(zeta(4))-4*zeta'(4)/zeta(4).
%e A395220 0.33378893288882013575...
%o A395220 (PARI) \p200
%o A395220 s=4; zs=zeta(s);
%o A395220 a=log(zs)-(s/zs)*zeta'(s);
%o A395220 precision(a, 105)
%Y A395220 Cf. A395218 (s=2), A395219 (s=3).
%Y A395220 Cf. A013661, A073002.
%K A395220 nonn,cons,new
%O A395220 0,1
%A A395220 _Stanislav Sykora_, Apr 18 2026
