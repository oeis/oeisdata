%I A395075 #14 Apr 12 2026 08:39:39
%S A395075 1,4,243,67104,50280485,80604257403,238578075027474,
%T A395075 1178741837443132376,9036272428220471876577,
%U A395075 101713755052019659176399705,1610269283304955515092070551540,34640154270707623660536959321081010,984420398002534655472050066608012685214,36099825032617288113038535933108751631313058
%N A395075 G.f. A(x) satisfies [x^n] exp( -n*A(x) ) / (1-n^3*x)^(1/n^2) = 0, for n >= 1.
%H A395075 Seiichi Manyama, <a href="/A395075/b395075.txt">Table of n, a(n) for n = 1..153</a>
%F A395075 a(n) = n^(3*n-4) + (1/n) * Sum_{k=1..n-1} k * c_n(k) * e_n(n-k),
%F A395075 where c_n(k) = n^(3*k-3)/k - a(k) for 1 <= k <= n-1,
%F A395075 and e_n(0) = 1, e_n(k) = (n/k) * Sum_{j=1..k} j * c_n(j) * e_n(k-j) for 1 <= k <= n-1.
%o A395075 (Ruby)
%o A395075 def A395075(n)
%o A395075   a = [0]
%o A395075   (1..n).each{|i|
%o A395075     c = [0] + (1..i - 1).map{|k| i ** (3 * k - 3) / k.to_r - a[k]}
%o A395075     e = [1]
%o A395075     (1..i - 1).each{|k| e << i / k.to_r * (1..k).inject(0){|s, j| s + j * c[j] * e[k - j]}}
%o A395075     a << i ** (3 * i - 4) + (1..i - 1).inject(0){|s, k| s + k * c[k] * e[i - k]}.to_i / i
%o A395075   }
%o A395075   a[1..-1]
%o A395075 end
%o A395075 p A395075(20)
%Y A395075 Cf. A319938, A395074.
%K A395075 nonn
%O A395075 1,2
%A A395075 _Seiichi Manyama_, Apr 10 2026
