%N A395634 a(n) = number of triples (x, y, z) such that 2*x^2 + y*z = n, where x, y, z are positive integers with x coprime to y*z.
%e A395634 a(11) = 5 counts these triples: (1,1,9), (1,3,3), (1,9,1), (2,1,3), (2,3,1).
%t A395634 t[n_, c_] := Module[{r}, r = Flatten[Table[If[n - 2 x^2 <= 0, {},
%t A395634 Map[({x, #, Quotient[n - 2 x^2, #]} &),
%t A395634 Select[Divisors[n - 2 x^2], Divisible[n - 2 x^2, #] &]]],
%t A395634 {x, 1, Floor[Sqrt[n - 1]]}], 1]; Select[r, Apply[c, #] &]];
%t A395634 c = CoprimeQ[#1, #2 #3] &;
%t A395634 Join[{0}, Table[Length[t[n, c]], {n, 1, 130}]]
