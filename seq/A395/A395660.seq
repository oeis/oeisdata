%N A395660 Expansion of (Sum_{k>=0} binomial(5*k,k) * x^k)^6.
%F A395660 a(n) = Sum_{x_1,x_2, ...,x_6 >= 0 and x_1+x_2+x_3+...+x_6=n} Product_{k=1..6} binomial(5*x_k,x_k).
%F A395660 G.f.: B(x)^6 where B(x) is the g.f. of A001449.
%F A395660 a(n) = Sum_{k=0..n} 4^k * binomial(k+4,4) * binomial(5*n+5,n-k).
%F A395660 a(n) = Sum_{k=0..n} 5^k * binomial(k+4,4) * binomial(5*n-k,n-k).
%F A395660 a(0) = 1; a(n) = (30/n) * Sum_{k=0..n-1} 4^k * binomial(k+6,6) * binomial(5*n+5,n-1-k).
%F A395660 a(0) = 1; a(n) = (30/n) * Sum_{k=0..n-1} 5^k * binomial(k+6,6) * binomial(5*n-2-k,n-1-k).
%o A395660 (PARI) a(n) = sum(k=0, n, 4^k*binomial(k+4, 4)*binomial(5*n+5, n-k));
