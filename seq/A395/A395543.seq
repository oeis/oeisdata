%T A395543 429981696,302875106592253,1550224166512,72081298828125,
%U A395543 9007199254740992,827240261886336764177,1647129056757192,1978419655660313589123979,12800000000000000000,18173520768629665467189
%N A395543 a(n) = denominator((n-1)!/n^n).
%F A395543 a(n) = denominator( Integral_{x=0..1} x^(n-1)*log(1/x)^n dx ).
%e A395543 The sequence of the fractions is: 1/1, 1/4, 2/27, 3/128, 24/3125, 5/1944, 720/823543, 315/1048576, ...
%t A395543 a[n_]:=Denominator[(n-1)!/n^n]; Array[a,21]
%o A395543 (Python)
%o A395543 from sympy import factorint
%o A395543 from sympy.ntheory.factor_ import digits
%o A395543 def A395543(n):
%o A395543     m = n**n
%o A395543     for p, e in factorint(n).items():
%o A395543         m //= p**min(e*n,(n-1-sum(digits(n-1,p)[1:]))//(p-1))
%o A395543     return m # _Chai Wah Wu_, May 02 2026
%Y A395543 Cf. A000142, A000312, A021139, A095996 (numerators).
%K A395543 nonn,frac,new
