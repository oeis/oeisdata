%N A395272 a(n) = (2*n)! * [x^(2*n)] cos(2*x) * cos(5*x) / cos(10*x).
%F A395272 a(n) = (-1)^n * (49^n + 9^n)/2 - Sum_{k=0..n-1} (-100)^(n-k) * binomial(2*n,2*k) * a(k).
%o A395272 (PARI) a_vector(n, s=2, t=5) = my(v=vector(n+1)); for(i=0, n, v[i+1]=(-1)^i*((s+t)^(2*i)+(s-t)^(2*i))/2-sum(j=0, i-1, (-(s*t)^2)^(i-j)*binomial(2*i, 2*j)*v[j+1])); v;
