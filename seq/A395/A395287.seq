%S A395287 1,9,135,2439,48519,1023759,22478121,507897945,11727334791,
%T A395287 275409734751,6556498796385,157841449993665,3835575156803625,
%U A395287 93947556526734465,2316867932996452215,57476307230175422439,1433280811235078958471,35905990596126060019455,903186018342615310954641,22802253371684252762688081
%N A395287 a(n) = 27^n * [z^n] 2F1(1/3, 1/3; 1; z)^3.
%C A395287 Apery-like sequence of level 3, associated with the modular curve X_0(3) and the weight-3 eta quotient f(tau) = eta(tau)^9/eta(3*tau)^3, whose Fourier expansion begins 1 - 9q + 27q^2 - 9q^3 - 117q^4 + 216q^5 + ... . The signed version b(n) = (-1)^n * a(n) satisfies Sum_{n>=0} b(n)*t^n = f(tau) when t = t_3(tau) = (eta(3*tau)/eta(tau))^12.
%C A395287 Level-3 analog of the Almkvist-Zudilin "(eta)" sequence A229111 (level 5, weight 2).
%C A395287 For every prime p >= 5 with p != 3, this sequence satisfies a one-step Dwork-type congruence mod p^4 on the Hauptmodul parameter t_3.
%H A395287 B. C. Berndt, S. Bhargava, and F. G. Garvan, <a href="https://doi.org/10.2307/2155035">Ramanujan's theories of elliptic functions to alternative bases</a>, Trans. Amer. Math. Soc. 347 (1995), 4163-4244.
%H A395287 A. Shvets, <a href="https://arxiv.org/abs/2604.06238">Order drop, Hecke descent, and a mod p^4 supercongruence for symmetric-cube hypergeometric coefficients</a>, arXiv:2604.06238 [math.NT], 2026.
%H A395287 D. Zagier, <a href="https://people.mpim-bonn.mpg.de/zagier/files/tex/AperylikeRecEqs/fulltext.pdf">Integral solutions of Apery-like recurrence equations</a>, in Groups and Symmetries, CRM Proc. Lecture Notes 47 (2009), 349-366.
%F A395287 a(n) = 27^n * [z^n] F(z)^3, where F(z) = 2F1(1/3, 1/3; 1; z) = Sum_{k>=0} ((1/3)_k)^2 / (k!)^2 * z^k and (x)_k denotes the Pochhammer symbol.
%F A395287 D-finite with recurrence: (n+1)^4 * a(n+1) = (54*n^4 + 108*n^3 + 102*n^2 + 48*n + 9) * a(n) - 729 * n^4 * a(n-1), with a(0) = 1, a(1) = 9.
%F A395287 a(n) ~ Gamma(1/3)^4 * 3^(3*n+3) / (16 * Pi^4 * n^(4/3)) * (1 - 32*Pi^4 / (3*Gamma(1/3)^8 * n^(1/3))). - _Vaclav Kotesovec_, Apr 19 2026
%t A395287 a[0] = 1; a[1] = 9;
%t A395287 a[n_] := a[n] = ((54*(n-1)^4 + 108*(n-1)^3 + 102*(n-1)^2 + 48*(n-1) + 9)*a[n-1] - 729*(n-1)^4 * a[n-2]) / n^4;
%t A395287 Table[a[n], {n, 0, 19}]
%o A395287 (PARI) a(n) = {my(F = sum(k=0, n, prod(i=0, k-1, (3*i+1)^2) / (9^k * (k!)^2) * z^k) + O(z^(n+1))); 27^n * polcoef(F^3, n);}
%Y A395287 Cf. A229111 (level-5 analog), A002893 (order-2 analog).
%K A395287 nonn,easy,new
%O A395287 0,2
