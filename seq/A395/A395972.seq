%T A395972 19200,3840,64,2304,28800,153600,345600,276480,46080,128,6272,112896,
%U A395972 940800,3763200,6773760,4515840,645120,256,16384,401408,4816896,30105600,96337920,144506880,82575360,10321920
%N A395972 Triangle read by rows: T(n, k) = 2^n * [x^k] hypergeom([-n, -n, 1], [1], x).
%F A395972 T(n, k) = 2^n * [x^k] Sum_{k=0..n} k! * binomial(n, k)^2 * x^k.
%e A395972 Triangle starts:
%e A395972   [0]   1;
%e A395972   [1]   2,    2;
%e A395972   [2]   4,   16,     8;
%e A395972   [3]   8,   72,   144,     48;
%e A395972   [4]  16,  256,  1152,   1536,    384;
%e A395972   [5]  32,  800,  6400,  19200,  19200,   3840;
%e A395972   [6]  64, 2304, 28800, 153600, 345600, 276480, 46080;
%p A395972 p := (n, x) -> 2^n * hypergeom([-n, -n, 1], [1], x):
%p A395972 T := (n, k) -> coeff(simplify(p(n, x)), x, k):
%p A395972 for n from 0 to 6 do seq(T(n, k), k = 0..n) od;
%o A395972 (SageMath)
%o A395972 def P(n):
%o A395972     x = SR.var('x')
%o A395972     poly = c = SR(1)
%o A395972     for k in range(n):
%o A395972         c = c * (n - k)^2 / (k + 1)
%o A395972         poly += c * x^(k + 1)
%o A395972     return 2^n * poly
%o A395972 for n in range(7): print(n, P(n).list())
%Y A395972 Cf. A395930, A000165 (main diagonal), A129683 (row sums), A002720.
