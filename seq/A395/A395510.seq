%N A395510 Number of derangements of [2*n+1] with n ascents.
%C A395510 Also number of derangements of [2*n+1] with n descents.
%H A395510 Seiichi Manyama, <a href="/A395510/b395510.txt">Table of n, a(n) for n = 0..224</a>
%F A395510 a(n) = A219836(2*n+1,n) = A395497(2*n+1,n).
%F A395510 a(n) ~ sqrt(3) * 2^(2*n+2) * n^(2*n+1) / exp(2*n+1). - _Vaclav Kotesovec_, Apr 26 2026
%t A395510 $RecursionLimit = Infinity; T[0, 0] = 1; T[n_, k_] := T[n, k] = If[k < 0 || n < 0, 0, (k+1)*T[n-1, k] + (n-k)*T[n-1, k-1] + (-1)^n * KroneckerDelta[k, n-1]]; Table[T[2*n+1, n], {n, 0, 20}] (* _Vaclav Kotesovec_, Apr 26 2026 *)
%Y A395510 Cf. A025585, A180056, A219836, A395497.
