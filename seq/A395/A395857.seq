%I A395857 #5 May 11 2026 23:52:46
%S A395857 3959,146649,7198141,447955715
%N A395857 Number of intervals in the weak order on the Coxeter group D_n.
%D A395857 Anders Björner and Francesco Brenti, Combinatorics of Coxeter groups. Graduate Texts in Mathematics, 231. Springer, New York, 2005.
%o A395857 (SageMath)
%o A395857 def WeakOrder(W):
%o A395857     L = [CoxeterGroup(W).one()]
%o A395857     G = {}
%o A395857     while len(L)>0:
%o A395857         L2 = set()
%o A395857         for w in L:
%o A395857             G[w] = w.upper_covers()
%o A395857             L2 = L2.union(G[w])
%o A395857         L = L2
%o A395857     return DiGraph(G)
%o A395857 print([Poset(WeakOrder(['D',n])).intervals_number() for n in range(4,7)])
%Y A395857 Cf. A002866, A007767 (type A), A395856 (type B).
%K A395857 nonn,more,new
%O A395857 4,1
%A A395857 _Ludovic Schwob_, May 08 2026
