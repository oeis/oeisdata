%T A395330 4,4,3,5,4,8,3,8,4,5,3,4,6,8,6,8,8,6,8,6,4,2,6,4,6,4,9,4,6,4,6,2,6,4,
%U A395330 8,9,8,8,8,8,9,8,4,6,2,8,4,8,6,10,3,10,6,8,4,8,2
%N A395330 Symmetric array read by antidiagonals: A(n,k) = tau(n*k), where tau = A000005.
%C A395330 A(n,k) is the number of distinct fractions reduced to the lowest terms that can be formed using the divisors of the two numbers n and k, respectively, as numerators and denominators.
%e A395330 The array begins as:
%e A395330   1, 2, 2, 3, 2,  4, 2,  4,  3,  4, ...
%e A395330   2, 3, 4, 4, 4,  6, 4,  5,  6,  6, ...
%e A395330   2, 4, 3, 6, 4,  6, 4,  8,  4,  8, ...
%e A395330   3, 4, 6, 5, 6,  8, 6,  6,  9,  8, ...
%e A395330   2, 4, 4, 6, 3,  8, 4,  8,  6,  6, ...
%e A395330   4, 6, 6, 8, 8,  9, 8, 10,  8, 12, ...
%e A395330   2, 4, 4, 6, 4,  8, 3,  8,  6,  8, ...
%e A395330   4, 5, 8, 6, 8, 10, 8,  7, 12, 10, ...
%e A395330   3, 6, 4, 9, 6,  8, 6, 12,  5, 12, ...
%e A395330   4, 6, 8, 8, 6, 12, 8, 10, 12,  9, ...
%e A395330   ...
%t A395330 A[n_,k_]:=DivisorSigma[0,n*k]; Table[A[n-k+1,k],{n,13},{k,n}]//Flatten
%t A395330 (* Alternative: *)
%t A395330 A[n_,k_]:=Length[DeleteDuplicates[Divide @@@ Tuples[{Divisors[n],Divisors[k]}]]]; Table[A[n-k+1,k],{n,13},{k,n}]//Flatten
%Y A395330 Cf. A027750, A072031 (antidiagonal sums).
%Y A395330 Diagonal gives A048691.
%Y A395330 Columns and rows give: A000005, A099777, A372713, A372784, A372785, A372786, A372787, A372788, A372789, A372790, A372791, A372792.
%K A395330 nonn,easy,tabl,new
