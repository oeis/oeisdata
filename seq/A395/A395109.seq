%U A395109 50319361,134193153,201302017,536821761,805257217,2147385345,3221127169,8589737985,12884705281,34359345153,51539214337,137438167041
%N A395109 Number of points covered by a regular level n H-Tree on a square lattice.
%C A395109 A regular H-Tree is taller than necessary, at odd n > 1, in order to maintain the size of the core at n+1. This results in a larger bounding box, 2^(n-2)-1 by 2^(n-2)-3, than a minimal H-Tree, 2^(n-2)-1 by 2^(n-3)-1, at odd n > 1.
%H A395109 David Cleaver, <a href="/A395109/b395109.txt">Table of n, a(n) for n = 0..1000</a>
%H A395109 David Cleaver, <a href="/A395109/a395109.png">Illustration of a(0)-a(6)</a>
%H A395109 Neil Robertson and P. D. Seymour, <a href="https://doi.org/10.1016/0095-8956(83)90079-5">Graph Minors. I. Excluding a Forest</a>, Journal of Combinatorial Theory, Series B, Volume 35, Issue 1, August 1983, Pages 39-61 (see H6 in Fig. 3 on p. 52).
%H A395109 Wikipedia, <a href="https://en.wikipedia.org/wiki/H_tree">H tree</a>.
%H A395109 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (1,6,-6,-8,8).
%F A395109 G.f.: (-2*x^3+2*x^2-2*x-1)/((x-1)*(2*x-1)*(2*x+1)*(2*x^2-1)).
%F A395109 a(n) = (2^floor(n/2) + 2^floor((n-1)/2) - 2)*2^(floor((n+3)/2))+2^ceiling(n/2)+1.
%F A395109 a(n) = A027383(n-2)*2^A004526(n+3) + A051032(n+1).
%F A395109 a(n) = A027383(n-2)*A016116(n+3) + A051032(n+1).
%F A395109 a(2n) = 3*2^n*(2^n-1) + 1, n >= 0; a(2n-1) = binomial(2^(n+1)-1,2), n > 0.
%t A395109 LinearRecurrence[{1, 6, -6, -8, 8}, {1, 3, 7, 21, 37}, 50] (* _Paolo Xausa_, Apr 21 2026 *)
%o A395109 (PARI) a(n)=(2^floor(n/2) + 2^floor((n-1)/2) - 2)*2^(floor((n+3)/2))+2^ceil(n/2)+1;
%Y A395109 Cf. A004526, A016116, A027383, A051032, A134057, A169726, A395108.
