%I A395907 #16 May 20 2026 10:46:16
%S A395907 0,1,1,2,4,2,5,3,5,6,8,6,9,7,10,11,11,12,14,11,13,15,14,15,17,18,16,
%T A395907 21,16,22,22,23,21,19,20,22,29,20,23,29,24,30,28,28,29,31,33,33,34,38,
%U A395907 30,35,39,35,40,39,37,35,41,40,45,42,42,43,45,47,37,38,39
%N A395907 a(0) = 0, and then a(n) is the numbers of ways to write a(n-1) as a(i) + a(j) with i <= j < n.
%C A395907 This sequence is unbounded:
%C A395907 - by contradiction, suppose that a(n) <= M for any n >= 0,
%C A395907 - by necessity, some value m <= M appears infinitely many times,
%C A395907 - so we have a(k_1) = ... = a(k_{M+1}) = m with k_1 < ... < k_{M+1},
%C A395907 - as a(0) + a(k_1) = ... = a(0) + a(k_{M+1}) = m, a(k_{M+1}+1) > M, a contradiction.
%C A395907 Does a(n)/n have a limit as n tends to infinity?
%H A395907 Rémy Sigrist, <a href="/A395907/b395907.txt">Table of n, a(n) for n = 0..10000</a>
%H A395907 Rémy Sigrist, <a href="/A395907/a395907_1.png">Scatterplot of (n, a(n)/n) for n in 1..4000000</a>
%H A395907 Rémy Sigrist, <a href="/A395907/a395907.txt">C++ program</a>
%F A395907 a(n) <= A000217(n).
%e A395907 The first terms, alongside the corresponding sums, are:
%e A395907   n  a(n)  Sums
%e A395907   -  ----  ----------------------------------------------------------------
%e A395907   0     0
%e A395907   1     1  a(0)+a(0)
%e A395907   2     1  a(0)+a(1)
%e A395907   3     2  a(0)+a(1), a(0)+a(2)
%e A395907   4     4  a(0)+a(3), a(1)+a(1), a(1)+a(2), a(2)+a(2)
%e A395907   5     2  a(0)+a(4), a(3)+a(3)
%e A395907   6     5  a(0)+a(3), a(0)+a(5), a(1)+a(1), a(1)+a(2), a(2)+a(2)
%e A395907   7     3  a(0)+a(6), a(1)+a(4), a(2)+a(4)
%e A395907   8     5  a(0)+a(7), a(1)+a(3), a(1)+a(5), a(2)+a(3), a(2)+a(5)
%e A395907   9     6  a(0)+a(6), a(0)+a(8), a(1)+a(4), a(2)+a(4), a(3)+a(7), a(5)+a(7)
%o A395907 (C++) // See Links section.
%o A395907 (Python)
%o A395907 from itertools import islice
%o A395907 from collections import Counter
%o A395907 def agen(): # generator of terms
%o A395907     alst, ways = [0], Counter()
%o A395907     while True:
%o A395907         yield alst[-1]
%o A395907         ways.update(alst[i]+alst[-1] for i in range(len(alst)))
%o A395907         alst.append(ways[alst[-1]])
%o A395907 print(list(islice(agen(), 70))) # _Michael S. Branicky_, May 10 2026
%Y A395907 See A395917 and A395918 for similar sequences.
%Y A395907 Cf. A000217, A265853, A396030.
