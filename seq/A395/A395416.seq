%S A395416 1,0,1,0,1,1,0,1,2,1,0,1,6,4,1,0,1,15,20,6,1,0,1,31,75,43,9,1,0,1,59,
%T A395416 262,249,84,12,1,0,1,120,871,1292,651,146,16,1,0,1,255,2770,6140,4580,
%U A395416 1464,234,20,1,0,1,511,8622,28007,29484,13159,2930,360,25,1
%N A395416 T(n,k) is the number of partitions of [n] into k blocks with distinct element sums; triangle T(n,k), n>=0, 0<=k<=n, read by rows.
%H A395416 Alois P. Heinz, <a href="/A395416/b395416.txt">Rows n = 0..16, flattened</a>
%H A395416 Wikipedia, <a href="https://en.wikipedia.org/wiki/Partition_of_a_set">Partition of a set</a>
%F A395416 Sum_{k=0..n} k! * T(n,k) = A395377(n).
%F A395416 T(n,2) = 2^(n-1) - 1 - A058377(n) for n>=1.
%e A395416 Triangle T(n,k) begins:
%e A395416   1;
%e A395416   0, 1;
%e A395416   0, 1,   1;
%e A395416   0, 1,   2,    1;
%e A395416   0, 1,   6,    4,     1;
%e A395416   0, 1,  15,   20,     6,     1;
%e A395416   0, 1,  31,   75,    43,     9,     1;
%e A395416   0, 1,  59,  262,   249,    84,    12,    1;
%e A395416   0, 1, 120,  871,  1292,   651,   146,   16,   1;
%e A395416   0, 1, 255, 2770,  6140,  4580,  1464,  234,  20,  1;
%e A395416   0, 1, 511, 8622, 28007, 29484, 13159, 2930, 360, 25, 1;
%e A395416   ...
%p A395416 b:= proc(n, l) option remember; (k-> `if`(k-nops({l[]})>n, 0,
%p A395416      `if`(n=0, x^k, b(n-1, [n, l[]])+add(b(n-1, sort(
%p A395416       subsop(j=l[j]+n, l))), j=1..nops(l)))))(nops(l))
%p A395416     end:
%p A395416 T:= (n, k)-> coeff(b(n, []), x, k):
%p A395416 seq(seq(T(n, k), k=0..n), n=0..10);
%Y A395416 Columns k=0-1 give: A000007, A057427.
%Y A395416 Row sums give A275780.
%Y A395416 T(n,n-1) gives A002620.
%Y A395416 Cf. A000225, A048993, A058377, A395377.
%K A395416 nonn,tabl,new
%O A395416 0,9
