%N A395908 Series expansion of (27*x - 14*x^2 + 2*x^3) / (1 - x)^7.
%H A395908 Vincenzo Librandi, <a href="/A395908/b395908.txt">Table of n, a(n) for n = 0..1000</a>
%H A395908 <a href="/index/Rec#order_07">Index entries for linear recurrences with constant coefficients</a>, signature (7,-21,35,-35,21,-7,1).
%F A395908 a(n) = A354794(n + 3, n).
%F A395908 a(n) = n * (n + 1) * (n + 2) * (n + 3) * (n + 5) * (n + 8) / 48.
%p A395908 gf := x*(2*x^2 - 14*x + 27)/(1 - x)^7: ser := series(gf, x, 33):
%p A395908 seq(coeff(ser, x, n), n = 0..32);
%t A395908 CoefficientList[Series[(2*x^3-14*x^2+27*x)/(1-x)^7,{x,0,40}],x] (* _Vincenzo Librandi_, May 11 2026 *)
%o A395908 (Python)
%o A395908 def a(n: int) -> int:
%o A395908     return n * (n + 1) * (n + 2) * (n + 3) * (n + 5) * (n + 8) // 48
%o A395908 L = [a(n) for n in range(33)]; print(L)
%o A395908 (Magma) m:=40; R<x>:=PowerSeriesRing(Integers(), m); [0] cat Coefficients(R!((27*x - 14*x^2 + 2*x^3) / (1 - x)^7)); // _Vincenzo Librandi_, May 11 2026
