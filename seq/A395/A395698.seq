%I A395698 #19 May 13 2026 12:50:35
%S A395698 1,1,2,1,1,2,3,1,2,1,1,1,1,3,4,1,3,1,1,1,2,2,2,1,1,2,1,4,5,1,4,1,1,1,
%T A395698 3,1,2,1,3,1,1,2,2,2,1,1,2,1,1,3,1,5,6,1,5,1,1,1,4,1,2,1,3,2,4,1,1,2,
%U A395698 3,1,2,1,1,1,2,3,3,1,1,3,2,2,1,2,2,1,1,4,1,6
%N A395698 Triangle read by rows: row n (n >= 1) gives the concatenated run-length encoding of the integer partitions of n, sorted first by length and then reverse-lexicographically.
%C A395698 Each partition lambda is represented as a list [p_1, m_1, p_2, m_2, ...] where p_i is the part value and m_i is its multiplicity.
%C A395698 The first term of row n is n itself, allowing the row to be decoded without external knowledge of n. (To support the sequence, we have also provided a decoder for Python.)
%e A395698 Triangle starts:
%e A395698   [1]  1, 1;
%e A395698   [2]  2, 1, 1, 2;
%e A395698   [3]  3, 1, 2, 1, 1, 1, 1, 3;
%e A395698   [4]  4, 1, 3, 1, 1, 1, 2, 2, 2, 1, 1, 2, 1, 4;
%e A395698   [5]  5, 1, 4, 1, 1, 1, 3, 1, 2, 1, 3, 1, 1, 2, 2, 2, 1, 1, 2, 1, 1, 3, 1, 5;
%p A395698 RunLength := proc(P) local row, p, i, val, count, idx;
%p A395698 if P = [[]] then return [] fi;
%p A395698 row := table(); idx := 1;
%p A395698 for p in P do
%p A395698   if nops(p) > 0 then
%p A395698     val := p[1]; count := 1;
%p A395698     for i from 2 to nops(p) do
%p A395698       if p[i] = val then count := count + 1;
%p A395698       else row[idx] := val; row[idx+1] := count;
%p A395698            idx := idx + 2; val := p[i]; count := 1;
%p A395698       fi od;
%p A395698     row[idx] := val; row[idx+1] := count;
%p A395698     idx := idx + 2;
%p A395698 fi od; return [seq(row[i], i = 1..idx - 1)] end:
%p A395698 A395698row := n -> RunLength(A334439row(n)):
%t A395698 A334439row[n_] := Flatten[ Table[ Tally /@ IntegerPartitions[n, {k}], {k, 1, n} ] ]
%t A395698 Do[Print[A334439row[n]], {n, 1, 9}]
%o A395698 (SageMath)
%o A395698 def A334439row(n: int) -> list[int]:
%o A395698     row = []
%o A395698     for k in range(n + 1):
%o A395698         for p in Partitions(n, length=k):
%o A395698             for part, cnt in p.to_exp_dict().items():
%o A395698                 row.append(part)
%o A395698                 row.append(cnt)
%o A395698     return row
%o A395698 for n in range(1, 10): print(A334439row(n))
%o A395698 (Python)
%o A395698 from itertools import groupby
%o A395698 def A334439rle(P: list[list[int]]) -> list[int]:
%o A395698     if P == [[]]: return []
%o A395698     out = []; append = out.append
%o A395698     for p in P:
%o A395698         if p:
%o A395698             for val, grp in groupby(p):
%o A395698                 append(val)
%o A395698                 append(sum(1 for _ in grp))
%o A395698     return out
%o A395698 def A395698row(n: int) -> list[int]: return A334439rle(A334439row(n))
%o A395698 for n in range(1, 10): print(A395698row(n))
%o A395698 # Decodes the RLE data by extracting n from the first element.
%o A395698 def decoder(data: list[int]) -> list[list[int]]:
%o A395698     if not data: return [[]]
%o A395698     n = data[0]
%o A395698     partitions = []
%o A395698     cur_part = []
%o A395698     cur_sum = 0
%o A395698     for i in range(0, len(data), 2):
%o A395698         val = data[i]
%o A395698         count = data[i+1]
%o A395698         cur_part.extend([val] * count)
%o A395698         cur_sum += val * count
%o A395698         if cur_sum == n:
%o A395698             partitions.append(cur_part)
%o A395698             cur_part = []
%o A395698             cur_sum = 0
%o A395698     return partitions
%Y A395698 Cf. A334439, A000041.
%K A395698 nonn,tabf,new
%O A395698 1,3
