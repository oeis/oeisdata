%S A395897 0,0,0,1,354,247731,337967905,833598415265,3467861726846496,
%T A395897 22972239607118717728,231166042967702216459008,
%U A395897 3398957264966889051589698304,70692604493435294115721592770560,2023446661503242179611925495577972736,77858314783438830128460700459646924685312
%N A395897 a(n) = Sum_{1 <= i < j < k <= n} ( n!/(i*j*k) )^4.
%H A395897 Seiichi Manyama, <a href="/A395897/b395897.txt">Table of n, a(n) for n = 0..144</a>
%F A395897 a(n) = (n!)^4 * (H(n,4)^3 - 3*H(n,4)*H(n,8) + 2*H(n,12))/6 where H(n,r) = Sum_{k=1..n} 1/k^r.
%F A395897 a(n) = A395066(n,n-3) = [x^(n-3)] Product_{k=0..n} (1 + k^4*x).
%F A395897 a(n) = (n^4 + (n-1)^4 + (n-2)^4) * a(n-1) - ((n-1)^8 + (n-1)^4 * (n-2)^4 + (n-2)^8) * a(n-2) + (n-2)^12 * a(n-3) + ((n-3)!)^4 for n > 2.
%o A395897 (PARI) a(n) = polcoef(prod(k=0, n, 1+k^4*x), n-3);
%Y A395897 Cf. A395066.
%K A395897 nonn,new
%O A395897 0,5
%A A395897 _Seiichi Manyama_, May 09 2026
