%U A395571 11925,632655,4812039,9086760,4812039,632655,11925,1,1,41980,3962770,49864435,160489695,160489695,49864435,3962770,41980,1
%N A395571 Triangle read by rows: coefficients of reciprocal polynomials refining A007334.
%C A395571 Define an integer-valued polynomial p_n(x) = Product_{i=2..n} ((n+2)*x+i) * (2*x+1) / n!. Then the n-th row describes the numerator of the generating function Sum_{k >= 0} p_n(k) t^k as a rational function.
%e A395571 The first few rows are:
%e A395571   1;
%e A395571   1, 1;
%e A395571   1, 6, 1;
%e A395571   1, 24, 24, 1;
%e A395571   1, 85, 260, 85, 1;
%e A395571   1, 291, 2109, 2109, 291, 1;
%e A395571   1, 994, 14959, 33628, 14959, 994, 1;
%o A395571 (SageMath)
%o A395571 x = polygen(QQ, 'x')
%o A395571 t = x.parent()[['t']].gen()
%o A395571 def row(n):
%o A395571     if n == 0: return [1]
%o A395571     pn = prod((n+2)*x+i for i in range(2, n+1)) * (2*x+1) / factorial(n)
%o A395571     return list((1 - t)**(n + 1) * sum(pn(k) * t**k for k in range(n + 1)).O(n + 1))
%Y A395571 Row sums are A007334.
%Y A395571 Similar to A108267, A394704, A395490.
%K A395571 nonn,tabl,new
%O A395571 0,5
%A A395571 _F. Chapoton_, Apr 28 2026
