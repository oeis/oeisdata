%U A395042 17,3,3,61,1,3,13,59,1,13,1,13,11,5,3,71,1,11,3,43,1,31,11,5,2,7,1,41,5,3,17,7,3,17,1,11
%N A395042 Greatest prime dividing arithmetic derivative of n; and for primes p, a(p)=1.
%H A395042 Antti Karttunen, <a href="/A395042/b395042.txt">Table of n, a(n) for n = 2..10000</a>
%F A395042 a(n) = A006530(A003415(n)).
%o A395042 (PARI)
%o A395042 A003415(n) = if(n<=1, 0, my(f=factor(n)); n*sum(i=1, #f~, f[i, 2]/f[i, 1]));
%o A395042 A006530(n) = if(n>1, vecmax(factor(n)[, 1]), 1);
%o A395042 A395042(n) = A006530(A003415(n));
%Y A395042 Cf. A003415, A006530.
%Y A395042 Cf. also A394895, A395052.
%K A395042 nonn,easy,new
%O A395042 2,3
%A A395042 _Antti Karttunen_, Apr 15 2026
