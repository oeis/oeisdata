%I A395097 #16 Apr 26 2026 23:36:06
%S A395097 1,1,1,2,1,1,2,1,3,3,4,1,7,1,3,4,10,1,9,1,8,4,5,1,22,5,5,15,17,1,11,1,
%T A395097 59,4,6,5,41,1,2,4,54,1,19,1,20,23,5,1,159,7,22,5,28,1,79,7,92,4,5,1,
%U A395097 99,1,4,36,647,6,31,1,38,4,29,1,404,1,6,36,37,6
%N A395097 a(n) is the number of partitions of n into distinct parts such that the sum of A001222 over the parts equals A001222(n).
%C A395097 We define A001222(0) = 0.
%H A395097 Felix Huber, <a href="/A395097/b395097.txt">Table of n, a(n) for n = 0..10000</a>
%F A395097 a(n) = [x^n y^A001222(n)] Product_{k>=1} (1 + x^k*y^A001222(k)), where A001222(0) = 0.
%F A395097 a(p) = 1 for primes p other than 3.
%F A395097 1 <= a(n) <= A000009(n).
%e A395097 a(8) = 3: [8], [2, 6], [1, 3, 4], since A001222(8) = 3 and A001222(2) + A001222(6) = 1 + 2 = 3 and A001222(1) + A001222(3) + A001222(4) = 0 + 1 + 2 = 3.
%p A395097 A := proc(f, N)
%p A395097     local d, i, k, m, n, s, v;
%p A395097     v := [0, seq(f(i), i = 1 .. N)];
%p A395097     m := max(op(v));
%p A395097     d := Array(0 .. N, 0 .. m, 'fill = 0');
%p A395097     d[0, 0] := 1;
%p A395097     for k from 1 to N do
%p A395097         for n from N by -1 to k do
%p A395097             for s from m by -1 to v[k + 1] do
%p A395097                 d[n, s] := d[n, s] + d[n - k, s - v[k + 1]]
%p A395097             od
%p A395097         od
%p A395097     od;
%p A395097     [seq(d[n, v[n + 1]], n = 0 .. N)]
%p A395097 end proc:
%p A395097 N := 77: # Enlarge if you want more terms
%p A395097 A395097 := A(NumberTheory:-Omega, N):
%p A395097 A395097(N);
%t A395097 {1}~Join~Table[With[{r = PrimeOmega[n]}, Count[Select[IntegerPartitions[n], DuplicateFreeQ], _?(Total[PrimeOmega /@ #] == r &)]], {n, 60}] (* _Michael De Vlieger_, Apr 15 2026 *)
%Y A395097 Cf. A000009, A001222, A394248, A395082, A395091, A395096.
%K A395097 nonn,new
%O A395097 0,4
%A A395097 _Felix Huber_, Apr 11 2026
