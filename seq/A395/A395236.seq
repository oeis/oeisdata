%S A395236 1,1,0,1,7,0,1,22,277,0,1,45,1456,27547,0,1,76,4545,202672,5112457,0,
%T A395236 1,115,10936,847485,48361216,1524907087,0,1,162,22405,2641696,
%U A395236 253299105,17630351872,667096092637,0,1,217,41112,6824215,968717056,110928530925,9114999832576,402374890155427,0
%N A395236 Square array A(n,k), n>=0, k>=0, read by antidiagonals downwards, where A(n,k) = (2*n)! * [x^(2*n)] (f(x)^k + f(-x)^k)/2 and f(x) = 1/(cosh(x) - 2 * sinh(x)).
%F A395236 A(0,k) = 1 and A(n,k) = 3*k*(k+1) * A(n-1,k+2) + k^2 * A(n-1,k) for n > 0.
%e A395236 Square array begins:
%e A395236   1,       1,        1,         1,         1, ...
%e A395236   0,       7,       22,        45,        76, ...
%e A395236   0,     277,     1456,      4545,     10936, ...
%e A395236   0,   27547,   202672,    847485,   2641696, ...
%e A395236   0, 5112457, 48361216, 253299105, 968717056, ...
%o A395236 (PARI) a(n, k) = if(n==0, 1, 3*k*(k+1)*a(n-1, k+2)+k^2*a(n-1, k));
%Y A395236 Columns k=0..2 give A000007, A395238, A395239.
%Y A395236 Cf. A395200, A395232.
%K A395236 nonn,tabl,new
%O A395236 0,5
%A A395236 _Seiichi Manyama_, Apr 17 2026
