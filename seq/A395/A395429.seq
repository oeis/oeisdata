%I A395429 #46 Jul 01 2026 16:21:55
%S A395429 9,27,21,31,61,46,37,42,59,49,23,26,16,51,39,74,37,68,127,61,37,28,26,
%T A395429 38,27,41,33,61,72,67,54,27,35,19,42,68,27,83,49,33,67,35,44,43,44,67,
%U A395429 52,58,39,17,83,41,45,39,47,61,85,43,32,52,31,44,47,93,32,43
%N A395429 Least k such that {1^n, 2^n, ..., k^n} contains numbers with every leading digit from 1 through 9.
%C A395429 Conjecture 1: There exists some integer n > 1 satisfying a(n) = 9. Equivalently, for such n, the leading digits of 1^n, 2^n, ..., 9^n are exactly the nine distinct values 1 through 9.
%C A395429 Conjecture 2: The sequence is uniformly bounded; there exists a fixed constant C such that a(n) <= C for all positive integers n.
%C A395429 In a(2)..a(10^5), the smallest term is 11, which appears first at a(2066) and then 21 other times, and the largest term is a(68641) = 361, which appears once. - _Michael S. Branicky_, Jun 24 2026
%H A395429 Michael S. Branicky, <a href="/A395429/b395429.txt">Table of n, a(n) for n = 1..10000</a>
%F A395429 a(n) >= 9.
%e A395429 a(1) = 9 since leading digits 1..9 are covered by k^1 = k for k = 1..9.
%e A395429 a(2) = 27 since leading digits 1..9 are first covered by 1^2 = 1, 5^2 = 25, 6^2 = 36, 2^2 = 4, 23^2 = 529, 8^2 = 64, 27^2 = 729, 9^2 = 81, 3^2 = 9, respectively, and 27 is the largest base needed.
%e A395429 a(3) = 21 since collecting the leading digits of 1^3, 2^3, ..., 21^3, we finally cover all leading digits 1..9.
%p A395429 f:= proc(n) local S,k,t;
%p A395429   S:= {}:
%p A395429   for k from 1 do
%p A395429     t:= k^n;
%p A395429     S:= S union {floor(t/10^ilog10(t))};
%p A395429     if S = {$1..9} then return k fi
%p A395429   od
%p A395429 end proc:
%p A395429 map(f, [$1..100]); # _Robert Israel_, Jun 24 2026
%t A395429 A395429[n_] := Module[{k = 1, s = {1}}, While[Length[s] < 9, s = Union[s, {First[IntegerDigits[++k^n]]}]]; k];
%t A395429 Array[A395429, 100] (* _Paolo Xausa_, Jul 01 2026 *)
%o A395429 (Python)
%o A395429 from gmpy2 import digits, mpz
%o A395429 from itertools import count
%o A395429 def a(n): s = {"1"}; return next(k for k in count(2) if len(s:=s|{digits(mpz(k)**mpz(n))[0]})==9)
%o A395429 print([a(n) for n in range(1, 67)]) # _Michael S. Branicky_, Jun 24 2026
