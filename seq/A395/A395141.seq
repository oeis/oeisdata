%S A395141 1,1,0,1,1,0,1,2,13,0,1,3,32,493,0,1,4,57,1376,37369,0,1,5,88,2739,
%T A395141 114176,4732249,0,1,6,125,4672,246801,15519488,901188997,0,1,7,168,
%U A395141 7265,454144,35822307,3132551168,240798388357,0,1,8,217,10608,757625,70084096,7636142793,879422726144,85948640603761,0
%N A395141 Square array A(n,k), n>=0, k>=0, read by antidiagonals downwards, where A(n,k) = (2*n)! * [x^(2*n)] C(x)^k and C(x) satisfies C(x) = cosh( Integral C(x)^3 dx ).
%H A395141 Seiichi Manyama, <a href="/A395141/b395141.txt">Antidiagonals n = 0..139, flattened</a>
%F A395141 A(0,k) = 1 and A(n,k) = k*(k+3) * A(n-1,k+6) - k*(k+2) * A(n-1,k+4) for n > 0.
%e A395141 Square array begins:
%e A395141   1,       1,        1,        1,        1,         1, ...
%e A395141   0,       1,        2,        3,        4,         5, ...
%e A395141   0,      13,       32,       57,       88,       125, ...
%e A395141   0,     493,     1376,     2739,     4672,      7265, ...
%e A395141   0,   37369,   114176,   246801,   454144,    757625, ...
%e A395141   0, 4732249, 15519488, 35822307, 70084096, 123844445, ...
%t A395141 A395141[n_, k_] := A395141[n, k] = If[n == 0, 1, k*(k+3)*A395141[n-1, k+6] - k*(k+2)*A395141[n-1, k+4]];
%t A395141 Table[A395141[k, n-k], {n, 0, 10}, {k, 0, n}] (* _Paolo Xausa_, Apr 15 2026 *)
%o A395141 (PARI) a(n, k) = if(n==0, 1, k*(k+3)*a(n-1, k+6)-k*(k+2)*a(n-1, k+4));
%Y A395141 Columns k=0..4 give A000007, A281181, A281183, A281184, A281180(n+1) (See A281180, item (4.a)).
%Y A395141 Cf. A395146, A395148.
%K A395141 nonn,tabl,changed
%O A395141 0,8
%A A395141 _Seiichi Manyama_, Apr 14 2026
