%I A395421 #22 Jun 02 2026 01:05:48
%S A395421 0,0,0,14,20,48,60,102,120,176,200,270,300,384,420,518,560,672,720,
%T A395421 846,900,1040,1100,1254,1320,1488,1560,1742,1820,2016,2100,2310,2400,
%U A395421 2624,2720,2958,3060,3312,3420,3686,3800,4080,4200,4494,4620,4928,5060,5382,5520,5856,6000,6350,6500,6864,7020,7398,7560
%N A395421 a(n) = (2*n-3-(-1)^n)*(10*n-1+(-1)^n)/8.
%C A395421 Sum of the perimeters of all composite rectangles formed by taking each of the distinct nonsquare L X W integer-sided rectangles with semiperimeter n = L + W, and gluing L X L squares to their lengths (see example).
%H A395421 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (1,2,-2,-1,1).
%F A395421 G.f.: 2*x^3*(7+3*x)/((1-x)^3*(1+x)^2).
%F A395421 a(n) = 2*floor((n-1)/2)*(3*n-1-floor((n-1)/2)).
%F A395421 a(n) = a(n-1) + 2*a(n-2) - 2*a(n-3) - a(n-4) + a(n-5).
%e A395421 For n = 8, the L X W rectangles with semiperimeter n, including the squares on their lengths are:
%e A395421 .
%e A395421            7       1       7
%e A395421      _____________ _ _____________
%e A395421     |             | |             |
%e A395421     |             | |             |
%e A395421     |             | |             |
%e A395421   7 |             | |             | 7
%e A395421     |             | |             |
%e A395421     |             | |             |
%e A395421     |_____________|_|_____________|
%e A395421            7       1       7
%e A395421 .
%e A395421           6       2       6
%e A395421      ___________ ___ ___________
%e A395421     |           |   |           |
%e A395421     |           |   |           |
%e A395421   6 |           |   |           | 6
%e A395421     |           |   |           |
%e A395421     |           |   |           |
%e A395421     |___________|___|___________|
%e A395421           6       2       6
%e A395421 .
%e A395421          5       3       5
%e A395421      _________ _____ _________
%e A395421     |         |     |         |
%e A395421     |         |     |         |
%e A395421   5 |         |     |         | 5
%e A395421     |         |     |         |
%e A395421     |_________|_____|_________|
%e A395421          5       3       5
%e A395421 .
%e A395421 The sum of the perimeters = 44 + 40 + 36 = 120.
%t A395421 Table[(2n - 3 - (-1)^n) (10n - 1 + (-1)^n)/8, {n, 0, 100}]
%t A395421 CoefficientList[Series[2*x^3*(7 + 3 x)/((1 - x)^3*(1 + x)^2), {x, 0, 100}], x]
%o A395421 (Magma) [(2*n-3-(-1)^n)*(10*n-1+(-1)^n)/8 : n in [0..100]];
%o A395421 (Python)
%o A395421 def A395421(n): return ((n-1)*(5*n-1) if n&1 else 5*n*(n-2))>>1 # _Chai Wah Wu_, Jun 01 2026
