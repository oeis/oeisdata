%T A395058 53,30031,1,1,1,510511,289,9,1,33,1,53,5,9699691,1,1,1,13,1877,289,1,
%U A395058 7,1,33,31907,223092871,1,5,1,6469693231,17,1,193,213,1,1877,2424923,37,1,7,1,200560490131,7,31907,1,2313
%N A395058 a(n) = A328478(A276085(n)).
%H A395058 Antti Karttunen, <a href="/A395058/b395058.txt">Table of n, a(n) for n = 2..4741</a>
%H A395058 <a href="/index/Pri#primorial_numbers">Index entries for sequences related to primorial numbers</a>.
%F A395058 a(n) = A276085(n) / A395059(n).
%o A395058 (PARI)
%o A395058 A276085(n) = { my(f=factor(n)); sum(k=1, #f~, f[k, 2]*prod(i=1,primepi(f[k, 1]-1),prime(i))); };
%o A395058 A111701(n) = forprime(p=2, , if(n%p, return(n), n /= p));
%o A395058 A328478(n) = { my(u=A111701(n)); if(u==n, return(n), return(A328478(u))); };
%o A395058 A395058(n) =  A328478(A276085(n));
%Y A395058 Cf. A276085, A328478, A395059.
%K A395058 nonn,easy,new
