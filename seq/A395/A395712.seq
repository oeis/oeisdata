%T A395712 909152384,7598810880,66645992960,611768051328,5863516200704,
%U A395712 58554559392000,608073693140480,6555174925218048,73240531093965824,846879886259742720,10120674102359859200
%N A395712 Number of valid manual turn-on sequences for n computers in a line, where a computer turns on automatically if its two neighbors are already on.
%H A395712 Codeforces, <a href="https://codeforces.com/problemset/problem/1515/E">Problem 1515E - Phoenix and Computers</a>
%F A395712 a(n) = Sum_{k=1..floor((n+1)/2)} k! * S(n-k+1, k) * 2^(n-2*k+1), where S(m, k) is the Stirling number of the second kind.
%e A395712 For n = 3, the a(3) = 6 valid sequences are: (1,3), (3,1), (1,2,3), (2,1,3), (2,3,1), (3,2,1). Note that for (1,3), computer 2 turns on automatically.
%t A395712 a[n_] := Sum[k! * StirlingS2[n - k + 1, k] * 2^(n - 2 k + 1), {k, 1, Floor[(n + 1)/2]}]
%t A395712 Table[a[n], {n, 1, 20}]
%o A395712 (Python)
%o A395712 import sympy
%o A395712 from sympy.functions.combinatorial.numbers import stirling
%o A395712 def a(n):
%o A395712     res = 0
%o A395712     for k in range(1, (n + 1) // 2 + 1):
%o A395712         res += sympy.factorial(k) * stirling(n - k + 1, k, kind=2) * (2 ** (n - 2 * k + 1))
%o A395712     return res
%o A395712 print([a(n) for n in range(1, 21)])
%Y A395712 Cf. A008277.
%K A395712 nonn,easy
