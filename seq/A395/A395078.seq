%U A395078 14481759761730572172382104,13986094497715126301126461057,15753377133338198042362649125528,20468370147831373470211360930072065
%N A395078 a(n) = Sum_{j=0..n} binomial(n, j) * j^(n + j) * (1 - j)^(n - j).
%H A395078 Paolo Xausa, <a href="/A395078/b395078.txt">Table of n, a(n) for n = 0..200</a>
%F A395078 a(n) ~ 2^(2*n - 1/2) * n^(2*n) / (sqrt(1-w) * exp(2*n-1) * w^(n - 1/2) * (2-w)^n), where w = -LambertW(-2*exp(-2)) = -A226775. - _Vaclav Kotesovec_, Jun 05 2026
%p A395078 a := n -> local j; add(binomial(n, j) * j^(n + j) * (1 - j)^(n - j), j = 0..n): seq(a(n), n = 0..16);
%t A395078 A395078[n_] := If[n <= 1, 1, Sum[Binomial[n, j]*j^(n+j)*(1-j)^(n-j), {j, 2, n}]];
%t A395078 Array[A395078, 20, 0] (* _Paolo Xausa_, Jun 05 2026 *)
%o A395078 (Python) # Using the recurrence of _Mikhail Kurkov_ in A394825.
%o A395078 def aList(lim: int) -> list[int]:
%o A395078     result = [0] * (lim + 1)
%o A395078     result[0] = 1
%o A395078     row = [1] * (lim + 1)
%o A395078     for k in range(1, lim + 1): row[k] += k * row[k - 1]
%o A395078     for i in range(1, lim + 1):
%o A395078         old = row[0]
%o A395078         row[0] = 0
%o A395078         for k in range(1, lim + 1):
%o A395078             row[k], old = k * (row[k - 1] + row[k] - old), row[k]
%o A395078         result[i] = row[i]
%o A395078     return result
%o A395078 print(aList(15))
%Y A395078 Main diagonal of A394825.
