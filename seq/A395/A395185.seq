%I A395185 #19 Apr 28 2026 17:26:09
%S A395185 1,1,1,1,2,1,1,2,2,1,1,2,4,2,1,1,2,8,8,2,1,1,2,16,64,16,2,1,1,2,32,
%T A395185 1024,1024,32,2,1,1,2,64,32768,1048576,32768,64,2,1,1,2,128,2097152,
%U A395185 34359738368,34359738368,2097152,128,2,1,1,2,256,268435456
%N A395185 A triangle read by rows: T(n,k) = T(n-1,k-1) * T(n-1,k) for n >= 3, 1 <= k <= n-1, with T(n,0) = T(n,n) = 1 and T(2,1) = 2.
%C A395185 This sequence can be viewed as the multiplicative version of Pascal's triangle (A007318).
%F A395185 T(n,k) = T(n-1,k-1) * T(n-1,k) for n >= 3, 1 <= k <= n-1, with a(n,0) = T(n,n) = 1 and T(2,1) = 2.
%F A395185 T(n,k) = 2^binomial(n-2,k-1), n >= 2.
%e A395185 The first 5 rows of the triangle are:
%e A395185   1
%e A395185   1, 1
%e A395185   1, 2, 1
%e A395185   1, 2, 2, 1
%e A395185   1, 2, 4, 2, 1
%e A395185   1, 2, 8, 8, 2, 1
%e A395185   ...
%o A395185 (MATLAB)
%o A395185 maxRows = 11;
%o A395185 targetTerms = 63;
%o A395185 sequence = [];
%o A395185 for n = 0:maxRows
%o A395185     for k = 0:n
%o A395185         if n < 2 || k == 0 || k == n
%o A395185             val = 1;
%o A395185         else
%o A395185             p = nchoosek(n-2, k-1);
%o A395185             val = sym(2)^p;
%o A395185         end
%o A395185         sequence = [sequence, val];
%o A395185     end
%o A395185 end
%o A395185 disp(sequence(1:targetTerms))
%Y A395185 Cf. A007318.
%K A395185 nonn,easy,tabl,new
%O A395185 0,5
%A A395185 _S. S. Krishna Chaitanya Bulusu_, Apr 15 2026
