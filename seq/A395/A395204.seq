%U A395204 132856868992999170539520000,357748119473813133324779520000,1150980081539198477103999221760000,4360462292735669908468666073088000000
%N A395204 a(n) = (2*n)! * [x^(2*n)] (f(x)^2 + f(-x)^2)/2 and f(x) = 1/sqrt(1 + 2*sqrt(2)*x + x^2).
%F A395204 a(n) = (2*n)! * [x^(2*n)] (1 + x^2)/(1 - 6*x^2 + x^4).
%F A395204 a(n) = (2*n)! * A002315(n).
%F A395204 Let A(n,k) = (2*n)! * [x^(2*n)] (f(x)^k + f(-x)^k)/2. A(0,k) = 1 and A(n,k) = k*(k+2) * A(n-1,k+4) + k*(k+1) * A(n-1,k+2) for n > 0. a(n) = A(n,2).
%o A395204 (PARI) a(n) = my(x='x+O('x^(2*n+1))); (2*n)!*polcoef((1+x^2)/(1-6*x^2+x^4), 2*n);
%Y A395204 Column k=2 of A395201.
%Y A395204 Cf. A002315.
