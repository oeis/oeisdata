%I A395373 #11 Apr 26 2026 17:38:56
%S A395373 1,1,2,0,1,1,2,2,1,0,2,0,0,1,1,2,2,3,0,2,0,2,1,0,0,2,0,0,0,1,1,2,2,3,
%T A395373 2,2,0,2,1,2,0,2,0,0,2,1,0,0,0,2,0,0,0,0,1,1,2,2,3,2,4,0,2,1,2,0,4,0,
%U A395373 0,2,1,0,2,0,2,0,0,0,2,1,0,0,0,0,2,0,0,0,0,0,1
%N A395373 Triangle read by rows: T(n, k) is the number of ordered pairs (x,y) with 1 <= x,y <= n such that x*y = k, for 1 <= k <= n^2.
%C A395373 The zeros correspond to integers that cannot be written as a product x*y with 1 <= x,y <= n.
%C A395373 The n-th row records the number of occurrences of the integers appearing in the n X n multiplication table.
%C A395373 Equivalently, T(n,k) counts the divisor pairs (d, k/d) of k such that d divides n.
%C A395373 Let A(n,q,r) = #{(i,j) : 1 <= i,j <= n and i*j = q*n + r}, with 0 <= r < n. Then T(n,k) = A(n, floor(k/n), k mod n).
%C A395373 The support of row n is given by A394016.
%H A395373 Frédéric D. W. Heidenthal-König, <a href="https://doi.org/10.5281/zenodo.18960359">Euclidean Decomposition of the Multiplication Table</a>, Zenodo, 2026.
%F A395373 T(n,k) = #{(x,y) : 1 <= x,y <= n and x*y = k}.
%F A395373 T(n,k) = #{d | k : d <= n and k/d <= n}.
%F A395373 Sum_{k=1..n^2} T(n,k) = n^2.
%e A395373 Rows for n = 1 to 6:
%e A395373   n=1: 1;
%e A395373   n=2: 1, 2, 0, 1;
%e A395373   n=3: 1, 2, 2, 1, 0, 2, 0, 0, 1;
%e A395373   n=4: 1, 2, 2, 3, 0, 2, 0, 2, 1, 0, 0, 2, 0, 0, 0, 1;
%e A395373   n=5: 1, 2, 2, 3, 2, 2, 0, 2, 1, 2, 0, 2, 0, 0, 2, 1, 0, 0, 0, 2, 0, 0, 0, 0, 1;
%e A395373   n=6: 1, 2, 2, 3, 2, 4, 0, 2, 1, 2, 0, 4, 0, 0, 2, 1, 0, 2, 0, 2, 0, 0, 0, 2, 1, 0, 0, 0, 0, 2, 0, 0, 0, 0, 0, 1.
%o A395373 (Python)
%o A395373 def T(n, k):
%o A395373     c = 0
%o A395373     for a in range(1, n+1):
%o A395373         if k % a == 0 and k//a <= n:
%o A395373             c += 1
%o A395373     return c
%o A395373 def row(n):
%o A395373     return [T(n, k) for k in range(1, n*n + 1)]
%o A395373 # triangle
%o A395373 a = []
%o A395373 for n in range(1, 7):
%o A395373     a.extend(row(n))
%o A395373 print(a)
%Y A395373 Cf. A027424, A394016.
%Y A395373 Cf. A000290 (row lengths).
%K A395373 nonn,tabf,new
%O A395373 1,3
