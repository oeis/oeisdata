%T A395583 221709057,1124366496,5702067544,28917238636,146649734311,
%U A395583 743713632006,3771639744393,19127343844858,97001651099718,491930316743952,2494755849908505,12651805629398072
%N A395583 a(n) = floor(r*a(n-1)) + floor(r*a(n-2)), a(0) = 0, a(1) = 1 and r = 2 + sqrt(5).
%C A395583 r is the 4th metallic ratio, the copper ratio, A098317.
%C A395583 In general, for r is the m-th metallic ratio, the linear recurrence has signature (m+1, 1, 1-m, -1, -1).
%H A395583 Wikipedia, <a href="https://en.wikipedia.org/wiki/Metallic_mean">Metallic mean</a>.
%H A395583 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (5,1,-3,-1,-1).
%F A395583 a(n) = A004976(a(n-1)) + A004976(a(n-2)).
%F A395583 Limit_{n -> oo} a(n)/a(n-1) = A394046.
%F A395583 Limit_{n -> oo} a(n)/a(n+1) = A298752-1.
%F A395583 G.f.: -x * (x^3 + x^2 + x - 1) / ((x - 1) * (x^4 + 2*x^3 + 5*x^2 + 4*x - 1)). - _Amiram Eldar_, May 08 2026
%t A395583 LinearRecurrence[{5, 1, -3, -1, -1}, {0, 1, 4, 20, 100}, 25] (* _Amiram Eldar_, May 08 2026 *)
