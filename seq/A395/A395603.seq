%T A395603 940,918,1155,1065,1291,1179,1597,1446,1736,1725,1751,2203,2083,2117,
%U A395603 2279,2570,2631,2951,3033,3008,3120,3456,3132,3359,3580,3839,4051,4155,4330,4754,5011,5050,5127,5220,5832,6065
%N A395603 Sum of the distinct prime divisors of C(8*n, n).
%H A395603 Vincenzo Librandi, <a href="/A395603/b395603.txt">Table of n, a(n) for n = 1..1000</a>
%F A395603 a(n) = sopf(binomial(8*n,n)) = A008472(A004381(n)).
%e A395603 a(2) = 10 because binomial(16,2) = 120 = 2^3*3*5 and 2+3+5 = 10.
%e A395603 a(3) = 36 because binomial(24,3) = 2024 = 2^3*11*23 and 2+11+23 = 36.
%t A395603 a[n_]:=Total[FactorInteger[Binomial[8*n,n]][[All,1]]]; Table[a[n],{n,1,54}]
%o A395603 (Magma) a := func<n | &+PrimeDivisors(Binomial(8*n, n))>; N := 54; [a(n) : n in [1..N]];
%o A395603 (Python)
%o A395603 from collections import Counter
%o A395603 from sympy import factorint
%o A395603 def A395603(n):
%o A395603     c = Counter()
%o A395603     for i in range(7*n+1,8*n+1):
%o A395603         c += factorint(i)
%o A395603     for i in range(2,n+1):
%o A395603         c -= factorint(i)
%o A395603     return sum(c) # _Chai Wah Wu_, May 12 2026
%Y A395603 Cf. A008472, A004381, A034387, A394454, A394591, A394592, A394593, A395515, A395566.
%K A395603 nonn
%O A395603 1,1
