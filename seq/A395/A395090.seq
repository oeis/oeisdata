%I A395090 #15 Apr 28 2026 09:14:52
%S A395090 1,1,2,1,2,1,3,3,2,1,3,1,2,3,3,1,4,1,4,3,2,1,3,5,2,4,3,1,4,1,5,3,2,4,
%T A395090 3,1,2,3,3,1,4,1,4,4,2,1,3,5,4,3,4,1,4,5,5,3,2,1,3,1,2,4,3,4,4,1,4,3,
%U A395090 5,1,4,1,2,5,3,5,4,1,5,5,2,1,3,5,2,3,3,1,4,4,4,3,2,4,3,1,4,4,5,1,5,1,5,5,2
%N A395090 a(n) is the minimum number of moves needed to reach 0 from n, where a move subtracts a prime divisor of the current number.
%C A395090 a(n) is the minimum number of steps required to reach 0 starting from n, where each step replaces x by x - p, and p is any prime divisor of x.
%C A395090 Equivalently, consider a directed graph on the nonnegative integers where there is an edge from x to x - p for each prime divisor p of x. Then a(n) is the length of the shortest path from n to 0.
%C A395090 This sequence can be compared with related sequences defined by restricting the choice of p, such as always subtracting the largest or smallest prime factor.
%H A395090 Alois P. Heinz, <a href="/A395090/b395090.txt">Table of n, a(n) for n = 2..65536</a>
%F A395090 For n > 1: a(n) = 1 + min(a(n - p)), where p ranges over the prime divisors of n.
%e A395090 a(12) = 3 since the optimal path is 12 -> 10 -> 5 -> 0.
%e A395090 a(6) = 2 since 6 -> 3 -> 0.
%p A395090 a:= proc(n) option remember; `if`(n=0, 0, 1+
%p A395090       min(seq(a(n-p), p=ifactors(n)[2][.., 1])))
%p A395090     end:
%p A395090 seq(a(n), n=2..106);  # _Alois P. Heinz_, Apr 11 2026
%o A395090 (MATLAB)
%o A395090 N = 100;
%o A395090 a = zeros(1, N);
%o A395090 factors = cell(1, N);
%o A395090 for p = 2:N
%o A395090     if isempty(factors{p})
%o A395090         for mult = p:p:N
%o A395090             factors{mult} = [factors{mult}, p];
%o A395090         end
%o A395090     end
%o A395090 end
%o A395090 for n = 2:N
%o A395090     min_dist = inf;
%o A395090     for p = factors{n}
%o A395090         target = n - p;
%o A395090         if target == 0
%o A395090             d = 0;
%o A395090         else
%o A395090             d = a(target);
%o A395090         end
%o A395090         if d < min_dist
%o A395090             min_dist = d;
%o A395090         end
%o A395090     end
%o A395090     a(n) = 1 + min_dist;
%o A395090 end
%o A395090 % Output the first 60 terms starting from n=2
%o A395090 fprintf('%d, ', a(2:61));
%K A395090 nonn,easy,new
%O A395090 2,3
%A A395090 _Connor O'Higgins_, Apr 11 2026
