%T A395215 0,1,125,17544,2652615,396789120,46896669225,0,1,174,33705,7087680,
%U A395215 1547328825,321413702400,50831084252025,0,1,231,58896,16296525,4761832320,1402608836475,381841394457600,77061447551313225,0
%N A395215 Square array A(n,k), n>=0, k>=0, read by antidiagonals downwards, where A(n,k) = (2*n)! * [x^(2*n)] 1/((1 - x)*(1 - 3*x))^(k/2).
%H A395215 Paolo Xausa, <a href="/A395215/b395215.txt">Table of n, a(n) for n = 0..11324</a> (first 150 antidiagonals, flattened).
%F A395215 A(0,k) = 1 and A(n,k) = k*(k+2) * A(n-1,k+4) + 3*k*(k+1) * A(n-1,k+2) for n > 0.
%F A395215 A(n,k) = (2*n)! * Sum_{j=0..n} 16^j * (-3)^(n-j) * binomial(n+j+k/2-1,n+j) * binomial(n+j,2*j).
%e A395215 Square array begins:
%e A395215   1,        1,         1,          1,          1, ...
%e A395215   0,        9,        26,         51,         84, ...
%e A395215   0,      681,      2904,       7965,      17544, ...
%e A395215   0,   148905,    786960,    2652615,    7087680, ...
%e A395215   0, 64805265, 396789120, 1547328825, 4761832320, ...
%t A395215 A395215[n_, k_] := A395215[n, k] = If[n == 0, 1, k*(k+2)*A395215[n-1, k+4] + 3*k*(k+1)*A395215[n-1, k+2]];
%t A395215 Table[A395215[k, n-k], {n, 0, 10}, {k, 0, n}] (* _Paolo Xausa_, Apr 16 2026 *)
%o A395215 (PARI) a(n, k) = if(n==0, 1, k*(k+2)*a(n-1, k+4)+3*k*(k+1)*a(n-1, k+2));
%Y A395215 Columns k=0..2 give A000007, A395216, (2*n)! * A096053(n).
%Y A395215 Cf. A395148, A395201.
%K A395215 nonn,tabl
%O A395215 0,5
%A A395215 _Seiichi Manyama_, Apr 16 2026
