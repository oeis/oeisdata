%I A395976 #12 May 13 2026 09:28:29
%S A395976 1,55,2581,255893,-4579919,-1075995491,2191041054791,4477083471901,
%T A395976 454915545479411,222043505853843095117,2554196391424824098947,
%U A395976 101965589154637708209573023,5671932708195621826085979743,480064450982937297998308585517,972680766741274534043401841619473
%N A395976 Numerators of rational coefficients related to asymptotic of A336293.
%C A395976 For n > 5, are all a(n) positive ?
%C A395976 Conjecture: A395976(n) / A395977(n) ~ c * n! / (n * 4^n), where c is about 4.69.
%H A395976 Vaclav Kotesovec, <a href="/A395976/b395976.txt">Table of n, a(n) for n = 0..40</a>
%e A395976 A336293(n) / (n^n*exp(4*sqrt(n)-n-2)/sqrt(8*Pi)) ~ (1 + 55/(24*n^(1/2)) + 2581/(1152*n) + 255893/(414720*n^(3/2)) - 4579919/(7962624*n^2) - 1075995491/(6688604160*n^(5/2)) + 2191041054791/(4815794995200*n^3) + ...)
%t A395976 nterms = 10; Clear[d]; Do[Clear[f]; f[n_] := (E^(-2 + 4*Sqrt[n] - n) * n^n / (2*Sqrt[2*Pi])) * (1 + Sum[d[j]/n^(j/2), {j, 1, k}]); ser = Series[Simplify[(((-(-2 + n)^2)*(-1 + n)^2*f[-3 + n] + (-1 + n)^2*(1 + 3*n)*f[-2 + n] + (1 - n - 3*n^2)*f[-1 + n] + n*f[n]) / (E^(-2 + 4*Sqrt[n] - n) * n^n / (2*Sqrt[2*Pi]))) * n^(k/2 + 2)], {n, Infinity, 1}]; sol = Solve[Normal[ser] == 0, d[k]][[1]]; d[k] = Limit[d[k] /. sol, n -> Infinity]; PrintTemporary[k];, {k, 1, nterms}]; Join[{1}, Numerator[Table[d[k], {k, 1, nterms}]]]
%Y A395976 Cf. A336293, A395977 (denominators).
%K A395976 sign,frac,new
%O A395976 0,2
%A A395976 _Vaclav Kotesovec_, May 12 2026
