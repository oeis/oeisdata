%S A395295 -2,-4,-2,0,-4,12,-2,-2,0,0,-4,8,-2,-2,-4,-2,-4,-2,0,28,-2,-2,20,-20,
%T A395295 -2,-2,-2,-4,4,-2,0,-20,4,-4,-2,-4,-2,-2,-4,-2,-2,0,44,-4,6,8,-2,-2,0,
%U A395295 12,-2,-32,0,-68,-2,-4,0,-4,0,-2,-4,-2,0,44,-4,10,60,-2,0,52,-2,-2,-4,-2,-2,-4,-4,-4,4,-2,-4,0
%N A395295 a(n) = L(1,p)-L(-1,p)-L(0,p) where p is the n-th odd prime and L(j,p) is the number of i with 0<=i<A001175(p) for which the Legendre symbol (A000045(i)/p)=j.
%H A395295 Jason D. Andoyo, <a href="/A395295/b395295.txt">Table of n, a(n) for n = 1..9591</a>
%H A395295 Jason D. Andoyo, <a href="https://doi.org/10.62072/acm.2026.09011">(a,b)-Fibonacci-Legendre Cordial Graphs and k-Pisano-Legendre Primes</a>, Annals of Communications in Mathematics, 9(1), Article no. 11.
%o A395295 (Python)
%o A395295 from sympy import legendre_symbol, primerange
%o A395295 def kval(p,in1,in2):
%o A395295     L, a, b, in1, in2 = [], in1, in2, in1%p, in2%p
%o A395295     while True:
%o A395295         L.append(legendre_symbol(a, p))
%o A395295         a, b = b, (a + b)%p
%o A395295         if (a, b) == (in1, in2): break
%o A395295     return L.count(1) - L.count(-1) - L.count(0)
%o A395295 print([kval(p,0,1) for p in primerange(3,500)])
%o A395295 (PARI) fibmod(n, m) = ((Mod([1, 1; 1, 0], m))^n)[1, 2];
%o A395295 isok(k, n) = (fibmod(k,n) == 0) && (fibmod(k+1,n) == 1);
%o A395295 pp(n) = my(k=1); while(!isok(k, n), k++); k; \\ A001175
%o A395295 L(k,p) = sum(i=0, pp(p)-1, kronecker(fibonacci(i), p) == k);
%o A395295 a(n) = my(p=prime(n+1)); L(1,p)-L(-1,p)-L(0,p); \\ _Michel Marcus_, Apr 20 2026
%Y A395295 Cf. A394870, A000045, A001175, A000040, A065091.
