%S A395400 10103,2003,20021,311,131,37,421,19,23,43,47,61,499,457,443,353,263,
%T A395400 227,137,2281,79,823,409,1637,193,2267,1579,677,863,827,971,1693,883,
%U A395400 829,2089,3947,2687,4793,12959,1697,8087,7907,7789,4877,16987,29927,19889
%N A395400 Smallest prime beginning a pair of consecutive primes with the same number of digits and a digit dot product equal to prime(n), n>=3, or -1 if none exists.
%C A395400 From _Michael S. Branicky_, Apr 22 2026: (Start)
%C A395400 a(1) exists and a(1) <= p, where
%C A395400   p = 1000000000000000000000000000099501,
%C A395400   q = 1000000000000000000000000000100041 = A151800(p), and
%C A395400   the digital dot product of p and q = 2 = prime(1).
%C A395400 a(2) exists and a(2) <= p, where
%C A395400   p = 1000000000000109981,
%C A395400   q = 1000000000000110001 = A151800(p), and
%C A395400   the digital dot product of p and q = 3 = prime(2). (End)
%C A395400 a(1) <= 100000000000000999999999999901. a(2) <= 110000099999831. - _David A. Corneth_, Apr 22 2026
%H A395400 Michael S. Branicky, <a href="/A395400/b395400.txt">Table of n, a(n) for n = 3..129</a>
%e A395400 a(3) = 10103: the consecutive prime 10111 has the same digit length, their digit dot product 1*1 + 0*0 + 1*1 + 0*3 + 3*1 equals prime(3) = 5, and no smaller solution exists.
%o A395400 (PARI) f(p)=my(q=nextprime(p+1),u=digits(p),v=digits(q));if(#u==#v,my(r=u*v~);if(ispseudoprime(r),return(primepi(r)),-1));-1
%o A395400 a(n)=forprime(p=2,oo,my(index=f(p));if(index==n,return(p)));-1
%o A395400 (Python)
%o A395400 from itertools import islice
%o A395400 from sympy import isprime, nextprime, primepi
%o A395400 def dot(p, q):
%o A395400     s, t = str(p), str(q)
%o A395400     return sum(int(si)*int(ti) for si, ti in zip(s, t)) if len(s) == len(t) else None
%o A395400 def agen(): # generator of terms
%o A395400     p, q, n, adict = 2, 3, 3, dict()
%o A395400     while True:
%o A395400         v = dot(p, q)
%o A395400         if v and isprime(v):
%o A395400             vi = primepi(v)
%o A395400             if vi not in adict:
%o A395400                 adict[vi] = p
%o A395400                 while n in adict:
%o A395400                     yield adict[n]; n += 1
%o A395400         p, q = q, nextprime(q)
%o A395400 print(list(islice(agen(), 50))) # _Michael S. Branicky_, Apr 22 2026
