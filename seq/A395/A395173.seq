%U A395173 11595368389451235094167552,17524133557023598578392629248,31312735848364798469407990874112,65300241111998358744664049700569088
%N A395173 a(n) = (2*n)! * [x^(2*n)] C(x)^2, where C(x) satisfies C(x) = cosh( Integral C(x)^5 dx ).
%F A395173 Let A(n,k) = (2*n)! * [x^(2*n)] C(x)^k. A(0,k) = 1 and A(n,k) = k*(k+5) * A(n-1,k+10) - k*(k+4) * A(n-1,k+8) for n > 0. a(n) = A(n,2).
%o A395173 (PARI) a(n, k=2) = if(n==0, 1, k*(k+5)*a(n-1, k+10)-k*(k+4)*a(n-1, k+8));
%Y A395173 Column k=2 of A395172.
%Y A395173 Cf. A000182, A010050, A052502, A281183.
%K A395173 nonn,new
%O A395173 0,2
