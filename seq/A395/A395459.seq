%S A395459 1,-1,2,2,-3,2,-6,8,-5,2,24,-30,18,-7,2,-120,144,-84,32,-9,2,720,-840,
%T A395459 480,-180,50,-11,2,-5040,5760,-3240,1200,-330,72,-13,2,40320,-45360,
%U A395459 25200,-9240,2520,-546,98,-15,2,-362880,403200,-221760,80640,-21840,4704,-840,128,-17,2
%N A395459 Triangle read by rows, T(1,0)=1, T(n,m) = (-1)^(n+m-1) * (n-2)! * (n+m-1) / m! for n >= 2, 0 <= m <= n-1.
%C A395459 det(M_N) = -(2*N-3)!! where M_N is the N X N matrix with M_N(i,j) = T(i+1,j) for 1<=i,j<=N (T(n,m)=0 for m>n-1); (-1)!!=1 by convention.
%D A395459 L. B. W. Jolley, Summation of Series, Dover, 1961, Eq. 302.
%H A395459 Sah Deepak Kumar Sureshprasad, <a href="https://doi.org/10.5281/zenodo.20184575">The n-th Derivative of H at Integer Points: Integer Structure, Closed Forms, and a Derangement Identity</a>, Zenodo, 2026.
%H A395459 Sah Deepak Kumar Sureshprasad, <a href="/A395459/a395459.pdf">The Coefficient triangle</a>
%H A395459 Z.-W. Sun and D. Xu, <a href="https://arxiv.org/abs/1007.1339">A Combinatorial Identity with Applications to Labeled Rooted Forests</a>, arXiv:1007.1339 [math.CO], 2010.
%F A395459 G.f. for right edge (d=0): Sum_{n>=2} T(n,n-1)*x^n = 2*x^2/(1-x).
%F A395459 G.f. for diagonal d (d>=1): Sum_{n>=d+1} T(n,n-1-d)*x^n = (-1)^d * d! * x^(d+1)*(1+x)/(1-x)^(d+1).
%e A395459 Triangle begins (n=1..9):
%e A395459   n\m |     0       1      2      3     4     5    6    7   8
%e A395459   ----+------------------------------------------------------
%e A395459     1 |     1
%e A395459     2 |    -1       2
%e A395459     3 |     2      -3      2
%e A395459     4 |    -6       8     -5      2
%e A395459     5 |    24     -30     18     -7     2
%e A395459     6 |  -120     144    -84     32    -9     2
%e A395459     7 |   720    -840    480   -180    50   -11    2
%e A395459     8 | -5040    5760  -3240   1200  -330    72  -13    2
%e A395459     9 | 40320  -45360  25200  -9240  2520  -546   98  -15   2
%o A395459 (Python)
%o A395459 from math import factorial
%o A395459 def T(n, m):
%o A395459     sign = (-1)**(n+m-1)
%o A395459     return sign * factorial(n-2) * (n+m-1) // factorial(m)
%o A395459 for n in range(2, 10):
%o A395459     print([T(n, m) for m in range(n)])
%Y A395459 Cf. A133942 (column 0 and for v=0), A001048 (column 1), A038720 (column 2), A097900 (column 3).
%Y A395459 Cf. A007395 (diagonal d=0), A005408 (diagonal d=1), A000290 (diagonal d=2 scaled by 2! or A001105), A000330 (diagonal d=3 scaled by 3! or A055112), A002415 (diagonal d=4 scaled by 4!), A005585 (diagonal d=5 scaled by 5!), A040977 (diagonal d=6 scaled by 6!), A050486 (diagonal d=7 scaled by 7!), A053347 (diagonal d=8 scaled by 8!), A054333 (diagonal d=9 scaled by 9!), A054334 (diagonal d=10 scaled by 10!), A057788 (diagonal d=11 scaled by 11!), A266561 (diagonal d=12 scaled by 12!).
%Y A395459 Cf. A105926 (row sums absolute for v=1), A392965 (alternating row sums absolute for v=-1), A000312 (for v=n-1).
%Y A395459 Cf. A001147 (determinant of triangle).
