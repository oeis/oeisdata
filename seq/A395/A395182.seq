%I A395182 #23 Apr 23 2026 15:24:24
%S A395182 3,29928,100488,259080,502680,597528,619368,896808,1708248,2093808,
%T A395182 2493240,2601768,2647128,3485688,4798248,5508408,6086088,7252248,
%U A395182 10936248,11648568,12581208,14462808,15389928,16056048,18003048,18258264,20857488,21132408,21756744,22306728,22972848
%N A395182 Values of Jordan's totient function J_2 (A007434) which are not values of Euler's totient function (A000010).
%e A395182 3 is a term since (2^2-1)*(2^2)^0 = 3 and 3 is not in A002202.
%e A395182 29928 is a term since (173^2)*(173^2)^0 = 29928 and 29928 is not in A002202.
%e A395182 4798248 is a term since (13^2-1)*(13^2)^2 = 4798248 and 4798248 is not in A002202.
%o A395182 (PARI) {A007434(n) = if( n<1, 0, direuler( p=2, n, (1 - X) / (1 - X*p^2))[n])};
%o A395182 lst(n) = my(A=[]); for(k = 1, oo, if(#A>=n, break); if(!istotient(A007434(k)), A = concat(A, a(k)))); A
%Y A395182 Cf. A000010, A002202, A007434, A395181.
%K A395182 nonn,new
%O A395182 1,1
%A A395182 _Miles Englezou_, Apr 15 2026
