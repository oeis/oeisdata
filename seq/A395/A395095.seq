%I A395095 #9 Apr 17 2026 00:22:17
%S A395095 0,6,7,8,9,13,16,22,32,43,45,82,97,145,162,188,214,224,330,358,394,
%T A395095 483,688,715,763
%N A395095 Indices of records in A295741(n) = min {d > 0 | primorial(n)/d + d is a prime}.
%C A395095 The initial term might have been 1 as well, since A295741(0) = A295741(1) as 0! = 1!.
%C A395095 It is still only conjectured that A295741(n) > 0 for all n, therefore it seems interesting to study those n which yield exceptionally high values.
%o A395095 (PARI) my(r=0); for(n=0,oo, A295741(n)>r && print1(n", ")+r=A295741(n))
%Y A395095 Cf. A295741, A002110.
%K A395095 nonn,more,new
%O A395095 1,2
%A A395095 _M. F. Hasler_, Apr 11 2026
