%N A395627 Infinite square array T(n,k) = (prime(n)-1)*prime(n)^k/2; n, k >= 1; read by falling antidiagonals.
%e A395627 The array starts as follows:
%e A395627   n\k:   1    2      3       4       5           6           7            8
%e A395627   ---+---------------------------------------------------------------------
%e A395627    1 |   1    2      4       8       16         32          64          128
%e A395627    2 |   3    9     27      81      243        729        2187         6561
%e A395627    3 |  10   50    250    1250     6250      31250      156250       781250
%e A395627    4 |  21  147   1029    7203    50421     352947     2470629     17294403
%e A395627    5 |  55  605   6655   73205   805255    8857805    97435855   1071794405
%e A395627    6 |  78 1014  13182  171366  2227758   28960854   376491102   4894384326
%e A395627    7 | 136 2312  39304  668168 11358856  193100552  3282709384  55806059528
%t A395627 T[n_,k_]:=(Prime[n]-1)*Prime[n]^k/2; Table[Reverse[Table[T[n-k+1,k],{k,n}]],{n,10}]//Flatten (* _Stefano Spezia_, May 01 2026 *)
%o A395627 (PARI) A395627(n,k=0)=if(k,(prime(n)-1)*prime(n)^k/2, A395627(n+=(1-k=sqrtint(8*n-7)\/2)*k\2, k-n+1)) \\ without 2nd arg, return n-th term a(n) of the "flattened" sequence
%o A395627 apply( A395627, [1..55])
