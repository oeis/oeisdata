%I A395270 #32 Jun 08 2026 15:33:31
%S A395270 6,10,14,22,26,30,34,38,42,46,58,62,66,70,74,78,82,86,94,102,105,106,
%T A395270 110,114,118,122,130,134,138,142,146,154,158,165,166,170,174,178,182,
%U A395270 186,190,194,195,202,206,210,214,218,222,226,230,238,246,254,258,262,266
%N A395270 Numbers that are radicals of abundant numbers.
%C A395270 For n = p_1^e_1*...*p_r^e_r, we take advantage of the fact that sigma is multiplicative and the prime powers p_i^e_i are pairwise coprime, so sigma(n) = Product_{i=1..r} sigma(p_i^e_i). For a prime power the divisors are 1, p_i, p_i^2, ..., p_i^e_i, hence sigma(p_i^e_i) = (p_i^(e_i + 1) - 1)/(p_i - 1). Therefore sigma(n)/n = Product_{i=1..r} (p_i/(p_i - 1))*(1 - p_i^(-e_i - 1)). Since each factor (1 - p_i^(-e_i - 1)) increases to 1 as e_i -> infinity, the maximum possible value of sigma(n)/n for the fixed prime set {p_1, ..., p_r} is Product_{i=1..r} p_i/(p_i - 1). A number is abundant when sigma(n) > 2*n, so an abundant number with these primes exists iff Product_{i=1..r} p_i/(p_i - 1) > 2.
%C A395270 No prime p occurs, since p/(p - 1) <= 2.
%C A395270 All even squarefree numbers 2*...*p_r occur for r >= 2, since Product_{i=1..r} p_i/(p_i - 1) = 2/(2 - 1)*Product_{i=2..r} p_i/(p_i - 1) > 2.
%C A395270 Odd squarefree numbers can occur for r >= 3. For r = 3 exactly the three terms 3*5*7 = 105, 3*5*11 = 165 and 3*5*13 = 195 occur. For r > 3, infinitely many terms occur, for example, all terms 3*5*7*q, where q is a prime > 7.
%H A395270 Felix Huber, <a href="/A395270/b395270.txt">Table of n, a(n) for n = 1..10000</a>
%e A395270 6 is a term since (2/(2 - 1))*(3/(3 - 1)) = 3 > 2.
%e A395270 105 is a term since (3/2)*(5/4)*(7/6) > 2.
%e A395270 5*7*11 is not a term since (5/4)*(7/6)*(11/10) < 2.
%p A395270 A395270 := proc(n) option remember;
%p A395270     global t; local k, r, p;
%p A395270     if not assigned(t) then t := table() end if;
%p A395270     k := `if`(n = 1, 1, A395270(n - 1) + 1);
%p A395270     while true do
%p A395270         if NumberTheory:-IsSquareFree(k) then
%p A395270             r := k;
%p A395270             if not assigned(t[r]) then t[r] := NumberTheory:-PrimeFactors(r) end if;
%p A395270             if mul(p/(p - 1), p in t[r]) > 2 then return r end if
%p A395270         end if;
%p A395270         k := k + 1;
%p A395270     end do
%p A395270 end proc:
%p A395270 seq(A395270(n), n = 1 .. 57);
%t A395270 s = Select[Range[270], And[SquareFreeQ[#], CompositeQ[#]] &]; Select[s, Or[EvenQ[#], Times @@ Map[#/(# - 1) &, FactorInteger[#][[All, 1]] ] > 2] &] (* _Michael De Vlieger_, May 13 2026 *)
%o A395270 (PARI) isok(k) = my(f = factor(k)); issquarefree(f) && if(k%2, vecprod(apply(x -> x/(x-1), f[,1])) > 2, k > 2); \\ _Amiram Eldar_, May 13 2026
%Y A395270 Subsequence of A005117.
%Y A395270 Subsequence of A120944.
%Y A395270 Supersequence of A039956, except for the initial term 2.
