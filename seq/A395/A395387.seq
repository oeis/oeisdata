%N A395387 a(n) = (2*n)! * [x^(2*n)] cosh(x) / cos(x)^4.
%F A395387 a(n) = 1 - (1/8) * Sum_{k=0..n-1} (-1)^(n-k) * (4^(n-k+1) + 16^(n-k)) * binomial(2*n,2*k) * a(k).
