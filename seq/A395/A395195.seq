%T A395195 6218897484800,349904316361600,21634432691872000,1458184259730598400,
%U A395195 106415830357124288000,8360082146039688064000,703476433917140595712000,63128211827804212753664000,6018098124614487341061632000
%N A395195 E.g.f. A(x) satisfies A'(x) = (1 + A(x)*A'(x))^2, with A(0)=0.
%F A395195 E.g.f. A(x) satisfies A'(x) = (1 + A(x)*A'(x))^k, with A(0)=0.
%F A395195 Let R(x) = Series_Reversion( (1 - (1-(2*k-1)*x) * (1-x)^(2*k-1))/(2*(2*k-1)) ).
%F A395195 A(x) = R(x) * (1-R(x))^(k-1).
%F A395195 For k > 0 and n > 1, k divides n! * [x^n] A(x).
%F A395195 From _Vaclav Kotesovec_, Jun 17 2026: (Start)
%F A395195 Recurrence: 17*a(n) = 12*(25*n - 54)*a(n-1) - 4*(441*n^2 - 2349*n + 3143)*a(n-2) + 108*(2*n - 7)*(4*n - 13)*(4*n - 11)*a(n-3).
%F A395195 a(n) ~ 2^(5*n-3) * 3^(n - 3/2) * n^(n-2) / (17^(n - 3/2) * exp(n)). (End)
%o A395195 (PARI) my(k=2, N=20, x='x+O('x^N), R=serreverse((1-(1-(2*k-1)*x)*(1-x)^(2*k-1))/(2*(2*k-1)))); Vec(serlaplace(R*(1-R)^(k-1)))
%Y A395195 Cf. A001147 (with offset 1), A397131, A397132.
%K A395195 nonn,new
%O A395195 1,2
%A A395195 _Seiichi Manyama_, Jun 17 2026
