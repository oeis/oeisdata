%S A395318 1,5,7,9,10,12,13,16,17,19,20,22,23,24,25,26,31,33,35,38,40,41,43,47,
%T A395318 48,54,55,56,57,62,63,67,68,69,74,75,78,80,81,83,88,92,93,95,98,100,
%U A395318 101,102,103,104,107,108,109,116,125,126,127,128,129,130,131,133
%N A395318 Numbers k such that prime(m) / m < prime(k) / k for any m < k (where prime(k) denotes the k-th prime number).
%C A395318 This sequence is infinite by the prime number theorem.
%H A395318 Rémy Sigrist, <a href="/A395318/b395318.txt">Table of n, a(n) for n = 1..10000</a>
%H A395318 Rémy Sigrist, <a href="/A395318/a395318.png">Illustration of initial terms</a>
%e A395318 See illustration in Links section.
%t A395318 f[k_]:=Prime[k]/k;q[k_]:=Module[{s=f/@Range[k-1]},AllTrue[s,#<f[k]&]]; Select[Range[133],q] (* _James C. McMahon_, Apr 20 2026 *)
%o A395318 (PARI) { my(mx = -oo, k = 0); forprime(p = 2, 751, my(r = p/k++); if(mx < r, mx = r; print1(k", "););); }
%Y A395318 Cf. A038606, A395319.
%K A395318 nonn,new
%O A395318 1,2
