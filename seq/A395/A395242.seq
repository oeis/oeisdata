%I A395242 #31 Jun 11 2026 18:10:14
%S A395242 3,6,11,12,13,19,22,24,25,26,27,35,38,43,44,45,48,49,50,51,52,53,54,
%T A395242 55,59,67,70,75,76,77,83,86,88,89,90,91,96,97,98,99,100,101,102,103,
%U A395242 104,105,106,107,108,109,110,111,115,118,123,131,134,139,140,141,147
%N A395242 Numbers whose binary representation contains isolated digits "11" at least once.
%C A395242 Complement of A173025.
%e A395242 Some terms:
%e A395242 a(1) = 3 = '11'_2.
%e A395242 a(2) = 6 = '110'_2.
%e A395242 a(3) = 12 = '1100'_2.
%e A395242 a(1001)= 1728 = '11011000000'_2.
%e A395242 23 is not a term since 23 = '10111'_2, but 55 = '110111'_2 is a term.
%o A395242 (Python)
%o A395242 from math import comb
%o A395242 from sympy import fibonacci
%o A395242 from oeis_sequences.OEISsequences import bisection
%o A395242 def A395242(n):
%o A395242     def f(x):
%o A395242         s = bin(x)[-1:1:-1]
%o A395242         t = '0'+s+'0'
%o A395242         return n-1+sum(sum(fibonacci(k+1)*comb(i-k+1,k) for k in range(i+1))  for i in range(len(s)) if s[i]=='1' and not '0110' in '0'+t[i+2:])+('0110' not in t)
%o A395242     return bisection(f,n,n)
%Y A395242 Cf. A173025.
%K A395242 nonn,base,new
%O A395242 1,1
%A A395242 _Chai Wah Wu_, Jun 10 2026
