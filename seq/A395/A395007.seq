%N A395007 Integers x such that there exist two integers 0<y<=z such that sigma(x)*psi(x)*phi(x) = x^3 + y^3 + z^3.
%C A395007 The numbers x, y and z form a sigma*psi*phi-cubic triple.
%e A395007 (6, 2, 4) is such a triple because sigma(6) * psi(6) * phi(6) = 12*12*2 = 6^3 + 2^3 + 4^3.
%o A395007 (PARI) isok(x)=
%o A395007 {
%o A395007   my(d=sigma(x)*dedekindpsi(x)*eulerphi(x)-x^3);
%o A395007   for(y=1,sqrtnint(d,3),
%o A395007     if((t=d-y^3)<y^3, break);
%o A395007     if(ispower(t,3), return(1))
%o A395007   );
%o A395007   0
%o A395007 }
%Y A395007 Cf. A000010, A000203, A001615, A003072, A385325, A391290, A395714.
%K A395007 nonn,new
