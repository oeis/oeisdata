%N A395293 a(n) = (2*n)! * [x^(2*n)] cos(x)^4 / cos(sqrt(2)*x).
%F A395293 a(n) = (-1)^n * (3*0^n + 4^(n+1) + 16^n)/8 - Sum_{k=0..n-1} (-2)^(n-k) * binomial(2*n,2*k) * a(k).
%o A395293 (PARI) a_vector(n) = my(v=vector(n+1)); for(i=0, n, v[i+1]=(-1)^i*(3*0^i+4^(i+1)+16^i)/8-sum(j=0, i-1, (-2)^(i-j)*binomial(2*i, 2*j)*v[j+1])); v;
