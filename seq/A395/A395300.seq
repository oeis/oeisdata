%T A395300 163,0,0,36,60,25,107,0,60,36,73,0,214,0,56,52,60,0,122,0,120,36,56,0,
%U A395300 180,25,97,36,60,0,432,0,60,76,0,25,396,0,120,36,392,0
%N A395300 Sum of numbers k < n such that rad(k) | n but k does not divide n, where rad = A007947.
%C A395300 Let omega(k) = A001221(k) be the number of distinct prime factors of k.
%C A395300 Scatterplot shows zones associated with the number of distinct prime factors of squarefree and nonsquarefree n; a(n) tends to be smaller for squarefree n compared to nonsquarefree m with omega(n) = omega(m). Likewise, a(n) tends to be smaller than a(k) for omega(n) < omega(k).
%H A395300 Michael De Vlieger, <a href="/A395300/b395300.txt">Table of n, a(n) for n = 1..10000</a>
%H A395300 Michael De Vlieger, <a href="/A395300/a395300.png">Log log scatterplot of a(n)</a>, n = 1..65536 (ignoring zeros), with a color function indicating a(n) as follows: dark green = squarefree composite, light blue = neither squarefree nor powerful, and accentuating the following with larger points: red = prime, orange = perfect power of squarefree composite, purple = Achilles number.
%H A395300 Michael De Vlieger, <a href="/A395300/a395300_1.png">Log log scatterplot of a(n)</a>, n = 1..262144 (ignoring zeros), with a color function indicating n as follows: dark green = squarefree, light blue = neither squarefree nor powerful, and accentuating the following with larger points: bright green = primorial, orange = perfect power, purple = Achilles number.
%F A395300 a(n) = sum of row n of A272618.
%F A395300 a(n) = A244974(n) - A000203(n).
%F A395300 a(n) = 0 for n in A000961 (powers of primes).
%F A395300 a(n) = A020639(n)^2 for n in A138109.
%F A395300 a(n) = A020639(n)^(n*(n+3)/2) = A020639(n)^A000096(n) for n in A138511.
%e A395300 Table of n, a(n) for select n:
%e A395300    n   a(n)  Row n of A272618.
%e A395300   --------------------------------------------------------------------
%e A395300    6     4   {4}
%e A395300   10    12   {4, 8}
%e A395300   12    17   {8, 9}
%e A395300   14    12   {4, 8}
%e A395300   15     9   {9}
%e A395300   18    40   {4, 8, 12, 16}
%e A395300   24    43   {9, 16, 18}
%e A395300   30   163   {4, 8, 9, 12, 16, 18, 20, 24, 25, 27}
%e A395300   42   214   {4, 8, 9, 12, 16, 18, 24, 27, 28, 32, 36}
%e A395300   60   432   {8, 9, 16, 18, 24, 25, 27, 32, 36, 40, 45, 48, 50, 54}
%e A395300   78   476   {4, 8, 9, 12, 16, 18, 24, 27, 32, 36, 48, 52, 54, 64, 72}
%t A395300 rad[x_] := Times @@ FactorInteger[x][[All,1]]; Table[If[PrimePowerQ[n], 0, Total@ Select[Range[n], Divisible[n, rad[#]] &] - DivisorSigma[1, n] ], {n, 120}]
%t A395300 (* Alternative: first, load the regs program in Links at A369609, then: *)
%t A395300 Table[If[PrimePowerQ[n], 0, Total@ regs[n] - DivisorSigma[1, n]], {n, 120}]
%Y A395300 Cf. A000203, A007947, A027750, A162306, A244974, A272618.
%K A395300 nonn,easy,new
%O A395300 1,6
