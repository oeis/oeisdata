%I A395494 #10 Apr 27 2026 01:20:41
%S A395494 0,111,123,159,189,239,259,271,279,297,311,357,479,481,497,551,561,
%T A395494 671,711,719,757,831,833,839,871,951,957,979,1023,1057,1111,1147,1151,
%U A395494 1161,1209,1231,1241,1271,1309,1313,1319,1321,1333,1337,1387,1391,1417,1419,1421
%N A395494 Primitive zeros of A395183.
%C A395494 Numbers m such that A395183(m) = 0 and A395183(d) != 0 for all proper divisors d of m.
%C A395494 A395183(k) = 0 if and only if k is a multiple of some term of this sequence.
%o A395494 (Python)
%o A395494 from itertools import count, product, islice
%o A395494 from sympy import multiplicity, n_order, divisors, gcd
%o A395494 def A395494_gen(): # generator of terms
%o A395494     A395494_set = set()
%o A395494     yield 0
%o A395494     for n in count(111):
%o A395494         m2, m5 = (~n & n-1).bit_length(), multiplicity(5,n)
%o A395494         k = n//5**m5>>m2
%o A395494         r = n_order(10,k) if k>1 else 1
%o A395494         flag = True
%o A395494         if gcd(10,n)>1:
%o A395494             alist = [range(2,r+max(m2,m5)+2),range(1,10),range(1,10)]
%o A395494             for d in product(*alist):
%o A395494                 for a in range(d[0]-1):
%o A395494                     b = d[0]-a
%o A395494                     if not (pow(10,b,n)*d[1]+d[2])*pow(10,a,n)%n:
%o A395494                         flag = False
%o A395494                         break
%o A395494         else:
%o A395494             alist = [range(r),range(1,10),range(1,10)]
%o A395494             for d in product(*alist):
%o A395494                 if not (pow(10,d[0],k)*d[1]+d[2])%k:
%o A395494                     t = d[0]
%o A395494                     if r<=2:
%o A395494                         while t<2:
%o A395494                             t += r
%o A395494                     if t>1:
%o A395494                         flag = False
%o A395494                         break
%o A395494         if flag:
%o A395494             if not any(d in A395494_set for d in divisors(n,proper=True)):
%o A395494                 A395494_set.add(n)
%o A395494                 yield n
%o A395494 A395494_list = list(islice(A395494_gen(),49))
%Y A395494 Cf. A395183.
%K A395494 nonn,base,new
%O A395494 1,2
%A A395494 _Chai Wah Wu_, Apr 25 2026
