%S A395253 3,4,3,7,7,3,7,7,3,4,3,7,3,4,3,7,7,3,4,3,7,3,4,3,7,7,3,7,7,3,4,3,7,7,
%T A395253 3,7,7,3,4,3,7,3,4,3,7,7,3,7,7,3,4,3,7,7,3,7,7,3,4,3,7,3,4,3,7,7,3,4,
%U A395253 3,7,3,4,3,7,7,3,7,7,3,4,3,7,3,4,3,7,7,3,4,3,7
%N A395253 Differences of A395251.
%C A395253 Frequencies (sqrt(2)-1, 3-2*sqrt(2), sqrt(2)-1) for 3, 4, 7 respectively.
%C A395253 Belongs to the minimal subshift generated by the primitive morphism 3 -> 3,4; 4 -> 3,7; 7 -> 3,7,7, with Perron eigenvalue 1 + sqrt(2) (silver ratio).
%H A395253 Benoit Cloitre, <a href="https://arxiv.org/abs/2604.10822">Beatty solutions of almost Golomb equations</a>, arXiv:2604.10822 [math.NT], 2026.
%t A395253 b[k_] := Floor[k/Sqrt[2] + 2*(Sqrt[2] - 1)]; q[k_] := b[b[k] + b[k - 1]] != k; Differences[Select[Range[500], q]] (* _Amiram Eldar_, Apr 17 2026 *)
%Y A395253 Cf. A395251.
%K A395253 nonn,new
%O A395253 1,1
%A A395253 _Benoit Cloitre_, Apr 17 2026
