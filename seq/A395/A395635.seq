%N A395635 a(n) = number of triples (x, y, z) such that 2*x^2 + y*z = n, where x, y, z are positive integers with gcd(x,y*z)>1.
%e A395635 a(20) = 6 counts these triples: (2,1,12), (2,2,6), (2,3,4), (2,4,3), (2,6,2), (2,12,1).
%t A395635 t[n_, c_] := Module[{r}, r = Flatten[Table[If[n - 2 x^2 <= 0, {},
%t A395635 Map[({x, #, Quotient[n - 2 x^2, #]} &),
%t A395635 Select[Divisors[n - 2 x^2], Divisible[n - 2 x^2, #] &]]],
%t A395635 {x, 1, Floor[Sqrt[n - 1]]}], 1]; Select[r, Apply[c, #] &]];
%t A395635 c = (! CoprimeQ[#1, #2 #3] &);
%t A395635 Table[Length[t[n, c]], {n, 10, 130}]
