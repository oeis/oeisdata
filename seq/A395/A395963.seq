%I A395963 #11 May 19 2026 19:45:26
%S A395963 1,3,5,7,9,11,13,15,16,18,20,22,24,26,28,30,33,35,37,39,41,43,45,47,
%T A395963 48,50,52,54,56,58,60,62,65,67,69,71,73,75,77,79,80,82,84,86,88,90,92,
%U A395963 94,97,99,101,103,105,107,109,111,112,114,116,118
%N A395963 Numbers k such that A395961(k) = 1.
%C A395963 Complement of A395962.
%H A395963 Benoit Cloitre, <a href="https://arxiv.org/abs/2604.06243">The Thue-Morse Transform</a>, arXiv:2604.06243 [math.NT], 2026.
%F A395963 a(n) = 2*(n-1) + 1 - A395961(2*(n-1)) for n >= 1.
%o A395963 (Python)
%o A395963 def A395961(n):
%o A395963     s, p = 0, 0
%o A395963     while (1 << p) <= n:
%o A395963         if (p & 3) == 0:
%o A395963             s ^= (n >> p) & 1
%o A395963         p += 1
%o A395963     return s
%o A395963 print([k for k in range(120) if A395961(k) == 1])
%Y A395963 Cf. A000035, A000069, A001969, A010060, A158704, A158705, A341389, A395958, A395959, A395960, A395961, A395962, A395964, A395965, A395966.
