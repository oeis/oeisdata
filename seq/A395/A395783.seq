%N A395783 Expansion of (Sum_{k>=0} binomial(3*k+2,k) * x^k)^3.
%F A395783 a(n) = Sum_{i,j,k >= 0 and i+j+k=n} binomial(3*i+2,i) * binomial(3*j+2,j) * binomial(3*k+2,k).
%F A395783 G.f.: (B(x)/x)^3 where B(x) is the g.f. of A025174.
%F A395783 a(n) = Sum_{k=0..n} (k+1) * 2^k * binomial(3*n+8,n-k).
%F A395783 a(n) = Sum_{k=0..n} (k+1) * 3^k * binomial(3*n+6-k,n-k).
%F A395783 a(0) = 1; a(n) = (1/n) * Sum_{k=0..n-1} (3*k+15) * 2^k * binomial(k+2,2) * binomial(3*n+8,n-1-k).
%F A395783 a(0) = 1; a(n) = (1/n) * Sum_{k=0..n-1} (2*k+15) * 3^k * binomial(k+2,2) * binomial(3*n+5-k,n-1-k).
%o A395783 (PARI) a(n) = sum(k=0, n, (k+1)*2^k*binomial(3*n+8, n-k));
