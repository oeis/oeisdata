%U A395079 14731760791405826353,1821596921118627413112,244673069988065590056025,35478934710659760285365851,5524449097025217753681737985,919439893040295438072449964745
%N A395079 a(n) = Sum_{k=0..n} n^k * binomial(n + 1, k + 1) * binomial(2*n + 2, k) / (n + 1).
%C A395079 The number of ternary trees with n nodes weighted by n colors on the middle and right edges.
%H A395079 Paolo Xausa, <a href="/A395079/b395079.txt">Table of n, a(n) for n = 0..300</a>
%F A395079 a(n) = A395080(n, n).
%F A395079 a(n) ~ e * n^n * C(n + 1) where C denotes the Catalan numbers; also a(n) ~ (4*e / Pi^(1/2)) *((4*n)^n / n^(3/2)).
%t A395079 A395079[n_] := Hypergeometric2F1[-n, -2*(n+1), 2, n];
%t A395079 Array[A395079, 20, 0] (* _Paolo Xausa_, Apr 12 2026 *)
%o A395079 (Python)
%o A395079 from math import comb
%o A395079 def A395079(n: int) -> int:
%o A395079     return sum(((n**i) * comb(n + 1, i + 1) * comb(2 * n + 2, i)) // (n + 1) for i in range(n + 1))
%o A395079 A = [A395079(n) for n in range(20)]; print(A)
%Y A395079 Cf. A395080.
%K A395079 nonn
%O A395079 0,2
