%T A395420 750,756,790,792,804,840,932,950,961,992,1184,1208,1344,1416,1448,
%U A395420 1452,1548,1642,1644,1654,1672,1680,1688,1690,1724,1740,1760,1796,1838,1852,1904,1928,1939,1952,1964
%N A395420 Numbers k = x + y such that there exists sigma(x) + sigma(y) = 3*(x+y).
%e A395420 186 can be split into 180 and 6, and sigma(180) + sigma(6) = 3 * (180+6). Thus 186 is a term.
%t A395420 s[k_] := s[k] = DivisorSigma[1, k]; q[k_] := AnyTrue[Range[1, k-1], s[#] + s[k-#] == 3*k &]; Select[Range[2000], q] (* _Amiram Eldar_, Apr 22 2026 *)
%o A395420 (PARI) isok3(k) = sum(x=1, k-1, sigma(x) + sigma(k-x) == 3*k) >= 1; \\ _Michel Marcus_, Apr 23 2026
%Y A395420 Cf. A000203, A395419.
