%S A395023 1,2,5,21,126,1001,10129,126006,1877593,32888637,666757418,
%T A395023 15442626557,404271491249,11855277004330,386411610169757,
%U A395023 13904155500245141,549062380938559062,23670411643929747681,1108835228310948875297,56206315123997801696158,3071280303942573508668753,180294553591510412499169117
%N A395023 Expansion of the o.g.f. Sum_{k >= 0} ((k + 1) * x^k) / Product_{j=1..k} (1 - j^2 * x).
%C A395023 a(n) is equal to the sum of the number of partitions of the set {1,1',2,2',...,n,n'} into disjoint nonempty subsets V1,...,Vk (1 <= k <= n) such that, for each 1 <= j <= k, if i is the least integer such that either i or i' belongs to Vj then {i,i'} is a subset of Vj (This matches A135920) and the total number of blocks (nonempty subsets V_j) across all such partitions (This matches A394822).
%H A395023 Alois P. Heinz, <a href="/A395023/b395023.txt">Table of n, a(n) for n = 0..335</a>
%F A395023 a(n) are the row sums of A395021 for even-indexed rows.
%F A395023 a(n) = A135920(n) + A394822(n) for n>=1.
%F A395023 a(n) = A395022(2*n).
%F A395023 a(n) = (2*n)! * [x^(2*n)] (cosh(2*sinh(x/2)) + sinh(x/2) * sinh(2*sinh(x/2))).
%F A395023 O.g.f.: 1 + 2*x/(1-x) + 3*x^2/((1-x)*(1-4*x)) + 4*x^3/((1-x)*(1-4*x)*(1-9*x)) + ...
%o A395023 (Python)
%o A395023 from functools import cache
%o A395023 @cache
%o A395023 def T(n, k):
%o A395023     if k == 1 or k == n: return 1
%o A395023     if k < 1 or k > n: return 0
%o A395023     if k % 2 == 0:
%o A395023         return 0 if n % 2 != 0 else (2 * T(n, k-1)) // k
%o A395023     else:
%o A395023         term1 = T(n-1, k) * (k + 1) // 2
%o A395023         if n % 2 == 0:
%o A395023             return term1
%o A395023         else:
%o A395023             term2 = T(n-1, k-2) * 2 // (k - 1)
%o A395023             return term1 + term2
%o A395023 def a(n):
%o A395023     if n == 0: return 1
%o A395023     return sum(T(2 * n, k) for k in range(1, 2 * n + 1))
%o A395023 print([a(n) for n in range(0, 22)])
%Y A395023 Bisection of A395022.
%Y A395023 Cf. A394813, A394582, A008957, A395021, A135920, A394822.
%K A395023 nonn,new
