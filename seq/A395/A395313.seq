%U A395313 8,0,8,22,24,10,0,9,28,26,11,2,11,30,32,14,2
%N A395313 Triangle read by rows: T(n, k) is the number of partitions of n into distinct parts with exactly k prime parts, where 0 <= k <= A350174(n).
%C A395313 This triangle refines A000009 by the number of prime parts.
%H A395313 Felix Huber, <a href="/A395313/b395313.txt">Table of n, a(n) for n = 0..10016</a>
%F A395313 G.f.: F(x, y) = Product_{m>=1} (1 + x^m)*Product_{p in A000040} (1 + (y - 1)*x^p).
%F A395313 T(n, k) = [x^n*y^k] Product_{m>=1} (1 + x^m)*Product_{p in A000040} (1 + (y - 1)*x^p).
%F A395313 Sum_{k>=0} T(n, k) = A000009(n).
%e A395313 The triangle begins:
%e A395313   n\k |  0   1   2   3   4
%e A395313   ----+-------------------
%e A395313    0  |  1
%e A395313    1  |  1
%e A395313    2  |  0   1
%e A395313    3  |  0   2
%e A395313    4  |  1   1
%e A395313    5  |  1   1   1
%e A395313    6  |  1   2   1
%e A395313    7  |  1   3   1
%e A395313    8  |  1   3   2
%e A395313    9  |  2   3   3
%e A395313   10  |  3   3   3   1
%e A395313   11  |  2   6   3   1
%e A395313   12  |  2   8   4   1
%e A395313   13  |  3   8   6   1
%e A395313   14  |  4   8   8   2
%e A395313   15  |  5  10   9   3
%e A395313   16  |  5  12  11   4
%e A395313   17  |  4  17  13   3   1
%e A395313   18  |  6  18  16   5   1
%e A395313   19  |  8  18  20   8   0
%e A395313   20  |  8  22  24  10   0
%e A395313   21  |  9  28  26  11   2
%e A395313   22  | 11  30  32  14   2
%e A395313 T(6, 0) = 1: [6]; T(6, 1) = 2: [1, 5], [2, 4]; T(6, 2) = 1: [1, 2, 3].
%p A395313 A350174 := proc(n) option remember;
%p A395313     local m, s;
%p A395313     m := 0; s := 0;
%p A395313     while s + ithprime(m + 1) <= n do
%p A395313         m := m + 1;
%p A395313         s := s + ithprime(m);
%p A395313     end do;
%p A395313     m;
%p A395313 end proc:
%p A395313 T := proc(n, k, i := n) option remember;
%p A395313     `if`(n = 0 and k = 0, 1,
%p A395313     `if`(i <= 0, 0,
%p A395313     `if`(isprime(i), T(n, k, i - 1) + T(n - i, k - 1, i - 1), T(n, k, i - 1) + T(n - i, k, i - 1))));
%p A395313 end proc:
%p A395313 seq(seq(T(n, k), k = 0 .. A350174(n)), n = 0 .. 22);
