%S A395201 1,1,0,1,5,0,1,14,249,0,1,27,984,35685,0,1,44,2565,172080,10111185,0,
%T A395201 1,65,5448,540855,56165760,4751389125,0,1,90,10185,1368000,202178025,
%U A395201 29462227200,3340612823625,0,1,119,17424,3009825,582099840,117975193875,22666834713600,3283368780817125,0
%N A395201 Square array A(n,k), n>=0, k>=0, read by antidiagonals downwards, where A(n,k) = (2*n)! * [x^(2*n)] (f(x)^k + f(-x)^k)/2 and f(x) = 1/sqrt(1 + 2*sqrt(2)*x + x^2).
%H A395201 Paolo Xausa, <a href="/A395201/b395201.txt">Table of n, a(n) for n = 0..11324</a> (first 150 antidiagonals, flattened).
%F A395201 A(0,k) = 1 and A(n,k) = k*(k+2) * A(n-1,k+4) + k*(k+1) * A(n-1,k+2) for n > 0.
%e A395201 Square array begins:
%e A395201   1,        1,        1,         1,         1, ...
%e A395201   0,        5,       14,        27,        44, ...
%e A395201   0,      249,      984,      2565,      5448, ...
%e A395201   0,    35685,   172080,    540855,   1368000, ...
%e A395201   0, 10111185, 56165760, 202178025, 582099840, ...
%t A395201 A395201[n_, k_] := A395201[n, k] = If[n == 0, 1, k*(k+2)*A395201[n-1, k+4] + k*(k+1)*A395201[n-1, k+2]];
%t A395201 Table[A395201[k, n-k], {n, 0, 10}, {k, 0, n}] (* _Paolo Xausa_, Apr 16 2026 *)
%o A395201 (PARI) a(n, k) = if(n==0, 1, k*(k+2)*a(n-1, k+4)+k*(k+1)*a(n-1, k+2));
%Y A395201 Columns k=0..4 give A000007, A395203, A395204, A395205, A395206.
%Y A395201 Cf. A395148, A395200, A395215.
%K A395201 nonn,tabl
%O A395201 0,5
%A A395201 _Seiichi Manyama_, Apr 15 2026
