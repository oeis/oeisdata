%S A395879 1,1,3,19,118,914,7499,65271,587907,5453628,51742827,500364560
%N A395879 Number of oriented polyominoes in the {6,5} tessellation of the hyperbolic plane.
%C A395879 For oriented polyominoes, chiral pairs are counted as two.
%H A395879 <a href="https://oeis.org/wiki/PF-Non-Euclidean">Wiki page indexing sequences related to non-euclidean polyforms</a>
%F A395879 a(n) = P{p,q}(n) (the number of oriented {p,q} polyominoes of size n) is equal to P{p,oo}(n) for n <= q. In this case, P{p,oo} = A221184.
%t A395879 (* Cf. A394862 with p=6 and q=5. *)
%Y A395879 Cf. A221184, A393730, A394862.
%K A395879 nonn,more
%O A395879 1,3
