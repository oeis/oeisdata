%I A395788 #14 May 11 2026 23:12:03
%S A395788 2,3,5,11,12,17,29,41,54,59,71,101,107,137,149,179,191,197,227,239,
%T A395788 269,281,311,347,350,419,431,461,521,569,578,599,617,641,659,809,821,
%U A395788 827,857,881,928,1019,1031,1049,1061,1083,1091,1151,1229,1277,1289,1301,1319,1427,1451,1481,1487
%N A395788 Numbers k for which sopfr(2*k) = sopfr(k + 2) where sopfr = A001414.
%H A395788 Robert Israel, <a href="/A395788/b395788.txt">Table of n, a(n) for n = 1..10000</a>
%p A395788 R:= NULL: count:= 0:
%p A395788 Q:= [0,2,3]:
%p A395788 for k from 2 while count < 100 do
%p A395788    Q:= [Q[2],Q[3],add(t[1]*t[2],t=ifactors(k+2)[2])];
%p A395788    if Q[3] = Q[1]+2 then count:= count+1; R:= R,k fi
%p A395788 od:
%p A395788 R; # _Robert Israel_, May 06 2026
%t A395788 sopfr[n_] := sopfr[n] = Plus @@ Times @@@ FactorInteger[n]; sopfr[1] = 0; Select[Range[1500], sopfr[#] + 2 == sopfr[# + 2] &] (* _Amiram Eldar_, May 07 2026 *)
%o A395788 (Magma) [k: k in [1..1700] | (2*k eq 1 select 0 else (&+[j[1]*j[2]: j in Factorization(2*k)])) eq (k+2 eq 1 select 0 else (&+[g[1]*g[2]: g in Factorization(k+2)]))];
%Y A395788 Cf. A001414, A394509. Includes A001359.
%K A395788 nonn,new
%O A395788 1,1
%A A395788 _Juri-Stepan Gerasimov_, May 05 2026
