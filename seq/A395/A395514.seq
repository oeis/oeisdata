%N A395514 Partial sums of A394760.
%H A395514 Michael De Vlieger, <a href="/A395514/b395514.txt">Table of n, a(n) for n = 1..10000</a>
%t A395514 Block[{a, c, f, k, r, s, u, nn}, nn = 120; c[_] := False; u[_] := 1; f[x_] := Times @@ FactorInteger[x][[;; , 1]]; a = Range[1, 2]; Map[Set[c[#], True] &, a]; s = Total[a]; a~Join~Reap[Do[r = f[s]; While[Set[k, u[r]*r]; Nand[! c[k], Divisible[r, f@ u[r] ] ], u[r]++]; s += k; Sow[s]; Set[c[k], True], {n, Length[a], nn}] ][[-1, 1]] ]
