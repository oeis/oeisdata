%S A395497 1,0,0,1,0,0,0,2,0,0,1,4,4,0,0,0,12,24,8,0,0,1,24,120,104,16,0,0,0,54,
%T A395497 480,896,392,32,0,0,1,108,1764,5984,5544,1368,64,0,0,0,224,6048,34520,
%U A395497 57640,30384,4552,128,0,0,1,448,19936,180416,495320,470504,153400,14680,256,0,0
%N A395497 T(n,k) is the number of derangements of [n] with k ascents; triangle T(n,k), n>=0, 0<=k<=n, read by rows.
%F A395497 T(n,k) = A219836(n,n-1-k) for n > 0.
%F A395497 T(n,k) = (k+1) * T(n-1,k) + (n-k) * T(n-1,k-1) + (-1)^n * delta(k,0), where delta(,) is the Kronecker delta.
%e A395497 Triangle begins:
%e A395497 n\k | 0   1    2    3    4   5  6  7
%e A395497 ----+--------------------------------
%e A395497   0 | 1;
%e A395497   1 | 0,  0;
%e A395497   2 | 1,  0,   0;
%e A395497   3 | 0,  2,   0,   0;
%e A395497   4 | 1,  4,   4,   0,   0;
%e A395497   5 | 0, 12,  24,   8,   0,  0;
%e A395497   6 | 1, 24, 120, 104,  16,  0, 0;
%e A395497   7 | 0, 54, 480, 896, 392, 32, 0, 0;
%o A395497 (PARI) T(n, k) = if(n==0, k==0, (k+1)*T(n-1, k)+(n-k)*T(n-1, k-1)+(-1)^n*(k==0));
%Y A395497 Columns k=0..3 give A059841, 2*A091919(n-3), A395498, A395499.
%Y A395497 T(2*n,n) gives A395500.
%Y A395497 Row sums give A000166.
%Y A395497 Cf. A219836.
%K A395497 nonn,tabl,new
%O A395497 0,8
