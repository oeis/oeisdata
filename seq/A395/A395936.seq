%N A395936 Numbers of the form (A004186(k)-A004185(k))/9; i.e., numbers occurring in A151950.
%H A395936 Hugo Pfoertner, <a href="/A395936/b395936.txt">Table of n, a(n) for n = 1..3995</a> (terms 20..73 from Andrey Drozdov)
%o A395936 (PARI) a395936(x10m) = {my(x10=10^x10m, mc=(x10-1)/9, c=vectorsmall(mc), a=[0]); for(n=1, x10, my(d=digits(n), k=fromdigits(vecsort(d,,4)) - fromdigits(vecsort(d))); if(k>0, c[k/9]=1)); for(n=1, mc, if(c[n], a=concat(a,n))); a};
