%I A395246 #18 Jul 14 2026 01:46:13
%S A395246 1,0,1,1,2,2,7,9,28,64,190,537,1705,5314,17403,57278,192537,652915,
%T A395246 2241792,7759418,27089290,95223671,336933072,1199014767,4289525622,
%U A395246 15419511669,55673601949,201829726504,734424491624,2681720960798,9823779704710,36094902629529,132993193703646
%N A395246 Number of multisets of nonisomorphic triangulated m-gons under rotational symmetry on a total of n nodes.
%C A395246 This is the multiset construction applied to A001683, in particular we include K2.
%D A395246 P. Flajolet and R. Sedgewick, Analytic combinatorics, Cambridge University Press, 2009, pages 26,27.
%D A395246 F. Harary and E. Palmer, Graphical Enumeration, Academic Press, 1973, page 52.
%H A395246 Marko Riedel, <a href="/A395246/a395246.maple.txt">Maple code for sequence</a>.
%F A395246 a(n) = (1/n) * Sum_{k=1..n} a(n-k) * Sum_{l|k} l*A001683(l), where a(0)=1.
%o A395246 (SageMath)
%o A395246 def P(n):
%o A395246     if n < 2: return 0
%o A395246     res = 1 / (n - 1) * binomial(2 * n - 4, n - 2)
%o A395246     if n % 2 == 0: res += binomial(n - 2, n // 2 - 1)
%o A395246     if n % 3 == 0: res += 2 * binomial(2 * (n // 3) - 2, (n // 3) - 1)
%o A395246     return res
%o A395246 def A395246_gen():
%o A395246     yield 1
%o A395246     n = 1; save = [1]
%o A395246     while True:
%o A395246         total = 0
%o A395246         for k in range(1, n + 1):
%o A395246             inner = sum(P(l) for l in divisors(k))
%o A395246             total += save[n - k] * inner
%o A395246         qn = total / n
%o A395246         save.append(qn)
%o A395246         yield qn
%o A395246         n += 1
%o A395246 A395246 = A395246_gen()
%o A395246 for n in range(33): print(next(A395246))  # _Peter Luschny_, Jul 13 2026
%Y A395246 Cf. A001683.
%K A395246 nonn,new
%O A395246 0,5
%A A395246 _Marko Riedel_, Jul 12 2026
