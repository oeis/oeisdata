%S A395210 1925,63,2431,1000,41431533,30625,3662497,222264,166966775,426888,
%T A395210 19604380625,583041888,1838389030481,2277507375,7157865535471,
%U A395210 528184889375,6696694484542797,721097217698,119884620161695,1208540458944,69547699769412575,62155907214856,1267873363472004597
%N A395210 Denominator of the probability that the unique sphere passing through four points, selected independently and uniformly at random in an n-ball, is entirely contained within that n-ball.
%C A395210 The probability that the four points are coplanar (i.e., lie on the same plane) and do not define a sphere is 0.
%H A395210 Amiram Eldar, <a href="/A395210/b395210.txt">Table of n, a(n) for n = 3..1002</a>
%H A395210 Fernando Affentranger, <a href="https://doi.org/10.1007/BF01199118">Random spheres in a convex body</a>, Archiv der Mathematik, Vol. 55 (1990), pp. 74-81.
%e A395210 Fractions begin with 24*Pi^2/1925, 11/63, 50*Pi^2/2431, 221/1000, 980000*Pi^2/41431533, 7429/30625, 92610*Pi^2/3662497, 56695/222264, 4390848*Pi^2/166966775, 112375/426888, 529056528*Pi^2/19604380625, 156835045/583041888, ...
%t A395210 a[n_] := Denominator[4 * n^3 * Pi * Gamma[2*n-1] * Gamma[(3*n+5)/2] * Gamma[n/2]^4 / (9 * Binomial[3*n+3, 3] * Gamma[3*n/2] * Gamma[(n-2)/2] * Gamma[2*n+1] * Gamma[(n+1)/2]^3)]; Array[a, 23, 3]
%o A395210 (PARI) gamma_my(n) = if(denominator(n) == 1, (n-1)!, my(m = n - 1/2); (2*m)! / (4^m * m!)); \\ gamma for integers, gamma(n)/sqrt(Pi) for half-integers
%o A395210 a(n) = denominator(4 * n^3 * gamma_my(2*n-1) * gamma_my((3*n+5)/2) * gamma_my(n/2)^4 / (9 * binomial(3*n+3, 3) * gamma_my(3*n/2) * gamma_my((n-2)/2) * gamma_my(2*n+1) * gamma_my((n+1)/2)^3));
%Y A395210 Cf. A395209 (numerators), A395207, A395208, A395211, A395212, A395213, A395214.
%K A395210 nonn,frac,easy,new
%O A395210 3,1
%A A395210 _Amiram Eldar_, Apr 16 2026
