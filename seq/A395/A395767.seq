%I A395767 #18 May 09 2026 11:13:54
%S A395767 1,3,8,22,52,128,288,672,1472,3328,7168,15872,33792,73728,155648,
%T A395767 335872,704512,1507328,3145728,6684672,13893632,29360128,60817408,
%U A395767 127926272,264241152,553648128,1140850688,2382364672,4898947072,10200547328,20937965568,43486543872
%N A395767 Minimal value of p(1) + Sum_{i=2...n} p(i-1)*p(i), as p ranges over all permutations of powers of 2 {1,2,4,...,2^(n-1)}.
%C A395767 The question originated from a generalization of the first puzzle, 'Low Budget', in the book Mathematical Puzzles and Curiosities.
%D A395767 I. David, T. Khovanova, and Y. Shpilman, Mathematical Puzzles and Curiosities, World Scientific, 2026, p.2.
%H A395767 <a href="/index/Rec#order_03">Index entries for linear recurrences with constant coefficients</a>, signature (2,4,-8).
%F A395767 a(n) = 2^(n-5)*(10*n+3+(-1)^n) for n > 1.
%F A395767 a(2n-1) = 2*A229278(n).
%F A395767 G.f.: x*(2*x^3-2*x^2+x+1)/((2*x+1)*(2*x-1)^2).
%e A395767 For n=4, the permutation that realizes the minimum value is 4,2,1,8. So a(4) = 4 + 4*2 + 2*1 + 1* = 22. Thus, a(4) = 22.
%t A395767 a[1]=1;a[n_]:=2^(n-5)*(10*n+3+(-1)^n);Array[a,32]
%t A395767 (* Alternative: *)
%t A395767 {1}~Join~LinearRecurrence[{2,4,-8},{3,8,22},31]
%t A395767 (* Alternative: *)
%t A395767 Rest[CoefficientList[Series[x*(2*x^3-2*x^2+x+1)/((2*x+1)*(2*x-1)^2),{x,0,32}],x]] (* _James C. McMahon_, May 08 2026 *)
%Y A395767 Cf. A026035, A229278, A110610, A110611, A393145.
%K A395767 nonn,easy,new
%O A395767 1,2
%A A395767 _Tanya Khovanova_ and PRIMES STEP junior group, May 05 2026
