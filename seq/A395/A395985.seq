%I A395985 #12 May 16 2026 22:24:55
%S A395985 2,3,4,5,2,7,8,9,10,11,3,13,2,15,16,17,18,19,4,21,22,23,24,25,26,27,
%T A395985 28,29,2,31,32,33,34,35,36,37,38,3,40,41,6,43,44,45,46,47,48,49,50,51,
%U A395985 52,53,54,55,7,57,58,59,60,61,2,63,64,65,66,67,68,69,70,71,8,73,74,75
%N A395985 Smallest base such that n is a repunit in that base.
%C A395985 1<a(n)<n.
%C A395985 When A088323(n)=1, a(n)=n-1.
%C A395985 When A088323(n)>1, a(n)<n-1.
%H A395985 Mital Ashok, <a href="/A395985/b395985.txt">Table of n, a(n) for n = 3..10000</a>
%e A395985 For n = 7, a(7) = 2 because 7 is 111_2 in base 2.
%o A395985 (Python)
%o A395985 def a(n):
%o A395985   for b in range(2, n):
%o A395985     x = (b-1)*n+1
%o A395985     while x%b == 0:
%o A395985       x //= b
%o A395985     if x == 1:
%o A395985       return b
%Y A395985 Cf. A088323, A055129.
%K A395985 nonn,base,new
%O A395985 3,1
%A A395985 _Mital Ashok_, May 13 2026
