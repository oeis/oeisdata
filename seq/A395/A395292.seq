%N A395292 a(n) = (2*n)! * [x^(2*n)] cos(x)^3 / cos(sqrt(2)*x).
%F A395292 a(n) = (-1)^n * (3 + 9^n)/4 - Sum_{k=0..n-1} (-2)^(n-k) * binomial(2*n,2*k) * a(k).
%F A395292 a(n) = (1/4) * Sum_{k=0..n} 2^k * (-1)^(n-k) * (3 + 9^(n-k)) * binomial(2*n,2*k) * A000364(k).
%o A395292 (PARI) a_vector(n) = my(v=vector(n+1)); for(i=0, n, v[i+1]=(-1)^i*(3+9^i)/4-sum(j=0, i-1, (-2)^(i-j)*binomial(2*i, 2*j)*v[j+1])); v;
