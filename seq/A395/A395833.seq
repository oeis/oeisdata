%N A395833 G.f. A(x) satisfies [x^n] A( x/A(x)^(2*n-1) ) = 0 for n > 1.
%C A395833 Conjecture: (2*n-1) divides a(n) for n >= 1.
%C A395833 Conjecture: a(n) == 0 (mod 3) for n >= 2.
%H A395833 Paul D. Hanna, <a href="/A395833/b395833.txt">Table of n, a(n) for n = 0..300</a>
%e A395833 G.f.: A(x) = 1 + x + 3*x^2 + 30*x^3 + 567*x^4 + 16452*x^5 + 663894*x^6 + 35188218*x^7 + 2357921985*x^8 + 194240779128*x^9 + 19248797472504*x^10 + ...
%e A395833 The table of coefficients in A(x/A(x)^(2*n-1)) begins:
%e A395833   n = 1: [1, 1,  2, 22, 443, 13450, 560462, 30401710, ...];
%e A395833   n = 2: [1, 1,  0,  9, 242,  8496, 386502, 22219201, ...];
%e A395833   n = 3: [1, 1, -2,  0,  97,  4747, 249993, 15622392, ...];
%e A395833   n = 4: [1, 1, -4, -5,   0,  1983, 143997, 10327326, ...];
%e A395833   n = 5: [1, 1, -6, -6, -57,     0,  62424,  6090486, ...];
%e A395833   n = 6: [1, 1, -8, -3, -82, -1390,      0,  2705515, ...];
%e A395833   n = 7: [1, 1,-10,  4, -83, -2359, -47765,        0, ...]; ...
%e A395833 in which a diagonal is all zeros after an initial term, showing that [x^n] A( x/A(x)^(2*n-1) ) = 0 for n > 1.
%o A395833 (PARI) {a(n) = my(A=[1, 1]); for(i=2, n, A=concat(A, 0); A[#A] = -Vec(subst(Ser(A), x, x/Ser(A)^(2*#A-3)))[#A]); GF = Ser(A); A[n+1]}
%o A395833 {upto(n) = a(n); Vec(GF)}
%o A395833 upto(25)
