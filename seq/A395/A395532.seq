%I A395532 #43 Jul 03 2026 11:36:31
%S A395532 2,8,5,17,25,9,48,50,51,14,122,145,99,86,20,323,365,291,164,130,27,
%T A395532 842,970,729,486,245,183,35,2208,2525,1941,1214,730,342,245,44,5777,
%U A395532 6625,5049,3236,1820,1023,455,316,54,15128,17330,13251,8414,4855,2547,1365,584,396,65
%N A395532 Square array read by antidiagonals downward: convolved numbers of order n of k-sections of the Fibonacci sequence at the third element position T(n, k) for n >= 0 and k >= 1.
%C A395532 This array represents an alternative cross-slice of the family of matrices of convolved k-sections of the Fibonacci sequence, where the element index within the convolution sequence is fixed at m = 3.
%C A395532 The row index n >= 0 represents the convolution order, while the column index k >= 1 represents the Fibonacci section parameter.
%C A395532 The array is read along the anti-diagonals downward in the order: T(0,1), T(0,2), T(1,1), T(0,3), T(1,2), T(2,1), ...
%C A395532 The array is connected to several classical sequences: the first row (n=0) yields A047946, the first column (k=1) yields A000096, the second column (k=2) yields A062728 (second hendecagonal numbers), and the third column (k=3) yields A005570 (walks on a cubic lattice).
%H A395532 Paolo Xausa, <a href="/A395532/b395532.txt">Table of n, a(n) for n = 0..11324</a> (first 150 antidiagonals, flattened).
%F A395532 T(n, k) = A(m, n, k) for n >= 0 and k >= 1, where
%F A395532   for odd k: A(m, n, k) = (-i)^(m-1) * GegenbauerC(m-1, 1+n, i * L(k) / 2),
%F A395532   for even k: A(m, n, k) = GegenbauerC(m-1, 1+n, L(k) / 2),
%F A395532   where i is the imaginary unit, m=3, and L(k) is the k-th Lucas number.
%F A395532 Alternatively, T(n, k) = (n+1)*(n+2)/2 * A000032(k)^2 + (-1)^(k+1) * (n+1) for n >= 0 and k >= 1.
%e A395532 The square array begins (rows indexed by n >= 0, columns by k >= 1):
%e A395532   n\k 1     2      3       4        5        6
%e A395532   0:  2,    8,    17,     48,     122,     323, ...   (A047946)
%e A395532   1:  5,   25,    50,    145,     365,     970, ...
%e A395532   2:  9,   51,    99,    291,     729,    1941, ...
%e A395532   3: 14,   86,   164,    486,    1214,    3236, ...
%e A395532   4: 20,  130,   245,    730,    1820,    4855, ...
%e A395532   5: 27,  183,   342,   1023,    2547,    6798, ...
%e A395532   ...
%e A395532 The array is read along anti-diagonals downward (rows indexed by n >= 0, columns by k >= 1):
%e A395532   d=1: T(0,1) = 1*2/2 * 1^2 + 1 = 2.
%e A395532   d=2: T(0,2) = 1*2/2 * 3^2 - 1 = 8;  T(1,1) = 2*3/2 * 1^2 + 2 = 5.
%e A395532   d=3: T(0,3) = 1*2/2 * 4^2 + 1 = 17; T(1,2) = 2*3/2 * 3^2 - 2 = 25; T(2,1) = 3 * 4/2 * 1^2 + 3 = 9.
%p A395532 T := proc(n, k) local Lk; Lk := round((1/2 + 1/2*sqrt(5))^k + (1/2 - 1/2*sqrt(5))^k); return (1/2*n + 1/2)*(n + 2)*Lk^2 + (-1)^(k + 1)*(n + 1); end proc;
%p A395532 for n from 0 to 5 do
%p A395532     print(seq(T(n, k), k = 1 .. 6));
%p A395532 end do;
%t A395532 A395532[n_, k_] := (n+1)*(LucasL[k]^2*(n+2)/2 - (-1)^k);
%t A395532 Table[A395532[j, j - n - 1], {n, 0, 10}, {j, 0, n}] (* _Paolo Xausa_, Jul 03 2026 *)
%Y A395532 Cf. A000032, A000096 (col 1), A005570 (col 3), A047946 (row 1), A062728 (col 2), A395431, A395902, A393329, A396358.
%K A395532 nonn,tabl,changed
%O A395532 0,1
%A A395532 _Alex Stokolos_, May 30 2026
