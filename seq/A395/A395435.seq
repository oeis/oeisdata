%I A395435 #3 Apr 22 2026 22:09:21
%S A395435 1,2,2,4,2,4,2,8,5,4,2,12,2,4,4,16,2,13,2,16,4,4,2,28,7,4,14,20,2,8,2,
%T A395435 32,4,4,4,45,2,4,4,40,2,8,2,28,22,4,2,60,9,19,4,32,2,40,4,52,4,4,2,56,
%U A395435 2,4,28,64,4,8,2,40,4,8,2,109,2,4,24,44,4,8,2,88,41,4,2,72,4,4,4,76,2,62,4,52,4,4,4,124
%N A395435 a(n) = sigma(n) - usigma(n) + tau(rad(n)).
%C A395435 For each divisor d of n, add 1 if gcd(d,n/d) = 1, else add d.
%F A395435 a(n) = Sum_{d|n} d^(1 - [gcd(d,n/d) = 1]), where [ ] is the Iverson bracket.
%F A395435 a(n) = A000203(n) - A034448(n) + A034444(n).
%e A395435 a(12) = 1^0 + 2^1 + 3^0 + 4^0 + 6^1 + 12^0 = 12.
%t A395435 Table[Sum[d^(1 - KroneckerDelta[GCD[d, n/d], 1]), {d, Divisors[n]}], {n, 100}]
%Y A395435 Cf. A000005 (tau), A000203 (sigma), A007947 (rad), A034444, A034448 (usigma).
%K A395435 nonn,easy,new
%O A395435 1,2
%A A395435 _Wesley Ivan Hurt_, Apr 22 2026
