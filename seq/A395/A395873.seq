%I A395873 #7 May 13 2026 12:11:49
%S A395873 1,1,2,12,47,267,1447,8590,51682,321146,2029853
%N A395873 Number of oriented polyominoes in the {5,4} tessellation of the hyperbolic plane.
%C A395873 For oriented polyominoes, chiral pairs are counted as two.
%H A395873 <a href="https://oeis.org/wiki/PF-Non-Euclidean">Wiki page indexing sequences related to non-euclidean polyforms</a>
%F A395873 a(n) = P{p,q}(n) (the number of oriented {p,q} polyominoes of size n) is equal to P{p,oo}(n) for n <= q. In this case, P{p,oo} = A005038.
%t A395873 (* Cf. A394862 with p=5 and q=4. *)
%Y A395873 Cf. A005038, A330211, A394862.
%K A395873 nonn,more,new
%O A395873 1,3
