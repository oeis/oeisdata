%S A395591 8,18,44,28,72,124,38,102,180,268,48,132,238,360,492,58,162,298,456,
%T A395591 630,816,68,192,358,554,772,1008,1256,78,222,418,654,918,1206,1512,
%U A395591 1832,88,252,478,754,1066,1408,1774,2160,2560,98,282,538,854,1216,1614,2042,2496,2970,3460
%N A395591 Triangle read by rows: T(n,k) is the number of triangles formed in an n X k rectangular grid of unit squares with diagonals drawn in all squares, 1 <= k <= n.
%H A395591 Akimenko Daniil, <a href="https://drive.google.com/drive/folders/1EoSTtQ5Q-6eQ-9o-Qi-_QzUNdFfk5IQo?usp=sharing">The number of triangles in a nXm grid divided into unit squares, each with both diagonals drawn</a>
%F A395591 T(n,k) = 4 * Sum_{i=0..k-1} (n-i)*(k-i) + 2 * Sum_{i=0..min(k-1,floor((2*n-1)/4))} (k-i)*(2*n-1-4*i) + 2*Sum_{i=0..floor((2*k-1)/4)} (n-i)*(2k-1-4i).
%F A395591 T(n,n) = A100583(n).
%e A395591 Triangle begins
%e A395591   8;
%e A395591   18 44;
%e A395591   28 72 124;
%e A395591   38 102 180 268;
%e A395591   48 132 238 360 492;
%e A395591   58 162 298 456 630 816;
%e A395591   68 192 358 554 772 1008 1256;
%e A395591   ...
%o A395591 (Python)
%o A395591 def counting_triangles_in_grid_n_on_k(n, k):
%o A395591     if k > n:
%o A395591         n, k = k, n
%o A395591         print("You entered a number less than the value of the smaller side\n"
%o A395591               "of the grid into the value of the larger side of the grid, \n"
%o A395591               "so these values were rearranged")
%o A395591     sum_triangles = 0
%o A395591     i = 0
%o A395591     while i < k:
%o A395591         #The sum of the triangles whose legs lie on the borders of the grid
%o A395591         sum_triangles += 4 * (n - i) * (k - i)
%o A395591         i += 1
%o A395591     i = 0
%o A395591     while i < k and i < (2*n - 1)/4:
%o A395591         # The sum of triangles whose hypotenuse lies on the border of the grid and it's vertical
%o A395591         sum_triangles += 2 * (k - i) * (2 * n - 1 - 4 * i)
%o A395591         i += 1
%o A395591     i = 0
%o A395591     while i < (2*k - 1)/4:
%o A395591         # The sum of triangles whose hypotenuse lies on the border of the grid and it's horizontal
%o A395591         sum_triangles += 2 * (n - i) * (2 * k - 1 - 4 * i)
%o A395591         i += 1
%o A395591     return sum_triangles
%o A395591 for n in range(1, 11):
%o A395591     print(n, end=" ")
%o A395591     for k in range(1, 11):
%o A395591         if n > k: print(counting_triangles_in_grid_n_on_k(n, k), end=", ")
%o A395591         if n == k: print(counting_triangles_in_grid_n_on_k(n, k))
%o A395591 (PARI) T(n, k) = my(s=4*sum(i=0, k-1, (n-i)*(k-i))); my(i=0); while ((i<=k-1) && (i < (2*n-1)/4), s += 2*(k-i)*(2*n-1-4*i); i++); i=0; while((i < (2*k-1)/4), s += 2*(n-i)*(2*k-1-4*i); i++); s;
%o A395591 row(n) = vector(n, k, T(n,k));
%o A395591 vector(10, n, row(n)) \\ _Michel Marcus_, May 01 2026
