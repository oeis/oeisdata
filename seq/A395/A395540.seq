%T A395540 11,11,11,12,12,12,12,12,12,12,12,12,12,12,12,12,12,12,12,13,13,13,13,
%U A395540 13,13,13,13,13,13,13,13,13,13,13,13,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,15,15,15
%N A395540 a(n) = floor(log_2(n)) + floor(log_2(2*n/3)) + 3.
%C A395540 For n >= 4, a(n - 1) is the tree-depth of the n-prism graph. - _Eric W. Weisstein_, Jul 08 2026
%C A395540 For n >= 4, a(n) is the tree-depth of the n-Moebius ladder. - _Eric W. Weisstein_, Jul 08 2026
%H A395540 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/MoebiusLadder.html">Moebius Ladder</a>.
%H A395540 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/PrismGraph.html">Prism Graph</a>.
%H A395540 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/Tree-Depth.html">Tree-Depth</a>.
%F A395540 a(n) = floor(log_2(n)) + floor(log_2(2*n/3)) + 3 for n >= 1. - _Eric W. Weisstein_, Jul 08 2026
%F A395540 a(n) = floor(log_2(n)) + floor(log_2(n - 2^(floor(log_2(n - 1)) - 1))) + 3 for n >= 3. - _Eric W. Weisstein_, Jul 08 2026
%e A395540 a(3) = 5 since floor(log_2(3)) + floor(log_2(2)) + 3 = 5.
%t A395540 Table[Floor[Log2[n]] + Floor[Log2[2*n/3]] + 3, {n, 20}] (* _Eric W. Weisstein_, Jul 08 2026 *)
%t A395540 (* Alternative: *)
%t A395540 Table[Floor[Log2[n]] + Floor[Log2[n - 2^(Floor[Log2[n - 1]] - 1)]] + 3, {n, 3, 20}] (* _Eric W. Weisstein_, Jul 08 2026 *)
%Y A395540 Cf. A394938 (tree-depths of antiprism graphs).
