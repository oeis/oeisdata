%T A395540 11,11,11,12,12,12,12,12,12,12,12,12,12,12,12,12,12,12,12,13,13,13,13,
%U A395540 13,13,13,13,13,13,13,13,13,13,13,13,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,14,15,15
%N A395540 a(n) = floor(log_2(n - 1)) + floor(log_2(n - 1 - 2^(floor(log_2(n - 2)) - 1))) + 3.
%C A395540 For n >= 4, a(n) is the tree-depth of the n-prism graph.
%H A395540 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/PrismGraph.html">Prism Graph</a>.
%H A395540 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/Tree-Depth.html">Tree-Depth</a>.
%F A395540 a(n) = floor(log_2(n - 1)) + floor(log_2(n - 1 - 2^(floor(log_2(n - 2)) - 1))) + 3 for n >= 3.
%e A395540 a(4) = 5 since floor(log_2(3)) + floor(log_2(2)) + 3 = 5.
%t A395540 Table[Floor[Log2[n - 1]] + Floor[Log2[n - 1 - 2^(Floor[Log2[n - 2]] - 1)]] + 3, {n, 3, 20}]
%Y A395540 Cf. A394938 (tree-depths of antiprism graphs).
