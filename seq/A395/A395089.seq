%N A395089 Binary complement of A395088.
%C A395089 Start with 1, apply 1 -> 100, 0 -> 1, take limit.
%C A395089 Define strings S(0) = 0, S(1) = 1, S(n) = S(n-1)S(n-2)S(n-2); iterate; sequence is S(infinity).
%C A395089 Related to the Thue-Morse sequence A010060 (see formula section).
%F A395089 a(n) = 1 - A395088(n).
%F A395089 a(n) = A026465(n+2) - 1.
%F A395089 P(a(n) = 0) = P(a(n) = 1) = 1/2.
%F A395089 a(n) = A284391(n+2).
%F A395089 a(n) = A284388(n+3).
%e A395089 100111001001001110011100111001001001110010010011...
%t A395089 f[n_]:=Module[{a={1},b={0}},While[Length[a]<n,{a,b}={Join[a,b,b],a}];Take[a,n]];a[n_]:=Module[{a={1},b={0}},While[Length[a]<=n,{a,b}={Join[a,b,b],a}];a[[n+1]]];a/@Range[0,86] (* _Robert P. P. McKone_, Apr 14 2026 *)
%o A395089 (Python)
%o A395089 def first(n): # returns first n terms
%o A395089     f0, f1 = "10"
%o A395089     while len(f0) < n:
%o A395089         f0, f1 = f0+2*f1, f0
%o A395089     return list(map(int, f0[0:n]))
%o A395089 print(first(87))
