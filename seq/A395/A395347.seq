%I A395347 #48 May 03 2026 18:36:34
%S A395347 1,1,1,7,1,1,13,13,1,21,19,1,1,21,1,31,7,1,21,31,1,1,43,39,37,31,1,43,
%T A395347 39,31,1,57,13,1,1,43,39,1,57,1,1,43,1,73,67,1,7,57,61,13,1,43,1,73,
%U A395347 67,7,57,1,1,91,21,79,73,19,67,1,57,91,1,79
%N A395347 Squarefree part of b^2 - b*c + c^2 for triples (a,b,c) with a<=b<=c, a+b>c, gcd(a,b,c)=1, ordered by perimeter.
%C A395347 All terms are odd.
%C A395347 The quadratic form b^2 - b*c + c^2 generates numbers whose prime factors are 3, primes congruent to 1 mod 3, and squares of primes congruent to 2 mod 3. The squarefree part of these numbers yields numbers whose prime factors are only 3 and primes congruent to 1 mod 3 (A007645).
%C A395347 The sequence is sorted by the sum a+b+c (perimeter).
%e A395347 For the triangle (1,1,1): b^2 - b*c + c^2 = 1, squarefree part is 1.
%e A395347 For the triangle (1,2,2): b^2 - b*c + c^2 = 4, squarefree part is 1.
%e A395347 For the triangle (2,2,3): b^2 - b*c + c^2 = 7, squarefree part is 7.
%o A395347 (Python)
%o A395347 from sympy.ntheory.factor_ import core
%o A395347 from math import gcd
%o A395347 def A395347(terms=70):
%o A395347     seq, p = [], 3
%o A395347     while len(seq) < terms:
%o A395347         for a in range(1, p // 3 + 1):
%o A395347             for b in range(a, (p - a) // 2 + 1):
%o A395347                 c = p - a - b
%o A395347                 if c >= b and a + b > c and gcd(a, b, c) == 1:
%o A395347                     seq.append(core(b * b - b * c + c * c, 2))
%o A395347         p += 1
%o A395347     return seq[:terms]
%Y A395347 Cf. A007645, A007913, A003136, A034017, A034021, A266836.
%K A395347 nonn,easy,new
%O A395347 1,4
%A A395347 _Chen Zhao_, Apr 20 2026
