%I A105616 #17 Jul 20 2026 03:10:22
%S A105616 1,4,26,226,2426,30826,451586,7489426,138722426,2839238026,
%T A105616 63654973826,1551919194226,40888965122426,1157981114051626,
%U A105616 35083865696279426,1132449247218851026,38800104353355372026,1406432065083818193226
%N A105616 Column 1 of triangle A105615.
%C A105616 Also equals column 0 of triangle A105623 (offset 1), where A105623 equals the matrix square-root of triangle A105615.
%C A105616 Let W_n be the set of words w=(w_1,...,w_n) of nonnegative integers such that w_0=0 and 0 <= w_i <= w_{i-1}+1. Define p(w) = Product_{i=0..n-1}(w_i+2), with p(empty word)=1. Then a(n) = Sum_{w in W_n} p(w). Thus a(n) is the sum of the next-place values over all length-n Catalan area words in this digit-dependent mixed-radix system. - _Philip Weiss_, Jul 09 2026
%F A105616 Let D(x) = Sum_{n>=0} (2*n-1)!!*x^n and E(x) = Sum_{n>=0} (2*n)!!*x^n, regarded as formal power series, with (-1)!!=0!!=1. Then Sum_{n>=0} a(n)*x^n = (E(x)/D(x)-1)/x. - _Philip Weiss_, Jul 09 2026
%o A105616 (PARI) {a(n)=if(n<0,0,(matrix(n+2,n+2,m,j,if(m>=j,if(m==j,1,if(m==j+1,-2*j, polcoeff(1/sum(i=0,m-j,(2*i)!/i!/2^i*x^i)+O(x^m),m-j) ))))^-1)[n+2,2])}
%Y A105616 Cf. A105615, A105623.
%Y A105616 Cf. A193229 (the weighted Catalan triangle used in deriving the formula).
%K A105616 nonn,changed
%O A105616 0,2
%A A105616 _Paul D. Hanna_, Apr 16 2005
