%I A105692 #6 Jun 05 2026 19:21:25
%S A105692 1,2,6,12,8,18,14,20,10,30,4,26,24,32,40,36,38,42,44,48,16,50,46,56,
%T A105692 54,60,62,68,74,72,66,34,78,96,114,82,52,108,58,84,80,102,110,92,90,
%U A105692 28,70,86,98,122,76,120,116,94,88,22,138,100,132,104,128,156,126,158,146,144
%N A105692 Minimal a(n)>0, not appeared previously, such that p(n)*p(n+1)+a(n) is prime.
%C A105692 1 and permutation(?) of even integers. Cf. A074928
%H A105692 Robert Israel, <a href="/A105692/b105692.txt">Table of n, a(n) for n = 1..10000</a>
%p A105692 N:= 200: # for terms before the first term > N
%p A105692 R:= 1: Cands:= 2*[$1..N/2]:
%p A105692 q:= 3:
%p A105692 for nC from nops(Cands) to 1 by -1 do
%p A105692   p:= q; q:= nextprime(q); s:= p*q;
%p A105692   found:= false;
%p A105692   for i from 1 to nC do
%p A105692     if isprime(s+Cands[i]) then
%p A105692       found:= true;
%p A105692       R:= R, Cands[i];
%p A105692       Cands:= subsop(i=NULL, Cands);
%p A105692       break
%p A105692     fi
%p A105692   od;
%p A105692   if not found then break fi;
%p A105692 od:
%p A105692 [R]; # _Robert Israel_, Jun 05 2026
%Y A105692 Cf. A074928.
%K A105692 nonn,changed
%O A105692 1,2
%A A105692 _Zak Seidov_, Apr 17 2005
