%S A105474 1,0,2,0,1,4,0,2,4,8,0,1,9,12,16,0,2,8,30,32,32,0,1,14,37,88,80,64,0,
%T A105474 2,12,66,136,240,192,128,0,1,19,75,257,440,624,448,256,0,2,16,116,352,
%U A105474 890,1312,1568,1024,512,0,1,24,126,564,1401,2844,3696,3840,2304,1024
%N A105474 Triangle read by rows: T(n,k) is number of compositions of n into k parts when each odd part can be of two kinds.
%H A105474 Alois P. Heinz, <a href="/A105474/b105474.txt">Rows n = 0..200, flattened</a>
%F A105474 G.f.: 1+t*z(2+z)/(1-2*t*z-z^2-t*z^2).
%F A105474 Sum_{k=0..n} (-1)^k * T(n,k) = A110164(n). - _Alois P. Heinz_, Apr 21 2026
%e A105474 T(4,2) = 9 because we have (1,3),(1',3),(1,3'),(1',3'),(3,1),(3',1),(3,1'),(3',1') and (2,2).
%e A105474 Triangle begins:
%e A105474   1;
%e A105474   0, 2;
%e A105474   0, 1, 4;
%e A105474   0, 2, 4,  8;
%e A105474   0, 1, 9, 12, 16;
%e A105474   0, 2, 8, 30, 32, 32;
%e A105474   ...
%p A105474 G:=1+t*z*(2+z)/(1-2*t*z-z^2-t*z^2): Gser:=simplify(series(G, z, 14)): for n from 0 to 12 do P[n]:=sort(coeff(Gser, z, n)) od: for n from 0 to 12 do seq(coeff(P[n], t, k), k=0..n) od; # yields sequence in triangular form
%p A105474 # Alternative:
%p A105474 b:= proc(n) option remember; `if`(n=0, 1, expand(
%p A105474       add(b(n-j)*`if`(j::odd, 2, 1)*x, j=1..n)))
%p A105474     end:
%p A105474 T:= (n, k)-> coeff(b(n), x, k):
%p A105474 seq(seq(T(n,k), k=0..n), n=0..10);  # _Alois P. Heinz_, Apr 21 2026
%Y A105474 Row sums yield A052945.
%Y A105474 Alternating row sums give A110164.
%Y A105474 Main diagonal gives A000079.
%K A105474 nonn,tabl,changed
%O A105474 0,3
%A A105474 _Emeric Deutsch_, Apr 09 2005
%E A105474 Row n=0 and column k=0 from _Alois P. Heinz_, Apr 21 2026
