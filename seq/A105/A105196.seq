%S A105196 1,1,4,2,12,27,6,44,162,256,24,200,945,2560,3125,120,1096,6075,21760,
%T A105196 46875,46656,720,7056,43848,188160,546875,979776,823543,5040,52272,
%U A105196 354564,1732864,6125000,15023232,23059204,16777216,40320,438336,3189348
%N A105196 Triangle read by rows: T(n,k) = |Stirling1(n,k)| * k^k, for 1 <= k <= n.
%C A105196 T(n,k) is the number of partitions of [n] into a list of trees of cycles, with k cycles in total. - _Natalia L. Skirrow_, Jul 12 2026
%F A105196 T(n,k) = |Stirling1(n,k)|*k^k.
%F A105196 From _Natalia L. Skirrow_, Jul 12 2026: (Start)
%F A105196 E.g.f. (with T(0,0) = 1 prepended): 1/(1 - T(y*log(1/(1-x)))) = 1/(1 + W(y*log(1-x))), where T(x) = -W(-x) and T(x) is Euler's tree function, W(x) is the Lambert W function.
%F A105196 n-th row's center of mass is ~ n/(e*(e^(1/e)-1)), approx. n*0.8273128629895801, and variance is ~ n*(e-(e-1)*e^(1/e))/(e*(e^(1/e)-1))^2, approx. 0.1614851039889884.
%F A105196 (End)
%e A105196 Table begins:
%e A105196 n\k|  1    2    3     4     5     6
%e A105196 ---+-------------------------------
%e A105196  1 |  1
%e A105196  2 |  1    4
%e A105196  3 |  2   12   27
%e A105196  4 |  6   44  162   256
%e A105196  5 | 24  200  945  2560  3125
%e A105196  6 |120 1096 6075 21760 46875 46656
%p A105196 (n,k) -> abs(stirling1(n,k))*k^k;
%t A105196 Flatten[Table[Table[k^k Abs[StirlingS1[n, k]], {k, 1, n}], {n, 1, 9}], 1]
%Y A105196 Cf. A008275, A305981 (row sums).
%Y A105196 Cf. A105197 (similar triangle for S2).
