%S A105694 1,10,99,990,9900,99000,990000,9900000,99000000,990000000,9900000000,
%T A105694 99000000000,990000000000,9900000000000,99000000000000,
%U A105694 990000000000000,9900000000000000,99000000000000000,990000000000000000,9900000000000000000,99000000000000000000,990000000000000000000
%N A105694 a(n) = ceiling(10^n - 10^(n-2)).
%C A105694 Apply the Riordan array (1-x,x/(1+x)) to 11^n.
%H A105694 <a href="/index/Rec#order_01">Index entries for linear recurrences with constant coefficients</a>, signature (10).
%F A105694 G.f.: (x-1)*(x+1)/(10*x-1).
%F A105694 a(n) = 10^n - 10^(n-2), n>1; a(0)=1, a(1)=10.
%F A105694 From _Elmo R. Oliveira_, Jun 13 2026: (Start)
%F A105694 a(n) = 10*a(n-1) for n > 2.
%F A105694 E.g.f.: (1 + 10*x + 99*exp(10*x))/100. (End)
%t A105694 Join[{1,10},NestList[10#&,99,20]] (* _Harvey P. Dale_, Sep 18 2022 *)
