%S A227931 5521819,33014273,36183593,39874273,47143739,82934191,83640653,
%T A227931 86225437,89121073,99551093,104663773,108616619,109514719,117611519,
%U A227931 131616409,142348637,151942291,168056137,168066791,172096037,196415237,197604227,203519819,204983507
%N A227931 Smallest of 5 consecutive primes with equal digital sum.
%C A227931 This sequence consists of all p = A210629(k) for which A210629(k+1) = nextprime(p+1). Terms such that a(n+1) = nextprime(a(n)+1) give A227933. - _M. F. Hasler_, May 07 2026
%H A227931 M. F. Hasler, <a href="/A227931/b227931.txt">Table of n, a(n) for n = 1..470</a> (based on earlier incomplete b-file by _Shyam Sunder Gupta_), May 07 2026
%e A227931 5521819 is in the sequence because 5521819, 5521891, 5521927, 5521963 and 5521981 are consecutive primes and the sum of the digits of each = 31.
%t A227931 a = {}; m = 1; s = 1; Do[If[(y = Apply[Plus, IntegerDigits[x = Prime[n]]]) == s , m = m + 1; If[m == 6, AppendTo[a, Prime[n - 5]]], m = 1]; s = y, {n, 2, 100000000}];a (* WARNING: misses some terms! *)
%t A227931 (* Alternative: *)
%t A227931 Select[Partition[Prime[Range[11340000]],5,1],Length[Union[Total/@(IntegerDigits/@ #)]] == 1&][[All,1]] (* _Harvey P. Dale_, Apr 14 2022 *)
%o A227931 (PARI) A227931_first(N)=A395623(5, N) /* might become slow; alternatively use the following with a precomputed vector A210629, e.g., from the b-file: */
%o A227931 A227931_start = [p | k<-[2..#A=A210629], A[k]==nextprime(1+p=A[k-1])] \\ _M. F. Hasler_, May 07 2026
%Y A227931 Cf. A071613 (column 1 of A395623); A066540, A209396, A210629, A227933 (similar for runs of length 2, 3, 4 and 6).
%Y A227931 Row 5 of A395623.
%K A227931 nonn,base,changed
%O A227931 1,1
