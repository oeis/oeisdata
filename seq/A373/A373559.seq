%I A373559 #22 Apr 03 2026 19:04:33
%S A373559 1,4,16,36,64,144,256,324,576,900,1024,1296,2304,2916,3600,4096,5184,
%T A373559 8100,9216,11664,14400,16384,20736,22500,26244,32400,36864,44100,
%U A373559 46656,57600,65536,72900,82944,90000,104976,129600,147456,176400,186624,202500,230400,236196,262144
%N A373559 Squares k such that rad(k) is a primorial number.
%C A373559 Squares k such that the squarefree kernel of k is primorial.
%C A373559 Intersection of A000290 and A055932.
%C A373559 1 is the only primorial term.
%C A373559 From _Michael De Vlieger_, Jun 09 2024: (Start)
%C A373559 Contains k^2 for k in each of A000079, A033845, A143207, A147571, A147572, etc.
%C A373559 Contains k^2 such that k is a product of primorials, i.e., A025487(i)^2, i >= 1, since A025487 is a proper subset of A055932. (End)
%H A373559 Michael De Vlieger, <a href="/A373559/b373559.txt">Table of n, a(n) for n = 1..10000</a>
%F A373559 a(n) = A055932(n)^2.
%e A373559 1 is a square, rad(1) = 1 = A002110(0).
%e A373559 4 is a square and rad(4) = 2 = A002110(1).
%e A373559 36 is a square and rad(36) = 6 = A002110(2).
%t A373559 {1}~Join~Select[Range[2, 512, 2], Or[# == {2}, Union@ Differences@ PrimePi[#] == {1}] &@ FactorInteger[#][[All, 1]] &]^2 (* _Michael De Vlieger_, Jun 09 2024 *)
%o A373559 (Python)
%o A373559 from functools import lru_cache
%o A373559 from itertools import count
%o A373559 from math import isqrt
%o A373559 from sympy import prime, integer_log
%o A373559 from oeis_sequences.OEISsequences import bisection
%o A373559 def A373559(n):
%o A373559     @lru_cache(maxsize=None)
%o A373559     def g(x, m): return sum(g(x//(prime(m)**i), m-1) for i in range(1,integer_log(x, prime(m))[0]+1)) if m-1 else x.bit_length()-1
%o A373559     def f(x):
%o A373559         c, p, y = n-1+x, 1, isqrt(x)
%o A373559         for k in count(1):
%o A373559             p *= prime(k)
%o A373559             if p>y:
%o A373559                 break
%o A373559             c -= g(y,k)
%o A373559         return c
%o A373559     return bisection(f,n,n) # _Chai Wah Wu_, Apr 02 2026
%o A373559 (Python)
%o A373559 from itertools import islice
%o A373559 from heapq import heappop, heappush
%o A373559 from sympy import nextprime
%o A373559 def A373559_gen(): # generator of terms if the first n terms are desired.
%o A373559     h, hset = [(1,(1,))], {1}
%o A373559     while True:
%o A373559         m, ps = heappop(h)
%o A373559         yield m
%o A373559         for p in ps:
%o A373559             mp = m*p**2
%o A373559             if mp not in hset:
%o A373559                 heappush(h,(mp,ps))
%o A373559                 hset.add(mp)
%o A373559         q = nextprime(max(ps,default=1))
%o A373559         mp = m*q**2
%o A373559         if mp not in hset:
%o A373559             heappush(h,(mp,(ps+(q,))))
%o A373559             hset.add(mp)
%o A373559 A373559_list = list(islice(A373559_gen(),43)) # _Chai Wah Wu_, Apr 02 2026
%Y A373559 Cf. A000290, A002110, A007947, A055932.
%K A373559 nonn,easy
%O A373559 1,2
%A A373559 _David James Sycamore_, Jun 09 2024
%E A373559 More terms from _David A. Corneth_, Jun 09 2024
