%T A373060 10867,9521,17699,13339,25415,27133,27841,23783,48977,39721,46343,
%U A373060 55555,72565,47909,104533,58591,100979,108833,104731,139451,185035,99901,146729,181159,251719
%N A373060 a(n) = Sum_{1 <= x_1, x_2, x_3 <= n} gcd(x_1, n)/gcd(x_1, x_2, x_3, n).
%H A373060 Amiram Eldar, <a href="/A373060/b373060.txt">Table of n, a(n) for n = 1..10000</a> (terms 1..200 from Seiichi Manyama)
%F A373060 Multiplicative with a(p^e) = Sum_{i,j,k=0..e} f(i,e,p)*f(j,e,p)*f(k,e,p)*p^(3*e-3-min(i, j, k)-j-k), where f(m,e,p) = p-1 if m < e, and p if m = e. - _Amiram Eldar_, Apr 21 2026
%t A373060 g[p_, i_, e_] := If[i == e, p, p-1]; f[p_, e_] := Sum[Sum[Sum[p^(3*e - 3 - Min[i, j, k] - j - k) * If[i == e, p, p - 1], {i, 0, e}] * If[j == e, p, p - 1], {j, 0, e}]*If[k == e, p, p - 1], {k, 0, e}]; a[1] = 1; a[n_] := Times @@ f @@@ FactorInteger[n]; Array[a, 100] (* _Amiram Eldar_, Apr 21 2026 *)
%o A373060 (PARI) a(n) = sum(i=1, n, sum(j=1, n, sum(k=1, n, gcd(i, n)/gcd([i, j, k, n]))));
%o A373060 (PARI) g(p, e) = sum(k = 0, e, if(k == e, p, p-1) * sum(j = 0, e, if(j == e, p, p-1) * sum(i = 0, e, if(i == e, p, p-1) * p^(3*e - 3 - vecmin([i, j, k]) - j - k))));
%o A373060 a(n) = {my(f = factor(n)); prod(i = 1, #f~, g(f[i, 1], f[i, 2]));} \\ _Amiram Eldar_, Apr 21 2026
%Y A373060 Cf. A372952, A373061.
