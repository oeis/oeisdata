%N A373771 Expansion of e.g.f. exp(x^2 / (2 * (1 - x)^3)) / (1 - x).
%H A373771 Robert Israel, <a href="/A373771/b373771.txt">Table of n, a(n) for n = 0..426</a>
%F A373771 a(n) = n! * Sum_{k=0..floor(n/2)} binomial(n+k,n-2*k)/(2^k * k!).
%F A373771 D-finite with recurrence: 2*(n + 1)^2*(n + 2)*(n + 3)*a(n) - (15 + 8*n)*(n + 2)*(n + 3)*a(n+1) + 4*(7 + 3*n)*(n + 3)*a(n+2) - 2*(13 + 4*n)*a(n + 3) + 2*a(n + 4) = 0. - _Robert Israel_, May 06 2026
%p A373771 f:= gfun:-rectoproc({2*(n + 1)^2*(n + 2)*(n + 3)*a(n) - (15 + 8*n)*(n + 2)*(n + 3)*a(n+1) + 4*(7 + 3*n)*(n + 3)*a(n+2) - 2*(13 + 4*n)*a(n + 3) + 2*a(n + 4), a(0) = 1, a(1) = 1, a(2) = 3, a(3) = 18}, a(n), remember):
%p A373771 map(f, [$0..25]); # _Robert Israel_, May 06 2026
%o A373771 (PARI) a(n) = n!*sum(k=0, n\2, binomial(n+k, n-2*k)/(2^k*k!));
