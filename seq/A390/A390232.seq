%T A390232 10243813494702080,10163266698756161536,12678333853101857177600,
%U A390232 19422906944247900899639296,35848212199606304514894725120,78455159096957357408585311584256,200891413690245126967691882151280640
%N A390232 a(n) = (2*n)! * [x^(2*n)] (f(x)^2 + f(-x)^2)/2 and f(x) = 1/(cos(x) + sqrt(3) * sin(x)).
%F A390232 a(n) = (2*n)! * [x^(2*n)] (1 + 2*sin(x)^2)/(1 - 4*sin(x)^2)^2.
%F A390232 Let A(n,k) = (2*n)! * [x^(2*n)] (f(x)^k + f(-x)^k)/2. A(0,k) = 1 and A(0,k) = 1 and A(n,k) = 4*k*(k+1) * A(n-1,k+2) - k^2 * A(n-1,k) for n > 0. a(n) = A(n,2).
%F A390232 a(n) ~ 2^(4*n+2) * 3^(2*n+2) * n^(2*n + 3/2) / (exp(2*n) * Pi^(2*n + 3/2)). - _Vaclav Kotesovec_, Apr 17 2026
%t A390232 nmax = 20; CoefficientList[Series[(1 + 2*Sin[Sqrt[x]]^2)/(1 - 4*Sin[Sqrt[x]]^2)^2, {x, 0, nmax}], x] * (2*Range[0, nmax])! (* _Vaclav Kotesovec_, Apr 17 2026 *)
%o A390232 (PARI) a(n) = my(x='x+O('x^(2*n+1))); (2*n)!*polcoef((1+2*sin(x)^2)/(1-4*sin(x)^2)^2, 2*n);
