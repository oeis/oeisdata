%U A390311 92356064213443430400,5560127550699321600000,356748820743606939648000,24304853343006640115712000,1752429851448311972192256000
%N A390311 a(n) = n!*(4^(n+1) - 3^(n+1)).
%D A390311 Miklos Bona, Introduction to Enumerative and Analytic Combinatorics, CRC Press, 2025, pp. 142-144.
%H A390311 Robert Israel, <a href="/A390311/b390311.txt">Table of n, a(n) for n = 0..364</a>
%F A390311 a(n) = Sum_{i=0..n} binomial(n,i)*3^i*i!*4^(n-i)*(n - i)!.
%F A390311 E.g.f.: 1/((1 - 3*x)*(1 - 4*x)).
%F A390311 D-finite with recurrence: 12*a(n)*(n + 1)*(n + 2) - 7*(n + 2)*a(n + 1) + a(n + 2) = 0. - _Robert Israel_, Apr 01 2026
%p A390311 f:= gfun:-rectoproc({12*a(n)*(n + 1)*(n + 2) - 7*(n + 2)*a(n + 1) + a(n + 2), a(0)=1, a(1) = 7}, a(n), remember):
%p A390311 map(f, [$0..30]); # _Robert Israel_, Apr 01 2026
%t A390311 a[n_]:=n!(4^(n+1)-3^(n+1)); Array[a,19,0]
