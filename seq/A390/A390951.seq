%S A390951 1,7,31,67,276,239,716,483,1332,2928,1304,4835,4169,2383,5422,9894,
%T A390951 12254,4609,15755,11914,6579,21594,16245,27245,41927,23681,12546,
%U A390951 26291,13890,29282,118588,38805,62617,21974,119076,25737,81339,87301,61503,97603,104448,36207,192806,40916,84479
%N A390951 a(1) = 1; for n > 1, a(n) is the number of integers k in [prime(n-1)^3..prime(n)^3 - 1] with exactly 4 divisors.
%e A390951 a(1) = 1 because [1..7] contains 1 number 6 with exactly 4 divisors;
%e A390951 a(2) = 7 because [8..26] contains 7 numbers 8, 10, 14, 15, 21, 22, 26 with exactly 4 divisors;
%e A390951 a(3) = 31 because [27..124] contains 31 numbers 27, 33, 34, ..., 123 with exactly 4 divisors.
%t A390951 a[1]=1; a[n_]/;n>1:=a[n]=Count[DivisorSigma[0,Range[Prime[n-1]^3,Prime[n]^3-1]],4]; a/@Range[1,45] (* _Robert P. P. McKone_, Apr 14 2026 *)
%o A390951 (Magma) [1] cat [#[k: k in [NthPrime(n-1)^3..NthPrime(n)^3-1] | #Divisors(k) eq 4]: n in [2..40]];
%Y A390951 Cf. A030513, A393179, A394917.
%K A390951 nonn,new
%O A390951 1,2
