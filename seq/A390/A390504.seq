%T A390504 41,42,43,45,47,48,49,51,53,54,55,56,57,58,59,60,61,63,65,67,68,69,71,
%U A390504 72,73,74,75,76,77,79,80,81,83,84,85,86,87,89,91,92,93,95,96,97,98,99
%N A390504 Positive integers whose binary representation can be reduced to length zero by removing palindromic substrings of length at least 2.
%H A390504 Codeforces, <a href="https://codeforces.com/group/KnOSBeoKK2/contest/671418/problem/I">Generalization to non-binary strings</a>
%e A390504 3 is a term since 3 = 11_2, which is a palindrome with length 2, so it can be removed.
%e A390504 5 is a term since 5 = 101_2, which is a palindrome with length 3, so it can be removed.
%e A390504 12 is a term since 12 = 1100_2, which can be removed by deleting 11 and then 00.
%o A390504 (Python)
%o A390504 from functools import cache
%o A390504 @cache
%o A390504 def okb(s): return s == "" or any(okb(s[:i]+s[j:]) for i in range(len(s)-1) for j in range(i+2,len(s)+1) if s[i:j] == s[i:j][::-1])
%o A390504 def ok(n): return okb(bin(n)[2:])
%o A390504 print([k for k in range(100) if ok(k)]) # _Michael S. Branicky_, Mar 07 2026
%Y A390504 Cf. A006995.
%K A390504 nonn,base,new
%O A390504 1,1
