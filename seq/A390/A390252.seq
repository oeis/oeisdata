%T A390252 1849,2023,2209,2527,2809,3481,3703,3721,4489,5041,5329,5887,6241,
%U A390252 6727,6889,7921,9409,9583,10201,10609,11449,11767,11881,12769,12943,15463,16129,17161,18769,19321,19663,22201,22801
%N A390252 Numbers k such that sigma(k) = psi(k) + omega(k)^3.
%C A390252 Includes p^2 for all primes p, and 7*p^2 for all primes other than 7. Are there terms other than 1 that are not in these families? - _Robert Israel_, Jul 21 2026
%H A390252 Robert Israel, <a href="/A390252/b390252.txt">Table of n, a(n) for n = 1..5400</a>
%e A390252 28 is in the sequence since sigma(28) = 56 = 48 + 2^3 = psi(28) + omega(28)^3.
%p A390252 filter:= proc(k) local F,s,p,w,t;
%p A390252   F:= ifactors(k)[2];
%p A390252   p:= k * mul(1+1/t[1],t=F);
%p A390252   s:= mul((t[1]^(t[2]+1)-1)/(t[1]-1),t=F);
%p A390252   w:= nops(F);
%p A390252   s = p + w^3;
%p A390252 end proc:
%p A390252 select(filter, [$1..10^5]); # _Robert Israel_, Jul 21 2026
%t A390252 psi[n_] := n * Times @@ (1 + 1/FactorInteger[n][[;; , 1]]); psi[1] = 1; Select[Range[23000], DivisorSigma[1, #] == psi[#] + PrimeNu[#]^3 &] (* _Amiram Eldar_, Oct 30 2025 *)
%Y A390252 Cf. A000203 (sigma), A001615 (psi), A001221 (omega).
%Y A390252 Cf. A387953, A387999, A389478, A390251, A390253.
%K A390252 nonn,changed
%O A390252 1,2
%A A390252 _S. I. Dimitrov_, Oct 30 2025
