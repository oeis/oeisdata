%I A390836 #14 Mar 03 2026 14:37:28
%S A390836 2,3,24,362880,20922789888000,15511210043330985984000000,
%T A390836 126886932185884164103433389335161480802865516174545192198801894375214704230400000000000000
%N A390836 Numerators of ratio n!/sigma(n), when the denominators are > 1 and where n! = factorial(n) (A000142) and sigma(n) = sum of divisors of n (A000203).
%C A390836 The next term is too large to be displayed.
%C A390836 First fractions n!/sigma(n) in their reduced form are: 2/3, 3/2, 24/7, 362880/13, 20922789888000/31, 15511210043330985984000000/31...
%C A390836 All terms are even, the third is 24 and all the next ones are multiples of 24. (verified for n <= 10^5).
%C A390836 See also comment in A390815.
%e A390836 For n = 4, 4!/sigma(4) = 24/7 and 7 does not divide 24, so 24 is a term.
%e A390836 For n = 5, 5!/sigma(5) = 120/6 and 6 divides 120, so 120 is not a term.
%o A390836 (PARI) isok(n) = ((n! % sigma(n)) != 0); \\ A325436.
%o A390836 for(n=1,1000,if(isok(n),print1(numerator(n!/sigma(n))", ")))
%Y A390836 Cf. A000142, A000203.
%Y A390836 Cf. A325436, A390815.
%K A390836 nonn,frac,new
%O A390836 1,1
%A A390836 _Claude H. R. Dequatre_, Feb 17 2026
