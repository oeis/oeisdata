%S A390251 1,4,9,12,25,49,75,121,147,169,289,361,363,507,529,841,867,961,1083,
%T A390251 1369,1587,1681,1849,2209,2523,2809,2883,3481,3721,4107,4489,5041,
%U A390251 5043,5329,5547,6241,6627,6889,7921,8427,9409,10201,10443,10609,11163,11449,11881,12769,13467,15123,15987,16129,17161
%N A390251 Numbers k such that sigma(k) = psi(k) + omega(k)^2.
%C A390251 Includes p^2 for all primes p, and 3*p^2 for all primes p <> 3.  Are there other terms besides 1? - _Robert Israel_, Jul 22 2026
%H A390251 Robert Israel, <a href="/A390251/b390251.txt">Table of n, a(n) for n = 1..400</a>
%e A390251 12 is in the sequence since sigma(12) = 28 = 24 + 2^2 = psi(12) + omega(12)^2.
%p A390251 filter:= proc(x)
%p A390251   local F,p,s,t,w;
%p A390251   F:= ifactors(x)[2];
%p A390251   p:= mul((t[1]+1)*t[1]^(t[2]-1),t=F);
%p A390251   s:= mul((t[1]^(t[2]+1)-1)/(t[1]-1),t=F);
%p A390251   w:= nops(F);
%p A390251   s = p + w^2;
%p A390251 end proc:
%p A390251 select(filter, [$1..20000]); # _Robert Israel_, Jul 22 2026
%t A390251 psi[n_] := n * Times @@ (1 + 1/FactorInteger[n][[;; , 1]]); psi[1] = 1; Select[Range[18000], DivisorSigma[1, #] == psi[#] + PrimeNu[#]^2 &] (* _Amiram Eldar_, Oct 30 2025 *)
%Y A390251 Cf. A000203 (sigma), A001615 (psi), A001221 (omega).
%Y A390251 Cf. A387953, A387999, A389478, A390252, A390253.
%K A390251 nonn,changed
%O A390251 1,2
%A A390251 _S. I. Dimitrov_, Oct 30 2025
