%I A390734 #60 Mar 11 2026 20:58:05
%S A390734 1709,2843,4027,4513,4519,4861,5023,5479
%N A390734 Primes whose fifth power are sums of fifth powers of seven distinct primes.
%C A390734 a(9) > 10000.
%H A390734 Fang, <a href="https://www.zhihu.com/question/1969756064867137498">How can we find all integer solutions where the fifth powers of a prime can be expressed as sums of fifth powers of seven distinct primes?</a> (in Chinese).
%e A390734 1709^5 = 1567^5+1373^5+719^5+503^5+431^5+367^5+349^5.
%e A390734 2843^5 = 2731^5+1933^5+1459^5+709^5+509^5+271^5+31^5.
%e A390734 4027^5 = 3301^5+3169^5+3037^5+2411^5+1481^5+859^5+569^5.
%e A390734 4513^5 = 3673^5+3347^5+3313^5+3041^5+2473^5+1979^5+1087^5.
%e A390734 4519^5 = 4409^5+2447^5+2293^5+2267^5+1319^5+1283^5+101^5.
%e A390734 4861^5 = 4513^5+3329^5+3217^5+2423^5+1381^5+601^5+197^5.
%e A390734 5023^5 = 4013^5+4007^5+3911^5+2767^5+1993^5+1693^5+1039^5.
%e A390734 5479^5 = 5209^5+3691^5+3019^5+2357^5+2339^5+1721^5+1543^5.
%t A390734 f[p_]:=(pp=Prime@Range[2,PrimePi@p-1]^5;IntegerPartitions[p^5,{7},pp]^(1/5));Do[v=f[p];If[v!={},Print[{p,f[p]}]],{p,Prime@Range@PrimePi@6000}]
%Y A390734 Cf. A000040, A000584, A114923.
%K A390734 nonn,hard,more,new
%O A390734 1,1
%A A390734 _Zhining Yang_, Feb 27 2026
