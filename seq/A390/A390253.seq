%I A390253 #25 Jul 23 2026 03:34:53
%S A390253 1,4,9,25,49,121,124,169,189,279,289,361,529,775,841,961,1029,1369,
%T A390253 1519,1681,1849,2209,2604,2809,3481,3721,3751,4489,5041,5239,5329,
%U A390253 6241,6889,7921,8959,9409,10201,10609,11191,11449,11881,12769,16129,16275,16399,17161,18769,19321,22201,22801,24649
%N A390253 Numbers k such that sigma(k) = psi(k) + omega(k)^5.
%C A390253 Includes p^2 for all primes p, 31*p^2 for all primes p <> 31, and 651*p^2 for all primes p other than 3, 7 and 31. Are the only terms not in these families 1, 189 and 1029? - _Robert Israel_, Jul 22 2026
%H A390253 Robert Israel, <a href="/A390253/b390253.txt">Table of n, a(n) for n = 1..500</a>
%e A390253 124 is in the sequence since sigma(124) = 224 = 192 + 2^5 = psi(124) + omega(124)^5.
%p A390253 filter:= proc(x)
%p A390253   local F,p,s,t,w;
%p A390253   F:= ifactors(x)[2];
%p A390253   p:= mul((t[1]+1)*t[1]^(t[2]-1),t=F);
%p A390253   s:= mul((t[1]^(t[2]+1)-1)/(t[1]-1),t=F);
%p A390253   w:= nops(F);
%p A390253   s = p + w^5;
%p A390253 end proc:
%p A390253 select(filter, [$1..10000]); # _Robert Israel_, Jul 22 2026
%t A390253 psi[n_] := n * Times @@ (1 + 1/FactorInteger[n][[;; , 1]]); psi[1] = 1; Select[Range[25000], DivisorSigma[1, #] == psi[#] + PrimeNu[#]^5 &] (* _Amiram Eldar_, Oct 30 2025 *)
%o A390253 (Python)
%o A390253 from math import prod
%o A390253 from sympy import factorint
%o A390253 def ok(n):
%o A390253     f = factorint(n)
%o A390253     sigma = prod((p**(e+1)-1)//(p-1) for p, e in f.items())
%o A390253     omega = len(f)
%o A390253     psi = prod((p+1)*p**(e-1) for p, e in f.items())
%o A390253     return sigma == psi + omega**5
%o A390253 print([k for k in range(25000) if ok(k)]) # _Michael S. Branicky_, Jul 22 2026
%Y A390253 Cf. A000203 (sigma), A001615 (psi), A001221 (omega).
%Y A390253 Cf. A387953, A387999, A389478, A390251, A390252.
%K A390253 nonn,changed
%O A390253 1,2
%A A390253 _S. I. Dimitrov_, Oct 30 2025
