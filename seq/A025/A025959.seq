%t A025959 a[0]=1;a[1]=18;Do[a[n]=(4^(n+1)-2^(n+1))/2+12*a[n-1]-35*a[n-2],{n,2,22}];Table[a[n],{n,0,22}] (* _Vincenzo Librandi_, Jun 01 2026 *)
