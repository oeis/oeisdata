%F A025959 a(n) = -4*2^n/15+32*4^n/3-125*5^n/6+343*7^n/30. - _R. J. Mathar_, Jun 20 2013
%F A025959 a(n) = (4^n-2^n)/2+12*a(n-1)-35*a(n-2). - _Vincenzo Librandi_, Jun 01 2026
%t A025959 CoefficientList[Series[1/((1-2*x)*(1-4*x)*(1-5*x)*(1-7*x)),{x,0,20}],x] (* _Harvey P. Dale_, Jan 11 2026 *)
