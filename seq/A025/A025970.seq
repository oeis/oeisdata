%N A025970 Expansion of 1/((1-2*x)*(1-4*x)*(1-6*x)*(1-12*x)).
%H A025970 Vincenzo Librandi, <a href="/A025970/b025970.txt">Table of n, a(n) for n = 0..900</a>
%H A025970 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (24,-188,576,-576).
%F A025970 a(n) = -2^n/10 + 2*4^n/1 - 9*6^n/2 + 18*12^n/5. - _R. J. Mathar_, Jun 20 2013
%F A025970 a(n) = 24*a(n-1) - 188*a(n-2) + 576*a(n-3) - 576*a(n-4), a(0)=1, a(1)=24, a(2)=388, a(3)=5376. - _Harvey P. Dale_, May 24 2015
%F A025970 a(n) = (4^(n+1)-2^(n+1))/2+18*a(n-1)-72*a(n-2). - _Vincenzo Librandi_, Jun 18 2026
%t A025970 CoefficientList[Series[1/((1-2x)(1-4x)(1-6x)(1-12x)),{x,0,20}],x] (* _Harvey P. Dale_, May 24 2015 *)
%t A025970 (* Alternative: *)
%t A025970 LinearRecurrence[{24,-188,576,-576},{1,24,388,5376},20] (* _Harvey P. Dale_, May 24 2015 *)
%t A025970 (* Alternative: *)
%t A025970 a[0]=1; a[1]=24; Do[a[n]=(4^(n+1)-2^(n+1))/2+18*a[n-1]-72*a[n-2],{n,2,22}]; Table[a[n],{n,0,18}] (* _Vincenzo Librandi_, Jun 18 2026 *)
%o A025970 (Magma) I:=[1, 24]; [n le 2 select I[n] else (4^n-2^n)/2+18*Self(n-1)-72*Self(n-2): n in [1..19]]; // _Vincenzo Librandi_, Jun 18 2026
