%T A025930 885205685,5513890200,34098207781,209668346176,1283419890645,
%U A025930 7827611393000,47601257612741,288785879108496,1748608103548405,10571116251513400,63824046118451301,384931051134427616,2319520273059954965
%N A025930 Expansion of 1/((1-2*x)*(1-3*x)*(1-5*x)*(1-6*x)).
%H A025930 Vincenzo Librandi, <a href="/A025930/b025930.txt">Table of n, a(n) for n = 0..900</a>
%H A025930 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (16,-91,216,-180).
%F A025930 From _Vincenzo Librandi_, Mar 19 2011: (Start)
%F A025930 a(n) = 16*a(n-1) - 91*a(n-2) + 216*a(n-3) - 180*a(n-4), n >= 4.
%F A025930 a(n) = 11*a(n-1) - 30*a(n-2) + 3^(n+1) - 2^(n+1), n >= 2. (End)
%F A025930 a(n) = 3*6^(n+1) - 5^(n+3)/6 + 3^(n+2)/2 - 2^(n+1)/3. - _R. J. Mathar_, Mar 19 2011
%F A025930 E.g.f.: exp(2*x)*(108*exp(4*x) - 125*exp(3*x) + 27*exp(x) - 4)/6. - _Stefano Spezia_, Apr 19 2026
%t A025930 a[0]=1;a[1]=16;a[n_]:=a[n]=3^(n+1)-2^(n+1)+11 a[n-1]-30 a[n-2];Table[a[n],{n,0,22}] (* _Vincenzo Librandi_, Apr 18 2026 *)
%o A025930 (Magma) I:=[1, 16]; [n le 2 select I[n] else 3^n-2^n+11*Self(n-1)-30*Self(n-2): n in [1..25]]; // _Vincenzo Librandi_, Apr 18 2026
%K A025930 nonn,easy,changed
%O A025930 0,2
