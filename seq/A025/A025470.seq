%N A025470 Expansion of 1/((1-2*x)*(1-3*x)*(1-4*x)*(1-9*x)).
%H A025470 Harvey P. Dale, <a href="/A025470/b025470.txt">Table of n, a(n) for n = 0..1000</a>
%H A025470 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (18,-107,258,-216).
%F A025470 a(n) = -4*2^n/7 +9*3^n/2 -32*4^n/5 +243*9^n/70. - _R. J. Mathar_, Jun 30 2013
%F A025470 a(n) = 3^(n+1) - 2^(n+1) + 13*a(n-1) - 36*a(n-2). - _Vincenzo Librandi_, Apr 15 2026
%t A025470 CoefficientList[Series[1/((1-2x)(1-3x)(1-4x)(1-9x)),{x,0,30}],x] (* or *) LinearRecurrence[{18,-107,258,-216},{1,18,217,2238},30] (* _Harvey P. Dale_, Dec 14 2023 *)
%t A025470 a[0]=1; a[1]=18; a[n_]:=a[n]=3^(n+1)-2^(n+1)+13 a[n-1]-36 a[n-2]; Table[a[n],{n,0,20}] (* _Vincenzo Librandi_, Apr 15 2026 *)
%o A025470 (Magma) I:=[1, 18]; [n le 2 select I[n] else 3^n-2^n+13*Self(n-1)-36*Self(n-2): n in [1..25]]; // _Vincenzo Librandi_, Apr 15 2026
