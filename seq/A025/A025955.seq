%N A025955 Expansion of 1/((1-2*x)*(1-3*x)*(1-10*x)*(1-11*x)).
%H A025955 Vincenzo Librandi, <a href="/A025955/b025955.txt">Table of n, a(n) for n = 0..900</a>
%H A025955 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (26,-221,676,-660).
%F A025955 a(n) = -2^n/9+27*3^n/56-125*10^n/7+1331*11^n/72. - _R. J. Mathar_, Jun 20 2013
%F A025955 a(0)=1, a(1)=26, a(2)=455, a(3)=6760, a(n) = 26*a(n-1)-221*a(n-2)+676*a(n-3)-660*a(n-4). - _Harvey P. Dale_, Aug 25 2014
%F A025955 a(n) = 3^(n+1)-2^(n+1)+21*a(n-1)-110*a(n-2). - _Vincenzo Librandi_, May 26 2026
%t A025955 CoefficientList[Series[1/((1-2*x)*(1-3*x)*(1-10*x)*(1-11*x)),{x,0,20}],x] (* _Harvey P. Dale_, Aug 25 2014 *)
%t A025955 (* Alternative: *)
%t A025955 LinearRecurrence[{26,-221,676,-660},{1,26,455,6760},20] (* _Harvey P. Dale_, Aug 25 2014 *)
%t A025955 (* Alternative: *)
%t A025955 a[0]=1;a[1]=26;a[n_]:=a[n]=3^(n+1)-2^(n+1)+21*a[n-1]-110*a[n-2];Table[a[n],{n,0,20}] (* _Vincenzo Librandi_, May 26 2026 *)
%o A025955 (Magma) I:=[1, 26]; [n le 2 select I[n] else 3^n-2^n+21*Self(n-1)-110*Self(n-2): n in [1..21]]; // _Vincenzo Librandi_, May 26 2026
