%N A025445 Expansion of 1/((1-2*x)*(1-3*x)*(1-4*x)*(1-7*x)).
%H A025445 Vincenzo Librandi, <a href="/A025445/b025445.txt">Table of n, a(n) for n = 0..1000</a>
%H A025445 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (16,-89,206,-168).
%F A025445 a(n) = (2*7^(n+3) - 5*4^(n+4) + 10*3^(n+4) - 3*2^(n+5))/120. - _Yahia Kahloune_, May 30 2013
%F A025445 a(0) = 1, a(1) = 16, a(2) = 167, a(3) = 1454, a(n) = 16*a(n-1) - 89*a(n-2) + 206*a(n-3) - 168*a(n-4). - _Harvey P. Dale_, Dec 07 2015
%t A025445 CoefficientList[Series[1/((1-2x)(1-3x)(1-4x)(1-7x)),{x,0,30}],x] (* or *) LinearRecurrence[{16,-89,206,-168},{1,16,167,1454},30] (* _Harvey P. Dale_, Dec 07 2015 *)
%t A025445 a[1]=1; a[2]=16; a[n_]:=a[n]=3^n-2^n+11 a[n-1]-28 a[n-2]; Table[a[n],{n,1,25}] (* _Vincenzo Librandi_, Apr 14 2026 *)
%o A025445 (Magma) I:=[1, 16]; [n le 2 select I[n] else 3^n - 2^n + 11*Self(n-1)-28*Self(n-2): n in [1..25]]; // _Vincenzo Librandi_, Apr 14 2026
