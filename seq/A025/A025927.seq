%N A025927 Expansion of 1/((1-2*x)*(1-3*x)*(1-4*x)*(1-10*x)).
%H A025927 Vincenzo Librandi, <a href="/A025927/b025927.txt">Table of n, a(n) for n = 0..950</a>
%H A025927 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (19,-116,284,-240).
%F A025927 a(n) = 19*a(n-1) - 116*a(n-2) + 284*a(n-3) - 240*a(n-4), with a(0)=1, a(1)=19, a(2)=245, a(3)=2735. - _Harvey P. Dale_, Oct 18 2011
%F A025927 a(n) = (10^(n+3) - 7*4^(n+4) + 16*3^(n+4) - 21*2^(n+3))/336. - _Yahia Kahloune_, May 19 2013
%F A025927 a(n) = 3^(n+1) - 2^(n+1) + 14*a(n-1) - 40*a(n-2). - _Vincenzo Librandi_, Apr 15 2026
%t A025927 CoefficientList[Series[1/((1-2x)(1-3x)(1-4x)(1-10x)),{x,0,30}],x] (* or *) LinearRecurrence[{19,-116,284,-240},{1,19,245,2735},31] (* _Harvey P. Dale_, Oct 18 2011 *)
%t A025927 a[0]=1; a[1]=19; a[n_]:=a[n]=3^(n+1)-2^(n+1)+14 a[n-1]-40 a[n-2]; Table[a[n],{n,0,20}] (* _Vincenzo Librandi_, Apr 15 2026 *)
%o A025927 (PARI) Vec((-4560*x^3 + 5156*x^2 - 1920*x + 245)/(240*x^4 - 284*x^3 + 116*x^2 - 19*x + 1)+O(x^25)) \\ _Charles R Greathouse IV_, May 20 2013
%o A025927 (Magma) I:=[1, 19]; [n le 2 select I[n] else 3^n - 2^n + 14*Self(n-1)-40*Self(n-2): n in [1..25]]; // _Vincenzo Librandi_, Apr 15 2026
