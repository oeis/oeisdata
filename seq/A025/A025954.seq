%N A025954 Expansion of 1/((1-2*x)*(1-3*x)*(1-9*x)*(1-12*x)).
%H A025954 Vincenzo Librandi, <a href="/A025954/b025954.txt">Table of n, a(n) for n = 0..900</a>
%H A025954 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (26,-219,666,-648).
%F A025954 a(n) = 26*a(n-1)-219*a(n-2)+666*a(n-3)-648*a(n-4) with a(0)=1, a(1)=26, a(2)=457, a(3)=6854. [_Harvey P. Dale_, Jan 19 2012]
%F A025954 a(n) = -4*2^n/35+3^n/2-81*9^n/14+32*12^n/5. - _R. J. Mathar_, Jun 20 2013
%F A025954 a(n) = 3^(n+1)-2^(n+1)+21*a(n-1)-108*a(n-2). - _Vincenzo Librandi_, May 26 2026
%t A025954 CoefficientList[Series[1/((1-2*x)*(1-3*x)*(1-9*x)*(1-12*x)),{x,0,20}],x] (* _Harvey P. Dale_, Jan 19 2012 *)
%t A025954 (* Alternative: *)
%t A025954 LinearRecurrence[{26,-219,666,-648},{1,26,457,6854},20] (* _Harvey P. Dale_, Jan 19 2012 *)
%t A025954 (* Alternative: *)
%t A025954 a[0]=1;a[1]=26;a[n_]:=a[n]=3^(n+1)-2^(n+1)+21*a[n-1]-108*a[n-2];Table[a[n],{n,0,20}] (* _Vincenzo Librandi_, May 26 2026 *)
%o A025954 (Magma) I:=[1, 26]; [n le 2 select I[n] else 3^n-2^n+21*Self(n-1)-108*Self(n-2): n in [1..21]]; // _Vincenzo Librandi_, May 26 2026
