%U A025960 249784713973935,1999514917852011,16002339732726039,128049957250049395,1024556404696890175,8197237170079803451
%N A025960 Expansion of 1/((1-2*x)*(1-4*x)*(1-5*x)*(1-8*x)).
%H A025960 Vincenzo Librandi, <a href="/A025960/b025960.txt">Table of n, a(n) for n = 0..1000</a>
%H A025960 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (19,-126,344,-320).
%F A025960 a(n) = (8^(n+3)-8*5^(n+3)+9*4^(n+3)-2^(n+4))/72. [_Yahia Kahloune_, May 25 2013]
%F A025960 a(n) = (4^(n+1)-2^(n+1))/2+13*a(n-1)-40*a(n-2). - _Vincenzo Librandi_, Jun 01 2026
%t A025960 CoefficientList[Series[1/((1-2*x)*(1-4*x)*(1-5*x)*(1-8*x)),{x,0,30}],x] (* _Harvey P. Dale_, Apr 02 2020 *)
%t A025960 (* Alternative: *)
%t A025960 a[0]=1; a[1]=19; Do[a[n]=(4^(n+1)-2^(n+1))/2+13*a[n-1]-40*a[n-2],{n,2,22}]; Table[a[n], {n,0,22}] (* _Vincenzo Librandi_, Jun 01 2026 *)
%o A025960 (Magma) I:=[1, 19]; [n le 2 select I[n] else (4^n-2^n)/2+13*Self(n-1)-40*Self(n-2): n in [1..22]]; // _Vincenzo Librandi_, Jun 01 2026
