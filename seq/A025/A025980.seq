%N A025980 Expansion of 1/((1-2*x)*(1-4*x)*(1-9*x)*(1-10*x)).
%H A025980 Vincenzo Librandi, <a href="/A025980/b025980.txt">Table of n, a(n) for n = 0..900</a>
%H A025980 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (25,-212,692,-720).
%F A025980 a(n) = -2^n/14 +16*4^n/15-729*9^n/35+125*10^n/6. - _R. J. Mathar_, Jun 20 2013
%F A025980 a(n) = (4^(n+1)-2^(n+1))/2+19*a(n-1)-90*a(n-2). - _Vincenzo Librandi_, Jul 01 2026
%t A025980 CoefficientList[Series[1/((1-2x)(1-4x)(1-9x)(1-10x)),{x,0,30}],x] (* _Harvey P. Dale_, Sep 06 2020 *)
%t A025980 (* Alternative: *)
%t A025980 a[0]=1;a[1]=25;Do[a[n]=(4^(n+1)-2^(n+1))/2+19*a[n-1]-90*a[n-2],{n,2,22}];Table[a[n],{n,0,19}] (* _Vincenzo Librandi_, Jul 01 2026 *)
%o A025980 (Magma) I:=[1, 25]; [n le 2 select I[n] else (4^n-2^n)/2+19*Self(n-1)-90*Self(n-2): n in [1..20]]; // _Vincenzo Librandi_, Jul 01 2026
