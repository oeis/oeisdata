%N A025958 Expansion of 1/((1-2*x)*(1-4*x)*(1-5*x)*(1-6*x)).
%H A025958 Harvey P. Dale, <a href="/A025958/b025958.txt">Table of n, a(n) for n = 0..1000</a>
%H A025958 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (17,-104,268,-240).
%F A025958 a(n) = -2^n/3+16*4^n-125*5^n/3+27*6^n. - _R. J. Mathar_, Jun 20 2013
%F A025958 a(0)=1, a(1)=17, a(2)=185, a(3)=1645, a(n) = 17*a(n-1)-104*a(n-2)+268*a(n-3)-240*a(n-4). - _Harvey P. Dale_, Oct 10 2015
%F A025958 a(n) = (4^(n+1)-2^(n+1))/2 + 11*a(n-1) - 30*a(n-2). - _Vincenzo Librandi_, May 30 2026
%t A025958 CoefficientList[Series[1/((1-2*x)*(1-4*x)*(1-5*x)*(1-6*x)),{x,0,30}],x] (* _Harvey P. Dale_, Oct 10 2015 *)
%t A025958 (* Alternative: *)
%t A025958 LinearRecurrence[{17,-104,268,-240},{1,17,185,1645},30] (* _Harvey P. Dale_, Oct 10 2015 *)
%t A025958 (* Alternative: *)
%t A025958 a[0]=1; a[1]=17; Do[a[n]=(4^(n+1)-2^(n+1))/2+11*a[n-1]-30*a[n-2],{n,2,22}];Table[a[n],{n,0,22}] (* _Vincenzo Librandi_, May 30 2026 *)
%o A025958 (Magma) I:=[1, 17]; [n le 2 select I[n] else (4^n-2^n)/2+11*Self(n-1)-30*Self(n-2): n in [1..22]]; // _Vincenzo Librandi_, May 30 2026
