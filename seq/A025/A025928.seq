%N A025928 Expansion of 1/((1-2*x)*(1-3*x)*(1-4*x)*(1-11*x)).
%H A025928 Harvey P. Dale, <a href="/A025928/b025928.txt">Table of n, a(n) for n = 0..900</a>
%H A025928 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (20,-125,310,-264).
%F A025928 a(n) = 20*a(n-1)-125*a(n-2)+ 310*a(n-3)- 264*a(n-4), with a(0)=1, a(1)=20, a(2)=275, a(3)=3310. - _Harvey P. Dale_, May 24 2012
%F A025928 a(n) = (11^(n+3)-9*4^(n+4)+7*3^(n+5)-7*2^(n+5))/504. - _Yahia Kahloune_, May 20 2013
%F A025928 a(n) = 3^(n+1) - 2^(n+1) + 15*a(n-1) - 44*a(n-2). - _Vincenzo Librandi_, Apr 17 2026
%t A025928 CoefficientList[Series[1/((1-2x)(1-3x)(1-4x)(1-11x)),{x,0,30}],x] (* or *) LinearRecurrence[{20,-125,310,-264},{1,20,275,3310},30] (* _Harvey P. Dale_, May 24 2012 *)
%t A025928 a[0]=1;a[1]=20;a[n_]:=a[n]=3^(n+1)-2^(n+1)+15 a[n-1]-44 a[n-2];Table[a[n],{n,0,20}] (* _Vincenzo Librandi_, Apr 17 2026 *)
%o A025928 (PARI) Vec(1/((1-2*x)*(1-3*x)*(1-4*x)*(1-11*x))+O(x^99)) \\ _Charles R Greathouse IV_, Sep 27 2012
%o A025928 (Magma) I:=[1, 20]; [n le 2 select I[n] else 3^n - 2^n + 15*Self(n-1)-44*Self(n-2): n in [1..25]]; // _Vincenzo Librandi_, Apr 17 2026
