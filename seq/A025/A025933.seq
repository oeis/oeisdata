%t A025933 CoefficientList[Series[1/((1-2x)(1-3x)(1-5x)(1-9x)),{x,0,25}],x] (* or *) LinearRecurrence[{19,-121,309,-270},{1,19,240,2570},25] (* _Harvey P. Dale_, Dec 26 2021 *)
%t A025933 a[0]=1;a[1]=19;a[n_]:=a[n]=3^(n+1)-2^(n+1)+14*a[n-1]-45*a[n-2];Table[a[n],{n,0,25}] (* _Vincenzo Librandi_, Apr 20 2026 *)
