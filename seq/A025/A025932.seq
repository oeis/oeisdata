%N A025932 Expansion of 1/((1-2*x)*(1-3*x)*(1-5*x)*(1-8*x)).
%H A025932 Vincenzo Librandi, <a href="/A025932/b025932.txt">Table of n, a(n) for n = 0..900</a>
%H A025932 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (18,-111,278,-240).
%F A025932 From _Vincenzo Librandi_, Mar 19 2011: (Start)
%F A025932 a(n) = 18*a(n-1) - 111*a(n-2) + 278*a(n-3) - 240*a(n-4), n >= 4.
%F A025932 a(n) = 13*a(n-1) - 40*a(n-2) + 3^(n+1) - 2^(n+1), n >= 2. (End)
%F A025932 a(n) = 4*8^(n+2)/45 - 2^(n+2)/9 - 5^(n+3)/18 + 3^(n+3)/10. - _R. J. Mathar_, Mar 19 2011
%t A025932 a[0]=1;a[1]=18;a[n_]:=a[n]=3^(n+1)-2^(n+1)+13a[n-1]-40 a[n-2];Table[a[n],{n,0,20}] (* _Vincenzo Librandi_, Apr 19 2026 *)
%o A025932 (Magma) I:=[1, 18]; [n le 2 select I[n] else 3^n-2^n+13*Self(n-1)-40*Self(n-2): n in [1..25]]; // _Vincenzo Librandi_, Apr 19 2026
