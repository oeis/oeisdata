%t A025989 a[0]=1;a[1]=23;Do[a[n]=(5^(n+1)-2^(n+1))/3+16*a[n-1]-60*a[n-2],{n,2,22}];Table[a[n],{n,0,20}] (* _Vincenzo Librandi_, Jul 07 2026 *)
