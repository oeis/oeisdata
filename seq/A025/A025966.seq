%N A025966 Expansion of 1/((1-2*x)*(1-4*x)*(1-6*x)*(1-8*x)).
%H A025966 Vincenzo Librandi, <a href="/A025966/b025966.txt">Table of n, a(n) for n = 0..900</a>
%H A025966 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (20,-140,400,-384).
%F A025966 a(n) = (2^n)*stirling2(n+4, 4), n>=0, with stirling2(n, m)=A008277(n, m).
%F A025966 a(n) = (-2^n+24*4^n-81*6^n+64*8^n)/3!.
%F A025966 G.f.: 1/((1-2*x)*(1-4*x)*(1-6*x)*(1-8*x)).
%F A025966 E.g.f.: (-exp(2*x)+24*exp(4*x)-81*exp(6*x)+64*exp(8*x))/3!.
%F A025966 a(n) = (4^(n+1)-2^(n+1))/2+14*a(n-1)-48*a(n-2).- _Vincenzo Librandi_, Jun 10 2026
%t A025966 CoefficientList[Series[1/((1-2*x)*(1-4*x)*(1-6*x)*(1-8*x)),{x,0,40}],x] (* _Harvey P. Dale_, Apr 13 2019 *)
%t A025966 (* Alternative: *)
%t A025966 a[0]=1; a[1]=20; Do[a[n]=(4^(n+1)-2^(n+1))/2+14*a[n-1]-48*a[n-2],{n,2,21}]; (* _Vincenzo Librandi_, Jun 10 2026 *)
%o A025966 (PARI) Vec(1/((1-2*x)*(1-4*x)*(1-6*x)*(1-8*x))+O(x^99)) \\ _Charles R Greathouse IV_, Sep 26 2012
%o A025966 (Magma) I:=[1, 20]; [n le 2 select I[n] else (4^n-2^n)/2+14*Self(n-1)-48*Self(n-2): n in [1..20]]; // _Vincenzo Librandi_, Jun 10 2026
