%N A025991 Expansion of 1/((1-2*x)*(1-5*x)*(1-6*x)*(1-12*x)).
%H A025991 Vincenzo Librandi, <a href="/A025991/b025991.txt">Table of n, a(n) for n = 0..900</a>
%H A025991 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (25,-208,684,-720).
%F A025991 a(n) = 25*a(n-1)-208*a(n-2)+684*a(n-3)-720*a(n-4) with a(0)=1, a(1)=25, a(2)=417, a(3)=5909. - _Harvey P. Dale_, May 20 2013
%F A025991 a(n) = -2^n/15+125*5^n/21-9*6^n/1+144*12^n/35. - _R. J. Mathar_, Jun 20 2013
%F A025991 a(n) = (5^(n+1)-2^(n+1))/3+18*a(n-1)-72*a(n-2). - _Vincenzo Librandi_, Jul 08 2026
%t A025991 CoefficientList[Series[1/((1-2x)(1-5x)(1-6x)(1-12x)),{x,0,20}],x] (* _Harvey P. Dale_, May 20 2013 *)
