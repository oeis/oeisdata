%N A025467 Expansion of 1/((1-2*x)*(1-3*x)*(1-4*x)*(1-8*x)).
%H A025467 Vincenzo Librandi, <a href="/A025467/b025467.txt">Table of n, a(n) for n = 0..1000</a>
%H A025467 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (17,-98,232,-192).
%F A025467 a(n) = (8^(n+3)-15*4^(n+3)+24*3^(n+3)-10*2^(n+3))/120. - _Yahia Kahloune_, May 27 2013
%F A025467 a(n) = 3^n-2^n+12*a(n-1)-32*a(n-2). - _Vincenzo Librandi_, Apr 14 2026
%F A025467 E.g.f.: exp(2*x)*(64*exp(6*x) - 120*exp(2*x) + 81*exp(x) - 10)/15. - _Stefano Spezia_, Apr 15 2026
%t A025467 CoefficientList[Series[1/((1-2x)(1-3x)(1-4x)(1-8x)),{x,0,30}],x] (* or *) LinearRecurrence[ {17,-98,232,-192},{1,17,191,1813},30] (* _Harvey P. Dale_, Jan 31 2023 *)
%t A025467 a[1]=1; a[2]=17; a[n_]:=a[n]=3^n-2^n+12 a[n-1]-32 a[n-2]; Table[a[n],{n,1,20}] (* _Vincenzo Librandi_, Apr 14 2026 *)
%o A025467 (Magma) I:=[1, 17]; [n le 2 select I[n] else 3^n - 2^n + 12*Self(n-1)-32*Self(n-2): n in [1..25]]; // _Vincenzo Librandi_, Apr 14 2026
