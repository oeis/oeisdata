%t A025951 a[0]=1;a[1]=25;a[n_]:=a[n]=3^(n+1)-2^(n+1)+20*a[n-1]-96*a[n-2];Table[a[n],{n,0,25}] (* _Vincenzo Librandi_, May 14 2026 *)
