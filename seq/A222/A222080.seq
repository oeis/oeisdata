%I A222080 #16 Apr 28 2026 11:57:40
%S A222080 1,2,11,92,1013,13726,219919,4057048,84545129,1961698586,50111003987,
%T A222080 1396488977908,42139540225501,1368234341961718,47547441824994647,
%U A222080 1760308790559597104,69151746439874522321,2872358517303945656242,125758844338252841129371,5787515297333376814677004
%N A222080 1 = Sum_{n>=0} a(n) * x^n * (1 - (2*n+1)*x)^2.
%C A222080 A self-convolution of an integer sequence (A222081).
%H A222080 Paul D. Hanna, <a href="/A222080/b222080.txt">Table of n, a(n) for n = 0..300</a>
%F A222080 a(n) = 2*(2*n-1)*a(n-1) - (2*n-3)^2*a(n-2). - _Seiichi Manyama_, Apr 28 2026
%F A222080 a(n) ~ (BesselK(1, 1/2)/sqrt(Pi)) * 2^(n - 3/2) * exp(2*sqrt(n) - n) * n^(n - 1/4) * (1 + 7/(48*sqrt(n))). - _Vaclav Kotesovec_, Apr 28 2026
%e A222080 The terms satisfy:
%e A222080 1 = (1-x)^2 + 2*x*(1-3*x)^2 + 11*x^2*(1-5*x)^2 + 92*x^3*(1-7*x)^2 + 1013*x^4*(1-9*x)^2 + 13726*x^5*(1-11*x)^2 + 219919*x^6*(1-13*x)^2 +...
%e A222080 G.f.: A(x) = 1 + 2*x + 11*x^2 + 92*x^3 + 1013*x^4 + 13726*x^5 + 219919*x^6 + 4057048*x^7 + 84545129*x^8 +...
%e A222080 The square-root of g.f. A(x) is an integer series:
%e A222080 A(x)^(1/2) = 1 + x + 5*x^2 + 41*x^3 + 453*x^4 + 6205*x^5 + 100649*x^6 + 1878277*x^7 + 39534033*x^8 +...+ A222081(n)*x^n +...
%t A222080 nmax = 20; FullSimplify[Assuming[{x > 0, x < 1/2}, CoefficientList[Series[(E^(x/(1 - 2*x)) * (BesselI[1, 1/2] * BesselK[0, 1/(-2 + 4*x)] - BesselI[0, 1/(2 - 4*x)] * BesselK[1, -1/2])) / (2*Sqrt[1 - 2*x]), {x, 0, nmax}], x] * Range[0, nmax]!]] (* _Vaclav Kotesovec_, Apr 28 2026 *)
%o A222080 (PARI) {a(n)=polcoeff(1-sum(m=0, n-1, a(m)*x^m*(1-(2*m+1)*x+x*O(x^n))^2), n)}
%o A222080 for(n=0,25,print1(a(n),", "))
%Y A222080 Cf. A002720, A222081.
%K A222080 nonn,changed
%O A222080 0,2
%A A222080 _Paul D. Hanna_, Feb 07 2013
