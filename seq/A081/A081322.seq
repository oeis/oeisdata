%I A081322 #16 Jul 08 2026 01:17:51
%S A081322 0,1,1,5,144,514229,190392490709135,
%T A081322 93202207781383214849429075266681969,
%U A081322 8269366108663463411004717981412027167937978847386801205243459016220834185059487057696
%N A081322 a(n) = F(P(n)), where F(n) = Fibonacci numbers A000045, P(n) = Pell numbers A000129.
%C A081322 This is a strong divisibility sequence, that is, gcd(a(n), a(m)) = a(gcd(n, m)) for n, m >= 1. In particular, this is a divisibility sequence: if n divides m then a(n) divides a(m). - _Peter Bala_, Jul 05 2026
%F A081322 a(n) ~ 1/sqrt(5) * exp(c*(1 + sqrt(2))^n), where c = log(phi)/(2*sqrt(2)) and phi = (1 + sqrt(5))/2 is the golden ratio. - _Peter Bala_, Jul 06 2026
%t A081322 f[n_] := f[n] = f[n - 1] + f[n - 2]; f[0] = 0; f[1] = 1; p[n_] := p[n] = 2p[n - 1] + p[n - 2]; p[0] = 0; p[1] = 1; Table[f[p[n]], {n, 0, 8}]
%Y A081322 Cf. A000045, A000129, A081323.
