%S A061634 0,-1,7,-61,648,-7661,97024,-1293185,17921632,-256059001,3749318884,
%T A061634 -56016555686,851132564144,-13118508087352,204692479176176,
%U A061634 -3228092918495239,51385854841200720,-824748030530781825,13334720844625613151,-217019187659075483044
%N A061634 Ooguri-Vafa invariants of disk degeneracies with boundary class 2 in the O(K) -> P^2 geometry (brane I or II).
%C A061634 a(n) is the corrected signed count attached to holomorphic disks whose boundary lies on the chosen Lagrangian D-brane and has boundary class 2. - _Robert P. P. McKone_, May 30 2026
%C A061634 Branes I and II are the two Z_3-related phases of the same brane, so they give the same sequence here. - _Robert P. P. McKone_, May 30 2026
%H A061634 Robert P. P. McKone, <a href="/A061634/b061634.txt">Table of n, a(n) for n = 0..127</a>
%H A061634 Mina Aganagic, Albrecht Klemm, and Cumrun Vafa, <a href="https://doi.org/10.1515/zna-2002-1-201">Disk Instantons, Mirror Symmetry and the Duality Web</a>, Z. Naturforsch. A 57 (2002), 1-28; also <a href="https://arxiv.org/abs/hep-th/0105045">arXiv:hep-th/0105045</a>, 2001. See Table 5, row m = 2.
%H A061634 Murad Alim, Michael Hecht, Peter Mayr, and Adrian Mertens, <a href="https://doi.org/10.1088/1126-6708/2009/09/126">Mirror symmetry for toric branes on compact hypersurfaces</a>, JHEP09(2009)126. See Table 3, diagonal l = m - 2. Also <a href="https://arxiv.org/abs/0901.2937">arXiv:0901.2937</a> [hep-th], 2009, see Table 3a.
%t A061634 inverseMirrorMapSeries[order_] := inverseMirrorMapSeries[order] = Normal[InverseSeries[Series[ser Exp[Sum[(-1)^ind (3 ind)! ser^ind/(ind (ind!)^3), {ind, 1, order}]], {ser, 0, order}]]] /. ser -> q; minusExpDeltaUSeries[order_] := minusExpDeltaUSeries[order] = Normal@Series[(q/inverseMirrorMapSeries[order + 1])^(1/3), {q, 0, order}]; vHat[deg_, bound_, order_] := vHat[deg, bound, order] = Module[{minusExpDeltaU = minusExpDeltaUSeries[order], quadArg, qCoeff}, quadArg = 4 q/(uHat minusExpDeltaU^2 (1 - uHat/minusExpDeltaU)^2); qCoeff = SeriesCoefficient[-Log[1 - uHat/minusExpDeltaU] - Log[(1 + Sqrt[1 + quadArg])/2], {q, 0, deg}]; If[bound <= 0, Coefficient[qCoeff, uHat, bound], SeriesCoefficient[qCoeff, {uHat, 0, bound}]]]; diskInvariant[deg_, bound_, order_] := diskInvariant[deg, bound, order] = Sum[MoebiusMu[cov] vHat[deg/cov, bound/cov, order]/(bound cov), {cov, Divisors[GCD[deg, Abs[bound]]]}]; a[n_Integer?NonNegative, m_] := a[n] = diskInvariant[n, m, Max[1, n]]; a[#, 2] & /@ Range[0, 12] (* _Robert P. P. McKone_, May 30 2026 *)
%Y A061634 Cf. A061605 - A061627, A061628 - A061637.
%K A061634 sign
%O A061634 0,3
