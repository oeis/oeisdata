%U A061403 5307515618936708136960000,3502960308498227370393600000,2690273516926638620462284800000,2378201788963148540488659763200000
%N A061403 Denominators of coefficients of even powers of x of the expansion of Bessel function J_4(x).
%H A061403 G. C. Greubel, <a href="/A061403/b061403.txt">Table of n, a(n) for n = 0..220</a> (terms 0..50 from T. D. Noe)
%H A061403 <a href="/index/Be#Bessel">Index entries for sequences related to Bessel functions or polynomials</a>.
%F A061403 From _Amiram Eldar_, Jul 23 2026: (Start)
%F A061403 a(n) = 2^(2n+4) * n! * (n+4)!.
%F A061403 a(n) ~ Pi * (2*n)^(2*n+5) / exp(2*n).
%F A061403 Sum_{n>=0} 1/a(n) = BesselI(4,1).
%F A061403 Sum_{n>=0} (-1)^n/a(n) = BesselJ(4,1). (End)
%t A061403 Denominator[Take[CoefficientList[Series[BesselJ[4, x], {x, 0, 500}], x], {5, -1, 2}]] (* _G. C. Greubel_, Aug 15 2017 *)
%Y A061403 Cf. A002474 (J_1), A002506 (J_2), A014401 (J_3), this sequence (J_4), A061404 (J_5), A061405 (J_6), A061406 (J_7), A061407 (J_8), A061440 (J_9), A061441 (J_10).
