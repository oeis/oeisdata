%S A061116 1,11,13,17,19,21,23,27,29,31,37,41,43,47,49,51,53,57,59,61,67,71,73,
%T A061116 79,81,83,87,89,91,97,111,113,117,119,121,127,131,133,137,139,141,143,
%U A061116 149,151,157,161,163,167,169,171,173,177,179,181,187,191,193,197,199,211
%N A061116 Numbers coprime to each of their decimal digits.
%C A061116 Subsequence of A138708. - _Reinhard Zumkeller_, Mar 26 2008
%H A061116 Michael S. Branicky, <a href="/A061116/b061116.txt">Table of n, a(n) for n = 1..10001</a>
%H A061116 <a href="/index/Ar#10-automatic">Index entries for 10-automatic sequences</a>.
%F A061116 A138707(a(n)) = 1. - _Reinhard Zumkeller_, Mar 26 2008
%e A061116 27 is a term as 2 and 7 both are coprime to 27.
%e A061116 53 is a term as 5 and 3 both are coprime to 53.
%p A061116 for n from 1 to 500 do it1 := convert(n, base, 10): flag := 1: for k from 1 to nops(it1) do if igcd(n, it1[k])<>1 then flag := 0 fi: od: if flag=1 then printf(`%d,`,n) fi: od:
%t A061116 Select[Range[1, 191, 2], CoprimeQ[Product[i, {i, IntegerDigits[#]}], #] &] (* _Arkadiusz Wesolowski_, May 19 2012 *)
%o A061116 (Python)
%o A061116 from math import gcd
%o A061116 def ok(n): return all(gcd(n, int(d)) == 1 for d in str(n))
%o A061116 print([k for k in range(212) if ok(k)]) # _Michael S. Branicky_, Nov 13 2021
%o A061116 (PARI) isok(k) = my(d=digits(k)); for (i=1, #d, if (gcd(i, k) != 1, return(0))); 1; \\ _Michel Marcus_, Apr 08 2026
%Y A061116 Cf. A138707, A138708.
%K A061116 nonn,base
