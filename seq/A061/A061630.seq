%T A061630 -7618685454,114738305494,-1754976434508,27201404827215,
%U A061630 -426469533708222,6753491326517886,-107892722577085630,1737188191882270008,-28166249116218020400,459547375155052288740
%N A061630 Ooguri-Vafa invariants of disk degeneracies with boundary class -3 in the O(K) -> P^2 geometry (brane I or II).
%C A061630 From _Robert P. P. McKone_, May 23 2026: (Start)
%C A061630 a(n) is the corrected signed count attached to holomorphic disks whose boundary lies on the chosen Lagrangian D-brane and has boundary class -3.
%C A061630 Branes I and II are the two Z_3-related phases of the same brane, so they give the same sequence here. (End)
%H A061630 Robert P. P. McKone, <a href="/A061630/b061630.txt">Table of n, a(n) for n = 0..127</a>
%H A061630 Mina Aganagic, Albrecht Klemm, and Cumrun Vafa, <a href="https://doi.org/10.1515/zna-2002-1-201">Disk Instantons, Mirror Symmetry and the Duality Web</a>, Z. Naturforsch. A 57 (2002), 1-28; also <a href="https://arxiv.org/abs/hep-th/0105045">arXiv:hep-th/0105045</a>, 2001. See Table 5, row m = -3.
%H A061630 Murad Alim, Michael Hecht, Peter Mayr, and Adrian Mertens, <a href="https://doi.org/10.1088/1126-6708/2009/09/126">Mirror symmetry for toric branes on compact hypersurfaces</a>, JHEP09(2009)126. See Table 3, diagonal l = m + 3. Also <a href="https://arxiv.org/abs/0901.2937">arXiv:0901.2937</a> [hep-th], 2009, Table 3a.
%t A061630 inverseMirrorMapSeries[order_] := inverseMirrorMapSeries[order] = Normal[InverseSeries[Series[ser Exp[Sum[(-1)^ind (3 ind)! ser^ind/(ind (ind!)^3), {ind, 1, order}]], {ser, 0, order}]]] /. ser -> q; minusExpDeltaUSeries[order_] := minusExpDeltaUSeries[order] = Normal@Series[(q/inverseMirrorMapSeries[order + 1])^(1/3), {q, 0, order}]; vHat[deg_, bound_, order_] := vHat[deg, bound, order] = Module[{minusExpDeltaU = minusExpDeltaUSeries[order], quadArg, qCoeff}, quadArg = 4 q/(uHat minusExpDeltaU^2 (1 - uHat/minusExpDeltaU)^2); qCoeff = SeriesCoefficient[-Log[1 - uHat/minusExpDeltaU] - Log[(1 + Sqrt[1 + quadArg])/2], {q, 0, deg}]; If[bound <= 0, Coefficient[qCoeff, uHat, bound], SeriesCoefficient[qCoeff, {uHat, 0, bound}]]]; diskInvariant[deg_, bound_, order_] := diskInvariant[deg, bound, order] = Sum[MoebiusMu[cov] vHat[deg/cov, bound/cov, order]/(bound cov), {cov, Divisors[GCD[deg, Abs[bound]]]}]; a[n_Integer?NonNegative, m_] := a[n] = diskInvariant[n, m, Max[1, n]]; a[#, -3] & /@ Range[0, 12] (* _Robert P. P. McKone_, May 23 2026 *)
%Y A061630 Cf. A061605 - A061627, A061628 - A061637.
%K A061630 sign,changed
%O A061630 0,5
%A A061630 _N. J. A. Sloane_, Jun 10 2001
%E A061630 a(10) onwards from _Robert P. P. McKone_, May 23 2026
