%S A061629 0,0,0,0,-2,28,-344,4360,-57760,793502,-11231776,162989668,
%T A061629 -2414988728,36416843610,-557441982720,8643826917378,-135546810008832,
%U A061629 2146585032573138,-34291266467394200,552048942171252042,-8949049634885755538,145975633406044760404
%N A061629 Ooguri-Vafa invariants of disk degeneracies with boundary class -4 in the O(K) -> P^2 geometry (brane I or II).
%C A061629 From _Robert P. P. McKone_, May 23 2026: (Start)
%C A061629 a(n) is the corrected signed count attached to holomorphic disks whose boundary lies on the chosen Lagrangian D-brane and has boundary class -4.
%C A061629 Branes I and II are the two Z_3-related phases of the same brane, so they give the same sequence here. (End)
%H A061629 Robert P. P. McKone, <a href="/A061629/b061629.txt">Table of n, a(n) for n = 0..127</a>
%H A061629 Mina Aganagic, Albrecht Klemm, and Cumrun Vafa, <a href="https://doi.org/10.1515/zna-2002-1-201">Disk Instantons, Mirror Symmetry and the Duality Web</a>, Z. Naturforsch. A 57 (2002), 1-28; also <a href="https://arxiv.org/abs/hep-th/0105045">arXiv:hep-th/0105045</a>, 2001. See Table 5, row m = -4.
%H A061629 Murad Alim, Michael Hecht, Peter Mayr, and Adrian Mertens, <a href="https://doi.org/10.1088/1126-6708/2009/09/126">Mirror symmetry for toric branes on compact hypersurfaces</a>, JHEP09(2009)126. See Table 3, diagonal l = m + 4. Also <a href="https://arxiv.org/abs/0901.2937">arXiv:0901.2937</a> [hep-th], 2009, see Table 3a.
%t A061629 inverseMirrorMapSeries[order_] := inverseMirrorMapSeries[order] = Normal[InverseSeries[Series[ser Exp[Sum[(-1)^ind (3 ind)! ser^ind/(ind (ind!)^3), {ind, 1, order}]], {ser, 0, order}]]] /. ser -> q; minusExpDeltaUSeries[order_] := minusExpDeltaUSeries[order] = Normal@Series[(q/inverseMirrorMapSeries[order + 1])^(1/3), {q, 0, order}]; vHat[deg_, bound_, order_] := vHat[deg, bound, order] = Module[{minusExpDeltaU = minusExpDeltaUSeries[order], quadArg, qCoeff}, quadArg = 4 q/(uHat minusExpDeltaU^2 (1 - uHat/minusExpDeltaU)^2); qCoeff = SeriesCoefficient[-Log[1 - uHat/minusExpDeltaU] - Log[(1 + Sqrt[1 + quadArg])/2], {q, 0, deg}]; If[bound <= 0, Coefficient[qCoeff, uHat, bound], SeriesCoefficient[qCoeff, {uHat, 0, bound}]]]; diskInvariant[deg_, bound_, order_] := diskInvariant[deg, bound, order] = Sum[MoebiusMu[cov] vHat[deg/cov, bound/cov, order]/(bound cov), {cov, Divisors[GCD[deg, Abs[bound]]]}]; a[n_Integer?NonNegative, m_] := a[n] = diskInvariant[n, m, Max[1, n]]; a[#, -4] & /@ Range[0, 12] (* _Robert P. P. McKone_, May 23 2026 *)
%Y A061629 Cf. A061605 - A061627, A061628 - A061637.
%K A061629 sign,changed
%O A061629 0,5
%A A061629 _N. J. A. Sloane_, Jun 10 2001
%E A061629 a(11) onwards from _Robert P. P. McKone_, May 23 2026
