%U A061404 265375780946835406848000,159225468568101244108800000,112094729871943275852595200000,91469299575505713095717683200000,85615264402673347457591751475200000
%N A061404 Denominators of coefficients of odd powers of x of the expansion of Bessel function J_5(x).
%H A061404 G. C. Greubel, <a href="/A061404/b061404.txt">Table of n, a(n) for n = 0..220</a> (terms 0..50 from T. D. Noe)
%H A061404 <a href="/index/Be#Bessel">Index entries for sequences related to Bessel functions or polynomials</a>.
%F A061404 From _Amiram Eldar_, Jul 23 2026: (Start)
%F A061404 a(n) = 2^(2n+5) * n! * (n+5)!.
%F A061404 a(n) ~ Pi * (2*n)^(2*n+6) / exp(2*n).
%F A061404 Sum_{n>=0} 1/a(n) = BesselI(5,1).
%F A061404 Sum_{n>=0} (-1)^n/a(n) = BesselJ(5,1). (End)
%t A061404 Denominator[Take[CoefficientList[Series[BesselJ[5, x], {x, 0, 500}], x], {6, -1, 2}]] (* _G. C. Greubel_, Aug 15 2017 *)
%Y A061404 Cf. A002474 (J_1), A002506 (J_2), A014401 (J_3), A061403 (J_4), this sequence (J_5), A061405 (J_6), A061406 (J_7), A061407 (J_8), A061440 (J_9), A061441 (J_10).
