%S A046019 1,9,2,6,6,5,5,9,4,4,7,4,2,12,6,8,7,5,3,10,4,4,8,4,4,14,5,3,7,6,2,11,
%T A046019 2,8,4,6,3,9,3,3,7,2,5,10,6,4,9,9,5,12,2,4,5,5,6,3,2,7,4,5,5,6,3,4,5,
%U A046019 5,4,9,2,6,4,3,3,6,5,6,4,4,5,9,5,3,5,5,2,6,3,7,7,4,3,8,4,4,9,6,2,8,2,5,6,3
%N A046019 a(n) gives the number of different powers m^n for which the sum of the digits is equal to m > 0.
%C A046019 Number of m >= 1 with m = sum of digits of m^n.
%H A046019 T. D. Noe, <a href="/A046019/b046019.txt">Table of n, a(n) for n = 0..1000</a>
%F A046019 a(n) = 1 + A046471(n). - _T. D. Noe_, Nov 26 2008
%e A046019 a(0) = 1 because sumdigits(m)^0 = 1 = m has only one solution, m = 1.
%e A046019 a(1) = 9 because sumdigits(m)^1 = m > 0 for the single digit numbers 1, ..., 9.
%e A046019 a(2) = 2 because sumdigits(m)^2 = m > 0 only for 1^2 = 1 and 9^2 = 81, 8 + 1 = 9.
%e A046019 a(7) = 9 because the only positive solutions for 7th powers are 1^7 = 1 and
%e A046019   18^7 = 612220032 with 6 + 1 + 2 + 2 + 2 + 3 + 2 = 18,
%e A046019   27^7 = 10460353203 with 1 + 4 + 6 + 3 + 5 + 3 + 2 + 3 = 27,
%e A046019   31^7 = 27512614111 with 2 + 7 + 5 + 1 + 2 + 6 + 1 + 4 + 1 + 1 + 1 = 31,
%e A046019   34^7 = 52523350144 with 5 + 2 + 5 + 2 + 3 + 3 + 5 + 1 + 4 + 4 = 34,
%e A046019   43^7 = 271818611107 with 2 + 7 + 1 + 8 + 1 + 8 + 6 + 1 + 1 + 1 + 7 = 43,
%e A046019   53^7 = 1174711139837 with 1 + 1 + 7 + 4 + 7 + 1 + 1 + 1 + 3 + 9 + 8 + 3 + 7 = 53,
%e A046019   58^7 = 2207984167552 with 2 + 2 + 7 + 9 + 8 + 4 + 1 + 6 + 7 + 5 + 5 + 2 = 58, and
%e A046019   68^7 = 6722988818432 with 6 + 7 + 2 + 2 + 9 + 8 + 8 + 8 + 1 + 8 + 4 + 3 + 2 = 68.
%e A046019 a(9) = 4 because the positive solutions for 9th powers are 1^9 = 1 and
%e A046019   54^9 = 3904305912313344 with sumdigits(3904305912313344) = 54,
%e A046019   71^9 = 45848500718449031 with sumdigits(45848500718449031) = 71, and
%e A046019   81^9 = 150094635296999121 with sumdigits(150094635296999121) = 81.
%e A046019 See the table A152147 for other exponents.
%Y A046019 Cf. A046471, A124359, A152147 (table of m such that the sum of digits of m^n equals m).
%K A046019 nonn,base
%O A046019 0,2
