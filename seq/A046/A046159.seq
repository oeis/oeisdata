%S A046159 3,11,15,27,35,47,51,63,75,83,99,107,111,123,143,147,155,171,191,195,
%T A046159 207,227,243,251,255,267,291,299,303,315,323,335,363,371,387,399,411,
%U A046159 431,435,443,447,467,483,495,507,515,531,555,575,587,591,603,623,627,651
%N A046159 Bends of spheres in the plane of Soddy's bowl of integers.
%C A046159 From _Martin Fuller_, Mar 05 2026: (Start)
%C A046159 The spheres are arranged in concentric rings. Bends in ring m = 1, 2... are given by 4(x^2 + xy + y^2) - 1 with x + y = m and x = 0..m-1 repeated six times. Compare A270248. The surrounding unit sphere with bend -1 could be considered to be in ring m = 0.
%C A046159 There are six radial lines of touching spheres with bends given by A000466. (End)
%H A046159 SeqFan group, <a href="https://groups.google.com/g/seqfan/c/OL5lmsPMtMI">RFE Mar 2026: Soddy's bowl of integers</a>
%H A046159 Frederick Soddy, <a href="https://doi.org/10.1038/139077a0">The Bowl of Integers and the Hexlet</a>, Nature 139, 77-79, 1937 [<a href="https://scispace.com/pdf/the-bowl-of-integers-and-the-hexlet-2g1v1j2x4s.pdf">Accessible copy</a>]
%H A046159 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/BowlofIntegers.html">Bowl of Integers</a>
%F A046159 a(n) = A270248(n+1)-1. - _Martin Fuller_, Mar 05 2026
%o A046159 (PARI) a(limit)={
%o A046159   my(s = Set);
%o A046159   for(m = 1, oo,
%o A046159     my(ring = Set(apply(x->my(y=m-x); 4*(x^2+x*y+y^2)-1, [0..m-1])));
%o A046159     if(#s >= limit && ring[1] > s[limit], return(s[1..limit]));
%o A046159     s = setunion(s, ring);
%o A046159   );
%o A046159 }; \\ _Martin Fuller_, Mar 07 2026
%Y A046159 Cf. A046160, A270248, A000466.
%Y A046159 Cf. A045506 (list of all bends: -1, 2, 3, 5, ...).
%K A046159 nonn,nice
%O A046159 1,1
%A A046159 _Eric W. Weisstein_
%E A046159 a(30) onward from _Martin Fuller_, Mar 05 2026
