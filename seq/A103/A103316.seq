%T A103316 -42,22,-7,1,-128,127,-120,99,-64,29,-8,1,256,-255,247,-219,163,-93,
%U A103316 37,-9,1,-512,511,-502,466,-382,256,-130,46,-10,1,1024,-1023,1013,-968,848,-638,386,-176,56,-11,1,-2048,2047,-2036,1981,-1816,1486,-1024,562,-232,67,-12,1
%N A103316 Riordan array (1/(1+2x), x/(1+x)).
%C A103316 Inverse array of A029653. Signed version of A055248. Row sums are (-1)^n*A011782(n), with g.f. (1+x)/(1+2x). Diagonal sums are (-1)^n*A027934(n), with g.f. (1+x)/((1+2x)(1+x-x^2)).
%F A103316 T(n,k) = (-1)^(n-k)*Sum_{j=0..n} binomial(n, k+j).
%F A103316 T(n,k) = T(n-1,k-1) - 3*T(n-1,k) + 2*T(n-2,k-1) - 2*T(n-2,k) with T(0,0)=1, T(1,0)=-2, T(1,1)=1, T(n,k)=0 if k<0 or if k>n. - _Philippe Deléham_, Jan 12 2014
%e A103316 Rows of the triangle start:
%e A103316     1;
%e A103316    -2,  1;
%e A103316     4, -3,  1;
%e A103316    -8,  7, -4, 1;
%e A103316    16, -15, 11, -5, 1;
%e A103316   -32, 31, -26, 16, -6, 1;
%e A103316    ...
%t A103316 T[n_,k_]:= (-1)^(n-k)*Sum[Binomial[n, k+j],{j,0,n}]; Table[T[n,k],{n,0,11},{k,0,n}]//Flatten (* _Stefano Spezia_, Mar 20 2026 *)
%Y A103316 Cf. A011782, A027934, A029653, A055248.
%K A103316 easy,sign,tabl
%O A103316 0,2
