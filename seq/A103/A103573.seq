%I A103573 #13 Jul 06 2026 17:32:55
%S A103573 0,10,24,42,64,90,120,153,189,229,272,318,368,420,476,535,597,662,729,
%T A103573 800,874,951,1031,1114,1199,1288,1379,1473,1570,1670,1773,1879,1987,
%U A103573 2098,2212,2329,2449,2571,2696,2824,2954,3087,3223,3362,3504,3648,3795
%N A103573 a(n) is the least integer such that floor(a(n)^(1/2)-a(n)^(1/3)) = n.
%H A103573 Robert Israel, <a href="/A103573/b103573.txt">Table of n, a(n) for n = 0..10000</a>
%F A103573 Conjecture: a(n) is either ceiling(n^2 + 2*n^(5/3) + 7/3*n^(4/3) + 2*n + 110/81*n^(2/3) + 182/243*n^(1/3)) or 1 + ceiling(n^2 + 2*n^(5/3) + 7/3*n^(4/3) + 2*n + 110/81*n^(2/3) + 182/243*n^(1/3)). - _Robert Israel_, Jul 06 2026
%e A103573 0^(1/2) - 0^(1/3) = 0.
%e A103573 10^(1/2) - 10^(1/3) = 1.00784...
%e A103573 24^(1/2) - 24^(1/3) = 2.01448...
%e A103573 42^(1/2) - 42^(1/3) = 3.00471...
%p A103573 f:= proc(n) local x,x0;
%p A103573   x0:= ceil(n^2 + 2*n^(5/3) + 7/3*n^(4/3) + 2*n + 110/81*n^(2/3) + 182/243*n^(1/3));
%p A103573   if floor(x0^(1/2) - x0^(1/3)) < n then
%p A103573     for x from x0 + 1 do
%p A103573      if floor(x^(1/2) - x^(1/3)) = n then return x fi
%p A103573     od
%p A103573   else
%p A103573     for x from x0-1 by -1 do
%p A103573      if floor(x^(1/2) - x^(1/3)) < n then return x + 1 fi;
%p A103573     od
%p A103573   fi
%p A103573 end proc:
%p A103573 map(f, [$0..100]); # _Robert Israel_, Jul 06 2026
%t A103573 f[n_] := Block[{k = 0}, While[ Floor[k^(1/2) - k^(1/3)] < n, k++ ]; k]; Table[ f[n], {n, 0, 46}] (* _Robert G. Wilson v_, Mar 23 2005 *)
%K A103573 nonn,changed
%O A103573 0,2
%A A103573 _Ray G. Opao_, Mar 22 2005
