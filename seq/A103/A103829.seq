%I A103829 #11 Mar 19 2026 23:52:05
%S A103829 2,4,6,8,12,14,16,18,20,21,22,24,26,28,34,36,38,40,41,42,43,44,46,48,
%T A103829 56,58,60,61,62,63,64,65,66,68,78,80,81,82,83,84,85,86,87,88,102,104,
%U A103829 106,108,114,116,118,120,122,124,126,128,136,138,140,141,142,144,146
%N A103829 Sum of even digits greater than sum of odd digits.
%C A103829 0 is assumed as even digit: A005843, A004275, A007928. Sum of even digits equals sum of odd digits A036301.
%H A103829 Robert Israel, <a href="/A103829/b103829.txt">Table of n, a(n) for n = 1..10000</a>
%p A103829 filter:= proc(n) local t;
%p A103829   add(t * (-1)^t, t = convert(n,base,10)) > 0
%p A103829 end proc:
%p A103829 select(filter, [$1..300]); # _Robert Israel_, Mar 18 2026
%t A103829 Select[Range[300], Plus@@Select[IntegerDigits[ # ], OddQ]<Plus@@Select[IntegerDigits[ # ], EvenQ]&]
%Y A103829 Cf. A005843, A004275, A007928, A036301.
%K A103829 nonn,base
%O A103829 1,1
%A A103829 _Zak Seidov_, Feb 17 2005
%E A103829 Corrected by _Robert Israel_, Mar 18 2026
