%I A103849 #33 Jun 14 2026 22:23:43
%S A103849 0,112,1,2,121,3,4,134,5,6,143,7,8,156,9,12,165,10,14,178,11,16,187,
%T A103849 13,18,211,15,20,314,17,21,336,19,22,341,23,24,358,25,26,363,27,28,
%U A103849 385,29,34,413,30,36,431,31,38,516,32,40,538,33,41,561,35,42,583,37,43,615,39
%N A103849 Rearrangement of natural numbers according to the sums of odd and even digits as partitioned by A036301, A103848 and A103829 (see Comments).
%C A103849 Sum of even digits (equal, less than and greater than) sum of odd digits: A036301, A103848 and A103829.
%C A103849 a(1) = 0 and then terms cycle through the successive values of A036301 (starting at index 2, i.e., skipping term 0), A103848 and A103829. - _Michael S. Branicky_, Jun 13 2026
%F A103849 Corrected by _Michael S. Branicky_, Jun 13 2026: (Start)
%F A103849 a(1) = 0, then for k = 1, 2, 3, ...:
%F A103849 a(3*k-1) = A036301(k+1),
%F A103849 a(3*k  ) = A103848(k),
%F A103849 a(3*k+1) = A103829(k). (End)
%e A103849 a(2) = a(3*1-1) = A036301(1+1) = A036301(2) = 112.
%e A103849 a(3) = a(3*1  ) = A103848(1) = 1.
%e A103849 a(4) = a(3*1+1) = A103829(1) = 2.
%e A103849 a(5) = a(3*2-1) = A036301(3) = 121.
%e A103849 a(6) = a(3*2  ) = A103848(2) = 3.
%e A103849 a(7) = a(3*2+1) = A103829(2) = 4.
%e A103849 a(8) = a(3*3-1) = A036301(4) = 134.
%e A103849 ...
%o A103849 (Python)
%o A103849 from itertools import count, islice
%o A103849 def eodiff(n): return sum(d*(-1)**(d&1) for d in list(map(int, str(n))))
%o A103849 def A036301_gen(): yield from (t for t in count(0) if eodiff(t) == 0)
%o A103849 def A103848_gen(): yield from (t for t in count(0) if eodiff(t) <  0)
%o A103849 def A103829_gen(): yield from (t for t in count(0) if eodiff(t) >  0)
%o A103849 def agen(): # generator of terms
%o A103849     eq, lt, gt = A036301_gen(), A103848_gen(), A103829_gen()
%o A103849     yield next(eq)
%o A103849     while True: yield from (next(eq), next(lt), next(gt))
%o A103849 print(list(islice(agen(), 66))) # _Michael S. Branicky_, Jun 13 2026
%Y A103849 Cf. A036301, A103829, A103848, A103877.
%K A103849 nonn,base,changed
%O A103849 1,2
%A A103849 _Zak Seidov_, Feb 18 2005
%E A103849 Edited by _Michael S. Branicky_, Jun 13 2026 to correct data mismatch found _Chris R. Rehmann_
