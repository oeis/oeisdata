%I A103848 #11 Mar 18 2026 20:33:41
%S A103848 1,3,5,7,9,10,11,13,15,17,19,23,25,27,29,30,31,32,33,35,37,39,45,47,
%T A103848 49,50,51,52,53,54,55,57,59,67,69,70,71,72,73,74,75,76,77,79,89,90,91,
%U A103848 92,93,94,95,96,97,98,99,100,101,103,105,107,109,110,111,113,115,117,119
%N A103848 Numbers k such that sum of even digits of k is less than sum of odd digits.
%C A103848 Sum of even digits equals sum of odd digits => A036301. Sum of even digits greater than sum of odd digits => A103829
%H A103848 Robert Israel, <a href="/A103848/b103848.txt">Table of n, a(n) for n = 1..10000</a>
%p A103848 filter:= proc(n) local t;
%p A103848   add(t * (-1)^t, t = convert(n,base,10)) < 0
%p A103848 end proc:
%p A103848 select(filter, [$1..300]); # _Robert Israel_, Mar 18 2026
%t A103848 Select[Range[300], Plus@@Select[IntegerDigits[ # ], OddQ]>Plus@@Select[IntegerDigits[ # ], EvenQ]&]
%Y A103848 Cf. A036301, A103829.
%K A103848 nonn,base,changed
%O A103848 1,2
%A A103848 _Zak Seidov_, Feb 18 2005
%E A103848 Mathematica program corrected by _Harvey P. Dale_, Oct 10 2024
%E A103848 Definition corrected by _Robert Israel_, Mar 18 2026
