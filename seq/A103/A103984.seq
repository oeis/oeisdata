%N A103984 Decimal expansion of average length of a line segment picked at random in a unit 5-cube.
%D A103984 Steven R. Finch, Mathematical Constants, Encyclopedia of Mathematics and its Applications, vol. 94, Cambridge University Press, 2003, Section 8.1, p. 480.
%H A103984 Johan Philip, <a href="https://web.archive.org/web/20250426234402/https://people.kth.se/~johanph/h45.pdf">The distance between two random points in a 4- and 5-cube</a>, 2008.
%H A103984 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/HypercubeLinePicking.html">Hypercube Line Picking</a>.
%F A103984 Equals (-449/165 - 4*Pi/9 + 4*Pi^2/15 + (568/165 - 8*arcsin(1/4)) * sqrt(3) + (3239/2970 + 5*Pi^2/16 - (73/3 + 5*Pi/8)*arcsin(1/3)) * sqrt(2) - 380/297 * sqrt(5) + (-124/9 + 26*Pi/3) * log(2) + (295/12 + 5*Pi/8) * log(3) + (7/18 - 5*Pi/2) * log(1 + sqrt(2)) + (40/3 - 52*Pi/3) * log(1 + sqrt(3)) + 64/9 * log(1 + sqrt(5)) + 52/3 * Integral_{t = 3..4} (acos(1/t) / sqrt(t^2 - 4*t + 3)) dt - 5/2 * Integral_{t = 1..sqrt(2)} (acos(1/(1+t^2)) * arcsec(t)) dt)/21 (Philip, 2008). - _Amiram Eldar_, Mar 26 2026
%e A103984 0.87853091526748027717891679633622474951189699108976...
%t A103984 $MaxExtraPrecision = 1200; RealDigits[(1/21)*(-449/165 - (4*Pi)/9 + (4*Pi^2)/15 + (568/165 - 8*ArcSin[1/4])*Sqrt[3] + (3239/2970 + (5/16)*Pi^2 - (73/3 + (5*Pi)/8)*ArcSin[1/3])*Sqrt[2] - (380/297)*Sqrt[5] + (-124/9 + (26*Pi)/3)*Log[2] + (295/12 + (5*Pi)/8)*Log[3] + (7/18 - (5*Pi)/2)*Log[1 + Sqrt[2]] + (40/3 - (52*Pi)/3)*Log[1 + Sqrt[3]] + (64/9)*Log[1 + Sqrt[5]] + (52/3)*NIntegrate[ArcSec[t]/Sqrt[t^2 - 4*t + 3], {t, 3, 4}, WorkingPrecision -> 120] - (5/2)*NIntegrate[ArcSec[1 + t^2]*ArcSec[t], {t, 1, Sqrt[2]}, WorkingPrecision -> 120])][[1]] (* _Amiram Eldar_, Mar 26 2026 *)
%o A103984 (PARI) (-449/165 - 4*Pi/9 + 4*Pi^2/15 + (568/165 - 8*asin(1/4)) * sqrt(3) + (3239/2970 + 5/16*Pi^2 - (73/3 + 5*Pi/8)*asin(1/3)) * sqrt(2) - 380/297 * sqrt(5) + (-124/9 + 26*Pi/3) * log(2) + (295/12 + 5*Pi/8) * log(3) + (7/18 - 5*Pi/2) * log(1 + sqrt(2)) + (40/3 - 52*Pi/3) * log(1 + sqrt(3)) + 64/9 * log(1 + sqrt(5)) + 52/3 * intnum(t = 3, 4, acos(1/t) / sqrt(t^2 - 4*t + 3)) - 5/2 * intnum(t = 1, sqrt(2), acos(1/(1+t^2)) * acos(1/t)))/21 \\ _Amiram Eldar_, Mar 26 2026
