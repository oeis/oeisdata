%F A003077 22/7 - Pi = Integral_{x=0..1} x^4*(1-x)^4/(1+x^2).  - _M. F. Hasler_, Oct 24 2011
%F A003077 Equals 60*Sum_{n>=1} 1/[(4*n^2-1)*(16*n^2-1)*(16*n^2-9)] . [Sofo] - _R. J. Mathar_, Jun 21 2024
%F A003077 From _Amiram Eldar_, Jul 02 2026: (Start)
%F A003077 Equals -Sum_{k>=1} (3*(4*k)!^2/(8*k+1)! + (4*k+1)!^2/(8*k+3)! - (1/2)*(4*k+2)!^2/(8*k+5)! - (4*k+3)!^2/(8*k+7)!)/(-4)^k (Dalzell, 1944 and 1971).
%F A003077 Equals -6*Sum_{k>=1} (k-3) * k! / ((k + 2)*(k + 3)*(k + 6)*(k + 7)*(2*k + 3)!!) (Walsh, 1949).
%F A003077 Equals Sum_{k>=2} (-1)^k * 24/((2*k + 1)*(2*k + 2)*(2*k + 3)*(2*k + 4)*(2*k + 5)) (Nimbran and Levrie 2017).
%F A003077 Equals Sum_{k>=2} 60/((4*k^2 - 1)*(16*k^2 - 1)*(16*k^2-9)) (Nimbran, 2013).
%F A003077 Formulas from Lucas and Nimbran (2022):
%F A003077 Equals -Sum_{k>=1} (-1/4)^k * (2/(4*k + 1) - 6/(4*k + 2) + 5/(4*k + 3) - 2/(4*k + 6) + 1/(4*k + 7)).
%F A003077 Equals Sum_{k>=1} (-1/4)^(k-1) * 30/((4*k + 1)*(4*k + 2)*(4*k + 3)*(4*k + 6)*(4*k + 7)).
%F A003077 Equals Sum_{k>=1} 30*(768*k^3 + 1984*k^2 + 836*k + 87)/(16^k*(16*k^2 - 1)*(64*k^2 - 1)*(64*k^2 - 9)*(4*k + 3)*(8*k + 7)).
%F A003077 Equals Sum_{k>=1} 240/((4*k + 1)*(4*k + 2)*(4*k + 3)*(4*k + 5)*(4*k + 6)*(4*k + 7)).
%F A003077 Equals (3/71) * Sum_{k>=3} (8*k^2 + 292*k + 143)/(4k*(k + 1)*(2*k + 1)*(4*k + 1)*(4*k + 3)).
%F A003077 Equals Sum_{k>=2} 8*(6*k^3 + 23*k^2 - 6*k - 47)*binomial(2*k,k)/((2*k + 1)*(2*k + 2)*(2*k + 3)*(2*k + 4)*(2*k + 5)*2^(4*k)).
%F A003077 Equals (1/120) * Sum_{k>=6} 2^k * (k + 242)/((2*k + 1)*(2*k+3)*binomial(2*k,k)). (End)
