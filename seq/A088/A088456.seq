%S A088456 1,1,2,4,9,22,56,146,387,1039,2819,7717,21287,59105,165038,463089,
%T A088456 1304945,3690970,10474213,29811119,85070660,243340754,697571153,
%U A088456 2003636629,5765473829,16617825248,47971281916,138677926537,401428641619,1163442587941,3375837976468,9805869144592,28512102516914
%N A088456 Number of integer sequences [y(1),...,y(n)] such that |y(i)-y(i+1)|<=1, 1=y(1)<=y(i)<=y(n).
%H A088456 Danai Deligeorgaki and Krishna Menon, <a href="https://arxiv.org/abs/2603.22565">How to bounce your canon permutation</a>, arXiv:2603.22565 [math.CO], 2026. See p. 29.
%e A088456 [1,1,1],[1,1,2],[1,2,2],[1,2,3] are the a(3)=4 sequences.
%o A088456 (PARI) a(n)=local(p0,p1,p2); if(n<0,0,p1=1; polcoeff(sum(i=0,n,if(p2=(1-x)*p1-x^2*p0,p0=p1; p1=p2; x^i/p0),x*O(x^n)),n))
%K A088456 nonn
%O A088456 0,3
%A A088456 _Michael Somos_, Oct 01 2003
