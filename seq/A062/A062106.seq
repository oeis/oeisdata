%I A062106 #5 Mar 10 2026 12:19:15
%S A062106 0,1,2,6,15,40,109,302,846,2390,6796,19426,55767,160668,464305,
%T A062106 1345282,3906701,11367696,33135987,96740610,282831981,827939880,
%U A062106 2426431239,7118546874,20904025380,61439768166,180725813478,532004277518,1567150286281,4619399683540
%N A062106 Number of ways a black pawn (from any starting square on the second back rank) can (theoretically) end on the n-th square of the leftmost file counted from the back rank.
%p A062106 ChessPawnTriangle := proc(r, c) option remember;
%p A062106         if r < 2 or c < 1 then 0
%p A062106       elif 2 = r then 1
%p A062106       elif 4 = r then 1+add(ChessPawnTriangle(r-1, c+j), j=-1..1)
%p A062106       else              add(ChessPawnTriangle(r-1, c+j), j=-1..1)
%p A062106         fi
%p A062106       end:
%p A062106 seq(ChessPawnTriangle(j, 1), j=1..30);
%Y A062106 The left column of table A062104. Cf. also A062107.
%K A062106 nonn
%O A062106 1,3
%A A062106 _Antti Karttunen_, May 30 2001
