%F A062107 a(n) = 10*3^(n-4) for n >= 4.
%F A062107 From _Paul Barry_, Oct 15 2004: (Start)
%F A062107 G.f.: x^2*(1+x^2)/(1-3*x);
%F A062107 a(n) = Sum_{k=0..n-2} 3^(n-k-2)binomial(1, k/2)(1+(-1)^k)/2. (End)
%F A062107 a(n) = floor(10*3^(n-4)). - _Paolo Xausa_, Mar 10 2026
%p A062107 series(x^2*(1+x^2)/(1-3*x),x,40):
%p A062107 seq(coeff(%,x,n), n=1..35);
