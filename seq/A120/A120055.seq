%I A120055 #33 May 04 2026 00:50:11
%S A120055 4,35,871,43217,5296623,2011783478,2954855689523
%N A120055 a(n) is the least semiprime s such that the Sum_{semiprime i <= s} 1/i exceeds n.
%C A120055 A002387(n+1) < a(n) < A016088(n).
%C A120055 a(n) is the k-th semiprime: k = 1, 13, 262, 10521, 1034924, 316108902, 376794353756; factors: 2*2, 5*7, 13*61, 23*1879, 3*1765541, 2*1005891739, 23*128471986501.
%C A120055 For a(1), sum = 1.0256943709884886355474590768...
%C A120055 for a(2), sum = 2.0009202082073190426639117947...
%C A120055 for a(3), sum = 3.0000002945465013188650189308...
%C A120055 for a(4), sum = 4.0000000316857024320853460898...
%C A120055 for a(5), sum = 5.0000000001698140071183459536...
%C A120055 for a(6), sum = 6.0000000000001143688806428973...
%e A120055 a(0)=4 because 1/4 > 0.
%e A120055 a(1)=35 because 1/4 + 1/6 + 1/9 + 1/10 + 1/14 + 1/15 + 1/21 + 1/22 + 1/25 + 1/26 + 1/33 + 1/34 + 1/35 = 15708817/15315300 > 1.
%t A120055 s = 0; k = 1; Do[ While[s <= n, If[ Plus @@ Last /@ FactorInteger@k == 2, s = N[ s + 1/k, 20]]; k++ ]; Print[{k - 1, s}]; k ++, {n, 0, 5}]
%Y A120055 Cf. A001358, A002387, A016088.
%K A120055 nonn,hard,more,changed
%O A120055 0,1
