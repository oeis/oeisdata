%T A120045 46636297326,466032880556,4668833302876,46861389462777
%N A120045 The (10^n)-th 4-almost prime.
%F A120045 a(n) = A014613(10^n). - _Chai Wah Wu_, Jun 03 2026
%t A120045 FourAlmostPrimePi[n_] := Sum[ PrimePi[n/(Prime@i*Prime@j*Prime@k)] - k + 1, {i, PrimePi[n^(1/4)]}, {j, i, PrimePi[(n/Prime@i)^(1/3)]}, {k, j, PrimePi@Sqrt[n/(Prime@i*Prime@j)]}];
%t A120045 FourAlmostPrime[n_] := Block[{e = Floor[Log[2, n] +3], a, b}, a = 2^e; Do[b = 2^p; While[FourAlmostPrimePi[a] < n, a = a + b]; a = a - b/2, {p, e, 0, -1}]; a + b/2]; Do[ Print@FourAlmostPrime[10^n], {n, 0, 11}]
%o A120045 (Python)
%o A120045 from math import isqrt
%o A120045 from sympy import primepi, primerange, integer_nthroot
%o A120045 from oeis_sequences.OEISsequences import bisection
%o A120045 def A120045(n):
%o A120045     n10 = 10**n
%o A120045     def f(x): return int(n10+x-sum(primepi(x//(k*m*r))-c for a,k in enumerate(primerange(integer_nthroot(x,4)[0]+1)) for b,m in enumerate(primerange(k,integer_nthroot(x//k,3)[0]+1),a) for c,r in enumerate(primerange(m,isqrt(x//(k*m))+1),b)))
%o A120045     return bisection(f,n10,n10) # _Chai Wah Wu_, Jun 03 2026
