%S A120566 1,1,1,3,7,33,109,643,2623,17929,85349,652395,3517911,29484193,
%T A120566 176844781,1605009651,10575269935,103033059513,738834271605,
%U A120566 7676696689275,59466011617671,655467253898577,5451048833933693,63461831974209539,563610159408512479,6904542032727135849,65184375718497967621
%N A120566 G.f. satisfies: A(x) = A(A(x)) - x*A(A(A(x))), with A(0) = 0.
%C A120566 If A(0, x) = x, A(n+1, x) = A( A(n, x)) = A(n, A(x)). Then A(n, x) = x + n*x^2 + n^2*x^3 + (n^3 + 2*n)*x^4 + (n^4 + 6*n^2)*x^5 + ... where [x^4] A(n, x) = A054602(n). - _Michael Somos_, Jan 22 2012
%C A120566 It appears that all terms are odd. - _Paul D. Hanna_, Jun 04 2026
%H A120566 Paul D. Hanna, <a href="/A120566/b120566.txt">Table of n, a(n) for n = 1..500</a>
%F A120566 G.f. A(x) = Sum_{n>=1} a(n)*x^n satisfies the following formulas.
%F A120566 (1) A(x) = A(A(x)) - x*A(A(A(x))).
%F A120566 (2) A(-A(-x)) = x.
%F A120566 (3) A(x) = x + A(A(x)) * Series_Reversion(A(x)).
%F A120566 (4) A(x) = x - A(-x) * A(A(x)).
%F A120566 (5) A(A(x)) = ( x - A(x) )/A(-x), thus higher order iterations of A(x) reduce to expressions involving A(x) and A(-x). - _Paul D. Hanna_, Jul 22 2006
%F A120566 From _Paul D. Hanna_, Jun 04 2026: (Start)
%F A120566 (6) A(x) = (1-x) * A(A(x)) / (1 + x*A(A(A(A(x))))).
%F A120566 (7) A(x) = x + Sum_{n>=1} d^(n-1)/dx^(n-1) (-A(x)*A(A(-x)))^n / n!.
%F A120566 (8) A(x) = x * exp( Sum_{n>=1} d^(n-1)/dx^(n-1) ((-A(x)*A(A(-x)))^n/x) / n! ). (End)
%e A120566 G.f.: A(x) = x + x^2 + x^3 + 3*x^4 + 7*x^5 + 33*x^6 + 109*x^7 + 643*x^8 + 2623*x^9 + 17929*x^10 + 85349*x^11 + 652395*x^12 + ...
%e A120566 where A(x) = x - A(-x)*A(A(x)).
%e A120566 RELATED SERIES.
%e A120566 The second and third iterations of g.f. A(x) begin
%e A120566 A(A(x)) = x + 2*x^2 + 4*x^3 + 12*x^4 + 40*x^5 + 168*x^6 + 736*x^7 + 3784*x^8 + 19824*x^9 + 117688*x^10 + ...
%e A120566 A(A(A(x))) = x + 3*x^2 + 9*x^3 + 33*x^4 + 135*x^5 + 627*x^6 + 3141*x^7 + 17201*x^8 + 99759*x^9 + 620027*x^10 + ...
%e A120566 where A(x) = A(A(x)) - x*A(A(A(x))).
%o A120566 (PARI) \\ From A(x) = x - A(-x)*A(A(x))
%o A120566 \\ ('truncate' is used here only to reduce runtime)
%o A120566 {a(n) = my(A = x + x^2); for(k=1,n, A = truncate(A) +x*O(x^k);
%o A120566 A = x - subst(A,x,-x) * subst(A,x,A) +x*O(x^n)); polcoeff(GF=A, n)}
%o A120566 {upto(n) = a(n); Vec(GF)}
%o A120566 upto(30) \\ program revised by _Paul D. Hanna_, Jun 04 2026
%Y A120566 Cf. A141202, A213591, A396100, A396099.
