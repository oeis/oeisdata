%N A120044 The 10^n-th 3-almost prime.
%F A120044 a(n) = A014612(10^n). - _Chai Wah Wu_, Jun 03 2026
%t A120044 ThreeAlmostPrimePi[n_] := Sum[ PrimePi[n/(Prime@i*Prime@j)] - j + 1, {i, PrimePi[n^(1/3)]}, {j, i, PrimePi@ Sqrt[n/Prime@i]}]; ThreeAlmostPrime[n_] := Block[{e = Floor[Log[2, n]], a, b}, a = 2^e; Do[b = 2^p; While[ThreeAlmostPrimePi[a] < n, a = a + b]; a = a - b/2, {p, e, 0, -1}]; a + b/2]; Do[ Print@ThreeAlmostPrime[10^n], {n, 0, 13}]
%t A120044 (* Alternative: *)
%t A120044 ThreePrime[n_] := Block[{e = Floor[ Log[2, n] +2], a, b}, a = 2^e; Do[b = 2^p; While[ ThreePrimePi[a] < n, a = a + b]; a = a - b/2, {p, e, 0, -1}]; a + b/2]; Table[ ThreePrime[n], {n, 0, 13}]
%o A120044 (Python)
%o A120044 from math import isqrt
%o A120044 from sympy import primepi, primerange, integer_nthroot
%o A120044 from oeis_sequences.OEISsequences import bisection
%o A120044 def A120044(n):
%o A120044     n10 = 10**n
%o A120044     def f(x): return int(n10+x-sum(primepi(x//(k*m))-b for a,k in enumerate(primerange(integer_nthroot(x,3)[0]+1)) for b,m in enumerate(primerange(k,isqrt(x//k)+1),a)))
%o A120044     return bisection(f,n10,n10) # _Chai Wah Wu_, Jun 04 2026
