%S A109625 5,91,9091,9181,9271,9361,9451,9541,9631,9721,9811,900991,901891,
%T A109625 902791,903691,904591,905491,906391,907291,908191,909091,910981,
%U A109625 911881,912781,913681,914581,915481,916381,917281,918181,919081,920971,921871,922771
%N A109625 Numbers k such that concatenation of k and its 10's complement is a palindrome.
%C A109625 For n > 1, numbers with digits x_1 ... x_{2*k} where x_1 = 9, x_{2*k} = 1, x_2 <= 8 and
%C A109625 x_{2k-i} + x_{i+1} = 9 for 2 <= i <= 2k-1. - _Robert Israel_, May 17 2026
%H A109625 Robert Israel, <a href="/A109625/b109625.txt">Table of n, a(n) for n = 1..10001</a>
%e A109625 a(3)=9091 because 10^4-9091 = 909 and concatenating produces the palindrome
%e A109625 9091909.
%p A109625 f:= proc(x) local i,L;
%p A109625     L:= convert(x,base,10);
%p A109625     10^nops(L)*x + add((9-L[-i])*10^(i-1),i=1..nops(L))+1;
%p A109625 end proc:
%p A109625 [5, 91, seq(seq(f(9*10^d+j),j=0..9*10^(d-1)-1),d=1..3)]; # _Robert Israel_, May 17 2026
%t A109625 Select[Range[923000],PalindromeQ[FromDigits[Join[IntegerDigits[#],IntegerDigits[ 10^IntegerLength[ #]-#]]]]&] (* _Harvey P. Dale_, Nov 01 2022 *)
%K A109625 base,nonn,changed
%O A109625 1,1
%A A109625 _Jason Earls_, Aug 02 2005
