%T A109595 81,9,1000,100,10,1331,121,11,1728,144,12,2197,169,13,2744,196,14,
%U A109595 3375,225,15,4096,256,16,4913,289,17,5832,324,18,6859,361,19,8000,400,20
%N A109595 n^3 followed by n^2 followed by n.
%H A109595 <a href="/index/Rec#order_12">Index entries for linear recurrences with constant coefficients</a>, signature (0,0,4,0,0,-6,0,0,4,0,0,-1).
%F A109595 a(n) = floor((n+2)/3)^((-3*(n mod 3)^2+7*(n mod 3)+2)/2). - _Luce ETIENNE_, Mar 01 2018
%F A109595 From _Elmo R. Oliveira_, Jul 01 2026: (Start)
%F A109595 a(n) = 4*a(n-3) - 6*a(n-6) + 4*a(n-9) - a(n-12).
%F A109595 G.f.: x*(1 + x + x^2 + 4*x^3 - 2*x^5 + x^6 - x^7 + x^8)/(1 - x^3)^4. (End)
%t A109595 Flatten[Table[{n^3,n^2,n},{n,20}]] (* _Harvey P. Dale_, Aug 22 2014 *)
%t A109595 (* Alternative: *)
%t A109595 LinearRecurrence[{0,0,4,0,0,-6,0,0,4,0,0,-1},{1,1,1,8,4,2,27,9,3,64,16,4},60] (* _Harvey P. Dale_, Aug 22 2014 *)
%o A109595 (Python)
%o A109595 def A109595(n): return n//3 if (m:=n%3)==0 else (n//3+1)**3 if m==1 else (n//3+1)**2 # _Chai Wah Wu_, Jul 01 2026
