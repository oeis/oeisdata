%F A029231 a(n) = (2*n^3+87*n^2+1134*n-13184)/16632 - (n mod 2)/8 + ((n+2) mod 3)*10/27 + ((4*n^3+6*n^2+1) mod 7)/7 + (-2*((n+7) mod 9) +5*((n+6) mod 9) -6*((n+5) mod 9) +5*((n+4) mod 9) -2*((n+3) mod 9))/27 + (((4*n^3+9*n^2+2*n+10) mod 11) -((n+4) mod 11) +2*((n+3) mod 11) -((n+2) mod 11))/11. - _Hoang Xuan Thanh_, May 31 2026
%t A029231 CoefficientList[Series[1/((1 - x^2) (1 - x^7) (1 - x^9) (1 - x^11)), {x, 0, 100}], x] (* _Vincenzo Librandi_, Jun 02 2014 *)
%o A029231 (PARI) Vec(1/((1-x^2)*(1-x^7)*(1-x^9)*(1-x^11)) + O(x^80)) \\ _Jinyuan Wang_, Mar 15 2020
%o A029231 (PARI) a(n) = (2*n^3+87*n^2+1134*n-19624)/16632 + [0,-1][n%2+1]/8 + [1,4,1,2,3,0,3][n%7+1]/7 + [28,8,36,1,35,0,28,8,18][n%9+1]/27 + [11,4,6,8,1,9,1,12,0,11,3][n%11+1]/11 \\ _Hoang Xuan Thanh_, May 31 2026
