%o A029351 (PARI) a(n) = ((n+37)*(n^2+17*n+245) - 21*(n%2)*(n^2+29*n+298) + 56*n*[1,1,-2][n%3+1] + 126*n*[1,-1,-1,1][n%4+1] + 168*n*[1,1,0,-1,-1,0][n%6+1] + 1728*[2,0,0,1,2,2,0][n%7+1])\12096 \\ _Hoang Xuan Thanh_, May 10 2026
