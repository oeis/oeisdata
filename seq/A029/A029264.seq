%F A029264 a(n) = floor((n^3+39*n^2+306*n+2160)/6336 - (n mod 2)*n/64 + ((n^3+2*n+1) mod 4)*n/32 - ((n^3+3*n^2+2*n) mod 4)/4 + ((8*n^3+4*n^2+6*n+10) mod 11)/11). - _Hoang Xuan Thanh_, Mar 24 2026
%t A029264 CoefficientList[Series[1/((1 - x^3) (1 - x^4) (1 - x^8) (1 - x^11)), {x, 0, 100}], x] (* _Vincenzo Librandi_, Jun 03 2014 *)
