%F A029321 a(n) = floor((n^3+51*n^2+1107*n-4784)/19008 - (n mod 2)*n/64 - ((2*n^2+2*n) mod 3)*n/36 + ((n mod 4) - ((n+1) mod 4))*n/192 + ((n+2) mod 3)/3 + ((10*n^3+4*n^2+4*n+10) mod 11)/11). - _Hoang Xuan Thanh_, Apr 15 2026
