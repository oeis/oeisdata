%F A029324 a(n) = floor((n+14)*(2*n^2+11*n-562)/42768 + ((n+2) mod 3)*(n^2+35*n)/648 - ((2*n^2+n) mod 3)*(66*n-263)/3888 + ((2*n^2+1) mod 3)*709/972 + ((4*n^3+n^2+9*n+5) mod 11)/11). - _Hoang Xuan Thanh_, Apr 15 2026
