%N A029294 Expansion of 1/((1-x^3)*(1-x^6)*(1-x^7)*(1-x^10)).
%C A029294 a(n) is the number of partitions of n into parts 3, 6, 7, and 10. - _Joerg Arndt_, Apr 07 2026
%H A029294 <a href="/index/Rec#order_26">Index entries for linear recurrences with constant coefficients</a>, signature (0,0,1,0,0,1,1,0,-1,0,0,0,-2,0,0,0,-1,0,1,1,0,0,1,0,0,-1).
%F A029294 G.f.: 1/((1-x^3)*(1-x^6)*(1-x^7)*(1-x^10)).
%F A029294 a(n) = a(n-3) + a(n-6) + a(n-7) - a(n-9) - 2*a(n-13) - a(n-17) + a(n-19) + a(n-20) + a(n-23) - a(n-26). - _Wesley Ivan Hurt_, Jun 20 2025
%F A029294 a(n) = floor((n^3+39*n^2+630*n+7201)/7560 - (n mod 2)*n/120 - ((2*n^2+n) mod 3)*n/18 - (n mod 3)/2 + ((-1)^floor(n/3) - 1)*((n+2) mod 3)/12 + ((3*n^3+5*n^2+1) mod 7)/7). - _Hoang Xuan Thanh_, Apr 07 2026
%t A029294 CoefficientList[Series[1/((1-x^3)(1-x^6)(1-x^7)(1-x^10)), {x, 0, 100}], x] (* _Jinyuan Wang_, Mar 11 2020 *)
%t A029294 LinearRecurrence[{0,0,1,0,0,1,1,0,-1,0,0,0,-2,0,0,0,-1,0,1,1,0,0,1,0,0,-1},{1,0,0,1,0,0,2,1,0,2,2,0,3,3,1,3,4,2,4,5,4,5,6,5,7,7},70] (* _Harvey P. Dale_, Oct 18 2020 *)
%o A029294 (PARI) a(n) = floor((n^3+39*n^2+630*n+7201)/7560 - (n%2)*n/120 - ((2*n^2+n)%3)*n/18 - [0,3,6,2,3,7][n%6+1]/6 + ((3*n^3+5*n^2+1)%7)/7) \\ _Hoang Xuan Thanh_, Apr 07 2026
