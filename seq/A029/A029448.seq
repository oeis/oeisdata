%S A029448 1,3,4,9,12,27,72,81,104,216,219,243,324,729,756,972,2187,3888,3921,
%T A029448 6561,9477,11664,16848,19683,21156,22599,26244,26811,29245,30132,
%U A029448 32805,37665,38788,39852,40905,45756,46965,47871,59049,78732,80676,82380,90396,91740,92340
%N A029448 Numbers k that divide the (right) concatenation of all numbers <= k written in base 3 (most significant digit on left).
%C A029448 Includes all powers of 3. - _Robert Israel_, Nov 06 2025
%H A029448 Michael S. Branicky, <a href="/A029448/b029448.txt">Table of n, a(n) for n = 1..125</a> (terms 1..79 from Jianing Song; terms 1..71 from Robert Israel)
%p A029448 c:= 1: R:= 1: count:= 1:
%p A029448 for k from 2 while count < 50 do
%p A029448   c:= c * 3^(1+ilog[3](k)) + k;
%p A029448   if c mod k = 0 then R:= R,k; count:= count+1 fi
%p A029448 od;
%p A029448 R; # _Robert Israel_, Nov 06 2025
%t A029448 b = 3; c = {}; Select[Range[10^4], Divisible[FromDigits[c = Join[c, IntegerDigits[#, b]], b], #] &] (* _Robert Price_, Mar 10 2020 *)
%o A029448 (PARI) c=0; for(d=1, 3^15, for(n=d, -1+d*=3, (c=c*d+n)%n || print1(n", ")); d--) \\ _Jianing Song_, Apr 26 2026, copied from _M. F. Hasler_'s program in A029455
%o A029448 (Python)
%o A029448 def ok(k): return concat_mod(3, k, k) == 0   # uses concat_mod by _Jason Yuen_ in A029455
%o A029448 print([k for k in range(1, 10**5) if ok(k)]) # _Michael S. Branicky_, Apr 26 2026
