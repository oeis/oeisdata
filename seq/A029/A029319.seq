%F A029319 a(n) = floor((n^3+48*n^2+744*n-5490)/15840 - (n mod 2)*(n+6)/160 + (2*((2*n^3+4*n^2+3*n+3) mod 8) + ((n+4) mod 8) - ((n+3) mod 8) - ((n^3+n^2+2*n) mod 4))/16 + ((n^3+4*n^2+7*n+10) mod 11)/11). - _Hoang Xuan Thanh_, Apr 14 2026
