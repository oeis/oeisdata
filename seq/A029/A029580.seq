%I A029580 #22 Apr 27 2026 04:08:18
%S A029580 1,5,13,29,61,125,253,509,1021,2045,4093,8189,8191,8193,8195,8197,
%T A029580 8199,8201,8203,8205,8207,8209,8211,8213,8215,8217,8219,8221,8223,
%U A029580 8225,8227,8229,8231,8233,8235,8237,8239,8241,8243,8245,8247,8249,8251,8253,8255
%N A029580 a(0) = 1; for n > 0, a(n) = [ A*a(n-1)+B ]/p^r, where p^r is the highest power of p dividing [ A*a(n)+B ] and p=2, A=2.00013, B=3.0.
%H A029580 Yasutoshi Kohmoto, <a href="/A029580/a029580.gif">Plot of first 4000 terms</a>
%o A029580 (Python)
%o A029580 import fractions
%o A029580 import math
%o A029580 def A029580():
%o A029580     A = fractions.Fraction(200013, 100000)
%o A029580     B = 3
%o A029580     p = 2
%o A029580     a = 1
%o A029580     while True:
%o A029580         yield a
%o A029580         a = math.floor(A * a + B)
%o A029580         while a % p == 0:
%o A029580             a //= p
%o A029580 # _Adam Reichert_, Apr 26 2026
%Y A029580 Cf. A036982.
%K A029580 nonn,easy,changed
