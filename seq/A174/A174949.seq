%N A174949 Triangle read by rows: T(n,k) = B(n,k) - B(n,0) + 1 where B(n,k) = 2 * (5*binomial(n,k)*(n+1)!*k!*(n-k)! + (n+k+1)!*(n-k)! + (2*n-k+1)!*k!) / ((n+1)!*k!*(n-k)!).
%C A174949 Triangle is symmetric.
%e A174949 Triangle begins:
%e A174949   {1},
%e A174949   {1, 1},
%e A174949   {1, 5, 1},
%e A174949   {1, -11, -11, 1},
%e A174949   {1, -99, -119, -99, 1},
%e A174949   {1, -451, -611, -611, -451, 1},
%e A174949   {1, -1783, -2561, -2763, -2561, -1783, 1},
%e A174949   ...
%t A174949 t[n_, m_, q_] = 12*(Binomial[n, m]*(1 - q) + (((n + m + 1)!/((n + 1)!* m!)) + ((2*n - m + 1)!/((n + 1)!*(n - m)!)))*q);
%t A174949 Table[Flatten[Table[Table[t[ n, m, q] - t[n, 0, q] + 1, {m, 0, n}], {n, 0, 10}]], {q, 0, 1, 1/12}]
