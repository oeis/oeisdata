%e A174966   ...
%t A174966 << DiscreteMath`Combinatorica`
%t A174966 t[n_, m_, q_] = If[q == 1, Binomial[n, m] + Eulerian[n + 1, m] - Binomial[n, m]*Eulerian[n + 1, m], (q - 1) + Binomial[ n, m]^q + Eulerian[n + 1, m]^q - q*Binomial[n, m]*Eulerian[n + 1, m]];
%t A174966 Table[Table[Sum[t[n, m, q], {m, 0, n}], {n, 0, 10}], {q, 1, 10}]
