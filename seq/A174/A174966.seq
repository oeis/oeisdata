%N A174966 Triangle read by rows: T(n,k) = binomial(n,k) + Eulerian1(n+1,k) - binomial(n,k) * Eulerian1(n+1,k).
%C A174966 Triangle is symmetric.
%e A174966 Triangle begins:
%e A174966   {1},
%e A174966   {1, 1},
%e A174966   {1, -2, 1},
%e A174966   {1, -19, -19, 1},
%e A174966   {1, -74, -324, -74, 1},
