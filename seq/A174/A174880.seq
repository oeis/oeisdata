%S A174880 10,2,6,28,9,10,5,21,7,10,5,21,54,217,153,89,89,345,57,169,55,442,446,
%T A174880 1788,889,890,445,1781,1767,890,55,442,446,1788,889,890,445,1781,1767,
%U A174880 890,23,186,190,764,377,378,189,757,743,378,23,186,190,764,377,378,189,757,743
%N A174880 Decimal representation of the consonants and vowels in the American English name of n mapped to binary 1 and 0.
%C A174880 Vowels are {a, e, i, o, u} as in A037196. In particular, the 'y' in 'twenty' is not considered to be a vowel in this sequence. Spaces and hyphens are ignored.
%H A174880 Michael S. Branicky, <a href="/A174880/b174880.txt">Table of n, a(n) for n = 0..10000</a>
%e A174880 Consonants = 1, vowels = 0. a(0) = zero = 1010 = 10, a(1) = one = 010 = 2, a(2) = two = 110 = 6, a(3) = three = 11100 = 28, a(73) = seventythree = 101011111100 = 2812.
%o A174880 (Python)
%o A174880 from num2words import num2words
%o A174880 def n2w(n): return "".join(c for c in num2words(n).replace(" and", "") if c.isalpha())
%o A174880 def a(n): return int("".join("0" if c in "aeiou" else "1" for c in n2w(n)), 2)
%o A174880 print([a(n) for n in range(60)]) # _Michael S. Branicky_, Mar 01 2026
%Y A174880 Cf. A005589, A037196.
%K A174880 base,easy,nonn,word
%O A174880 0,1
