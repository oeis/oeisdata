%T A174411 4160,104,1,1,273,28392,1135680,1135680,28392,273,1,1,714,194922,
%U A174411 20271888,810875520,20271888,194922,714,1,1,1870,1335180,364504140
%N A174411 Triangle read by rows: T(n,k) = c(n) / c(max(k, n-k)) where c(n) = Product_{i=1..n} F(i)*F(i+1) and F(i) the Fibonacci numbers.
%e A174411 Triangle begins:
%e A174411   {1},
%e A174411   {1, 1},
%e A174411   {1, 2, 1},
%e A174411   {1, 6, 6, 1},
%e A174411   {1, 15, 90, 15, 1},
%e A174411   {1, 40, 600, 600, 40, 1},
%e A174411   {1, 104, 4160, 62400, 4160, 104, 1},
%e A174411   {1, 273, 28392, 1135680, 1135680, 28392, 273, 1},
%e A174411   ...
%t A174411 f[0, a_] := 0; f[1, a_] := 1;
%t A174411 f[n_, a_] := f[n, a] = f[n - 1, a] + a*f[n - 2, a];
%t A174411 c[n_, a_] := If[n == 0, 1, Product[f[i, a]*f[i + 1, a], {i, 1, n}]];
%t A174411 t[n_, m_, q_] = If[Floor[n/2] >= m, c[n, q]/c[n - m, q], c[n, q]/c[m, q]];
%t A174411 Table[Flatten[Table[Table[t[n, m, q], {m, 0, n}], {n, 0, 10}]], {q, 1, 10}]
%Y A174411 Cf. A000045.
%K A174411 nonn,tabl,less
%O A174411 0,5
