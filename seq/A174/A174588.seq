%N A174588 Triangle read by rows: T(n,k) = S(n,k) - S(n,0) + 1 where S(n,k) = Sum_{j=0..n} (-1)^j * (k-j)^n * binomial(n, j)* Eulerian1(n+1, j) with S(0,k)=1.
%C A174588 Triangle is symmetrical.
%e A174588 Triangle begins:
%e A174588   {1},
%e A174588   {1, 1},
%e A174588   {1, 7, 1},
%e A174588   {1, 181, 181, 1},
%e A174588   {1, 751, 1761, 751, 1},
%e A174588   {1, -323399, -354899, -354899, -323399, 1},
%e A174588   {1, -20873579, -27315455, -27944027, -27315455, -20873579, 1},
%e A174588   ...
%t A174588 << DiscreteMath`Combinatorica`
%t A174588 t[n_, m_] = If[n == 0, 1, Sum[Binomial[n, k]*Eulerian[n + 1, k]*(-1)^k*(m + 1 - k)^n, {k, 0, n}]];
%t A174588 Table[Table[t[n, m] - t[n, -1] + 1, {m, -1, n - 1}], {n, 0, 10}];
