%N A174545 Triangle read by rows: T(n,0) = T(n,n) = 1, T(n,k) = Stirling2(n,m) * 2^m where m = min(k,n-k).
%e A174545 Triangle begins:
%e A174545   {1},
%e A174545   {1, 1},
%e A174545   {1, 2, 1},
%e A174545   {1, 2, 2, 1},
%e A174545   {1, 2, 28, 2, 1},
%e A174545   {1, 2, 60, 60, 2, 1},
%e A174545   {1, 2, 124, 720, 124, 2, 1},
%e A174545   {1, 2, 252, 2408, 2408, 252, 2, 1},
%e A174545   ...
%p A174545 T:= (n,k)-> `if`(k=0 or k=n, 1, (m-> Stirling2(n, m)*2^m)(min(k, n-k))):
%p A174545 seq(seq(T(n,k), k=0..n), n=0..10);  # _Alois P. Heinz_, Mar 03 2026
%t A174545 t[n_, m_, q_] = If[m == 0 || m == n, 1, If[Floor[n/2] >= m, StirlingS2[n, m]*q^ m, StirlingS2[n, n - m]*q^(n - m)]];
%t A174545 Table[Flatten[Table[Table[t[n, m, q], {m, 0, n}], {n, 0, 10}]], {q, 1, 10}]
