%I A174885 #16 Mar 08 2026 16:21:31
%S A174885 29,409,461,661,929,1249,1289,1381,1801,1901,2081,2609,2621,2749,3041,
%T A174885 3301,3881,5309,5701,6421,6481,6521,6529,7349,7489,7789,8641,8849,
%U A174885 9349,9629,9649,9689,9829,10321,10709,10861,12841,14321,14561,15061,16661
%N A174885 Prime hypotenuses c with concatenation p = c||a||b a prime number, where (a,b,c) is a primitive Pythagorean triple with a the even leg.
%C A174885 See comments in A174825
%C A174885 c is the prime hypotenuse c, i. e. c of a primitive Pythagorean triple: a^2 + b^2 = c^2
%D A174885 W. W. R. Ball, H. S. M. Coxeter: Mathematical Recreations and Essays, New York: Dover, 1987
%D A174885 L. E. Dickson, "Rational Right Triangles", ch. 4 in History of the Theory of numbers, vol. II, Dover Publications 2005
%D A174885 W. Sierpinski, Pythagorean Triangles, Mineola, NY, Dover Publications, Inc, 2003
%H A174885 Robert Israel, <a href="/A174885/b174885.txt">Table of n, a(n) for n = 1..10000</a>
%e A174885 a(1) = 29 with 29^2 = 20^2 + 21^2 and 29 and 29||20||21 = 292021 prime.
%e A174885 a(2) = 409 with 409^2 = 120^2 + 391^2 and 409 and 409||120||391 = 409120391 prime.
%e A174885 a(3) = 461 with 461^2 = 380^2 + 261^2 and 461 and 461||380||261 = 461380261 prime.
%e A174885 a(4) = 661 with 661^2 = 300^2 + 589^2 and 661 and 661||300||589 = 661300589 prime.
%e A174885 a(5) = 929 with 929^2 = 920^2 + 129^2 and 929 and 929||920||129 = 929920129 prime.
%p A174885 N:= 20000: # for terms <= N
%p A174885 S:= {}:
%p A174885 for x from 2 while x^2 < N do
%p A174885   for y from 3 - (x mod 2) to x-1 by 2 while x^2 + y^2 <= N do
%p A174885     if igcd(x,y) > 1 then next fi;
%p A174885     c:= x^2 + y^2;
%p A174885     if not isprime(c) then next fi;
%p A174885     a:= 2*x*y;
%p A174885     b:= x^2-y^2;
%p A174885     if isprime((c*10^(1+ilog10(a))+a)*10^(1+ilog10(b))+b) then
%p A174885       S:= S union {c}
%p A174885     fi
%p A174885 od od:
%p A174885 sort(convert(S,list)); # _Robert Israel_, Mar 06 2026
%Y A174885 Cf. A008846, A020882, A048161, A067756, A138044, A174825.
%K A174885 base,nonn,changed
%O A174885 1,1
