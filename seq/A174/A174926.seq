%I A174926 #17 Jul 22 2026 15:31:05
%S A174926 101,11,41,19,1601,251,1361,149,641,181,1009,12101,14401,1699,11969,
%T A174926 2251,12569,1289,13241,1361,4001,4441,48409,10529,15761,62501,6761,
%U A174926 4729,7841,8419,9001,9619,102409,10891,115601,12251,129641,11369,14449
%N A174926 Smallest prime which has a decimal representation which shows n^2 embedded in otherwise only decimal square digits 0, 1, 4 and 9.
%C A174926 There are four decimal square digits: 0 = 0^2 = 0, 1 = 1^2, 4 = 2^2, 9 = 3^2.
%C A174926 It is conjectured that sequence is infinite.
%C A174926 Some primes of the form n^2//1 = 10 * n^2 + 1 are in this sequence: for n = 1, 2, 5, ...
%C A174926 Note this curiosity of a double appearance of 1361 as  1//6^2//1 = p(6^2) = 1361 = p(19^2) = 1//19^2 or of 13691 = prime(1618) = 37^2//1 > 11369 = prime(1373) = 1//37^2 = p(37^2), 38th term of sequence
%H A174926 Robert Israel, <a href="/A174926/b174926.txt">Table of n, a(n) for n = 0..10000</a>
%e A174926 Let // denote concatenation of digits. Then:
%e A174926 101 = prime(26) = 1//0^2//1.
%e A174926 11 = prime(5) = 1^2//1.
%e A174926 41 = prime(13) = 2^2//1.
%e A174926 19 = prime(8) = 1//3^2.
%e A174926 1601 = prime(252) = 4^2//0//1.
%e A174926 251 = prime(54) = 5^2//1.
%e A174926 1361 = prime(218) = 1//6^2//1.
%e A174926 149 = prime(35) = 1//7^2.
%e A174926 641 = prime(116) = 8^2//1.
%e A174926 181 = prime(42) = 1//9^2.
%e A174926 1009 = prime(169) = 10^2//9.
%e A174926 12101 = prime(1448) = 11^2//0//1.
%p A174926 U[1]:= [0,1,4,9]: V[1]:= [1,4,9]: W[1]:= [1,9]:
%p A174926 for d from 2 to 5 do U[d]:= map(t -> (10*t,10*t+1,10*t+4,10*t+9), U[d-1]);
%p A174926 V[d]:= select(t -> ilog10(t) = d-1, U[d]);
%p A174926 W[d]:= select(t -> member(t mod 10, [1,9]), U[d]) od:
%p A174926 f:= proc(k) local d,i,R,m,v,w,x;
%p A174926    if isprime(k) then return k fi;
%p A174926    m:= 1 + ilog10(k);
%p A174926    for d from 1 to 5 do
%p A174926      R:= sort([seq(v*10^m+k,v=V[d]),seq(k*10^d+w,w=W[d]),seq(seq(seq(v*10^(m+i)+k*10^i+w,v=V[d-i]),w=W[i]),i=1..d-1)]);
%p A174926      for x in R do if isprime(x) then return x fi od
%p A174926    od;
%p A174926  FAIL;
%p A174926 end proc:
%p A174926 f(0):= 101:
%p A174926 map(t -> f(t^2), [$0..50]); # _Robert Israel_, Jul 22 2026
%Y A174926 Cf. A174884, A062584.
