%S A174018 12,24,36,192,420,720,1020,1752,2268,3648,4596,6624,8148,11112,12924,
%T A174018 17328,20076,25488,28452,36312,39924,49152,54060,64944,70716,84696,
%U A174018 90612,106896,114756,133200,141708,164184,173340,198192,209796,237600
%N A174018 Number of reduced 3 X 3 magilatin squares with largest entry n.
%C A174018 A magilatin square has equal row and column sums and no number repeated in any row or column. It is reduced if the least value in it is 0.
%C A174018 a(n) is given by a quasipolynomial of degree 3 and period 60. [corrected by _Hoang Xuan Thanh_, Jul 14 2026]
%H A174018 Thomas Zaslavsky, <a href="/A174018/b174018.txt">Table of n, a(n) for n = 2..10000</a>.
%H A174018 Matthias Beck and Thomas Zaslavsky, <a href="https://arxiv.org/abs/math/0506315">An enumerative geometry for magic and magilatin labellings</a>, arXiv:math/0506315 [math.CO], 2005; Ann. Combinatorics, 10 (2006), no. 4, 395-413. MR 2007m:05010. Zbl 1116.05071.
%H A174018 Matthias Beck and Thomas Zaslavsky, <a href="https://cs.uwaterloo.ca/journals/JIS/VOL13/Zaslavsky/sls.html">Six Little Squares and How Their Numbers Grow </a>, J. Int. Seq. 13 (2010), 10.6.2.
%H A174018 Matthias Beck and Thomas Zaslavsky, <a href="https://people.math.binghamton.edu/zaslav/Tpapers/SLSfiles/">"Six Little Squares and How their Numbers Grow" Web Site</a>: Maple worksheets and supporting documentation.
%H A174018 <a href="/index/Rec#order_17">Index entries for linear recurrences with constant coefficients</a>, signature (-2,-1,2,5,5,2,-3,-7,-7,-3,2,5,5,2,-1,-2,-1).
%F A174018 G.f.: 12*x^2/(x-1)^2 - 36*x^3/(x-1)^3 - 72*x^3/((x-1)*(x^2-1)) - 36*x^3/(x^3-1) - 72*x^4/((x-1)^2*(x^2-1)) - 36*x^4/((x-1)*(x^3-1)) - 72*x^4/(x^2-1)^2 + 72*x^5/((x-1)^3*(x^2-1)) + 72*x^5/((x-1)^2*(x^3-1)) + 144*x^5/((x-1)*(x^2-1)^2) + 72*x^5/((x-1)*(x^4-1)) + 108*x^5/((x^2-1)*(x^3-1)) + 72*x^5/(x^5-1) + 144*x^6/((x-1)*(x^2-1)*(x^3-1)) + 72*x^6/(x^2-1)^3 + 144*x^6/((x^2-1)*(x^4-1)) + 72*x^6/(x^3-1)^2 + 72*x^7/((x^2-1)^2*(x^3-1)) + 72*x^7/((x^2-1)*(x^5-1)) + 72*x^7/((x^3-1)*(x^4-1)) + 72*x^8/((x^3-1)*(x^5-1)).
%F A174018 a(n) ~ 6*n^3. - _Charles R Greathouse IV_, May 28 2026
%F A174018 a(n) = 3*(2*n^3-21*n^2+106*n-172) + (n mod 2)*(9*n^2-108*n+306) + 24*(n-6)*((2*n^2+1) mod 3) + 48*(n mod 3) - 144*([(n mod 4)=0] + [(n mod 5)=0]). - _Hoang Xuan Thanh_, Jul 14 2026
%o A174018 (PARI) Vec((948*x^19 + 384*x^18 - 492*x^17 - 960*x^16 - 348*x^15 + 84*x^14 + 408*x^13 + 180*x^12 - 60*x^11 - 492*x^10 - 324*x^9 - 96*x^8 + 300*x^7 + 300*x^6 + 120*x^5 + 12*x^4 + 24*x^3 + 12*x^2)/((1-x^2)^2*(1-x^3)^2*(1-x^4)*(1-x^5)) + O(x^60)) \\ _Hoang Xuan Thanh_, Jul 14 2026
