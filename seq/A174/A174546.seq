%e A174546   ...
%p A174546 T:= (n,k)-> `if`(k=0 or k=n, 1, (m-> Stirling2(n, m)*3^m)(min(k, n-k))):
%p A174546 seq(seq(T(n,k), k=0..n), n=0..10);  # _Alois P. Heinz_, Mar 03 2026
%t A174546 t[n_, m_, q_] = If[m == 0 || m == n, 1, If[Floor[n/2] >= m, StirlingS2[n, m]*q^ m, StirlingS2[n, n - m]*q^(n - m)]];
%t A174546 Table[Flatten[Table[Table[t[n, m, q], {m, 0, n}], {n, 0, 10}]], {q, 1, 10}]
