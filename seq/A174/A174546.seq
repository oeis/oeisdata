%N A174546 Triangle read by rows: T(n,0) = T(n,n) = 1, T(n,k) = Stirling2(n,m) * 3^m where m = min(k,n-k).
%e A174546 Triangle begins:
%e A174546   {1},
%e A174546   {1, 1},
%e A174546   {1, 3, 1},
%e A174546   {1, 3, 3, 1},
%e A174546   {1, 3, 63, 3, 1},
