%T A174639 3624,3024,1560,1,1,8139,17176,23161,23161,17176,8139,1,1,45094,
%U A174639 101634,149374,168134,149374,101634,45094,1,1,264672,629226,989046,1214082,1214082,989046,629226,264672,1
%N A174639 Triangle read by rows: T(n,k) = binomial(n,k) * bell(k+1) * bell(n-k+1) - bell(n+1) + 1 where bell(n) = A000110(n) are the Bell numbers.
%C A174639 Triangle is symmetric.
%e A174639 Triangle begins:
%e A174639   {1},
%e A174639   {1, 1},
%e A174639   {1, 4, 1},
%e A174639   {1, 16, 16, 1},
%e A174639   {1, 69, 99, 69, 1},
%e A174639   {1, 318, 548, 548, 318, 1},
%e A174639   {1, 1560, 3024, 3624, 3024, 1560, 1},
%e A174639   {1, 8139, 17176, 23161, 23161, 17176, 8139, 1},
%e A174639   ...
%p A174639 B:= proc(n) option remember; `if`(n=0, 1,
%p A174639       add(B(n-j)*binomial(n-1, j-1), j=1..n))
%p A174639     end:
%p A174639 T:= (n,k)-> binomial(n,k)*B(k+1)*B(n-k+1)-B(n+1)+1:
%p A174639 seq(seq(T(n,k), k=0..n), n=0..9);  # _Alois P. Heinz_, Mar 07 2026
%t A174639 f[n_] := Sum[StirlingS2[n, k], {k, 1, n}];
%t A174639 t[n_, m_] = Binomial[n, m]*f[m + 1]*f[n - m + 1]
%t A174639 Table[Table[t[n, m] - t[n, 0] + 1, {m, 0, n}], {n, 0, 10}];
%t A174639 Flatten[%]
%Y A174639 Cf. A000110.
%K A174639 nonn,tabl,less,changed
%O A174639 0,5
