%S A028339 1,9,86,950,12139,177331,2924172,53809164,1094071221,24372200061,
%T A028339 590546123298,15467069396610,435512515705695,13121113142970855,
%U A028339 421214220916438680,14354510691610713240,517596339235489288425,19688993487602867898225,787995759739909824183150
%N A028339 Coefficient of x^2 in expansion of (x+1)*(x+3)*...*(x+2*n-1).
%C A028339 (2n-1)!!*a(n) is the sum (and a(n)/(2n-1)!! is the average), over all (2n-1)!!^2 permutations P in S_n consisting of even cycles only, of binomial(# of cycles in P, 2). - _Natalia L. Skirrow_, Jul 10 2026
%H A028339 G. C. Greubel, <a href="/A028339/b028339.txt">Table of n, a(n) for n = 2..400</a>
%F A028339 a(n) = A028338(n,2).
%F A028339 a(n) = A161198(n,2)/4. - _Johannes W. Meijer_, Jun 08 2009
%F A028339 a(n) = Sum_{i=k..n} 2^(n-i) * C(i,k) * s1(n,i) with k = 2, where s1(n,i) are unsigned Stirling numbers of the first kind. - Victor Adamchik (adamchik(AT)ux10.sp.cs.cmu.edu), Jan 23 2001 (corrected by _Natalia L. Skirrow_, Jul 10 2026)
%F A028339 E.g.f.: (log(1-2*x))^2/(8*sqrt(1-2*x)). - _Vladeta Jovovic_, Feb 19 2003
%F A028339 a(n) ~ n! * log(n)^2 * 2^(n-3) / sqrt(Pi*n) * (1 + (2*gamma + 4*log(2))/log(n)), where gamma is the Euler-Mascheroni constant (A001620). - _Vaclav Kotesovec_, Oct 18 2017
%F A028339 From _Natalia L. Skirrow_, Jul 10 2026: (Start)
%F A028339 D-finite with a(n) = 3*(2*n-3)*a(n-1) - (12*(n-2)^2 + 1)*a(n-2) + (2*n-5)^3*a(n-3).
%F A028339 a(n) = Sum_{k=2..n} C(n,k) * (2n-2k-1)!! * 2^(k-2) * s1(k,2).
%F A028339 a(n) = n! * Sum_{k=2..n} C(2n-2k,n-k) * 2^(2k-n-2) * H(k-1)/k.
%F A028339 a(n) = (2n-1)!! * Sum_{0 <= i < j < n} 1/((2i+1)*(2j+1)).
%F A028339 a(n) = (A004041(n-1)^2 - A001824(n-1)) / (2*(2n-1)!!).
%F A028339 a(n) = (2n-1)!! * ((H(2n)-H(n)/2)^2 - (H(2n,2)-H(n,2)/4))/2 where H(n,p) = Sum_{k=1..n} 1/k^p are the generalized harmonic numbers.
%F A028339 a(n) = (2n-1)!! * ((H(n-1/2)/2 + log(2))^2 - H(n-1/2,2)/4 - Pi^2/12)/2 using the extension H(x,p) = Sum_{k>=1} 1/k^p - 1/(k+x)^p for real x.
%F A028339 a(n) = sqrt(2) * (2n/e)^n * ((log(n)/2 + c)^2 - Pi^2/8 + O(1/n))/2, with c = log(2) + gamma/2 = A114864.
%F A028339 (End)
%e A028339 E.g.f. = x^2/2! + 9*x^3/3! + 86*x^4/4! + 950*x^5/5! + 12139*x^6/6! + 177331*x^7/7! + ...
%p A028339 egf := log(1 - 2*x)^2/(8*sqrt(1 - 2*x)): ser := series(egf, x, 21):
%p A028339 seq(n!*coeff(ser, x, n), n = 2..20); # _Peter Luschny_, Jul 11 2026
%t A028339 Table[Coefficient[Product[x + 2*k - 1, {k, 1, n}], x, 2], {n,2,50}] (* _G. C. Greubel_, Nov 24 2016 *)
%t A028339 (* Alternative: faster *)
%t A028339 H:=HarmonicNumber
%t A028339 A028339[n_]:=(2n-1)!!*((H[2n]-H[n]/2)^2-H[2n,2]+H[n,2]/4)/2
%t A028339 Table[A028339[n],{n,2,50}] (* _Natalia L. Skirrow_, Jul 10 2026 *)
%t A028339 (* Alternative: for manipulating asymptotics *)
%t A028339 A028339[n_]:=FullSimplify[(2n-1)!!*((H[n-1/2]/2+Log[2])^2-H[n-1/2,2]/4-Pi^2/12)/2] (* _Natalia L. Skirrow_, Jul 10 2026 *)
%o A028339 (PARI) a(n) = polcoeff(prod(k=1, n, x+2*k-1), 2); \\ _Michel Marcus_, Nov 12 2014
%Y A028339 Cf. A001824, A004041.
%Y A028339 Cf. A028338, A161198.
%Y A028339 Cf. A001620, A114864.
%K A028339 nonn,changed
%O A028339 2,2
