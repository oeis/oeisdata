%T A028576 152342891952,2080240006923,28738242567524,401024083514775,
%U A028576 5645275548076800,80084088088568947,1143862232096407392,16437995698573558421,237520818846111947600,3449065945198414208745
%N A028576 a(n) = (1/(4*n)) * Sum_{d|n} mu(n/d) * binomial(2*d, d)^2.
%C A028576 Conjecture: a(n) is divisible by n and 3*a(n) by n^2. - _F. Chapoton_, Feb 25 2026
%H A028576 Michel Marcus, <a href="/A028576/b028576.txt">Table of n, a(n) for n = 1..800</a>
%t A028576 A028576[n_] := DivisorSum[n, MoebiusMu[n/#]*Binomial[2*#, #]^2 &]/(4*n);
%t A028576 Array[A028576, 25] (* _Paolo Xausa_, Mar 02 2026 *)
%o A028576 (PARI) a(n) = sumdiv(n, d, moebius(n/d)*binomial(2*d, d)^2)/(4*n) \\ _Michel Marcus_, Jun 15 2013
