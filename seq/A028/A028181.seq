%F A028181 G.f.: 1/((1-5x)(1-7x)(1-8x)(1-10x)).
%F A028181 a(n) = (10^(n+3)-5*8^(n+3)+5*7^(n+3)-5^(n+3))/30. - _Yahia Kahloune_, Jun 04 2013
%F A028181 a(0)=1, a(1)=30, a(2)=569, a(3)=8730, a(n) = 30*a(n-1)-331*a(n-2)+1590*a(n-3)-2800*a(n-4). - _Harvey P. Dale_, Aug 18 2013
%F A028181 a(n) = (7^(n+1)-5^(n+1))/2+18*a(n-1)-80*a(n-2). - _Vincenzo Librandi_, Jul 22 2026
%t A028181 CoefficientList[Series[1/((1-5x)(1-7x)(1-8x)(1-10x)),{x,0,20}],x] (* _Harvey P. Dale_, Aug 18 2013 *)
%t A028181 (* Alternative: *)
%t A028181 LinearRecurrence[{30,-331,1590,-2800},{1,30,569,8730},20] (* _Harvey P. Dale_, Aug 18 2013 *)
%o A028181 (Magma) I:=[1, 30]; [n le 2 select I[n] else (7^n-5^n)/2+18*Self(n-1)-80*Self(n-2): n in [1..20]]; // _Vincenzo Librandi_, Jul 22 2026
