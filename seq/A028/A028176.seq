%N A028176 Expansion of 1/((1-5*x)*(1-6*x)*(1-9*x)*(1-12*x)).
%H A028176 Vincenzo Librandi, <a href="/A028176/b028176.txt">Table of n, a(n) for n = 0..900</a>
%H A028176 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (32,-369,1818,-3240).
%F A028176 G.f.: 1/((1-5*x)*(1-6*x)*(1-9*x)*(1-12*x)).
%F A028176 a(n) = (2*12^(n+3)-7*9^(n+3)+14*6^(n+3)-9*5^(n+3))/252. - _Yahia Kahloune_, Jun 03 2013
%F A028176 a(n) = 32*a(n-1) - 369*a(n-2) + 1818*a(n-3) - 3240*a(n-4). - _Wesley Ivan Hurt_, Jan 25 2023
%F A028176 a(n) = 6^(n+1)-5^(n+1)+21*a(n-1)-108*a(n-2). - _Vincenzo Librandi_, Jul 17 2026
%F A028176 E.g.f.: exp(5*x)*(384*exp(7*x) - 567*exp(4*x) + 336*exp(x) - 125)/28. - _Stefano Spezia_, Jul 18 2026
%t A028176 CoefficientList[Series[1/((1-5x)(1-6x)(1-9x)(1-12x)),{x,0,20}],x] (* _Harvey P. Dale_, Sep 26 2016 *)
%t A028176 (* Alternative: *)
%t A028176 LinearRecurrence[{32,-369,1818,-3240},{1,32,655,10970},20] (* _Harvey P. Dale_, Sep 26 2016 *)
%o A028176 (Magma) I:=[1, 32]; [n le 2 select I[n] else 6^n-5^n+21*Self(n-1)-108*Self(n-2): n in [1..19]]; // _Vincenzo Librandi_, Jul 17 2026
