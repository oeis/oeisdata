%N A063628 Smallest k such that 9^k has exactly n 2's in its decimal representation.
%t A063628 a = {}; Do[k = 1; While[ Count[ IntegerDigits[9^k], 2] != n, k++ ]; a = Append[a, k], {n, 0, 50} ]; a
%t A063628 Join[{1},With[{c=DigitCount[9^Range[0,500],10,2]},{th=Thread[{Range[501],c}]},Table[SelectFirst[th,#[[2]]==n&],{n,50}]][[;;,1]]-1] (* _Harvey P. Dale_, May 15 2026 *)
