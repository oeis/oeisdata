%I A378274 #12 Jul 13 2026 13:06:13
%S A378274 0,0,0,0,1,2,3,4,5,9,11,17,19,25,31,40,48,59
%N A378274 Number of subgroups of S_n isomorphic to S_5 up to conjugacy, where S_n is the n-th symmetric group.
%H A378274 James East, Attila Egri-Nagy, Andrew R. Francis, and James D. Mitchell, <a href="http://ijnc.org/index.php/ijnc/article/view/348">Computing Embeddings and Isomorphisms of Finite Semigroups</a>, International Journal of Networking and Computing, Volume 16, Number 2 (2026), pages 147-165. See p. 162.
%o A378274 (GAP) A378274 := function(n)
%o A378274 return Length(IsomorphicSubgroups(SymmetricGroup(n), SymmetricGroup(5)));
%o A378274 end;
%Y A378274 Column k=5 of A378177.
%Y A378274 Cf. A004526, A378266, A378273.
%K A378274 nonn,hard,more,changed
