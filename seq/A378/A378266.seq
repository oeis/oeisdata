%I A378266 #32 Jul 13 2026 13:04:40
%S A378266 0,0,1,1,2,4,5,7,10,12,15,20,23,28,34,39,45,54
%N A378266 Number of subgroups of S_n isomorphic to S_3 up to conjugacy, where S_n is the n-th symmetric group.
%H A378266 James East, Attila Egri-Nagy, Andrew R. Francis, and James D. Mitchell, <a href="http://ijnc.org/index.php/ijnc/article/view/348">Computing Embeddings and Isomorphisms of Finite Semigroups</a>, International Journal of Networking and Computing, Volume 16, Number 2 (2026), pages 147-165. See p. 162.
%o A378266 (GAP) A378266 := function(n)
%o A378266 return Length(IsomorphicSubgroups(SymmetricGroup(n), SymmetricGroup(3)));
%o A378266 end;
%Y A378266 Column k=3 of A378177.
%Y A378266 Cf. A004526, A378273, A378274.
