%I A378273 #13 Jul 13 2026 13:05:29
%S A378273 0,0,0,1,1,4,5,10,13,22,27,47,56,84,104,147,175,250
%N A378273 Number of subgroups of S_n isomorphic to S_4 up to conjugacy, where S_n is the n-th symmetric group.
%H A378273 James East, Attila Egri-Nagy, Andrew R. Francis, and James D. Mitchell, <a href="http://ijnc.org/index.php/ijnc/article/view/348">Computing Embeddings and Isomorphisms of Finite Semigroups</a>, International Journal of Networking and Computing, Volume 16, Number 2 (2026), pages 147-165. See p. 162.
%o A378273 (GAP) A378273 := function(n)
%o A378273 return Length(IsomorphicSubgroups(SymmetricGroup(n), SymmetricGroup(4)));
%o A378273 end;
%Y A378273 Column k=4 of A378177.
%Y A378273 Cf. A004526, A378266, A378274.
%K A378273 nonn,hard,more,changed
%O A378273 1,6
