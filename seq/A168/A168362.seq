%S A168362 1,2,6,34,280,3010,39984,634040,11704548,246799212,5856139256,
%T A168362 154509170816,4488522398568,142395677932872,4899139202191216,
%U A168362 181714457372434436,7228856213182113768,307047663830976178304,13869994589640136690336,663976989978171594869350,33579260181092227231600048
%N A168362 a(n) = coefficient of x^n in the n-th iteration of Sum_{k>=0} x^(2^k), n>=1.
%C A168362 It appears that a(n+1)/a(n) ~ n*exp(1). - _Paul D. Hanna_, May 22 2026
%H A168362 Paul D. Hanna, <a href="/A168362/b168362.txt">Table of n, a(n) for n = 1..520</a>
%e A168362 Given F(x) = x + x^2 + x^4 + x^8 + x^16 +...+ x^(2^n) + ...,
%e A168362 define F^n(x) = F^(n-1)(F(x)) as the n-th iteration of F(x);
%e A168362 then the table of coefficients of x^k in F^n(x) begins
%e A168362   n = 1: [1, 1,  0,   1,    0,     0,     0,      1, ...];
%e A168362   n = 2: [1, 2,  2,   3,    6,     8,     8,     16, ...];
%e A168362   n = 3: [1, 3,  6,  12,   28,    68,   152,    330, ...];
%e A168362   n = 4: [1, 4, 12,  34,  100,   310,   972,   3012, ...];
%e A168362   n = 5: [1, 5, 20,  75,  280,  1070,  4176,  16449, ...];
%e A168362   n = 6: [1, 6, 30, 141,  650,  3010, 14116,  66972, ...];
%e A168362   n = 7: [1, 7, 42, 238, 1316,  7238, 39984, 222614, ...];
%e A168362   n = 8: [1, 8, 56, 372, 2408, 15428, 98728, 634040, ...]; ...
%e A168362 in which the main diagonal forms the initial terms of this sequence.
%e A168362 For n > 1, a(n) == 2 (mod 4) when n = [2, 3, 4, 6, 20, 24, 40, 68, 136, 260, 520, ...], and it appears that a(n) == 0 (mod 4) elsewhere. - _Paul D. Hanna_, May 22 2026
%o A168362 (PARI) {a(n) = my(A=vector(n),G=x, B = sum(k=0,#binary(n),x^(2^k)) +x*O(x^n)); A[#A]=1; for(m=1,n, G=subst(B,x,G); A[m] = polcoeff(G,m)); AV=A; A[n]}
%o A168362 {upto(n) = a(n); AV}
%o A168362 upto(20) \\ program revised by _Paul D. Hanna_, May 22 2026
