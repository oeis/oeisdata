%S A168575 8,1331,1030301,1003003001,1000300030001,1000030000300001,
%T A168575 1000003000003000001,1000000300000030000001,1000000030000000300000001,
%U A168575 1000000003000000003000000001,1000000000300000000030000000001,1000000000030000000000300000000001,1000000000003000000000003000000000001
%N A168575 a(n) = (10^n + 1)^3.
%H A168575 Gustavus J. Simmons, <a href="/A002778/a002778.pdf">On palindromic squares of non-palindromic numbers</a>, J. Rec. Math., 5 (No. 1, 1972), 11-19. [Annotated scanned copy] See Table 4.
%H A168575 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (1111,-112110,1111000,-1000000).
%F A168575 From _Elmo R. Oliveira_, May 23 2026: (Start)
%F A168575 G.f.: (8 - 7557*x + 448440*x^2 - 1331000*x^3) / ((1-x)*(1-10*x)*(1-100*x)*(1-1000*x)).
%F A168575 E.g.f.: (1 + 3*exp(9*x) + 3*exp(99*x) + exp(999*x))*exp(x).
%F A168575 a(n) = 1111*a(n-1) - 112110*a(n-2) + 1111000*a(n-3) - 1000000*a(n-4).
%F A168575 a(n) = A062397(n)^3 = A000578(A062397(n)). (End)
%t A168575 Table[(10^n+1)^3, {n,0,25}] (* _G. C. Greubel_, Jul 26 2016 *)
%t A168575 (* Alternative: *)
%t A168575 LinearRecurrence[{1111,-112110,1111000,-1000000},{8,1331,1030301,1003003001},20] (* _Harvey P. Dale_, Dec 31 2018 *)
%o A168575 (PARI) for(n=0,12,print1((10^n+1)^3","))
%Y A168575 Cf. A000578, A062397.
