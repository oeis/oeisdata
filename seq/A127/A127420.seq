%I A127420 #25 Jul 18 2026 09:27:44
%S A127420 1,1,1,2,1,1,4,2,2,1,9,5,5,3,1,1,24,15,15,10,5,5,2,1,77,53,53,38,23,
%T A127420 23,13,8,3,3,1,295,218,218,165,112,112,74,51,28,28,15,7,4,1,1,1329,
%U A127420 1034,1034,816,598,598,433,321,209,209,135,84,56,28,28,13,6,2,1,6934,5605,5605,4571,3537,3537,2721,2123,1525,1525,1092,771,562,353,353,218,134,78,50,22,22,9,3,1
%N A127420 Triangle, read by rows, where row n+1 is generated from row n by first inserting a zero after terms found at positions {m*(m+3)/2, m >= 0} in row n and then taking the partial sums from right to left, for n >= 1. Row 0 consists of a single '1' by convention.
%C A127420 Column 0 forms A091352, which also equals column 1 of table A125781, where table A125781 is generated by a complementary recurrence of this triangle.
%C A127420 The number of terms in row n is A127419(n).
%H A127420 Paul D. Hanna, <a href="/A127420/b127420.txt">Table of n, a(n) for n = 0..8173 (rows 0..40)</a>
%e A127420 To generate row 6 from row 5, which begins
%e A127420 24, 15, 15, 10, 5, 5, 2, 1;
%e A127420 first segment the terms into groups of size k for k = 1, 2, 3, ...
%e A127420 (24), (15, 15), (10, 5, 5), (2, 1, 0, 0);
%e A127420 next insert a zero between groups,
%e A127420 (24), 0, (15, 15), 0, (10, 5, 5), 0, (2, 1, 0, 0);
%e A127420 ignore segmentation and drop trailing zeros,
%e A127420 24,  0, 15, 15,  0, 10,  5, 5, 0, 2, 1;
%e A127420 then take partial sums from right to left to obtain row 6:
%e A127420 77, 53, 53, 38, 23, 23, 13, 8, 3, 3, 1.
%e A127420 Starting with row 1 = [1, 1] and continuing in this way will generate all subsequent rows of this triangle.
%e A127420 This triangle begins:
%e A127420   1;
%e A127420   1, 1;
%e A127420   2, 1, 1;
%e A127420   4, 2, 2, 1;
%e A127420   9, 5, 5, 3, 1, 1;
%e A127420   24, 15, 15, 10, 5, 5, 2, 1;
%e A127420   77, 53, 53, 38, 23, 23, 13, 8, 3, 3, 1;
%e A127420   295, 218, 218, 165, 112, 112, 74, 51, 28, 28, 15, 7, 4, 1, 1;
%e A127420   1329, 1034, 1034, 816, 598, 598, 433, 321, 209, 209, 135, 84, 56, 28, 28, 13, 6, 2, 1; ...
%e A127420 Column 0 of this triangle equals column 1 of triangle A091351, where triangle A091351 begins:
%e A127420   1;
%e A127420   1, 1;
%e A127420   1, 2, 1;
%e A127420   1, 4, 3, 1;
%e A127420   1, 9, 9, 4, 1;
%e A127420   1, 24, 30, 16, 5, 1;
%e A127420   1, 77, 115, 70, 25, 6, 1;
%e A127420   1, 295, 510, 344, 135, 36, 7, 1; ...
%e A127420 and column k of A091351 = row sums of matrix power A091351^k for k>=0.
%o A127420 (PARI) \\ By definition - _Paul D. Hanna_, Jul 16 2026
%o A127420 \\ Insert zeros in vector after each group of k terms as k = 1,2,3,...
%o A127420 {InsertZeros(V) = my(v=0,k=0,W=[]); until(v==#V, k=k+1; for(i=1,k, if(v<#V, W=concat(W,V[v=v+1]) )); W=concat(W,0); ); W}
%o A127420 \\ Calculate the first N row vectors R
%o A127420 \\ Returns a vector V of N row vectors
%o A127420 {GetRows(N) = my(R=[1,1],V=vector(N+1)); V[1]=[1]; V[2]=R;
%o A127420 for(n=3,N+1, R = Vecrev(Vec(Ser(Vecrev(InsertZeros(R)))/(1-x))); V[n] = R); T=V}
%o A127420 \\ print the table T of the first N rows
%o A127420 {uptoRow(N) = GetRows(N); for(n=0,N, print(T[n+1]))}
%o A127420 uptoRow(12)
%Y A127420 Cf. A091352, A091351, A125781, A127419.
%K A127420 nonn,tabf,changed
%O A127420 0,4
%A A127420 _Paul D. Hanna_, Jan 14 2007
