%U A127732 24039065352401162580869899907532787,2590596133095312437932791734267691653442607,29987151430893484246716697508064240936086917614616072924464106966030657
%N A127732 Primes of the form k# + (k+1)# ... +(k+x)# + 61; where k#,(k+1)#,(k+x)# are primorial numbers, members of A002110, where the 1st summand is primorial 6.
%C A127732 Primes of the form A002110(k)+A002110(k+1)+...A002110(k+x) + 61.
%e A127732 67 = 6 + 61;
%e A127732 97 = 6 + 30 + 61;
%e A127732 307 = 6 + 30 + 210 + 61;
%e A127732 2617 = 6 + 30 + 210 + 2310 + 61;
%e A127732 32647 = 6 + 30 + 210 + 2310 + 30030 + 61;
%e A127732 ... where 6, 30, 210, 2310, 30030 are terms of A002110.
%o A127732 (PARI) f(n) = sum(k=2, n, P(k))+61;
%o A127732 select(isprime, vector(50, n, f(n+1))) \\ _Michel Marcus_, Jun 03 2026
%Y A127732 Cf. A125191; A002110.
%K A127732 nonn,changed
