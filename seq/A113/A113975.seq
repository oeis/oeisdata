%T A113975 6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,
%U A113975 6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,6,6
%N A113975 Absolute value of the n-th coefficient in the expansion of the generating function (2-7*x-x^2) / (1-x).
%C A113975 I call it the devil's Farey because of the 6,6,6 structure.
%F A113975 a(n) = abs([x^n] x * (1 + 2/x - 6/(1-x))).
%F A113975 a(n) = abs([x^n] (2-7*x-x^2) / (1-x)).
%F A113975 a(n) = 6 for all n >= 2.
%t A113975 a = 1; b = 2; c = 3; d = 3; e = 0; f = -1 p[x_] = FullSimplify[ExpandAll[(x - a)*(x - b)*(x - c)/((x - d)*(x - e)*(x -f))]] a = Abs[ReplacePart[Table[Abs[Coefficient[Series[p[x], {x, 0, 30}], x^n]], {n, -1, 30}], -5, 2]]
%Y A113975 Cf. A010722, A113923.
%K A113975 nonn,dumb,less
%O A113975 0,1
%A A113975 _Roger L. Bagula_, Jan 31 2006
