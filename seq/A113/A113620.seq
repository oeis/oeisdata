%I A113620 #17 Jul 07 2026 01:10:16
%S A113620 21600,36000,48600,121500,169344,225000,337500,395136,857304,3000564,
%T A113620 6690816,19600000,24532992,37380096,53782400,59295096,88942644,
%U A113620 122500000,161980416,171478296,658834400,774400000,943130628,1022754816,2155524696,2344190625,4326400000
%N A113620 Numbers whose 3 prime powers are a permutation of each other. Numbers with 3 distinct prime factors whose 3 exponents are a permutation of the 3 bases.
%H A113620 Robert Israel, <a href="/A113620/b113620.txt">Table of n, a(n) for n = 1..10000</a>
%F A113620 {a(n)} = {p1^a * p2^b * p3^c for 3 distinct primes p1, p2, p3 such that (a, b, c) is a permutation of (p1, p2, p3)}.
%e A113620 21600 = 2^5 * 3^3 * 5^2
%e A113620 36000 = 2^5 * 3^2 * 5^3
%e A113620 48600 = 2^3 * 3^5 * 5^2
%e A113620 121500 = 2^2 * 3^5 * 5^3
%e A113620 169344 = 2^7 * 3^3 * 7^2
%e A113620 225000 = 2^3 * 3^2 * 5^5
%e A113620 337500 = 2^2 * 3^3 * 5^5
%e A113620 395136 = 2^7 * 3^2 * 7^3
%e A113620 857304 = 2^3 * 3^7 * 7^2
%e A113620 3000564 = 2^2 * 3^7 * 7^3
%e A113620 6690816 = 2^11 * 3^3 * 11^2
%e A113620 24532992 = 2^11 * 3^2 * 11^3
%e A113620 37380096 = 2^13 * 3^3 * 13^2
%e A113620 59295096 = 2^3 * 3^2 * 7^7
%e A113620 88942644 = 2^2 * 3^3 * 7^7
%e A113620 161980416 = 2^13 * 3^2 * 13^3
%e A113620 171478296 = 2^3 * 3^11 * 11^2
%e A113620 943130628 = 2^2 * 3^11 * 11^3
%e A113620 2155524696 = 2^3 * 3^13 * 13^2
%e A113620 2344190625 = 3^7 * 5^5 * 7^3
%e A113620 4594613625 = 3^7 * 5^3 * 7^5
%e A113620 6511640625 = 3^5 * 5^7 * 7^3
%e A113620 14010910524 = 2^2 * 3^13 * 13^3
%e A113620 25015118625 = 3^5 * 5^3 * 7^7
%e A113620 35452265625 = 3^3 * 5^7 * 7^5
%e A113620 69486440625 = 3^3 * 5^5 * 7^7
%e A113620 736820803125 = 3^11 * 5^5 * 11^3
%e A113620 3083660425988 = 2^2 * 3^3 * 11^11
%e A113620 3566212687125 = 3^11 * 5^3 * 11^5
%e A113620 15792626953125 = 3^5 * 5^11 * 11^3
%e A113620 20542440283992 = 2^3 * 3^2 * 11^11
%e A113620 212323095703125 = 3^3 * 5^11 * 11^5
%e A113620 8666341994809125 = 3^5 * 5^3 * 11^11
%e A113620 21807007674642216 = 2^3 * 3^2 * 13^13
%e A113620 24073172207803125 = 3^3 * 5^5 * 11^11
%e A113620 32710511511963324 = 2^2 * 3^3 * 13^13
%p A113620 N:= 10^20: # for terms <= N
%p A113620 patterns:= map(t -> a^t[1]*b^t[2]*c^t[3],combinat:-permute([a,b,c])):
%p A113620 R:= NULL:
%p A113620 for P in patterns do
%p A113620   for ia from 1 while subs(a=ithprime(ia),b=ithprime(ia+1),c=ithprime(ia+2),P) <= N do
%p A113620     for ib from ia+1 while subs(a = ithprime(ia), b = ithprime(ib), c = ithprime(ib+1), P) <= N do
%p A113620       for ic from ib+1 do
%p A113620         x:= subs(a=ithprime(ia),b=ithprime(ib),c=ithprime(ic),P);
%p A113620         if x > N then break fi;
%p A113620         R:= R,x
%p A113620 od od od od:
%p A113620 sort([R]); # _Robert Israel_, Jul 06 2026
%Y A113620 Cf. A113855.
%K A113620 easy,nonn
%O A113620 1,1
