%I A113001 #12 Jul 16 2026 15:45:20
%S A113001 1,3,2,4,5,6,9,7,12,8,11,10,14,13,15,19,18,17,16,20,24,22,21,26,25,23,
%T A113001 28,27,30,32,31,37,29,39,36,33,35,42,34,45,38,40,44,43,41,48,47,52,51,
%U A113001 49,46,53,54,55,58,57,56,60,64,50,63,62,61,59,66,65,71,70,69,67,72,68
%N A113001 Smallest k, not occurring earlier, such that (2*k + n-th odd prime) is prime.
%C A113001 Permutation of the natural numbers with fixed points A113005: a(A113005(n))=A113005(n);
%C A113001 inverse: A113004; A113006(n) = a(a(n));
%C A113001 A113002(n) = 2*a(n) + A065091(n).
%H A113001 Robert Israel, <a href="/A113001/b113001.txt">Table of n, a(n) for n = 1..10000</a>
%H A113001 <a href="/index/Per#IntegerPermutation">Index entries for sequences that are permutations of the natural numbers</a>
%p A113001 N:= 200: # for terms before the first term > N
%p A113001 Cands:= [$1..N]: nC:= N:
%p A113001 p:= 2: R:= NULL: found:= true:
%p A113001 for n from 1 while found do
%p A113001   p:= nextprime(p);
%p A113001   found:= false;
%p A113001   for j from 1 to nC do
%p A113001     if isprime(p+2*Cands[j]) then
%p A113001       R:= R, Cands[j];
%p A113001       Cands:= subsop(j=NULL,Cands);
%p A113001       nC:= nC-1;
%p A113001       found:= true;
%p A113001       break
%p A113001     fi;
%p A113001   od;
%p A113001 od:
%p A113001 R; # _Robert Israel_, Jul 16 2026
%Y A113001 Cf. A113002, A113004, A113005, A113006, A065091.
%K A113001 nonn,changed
%O A113001 1,2
%A A113001 _Reinhard Zumkeller_, Oct 10 2005
