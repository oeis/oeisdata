%S A113393 1,12,186,3892,106089,3620379,149740555,7316974618,413939637263,
%T A113393 26674140920951,1932099681055593,155591826253029963,
%U A113393 13802736990317399904,1338361705725008068468,140897444878639681727527,16011627854373788685284865,1954208195019902817905605773,255019192486460947257880420210
%N A113393 Column 1 of triangle A113392, also equals column 0 of A113381^6.
%F A113393 A113392 equals the matrix square of A113389, which has the property: Column k of A113389^2 = column 0 of A113381^(3*k+3) for k>=0.
%o A113393 (PARI) {a(n) = my(A,B); A=Mat(1); for(m=2,n+2, B=matrix(m,m); for(i=1,m, for(j=1,i, if(i<3 || j==i || j>m-1, B[i,j]=1, if(j==1, B[i,1]=1, B[i,j]=(A^(3*j-2))[i-j+1,1]));)); A=B); (matrix(#A,#A,r,c,if(r>=c,(A^(3*c))[r-c+1,1]))^2)[n+2,2]}
%o A113393 for(n=0,20, print1(a(n),", ")) \\ program revised by _Paul D. Hanna_, May 23 2026
%Y A113393 Cf. A113392, A113389, A113381, A113388.
%K A113393 nonn,changed
%O A113393 0,2
