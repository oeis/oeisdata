%I A114468 #26 Jul 10 2026 08:04:43
%S A114468 1,4,40,433,4345,43450,434110,4342302,43428678
%N A114468 Number of decimal digits in the denominator of the 10^n-th harmonic number.
%C A114468 These numbers converge to the decimal expansion of log_10(e) = 0.43429448... (A002285).
%H A114468 Jonathan Sondow and Eric W. Weisstein, <a href="https://mathworld.wolfram.com/HarmonicNumber.html">MathWorld: Harmonic Number</a>.
%t A114468 a[n_] := IntegerLength[Denominator[HarmonicNumber[10^n]]]; Array[a, 8, 0] (* _Amiram Eldar_, Jul 10 2026 *)
%o A114468 (Python)
%o A114468 from gmpy2 import digits, mpq
%o A114468 def a(n): return len(digits(sum(mpq(1, n) for n in range(1, 10**n+1)).denominator))
%o A114468 print([a(n) for n in range(6)]) # _Michael S. Branicky_, Jun 22 2023
%Y A114468 Cf. A001008, A002285, A002805, A114467.
%K A114468 nonn,base,more,changed
%O A114468 0,2
