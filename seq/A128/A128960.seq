%I A128960 #51 Jul 08 2026 08:56:02
%S A128960 0,24,192,960,3840,13440,43008,129024,368640,1013760,2703360,7028736,
%T A128960 17891328,44728320,110100480,267386880,641728512,1524105216,
%U A128960 3586129920,8367636480,19377684480,44568674304,101871255552,231525580800,523449139200,1177760563200,2638183661568
%N A128960 a(n) = (n^3 - n)*2^n.
%C A128960 a(n) is the number of induced subgraphs isomorphic to the path P_4 in the (n+1)-dimensional hypercube Q_(n+1). To count directed copies, choose first one of the 2^(n+1) starting vertices. From it there are n+1 choices for the first coordinate direction, then n remaining choices for the second direction, and then n-1 remaining choices for the third direction. The three directions must be distinct. This gives an induced path of length 3, since nonconsecutive vertices differ in at least two coordinates. Hence there are 2^(n+1)*(n+1)*n*(n-1) directed induced paths. Each undirected induced P_4 is counted twice, once from each endpoint, so a(n) = 2^(n+1)*(n+1)*n*(n-1)/2 = (n^3-n)*2^n. For example, Q_3 has 24 such induced paths, Q_4 has 192, and Q_5 has 960. - _Constantinos Kourouzides_, Jun 30 2026
%H A128960 Vincenzo Librandi, <a href="/A128960/b128960.txt">Table of n, a(n) for n = 1..1000</a>
%H A128960 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (8,-24,32,-16).
%F A128960 G.f.: 24*x^2/(1-2*x)^4. - _Vincenzo Librandi_, Feb 12 2013
%F A128960 a(n) = 8*a(n-1) - 24*a(n-2) + 32*a(n-3) - 16*a(n-4). - _Vincenzo Librandi_, Feb 12 2013
%F A128960 From _Amiram Eldar_, Oct 02 2022: (Start)
%F A128960 a(n) = A007531(n+1)*A000079(n).
%F A128960 Sum_{n>=2} 1/a(n) = (2*log(2)-1)/8.
%F A128960 Sum_{n>=2} (-1)^n/a(n) = (3/2)^2*log(3/2) - 7/8. (End)
%F A128960 a(n) = 3*binomial(n+1,3)*2^(n+1). - _Chai Wah Wu_, Jun 30 2026
%F A128960 E.g.f.: 4*exp(2*x)*x^2*(3 + 2*x). - _Stefano Spezia_, Jul 08 2026
%t A128960 CoefficientList[Series[24 x/(1 - 2 x)^4, {x, 0, 30}], x] (* _Vincenzo Librandi_, Feb 12 2013 *)
%t A128960 (* Alternative: *)
%t A128960 LinearRecurrence[{8, -24, 32, -16}, {0, 24, 192, 960}, 30] (* _Vincenzo Librandi_, Feb 12 2013 *)
%o A128960 (Magma) [(n^3-n)*2^n: n in [1..25]]; // _Vincenzo Librandi_, Feb 12 2013
%o A128960 (Magma) I:=[0,24,192,960]; [n le 4 select I[n] else 8*Self(n-1)-24*Self(n-2)+32*Self(n-3)-16*Self(n-4): n in [1..25]]; // _Vincenzo Librandi_, Feb 12 2013
%o A128960 (PARI) a(n)=(n^3-n)<<n \\ _Charles R Greathouse IV_, Oct 07 2015
%o A128960 (Python)
%o A128960 from math import comb
%o A128960 def A128960(n): return 3*comb(n+1,3)<<n+1 # _Chai Wah Wu_, Jun 30 2026
