%e A106599 Triangle begins:
%e A106599   1;
%e A106599   5, 6;
%e A106599   3, 1, 2;
%e A106599   5, 5, 6, 4;
%e A106599   3, 3, 1, 2, 2;
%e A106599   5, 5, 5, 6, 4, 4;
%e A106599   3, 3, 3, 1, 2, 2, 2;
%e A106599   5, 5, 5, 5, 6, 4, 4, 4;
%e A106599   ...
%p A106599 f:= n-> [[5,6], [4], [5], [2], [3], [1,2]][n][]:
%p A106599 T:= proc(n) option remember; `if`(n=0, 1, map(f, [T(n-1)])[]) end:
%p A106599 seq(T(n), n=0..13);  # _Alois P. Heinz_, May 11 2026
