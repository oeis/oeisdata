%U A375914 67921,75361,79381,90241,100651,102311,104721,106201,106561,112141,113201,115921,121463,133141
%N A375914 Base-5 Euler-Jacobi pseudoprimes: odd composite k coprime to 5 such that 5^((k-1)/2) == (5/k) (mod k), where (5/k) is the Jacobi symbol (or Kronecker symbol).
%H A375914 Jianing Song, <a href="/A375914/b375914.txt">Table of n, a(n) for n = 1..1000</a>
%e A375914 781 is a term because 781 = 11*71 is composite, (5/781) = 1, and 5^((781-1)/2) == 1 (mod 781).
%e A375914 7813 is a term because 7813 = 13*601 is composite, (5/7813) = -1, and 5^((7813-1)/2) == -1 (mod 7813).
%t A375914 q[k_] := OddQ[k] && CoprimeQ[k, 5] && CompositeQ[k] && PowerMod[5, (k-1)/2, k] == Mod[JacobiSymbol[5, k], k]; Select[Range[135000], q] (* _Amiram Eldar_, Mar 21 2026 *)
%o A375914 (PARI) isA375914(k) = k>1 && !isprime(k) && gcd(k,10)==1 && Mod(5,k)^((k-1)/2)==kronecker(5,k)
%Y A375914 For a list of sequences related to Euler-Jacobi pseudoprimes and Euler pseudoprimes, see A306310.
%K A375914 nonn
%O A375914 1,1
