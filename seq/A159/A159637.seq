%e A159637 (End)
%t A159637 A159637[n_, k_] := BitXor @@ ThueMorse[{n, k}];
%t A159637 Table[A159637[n-k, k], {n, 0, 12}, {k, 0, n}] (* _Paolo Xausa_, Apr 18 2026 *)
%o A159637 (PARI) T(n, k) = bitxor(hammingweight(n)%2, hammingweight(k)%2) \\ _Rémy Sigrist_, Apr 18 2026
%o A159637 (Python)
%o A159637 def T(n, k): return (n.bit_count()&1) ^ (k.bit_count()&1)    # after _Rémy Sigrist_
%o A159637 print([T(ad-n, n) for ad in range(13) for n in range(ad+1)]) # _Michael S. Branicky_, Apr 18 2026
