%T A347701 2244,2622,3040,3500,4004,4554,5152,5800,6500,7254,8064,8932,9860,
%U A347701 10850,11904,13024,14212,15470,16800,18204,19684,21242,22880,24600,26404,28294,30272,32340,34500,36754,39104,41552,44100
%N A347701 Rightmost diagonal of A347700.
%C A347701 Apparently a(n) = A159920(n), n>=2. - _R. J. Mathar_, Apr 08 2026
%C A347701 From _Jianing Song_, Apr 09 2026: (Start)
%C A347701 This is indeed idential to A159920.
%C A347701 By definition, a(n) counts the n X n (0,1)-matrices M, up to simultaneous permutations of rows and columns, such that
%C A347701   - M[i,j] = 0 unless i = j or j = 1;
%C A347701   - at least one among M[2,1], ..., M[n,1] is 1.
%C A347701 Let
%C A347701   A = {2<=i<=n : M[i,1] = 0, M[i,i] = 0},
%C A347701   B = {2<=i<=n : M[i,1] = 0, M[i,i] = 1},
%C A347701   C = {2<=i<=n : M[i,1] = 1, M[i,i] = 0},
%C A347701   D = {2<=i<=n : M[i,1] = 1, M[i,i] = 1}.
%C A347701 Since the matrices are counted up to permutations, only the cardinalities of A, B, C, D matter, and so
%C A347701   a(n) = 2*#{(|A|,|B|,|C|,|D|) : |A|+|B|+|C|+|D|=n-1, at least one of |C| and |D| is nonzero},
%C A347701 as M[1,1] can take arbitrarily 0 or 1. We finally get a(n) = 2*(binomial(n+2,3) - binomial(n,1)) = (n - 1)*n*(n + 4)/3 = A159920(n). (End)
%H A347701 H. Sharp, Jr., <a href="https://doi.org/10.1016/0012-365X(73)90081-2">Enumeration of vacuously transitive relations</a>, Discrete Math. 4 (1973), 185-196.
%Y A347701 Cf. A003041, A347700.
