%U A347993 222655633595044875,9369696305273798656,419790650812640438641,19950175280765680680960,1002394352017754098219999,53092232229227200348160000
%N A347993 a(n) = n! * Sum_{k=1..n} (-1)^(k+1) * n^(n-k) / (n-k)!.
%F A347993 E.g.f.: -LambertW(-x) / (1 - LambertW(-x)^2).
%F A347993 a(n) = n * A133297(n).
%F A347993 a(n) = n^n * hypergeom([1, 1-n], [], 1/n). - _Peter Luschny_, Mar 09 2026
%p A347993 a := n -> ifelse(n = 0, 0, n^n * hypergeom([1, 1-n], [], 1/n)):
%p A347993 seq(simplify(a(n)), n = 1..20);  # _Peter Luschny_, Mar 09 2026
%t A347993 Table[n! Sum[(-1)^(k + 1) n^(n - k)/(n - k)!, {k, 1, n}], {n, 1, 20}]
%t A347993 nmax = 20; CoefficientList[Series[-LambertW[-x]/(1 - LambertW[-x]^2), {x, 0, nmax}], x] Range[0, nmax]! // Rest
%o A347993 (PARI) a(n) = n! * sum(k=1, n, (-1)^(k+1)*n^(n-k)/(n-k)!); \\ _Michel Marcus_, Sep 23 2021
%o A347993 (Python)
%o A347993 from math import factorial
%o A347993 def a(n: int) -> int:
%o A347993     if n == 0: return 0
%o A347993     t = factorial(n)
%o A347993     if n % 2 == 0: t = -t
%o A347993     f = t
%o A347993     for k in range(n, 1, -1):
%o A347993         t = -n * t // (n - k + 1)
%o A347993         f += t
%o A347993     return f
%o A347993 print([a(n) for n in range(1, 21)])  # _Peter Luschny_, Mar 09 2026
