%S A359687 489489,525698,526535,763002,903210,1423214,1588620,1886852,2152934,
%T A359687 2241441,2577185,2582431,2773897,2861430,2976190,3091110,3279211,
%U A359687 3616639,3930234
%N A359687 Numbers k for which rank of the elliptic curve y^2 = x^3 - 432*k^2 is 5.
%F A359687 A060838(a(n)) = 5.
%F A359687 (6/5 + o(1))*n < a(n) << n^3. - _Charles R Greathouse IV_, Apr 27 2026
%o A359687 (PARI) is(n,f=factor(n))=my(c=prod(i=1, #f~, f[i, 1]^(f[i, 2]\3)), r=n/c^3); if(r<4e6, return(!!setsearch([489489, 525698, 526535, 763002, 903210, 1423214, 1588620, 1886852, 2152934, 2241441, 2577185, 2582431, 2773897, 2861430, 2976190, 3091110, 3279211, 3616639, 3930234],n))); my(E=ellinit([0, 16*r^2]), eri=ellrankinit(E), mwr=ellrank(eri), ar); if(mwr[1]>5 || mwr[2]<5, return(0)); if(mwr[1]==mwr[2], return(mwr[1]==5)); ar=ellanalyticrank(E)[1]; if(ar<2, return(0)); for(effort=1, 99, mwr=ellrank(eri, effort); if(mwr[1]>5 || mwr[2]<5, return(0), mwr[1]==5 && mwr[2]==5, return(1))); Str("unknown; ", ar==5, " under BSD conjecture since analytic rank = ", ar) \\ _Charles R Greathouse IV_, Apr 28 2026
