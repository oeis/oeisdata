%I A359750 #11 Mar 30 2026 00:02:33
%S A359750 24,48,96,144,192,288,384,576,720,768,864,1152,1440,1536,1728,2304,
%T A359750 2880,3072,3456,4320,4608,5184,5760,6144,6912,8640,9216,10368,11520,
%U A359750 12288,13824,17280,18432,20736,23040,24576,25920,27648,31104,34560,36864,40320,41472,46080
%N A359750 Numbers that are a product of one or more factorials j!, j >= 2, in at least two ways.
%H A359750 Chai Wah Wu, <a href="/A359750/b359750.txt">Table of n, a(n) for n = 1..10000</a>
%e A359750 24 = 2! * 3! = 4!.
%e A359750 144 = (2!)^2 * (3!)^2 = 3! * 4!.
%o A359750 (PARI) is(n) = { if(n == 1, return(0)); my(i, factorials, e, res, v); f = factor(n); if(prime(#f~) != f[#f~, 1], return(0); ); if(f[,2] != vecsort(f[,2],,4), return(0); ); factorials = List(); e = List(); res = List(); for(i = 2, oo, v = valuation(n, i!); if(v > 0, listput(factorials, i!); listput(e, v); , break ) ); forvec(x = vector(#e-1, i, [0, e[i+1]]), c = prod(i = 1, #e-1, factorials[i+1]^x[i]); if(c <= n && denominator(n/c) == 1&& 1 << logint(n/c, 2) == n/c, listput(res, concat([valuation(n/c, 2)], x)) ) ); #res >= 2 } \\ _David A. Corneth_, Jan 13 2023
%o A359750 (Python)
%o A359750 from itertools import count, islice
%o A359750 from functools import lru_cache
%o A359750 from sympy import integer_log
%o A359750 from oeis_sequences.OEISsequences import bisection
%o A359750 def A359750_gen(): # generator of terms
%o A359750     @lru_cache(maxsize=None)
%o A359750     def g(x, m, j): return sum(g(x//m**i, m-1, i) for i in range(j,integer_log(x, m)[0]+1)) if m-2 else max(0,x.bit_length()-j)
%o A359750     def f(x):
%o A359750         c, f = n-1+x, 1
%o A359750         for k in count(2):
%o A359750             f *= k
%o A359750             if f>x:
%o A359750                 break
%o A359750             c -= g(x,k,1)
%o A359750         return c
%o A359750     a, b = 0, 0
%o A359750     for n in count(1):
%o A359750         k = bisection(f,max(b,n),max(b,n))
%o A359750         if k == b and k != a:
%o A359750             yield k
%o A359750         a, b = b, k
%o A359750 A359750_list = list(islice(A359750_gen(),30)) # _Chai Wah Wu_, Mar 29 2026
%Y A359750 Cf. A001013.
%K A359750 nonn
%O A359750 1,1
%A A359750 _David A. Corneth_, Jan 13 2023
