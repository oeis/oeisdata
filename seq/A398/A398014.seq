%t A398014 RealDigits[-Zeta'[2]/Zeta[2]^2, 10, 120][[1]]
%o A398014 (PARI) (1 - 12*zeta'(-1) - log(2*Pi) - Euler)/zeta(2)
%o A398014 (PARI) -zeta'(2)/zeta(2)^2
