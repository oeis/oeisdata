%S A398167 1,2,3,5,6,10,11,13,14,17,19,21,22,29,30,33,34,35,37,38,41,42,43,46,
%T A398167 51,57,58,59,61,62,65,66,67,69,70,73,74,77,78,82,83,85,86,89,91,93,94,
%U A398167 97,101,102,105,106,109,110,113,114,115,118,122,123,129,130,131,133,137,138,139
%N A398167 Squarefree numbers k such that k+1 is cubefree.
%C A398167 The asymptotic density of this sequence is d = Product_{p prime} (1 - 1/p^2 - 1/p^3) = 0.479145344433396245631... . The number of terms not exceeding x is d * x + O(x^(2/3+eps)), where eps > 0 (Srichan et al., 2026, p. 3, Corollary 1.2).
%H A398167 Amiram Eldar, <a href="/A398167/b398167.txt">Table of n, a(n) for n = 1..10000</a>
%H A398167 Teerapat Srichan, Nithi Rungtanapirom, and Saeree Wananiyakul, <a href="https://doi.org/10.1051/ita/2026022">On the distribution of consecutive M-free integers</a>, RAIRO - Theoretical Informatics and Applications, Vol. 60 (2026), Article 22.
%t A398167 freeQ[m_, k_] := freeQ[m, k] = AllTrue[FactorInteger[m][[;; , 2]], # < k &];
%t A398167 Select[Range[140], freeQ[#, 2] && freeQ[#+1, 3] &]
%o A398167 (PARI) isfree(m, k) = #select(x -> x >= k, factor(m)[,2]) == 0;
%o A398167 isok(m) = isfree(m, 2) && isfree(m+1, 3);
%Y A398167 Subsequence of A005117 and A340152.
%Y A398167 A007674 is a subsequence.
%Y A398167 Cf. A004709.
