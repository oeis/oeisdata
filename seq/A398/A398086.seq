%S A398086 1,9,387,19449,1046547,58522509,3354252831,195575471163,
%T A398086 11547992056851,688476974577453,41360187962340387,2500086841408822653,
%U A398086 151893882431107567263,9267931589752183800006,567552714806995882874037,34865112185891854033619574,2147634976025186016846267411
%N A398086 a(n) = [x^n] A(x)^n where A(x) = exp(Sum_{k >= 1} binomial(3*k,k)^2 * x^k/k).
%H A398086 Vaclav Kotesovec, <a href="/A398086/b398086.txt">Table of n, a(n) for n = 0..550</a>
%F A398086 a(n) ~ c * d^n / sqrt(n), where d = 64.00020399378086208276757645331387324057653712602012555... = exp(9*r*HypergeometricPFQ[{1, 1, 4/3, 4/3, 5/3, 5/3}, {3/2, 3/2, 2, 2, 2}, 729*r/16])/r and c = 0.088255861154390549063460633309628377980548073844424950... = 1/sqrt(18*Pi*r*HypergeometricPFQ[{4/3, 4/3, 5/3, 5/3}, {3/2, 3/2, 2}, 729*r/16]), where r = 0.021696826941458118100212954736030306018735497767441166... is the real root of the equation HypergeometricPFQ[{1/3, 1/3, 2/3, 2/3}, {1/2, 1/2, 1}, 729*r/16] = 2.
%t A398086 nmax = 20; Table[SeriesCoefficient[Exp[n*Sum[Binomial[3*k, k]^2 * x^k/k, {k, 1, n}]], {x, 0, n}], {n, 0, nmax}]
%t A398086 (* Alternative: *)
%t A398086 nmax = 20; Table[SeriesCoefficient[Exp[9*n*x*HypergeometricPFQ[{1, 1, 4/3, 4/3, 5/3, 5/3}, {3/2, 3/2, 2, 2, 2}, 729*x/16]], {x, 0, n}], {n, 0, nmax}]
%Y A398086 Cf. A362730, A188662, A398085.
