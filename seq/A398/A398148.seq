%T A398148 45,36,28,8,30,48,20,16,24,90,36,18,24,48,40,12,42,60,60,22,46,48,91,
%U A398148 45,32,72,52,45,40,72,36,28,58,48,60,30,90,96,48,20,66,96,44,24,70,180,72,36,90,108,60,24,78,96,135,40,82,72,64
%N A398148 Dirichlet g.f.: zeta(s-1) * Product_{p prime} (1 - 1/p^s + 1/p^(2*s-2)).
%H A398148 Vaclav Kotesovec, <a href="/A398148/b398148.txt">Table of n, a(n) for n = 1..10000</a>
%H A398148 Vaclav Kotesovec, <a href="/A398148/a398148.jpg">Graph - the asymptotic ratio (100000000 terms)</a>
%F A398148 Sum_{k=1..n} a(k) ~ n^2/2.
%F A398148 Multiplicative with a(p) = p-1, and a(p^e) = (2*p-1)*p^(e-1) for e >= 2. - _Amiram Eldar_, Jul 22 2026
%t A398148 f[p_, 1] := p-1; f[p_, e_] := (2*p-1)*p^(e-1); a[1] = 1; a[n_] := Times @@ f @@@ FactorInteger[n]; Array[a, 100] (* _Amiram Eldar_, Jul 22 2026 *)
%o A398148 (PARI) for(n=1, 100, print1(direuler(p=2, n, 1/(1-p*X)*(1 - X + p^2*X^2))[n], ", "))
%Y A398148 Cf. A397412.
%K A398148 nonn,mult,easy,new
%O A398148 1,3
