%e A398114   8 | 0  1 11 319 903 6141 11954 44711 72890 ...
%e A398114   ...
%e A398114 The T(4,3) = 2 cacti are:
%e A398114    o---o---o---o---o     o---o---o---o
%e A398114     \ / \ / \ / \ /       \ / \ / \ /
%e A398114      o   o   o   o         o   o   o
%e A398114                               / \
%e A398114                              o---o
%e A398114 The T(4,4) = 4 cacti are:
%e A398114     o--o          o--o          o--o       o--o
%e A398114     |  |          |  |          |  |       |  |
%e A398114     o--o--o       o--o--o       o--o--o    o--o--o
%e A398114        |  |          |  |          |  |       |  |
%e A398114        o--o--o       o--o--o    o--o--o    o--o--o--o
%e A398114           |  |          |  |    |  |       |  |  |  |
%e A398114           o--o--o    o--o--o    o--o--o    o--o  o--o
%e A398114              |  |    |  |          |  |
%e A398114              o--o    o--o          o--o
%o A398114 (PARI)
%o A398114 G(n,k) = { if(k==0, 1+x+O(x*x^n), my(g=O(1)); for(i=0, n, g = 1+x*(g^k + g^(k%2)*subst(g^(k\2), x, x^2))/2); g) }
%o A398114 CPalK(g,k) = { my(g2=subst(g, x,x^2)); if(k%2, g*g2^(k\2), (g^2*g2^(k/2-1) + g2^(k/2))/2) }
%o A398114 U(n,k)={ my(g = G(n-1,k-1)); 1 + (subst(g-1,x,x^2) - (g - 1)^2)/2 + x*(CPalK(g,k) + sumdiv(k, d, eulerphi(d)*subst((g + O(x^(n\d+1)))^(k/d), x, x^d))/k)/2 }
%o A398114 T(n, m=n+1)={Mat(vector(m, k, Col(U(n, k))))}
%o A398114 { my(A=T(8)); for(n=1, #A, print(A[n, ])) }
%Y A398114 Columns k=2..5 are A000012, A000672, A135527, A398115.
%Y A398114 Cf. A332649, A398112 (rooted at vertex).
