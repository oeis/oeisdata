%U A398039 16301328840,48904262028,146712786084,440139185892,1320417557676,3961255155948,11883765467844,35651303855640
%N A398039 G.f. A(x) satisfies A(x) = A(x^2) / (1-3*x), with A(0) = 1.
%F A398039 G.f.: Product_{k>=0} 1/(1 - 3*x^(2^k)).
%F A398039 G.f.: 1 + 3 * Sum_{j>=0} x^(2^j) / Product_{k=0..j} (1 - 3*x^(2^k)).
%F A398039 a(0) = 1; for n >= 1, a(n) = 3*a(n-1) + a(n/2) if 2|n, and a(n) = 3*a(n-1) otherwise.
%F A398039 a(n) = Sum_{k=0..floor(n/2)} 3^(n-2*k) * a(k) for n >= 1.
%o A398039 (PARI) my(N=30, x='x+O('x^N)); Vec(1/prod(k=0, logint(N, 2), 1-3*x^2^k))
%Y A398039 Cf. A018819, A309728, A398040.
%K A398039 nonn,new
%O A398039 0,2
%A A398039 _Seiichi Manyama_, Jul 18 2026
