%I A398162 #12 Jul 23 2026 22:59:31
%S A398162 1,2,3,5,6,8,10,11,13,14,15,17,19,21,22,24,27,29,30,32,33,34,35,37,38,
%T A398162 40,41,42,43,46,47,51,54,56,57,58,59,61,62,65,66,67,69,70,73,74,77,78,
%U A398162 79,82,83,85,86,88,89,91,93,94,96,97,101,102,104,105,106,109,110,111,113,114,115,118,120
%N A398162 Exponentially odd numbers k such that the prime factorization exponents of k+1 are either 1 or even.
%C A398162 Terms k is in A268335 such that k+1 is a term in A335275.
%C A398162 The asymptotic density of this sequence is 1/zeta(2) = 6/Pi^2 = 0.607927... (A059956). The number of terms not exceeding x is d * x + O(x^(2/3+eps)), where eps > 0 (Srichan et al., 2026, p. 3, Corollary 1.3).
%H A398162 Amiram Eldar, <a href="/A398162/b398162.txt">Table of n, a(n) for n = 1..10000</a>
%H A398162 Teerapat Srichan, Nithi Rungtanapirom, and Saeree Wananiyakul, <a href="https://doi.org/10.1051/ita/2026022">On the distribution of consecutive M-free integers</a>, RAIRO - Theoretical Informatics and Applications, Vol. 60 (2026), Article 22.
%t A398162 a268335Q[n_] := a268335Q[n] = AllTrue[FactorInteger[n][[;; , 2]], OddQ[#] &];
%t A398162 a335275Q[n_] := a335275Q[n] = AllTrue[FactorInteger[n][[;; , 2]], # == 1 || EvenQ[#] &];
%t A398162 Select[Range[120], a268335Q[#] && a335275Q[#+1] &]
%o A398162 (PARI) isA268335(k) = #select(x -> !(x%2), factor(k)[,2]) == 0;
%o A398162 isA335275(k) = #select(x -> x > 1 && x%2, factor(k)[,2]) == 0;
%o A398162 isok(k) = isA268335(k) && isA335275(k+1);
%Y A398162 Subsequence of A268335.
%Y A398162 Cf. A059956, A335275.
%Y A398162 Similar sequences: A007674, A340152, A367695, A372690, A391396, A398161, A398163, A398164, A398165, A398166, A398167, A398168, A398169, A398170.
%K A398162 nonn,easy,new
%O A398162 1,2
%A A398162 _Amiram Eldar_, Jul 22 2026
