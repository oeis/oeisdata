%T A398031 87,57,119,111,27,49,9,33,1027,9,27,143,21,21,253,21,9,143,9,87,77,27,
%U A398031 9,49,87,27,49,27,9,49,21,33,49,27,21,77,9,9,187,9,27,1007
%N A398031 Least composite k such that the concatenation (k, n, k) is prime.
%C A398031 Within the first 10000 terms, the range of values spans from 9 to 1273, with only 13 isolated peaks showing values between 100013 and 100157. For example: a(1122) = 100061, a(1309) = 100017, a(5049) = 100081, etc.
%C A398031 a(n) is coprime to 10 and not equivalent to n (mod 3).
%C A398031 Computing possible remainders for n based on this all numbers < 9 are excluded and as for some n we have a(n) = 9 we have a(n) >= 9 for all n. - _David A. Corneth_, Jul 19 2026
%H A398031 Paolo P. Lava, <a href="/A398031/b398031.txt">Table of n, a(n) for n = 1..10000</a>
%e A398031 a(1) = 9 -> 919;
%e A398031 a(2) = 9 -> 929;
%e A398031 a(3) = 77 -> 77377; etc.
%p A398031 a:=proc(q) local k; k:=9; while not isprime(parse(cat(k,q,k))) or isprime(k) do k:=k+2; od; k end:
%p A398031 seq(a(n),n=1..100);
%t A398031 a[n_]:=Module[{k=4},While[PrimeQ[k]||!PrimeQ[FromDigits[Join[IntegerDigits[k],IntegerDigits[n],IntegerDigits[k]]]], k++]; k]; Array[a,66] (* _Stefano Spezia_, Jul 18 2026 *)
%o A398031 (Python)
%o A398031 from sympy import isprime
%o A398031 from itertools import count
%o A398031 def a(n):
%o A398031     sn = str(n)
%o A398031     return next(k for k in count(9, 2) if not isprime(k) and isprime(int((sk:=str(k))+sn+sk)))
%o A398031 print([a(n) for n in range(1, 67)]) # _Michael S. Branicky_, Jul 19 2026
%o A398031 (PARI) a(n) = my(sn=Str(n)); forcomposite(k=2, oo, my(sk=Str(k)); if (isprime(eval(concat(concat(sk, sn), sk))), return(k))); \\ _Michel Marcus_, Jul 19 2026
