%I A398170 #11 Jul 23 2026 22:59:27
%S A398170 1,2,5,6,10,13,14,21,22,29,30,32,33,34,37,38,40,41,42,46,54,56,57,58,
%T A398170 61,65,66,69,70,73,77,78,82,85,86,88,93,94,96,101,102,104,105,106,109,
%U A398170 110,113,114,118,122,128,129,130,133,136,137,138,141,142,145,154,157,158,160
%N A398170 Exponentially odd numbers numbers k such that k+1 is squarefree.
%C A398170 Terms k in A268335 such that k+1 is a term in A005117.
%C A398170 The asymptotic density of this sequence is d = Product_{p prime} (1 - 1/p^2 - 1/(p*(p+1))) = 0.394391775736286326344... . The number of terms not exceeding x is d * x + O(x^(2/3+eps)), where eps > 0 (Srichan et al., 2026, a consequence of Theorem 1.1).
%H A398170 Amiram Eldar, <a href="/A398170/b398170.txt">Table of n, a(n) for n = 1..10000</a>
%H A398170 Teerapat Srichan, Nithi Rungtanapirom, and Saeree Wananiyakul, <a href="https://doi.org/10.1051/ita/2026022">On the distribution of consecutive M-free integers</a>, RAIRO - Theoretical Informatics and Applications, Vol. 60 (2026), Article 22.
%t A398170 expOddQ[k_] := AllTrue[FactorInteger[k][[;;, 2]], OddQ];
%t A398170 Select[Range[160], expOddQ[#] && SquareFreeQ[#+1] &]
%o A398170 (PARI) isexpodd(k) = #select(x -> !(x % 2), factor(k)[,2]) == 0;
%o A398170 isok(k) = isexpodd(k) && issquarefree(k+1);
%Y A398170 Subsequence of A268335 and A367695.
%Y A398170 A007674 is a subsequence.
%Y A398170 Cf. A005117.
%Y A398170 Similar sequences: A340152, A372690, A391396, A398161, A398162, A398163, A398164, A398165, A398166, A398167, A398168, A398169.
%K A398170 nonn,easy,new
%O A398170 1,2
