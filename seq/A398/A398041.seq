%U A398041 44914464,89828928,179658538,359317076,718634152,1437269668,2874539336,5749078672,11498160072,22996320144
%N A398041 G.f. A(x) satisfies A(x) = A(x^3) / (1-2*x), with A(0) = 1.
%F A398041 G.f.: Product_{k>=0} 1/(1 - 2*x^(3^k)).
%F A398041 G.f.: 1 + 2 * Sum_{j>=0} x^(3^j) / Product_{k=0..j} (1 - 2*x^(3^k)).
%F A398041 a(0) = 1; for n >= 1, a(n) = 2*a(n-1) + a(n/3) if 3|n, and a(n) = 2*a(n-1) otherwise.
%F A398041 a(n) = Sum_{k=0..floor(n/3)} 2^(n-3*k) * a(k) for n >= 1.
%o A398041 (PARI) my(N=40, x='x+O('x^N)); Vec(1/prod(k=0, logint(N, 3), 1-2*x^3^k))
%Y A398041 Cf. A062051, A374626, A398042.
%K A398041 nonn,new
%O A398041 0,2
