%T A398036 4599018,13797028,41391084,124173252,372519756,1117559190,3352677570,
%U A398036 10058032710,30174098130,90522294156,271566882468,814700647404,2444101942212,7332305825934,21996917477802
%N A398036 G.f. A(x) satisfies (1-3*x)*A(x) + A(x^4) = x.
%F A398036 G.f.: Sum_{j>=0} (-1)^j*x^(4^j) / Product_{k=0..j} (1 - 3*x^(4^k)).
%F A398036 a(1) = 1; for n >= 2, a(n) = 3*a(n-1) - a(n/4) if 4|n, and a(n) = 3*a(n-1) otherwise.
%F A398036 a(n) = 3^(n-1) - Sum_{k=1..floor(n/4)} 3^(n-4*k) * a(k).
%o A398036 (Ruby)
%o A398036 def A398036(n)
%o A398036   a = [0]
%o A398036   (1..n).each{|i|
%o A398036   a << (1..i / 4).inject(3 ** (i - 1)){|s, k| s - 3 ** (i - 4 * k) * a[k]}}
%o A398036   a[1..-1]
%o A398036 end
%o A398036 p A398036(30)
%Y A398036 Cf. A045694, A397274.
%K A398036 nonn,new
%O A398036 1,2
