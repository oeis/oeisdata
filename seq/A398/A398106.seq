%T A398106 109,135,11,0,1,1,6,50,268,768,622,23,0,1,1,7,72,535,2574,5652,3032,
%U A398106 46,0,1,1,8,98,938,6510,26004,43618,15134,98,0,1,1,9,128,1505,13821,83601,274752,346353,77506,207,0
%N A398106 Array read by antidiagonals: T(n,k) is the number of rooted 2k-ary dyslexic trees with n internal nodes, n >= 0, k >= 0.
%C A398106 A dyslexic tree is a tree in which child nodes are reversible but otherwise ordered (cf. A032128).
%H A398106 Andrew Howroyd, <a href="/A398106/b398106.txt">Table of n, a(n) for n = 0..1325</a> (first 51 antidiagonals)
%F A398106 G.f. of column k satisfies A(x) = 1 + x*cycle_index(G,A(x)) where G = cyclic group of order 2 generated by a permutation consisting of n 2-cycles.
%F A398106 G.f. of column k satisfies A(x) = 1 + x*(A(x)^(2*k) + A(x^2)^k))/2.
%e A398106 Array begins:
%e A398106 ========================================================
%e A398106 n\k | 0  1    2     3      4       5       6       7 ...
%e A398106 ----+---------------------------------------------------
%e A398106   0 | 1  1    1     1      1       1       1       1 ...
%e A398106   1 | 1  1    1     1      1       1       1       1 ...
%e A398106   2 | 0  1    2     3      4       5       6       7 ...
%e A398106   3 | 0  2    8    18     32      50      72      98 ...
%e A398106   4 | 0  3   30   109    268     535     938    1505 ...
%e A398106   5 | 0  6  135   768   2574    6510   13821   26040 ...
%e A398106   6 | 0 11  622  5652  26004   83601  215322  476938 ...
%e A398106   7 | 0 23 3032 43618 274752 1121565 3502456 9117528 ...
%e A398106   ...
%e A398106 T(1,2) = 1 corresponds to the following 4-array tree:
%e A398106                   o
%e A398106              -----+----
%e A398106              |  |  |  |
%e A398106 The T(2,2) = 2 4-array trees (reversals are considered the same) are:
%e A398106              o                  o
%e A398106         -----+----         -----+----
%e A398106         |  |  |  |         |  |  |  |
%e A398106         o                     o
%e A398106    -----+----            -----+----
%e A398106    |  |  |  |            |  |  |  |
%o A398106 (PARI)
%o A398106 G(n,k)=if(k==0, 1+x+O(x*x^n), my(g=O(1)); for(i=0, n, g = 1+x*(g^(2*k) + subst(g^k, x, x^2))/2); g)
%o A398106 T(n,m=n)={Mat(vector(m+1, k, Col(G(n, k-1))))}
%o A398106 { my(A=T(8)); for(n=1, #A, print(A[n, ])) }
%Y A398106 Columns k=0..4 are: A019590, A001190(n+1), A036723, A036724, A036725.
%Y A398106 Cf. A032128, A070914 (linear order), A299038 (for symmetric group), A398107 (for cyclic group).
%K A398106 nonn,tabl,new
%O A398106 0,13
