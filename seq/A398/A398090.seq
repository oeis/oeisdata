%N A398090 G.f.: exp(Sum_{k>=1} binomial(4*k,k)^2 * x^k/k).
%H A398090 Vaclav Kotesovec, <a href="/A398090/b398090.txt">Table of n, a(n) for n = 0..500</a>
%F A398090 a(n) ~ 2 * exp(729*HypergeometricPFQ[{1, 1, 5/4, 5/4, 3/2, 3/2, 7/4, 7/4}, {4/3, 4/3, 5/3, 5/3, 2, 2, 2}, 1]/4096) * (65536/729)^n / (3*Pi*n^2).
%t A398090 nmax = 20; Table[SeriesCoefficient[Exp[Sum[Binomial[4*k, k]^2*x^k/k, {k, 1, n}]], {x, 0, n}], {n, 0, nmax}]
%t A398090 (* Alternative: *)
%t A398090 CoefficientList[Series[Exp[16*x*HypergeometricPFQ[{1, 1, 5/4, 5/4, 3/2, 3/2, 7/4, 7/4}, {4/3, 4/3, 5/3, 5/3, 2, 2, 2}, 65536*x/729]], {x, 0, 20}], x]
