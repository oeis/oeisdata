%U A398040 372343650880,1489376023440,5957504093760,23830022054720,95320088218880,381280375599760,1525121502399040
%N A398040 G.f. A(x) satisfies A(x) = A(x^2) / (1-4*x), with A(0) = 1.
%F A398040 G.f.: Product_{k>=0} 1/(1 - 4*x^(2^k)).
%F A398040 G.f.: 1 + 4 * Sum_{j>=0} x^(2^j) / Product_{k=0..j} (1 - 4*x^(2^k)).
%F A398040 a(0) = 1; for n >= 1, a(n) = 4*a(n-1) + a(n/2) if 2|n, and a(n) = 4*a(n-1) otherwise.
%F A398040 a(n) = Sum_{k=0..floor(n/2)} 4^(n-2*k) * a(k) for n >= 1.
%o A398040 (PARI) my(N=30, x='x+O('x^N)); Vec(1/prod(k=0, logint(N, 2), 1-4*x^2^k))
%Y A398040 Cf. A018819, A309728, A398039.
%K A398040 nonn,new
%O A398040 0,2
