%N A398002 E.g.f. A(x) satisfies A'(x) = 1 + A((exp(3*x) - 1)/3), with A(0) = 0.
%F A398002 a(1) = 1; a(n+1) = Sum_{k=1..n} 3^(n-k) * Stirling2(n,k) * a(k).
%o A398002 (PARI) a_vector(n) = my(v=vector(n)); v[1]=1; for(i=1, n-1, v[i+1]=sum(j=1, i, 3^(i-j)*stirling(i, j, 2)*v[j])); v;
