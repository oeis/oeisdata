%I A398166 #12 Jul 23 2026 22:59:52
%S A398166 1,2,5,6,10,13,14,15,16,21,22,29,30,33,34,37,38,41,42,46,47,57,58,61,
%T A398166 65,66,69,70,73,77,78,79,80,81,82,85,86,93,94,101,102,105,106,109,110,
%U A398166 111,112,113,114,118,122,129,130,133,137,138,141,142,145,154,157,158,161,162,165
%N A398166 Numbers k such that all the exponents in the prime factorizations of k and k+1 are squares.
%C A398166 Numbers k such that k and k+1 are both terms in A197680.
%C A398166 The asymptotic density of this sequence is d = Product_{p prime} (1 - 2*(p-1)*Sum_{k>=2, k nonsquare} 1/p^(k+1)) = Product_{p prime} (1 - 2/p^2 + 2*Sum_{k>=2} (1/p^(k^2) - 1/p^(k^2+1))) = 0.373378234795363735351... . The number of terms not exceeding x is d * x + O(x^(2/3+eps)), where eps > 0 (Srichan et al., 2026, a consequence of Theorem 1.1).
%H A398166 Amiram Eldar, <a href="/A398166/b398166.txt">Table of n, a(n) for n = 1..10000</a>
%H A398166 Teerapat Srichan, Nithi Rungtanapirom, and Saeree Wananiyakul, <a href="https://doi.org/10.1051/ita/2026022">On the distribution of consecutive M-free integers</a>, RAIRO - Theoretical Informatics and Applications, Vol. 60 (2026), Article 22.
%t A398166 a197680Q[n_] := a197680Q[n] = AllTrue[FactorInteger[n][[;; , 2]], IntegerQ[Sqrt[#]] &];
%t A398166 Select[Range[100], a197680Q[#] && a197680Q[#+1] &]
%o A398166 (PARI) isA197680(k) = #select(x -> !issquare(x), factor(k)[,2]) == 0;
%o A398166 isok(k) = isA197680(k) && isA197680(k+1);
%Y A398166 Subsequence of A197680.
%Y A398166 Cf. A000037.
%Y A398166 Similar sequences: A007674, A340152, A367695, A372690, A391396, A398161, A398162, A398163, A398164, A398165, A398167, A398168, A398169, A398170.
%K A398166 nonn,easy,new
%O A398166 1,2
