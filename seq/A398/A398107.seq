%o A398107 (PARI)
%o A398107 G(n,k) = {if(k==0, 1+x+O(x*x^n), my(g=O(1)); for(i=0, n, g = 1+x*(sumdiv(k, d, eulerphi(d)*subst((g + O(x^(i\d+1)))^(k/d), x, x^d)))/k); g)}
%o A398107 T(n,m=n)={Mat(vector(m+1, k, Col(G(n, k-1))))}
%o A398107 { my(A=T(8)); for(n=1, #A, print(A[n, ])) }
