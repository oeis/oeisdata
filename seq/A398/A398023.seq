%S A398023 1,1,2,2,5,2,11,2,14,18,17,2,66,2,23,78,121,2,127,2,313,144,35,2,625,
%T A398023 542,41,232,791,2,2100,2,1044,342,53,2730,5372,2,59,474,6073,2,11558,
%U A398023 2,2585,8618,71,2,22507,23960,10984,804,4443,2,30127,15064,80886,1002,89,2,71019
%N A398023 Number of integer compositions of n such that every initial segment has an integer average.
%C A398023 a(n) counts compositions (c_1, ..., c_k) of n with i dividing c_1 + ... + c_i for all i; a(0) = 1 (the empty composition).
%C A398023 Let T(n,k) be the number of such compositions with exactly k parts. The number of parts k divides n (the last partial sum is n), so a(n) = Sum_{k|n} T(n,k). The constant composition (n/k, ..., n/k) always qualifies, so T(n,k) >= 1 for each divisor k of n; hence a(n) >= A000005(n) (the number of divisors of n). In particular, a(n) = 2 if and only if n is prime (n >= 2).
%H A398023 Andrew Howroyd, <a href="/A398023/b398023.txt">Table of n, a(n) for n = 0..10000</a>
%F A398023 a(n) >= A000005(n).
%F A398023 a(p) = 2 for prime p.
%e A398023 a(4) = 5: the qualifying compositions of 4 are (4), (1,3), (3,1), (2,2), (1,1,1,1); for example (1,3) has partial sums 1, 4, divisible by 1 and 2.
%e A398023 a(6) = 11: the qualifying compositions are: (6), (1,5), (2,4), (3,3), (4,2), (5,1), (1,3,2), (2,2,2), (3,1,2), (1,1,4), (1,1,1,1,1,1).
%o A398023 (Python)
%o A398023 from functools import lru_cache
%o A398023 def a(n):
%o A398023     if n == 0: return 1
%o A398023     @lru_cache(None)
%o A398023     def g(s, i):
%o A398023         if s == n: return 1
%o A398023         return sum(g(s+p, i+1) for p in range(1, n-s+1) if (s+p)%(i+1) == 0)
%o A398023     return g(0, 0)
%o A398023 (PARI)
%o A398023 step(u,d) = { my(v=vector(#u), s=0); for(i=1, #u, if((i-1)%d==0, v[i]=s); s+=u[i]); v }
%o A398023 seq(n)={my(v=vector(n+1), r=v, d=0); v[1]=1; while(v, r+=v; d++; v=step(v,d)); r} \\ _Andrew Howroyd_, Jul 17 2026
%Y A398023 Cf. A000005, A011782.
