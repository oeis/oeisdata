%N A398091 G.f.: exp(Sum_{k>=1} binomial(5*k,k)^2 * x^k/k).
%H A398091 Vaclav Kotesovec, <a href="/A398091/b398091.txt">Table of n, a(n) for n = 0..460</a>
%F A398091 a(n) ~ 5*exp(65536*HypergeometricPFQ[{1, 1, 6/5, 6/5, 7/5, 7/5, 8/5, 8/5, 9/5, 9/5}, {5/4, 5/4, 3/2, 3/2, 7/4, 7/4, 2, 2, 2}, 1]/390625) * (9765625/65536)^n / (8*Pi*n^2).
%t A398091 nmax = 20; Table[SeriesCoefficient[Exp[Sum[Binomial[5*k, k]^2*x^k/k, {k, 1, n}]], {x, 0, n}], {n, 0, nmax}]
