%I A398169 #11 Jul 23 2026 22:59:55
%S A398169 1,2,5,6,7,10,13,14,21,22,23,26,29,30,31,33,34,37,38,39,41,42,46,53,
%T A398169 55,57,58,61,65,66,69,70,73,77,78,82,85,86,87,93,94,95,101,102,103,
%U A398169 105,106,109,110,113,114,118,119,122,127,129,130,133,134,137,138,141,142,145
%N A398169 Squarefree numbers k such that k+1 is an exponentially odd number.
%C A398169 Terms k in A005117 such that k+1 is a term in A268335.
%C A398169 The asymptotic density of this sequence is d = Product_{p prime} (1 - 1/p^2 - 1/(p*(p+1))) = 0.394391775736286326344... . The number of terms not exceeding x is d * x + O(x^(2/3+eps)), where eps > 0 (Srichan et al., 2026, a consequence of Theorem 1.1).
%H A398169 Amiram Eldar, <a href="/A398169/b398169.txt">Table of n, a(n) for n = 1..10000</a>
%H A398169 Teerapat Srichan, Nithi Rungtanapirom, and Saeree Wananiyakul, <a href="https://doi.org/10.1051/ita/2026022">On the distribution of consecutive M-free integers</a>, RAIRO - Theoretical Informatics and Applications, Vol. 60 (2026), Article 22.
%t A398169 expOddQ[k_] := AllTrue[FactorInteger[k][[;;, 2]], OddQ];
%t A398169 Select[Range[150], SquareFreeQ[#] && expOddQ[#+1] &]
%o A398169 (PARI) isexpodd(k) = #select(x -> !(x % 2), factor(k)[,2]) == 0;
%o A398169 isok(k) = issquarefree(k) && isexpodd(k+1);
%Y A398169 Subsequence of A005117 and A367695.
%Y A398169 A007674 is a subsequence.
%Y A398169 Cf. A268335.
%Y A398169 Similar sequences: A340152, A372690, A391396, A398161, A398162, A398163, A398164, A398165, A398166, A398167, A398168, A398170.
