%U A398042 293207573568,1172830294272,4691321194560,18765284778240,75061139112960,300244556521728,1200978226086912
%N A398042 G.f. A(x) satisfies A(x) = A(x^3) / (1-4*x), with A(0) = 1.
%F A398042 G.f.: Product_{k>=0} 1/(1 - 4*x^(3^k)).
%F A398042 G.f.: 1 + 4 * Sum_{j>=0} x^(3^j) / Product_{k=0..j} (1 - 4*x^(3^k)).
%F A398042 a(0) = 1; for n >= 1, a(n) = 4*a(n-1) + a(n/3) if 3|n, and a(n) = 4*a(n-1) otherwise.
%F A398042 a(n) = Sum_{k=0..floor(n/3)} 4^(n-3*k) * a(k) for n >= 1.
%o A398042 (PARI) my(N=30, x='x+O('x^N)); Vec(1/prod(k=0, logint(N, 3), 1-4*x^3^k))
%Y A398042 Cf. A062051, A374626, A398041.
%K A398042 nonn,new
