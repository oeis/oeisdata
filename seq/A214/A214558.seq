%I A214558 #24 Jul 22 2026 22:31:04
%S A214558 864197532,886644219977553312,87765443219997765543222,
%T A214558 888666444221999777555333112,88776654443221999977765554332212,
%U A214558 888866664444222199997777555533331112,8777765544433221999997776655544322222,88877666544443222199999777765555433322112
%N A214558 Fixed points of the Kaprekar map A151949 of the form 8{p+1}7{2*q}6{p+1}5{q}4{p+q+1}3{q}2{p+q}19{p+2*q+1}7{p+q+1}6{q}5{p+q+1}4{q}3{p+1}2{2*q}1{p}2, p, q >= 0, where d{n} is digit d repeated n times.
%C A214558 The size of terms produced by the expression for given p and q is determined first by their length 9*p + 14*q + 9, then (for equal length) by increasing p-value. Using binary search and "floor sum" to count the exact number of pairs (p,q) giving terms of size < 10^L, one can determine the n-th term in O(log n) at worst, practically in O(1). - _M. F. Hasler_, Jul 17 2026
%H A214558 Syed Iddi Hasan, <a href="/A214558/b214558.txt">Table of n, a(n) for n = 0..92</a>
%e A214558 a(2) = 886644219977553312 is a fixed point of the map A151949 and corresponds to the given expression with p = 1, q = 0.
%o A214558 (Python)
%o A214558 def A214558(n=0, p=0, q=0): # p>0 here is p+1 in NAME
%o A214558     "Return a(n) if n is given, term(p,q) if p>0 is given, else a generator."
%o A214558     if p: return int('8'*p+'77'*q+'6'*p+'5'*q+'4'*(p+q)+'3'*q+'2'*(p-1+q)+'1'+
%o A214558         '9'*(p+2*q)+'7'*(p+q)+'6'*q+'5'*(p+q)+'4'*q+'3'*p+'22'*q+'1'*(p-1)+'2')
%o A214558     if not hasattr(A:=A214558, 'L'): A.L = 9; A.terms = [] # list of terms
%o A214558     if not n: return(A(n)for n in range(1<<63))# generator of the sequence
%o A214558     while n > len(A.terms): # extend list
%o A214558         p = 11*A.L%14 if A.L%14 else 14; q = (A.L - 9*p)//14
%o A214558         while q >= 0: A.terms += [A(p=p, q=q)]; p += 14; q -= 9
%o A214558         A.L += 1
%o A214558     return A.terms[n-1] # _M. F. Hasler_, Jul 17 2026
%Y A214558 Cf. A151949 (Kaprekar map n' - n": (digits in decreasing order) - (digits in increasing order)).
%Y A214558 Subsequence of A099009 (all fixed points of A151949).
%Y A214558 Cf. A214555, A214556, A214557, A214559 (fixed points following other patterns).
%K A214558 nonn,base,changed
%O A214558 1,1
%A A214558 _Syed Iddi Hasan_, Jul 20 2012
%E A214558 Edited to use standard POSIX regex notation in name, offset 1, example reworded, crossrefs completed by _M. F. Hasler_, Jul 17 2026
