%I A214557 #32 Jul 22 2026 23:49:17
%S A214557 864197532,86431976532,8643319766532,864333197666532,
%T A214557 86433331976666532,886644219977553312,8643333319766666532,
%U A214557 88664432199776553312,864333333197666666532,8866443321997766553312,86433333331976666666532,886644333219977666553312
%N A214557 Fixed points of the Kaprekar map A151949, of the form 8{p+1}6{p+1}4{p+1}3{q}2{p}19{p+1}7{p+1}6{q}5{p+1}3{p+1}1{p}2, where d{n} is digit d repeated n times, p, q >= 0.
%C A214557 Since p occurs 9 times and q occurs 2 times in the expression, the terms can be ordered by increasing length 9 + 9*p + 2*q first, then by increasing p, cf. example. - _M. F. Hasler_, Jul 17 2026
%H A214557 Syed Iddi Hasan, <a href="/A214557/b214557.txt">Table of n, a(n) for n = 0..599</a>
%e A214557 a(2) = 86431976532 is a fixed point of the map, obtained from the given expression for p=0, q=1.
%e A214557 a(14) = 864333333333197666666666532 = expr(p = 0, q = 9) and a(15) = 888666444221999777555333112 = expr(p = 2, q = 0) have the same length = 9*(p+1) + 2*q = 27, but the larger p yields a larger number. - _M. F. Hasler_, Jul 17 2026
%o A214557 (PARI) A214557_row(n, p=0)={if(p, eval(Str(8*p=10^p\9,6*p,4*p,if(n, (n=10^n\3*2)/2, n=""), if(p>1, p\5, ""), 1, 9*p, 7*p, n, 5*p, 3*p, if(p>1, p\10, ""), 2)), [A214557_row((n-9*p)/2,p) | p<-[1..n\9], n%2==p%2])} \\ gives the list of terms of length n; if p > 0 is given, returns the term obtained for parameter p-1 and q = n.
%o A214557 concat(apply(A214557_row,[1..24])) \\ gives DATA. - _M. F. Hasler_, Jul 17 2026
%o A214557 (Python)
%o A214557 def A214557(n=None, p=0, q=0, L=0):# NB: p>0 here is p+1 of the seq.
%o A214557   "Give n, or p>0 and q, or length L for a list of all terms with length L."
%o A214557   if p: return int('8'*p+'6'*p+'4'*p+'3'*q+'2'*(p-1)+'1'
%o A214557                    +'9'*p+'7'*p+'6'*q+'5'*p+'3'*p+'1'*(p-1)+'2')
%o A214557   if L: return [A214557(p=p, q=(L-9*p)//2) for p in range(1,L//9+1) if L-p &1==0]
%o A214557   if not hasattr(A:=A214557, 'L'): A.L = 9; A.terms = []
%o A214557   while n>len(A.terms): A.terms += A214557(L=A.L); A.L += 1
%o A214557   return A.terms[n-1] # _M. F. Hasler_, Jul 17 2026
%Y A214557 Cf. A151949 (Kaprekar map n'-n"), A099009 (all fixed points thereof).
%Y A214557 Cf. A214555, A214556, A214558, A214559 (fixed points following other patterns).
%K A214557 nonn,base,changed
%O A214557 1,1
