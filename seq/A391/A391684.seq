%T A391684 2,3,2,3,3,3,2,6,2,3,3,3,2,3,2,3,3,3,2,3,3,4,3,3,2,6,2,3,2,2,2,5,2,3,
%U A391684 3,4,2,4,2,3,3,3,2,5,2,3,2,3,2,5,2,3,3,3,2,5,3,3,3,3,3,3,2,3,2,3
%N A391684 Number of divisors d of n which also divide (n/d)^2 - 1.
%C A391684 From _Robert Israel_, Mar 29 2026: (Start)
%C A391684 a(n) >= 2 for n > 1, since d = 1 and d = n always work.
%C A391684 a(n) = 2 if n is a prime power (A246655). (End)
%H A391684 Robert Israel, <a href="/A391684/b391684.txt">Table of n, a(n) for n = 1..10000</a>
%e A391684 a(4) = 2 because (4/d)^2 - 1 == 0 (mod d) for d = 1 (or 4) of n = 4, but d = 2 is a nondivisor of 3 = (4/2)^2 - 1.
%p A391684 f:= proc(n)
%p A391684   nops(select(d -> (n/d)^2-1 mod d = 0, NumberTheory:-Divisors(n)))
%p A391684 end proc:
%p A391684 map(f, [$1..100]); # _Robert Israel_, Mar 29 2026
%t A391684 a[n_] := DivisorSum[n, 1 &, Divisible[(n/#)^2 - 1, #] &]; Array[a, 100] (* _Amiram Eldar_, Mar 29 2026 *)
%o A391684 (Magma) [#[d: d in Divisors(n) | ((n div d)^2 - 1) mod d eq 0]: n in [1..100]];
%o A391684 (PARI) a(n) = sumdiv(n, d, (((n/d)^2-1) % d) == 0); \\ _Michel Marcus_, Apr 06 2026
%Y A391684 Cf. A000005, A034444, A116974, A163671, A246655, A394362.
%K A391684 nonn,new
%O A391684 1,2
