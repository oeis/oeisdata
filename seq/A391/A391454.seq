%T A391454 4839738501,40910211110,348648196840,2992390437879,25842906965328,
%U A391454 224409469141039,1958188706568797,17161676257412695,150996915954255514,1333269446351120464
%N A391454 Expansion of g^2/(1 + x^3*g), where g = 1+x*g^4 is the g.f. of A002293.
%H A391454 Robert Israel, <a href="/A391454/b391454.txt">Table of n, a(n) for n = 0..1023</a>
%H A391454 Robert Israel, <a href="/A391454/a391454.txt">Recurrence of order 37</a>
%F A391454 a(n) = Sum_{k=0..floor(n/3)} (-1)^k * (k+2) * binomial(4*n-11*k+2,n-3*k)/(4*n-11*k+2).
%F A391454 D-finite with recurrence of order 37 (see link). - _Robert Israel_, Jul 16 2026
%p A391454 with(gfun):
%p A391454 e1:= -g + 1 + x*g^4:
%p A391454 e2:= z*(1+x^3*g)-g^2:
%p A391454 e3:= resultant(e1,e2,g):
%p A391454 de:= algeqtodiffeq(e3,z(x)):
%p A391454 rec:= diffeqtorec(de,z(x),a(n)):
%p A391454 f:= rectoproc(rec,a(n),remember):
%p A391454 map(f, [$0..50]); # _Robert Israel_, Jul 16 2026
%o A391454 (PARI) a(n) = sum(k=0, n\3, (-1)^k*(k+2)*binomial(4*n-11*k+2, n-3*k)/(4*n-11*k+2));
%Y A391454 Cf. A002293, A389653.
%K A391454 nonn,changed
%O A391454 0,2
%A A391454 _Seiichi Manyama_, Dec 10 2025
