%T A391126 1035202711,6295845125,38549631470,237446950848,1470270105474,
%U A391126 9146689133831,57142245734278,358342549067332,2254931066760716,14234056382288269,90109044310947462
%N A391126 Expansion of g^2/(1 - x^2*g^3), where g = 1+x*g^3 is the g.f. of A001764.
%H A391126 Vincenzo Librandi, <a href="/A391126/b391126.txt">Table of n, a(n) for n = 0..1000</a>
%F A391126 a(n) = Sum_{k=0..floor(n/2)} (3*k+2) * binomial(3*n-3*k+2,n-2*k)/(3*n-3*k+2).
%F A391126 D-finite with recurrence: -6*(3*n + 7)*(3*n + 5)*a(n) + (845*n^2 + 6389*n + 11010)*a(n + 1) + (3251*n^2 + 24281*n + 44484)*a(n + 2) + 2*(1208*n^2 + 8759*n + 15153)*a(n + 3) + 3*(27*n^2 - 2051*n - 10932)*a(n + 4) - 2*(281*n^2 + 3779*n + 12108)*a(n + 5) - 18*(23*n^2 + 281*n + 846)*a(n + 6) + 36*(n + 8)*(2*n + 13)*a(n + 7) = 0. - _Robert Israel_, Jun 11 2026
%p A391126 f:= gfun:-rectoproc({-6*(3*n + 7)*(3*n + 5)*a(n) + (845*n^2 + 6389*n + 11010)*a(n + 1) + (3251*n^2 + 24281*n + 44484)*a(n + 2) + 2*(1208*n^2 + 8759*n + 15153)*a(n + 3) + 3*(27*n^2 - 2051*n - 10932)*a(n + 4) - 2*(281*n^2 + 3779*n + 12108)*a(n + 5) - 18*(23*n^2 + 281*n + 846)*a(n + 6) + 36*(n + 8)*(2*n + 13)*a(n + 7), a(0) = 1, a(1) = 2, a(2) = 8, a(3) = 35, a(4) = 169, a(5) = 866, a(6) = 4629}, a(n), remember):
%p A391126 map(f, [$0..30]); # _Robert Israel_, Jun 11 2026
%t A391126 Table[Sum[ (3*k+2)*Binomial[3*n -3*k+2,n-2*k]/(3*n-3*k+2),{k,0,Floor[n/2]}],{n,0,26}] (* _Vincenzo Librandi_, Nov 30 2025 *)
%o A391126 (PARI) a(n) = sum(k=0, n\2, (3*k+2)*binomial(3*n-3*k+2, n-2*k)/(3*n-3*k+2));
%o A391126 (Magma) [&+[(3*k+2)*Binomial(3*n-3*k+2, n-2*k)/(3*n-3*k+2): k in [0..Floor(n/2)]] : n in [0..40] ]; // _Vincenzo Librandi_, Nov 30 2025
