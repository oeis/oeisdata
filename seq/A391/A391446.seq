%U A391446 123,125,128,132,135,138,140,144,146,148,150,152,154,156,158,160
%N A391446 Numbers k such that gcd(A381466(k-1),k) > 1.
%C A391446 a(n) is the index of the n-th term in the lowest band of the graph of A381466.
%C A391446 a(n) is the n-th division step of A381466.
%H A391446 Sam Chapman, <a href="/A391446/b391446.txt">Table of n, a(n) for n = 0..9999</a>
%e A391446 4 is a term because A381466(3) = 10, and (10,4) = 2 > 1.
%e A391446 8 is a term because A381466(7) = 20, and (20,8) = 4 > 1.
%t A391446 s={4};k={}; Do[G=GCD[s[[-1]], n]; AppendTo[s, If[G==1, s[[-1]]+n, n/G]];If[G>1,AppendTo[k,n]], {n, 160}]; k (* _James C. McMahon_, Apr 01 2026 *)
