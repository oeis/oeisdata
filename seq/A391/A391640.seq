%I A391640 #25 Mar 19 2026 09:22:28
%S A391640 1,1,27,7560,20096706,469234550400,91647719244727380,
%T A391640 144882476551619079125580,1810530857631422460202014819060,
%U A391640 175700644017711682078282449152774420640,130588994626958481587169008526902476575988659000,735177542920409283519725843348729064179058776531183808000
%N A391640 a(n) is the hafnian of the 2n X 2n Hankel matrix whose generic element is given by A000045(i+j-1) with i,j = 1, ..., n.
%C A391640 The Hankel transform of A000045 has the following polynomial as g.f. 1 + x + x^2: the matrices are singular for n > 2.
%H A391640 Wikipedia, <a href="https://en.wikipedia.org/wiki/Hafnian">Hafnian</a>.
%H A391640 Wikipedia, <a href="https://en.wikipedia.org/wiki/Hankel_matrix">Hankel matrix</a>.
%H A391640 Wikipedia, <a href="https://en.wikipedia.org/wiki/Symmetric_matrix">Symmetric matrix</a>.
%e A391640 a(2) = 27 because the hafnian of
%e A391640   [1, 1, 2,  3]
%e A391640   [1, 2, 3,  5]
%e A391640   [2, 3, 5,  8]
%e A391640   [3, 5, 8, 13]
%e A391640 equals M_{1,2}*M_{3,4} + M_{1,3}*M_{2,4} + M_{1,4}*M_{2,3} = 27.
%t A391640 M[i_, j_, n_]:=Part[Part[Table[Fibonacci[r+c-1], {r, n}, {c, n}], i], j]; a[n_]:=Sum[Product[M[Part[PermutationList[s, 2n], 2i-1], Part[PermutationList[s, 2n], 2i], 2n], {i, n}], {s, SymmetricGroup[2n]//GroupElements}]/(n!*2^n); Array[a, 6, 0]
%o A391640 (PARI) tm(n) = matrix(n, n, i, j, fibonacci(i+j-1));
%o A391640 a(n) = my(m = tm(2*n), s=0); forperm([1..2*n], p, s += prod(j=1, n, m[p[2*j-1], p[2*j]]); ); s/(n!*2^n); \\ _Michel Marcus_, Mar 15 2026
