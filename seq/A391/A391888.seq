%S A391888 5,7,18,60,248,1250,7512,52598,420800,3787218,37872200,416594222,
%T A391888 4999130688,64988698970,909841785608,13647626784150,218362028546432,
%U A391888 3712154485289378,66818780735208840,1269556833968967998,25391136679379360000,533213870266966560042,11730705145873264320968
%N A391888 a(0)=5 and a(n) = n*(a(n-1) + 2) for n > 0.
%D A391888 Miklos Bona, Introduction to Enumerative and Analytic Combinatorics, CRC Press, 2025, pp. 128-130.
%F A391888 E.g.f.: (5 + 2*x*exp(x))/(1 - x).
%F A391888 a(n) = 5*n! + 2*Sum_{i=0..n-1} n!/i!.
%F A391888 a(n) ~ (2*e + 5)*sqrt(2*Pi)*(12*n + 1)*n^(n+1/2)*exp(-n)/(12*n).
%p A391888 a:= proc(n) option remember;
%p A391888       `if`(n=0, 5, n*(a(n-1)+2))
%p A391888     end:
%p A391888 seq(a(n), n=0..23);  # _Alois P. Heinz_, Mar 24 2026
%t A391888 a[n_]:=5n!+2Sum[n!/i!,{i,0,n-1}]; Array[a,23,0]
%Y A391888 Cf. A000142, A007526, A033540, A052648, A165792.
%K A391888 nonn,easy,new
%O A391888 0,1
