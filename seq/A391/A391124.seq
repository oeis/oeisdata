%N A391124 Expansion of g^2/(1 - x^3*g^2), where g = 1+x*g^3 is the g.f. of A001764.
%H A391124 Vincenzo Librandi, <a href="/A391124/b391124.txt">Table of n, a(n) for n = 0..1000</a>
%F A391124 a(n) = Sum_{k=0..floor(n/3)} (2*k+2) * binomial(3*n-7*k+2,n-3*k)/(3*n-7*k+2).
%F A391124 D-finite with recurrence: -18*(3*n + 17)*(3*n + 16)*a(n) + 12*(n + 7)*(2*n + 11)*a(n + 1) + 189*(3*n + 29)*(3*n + 22)*a(n + 2) - 12*(21*n^2 + 510*n + 2695)*a(n + 3) + 108*(17 + 2*n)*a(n + 4) - 3*(693*n^2 + 11295*n + 46498)*a(n + 5) + 2*(235*n^2 + 4361*n + 20298)*a(n + 6) + 60*(59*n^2 + 985*n + 4055)*a(n + 7) - 42*(19*n^2 + 350*n + 1578)*a(n + 8) - (1661*n^2 + 28105*n + 116574)*a(n + 9) + 6*(51*n^2 + 849*n + 3166)*a(n + 10) - 4*(2*n^2 + 19*n - 66)*a(n + 11) + 6*(3*n + 40)*(3*n + 38)*a(n + 12) - 4*(n + 14)*(2*n + 27)*a(n + 13) = 0. - _Robert Israel_, Jun 11 2026
%p A391124 f:= gfun:-rectoproc({-18*(3*n + 17)*(3*n + 16)*a(n) + 12*(n + 7)*(2*n + 11)*a(n + 1) + 189*(3*n + 29)*(3*n + 22)*a(n + 2) - 12*(21*n^2 + 510*n + 2695)*a(n + 3) + 108*(17 + 2*n)*a(n + 4) - 3*(693*n^2 + 11295*n + 46498)*a(n + 5) + 2*(235*n^2 + 4361*n + 20298)*a(n + 6) + 60*(59*n^2 + 985*n + 4055)*a(n + 7) - 42*(19*n^2 + 350*n + 1578)*a(n + 8) - (1661*n^2 + 28105*n + 116574)*a(n + 9) + 6*(51*n^2 + 849*n + 3166)*a(n + 10) - 4*(2*n^2 + 19*n - 66)*a(n + 11) + 6*(3*n + 40)*(3*n + 38)*a(n + 12) - 4*(n + 14)*(2*n + 27)*a(n + 13), a(0) = 1, a(1) = 2, a(2) = 7, a(3) = 31, a(4) = 147, a(5) = 746, a(6) = 3965, a(7) = 21779, a(8) = 122656, a(9) = 704439, a(10) = 4109955, a(11) = 24291361, a(12) = 145133962}, a(n), remember):
%p A391124 map(f, [$0..30]); # _Robert Israel_, Jun 11 2026
%t A391124 Table[Sum[ (2*k+2)*Binomial[3*n -7*k+2,n-3*k]/(3*n-7*k+2),{k,0,Floor[n/3]}],{n,0,26}] (* _Vincenzo Librandi_, Nov 30 2025 *)
%o A391124 (PARI) a(n) = sum(k=0, n\3, (2*k+2)*binomial(3*n-7*k+2, n-3*k)/(3*n-7*k+2));
%o A391124 (Magma) [&+[(2*k+2)*Binomial(3*n-7*k+2, n-3*k)/(3*n-7*k+2): k in [0..Floor(n/3)]] : n in [0..40] ]; // _Vincenzo Librandi_, Nov 30 2025
