%T A391206 152333571303,4804267653047,165552509055571,6189393910521307,
%U A391206 249534333735302649,10792240521968254999,498441903977024442881,24484990389453763815201,1274755126330942972043679
%N A391206 E.g.f. A(x) satisfies A(x) = 1/(1 - A(x) * Sum_{i>0} x^i/(i! + A(x)*x^i)).
%C A391206 a(n) is the number of ordered rooted trees such that the non-root nodes are each labeled with a subset of [n], no two adjacent sibling nodes are labeled with subsets of the same size, and the labels of a given tree form a set partition of [n].
%F A391206 E.g.f. satisfies A(x) = 1/(1 + Sum_{k>=1} Sum_{m>=1} ( -A(x)*x^k/k! )^m ). - _Paul D. Hanna_, Mar 14 2026
%e A391206 The tree below has node labels that partition [7] and no adjacent sibling nodes have the same weight so this is counted under a(7) = 455463.
%e A391206         ___o___
%e A391206        /   |   \
%e A391206      {6} {2,3} {5}
%e A391206          /   \
%e A391206       {4,7}  {1}
%e A391206 a(2) = 3 counts:
%e A391206     o        o         o
%e A391206     |        |         |
%e A391206   {1,2}     {1}       {2}
%e A391206              |         |
%e A391206             {2}       {1}
%e A391206 E.g.f.: A(x) = 1 + x + 3*x^2/2! + 19*x^3/3! + 167*x^4/4! + 1881*x^5/5! + 26655*x^6/6! + 455463*x^7/7! + 9076919*x^8/8! + ...
%o A391206 (PARI) {a(n) = my(A=1,x='x+x*O('x^n)); for(i=1, n,
%o A391206 A = 1/(1 - sum(k=1, n, (A*x^k/k!) / (1 + (A*x^k/k!)) ) )); EGF=A; n!*polcoef(A, n)}
%o A391206 {upto(n) = a(n); Vec(serlaplace(EGF))}
%o A391206 upto(30) \\ _Paul D. Hanna_, Mar 14 2026
