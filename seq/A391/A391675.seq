%I A391675 #52 Jul 21 2026 01:02:17
%S A391675 1,-1,3,15,40,12,24,84,60,120,180,360,420,1560,1440,840,1680,3360,
%T A391675 4620,10920,2520,5040,7560,15120,18480,36960,57120,42840,27720,115920,
%U A391675 85680,55440,83160,65520,131040,332640,196560,277200,415800,360360,526680,1404480,831600,942480,1053360,1113840
%N A391675 a(n) is the smallest k for which A243865(k) = n, or -1 if no such k exists.
%C A391675 a(1) = -1 (by definition).
%H A391675 Robert Israel, <a href="/A391675/b391675.txt">Table of n, a(n) for n = 0..105</a>
%p A391675 N:= 50: # for a(0)..a(N)
%p A391675 tds:= proc(n) nops(select(d -> (d >= 3 and n mod (d-2) = 0) or n mod (d+2) = 0, NumberTheory:-Divisors(n))) end proc:
%p A391675 V:= Array(0..N): V[1]:= -1: count:= 1:
%p A391675 for i from 1 while count < N+1 do
%p A391675   v:= tds(i);
%p A391675   if v <= N and V[v] = 0 then V[v]:= i; count:= count+1 fi;
%p A391675 od:
%p A391675 convert(V,list); # _Robert Israel_, Jul 20 2026
%o A391675 (PARI) nbtd(n) = sumdiv(n, d, ((d>2) && !(n % (d-2))) || !(n % (d+2))); \\ A243865
%o A391675 a(n) = if (n==1, return(-1)); my(m=1); while (nbtd(m) != n, m++); m; \\ _Michel Marcus_, Feb 20 2026
%Y A391675 Cf. A243865, A243917.
%K A391675 sign,changed
%O A391675 0,3
%A A391675 _Juri-Stepan Gerasimov_, Feb 19 2026
%E A391675 More terms from _Michel Marcus_, Feb 20 2026
