%N A391152 a(0) = 1; a(n) = n * Sum_{k=1..n} binomial(n,k-1) * a(n-k).
%F A391152 G.f. A(x) satisfies: A(x) = 1 + x * d/dx ( x * A(x/(1 - x)) / (1 - x)^2 ).
%t A391152 a[0] = 1; a[n_] := a[n] = n Sum[Binomial[n, k - 1] a[n - k], {k, 1, n}]; Table[a[n], {n, 0, 20}]
%t A391152 nmax = 20; A[_] = 0; Do[A[x_] = 1 + x D[x A[x/(1 - x)]/(1 - x)^2, x] + O[x]^(nmax + 1) // Normal, nmax + 1]; CoefficientList[A[x], x]
