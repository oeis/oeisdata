%N A391122 Expansion of g^2/(1 - x^2*g), where g = 1+x*g^3 is the g.f. of A001764.
%H A391122 Vincenzo Librandi, <a href="/A391122/b391122.txt">Table of n, a(n) for n = 0..1000</a>
%F A391122 a(n) = Sum_{k=0..floor(n/2)} (k+2) * binomial(3*n-5*k+2,n-2*k)/(3*n-5*k+2).
%F A391122 D-finite with recurrence: -9*(3*n + 8)*(3*n + 7)*a(n) + 6*(2*n + 7)*(n + 3)*a(n + 1) + 27*(3*n + 14)*(3*n + 13)*a(n + 2) - 18*(137*n^2 + 1911*n + 6295)*a(n + 3) + 9*(55*n^2 + 983*n + 4042)*a(n + 4) + (3301*n^2 + 52541*n + 205854)*a(n + 5) - 3*(317*n^2 + 5791*n + 26172)*a(n + 6) - 4*(172*n^2 + 3713*n + 19014)*a(n + 7) - 2*(1078*n^2 + 13859*n + 38421)*a(n + 8) + 3*(193*n^2 + 2879*n + 9360)*a(n + 9) + 6*(156*n^2 + 3141*n + 15781)*a(n + 10) - 18*(17*n^2 + 379*n + 2103)*a(n + 11) + 6*(13*n^2 + 332*n + 2118)*a(n + 12) - 4*(n + 14)*(2*n + 27)*a(n + 13) = 0. - _Robert Israel_, Jun 11 2026
%p A391122 f:= gfun:-rectoproc({-9*(3*n + 8)*(3*n + 7)*a(n) + 6*(2*n + 7)*(n + 3)*a(n + 1) + 27*(3*n + 14)*(3*n + 13)*a(n + 2) - 18*(137*n^2 + 1911*n + 6295)*a(n + 3) + 9*(55*n^2 + 983*n + 4042)*a(n + 4) + (3301*n^2 + 52541*n + 205854)*a(n + 5) - 3*(317*n^2 + 5791*n + 26172)*a(n + 6) - 4*(172*n^2 + 3713*n + 19014)*a(n + 7) - 2*(1078*n^2 + 13859*n + 38421)*a(n + 8) + 3*(193*n^2 + 2879*n + 9360)*a(n + 9) + 6*(156*n^2 + 3141*n + 15781)*a(n + 10) - 18*(17*n^2 + 379*n + 2103)*a(n + 11) + 6*(13*n^2 + 332*n + 2118)*a(n + 12) - 4*(n + 14)*(2*n + 27)*a(n + 13), a(0) = 1, a(1) = 2, a(2) = 8, a(3) = 33, a(4) = 156, a(5) = 787, a(6) = 4168, a(7) = 22839, a(8) = 128408, a(9) = 736537, a(10) = 4292990, a(11) = 25353172, a(12) = 151380355}, a(n), remember):
%p A391122 map(f, [$0..30]); # _Robert Israel_, Jun 11 2026
%t A391122 Table[Sum[ (k+2)*Binomial[3*n -5*k+2,n-2*k]/(3*n-5*k+2),{k,0,Floor[n/2]}],{n,0,26}] (* _Vincenzo Librandi_, Nov 30 2025 *)
%o A391122 (PARI) a(n) = sum(k=0, n\2, (k+2)*binomial(3*n-5*k+2, n-2*k)/(3*n-5*k+2));
%o A391122 (Magma) [&+[(k+2)*Binomial(3*n-5*k+2, n-2*k)/(3*n-5*k+2): k in [0..Floor(n/2)]] : n in [0..40] ]; // _Vincenzo Librandi_, Nov 30 2025
