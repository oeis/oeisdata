%S A391451 2,3,4,7,8,14,16,20,21,24,26,31,33,34,35,36,38,39,40,44,45,48,50,51,
%T A391451 52,54,55,56,57,62,63,64,65,68,69,72,74,75,76,77,80,85,86,87,88,91,92,
%U A391451 93,94,95,96,98,99,100,104,106,108,111,112,115,116,117,118,119,122,123,124,127
%N A391451 Numbers k such that omega(k) = omega(d + k/d) for some divisor d of k and omega = A001221.
%H A391451 Robert Israel, <a href="/A391451/b391451.txt">Table of n, a(n) for n = 1..10000</a>
%e A391451 8 is a term because omega(8) = omega(1 + 8/1) = 1.
%p A391451 filter:= proc(k) local t,d;
%p A391451   t:= NumberTheory:-Omega(k,distinct);
%p A391451   ormap(d -> d^2 <= k and NumberTheory:-Omega(d+k/d,distinct)=t, NumberTheory:-Divisors(k))
%p A391451 end proc:
%p A391451 select(filter, [$1..200]); # _Robert Israel_, May 14 2026
%t A391451 q[k_] := AnyTrue[Divisors[k], PrimeNu[# + k/#] == PrimeNu[k] &]; Select[Range[128], q] (* _Amiram Eldar_, Dec 14 2025 *)
%o A391451 (PARI) is_a391451(n)=my(o=omega(n)); fordiv(n, d, if(omega(d+n\d)==o, return(1))); 0 \\ _Hugo Pfoertner_, Dec 14 2025
%Y A391451 Cf. A000005, A000668, A001221, A343733.
%K A391451 nonn,changed
%O A391451 1,1
