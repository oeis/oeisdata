%S A391105 0,1,13,136,1325,12501,116032,1067760,9782829,89456455,817615513,
%T A391105 7475802412,68416856768,626891134156,5751871734720,52849221767136,
%U A391105 486272088165933,4480380512338923,41335163417004835,381823967694522700,3531124297706368825,32691615281688295845
%N A391105 a(n) = binomial(4*n,n) - binomial(3*n,n).
%C A391105 It appears that a(n) mod n^3 == 1 iff n is an odd prime (tested to 500000).
%C A391105 In general, it appears that C((k+1)*n,n)-C(k*n,n) == 1 (mod n^k) if n is prime.
%C A391105 For k = 1, there are 60 pseudoprimes < 50000 with only two of them, 418 = 2*11*19 and 27173 = 29*937 not being a power of a prime. For k = 2, 49 is the only pseudoprime < 50000. For k = 3, 2 is the only pseudoprime < 50000.
%H A391105 Robert Israel, <a href="/A391105/b391105.txt">Table of n, a(n) for n = 0..1020</a>
%F A391105 a(n) = (1/n!)*((4*n)!/(3*n)! - (3*n)!/(2*n)!).
%F A391105 a(n) = Sum_{k=1..n} binomial(n,k)*binomial(3*n,n-k).
%F A391105 a(n) = (Product_{j=1..n} (3*n+j) - Product_{j=1..n} (2*n+j))/n!.
%F A391105 G.f.: hypergeom([1/4, 1/2, 3/4], [1/3, 2/3], 2^8*x/3^3) - 2*cos(arccos(1-27*x/2)/6)/sqrt(4 - 27*x). - _Stefano Spezia_, Nov 30 2025
%F A391105 D-finite with recurrence: 24*(4*n + 3)*(3*n + 2)*(2*n + 1)*(3*n + 1)*(4*n + 1)*(295*n^4 + 1770*n^3 + 3959*n^2 + 3912*n + 1440)*a(n) - (n + 1)*(517135*n^8 + 4137080*n^7 + 13890622*n^6 + 25424612*n^5 + 27575647*n^4 + 18030668*n^3 + 6893580*n^2 + 1395936*n + 112320)*a(n + 1) + 6*(295*n^4 + 590*n^3 + 419*n^2 + 124*n + 12)*(n + 1)*(2*n + 3)*(3*n + 4)*(3*n + 5)*(n + 2)*a(n + 2) = 0. - _Robert Israel_, May 20 2026
%p A391105 seq(binomial(4*n, n) - binomial(3*n, n), n=0..20);
%Y A391105 Cf. A030662, A006480.
%K A391105 nonn,easy,changed
%O A391105 0,3
