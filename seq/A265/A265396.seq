%I A265396 #11 May 05 2026 00:34:07
%S A265396 0,3,5,11,13,29,37,61,73,157,193,277,313,397,421,457,541,613,661,673,
%T A265396 733,757,877,997,1093,1153,1201,1213,1237,1321,1381,1453,1621,1657,
%U A265396 1753,1873,1933,1993,2017,2137,2341,2473,2557,2593,2797,2857,2917,3061,3217,3253,3313,3517,3733,4021,4057,4177,4261,4273,4357,4441
%N A265396 Numerator of A265395(n)/A265394(n), record values / record positions in A265388.
%C A265396 It seems that n=4 is the only case where A265395(n)/A265394(n) is not integral (as 33/6 = 11/2), thus for other n, a(n) actually seems to give the value of A265395(n)/A265394(n).
%H A265396 Chai Wah Wu, <a href="/A265396/b265396.txt">Table of n, a(n) for n = 1..10000</a> (terms 1..192 from Antti Karttunen)
%o A265396 (Scheme) (define (A265396 n) (numerator (/ (A265395 n) (A265394 n))))
%o A265396 (Python)
%o A265396 from math import prod, gcd
%o A265396 from itertools import count, islice
%o A265396 from sympy.ntheory.factor_ import digits
%o A265396 from sympy import primefactors
%o A265396 def A265396_gen(): # generator of terms
%o A265396     c = -1
%o A265396     for n in count(1):
%o A265396         m = prod((p if sum(digits(n<<1,p)[1:])==2 else 1) for p in primefactors(n*((n<<1)-1)) if p>2)<<(not(n&-n)^n) if n>1 else 0
%o A265396         if m>c:
%o A265396             yield m//gcd(m,n)
%o A265396             c = m
%o A265396 A265396_list = list(islice(A265396_gen(),20)) # _Chai Wah Wu_, May 04 2026
%Y A265396 Cf. A265388, A265394, A265395.
%Y A265396 For many terms coincides with A005383, A079147, A113733 and A256072.
%K A265396 nonn,changed
%O A265396 1,2
%A A265396 _Antti Karttunen_, Dec 11 2015
