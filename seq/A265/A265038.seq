%F A265038 G.f.: (1 +12*x +51*x^2 +130*x^3 +243*x^4 +350*x^5 +450*x^6 +418*x^7 +327*x^8 +182*x^9 +51*x^10 +16*x^11 -7*x^12 +8*x^13 +12*x^14) / ((1 -x)^4*(1 +x)*(1 +x^2)^2*(1 +x +x^2)^2). - _Colin Barker_, Dec 19 2015
%F A265038 From _Jianing Song_, May 22 2026: (Start)
%F A265038 a(n) = a(n-1) - a(n-2) + 3*a(n-3) - a(n-4) + a(n-5) - 2*a(n-6) - 2*a(n-7) + a(n-8) - a(n-9) + 3*a(n-10) - a(n-11) + a(n-12) - a(n-13) for n >= 15.
%F A265038 a(n) = (374*n^3 + 303*n^2 + c1*n + c0)/72 for n >= 2, where c1 = [204,204,120,312,204,12,312,312,12,204,312,120] and c0 = [-1368,-809,92,-585,-728,-745,-612,55,-664,-1449,28,119] for n == 0..11 (mod 12). (End)
%o A265038 (PARI) a(n) = if(n<=1, [1,13][n+1], my(c1=[204,204,120,312,204,12,312,312,12,204,312,120], c0 = [-1368,-809,92,-585,-728,-745,-612,55,-664,-1449,28,119]); (374*n^3 + 303*n^2 + c1[n%12+1]*n + c0[n%12+1])/72) \\ _Jianing Song_, May 22 2026
