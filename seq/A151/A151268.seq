%S A151268 1,1,3,7,23,69,241,815,2973,10765,40599,153519,594441,2315819,9159005,
%T A151268 36470431,146745519,594261517,2425275509,9954790549,41110526691,
%U A151268 170626390065,711716332495,2981638200405,12543716384153,52971343747061,224502013317731,954637799193723,4072108059395579
%N A151268 Number of walks within N^2 (the first quadrant of Z^2) starting at (0,0) and consisting of n steps taken from {(-1, 1), (-1, 0), (0, -1), (0, 1), (1, -1)}.
%C A151268 Apparently a duplicate of A148700. [From _R. J. Mathar_, Dec 13 2008]
%H A151268 Robert Israel, <a href="/A151268/b151268.txt">Table of n, a(n) for n = 0..500</a>
%H A151268 Alin Bostan and Manuel Kauers, <a href="https://arxiv.org/abs/0811.2899">Automatic Classification of Restricted Lattice Walks</a>, arXiv:0811.2899 [math.CO], 2008.
%H A151268 Mireille Bousquet-Mélou and Marni Mishna, <a href="https://arxiv.org/abs/0810.4387">Walks with small steps in the quarter plane</a>, arXiv:0810.4387 [math.CO], 2008.
%H A151268 Marni Mishna and Juan Pulido, <a href="https://arxiv.org/abs/2605.16688">On the small-step quarter plane lattice walks with a non D-finite univariate generating function</a>, arXiv:2605.16688 [math.CO], 2026. See p. 8 (Theorem 7, Table 4).
%p A151268 steps:= [[-1, 1], [-1, 0], [0, -1], [0, 1], [1, -1]]:
%p A151268 f:= proc(n, p) option remember; local t;
%p A151268   if n <= min(p) then return 5^n fi;
%p A151268   add(procname(n-1, t), t=remove(has, map(`+`, steps, p), -1));
%p A151268 end proc:
%p A151268 A:=map(f, [$0..100], [0, 0]); # _Robert Israel_, Jun 03 2026
%t A151268 aux[i_Integer, j_Integer, n_Integer] := Which[Min[i, j, n] < 0 || Max[i, j] > n, 0, n == 0, KroneckerDelta[i, j, n], True, aux[i, j, n] = aux[-1 + i, 1 + j, -1 + n] + aux[i, -1 + j, -1 + n] + aux[i, 1 + j, -1 + n] + aux[1 + i, -1 + j, -1 + n] + aux[1 + i, j, -1 + n]]; Table[Sum[aux[i, j, n], {i, 0, n}, {j, 0, n}], {n, 0, 25}]
%K A151268 nonn,walk,changed
%O A151268 0,3
%A A151268 _Manuel Kauers_, Nov 18 2008
