%I A151267 #13 Jun 04 2026 00:32:16
%S A151267 1,1,3,7,21,55,165,457,1371,3909,11727,33993,101979,298629,895887,
%T A151267 2640931,7922793,23460851,70382553,209078319,627234957,1867531435,
%U A151267 5602594305,16709292259,50127876777,149690954499,449072863497,1342297451651,4026892354953,12045410486339,36136231459017,108154061971965
%N A151267 Number of walks within N^2 (the first quadrant of Z^2) starting at (0,0) and consisting of n steps taken from {(-1, 1), (1, -1), (1, 1)}.
%H A151267 Robert Israel, <a href="/A151267/b151267.txt">Table of n, a(n) for n = 0..750</a>
%H A151267 A. Bostan and M. Kauers, 2008. Automatic Classification of Restricted Lattice Walks, <a href="https://arxiv.org/abs/0811.2899">ArXiv 0811.2899</a>.
%H A151267 M. Bousquet-Mélou and M. Mishna, 2008. Walks with small steps in the quarter plane, <a href="https://arxiv.org/abs/0810.4387">ArXiv 0810.4387</a>.
%p A151267 steps:= [[-1,1],[1,-1],[1,1]]:
%p A151267 f:= proc(n, p) option remember; local t;
%p A151267   if n <= min(p) then return 3^n fi;
%p A151267   add(procname(n-1, t), t=remove(has, map(`+`, steps, p), -1));
%p A151267 end proc:
%p A151267 A:=map(f, [$0..100], [0, 0]); # _Robert Israel_, Jun 03 2026
%t A151267 aux[i_Integer, j_Integer, n_Integer] := Which[Min[i, j, n] < 0 || Max[i, j] > n, 0, n == 0, KroneckerDelta[i, j, n], True, aux[i, j, n] = aux[-1 + i, -1 + j, -1 + n] + aux[-1 + i, 1 + j, -1 + n] + aux[1 + i, -1 + j, -1 + n]]; Table[Sum[aux[i, j, n], {i, 0, n}, {j, 0, n}], {n, 0, 25}]
%K A151267 nonn,walk,changed
%O A151267 0,3
%A A151267 _Manuel Kauers_, Nov 18 2008
