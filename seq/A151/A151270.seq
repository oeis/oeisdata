%I A151270 #15 Jun 03 2026 14:31:19
%S A151270 1,1,4,9,30,90,286,941,3072,10308,34814,118138,406368,1399630,4858636,
%T A151270 16948153,59302432,208587930,735602234,2602943312,9239044912,
%U A151270 32867768218,117244508016,419105764722,1501220073148,5388115272948,19371438711296,69764776854918,251641664047600,908984140277160,3288068461179108
%N A151270 Number of walks within N^2 (the first quadrant of Z^2) starting at (0,0) and consisting of n steps taken from {(-1, -1), (-1, 0), (0, -1), (1, 1)}.
%H A151270 Robert Israel, <a href="/A151270/b151270.txt">Table of n, a(n) for n = 0..500</a>
%H A151270 Alin Bostan and Manuel Kauers, <a href="https://arxiv.org/abs/0811.2899">Automatic Classification of Restricted Lattice Walks</a>, arXiv:0811.2899 [math.CO], 2008.
%H A151270 Mireille Bousquet-Mélou and Marni Mishna, <a href="https://arxiv.org/abs/0810.4387">Walks with small steps in the quarter plane</a>, arXiv:0810.4387 [math.CO], 2008.
%H A151270 Marni Mishna and Juan Pulido, <a href="https://arxiv.org/abs/2605.16688">On the small-step quarter plane lattice walks with a non D-finite univariate generating function</a>, arXiv:2605.16688 [math.CO], 2026. See p. 7 (Theorem 7, Table 4).
%p A151270 steps:= [[-1, -1], [-1, 0], [0, -1], [1, 1]]:
%p A151270 f:= proc(n, p) option remember; local t;
%p A151270   if n <= min(p) then return 4^n fi;
%p A151270   add(procname(n-1, t), t=remove(has, map(`+`, steps, p), -1));
%p A151270 end proc:
%p A151270 map(f, [$0..100], [0, 0]); # _Robert Israel_, Jun 03 2026
%t A151270 aux[i_Integer, j_Integer, n_Integer] := Which[Min[i, j, n] < 0 || Max[i, j] > n, 0, n == 0, KroneckerDelta[i, j, n], True, aux[i, j, n] = aux[-1 + i, -1 + j, -1 + n] + aux[i, 1 + j, -1 + n] + aux[1 + i, j, -1 + n] + aux[1 + i, 1 + j, -1 + n]]; Table[Sum[aux[i, j, n], {i, 0, n}, {j, 0, n}], {n, 0, 25}]
%K A151270 nonn,walk
%O A151270 0,3
%A A151270 _Manuel Kauers_, Nov 18 2008
