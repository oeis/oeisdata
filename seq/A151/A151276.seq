%U A151276 445185708105,2106762523813,9994758390849,47525328431357,226456780880985,1081142185822101,5170719824783825,24770430475804429,118844354630579049
%N A151276 Number of walks within N^2 (the first quadrant of Z^2) starting at (0,0) and consisting of n steps taken from {(-1, 1), (-1, 0), (0, -1), (1, -1), (1, 1)}.
%H A151276 Alin Bostan and Manuel Kauers, <a href="https://arxiv.org/abs/0811.2899">Automatic Classification of Restricted Lattice Walks</a>, arXiv:0811.2899 [math.CO], 2008.
%H A151276 Mireille Bousquet-Mélou and Marni Mishna, <a href="https://arxiv.org/abs/0810.4387">Walks with small steps in the quarter plane</a>, arXiv:0810.4387 [math.CO], 2008.
%H A151276 Marni Mishna and Juan Pulido, <a href="https://arxiv.org/abs/2605.16688">On the small-step quarter plane lattice walks with a non D-finite univariate generating function</a>, arXiv:2605.16688 [math.CO], 2026. See p. 6 (Table 3).
%t A151276 aux[i_Integer, j_Integer, n_Integer] := Which[Min[i, j, n] < 0 || Max[i, j] > n, 0, n == 0, KroneckerDelta[i, j, n], True, aux[i, j, n] = aux[-1 + i, -1 + j, -1 + n] + aux[-1 + i, 1 + j, -1 + n] + aux[i, 1 + j, -1 + n] + aux[1 + i, -1 + j, -1 + n] + aux[1 + i, j, -1 + n]]; Table[Sum[aux[i, j, n], {i, 0, n}, {j, 0, n}], {n, 0, 25}]
%K A151276 nonn,walk,changed
%O A151276 0,3
%A A151276 _Manuel Kauers_, Nov 18 2008
