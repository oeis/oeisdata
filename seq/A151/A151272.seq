%U A151272 18797194292,68593029228,250803101058,918497353314,3368841454202,12375002551280,45518663980004,167631635849400,618071950062304,2281410957097608
%N A151272 Number of walks within N^2 (the first quadrant of Z^2) starting at (0,0) and consisting of n steps taken from {(-1, 0), (0, -1), (1, -1), (1, 1)}.
%H A151272 Alin Bostan and Manuel Kauers, <a href="https://arxiv.org/abs/0811.2899">Automatic Classification of Restricted Lattice Walks</a>, arXiv:0811.2899 [math.CO], 2008.
%H A151272 Mireille Bousquet-Mélou and Marni Mishna, <a href="https://arxiv.org/abs/0810.4387">Walks with small steps in the quarter plane</a>, arXiv:0810.4387 [math.CO], 2008.
%H A151272 Marni Mishna and Juan Pulido, <a href="https://arxiv.org/abs/2605.16688">On the small-step quarter plane lattice walks with a non D-finite univariate generating function</a>, arXiv:2605.16688 [math.CO], 2026. See p. 12 (Table 5).
%t A151272 aux[i_Integer, j_Integer, n_Integer] := Which[Min[i, j, n] < 0 || Max[i, j] > n, 0, n == 0, KroneckerDelta[i, j, n], True, aux[i, j, n] = aux[-1 + i, -1 + j, -1 + n] + aux[-1 + i, 1 + j, -1 + n] + aux[i, 1 + j, -1 + n] + aux[1 + i, j, -1 + n]]; Table[Sum[aux[i, j, n], {i, 0, n}, {j, 0, n}], {n, 0, 25}]
%K A151272 nonn,walk,changed
%O A151272 0,3
%A A151272 _Manuel Kauers_, Nov 18 2008
