%T A389423 56229888,205920,843448320,875160,12745441280,3695120,193730707456,
%U A389423 15519504,2958796259328,64899744,45368209309696,270415600,697972450918400,1123264800,10768717814169600
%N A389423 a(n) = n*binomial(n, n/2) if n is even otherwise 2^(n-1)*binomial(n-1, (n-1)/2).
%H A389423 Paolo Xausa, <a href="/A389423/b389423.txt">Table of n, a(n) for n = 0..1500</a>
%F A389423 a(n) = (2^(n-1)/Pi)*H(n) if n is even otherwise 2^(2*n-1)/H(n) where H(n) = n*Integral_{x=-Pi/2..Pi/2} (cos(x)^n + sin(x)^n) dx.
%F A389423 a(2*n + 1) = A098430(n).
%F A389423 a(2*n + 2) = A002011(n).
%F A389423 From _Robert Israel_, Jul 07 2026: (Start)
%F A389423 G.f. 4*x^2/(1-4*x^2)^(3/2) + x/sqrt(1-16*x^2).
%F A389423 D-finite with recurrence: 4096*n*(n + 1)*a(n) + 256*(n^2 + 40*n + 75)*a(n + 2) - 480*(n + 5)*(n + 3)*a(n + 4) + 4*(11*n^2 + 104*n + 249)*a(n + 6) - (n + 7)*(n + 6)*a(n + 8) = 0. (End)
%p A389423 a := n -> ifelse(n::even, n*binomial(n, n/2), 2^(n-1)*binomial(n-1, (n-1)/2)):
%p A389423 seq(a(n), n = 0..29);
%t A389423 A389423[n_] := If[OddQ[n], 2^(n-1)*Binomial[n-1, (n-1)/2], n*Binomial[n, n/2]];
%t A389423 Array[A389423, 50, 0] (* _Paolo Xausa_, Oct 07 2025 *)
