%I A389808 #167 Jun 28 2026 21:24:40
%S A389808 1,36,36,180,36,516,180,324,36,612,516,468,180,1188,324,2580,36,1236,
%T A389808 612,756,516,1620,468,900,180,3588,1188,1908,324,1764,2580,1188,36,
%U A389808 2340,1236,4644,612,1956,756,5940,516,2100,1620,1620,468,8772,900,1764,180,2340
%N A389808 a(n) is the number of ordered pairs of integer vectors in Z^3 of norm n that span a rhombus with integer area.
%C A389808 Degenerate rhombi of area 0 are included.
%C A389808 Let t = u.v; by Lagrange's identity, |u x v|^2 + t^2 = n^4, so the integer-area condition is equivalent to n^4 - t^2 being a square.
%C A389808 For n = 2^k (k >= 1), let v2(w) be the exponent of 2 in w and set s = min(v2(x), v2(y), v2(z)). From x^2 + y^2 + z^2 = 2^(2*k) one has x = 2^s*x1, y = 2^s*y1, z = 2^s*z1 with x1^2 + y1^2 + z1^2 = 2^(2*k - 2*s). If 2*k - 2*s >= 3, then the right side is 0 mod 8, which forces x1, y1, z1 all even, a contradiction. Hence s >= k - 1. Since x1^2 + y1^2 + z1^2 = 2^(2*k - 2*s), it follows that x1^2 + y1^2 + z1^2 is 1 or 4, whose only solutions are permutations/signs of (+-1, 0, 0) or (+-2, 0, 0). Therefore the only integer vectors of norm n are (+-n, 0, 0), (0, +-n, 0), and (0, 0, +-n). For ordered pairs (u, v), the admissible dot products are t in {-n^2, 0, n^2} with multiplicities 6, 24, and 6, respectively; hence a(2^k) = 36.
%C A389808 a(n) == 12 (mod 24) for all n >= 1 (Proof see links).
%H A389808 Felix Huber, <a href="/A389808/a389808.txt">Proof that a(n) == 12 (mod 24) for all n >= 1</a>.
%H A389808 Wikipedia, <a href="https://en.wikipedia.org/wiki/Lagrange%27s_identity">Lagrange's identity</a>.
%F A389808 a(n) = #{(u, v) in Z^3 x Z^3 : ||u|| = ||v|| = n and |u x v| is an integer}.
%F A389808 a(2^k) = 36 for all k >= 1.
%e A389808 a(5) = 516; the admissible dot products are +-25, +-24, +-20, +-15, +-7, and 0, with multiplicities 30, 24, 48, 48, 24, and 168, respectively; summing 2*(30 + 24 + 48 + 48 + 24) + 168 gives 516.
%e A389808 a(8) = 36; the only integer vectors of norm 8 are (+-8, 0, 0), (0, +-8, 0), and (0, 0, +-8), yielding dot-product multiplicities 6, 24, and 6 for +64, 0, and -64, respectively.
%p A389808 A389808 := proc(n)
%p A389808     local a, h, i, j, k, l, m, q, r, s, t, x, y, z;
%p A389808     l := []; s := n^2;
%p A389808     for x from -n to n do
%p A389808         for y from -n to n do
%p A389808             t := s - x^2 - y^2;
%p A389808             if t >= 0 and issqr(t) then
%p A389808                 z := isqrt(t); l := [op(l), [x, y, z]];
%p A389808                 if z <> 0 then
%p A389808                     l := [op(l), [x, y, -z]]
%p A389808                 end if
%p A389808             end if
%p A389808         end do
%p A389808     end do;
%p A389808     m := nops(l); r := s^2; h := Array(0 .. s, 'datatype' = integer[1]);
%p A389808     for k from 0 to s do
%p A389808         h[k] := `if`(issqr(r - k^2), 1, 0)
%p A389808     end do;
%p A389808     a := 0;
%p A389808     for i to m do
%p A389808         for j to m do
%p A389808             q := abs(l[i][1]*l[j][1] + l[i][2]*l[j][2] + l[i][3]*l[j][3]);
%p A389808             if h[q] = 1 then a := a + 1 end if
%p A389808         end do
%p A389808     end do;
%p A389808     a
%p A389808 end proc:
%p A389808 seq(A389808(n), n = 0 .. 49);
%Y A389808 Cf. A005875.
%K A389808 nonn,new
%O A389808 0,2
%A A389808 _Felix Huber_, Jun 23 2026
