%T A049047 5,3,2,2,3,2,2,2,2,3,2,6,3,3,3,2,5,4,2,3,2,2,2,3,3,2,3,2,4,6,2,2,5,2,
%U A049047 2,2,2,6,2,2,3,2,4,3,5,2,3,2,3,2,5,2,5,4,5,3,5,4,3,2,4,4,2,4,2,2,3,3,2,2,4
%N A049047 Number of distinct factorial numbers congruent to 1 (mod prime(n)).
%H A049047 Alois P. Heinz, <a href="/A049047/b049047.txt">Table of n, a(n) for n = 1..10000</a> (first 5000 terms from Amiram Eldar)
%p A049047 a:= proc(n) option remember; local f, k, p, s; f, s, p:= 1$2, ithprime(n);
%p A049047       for k from 2 to p-1 do f:= f*k mod p; if f=1 then s:=s+1 fi od: s
%p A049047     end:
%p A049047 seq(a(n), n=1..105);  # _Alois P. Heinz_, Jun 01 2026
%t A049047 a[n_] := Module[{p = Prime[n]}, Count[Range[1, p-1], _?(Mod[#!, p] == 1 &)]]; Array[a, 100] (* _Amiram Eldar_, Aug 05 2025 *)
%o A049047 (PARI) a(n) = {my(p = prime(n)); sum(k = 1, p-1, k! % p == 1);} \\ _Amiram Eldar_, Aug 05 2025
%Y A049047 Cf. A000142.
%K A049047 nonn
%O A049047 1,3
%A A049047 _David W. Wilson_
