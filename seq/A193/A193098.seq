%I A193098 #14 Jun 10 2026 01:07:00
%S A193098 1,1,3,18,171,2283,39942,874944,23243829,731486637,26782956144,
%T A193098 1124838704976,53567894139165,2865318598843281,170774893724336223,
%U A193098 11264050942430761881,817374450539598433587,64917115563124199691834
%N A193098 E.g.f. A(x) satisfies: A'(x) = 1 + A(A(A(x))).
%H A193098 Paul D. Hanna, <a href="/A193098/b193098.txt">Table of n, a(n) for n = 1..200</a>
%F A193098 E.g.f. A(x) = Sum_{n>=1} a(n)*x^n/n! satisfies the following formulas, in which the constant of integration is zero where applicable.
%F A193098 (1) A'(x) = 1 + A(A(A(x))).
%F A193098 (2) A(x) = x + Integral A(A(A(x))) dx.
%F A193098 (3) A(x) = Series_Reversion( Integral 1/(1 + A(A(x))) dx ). - _Paul D. Hanna_, Jun 09 2026
%e A193098 E.g.f.: A(x) = x + x^2/2! + 3*x^3/3! + 18*x^4/4! + 171*x^5/5! + 2283*x^6/6! + ...
%e A193098 Related expansions.
%e A193098 The second iteration of A(x) begins
%e A193098 A(A(x)) = x + 2*x^2/2! + 9*x^3/3! + 69*x^4/4! + 777*x^5/5! + 11802*x^6/6! + 229047*x^7/7! + 5472600*x^8/8! + ...
%e A193098 where A(x) = Series_Reversion( Integral 1/(1 + A(A(x))) dx ).
%e A193098 The third iteration of A(x) begins
%e A193098 A(A(A(x))) = x + 3*x^2/2! + 18*x^3/3! + 171*x^4/4! + 2283*x^5/5! + ...
%e A193098 where A(x) = x + Integral A(A(A(x))) dx.
%o A193098 (PARI) {a(n) = my(A=x); for(k=1, n, A= truncate(A) + x*O(x^k);
%o A193098 A = intformal(1 + subst(A, x, subst(A, x, A))) +x*O(x^n) ); n!*polcoef(EGF=A, n)}
%o A193098 {upto(n) = a(n); Vec(serlaplace(EGF))}
%o A193098 upto(25) \\ program revised by _Paul D. Hanna_, Jun 09 2026
%Y A193098 Cf. A001028, A193099, A193100, A179420.
%K A193098 nonn,changed
%O A193098 1,3
