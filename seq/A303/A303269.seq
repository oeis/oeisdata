%T A303269 -8,5,-20,21,-40,45,-68,77,9,10,5,18,-7,34,-27,58,-55,90,-16,-15,-20,
%U A303269 -7,-32,9,-52,33,-80,65,25,26,21,34,9,50,-11,74,-39,106,-36,-35,-40,-27
%N A303269 Sum of squares of odd digits minus sum of squares of even digits of n.
%C A303269 Up to 10^4, resp. 10^5, there are 5824, resp. 59316, positive terms. All terms from a(1) to a(11111) are nonzero: see A076164 for indices of zeros.
%H A303269 Robert Israel, <a href="/A303269/b303269.txt">Table of n, a(n) for n = 0..10000</a>
%p A303269 f:= proc(n) local t;
%p A303269   add(t^2*(-1)^(t+1),t=convert(n,base,10))
%p A303269 end proc:
%p A303269 map(f, [$0..100]); # _Robert Israel_, Mar 17 2026
%o A303269 (PARI) A303269(n)=-vecsum(apply(d->d^2*(-1)^d,digits(n)))
%Y A303269 Cf. A076164, A071650, A036301.
%K A303269 sign,base,changed
%O A303269 0,3
