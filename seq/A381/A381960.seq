%C A381960 The first three centered heptagonal numbers that are squares of primes are a(5) = A069099(16) = 841 = 19^2, a(4018) = A069099(13920) = 678133681 = 26041^2, and A069099(9051630721904160) = 286762065540017254794549261905041 = 16934050476481321^2. - _Robert Israel_, Apr 21 2026
%H A381960 Robert Israel, <a href="/A381960/b381960.txt">Table of n, a(n) for n = 1..10000</a>
%e A381960 A069099(3) = 22 = 21*(3-1)/2 + 1 = 2*11.
%e A381960 A069099(6) = 106 = 42*(6-1)/2 + 1 = 2*53.
%e A381960 A069099(9) = 253 = 63*(9-1)/2 + 1 = 11*23.
%p A381960 select(t -> NumberTheory:-Omega(t)=2, [seq((7*n^2 - 7*n + 2)/2, n=1..1000)]); # _Robert Israel_, Apr 21 2026
%t A381960 Select[Table[(7*n^2 - 7*n + 2)/2, {n, 1, 120}], PrimeOmega[#] == 2 &] (* _Amiram Eldar_, Mar 11 2025 *)
