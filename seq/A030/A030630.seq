%I A030630 #33 May 03 2026 05:39:07
%S A030630 60,72,84,90,96,108,126,132,140,150,156,160,198,200,204,220,224,228,
%T A030630 234,260,276,294,306,308,315,340,342,348,350,352,364,372,380,392,414,
%U A030630 416,444,460,476,486,490,492,495,500,516,522,525,532,544,550
%N A030630 Numbers with 12 divisors.
%C A030630 Numbers of the form p^11 A079395, p*q^5 A178740, p*q*r^2 A085987, or p^2*q^3 A143610, where p, q and r are distinct primes. - _R. J. Mathar_, Mar 01 2010, Mar 17 2010
%H A030630 R. J. Mathar, <a href="/A030630/b030630.txt">Table of n, a(n) for n = 1..1000</a>
%t A030630 Select[Range[600], Length[Divisors[ # ]] == 12 &] (* _Stefan Steinerberger_, Apr 10 2006 *)
%t A030630 Select[Range[600],DivisorSigma[0,#]==12&] (* _Harvey P. Dale_, Jun 01 2016 *)
%o A030630 (PARI) for(n=1, 1e3, if(numdiv(n)==12, print1(n,", "))) \\ _Altug Alkan_, Nov 11 2015
%o A030630 (Python)
%o A030630 from math import isqrt
%o A030630 from sympy import integer_nthroot, primerange, primepi
%o A030630 from oeis_sequences.OEISsequences import bisection
%o A030630 def A030630(n):
%o A030630     def f(x):
%o A030630         x4 = integer_nthroot(x,4)[0]+1
%o A030630         x5 = integer_nthroot(x,5)[0]
%o A030630         c = n+x
%o A030630         c += -sum(primepi(x//(k*k*m))-b for a,k in enumerate(primerange(x4),1) for b,m in enumerate(primerange(k+1,isqrt(x//(k*k))+1),a+1))
%o A030630         c += -sum(primepi(x//(k*m*m))-b for a,k in enumerate(primerange(x4),1) for b,m in enumerate(primerange(k+1,integer_nthroot(x//k,3)[0]+1),a+1))
%o A030630         c += -sum(primepi(isqrt(x//(k*m)))-b for a,k in enumerate(primerange(x4),1) for b,m in enumerate(primerange(k+1,integer_nthroot(x//k,3)[0]+1),a+1))
%o A030630         c += -sum(primepi(x//p**5) for p in primerange(x5+1))+primepi(integer_nthroot(x,6)[0])
%o A030630         c += -sum(primepi(isqrt(x//p**3)) for p in primerange(integer_nthroot(x,3)[0]+1))+primepi(x5)
%o A030630         c += -primepi(integer_nthroot(x,11)[0])
%o A030630         return int(c)
%o A030630     return bisection(f,n,n) # _Chai Wah Wu_, May 01 2026
%K A030630 nonn,changed
%O A030630 1,1
%A A030630 _Jeff Burch_
