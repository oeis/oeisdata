%S A108504 1,1,2,2,2,3,3,4,4,3,5,5,6,4,6,6,8,4,8,9,7,8,8,10,5,9,12,8,12,10,12,5,
%T A108504 11,15,9,16,12,14,14,6,16,12,18,13,18,10,20,14,18,16,6,20,14,16,24,15,
%U A108504 21,11,24,16,23,18,7,24,15,24,30,18,24,24,12,27,25,28,18,27,32,20,18,7
%N A108504 Number of divisors of A025487(n) that are at most sqrt(A025487(n)).
%H A108504 Amiram Eldar, <a href="/A108504/b108504.txt">Table of n, a(n) for n = 1..10000</a>
%F A108504 a(n) = A038548(A025487(n)).
%o A108504 (Python)
%o A108504 from itertools import count
%o A108504 from functools import lru_cache
%o A108504 from sympy import prime, integer_log, primorial, divisor_count
%o A108504 from oeis_sequences.OEISsequences import bisection
%o A108504 def A108504(n):
%o A108504     if n == 1: return 1
%o A108504     @lru_cache(maxsize=None)
%o A108504     def g(x, m, j): return sum(g(x//(prime(m)**i), m-1, i) for i in range(j,integer_log(x, prime(m))[0]+1)) if m-1 else max(0,x.bit_length()-j)
%o A108504     def f(x):
%o A108504         c = n-1+x
%o A108504         for k in count(1):
%o A108504             if primorial(k)>x:
%o A108504                 break
%o A108504             c -= g(x,k,1)
%o A108504         return c
%o A108504     return divisor_count(bisection(f,n,n))+1>>1 # _Chai Wah Wu_, Mar 24 2026
%Y A108504 Cf. A025487, A038548.
%K A108504 nonn,changed
