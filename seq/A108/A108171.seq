%U A108171 3,3,4,3,3,4,3,4,3,3,4,3,4,3,3,4,3,3,4,3,4,3,3,4,3,3,4,3,4,3,3
%N A108171 Tribonacci version of A076662 using the positive real Pisot root of x^3 - x^2 - x - 1.
%C A108171 The sequence b(n) is similar to, but not the same as, A195171. - _Sean A. Irvine_, Jul 05 2026
%F A108171 a(n) = b(n) - b(n-1) where b(n) = 1 + ceiling((n-1)*beta^2) and beta = A058265 = 1.83928675... is the positive real root of x^3-x^2-x-1.
%t A108171 beta = Root[x^3-x^2-x-1, 1];
%t A108171 a[n_] = 1 + Ceiling[(n - 1)*beta^2]; (* A007066-like *)
%t A108171 b = Table[a[n] - a[n - 1], {n, 2, 100}] (* A076662-like *)
%Y A108171 Cf. A007066, A076662, A058265, A195171.
%K A108171 nonn
%O A108171 0,1
%A A108171 _Roger L. Bagula_, Jun 13 2005
%E A108171 Edited by _Sean A. Irvine_, Jul 05 2026
