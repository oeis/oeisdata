%I A108119 #14 Apr 07 2026 00:16:13
%S A108119 42,53,82,115,125,141,172,177,193,233,279,369,399,431,474,500,575,580,
%T A108119 585,650,651,672,708,737,751,760,795,798,820,841,842,863,873,933,1019,
%U A108119 1031,1099,1112,1166,1178,1225,1245,1266,1312,1352,1436,1463,1479,1505
%N A108119 Numbers k such that prime(k) and prime(k+1) are congruent to 1 (mod 10).
%H A108119 Robert Israel, <a href="/A108119/b108119.txt">Table of n, a(n) for n = 1..10000</a>
%F A108119 A330366(n) = prime(a(n)). - _Robert Israel_, Apr 06 2026
%e A108119 Prime(42)=181, prime(43)=191. This is the first pair of successive primes both ending with 1.
%p A108119 R:= NULL: p:= 2: count:= 0:
%p A108119 for k from 1 do
%p A108119   q:= p; p:= nextprime(p);
%p A108119   if q mod 10 = 1 and p mod 10 = 1 then
%p A108119     count:= count+1; R:= R,k; if count = 100 then break fi
%p A108119   fi
%p A108119 od:
%p A108119 R; # _Robert Israel_, Apr 06 2026
%t A108119 ra=Range[2000];cnd=Mod[Prime[ # ], 10]==Mod[Prime[ #+1], 10]==1&;se=Select[ra, cnd]
%Y A108119 Cf. A330366.
%K A108119 nonn
%O A108119 1,1
%A A108119 _Zak Seidov_, Jun 04 2005
