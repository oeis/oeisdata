%I A108972 #9 Mar 02 2026 13:15:22
%S A108972 1,3,6,19,30,91,134,307,318,1051,1158,1867,2358,2971,3590,3979,4670,
%T A108972 5131,5478,7747,7878,8251,8390,16891,17334,22267,28358,30691,31310,
%U A108972 36811,37718,61507,64518,70171,70454,74707,76614,79411,79790,89131,94910,206491,206958,235267,242214,243595,247806
%N A108972 a(1) = 1; for n > 1, a(n) is the least k > a(n-1) such that a(n) + a(n-1) is square and a(n) - a(n-1) is prime.
%H A108972 Robert Israel, <a href="/A108972/b108972.txt">Table of n, a(n) for n = 1..10000</a>
%e A108972 Given a(5) = 30, the least k > 30 such that k + 30 is square and k - 30 is prime is 91 (91 + 30 = 121 = 11^2; and 91 - 30 = 61 is prime), so a(6) = 91.
%p A108972 f:= proc(x) local k,s;
%p A108972   for s from ceil(sqrt(2*x+1)) do
%p A108972      k:= s^2 - x;
%p A108972      if isprime(k-x) then return k fi
%p A108972   od
%p A108972 end proc:
%p A108972 R:= 1: r:= 1:
%p A108972 for n from 2 to 100 do
%p A108972   r:= f(r);
%p A108972   R:= R,r
%p A108972 od:
%p A108972 R; # _Robert Israel_, Mar 01 2026
%t A108972 a = 1; Print[a]; Do[k = a + 1; While[ !(PrimeQ[k - a] && IntegerQ[Sqrt[k + a]]), k++ ]; a = k; Print[a], {n, 1, 30}]
