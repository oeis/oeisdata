%I A083811 #20 Jun 30 2026 18:46:57
%S A083811 36,396,3996,39996,399996,3999996,39999996,399999996,3999999996,
%T A083811 39999999996,399999999996,3999999999996
%N A083811 Numbers k such that 2*k+1 is the digit reversal of k+1.
%C A083811 1. a(n) = 36 + 360 + 3600+ ...+ up to n terms. a(n) = sum of n terms of the geometric progression with the first term 36 and common ratio 10. 2. a(n) = 36*A000042(n).( the unary sequence).
%H A083811 <a href="/index/Rec#order_02">Index entries for linear recurrences with constant coefficients</a>, signature (11,-10).
%F A083811 a(n) = 4*(10^n - 1).
%F A083811 G.f.: 36*x/(1 - 11*x + 10*x^2). - _Charles R Greathouse IV_, May 20 2026
%e A083811 36 + 1 = 37, 2*36 + 1 = 73.
%t A083811 Accumulate[36*10^Range[0,20]] (* _Harvey P. Dale_, Dec 03 2025 *)
%t A083811 (* Alternative: *)
%t A083811 LinearRecurrence[{11,-10},{36,396},20] (* _Harvey P. Dale_, Dec 03 2025 *)
%o A083811 (PARI) a(n)=4*10^n-4 \\ _Charles R Greathouse IV_, May 20 2026
%Y A083811 Cf. A000042.
%K A083811 base,nonn,easy,changed
%O A083811 1,1
%A A083811 _Amarnath Murthy_ and Meenakshi Srikanth (menakan_s(AT)yahoo.com), May 08 2003
