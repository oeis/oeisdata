%C A023942 Inner Product Denominator: 2
%C A023942 Level is 4, dimension of space of modular forms is 6. - _John Cannon_
%C A023942 The g.f. identity in the Formula section is proven by Sturm's theorem: both sides are modular forms of weight 10 on Gamma_0(4), expressed in the standard degree-5 theta constant basis generated by theta_3(q)^4 and theta_4(q)^4; agreement through q^5 suffices since floor(10*6/12) = 5. The formula was also checked against the b-file for n = 0..999 and against direct lattice enumeration from the Nebe-Sloane Gram matrix through squared norm 16. - _Steven Kotlarz_, Jul 01 2026
%D A023942 J. H. Conway and N. J. A. Sloane, "Sphere Packings, Lattices and Groups", Springer-Verlag, p. 174.
%H A023942 John Cannon, <a href="/A023942/b023942.txt">Table of n, a(n) for n = 0..999</a>
%H A023942 G. Nebe and N. J. A. Sloane, <a href="http://www.math.rwth-aachen.de/~Gabriele.Nebe/LATTICES/LAMBDA20.html">Home page for this lattice</a>
%F A023942 G.f.: Let t3 = Sum_{m in Z} q^(m^2), t4 = Sum_{m in Z} (-1)^m*q^(m^2), A = t3^4, B = t4^4. Then Sum_{n>=0} a(n)*q^n = (B^5 + 5*A*B^4 - 140*A^2*B^3 + 520*A^3*B^2 - 640*A^4*B + 256*A^5)/2. - _Steven Kotlarz_, Jul 01 2026
%e A023942 G.f. = 1 + 17400*q^4 + 645120*q^6 + 8699640*q^8 + 64266240*q^10 + 334145760*q^12 + O(q^14).
%o A023942 (Magma) L:=Lattice("Lambda",20); T<q> := ThetaSeries(L,14); T;
%o A023942 (Magma) A := Basis(ModularForms(Gamma0(4), 10), 20); A[1] + 17400*A[3] + 645120*A[4] + 8699640*A[5] + 64266240*A[6]; /* _Michael Somos_, May 26 2023 */
%o A023942 (SageMath)
%o A023942 M = ModularForms(Gamma0(4), 10);
%o A023942 bases = [_.q_expansion(20) for _ in M.integral_basis()];
%o A023942 f = sum(x*y for (x, y) in zip(bases, [1, 0, 17400, 645120, 8699640, 64266240])); list(f) # _Andy Huchala_, Jun 05 2021
%o A023942 (PARI) my(T=25, q='q+O('q^T), th3=sum(m=-sqrtint(T-1),sqrtint(T-1),q^(m^2)), th4=sum(m=-sqrtint(T-1),sqrtint(T-1),(-1)^m*q^(m^2)), A=th3^4, B=th4^4); Vec((B^5 + 5*A*B^4 - 140*A^2*B^3 + 520*A^3*B^2 - 640*A^4*B + 256*A^5)/2) \\ _Steven Kotlarz_, Jul 01 2026
%o A023942 (Python)
%o A023942 def A023942_list(T):
%o A023942     def mul(a, b):
%o A023942         c = [0]*T
%o A023942         for i, ai in enumerate(a):
%o A023942             if ai:
%o A023942                 for j in range(T-i):
%o A023942                     if b[j]:
%o A023942                         c[i+j] += ai*b[j]
%o A023942         return c
%o A023942     def pw(a, e):
%o A023942         r = [0]*T
%o A023942         r[0] = 1
%o A023942         while e:
%o A023942             if e & 1:
%o A023942                 r = mul(r, a)
%o A023942             a = mul(a, a)
%o A023942             e >>= 1
%o A023942         return r
%o A023942     th3 = [0]*T
%o A023942     th4 = [0]*T
%o A023942     th3[0] = th4[0] = 1
%o A023942     m = 1
%o A023942     while m*m < T:
%o A023942         th3[m*m] += 2
%o A023942         th4[m*m] += 2*(-1 if m % 2 else 1)
%o A023942         m += 1
%o A023942     A = pw(th3, 4)
%o A023942     B = pw(th4, 4)
%o A023942     terms = [(1, pw(B, 5)), (5, mul(A, pw(B, 4))), (-140, mul(pw(A, 2), pw(B, 3))),
%o A023942              (520, mul(pw(A, 3), pw(B, 2))), (-640, mul(pw(A, 4), B)), (256, pw(A, 5))]
%o A023942     total = [0]*T
%o A023942     for c, f in terms:
%o A023942         for i in range(T):
%o A023942             total[i] += c*f[i]
%o A023942     return [x//2 for x in total]
%o A023942 print(A023942_list(25)) # _Steven Kotlarz_, Jul 01 2026
%Y A023942 Cf. A005933, A006909, A006910, A006911, A023941, A023943.
%K A023942 nonn
%O A023942 0,3
