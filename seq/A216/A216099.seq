%I A216099 #26 Apr 03 2026 12:10:21
%S A216099 4,20,100,500,5000,50000,500000,5000000,50000000,500000000,5000000000,
%T A216099 50000000000,500000000000,5000000000000,50000000000000,
%U A216099 500000000000000,5000000000000000,50000000000000000,500000000000000000,5000000000000000000,50000000000000000000,500000000000000000000
%N A216099 Period of powers of 3 mod 10^n.
%H A216099 <a href="/index/Rec#order_01">Index entries for linear recurrences with constant coefficients</a>, signature (10).
%F A216099 a(n) = 4*5^(n-1) for n <= 4.
%F A216099 a(n) = 5*10^(n-2) for n >= 5.
%F A216099 From _Elmo R. Oliveira_, Apr 02 2026: (Start)
%F A216099 a(n) = A216164(n+1).
%F A216099 a(n) = 10*a(n-1) for n > 4.
%F A216099 G.f.: 4*x*(125*x^3 + 25*x^2 + 5*x - 1)/(10*x - 1).
%F A216099 E.g.f.: (1/60)*(3*exp(10*x) - 3 + 210*x + 450*x^2 + 500*x^3). (End)
%t A216099 Table[If[n<5,(4*5^n)/5,10^n/20],{n,20}] (* or *) Join[{4,20,100},NestList[ 10#&,500,20]] (* _Harvey P. Dale_, May 31 2017 *)
%o A216099 (PARI) a(n)=if(n<5,4*5^n/5,10^n/20) \\ _Charles R Greathouse IV_, Mar 26 2016
%Y A216099 Cf. A000244, A001148, A001218, A093143, A216164.
%K A216099 nonn,base,easy
