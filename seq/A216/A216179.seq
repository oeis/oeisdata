%S A216179 13,103,1003,10003,100003,1000003,10000003,100000003,1000000003,
%T A216179 10000000003,100000000003,1000000000003,10000000000003,
%U A216179 100000000000003,1000000000000003,10000000000000003,100000000000000003,1000000000000000003,10000000000000000003
%N A216179 a(n) = 10^n + 3.
%C A216179 1 followed by n - 1 0's followed by 3.
%H A216179 Markus Tervooren, <a href="https://factordb.com/index.php?query=10^x%2B3">Factorizations of 1(0)w3</a>.
%H A216179 <a href="/index/Rec#order_02">Index entries for linear recurrences with constant coefficients</a>, signature (11,-10).
%F A216179 a(n) = 10*a(n-1) - 27 with n > 1, a(1)=13.
%F A216179 From _Elmo R. Oliveira_, Mar 26 2026: (Start)
%F A216179 O.g.f.: x*(13 - 40*x)/((10*x - 1)*(x - 1)).
%F A216179 E.g.f.: (3 + exp(9*x))*exp(x) - 4.
%F A216179 a(n) = 11*a(n-1) - 10*a(n-2); a(1)=13, a(2)=103.
%F A216179 a(n) = A011557(n) + 3. (End)
%t A216179 Table[10^n + 3, {n, 1, 19}]
%t A216179 NestList[10# - 27 &, 13, 18]
