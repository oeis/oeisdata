%I A060785 #34 Jun 20 2026 05:52:31
%S A060785 0,12,54,126,228,360,522,714,936,1188,1470,1782,2124,2496,2898,3330,
%T A060785 3792,4284,4806,5358,5940,6552,7194,7866,8568,9300,10062,10854,11676,
%U A060785 12528,13410,14322,15264,16236,17238,18270,19332,20424,21546,22698,23880,25092,26334
%N A060785 a(n) = 3*(n - 2)*(5*n -11).
%D A060785 Luigi Berzolari, Allgemeine Theorie der Höheren Ebenen Algebraischen Kurven, Encyclopädie der Mathematischen Wissenschaften mit Einschluss ihrer Anwendungen, Band III_2, Heft 3, Leipzig: B. G. Teubner, 1906, pp. 313-455.
%D A060785 H. Brocard and T. Lemoyne, Courbes géométriques remarquables (courbes spéciales) Planes et Gauches, Tome I, Paris: Albert Blanchard, 1967 [First publ. 1919]; see p. 135.
%H A060785 Harry J. Smith, <a href="/A060785/b060785.txt">Table of n, a(n) for n = 2..1000</a>
%H A060785 <a href="/index/Rec#order_03">Index entries for linear recurrences with constant coefficients</a>, signature (3,-3,1).
%F A060785 a(n) = 30*n + a(n-1) - 78 with n>2, a(2)=0. - _Vincenzo Librandi_, Aug 07 2010
%F A060785 G.f.: 6*x^3*(2+3*x)/(1-x)^3. - _Colin Barker_, Feb 28 2012
%F A060785 Sum_{n>=3} 1/a(n) = sqrt(5)*log(phi)/6 - tan(3*Pi/10)*Pi/6 + 5*log(5)/12, where phi is the golden ratio (A001622). - _Amiram Eldar_, Jun 20 2026
%F A060785 Sum_{n>=3} (-1)^(n+1)/a(n) = (Pi*sqrt(phi)/5^(1/4) - 2*log(2) - sqrt(5)*log(phi))/3. - _Vaclav Kotesovec_, Jun 20 2026
%t A060785 Table[3(n-2)(5n-11),{n,2,50}] (* _Harvey P. Dale_, May 24 2023 *)
%t A060785 (* Alternative: *)
%t A060785 LinearRecurrence[{3,-3,1},{0,12,54},50] (* _Harvey P. Dale_, May 24 2023 *)
