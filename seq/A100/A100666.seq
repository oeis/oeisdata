%I A100666 #32 Mar 08 2026 10:28:03
%S A100666 3,3,7,21,79,357,1879,11277,75967,567381,4652071,41534493,401057935,
%T A100666 4164175845,46260731384,547489559470,6876483788377,91352567576937,
%U A100666 1279774932585453,18855298837939164,291449116254193528,4715873702469251801,79718157485054734977
%N A100666 a(n) = Sum_{k>=0} k^n/Catalan(k) rounded to nearest integer.
%C A100666 The exact values are conjectured to be close to integers, but there is no sound basis for it as yet. The coincidence for the first 10 instances is however intriguing.
%C A100666 Conjecture is false: a(15) = round(547489559469.6423...), a(23) = round(1405230835254158841468.5247...), in fact, it seems values arbitrarily close to m+1/2 are possible. - _Sean A. Irvine_, Mar 07 2026
%F A100666 a(n) = round(Sum_{k>=0} k^n * k! * (k + 1)! / (2*k)!).
%F A100666 a(n) = round(Sum_{m=0..n} hypergeom([m+1, m+2], [m+1/2], 1/4) * Stirling2(n, m) * (m!)^2 * (m+1)! / (2*m)!).
%e A100666 n  float(n)    Exact(n)
%e A100666 0  2.806133... 2 + (4*Pi)/(9*sqrt(3)) = A268813 = 1 + A121839.
%e A100666 1  3.074844... 2 + (16*Pi)/(27*sqrt(3)).
%e A100666 2  6.995495... (2*(567 + 52*sqrt(3)*Pi))/243.
%e A100666 3 20.986486... 14 + (104*Pi)/(27*sqrt(3)).
%e A100666 4 79.000346... 158/3 + (392*Pi)/(27*sqrt(3)).
%p A100666 C:= proc(n) option remember; binomial(2*n, n)/(n+1) end:
%p A100666 a:= proc(n) option remember; round(sum(k^n/C(k), k=0..infinity)) end:
%p A100666 seq(a(n), n=0..10);  # _Alois P. Heinz_, Mar 07 2026
%t A100666 h[a_]:=h[a]=Apart[(4*(-3+2*a)*((-5+2*a)*h[ -2+a]-(-4+a)*h[ -1+a]))/(3*(-1+a)*a)]; h[1]:=2+(4*Pi)/(9*Sqrt[3]); h[0]:=1; Table[Round[Sum[h[m+1] StirlingS2[n, m]/(2m-1)!!/2^m (m+1)!m!, {m, 0, n}]], {n, 14}]
%Y A100666 Cf. A000108, A121839, A268813.
%K A100666 easy,nonn
%O A100666 0,1
