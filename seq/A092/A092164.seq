%T A092164 621937811,3731626861,22389761171,134338567021,806031402131,
%U A092164 4836188412781,29017130476691,174102782860141,1044616697160851,6267700182965101,37606201097790611,225637206586743661
%N A092164 Let M = 2 X 2 matrix [ 1 2 / 5 4 ]; a(n) = (1,1) entry of M^n.
%H A092164 <a href="/index/Rec#order_02">Index entries for linear recurrences with constant coefficients</a>, signature (5,6).
%F A092164 a(n) = (2*6^n + 5*(-1)^n)/7.
%F A092164 a(n) = A092165(n) + (-1)^n.
%F A092164 From _R. J. Mathar_, Apr 20 2009: (Start)
%F A092164 a(n) = 5*a(n-1) + 6*a(n-2).
%F A092164 G.f.: (4*x-1)/((x+1)*(6*x-1)). (End)
%F A092164 E.g.f.: exp(-x)*(5 + 2*exp(7*x))/7. - _Elmo R. Oliveira_, Jul 07 2026
%t A092164 Table[ MatrixPower[{{1, 2}, {5, 4}}, n][[1, 1]], {n, 20}] (* _Robert G. Wilson v_, Apr 22 2004 *)
