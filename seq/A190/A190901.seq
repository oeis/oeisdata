%I A190901 #30 Jul 21 2026 15:34:16
%S A190901 1,1,8,15,384,945,46080,135135,10321920,34459425,3715891200,
%T A190901 13749310575,1961990553600,7905853580625,1428329123020800,
%U A190901 6190283353629375,1371195958099968000,6332659870762850625,1678343852714360832000,8200794532637891559375,2551082656125828464640000
%N A190901 a(n) = Product_{k in M_n} k; M_n = {k | 1 <= k <= 2n and k mod 2 = n mod 2}.
%H A190901 G. C. Greubel, <a href="/A190901/b190901.txt">Table of n, a(n) for n = 0..400</a>
%H A190901 Peter Luschny, <a href="https://oeis.org/wiki/User:Peter_Luschny/Multifactorials">Multifactorials</a>.
%F A190901 a(2*k)   = A006882(4*k)   = 4^k * Gamma(2*k+1).
%F A190901 a(2*k+1) = A001147(2*k+1) = 4^k * Gamma(2*k+3/2) / sqrt(Pi/4).
%F A190901 From _Amiram Eldar_, Jul 21 2026: (Start)
%F A190901 a(n) ~ sqrt(Pi) * (2*n)^(n+1/2) / exp(n) for n even, and  2^(n+1/2) * n^n / exp(n) for n odd.
%F A190901 Sum_{n>=0} 1/a(n) = cosh(1/2) + (1/2)*sqrt(e*Pi/2)*erf(1/sqrt(2)) + (1/2)*sqrt(Pi/(2*e))*erfi(1/sqrt(2)), where erf and erfi are the error function and imaginary error function, respectively.
%F A190901 Sum_{n>=0} (-1)^n/a(n) = cosh(1/2) - (1/2)*sqrt(e*Pi/2)*erf(1/sqrt(2)) - (1/2)*sqrt(Pi/(2*e))*erfi(1/sqrt(2)). (End)
%p A190901 A190901 := proc(n) local k; mul(k, k = select(k-> k mod 2 = n mod 2, [$1 .. 2*n])) end: seq(A190901(n), n=0..18);
%t A190901 a[n_] := With[{m = Mod[n, 2]}, Product[If[Mod[k, 2] == m, k, 1], {k, 1, 2*n}]]; Table[a[n], {n, 0, 20}] (* _Jean-François Alcover_, Jan 27 2014 *)
%Y A190901 Cf. A001147, A006882.
%K A190901 nonn,changed
%O A190901 0,3
%A A190901 _Peter Luschny_, Jun 23 2011
