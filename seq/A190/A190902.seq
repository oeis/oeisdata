%I A190902 #37 Apr 30 2026 22:01:01
%S A190902 1,-2,-3,0,-5,36,-7,0,0,100,-11,0,-13,196,225,0,-17,0,-19,0,441,484,
%T A190902 -23,0,0,676,0,0,-29,810000,-31,0,1089,1156,1225,0,-37,1444,1521,0,
%U A190902 -41,3111696,-43,0,0,2116,-47,0,0,0,2601,0,-53,0,3025,0,3249,3364,-59,0,-61,3844
%N A190902 a(n) = Product_{d|n} d*mu(n/d).
%C A190902 a(n) is the multiplicative equivalent to Euler's totient function, phi(n) = Sum_{d|n} d*mu(n/d).
%C A190902 a(n) is the determinant of the symmetric tau(n) X tau(n) matrix M(n) defined by M(n) = [sigma(d_i*d_j)], where d_i, d_j run through the divisors of n. - _Ridouane Oudra_, Apr 25 2026
%F A190902 a(n) = 0 iff n is not squarefree (A013929).
%F A190902 a(n) < 0 iff n is prime (A000040).
%F A190902 a(n) = -n iff n is prime.
%F A190902 From _Ridouane Oudra_, Apr 25 2026: (Start)
%F A190902 a(n) = A069158(n)*A007955(n).
%F A190902 a(n) = A069158(n)*A061537(n).
%F A190902 a(n) = n^(tau(n)/2) for n in A000469.
%F A190902 a(n) = (A076479(n)*n)^(tau(n)/2) for n in A005117. (End)
%e A190902 a(14) = 1*(1)*2*(-1)*7*(-1)*14*(1) = 14^2 = 196.
%p A190902 with(numtheory): A190902 := proc(n) local d; mul(d*mobius(n/d),d=divisors(n)) end:
%p A190902 # Alternative:
%p A190902 with(numtheory): A190902 := proc(n) if mobius(n)=0 then 0 elif isprime(n) then -n else n^(2^(nops(factorset(n))-1)) fi end:
%t A190902 a[n_] := Product[d MoebiusMu[n/d], {d, Divisors[n]}];
%t A190902 Array[a, 62] (* _Jean-François Alcover_, Jun 24 2019 *)
%t A190902 (* Alternative: *)
%t A190902 a[n_]:=Det[Table[DivisorSigma[1,Part[d=Divisors[n],i]*Part[d,j]],{i,DivisorSigma[0,n]},{j,DivisorSigma[0,n]}]]; Array[a,62] (* _Stefano Spezia_, Apr 26 2026 *)
%o A190902 (PARI) a(n)={my(r=1);fordiv(n,d,r*=d*moebius(n/d));return(r);}
%o A190902 (Python)
%o A190902 from sympy import mobius, primenu
%o A190902 def A190902(n): return 0 if not mobius(n) else 1 if n==1 else -n**(1<<m-1) if (m:=primenu(n))==1 else n**(1<<m-1) # _Chai Wah Wu_, Apr 25 2026
%Y A190902 Cf. A008683, A000005, A000010, A000203, A007955, A061537, A001221, A069158, A000469, A005117, A076479.
%K A190902 sign,changed
%O A190902 1,2
