%e A338444   14    30  2 3 5
%e A338444   15    34  2           17
%e A338444   16    17              17
%t A338444 Block[{c, k, m, r, s, w, nn},
%t A338444   nn = 120; c[_] := False; r = s = 1;
%t A338444   Reap[Do[w = GCD[r, s]; m = r/w;
%t A338444   Which[
%t A338444     Mod[i, 4] == 2, k = 2*m,
%t A338444     Mod[i, 4] == 4, k = m/2,
%t A338444     True, k = m;
%t A338444       While[Or[c[k], ! SquareFreeQ[k], ! CoprimeQ[w, k] ], k += m] ];
%t A338444   Sow[k]; Set[{s, r, c[k]}, {r, k, True}], {i, nn}] ][[-1, 1]] ] (* _Michael De Vlieger_, Jun 19 2026 *)
