%U A338418 7235039300,26840154388,101944730262,392596623714,1530559274958,6072449285528,24470393750806,100062786402800
%N A338418 a(n) is the number of length-n ballot sequences whose reversals are also ballot sequences.
%C A338418 Ballot sequences B have positive terms, and for any finite prefix P of B and any k > 0, the number of occurrences of k in P is greater than or equal to the number of occurrences of k+1 in P.
%H A338418 Bert Dobbelaere, <a href="/A338418/b338418.txt">Table of n, a(n) for n = 0..70</a>
%H A338418 Rémy Sigrist, <a href="/A338418/a338418.txt">C++ program for A338418</a>
%F A338418 a(n) >= A338417(n).
%e A338418 For n = 5:
%e A338418 - the reversals of the following length-5 ballot sequences are also ballot sequences:
%e A338418      (1, 1, 1, 1, 1)
%e A338418      (1, 1, 1, 2, 1)
%e A338418      (1, 1, 2, 1, 1)
%e A338418      (1, 2, 1, 1, 1)
%e A338418      (1, 2, 1, 2, 1)
%e A338418 - so a(5) = 5.
%o A338418 (C++) // See Links section.
