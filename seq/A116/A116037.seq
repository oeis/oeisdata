%S A116037 1,17,20,29,253,344,370,445,479,675,786,887,1539,3115,4221,4271,6002,
%T A116037 6416,7657,9015,10003,11563,12651,12984,14200,14494,14880,14928,15504,
%U A116037 15738,17064,18008,18265,18395,19065,21795,23093,23676,24078,24570
%N A116037 Numbers k such that k+prime(k)+prime(prime(k)) is a palindrome, where prime(k) denotes the k-th prime.
%H A116037 Robert Israel, <a href="/A116037/b116037.txt">Table of n, a(n) for n = 1..385</a>
%e A116037 10003+prime(10003)+prime(prime(10003)) = 1481841.
%p A116037 ispali:= proc(n) local L; L:= convert(n,base,10); andmap(i -> L[i]=L[-i],[$1..nops(L)/2]) end proc:
%p A116037 filter:= proc(n) local p; p:= ithprime(n); ispali(n+p+ithprime(p)) end proc:
%p A116037 select(filter, [$1..30000]); # _Robert Israel_, May 01 2026
