%e A116884 |432^5 - 3878907^2| = 8217 < 432^(3/2).
%t A116884 Select[Range[1,5*100^3],Function[k,Module[{m0=Round[Sqrt[k^5]]},AnyTrue[Range[m0-2,m0+2], Function[m,0<Abs[k^5-m^2]<=k^(3/2)]]]]] (* _Vincenzo Librandi_, Mar 20 2026 *)
%o A116884 (Magma) res := [1]; for k in [1..100^3] do m0 := Round(Sqrt(k^5)); ok := false;
%o A116884 for m in [m0-2..m0+2] do if m ne 0 and Abs(k^5 - m^2) gt 0 and Abs(k^5 - m^2) le k^(3/2) then
%o A116884 ok := true; break; end if; end for; if ok then Append(~res, k); end if; end for; res; // _Vincenzo Librandi_, Mar 20 2026
