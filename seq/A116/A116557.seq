%S A116557 1,3,6,11,19,32,52,85,139,225,365,592,958,1551,2511,4064,6577,10642,
%T A116557 17220,27863,45084,72948,118033,190982,309016,500000
%N A116557 a(25)=500000, a(n) = floor(a(n+1) * (sqrt(5)-1) / 2).
%C A116557 Given a target of 500000 rabbits, this sequence shows that 25 generations of Fibonacci rabbits are needed.
%t A116557 f[0] = 500000; f[n_] := f[n] = Floor[f[n - 1]*(-1/2 + Sqrt[5]/2)] a = Table[f[n], {n, 25, 1, -1}]
