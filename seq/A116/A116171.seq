%T A116171 60020753655608135708762056127156,60446518621981165303188950156776,
%U A116171 71135436903815748345367595855336,72876856643103028189103298533248,84570848711413793538075759738752,85076101372363641092906686735252,99714785145539288825781952765036
%N A116171 Numbers k such that k concatenated with k+2 gives the product of two numbers which differ by 3.
%C A116171 Also numbers k such that k concatenated with k+4 gives the product of two numbers which differ by 1.
%H A116171 Robert Israel, <a href="/A116171/b116171.txt">Table of n, a(n) for n = 1..36</a>
%e A116171 63716866//63716868 = 79822844 * 79822847, where // denotes concatenation.
%e A116171 63716866//63716870 = 79822845 * 79822846.
%p A116171 As:= {}: count:= 0:
%p A116171 for m from 2 to 50 do
%p A116171    acands:= map(t -> rhs(op(t)), [msolve(a*(a+1)=4, 10^m+1)]);
%p A116171    bcands:= map(t -> t*(t+1) mod 10^m, acands);
%p A116171    good:= select(t -> bcands[t]>=10^(m-1), [$1..nops(acands)]);
%p A116171    As:= As union convert(bcands[good], set);
%p A116171 od:
%p A116171 map(t -> t-4, sort(convert(As, list))); # _Robert Israel_, Mar 18 2026
