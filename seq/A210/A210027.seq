%I A210027 #15 Apr 28 2026 00:50:38
%S A210027 0,0,0,3,9,23,27,47,59,79,111,147,159,203,223,291,319,379,399,467,535,
%T A210027 579,615,699,727,883,927,995,1039,1147,1215,1331,1391,1467,1527,1739,
%U A210027 1783,1923,1991,2083,2223,2379,2423,2587,2663,2875,2959,3139,3199,3363,3519
%N A210027 Number of 2 X 2 matrices having all elements in {1,2,...,n} and determinant 5.
%C A210027 See A210000 for a guide to related sequences.
%H A210027 Chai Wah Wu, <a href="/A210027/b210027.txt">Table of n, a(n) for n = 0..10000</a>
%F A210027 a(n) = A209977(n) - 4*n - 2 for n >= 5. - _David Radcliffe_, Apr 27 2026
%t A210027 a = 1; b = n; z1 = 50;
%t A210027 t[n_] := t[n] = Flatten[Table[w*z - x*y, {w, a, b}, {x, a, b}, {y, a, b}, {z, a, b}]]
%t A210027 c[n_, k_] := c[n, k] = Count[t[n], k]
%t A210027 Table[c[n, 5], {n, 0, z1}]
%Y A210027 Cf. A210000, A209977.
%K A210027 nonn,easy,changed
%O A210027 0,4
%A A210027 _Clark Kimberling_, Mar 16 2012
