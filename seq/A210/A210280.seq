%S A210280 1,720,1779148800,148953184174080000,126983900296423931904000000,
%T A210280 614812159599342234168301977600000000,
%U A210280 11942354952042770431904585727413846016000000000,738615790595351500616546025309298211371540807680000000000
%N A210280 a(n) = (7n)!/7^n.
%H A210280 Vincenzo Librandi, <a href="/A210280/b210280.txt">Table of n, a(n) for n = 0..60</a>
%F A210280 E.g.f.: 1/(1-x^7/7).
%F A210280 a(n) ~ sqrt(2*Pi) * 7^(6*n+1/2) * n^(7*n+1/2) / exp(7*n). - _Amiram Eldar_, Jul 21 2026
%F A210280 From _Vaclav Kotesovec_, Jul 21 2026: (Start)
%F A210280 Sum_{n>=0} 1/a(n) = (exp(7^(1/7)) + 2*cos(7^(1/7)*cos(Pi/14)) / exp(7^(1/7)*sin(Pi/14)) + 2*exp(7^(1/7)*sin(3*Pi/14)) * cos(7^(1/7)*cos(3*Pi/14)) + 2*cos(7^(1/7)*sin(Pi/7)) / exp(7^(1/7)*cos(Pi/7)))/7.
%F A210280 Sum_{n>=0} (-1)^n/a(n) = (exp(-7^(1/7)) + 2*exp(7^(1/7)*sin(Pi/14)) * cos(7^(1/7)*cos(Pi/14)) + 2*cos(7^(1/7)*cos(3*Pi/14)) / exp(7^(1/7) * sin(3*Pi/14)) + 2*exp(7^(1/7)*cos(Pi/7)) * cos(7^(1/7)*sin(Pi/7)))/7. (End)
%t A210280 Table[(7 n)!/7^n, {n, 0, 10}] (* _Vincenzo Librandi_, Feb 15 2013 *)
%o A210280 (Magma) [Factorial(7*n)/7^n: n in [0..10]]; // _Vincenzo Librandi_, Feb 15 2013
