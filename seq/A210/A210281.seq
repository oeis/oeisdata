%U A210281 24899758399899222849902687670779904000000000,47355329866546908076714664639943599847875543040000000000,339030546095306135108015845996725535267113675537666539520000000000000
%N A210281 a(n) = (8n)!/8^n.
%H A210281 Vincenzo Librandi, <a href="/A210281/b210281.txt">Table of n, a(n) for n = 0..50</a>
%F A210281 E.g.f.: 1/(1-x^8/8).
%F A210281 From _Amiram Eldar_, Jul 21 2026: (Start)
%F A210281 a(n) ~ sqrt(Pi) * 2^(21*n+2) * n^(8*n+1/2) / exp(8*n).
%F A210281 Sum_{n>=0} 1/a(n) = (cos(2^(3/8)) + 2*cos(2^(-1/8))*cosh(2^(-1/8)) + cosh(2^(3/8)))/4.
%F A210281 Sum_{n>=0} (-1)^n/a(n) = (cos(2^(3/8)*sin(Pi/8))*cosh(2^(3/8)*cos(Pi/8)) + cos(2^(3/8)*cos(Pi/8))*cosh(2^(3/8)*sin(Pi/8)))/2. (End)
%t A210281 Table[(8 n)!/8^n, {n, 0, 10}] (* _Vincenzo Librandi_, Feb 15 2013 *)
%o A210281 (Magma) [Factorial(8*n)/8^n: n in [0..10]]; // _Vincenzo Librandi_, Feb 15 2013
