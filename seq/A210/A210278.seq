%T A210278 16976183027980227752723742720,132264293969742655099733137120296960,
%U A210278 2088743125114618199924764850166056689336320,61246577083125859615725138685776750112964471685120
%N A210278 a(n) = (5n)!/5^n.
%H A210278 Vincenzo Librandi, <a href="/A210278/b210278.txt">Table of n, a(n) for n = 0..90</a>
%F A210278 E.g.f.: 1/(1-x^5/5).
%F A210278 a(n) ~ sqrt(2*Pi) * 5^(4*n+1/2) * n^(5*n+1/2) / exp(5*n). - _Amiram Eldar_, Jul 21 2026
%F A210278 From _Vaclav Kotesovec_, Jul 21 2026: (Start)
%F A210278 Sum_{n>=0} 1/a(n) = (exp(5^(1/5)) + 2*cos(5^(9/20) / (2*sqrt(phi))) / exp( phi*5^(1/5)/2) + 2*exp(5^(1/5)/(2*phi)) * cos(5^(9/20) * sqrt(phi)/2))/5.
%F A210278 Sum_{n>=0} (-1)^n/a(n) = (exp(-5^(1/5)) + 2*cos(5^(9/20) * sqrt(phi)/2) / exp(5^(1/5)/(2*phi)) + 2*exp(5^(1/5)*phi/2) * cos(5^(9/20) / (2*sqrt(phi))))/5, where phi = A001622 is the golden ratio. (End)
%t A210278 Table[(5 n)!/5^n, {n, 0, 10}] (* _Vincenzo Librandi_, Feb 15 2013 *)
%t A210278 (* Alternative: *)
%t A210278 With[{nn=100},Take[CoefficientList[Series[1/(1-x^5/5),{x,0,nn}],x] Range[0,nn]!,{1,-1,5}]] (* _Harvey P. Dale_, May 27 2025 *)
%o A210278 (Magma) [Factorial(5*n)/5^n: n in [0..10]]; // _Vincenzo Librandi_, Feb 15 2013
