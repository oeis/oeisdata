%I A118045 #19 Mar 10 2026 04:23:05
%S A118045 1,3,2,9,8,3,26,28,15,4,73,86,57,24,5,191,250,192,96,35,6,500,696,567,
%T A118045 356,145,48,7,1234,1824,1683,1060,590,204,63,8,3051,4754,4392,3344,
%U A118045 1765,906,273,80,9,7201,11562,12084,8672,5895,2718,1316,352,99,10,16995,28720,29073,25108,15180,9576,3955,1832,441,120,11
%N A118045 Triangle T, read by rows, equal to a diagonal bisection of A118032 such that diagonal n of T equals diagonal 2*n+1 of A118032: T(n,k) = A118032(2*n+1-k,k); also equals the matrix product of A118032 and SHIFT_UP(A118032).
%H A118045 Paul D. Hanna, <a href="/A118045/b118045.txt">Table of n, a(n) for n = 0..5150 (rows 0..100)</a>
%e A118045 Triangle begins:
%e A118045   1;
%e A118045   3, 2;
%e A118045   9, 8, 3;
%e A118045   26, 28, 15, 4;
%e A118045   73, 86, 57, 24, 5;
%e A118045   191, 250, 192, 96, 35, 6;
%e A118045   500, 696, 567, 356, 145, 48, 7;
%e A118045   1234, 1824, 1683, 1060, 590, 204, 63, 8;
%e A118045   3051, 4754, 4392, 3344, 1765, 906, 273, 80, 9;
%e A118045   7201, 11562, 12084, 8672, 5895, 2718, 1316, 352, 99, 10;
%e A118045   ...
%e A118045 which is formed from the odd-indexed diagonals of triangle A118032, which starts:
%e A118045   1;
%e A118045   1, 1;
%e A118045   2, 2, 1;
%e A118045   3, 4, 3, 1;
%e A118045   6, 8, 6, 4, 1;
%e A118045   9, 14, 15, 8, 5, 1;
%e A118045   ...
%e A118045 Let U = SHIFT_UP(A118032), shifting columns of A118032 up 1 row and dropping the main diagonal, so that U =
%e A118045   1;
%e A118045   2, 2;
%e A118045   3, 4, 3;
%e A118045   6, 8, 6, 4;
%e A118045   9, 14, 15, 8, 5;
%e A118045   16, 28, 24, 24, 10, 6;
%e A118045   ...
%e A118045 Then the matrix product A118032*U equals this triangle.
%o A118045 (PARI) {A118032(n, k) = if(n<k||k<0, 0,  if(n==k, 1,  if(n==k+1, n, sum(i=k, (n+k)\2,  A118032((n+k)\2, i) * A118032(i+(n+k)%2, k) ) )))}
%o A118045 \\ Set size
%o A118045 N = 16
%o A118045 \\ Load matrix M = A118032
%o A118045 M = matrix(N+1,N+1,n,k,if(n>=k, A118032(n-1, k-1)))
%o A118045 \\ Load matrix U = SHIFT_UP(A118032)
%o A118045 U = matrix(N+1,N+1,n,k, if(n==N+1, A118032(n, k-1), if(n>=k, M[n+1,k])))
%o A118045 \\ Create this matrix T = M*U
%o A118045 T = M*U
%o A118045 \\ Print this triangle from T
%o A118045 for(n=0, N, for(k=0, n, print1(T[n+1, k+1], ", ")); print("")) \\ _Paul D. Hanna_, Mar 10 2026
%Y A118045 Cf. columns: A118046, A118047, A118048; A118049 (row sums).
%Y A118045 Cf. related triangles: A118032, A118040.
%K A118045 nonn,tabl
%O A118045 0,2
%A A118045 _Paul D. Hanna_, Apr 10 2006
