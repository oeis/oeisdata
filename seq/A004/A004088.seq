%S A004088 1,1,2,3,5,7,2,6,4,3,6,11,14,2,9,14,6,18,16,13,15,18,3,13,18,23,15,4,
%T A004088 19,20,15,20,24,9,7,24,31,19,14,18,24,24,20,18,25,25,24,23,24,23,16,
%U A004088 30,33,27,28,25,26,21,17,22,38,15,16,33,22,23,17,47,33,29,42,33,37,43,29,30,38
%N A004088 Sum of digits of number of partitions of n.
%C A004088 a(n) > log(n)/(7*log(log(n))) holds for almost all n (see Luca link). - _Shreyansh Jaiswal_, Apr 14 2026
%H A004088 Shreyansh Jaiswal, <a href="/A004088/b004088.txt">Table of n, a(n) for n = 0..1000</a>
%H A004088 Florian Luca, <a href="https://doi.org/10.1007/s00013-011-0350-2">On the number of nonzero digits of the partition function</a>, Archiv der Mathematik, Vol. 98, (2012), pp. 235-240.
%F A004088 a(n) = A007953(A000041(n)). - _Shreyansh Jaiswal_, Apr 08 2026
%e A004088 a(10) = 6 because A000041(10) = 42, and 4 + 2 = 6.
%t A004088 Total/@IntegerDigits[PartitionsP[Range[0,80]]] (* _Harvey P. Dale_, Feb 03 2015 *)
%o A004088 (Python)
%o A004088 from sympy.functions.combinatorial.numbers import partition
%o A004088 def A007953(n): return sum(int(d) for d in str(n)) #from A007953
%o A004088 def a(n): return A007953(partition(n)) # _Shreyansh Jaiswal_, Apr 08 2026
%o A004088 (PARI) a(n) = sumdigits(numbpart(n)); \\ _Michel Marcus_, Apr 08 2026
%Y A004088 Cf. A000041, A007953.
%K A004088 nonn,base
%O A004088 0,3
%A A004088 _N. J. A. Sloane_
