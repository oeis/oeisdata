%t A004779 A004779Q[k_] := StringContainsQ[IntegerString[k, 2], "000"];
%t A004779 Select[Range[200],A004779Q] (* _Paolo Xausa_, Apr 18 2026 *)
%o A004779 (PARI) is(n)=while(n>7,if(bitand(n,7)==0,return(1));n>>=1); 0 \\ _Charles R Greathouse IV_, Feb 11 2017
%o A004779 (Python)
%o A004779 def ok(n): return "000" in bin(n)
%o A004779 print([k for k in range(169) if ok(k)]) # _Michael S. Branicky_, Apr 18 2026
