%U A057840 348519,383913,531441,745339,823543,911853,1594323,2384883,3610523,3814857,4782969,5764801
%N A057840 Numbers k such that k | 8^k + 6^k + 4^k + 2^k + 1.
%t A057840 Select[ Range[ 10^6 ], Mod[ PowerMod[ 8, #, # ] + PowerMod[ 6, #, # ] + PowerMod[ 4, #, # ] + PowerMod[ 2, #, # ] + 1, # ] == 0 & ]
%o A057840 (PARI) is(k)=sum(i=1, 4, Mod(2*i, k)^k)==-1; \\ _Jinyuan Wang_, Jun 18 2026
%o A057840 (Python)
%o A057840 from itertools import count, islice
%o A057840 def A057840_gen(startvalue=1): # generator of terms >= startvalue
%o A057840     for k in count(max(startvalue,1)):
%o A057840         a, b = pow(2,k,k), pow(3,k,k)
%o A057840         c = ((a+1)*a+b+1)%k
%o A057840         c = c*a%k
%o A057840         if c == k-1:
%o A057840             yield k
%o A057840 A057840_list = list(islice(A057840_gen(),30)) # _Chai Wah Wu_, Jun 19 2026
