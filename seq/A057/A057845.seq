%N A057845 Numbers k such that k | 4^k + 2^k + 1.
%t A057845 Select[ Range[ 10^6 ], Mod[ PowerMod[ 4, #, # ] + PowerMod[ 2, #, # ] + 1, # ] == 0 & ]
%o A057845 (PARI) isok(n) = Mod(4,n)^n + Mod(2,n)^n == -1 \\ _Andrew Howroyd_, Oct 30 2025
%o A057845 (Python)
%o A057845 from itertools import count, islice
%o A057845 def A057845_gen(startvalue=1): # generator of terms >= startvalue
%o A057845     return filter(lambda k: (a:=pow(2,k,k))*(a+1)%k == k-1, count(max(startvalue,1)))
%o A057845 A057845_list = list(islice(A057845_gen(),30)) # _Chai Wah Wu_, Jun 19 2026
