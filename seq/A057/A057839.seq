%I A057839 #21 Jun 19 2026 01:00:42
%S A057839 1,31,198089,876881261,2026728077,24973890553
%N A057839 Numbers k such that k | 10^k + 8^k + 6^k + 4^k + 2^k + 1.
%C A057839 a(7) > 10^11. - _Jason Yuen_, Jan 18 2026
%t A057839 Select[ Range[ 10^6 ], Mod[ PowerMod[ 10, #, # ] + PowerMod[ 8, #, # ] + PowerMod[ 6, #, # ] + PowerMod[ 4, #, # ] + PowerMod[ 2, #, # ] + 1, # ] == 0 & ]
%o A057839 (Python)
%o A057839 def afind(limit):
%o A057839   for k in range(1, limit+1, 2):
%o A057839     if (1 + sum(pow(e, k, k) for e in [2, 4, 6, 8, 10])) % k == 0:
%o A057839       print(k, end=", ")
%o A057839 afind(10**6) # _Michael S. Branicky_, Apr 01 2021 after _Robert G. Wilson v_
%o A057839 (Python)
%o A057839 from itertools import count, islice
%o A057839 def A057839_gen(startvalue=1): # generator of terms >= startvalue
%o A057839     for k in count(max(startvalue,1)):
%o A057839         a2, a3 = pow(2,k,k), (pow(3,k,k)+pow(5,k,k)+1)%k
%o A057839         c = ((a2+1)*a2+a3)%k
%o A057839         c = c*a2%k
%o A057839         if c == k-1:
%o A057839             yield k
%o A057839 A057839_list = list(islice(A057839_gen(),30)) # _Chai Wah Wu_, Jun 19 2026
%o A057839 (PARI) is_ok(k)=(sum(j=1,5,Mod(2*j,k)^k) + 1)==0;  \\ _Joerg Arndt_, Apr 02 2021
