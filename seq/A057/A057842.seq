%N A057842 Numbers k such that k | 6^k + 4^k + 2^k + 1.
%C A057842 Numbers k that divide A074533(k)+1. - _Michel Marcus_, Oct 30 2025
%t A057842 Select[ Range[ 10^6 ], Mod[ PowerMod[ 6, #, # ] + PowerMod[ 4, #, # ] + PowerMod[ 2, #, # ] + 1, # ] == 0 & ]
%o A057842 (PARI) isok(n) = Mod(6,n)^n + Mod(4,n)^n + Mod(2,n)^n == -1 \\ _Andrew Howroyd_, Oct 30 2025
%o A057842 (Python)
%o A057842 from itertools import count, islice
%o A057842 def A057842_gen(startvalue=1): # generator of terms >= startvalue
%o A057842     for k in count(max(startvalue,1)):
%o A057842         a, b = pow(2,k,k), pow(3,k,k)
%o A057842         if a*(a+b+1)%k == k-1:
%o A057842             yield k
%o A057842 A057842_list = list(islice(A057842_gen(),7)) # _Chai Wah Wu_, Jun 19 2026
