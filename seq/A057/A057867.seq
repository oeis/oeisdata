%S A057867 180,56700,425675250,390769879500,21438612514068750,
%T A057867 1211517431782539131250,3952575621190533915703125,
%U A057867 28870481903812321637757079687500,923465669416292826066116829424218750,64875239172012679286579449799415644531250,2919353325120984561556431951248804296083984375
%N A057867 Sum_{k>=1} 1/(tanh(k*Pi) * k^(4n-1)) = Pi^(4n-1)*A057866(n)/a(n).
%D A057867 E. C. Titchmarsh, The Theory of Functions, 2nd ed., Oxford Univ. Press, 1939, p. 135.
%H A057867 Seiichi Manyama, <a href="/A057867/b057867.txt">Table of n, a(n) for n = 1..125</a>
%H A057867 Simon Plouffe, <a href="http://www.plouffe.fr/simon/inspired2.pdf">Identities inspired by Ramanujan Notebooks (part 2)</a>, April 2006.
%H A057867 Linas Vepštas, <a href="https://doi.org/10.1007/s11139-011-9335-9">On Plouffe's Ramanujan identities</a>, The Ramanujan Journal, Vol. 27 (2012), pp. 387-408; <a href="https://arxiv.org/abs/math/0609775">arXiv preprint</a>, arXiv:math/0609775 [math.NT], 2006-2010.
%H A057867 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/RiemannZetaFunction.html">Riemann Zeta Function</a>.
%F A057867 Sum_{k>0} 1/(tanh(k*Pi)k^(4n-1)) = Pi^(4n-1)*A057866(n)/a(n). - _Michael Somos_, Feb 11 2004
%F A057867 From _Jwalin Bhatt_, Apr 15 2026: (Start)
%F A057867 A057866(n)/a(n) = -(2^(4n-2)/(4n)!) * Sum_{j=0..2n} (-1)^j * binomial(4n, 2j) * B_{2j} * B_{4n-2j}, where B_k are the Bernoulli numbers (A027641/A027642).
%F A057867 Limit_{n->oo} (Pi^(4n-1)*A057866(n)/a(n)-coth(Pi)) / (zeta(4n-1)-1) = coth(2*Pi). (End)
%F A057867 a(n) = A394977(2n-1). - _Jwalin Bhatt_, Apr 28 2026
%e A057867 Sum_{k>0} 1/(tanh(k*Pi)k^3) = Pi^3*7/180;
%e A057867 Sum_{k>0} 1/(tanh(k*Pi)k^7) = Pi^7*19/56700.
%t A057867 Denominator[Table[2^(k-1)/(k+1)! Sum[(-1)^(n-1)Binomial[k+1, 2n]BernoulliB[k+1-2n]BernoulliB[2n], {n, 0, (k+1)/2}], {k, 3, 50, 4}]]
%o A057867 (Python)
%o A057867 from sympy import binomial, bernoulli, factorial
%o A057867 def a(n):
%o A057867     s = sum(
%o A057867         (-1)**j * binomial(4*n, 2*j) * bernoulli(4*n-2*j) * bernoulli(2*j)
%o A057867         for j in range(2*n + 1)
%o A057867     )
%o A057867     frac = -2**(4*n-2) * s / factorial(4*n)
%o A057867     return frac.denominator  # _Jwalin Bhatt_, Apr 15 2026.
%Y A057867 Cf. A027641, A027642, A057866 (numerators), A384962, A394977.
%K A057867 nonn,frac,changed
%O A057867 1,1
