%I A057866 #43 Apr 20 2026 01:07:33
%S A057866 7,19,1453,13687,7708537,4472029801,149780635937,11231299844779783,
%T A057866 3688053840923281541,2659842854283579394387,1228751826452728351300837,
%U A057866 67537532722660373286810600661,251492292317888012003479295207,25465609788816025420512226447159951
%N A057866 Sum_{k>=1} 1/(tanh(k*Pi) * k^(4n-1)) = Pi^(4n-1)*a(n)/A057867(n).
%D A057866 E. C. Titchmarsh, The Theory of Functions, 2nd ed., Oxford Univ. Press, 1939, p. 135. See Example 15.
%H A057866 Seiichi Manyama, <a href="/A057866/b057866.txt">Table of n, a(n) for n = 1..157</a>
%H A057866 Simon Plouffe, <a href="http://www.plouffe.fr/simon/inspired2.pdf">Identities inspired by Ramanujan Notebooks (part 2)</a>, April 2006.
%H A057866 Linas Vepštas, <a href="https://doi.org/10.1007/s11139-011-9335-9">On Plouffe's Ramanujan identities</a>, The Ramanujan Journal, Vol. 27 (2012), pp. 387-408; <a href="https://arxiv.org/abs/math/0609775">arXiv preprint</a>, arXiv:math/0609775 [math.NT], 2006-2010.
%H A057866 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/RiemannZetaFunction.html">Riemann Zeta Function</a>.
%F A057866 Numerator of coefficient of Pi^(4n-1) in Ramanujan-like series for zeta(4n-1).
%F A057866 From _Jwalin Bhatt_, Apr 15 2026: (Start)
%F A057866 a(n)/A057867(n) = -(2^(4n-2)/(4n)!) * Sum_{j=0..2n} (-1)^j * binomial(4n, 2j) * B_{2j} * B_{4n-2j}, where B_k are the Bernoulli numbers (A027641/A027642).
%F A057866 Limit_{n->oo} (Pi^(4n-1)*a(n)/A057867(n)-coth(Pi)) / (zeta(4n-1)-1) = coth(2*Pi). (End)
%e A057866 Sum_{k>=1} 1/(tanh(k*Pi)k^3) = Pi^3*7/180,
%e A057866 Sum_{k>=1} 1/(tanh(k*Pi)k^7) = Pi^7*19/56700.
%t A057866 Numerator[Table[2^(k-1)/(k+1)! Sum[(-1)^(n-1)Binomial[k+1, 2n]BernoulliB[k+1-2n]BernoulliB[2n], {n, 0, (k+1)/2}], {k, 3, 50, 4}]]
%o A057866 (Python)
%o A057866 from sympy import binomial, bernoulli, factorial
%o A057866 def a(n):
%o A057866     s = sum(
%o A057866         (-1)**j * binomial(4*n, 2*j) * bernoulli(4*n-2*j) * bernoulli(2*j)
%o A057866         for j in range(2*n + 1)
%o A057866     )
%o A057866     frac = -2**(4*n-2) * s / factorial(4*n)
%o A057866     return frac.numerator  # _Jwalin Bhatt_, Apr 15 2026
%Y A057866 Cf. A027641, A027642, A057867, A384962, A394976.
%K A057866 nonn,frac,changed
%O A057866 1,1
%A A057866 _Eric W. Weisstein_
