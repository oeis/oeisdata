%T A057255 78125,93025,129625,133475,190625,201605,265625,390625,465125,492575,
%U A057255 537715,953125,957695,1134905,1484375,1639375,1886425,1953125,2325625,3621875,4223335,4765625,5674525,7940675,8392075,8837375,9765625
%N A057255 Numbers k such that k | 7^k + 6^k + 5^k + 4^k + 3^k.
%t A057255 Select[ Range[ 10^6 ], Mod[ PowerMod[ 7, #, # ] + PowerMod[ 6, #, # ] + PowerMod[ 5, #, # ] + PowerMod[ 4, #, # ] + PowerMod[ 3, #, # ], # ] == 0 & ]
%t A057255 With[{c=Mod[Total[Table[PowerMod[k,#1,#1],{k,3,7}]],#1]==0&},Select[Range[10^6],c]] (* _Harvey P. Dale_, Mar 07 2026 *)
%o A057255 (Python)
%o A057255 def ok(k): return k and sum(pow(m, k, k) for m in range(3, 8))%k == 0
%o A057255 print([k for k in range(10**6) if ok(k)]) # _Michael S. Branicky_, Mar 08 2026
