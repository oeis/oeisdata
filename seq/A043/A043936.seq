%N A043936 Numbers k such that 0 and 5 occur juxtaposed in the base-8 representation of k but not of k+1.
%H A043936 Harvey P. Dale, <a href="/A043936/b043936.txt">Table of n, a(n) for n = 1..1000</a>
%t A043936 n05Q[n_]:=MemberQ[Sort/@Partition[IntegerDigits[n,8],2,1], {0,5}]; Select[ Range[1500],n05Q[#]&&!n05Q[#+1]&] (* _Harvey P. Dale_, May 07 2011 *)
%t A043936 SequencePosition[Table[If[SequenceCount[IntegerDigits[n,8],{0,5}]>0||SequenceCount[IntegerDigits[n,8],{5,0}]>0,1,0],{n,1500}],{1,0}][[;;,1]] (* _Harvey P. Dale_, May 14 2026 *)
