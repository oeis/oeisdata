%o A121057 (PARI) trga(nrows) = {for (n=1, nrows, for (m=1, n, print1(prime(n)^m*(prime(n) - 1)/2, ", ");); print(););} \\ _Michel Marcus_, Apr 11 2013
%o A121057 (PARI) row(n) = vector(n, k, prime(n)^k*(prime(n) - 1)/2); \\ _Michel Marcus_, May 01 2026
