%T A121893 58,60,62,65,66,68,69,70,74,75,76,77,78,82,84,85,86,87,88,91,92,93,94,
%U A121893 95,96,98,102,104,105,106,108,111,112,114,115,116,117,118,119,122
%N A121893 Composite integers not equal to k*[k or k+1 or k+2] where k is a natural number.
%H A121893 Robert Israel, <a href="/A121893/b121893.txt">Table of n, a(n) for n = 1..10000</a>
%p A121893 N:= 300: # for terms <= N
%p A121893 km:= floor(sqrt(N)):
%p A121893 sort(convert(remove(isprime,{$4..N}) minus {seq(k^2,k=1..km),seq(k*(k+1),k=1..km),seq(k*(k+2),k=1..km)}, list)); # _Robert Israel_, Mar 31 2026
