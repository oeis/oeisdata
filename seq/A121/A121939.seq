%I A121939 #24 May 27 2026 16:06:56
%S A121939 1,2,3,4,5,6,7,8,9,919,1881,8118,9229,10801,11711,12621,13531,14441,
%T A121939 15351,16261,17171,18081,21612,25152,27972,28882,29792,31513,33133,
%U A121939 41014,41114,41214,41314,41414,41514,41614,41714,41814,41914,51315,58285,61216,66266,71117
%N A121939 Palindromic numbers that contain the sum of their digits as a substring.
%H A121939 David A. Corneth, <a href="/A121939/b121939.txt">Table of n, a(n) for n = 1..10000</a> (first 2000 terms from Harvey P. Dale)
%H A121939 David A. Corneth, <a href="/A121939/a121939.gp.txt">PARI program</a>
%e A121939 From _David A. Corneth_, May 27 2026: (Start)
%e A121939 11711 is a term as 11711 is a palindrome and the sum of digits of 11711 is 11 and 11 is a substring of 11711.
%e A121939 123 is no term as it is no palindrome.
%e A121939 10901 is no term as the sum of digits of 10901 is 11 but 11 is no substring of 10901. (End)
%t A121939 Select[Table[n, {n, 100000}], Length[StringPosition[ToString[ # ], ToString[Plus @@ IntegerDigits[ # ]]]] > 0 && ToString[ # ] == StringReverse[ToString[ # ]] &]
%t A121939 (* Alternative: *)
%t A121939 Select[Range[60000],PalindromeQ[#]&&With[{idn=IntegerDigits[#]},SequenceCount[idn,IntegerDigits[Total[idn]]]]>0&] (* _Harvey P. Dale_, May 27 2026 *)
%o A121939 (PARI) \\ See Corneth link
%Y A121939 Palindromic subsequence of A052018.
%K A121939 nonn,easy,base
%O A121939 1,2
%A A121939 _Tanya Khovanova_, Sep 03 2006
