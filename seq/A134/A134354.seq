%I A134354 #14 May 25 2026 08:50:12
%S A134354 1,4,34,553,13929,504211,24804343,1592201163,129266762933,
%T A134354 12950610156346,1569397748147942,226278584786787356,
%U A134354 38281932323382964780,7510129222684066040577,1691120063240224327004643,433227358889999321792523782,125279419365525918256280791436
%N A134354 Integer nearest to expression 2*Pi*n^(2*n + 1)*e^(-2*n).
%C A134354 Integers in this sequence are <= (n!)^2 (see A001044).
%F A134354 a(n) = round(2*Pi*n^(2*n + 1)*e^(-2*n)).
%t A134354 Table[Round[2 Pi n^(2 n + 1)E^(-2 n)], {n, 1, 30}]
%o A134354 (Python)
%o A134354 import mpmath
%o A134354 from mpmath import iv
%o A134354 def a(n):
%o A134354     dps = 50
%o A134354     while True:
%o A134354         iv.dps = mpmath.mp.dps = dps
%o A134354         v = 2 * iv.pi * (iv.mpf(n) ** (2 * n + 1)) * iv.exp(-2 * n)
%o A134354         lo_raw, hi_raw = v._mpi_
%o A134354         lo_round = int(mpmath.floor(mpmath.mpf(lo_raw) + 0.5))
%o A134354         hi_round = int(mpmath.floor(mpmath.mpf(hi_raw) + 0.5))
%o A134354         if lo_round == hi_round:
%o A134354             return lo_round
%o A134354 dps *= 2  # _Falk Hüffner_, May 25 2026
%Y A134354 Cf. A001044, A134354.
%K A134354 nonn
%O A134354 1,2
%A A134354 _Artur Jasinski_, Oct 22 2007
%E A134354 a(12)-a(15) corrected and a(16)-a(17) added by _Falk Hüffner_, May 25 2026
