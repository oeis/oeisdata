%S A097905 1,2,1,6,3,2,24,3,8,3,120,15,40,15,24,720,45,80,45,144,5,5040,315,560,
%T A097905 315,1008,35,720,40320,315,4480,315,8064,35,5760,315,362880,2835,4480,
%U A097905 2835,72576,35,51840,2835,4480,3628800,14175,44800,14175,145152,175,518400,14175,44800,567
%N A097905 Triangle where T(n,m) = largest divisor of n! coprime to m.
%C A097905 Right edge of triangle is sequence A095996.
%F A097905 T(n,m) = Sum_{d|n!} sigma(n!/d)*mu(d)*gcd(d,m). - _Ridouane Oudra_, Jun 13 2026
%e A097905 T(6,3) = 80 because 80 is largest divisor of 720 which is coprime to 3.
%e A097905 Triangle begins:
%e A097905        1;
%e A097905        2,    1;
%e A097905        6,    3,    2;
%e A097905       24,    3,    8,    3;
%e A097905      120,   15,   40,   15,    24;
%e A097905      720,   45,   80,   45,   144,  5;
%e A097905     5040,  315,  560,  315,  1008, 35,   720;
%e A097905    40320,  315, 4480,  315,  8064, 35,  5760,  315;
%e A097905   362880, 2835, 4480, 2835, 72576, 35, 51840, 2835, 4480;
%e A097905   ...
%p A097905 seq(seq(denom(m^n/n!),m=1..n),n=1..11); # _Vladeta Jovovic_, May 03 2005
%t A097905 Flatten[Table[Table[Select[Divisors[n! ], GCD[ #,m]==1&][[ -1]], {m,1,n}],{n,1, 10}]] (* _Stefan Steinerberger_, Nov 09 2007 *)
%o A097905 (Python)
%o A097905 from math import factorial, isqrt, comb
%o A097905 from sympy import factorint
%o A097905 from sympy.ntheory.factor_ import digits
%o A097905 def A097905_T(n,m):
%o A097905     k = factorial(n)
%o A097905     for p, e in factorint(m).items():
%o A097905         k //= p**min(e*n,(n-sum(digits(n,p)[1:]))//(p-1))
%o A097905     return k
%o A097905 def A097905(m):
%o A097905     a = (n:=isqrt(k:=m<<1))+(k>n*(n+1))
%o A097905     return A097905_T(a,m-comb(a,2)) # _Chai Wah Wu_, Jun 12 2026
%Y A097905 Cf. A095996, A000142, A008683, A000203.
%K A097905 nonn,tabl
