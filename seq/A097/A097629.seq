%I A097629 #66 Jun 22 2026 11:42:24
%S A097629 1,2,12,128,2000,41472,1075648,33554432,1224440064,51200000000,
%T A097629 2414538435584,126806761930752,7340688973975552,464436530178424832,
%U A097629 31886460000000000000,2361183241434822606848,187591757103747287810048,15917322219892801768783872
%N A097629 a(n) = 2*(2*n)^(n-2).
%C A097629 Number of all unrooted directed trees on n nodes.
%C A097629 Ditrees are well-colored directed trees. Well-colored means, each green vertex has at least a red child, each red vertex has no red child.
%H A097629 G. C. Greubel, <a href="/A097629/b097629.txt">Table of n, a(n) for n = 1..352</a>
%H A097629 Federico Ardila, Matthias Beck, and Jodi McWhirter, <a href="https://arxiv.org/abs/2004.02952">The Arithmetic of Coxeter Permutahedra</a>, arXiv:2004.02952 [math.CO], 2020. See p. 10.
%H A097629 Cyril Banderier, Jean-Marie Le Bars, and Vlady Ravelomanana, <a href="https://arxiv.org/abs/math/0411138">Generating functions for kernels of digraphs</a>, arXiv:math/0411138 [math.CO], 2004.
%H A097629 Vsevolod Gubarev, <a href="https://arxiv.org/abs/1811.08219">Rota-Baxter operators on a sum of fields</a>, arXiv:1811.08219 [math.RA], 2018.
%H A097629 Pamela E. Harris, J. Carlos Martínez Mori, and Alexander N. Wilson, <a href="https://gja.intrasci.net/article_25169_8de251feae057b8675fb551e684a295c.pdf">Inducing Parking Spaces to the Hyperoctahedral Group</a>, Galois J. Alg. 3(1) (2027), 26-50. See pp. 35 (Theorem 3.8), 47.
%H A097629 Jean-Christophe Novelli and Jean-Yves Thibon, <a href="https://arxiv.org/abs/0806.3682">Free quasi-symmetric functions and descent algebras for wreath products, and noncommutative multi-symmetric functions</a> arXiv:0806.3682 [math.CO], 2008. See also <a href="https://doi.org/10.1016/j.disc.2010.09.008">Disc. Math.</a> 310 (2010), No. 24, 3584-3606.
%H A097629 Jean-Christophe Novelli and Jean-Yves Thibon, <a href="https://arxiv.org/abs/1209.5959">Duplicial algebras and Lagrange inversion</a>, arXiv preprint arXiv:1209.5959 [math.CO], 2012.
%H A097629 Jean-Baptiste Priez and Aladin Virmaux, <a href="https://arxiv.org/abs/1411.4161">Non-commutative Frobenius characteristic of generalized parking functions: Application to enumeration</a>, arXiv:1411.4161 [math.CO], 2014-2015.
%F A097629 E.g.f.: A(x) = B(x)-B(x)^2, B(x) = e.g.f. of A052746 or A(x) = C(2*x)/2, C(x) = e.g.f. of A000272.
%F A097629 E.g.f. satisfies: A(x) = 1 + 2*Sum_{n>=1} x^(2*n-1)/(2*n-1)! * A(x)^((4*n-1)/2) when offset=0: A(x) = Sum_{n>=0} a(n)*x^n/n!. - _Paul D. Hanna_, Sep 07 2012
%F A097629 E.g.f. satisfies: A(x) = 1/A(-x*A(x)^2) when offset=0. - _Paul D. Hanna_, Sep 07 2012
%F A097629 a(n) = (1/n) * Sum_{k=0..n-1} k!*Stirling2(n-1,k)*binomial(2*n,k). - _Vladimir Kruchinin_, Nov 19 2014
%F A097629 E.g.f.: -LambertW(-2*x)*(1+LambertW(-2*x)/2)/2. - _Vaclav Kotesovec_, Dec 08 2014
%F A097629 a(n) = A052746(n)/n. - _Alois P. Heinz_, Jun 22 2026
%t A097629 Table[2*(2*n)^(n - 2), {n, 1, 50}] (* _G. C. Greubel_, Nov 15 2017 *)
%t A097629 (* Alternative: *)
%t A097629 With[{nmax = 40}, CoefficientList[Series[-LambertW[-2*x]*(1+LambertW[-2*x]/2)/2, {x, 0, nmax}], x]*Range[0, nmax]!] (* _G. C. Greubel_, Nov 15 2017 *)
%o A097629 (PARI) /* E.g.f. when offset=0 satisfies: */
%o A097629 {a(n)=local(A=1+2*x);for(i=1,21,A=1+2*sum(n=1,21,x^(2*n-1)/(2*n-1)!*A^((4*n-1)/2))+x*O(x^n));n!*polcoeff(A,n)} \\ _Paul D. Hanna_, Sep 07 2012
%o A097629 for(n=0,20,print1(a(n),", "))
%o A097629 (Maxima) a(n):=sum(k!*stirling2(n-1,k)*binomial(2*n,k),k,0,n-1)/(n); /* _Vladimir Kruchinin_, Nov 19 2014 */
%o A097629 (Magma) [1] cat [2*(2*n)^(n-2): n in [2..20]]; // _Vincenzo Librandi_, Nov 19 2014
%o A097629 (PARI) my(x='x+O('x^50)); Vec(serlaplace(-lambertw(-2*x)*(1 + lambertw(-2*x)/2)/2)) \\ _G. C. Greubel_, Nov 15 2017
%Y A097629 Equals (1/2) A038058 = A097630(n) + A097631(n).
%Y A097629 Cf. A052746, A097627.
%K A097629 nonn,easy
%O A097629 1,2
%A A097629 _Ralf Stephan_, Aug 17 2004
