%I A035000 #20 Apr 28 2026 21:11:06
%S A035000 1,3,6,7,10,15,16,19,21,28,30,36,45,50,51,55,66,77,78,90,91,105,112,
%T A035000 120,126,136,141,153,156,161,171,190,210,231,253,266,275,276,300,325,
%U A035000 351,352,357,378,393,406,414,435,442,465,496,504,528,546,561,595,615
%N A035000 Nontrivial trinomial coefficients.
%D A035000 L. Comtet, Advanced Combinatorics, Reidel, 1974, p. 78.
%H A035000 Sean A. Irvine, <a href="https://github.com/archmageirvine/joeis/blob/master/src/irvine/oeis/a035/A035000.java">Java program</a> (github)
%F A035000 1 plus T(n,k) for n >= 2 and 2 <= k <= n, duplicates removed and sorted, where T(n,k) is the triangle of trinomial coefficients (A027907). - _Chai Wah Wu_, Apr 27 2026
%F A035000 a(n) = n^2/2 - b*n^(5/3) - c*n^(3/2) + O(n^(7/5)), where b = 3^(1/3) and c = 12^(1/4). - _Charles R Greathouse IV_, Apr 28 2026
%o A035000 (Python)
%o A035000 from itertools import count, islice
%o A035000 from math import comb
%o A035000 from heapq import heappop, heappush
%o A035000 def A035000_gen(): # generator of terms
%o A035000     h, hset = [1], {1}
%o A035000     for n in count(2):
%o A035000         yield heappop(h)
%o A035000         for k in range(2,n+1):
%o A035000             t = sum(comb(n,m:=2*i+n-k)*comb(m,i) for i in range((k>>1)+1))
%o A035000             if t not in hset:
%o A035000                 heappush(h,t)
%o A035000                 hset.add(t)
%o A035000 A035000_list = list(islice(A035000_gen(),57)) # _Chai Wah Wu_, Apr 27 2026
%o A035000 (PARI) T(n, k) = sum(i = 0, k\2, binomial(n, 2*i + n - k) * binomial(2*i + n - k, i))
%o A035000 list(lim)=lim\=1; my(v=List([1])); for(n=2,(sqrtint(8*lim+1)-1)\2, for(k=2,n, my(t=T(n,k)); if(t>lim, break); listput(v,t))); Set(v) \\ _Charles R Greathouse IV_, Apr 28 2026
%Y A035000 Cf. A027907.
%K A035000 nonn,changed
%O A035000 1,2
%A A035000 _Erich Friedman_
