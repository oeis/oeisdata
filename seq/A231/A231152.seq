%I A231152 #23 Mar 19 2026 23:39:21
%S A231152 1,2,2,2,2,3,3,3,4,4,4,5,5,5,6,6,7,7,7,8,8,8,9,9,9,10,10,10,11,11,11,
%T A231152 12,12,13,13,13,14,14,14,15,15,16,16,16,17,17,17,18,18,19,19,19,20,20,
%U A231152 20,21,21,21,22,22,22,23,23,24,24,24,25,25,26,26,26,27,27,27,28,28,29,29,29,30,30
%N A231152 Least integer k such that prime(n+1) + ... + prime(n+k) > prime(1) + ... + prime(n).
%C A231152 a(n) is the least k such that 2*s(n) < s(n+k), where s(n) is the n-th partial sum of primes.
%H A231152 Robert Israel, <a href="/A231152/b231152.txt">Table of n, a(n) for n = 1..10000</a>
%F A231152 a(n) = A231153(n) + 1.
%e A231152 5 <= 2 + 3 < 5 + 7, so a(2) = 2.
%e A231152 19 + 23 <= 2 + 3 + 5 + 7 + 11 + 13 + 17 < 19 + 23 + 27, so a(7) = 3.
%p A231152 P:= [seq(ithprime(i),i=1..10^5)]:
%p A231152 S:= ListTools:-PartialSums(P):
%p A231152 f:= proc(n) local j;
%p A231152     ListTools:-BinaryPlace(S,2*S[n]+1/2)+1-n;
%p A231152 end proc:
%p A231152 map(f, [$1..200]); # _Robert Israel_, Mar 15 2026
%t A231152 test = 0; u = Table[test = test + Prime[n]; tmp = 0; NestWhile[# + 1 &, n, test >= (tmp = tmp + Prime[#+1]) &] - n, {n, 1, 80}]; u + 1  (* _Peter J. C. Moses_, Nov 02 2013 *)
%o A231152 (PARI) a(n) = my(s=vecsum(primes(n)), k=1); while (vecsum(primes(n+k)) - 2*s <= 0, k++); k; \\ _Michel Marcus_, Mar 18 2026
%Y A231152 Cf. A007504, A231151, A231153.
%K A231152 nonn,easy,changed
%O A231152 1,2
%A A231152 _Clark Kimberling_, Nov 09 2013
%E A231152 Corrected by _Robert Israel_, Mar 15 2026
