%I A231388 #17 Jul 08 2026 01:00:07
%S A231388 1,2,4,8,16,32,56,64,112,128,224,256,272,392,448,512,544,728,784,896,
%T A231388 992,1024,1088,1456,1568,1792,1904,1984,2048,2176,2408,2744,2912,3136,
%U A231388 3584,3808,3968,4096,4352,4624,4816,5096,5488,5824,6176,6272,6944,7168,7616
%N A231388 Numbers n dividing the Lucas sequence u(n), defined by u(i) = 2*u(i-1) - 3*u(i-2) with initial conditions u(0)=0, u(1)=1.
%C A231388 Except for 1 and 2, all other terms are divisible by 4. This sequence contains every nonnegative power of 2.
%H A231388 C. Smyth, <a href="https://cs.uwaterloo.ca/journals/JIS/VOL13/Smyth/smyth2.html"> The terms in Lucas sequences divisible by their indices</a>, Journal of Integer Sequences, Vol.13 (2010), Article 10.2.4.
%e A231388 For n=0,...,5 we have u(n)=0,1,2,1,-4,-11. Clearly n=1,2,4 divide their respective u(n).
%t A231388 nn = 10000; s = LinearRecurrence[{2, -3}, {1, 2}, nn]; t = {}; Do[If[Mod[s[[n]], n] == 0, AppendTo[t, n]], {n, nn}]; t (* _T. D. Noe_, Nov 08 2013 *)
%o A231388 (Python)
%o A231388 from itertools import count, islice
%o A231388 def A231388_gen(): # generator of terms
%o A231388     def u(n):
%o A231388         a, b, c, d, a2, b2, c2, d2 = 2, -3, 1, 0, 1, 0, 0, 1
%o A231388         for x in bin(n)[2:]:
%o A231388             e, f = b2*c2%n, k if (k:=a2+d2)<n else k-n
%o A231388             a2, b2, c2, d2 = (a2*a2+e)%n, b2*f%n, c2*f%n, (d2*d2+e)%n
%o A231388             if x=='1':
%o A231388                 a2, b2, c2, d2 = (a2*a+b2*c)%n, (a2*b+b2*d)%n, (c2*a+d2*c)%n, (c2*b+d2*d)%n
%o A231388         return c2
%o A231388     yield from (1,2)
%o A231388     for i in count(4,4):
%o A231388         if not u(i)%i: yield i
%o A231388 A231388_list = list(islice(A231388_gen(),30)) # _Chai Wah Wu_, Jul 07 2026
%Y A231388 Cf. A000079 (powers of 2 (subsequence)).
%Y A231388 Cf. A088137 (Lucas sequence).
%K A231388 nonn,changed
%O A231388 1,2
%A A231388 _Thomas M. Bridge_, Nov 08 2013
