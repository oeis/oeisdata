%S A147516 1,3,9,15,27,45,81,105,135,225,243,315,405,675,729,945,1155,1215,1575,
%T A147516 2025,2187,2835,3375,3465,3645,4725,6075,6561,8505,10125,10395,10935,
%U A147516 11025,14175,15015,17325,18225,19683,23625,25515,30375,31185,32805
%N A147516 List giving least odd integer of each prime signature.
%C A147516 All numbers of the form 3^k2*5^k3*...*p_n^k_n, where k2 >= k3 >= ... >= k_n, sorted.
%H A147516 Ray Chandler, <a href="/A147516/b147516.txt">Table of n, a(n) for n = 1..10000</a>
%H A147516 David Ryan, <a href="https://arxiv.org/abs/1603.08904">Mathematical Harmony Analysis</a>, arXiv preprint arXiv:1603.08904 [cs.SD], 2016-2017.
%F A147516 Sum_{n>=1} 1/a(n) = Product_{n>=2} 1/(1 - 1/A070826(n)) = 1.6241170949... - _Amiram Eldar_, Oct 20 2020
%t A147516 PrimeExponents[n_] := FactorInteger[n][[All, 2]]; lpe = {}; A147516 = {1}; Do[pe = PrimeExponents[n] // Sort; If[FreeQ[lpe, pe], AppendTo[lpe, pe]; AppendTo[A147516, n]], {n, 3, 40000, 2}]; A147516 (* _Jean-François Alcover_, Jan 27 2015, after _Robert G. Wilson v_ *)
%o A147516 (PARI) is(n)=my(k=oo, t); forprime(p=3,, t=valuation(n, p); if(t>k, return(0), k=t); if(k, n/=p^k, return(n==1))) \\ _Charles R Greathouse IV_, Aug 20 2015
%o A147516 (Python)
%o A147516 from functools import lru_cache
%o A147516 from itertools import count
%o A147516 from sympy import prime, integer_log, primorial
%o A147516 from oeis_sequences.OEISsequences import bisection
%o A147516 def A147516(n):
%o A147516     @lru_cache(maxsize=None)
%o A147516     def g(x, m, j): return sum(g(x//(prime(m)**i), m-1, i) for i in range(j,integer_log(x, prime(m))[0]+1)) if m>2 else max(0,integer_log(x,3)[0]+1-j)
%o A147516     def f(x):
%o A147516         c = n-1+x
%o A147516         for k in count(2):
%o A147516             if primorial(k)>(x<<1):
%o A147516                 break
%o A147516             c -= g(x,k,1)
%o A147516         return c
%o A147516     return bisection(f,n,n) # _Chai Wah Wu_, Mar 23 2026
%o A147516 (Python)
%o A147516 from itertools import islice
%o A147516 from heapq import heappop, heappush
%o A147516 from sympy import factorint, prevprime, nextprime
%o A147516 def A147516_gen(): # generator of terms when the first n terms are desired
%o A147516     h, hset = [1], {1}
%o A147516     while True:
%o A147516         yield (m:=heappop(h))
%o A147516         ps = factorint(m)
%o A147516         for p in ps:
%o A147516             if p == 3 or ps[prevprime(p)]>ps[p]:
%o A147516                 mp = m*p
%o A147516                 if mp not in hset:
%o A147516                     heappush(h,mp)
%o A147516                     hset.add(mp)
%o A147516         mp = m*nextprime(max(ps.keys(),default=2))
%o A147516         if mp not in hset:
%o A147516             heappush(h,mp)
%o A147516             hset.add(mp)
%o A147516 A147516_list = list(islice(A147516_gen(),40)) # _Chai Wah Wu_, Mar 23 2026
