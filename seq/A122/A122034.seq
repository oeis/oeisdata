%T A122034 58896881,61953641,64166273,70045993,70735409,76033889,82761857,
%U A122034 95049881,102087721,120618073,127318537,131584841,177350489,184799233
%N A122034 Prime numbers with five partitions into a square and cube.
%C A122034 There are 34958 terms <= 10^15. - _Carlo Corti_, May 28 2026
%H A122034 Carlo Corti, <a href="/A122034/b122034.txt">Table of n, a(n) for n = 1..10000</a>
%H A122034 Carlo Corti, <a href="/A122034/a122034.txt">Table of n, a(n), and the five representations a(n) = x^2 + y^3 for n=1..34958</a>
%H A122034 Carlo Corti, <a href="https://github.com/carcorti/A122034">Computational extension of OEIS sequence A122034</a>
%F A122034 p = a^2 + b^3 for exactly five different pairs {a,b} of positive integers.
%e A122034 { p      {a1,b1}..{a5,b5} }
%e A122034 {3193361,{1769,40},{1606,85},{1481,100},{1047,128},{285,146}},
%e A122034 {4251817,{2061,16},{2035,48},{1005,148},{618,157},{17,162}},
%e A122034 {4297609,{1981,72},{1799,102},{1772,105},{1603,120},{654,157}},
%e A122034 {17969129,{4239,2},{4002,125},{3945,134},{3924,137},{627,260}},
%e A122034 {22618657,{4751,36},{4643,102},{4629,106},{4132,177},{3183,232}},
%e A122034 {25266041,{4693,148},{4482,173},{4065,206},{3552,233},{2453,268}}.
%o A122034 (PARI) cuberootfloor(n) = {my(r = sqrtnint(n, 3)); while((r+1)^3 <= n, r++); while(r^3 > n, r--); r}
%o A122034 isA122034(p) = {if(!isprime(p), return(0)); my(c = 0); for(b = 1, cuberootfloor(p-1), if(issquare(p - b^3), c++; if(c > 5, return(0)))); c == 5}
%o A122034 \\ Returns 1 if p is in A122034, 0 otherwise.
%o A122034 \\ _Carlo Corti_, May 28 2026
