%T A122179 0,3,0,0,0,2,0,1,0,1,1,0,0,4,0,1,0,1,0,2,0,2,0,0,0,4,0,0,1,3,0,1,0,1,
%U A122179 0,1,0,6,0,0,1,1,0,1,0,4,1,0,0,4,0,0,0,2,0,4,0,1,0,0,0,6,0,1,1,3,0,1,0,2,1
%N A122179 Number of ways to write n as n = x*y*z with 1<x<=y<=z<n.
%C A122179 x,y,z are proper factors of n. a(n) > 0 iff n is a term of A033942; a(n) = 0 iff n is a term of A037143.
%C A122179 By Burnside on S3: nondecreasing triples with x*y*z = n give (A007425(n) + 3*A046951(n) + 2*A010057(n))/6; subtract A038548(n) to exclude triples containing 1. - _Felix Huber_, May 27 2026
%H A122179 Felix Huber, <a href="/A122179/b122179.txt">Table of n, a(n) for n = 1..10000</a> (terms 1..2048 from Antti Karttunen, terms 2049..8192 from Seiichi Manyama)
%H A122179 Wikipedia, <a href="https://en.wikipedia.org/wiki/Burnside%27s_lemma">Burnside's lemma</a>
%F A122179 a(n) = (A007425(n) + 3*A046951(n) + 2*A010057(n))/6 - A038548(n) = A034836(n) - A038548(n). - _Felix Huber_, May 27 2026
%e A122179 a(24) = 2 because 24 = 2*2*6 = 2*3*4, two products of three proper factors of 24.
%p A122179 A122179 := proc(n)
%p A122179     local i, l, x;
%p A122179     l := [seq(i[2], i in ifactors(n)[2])];
%p A122179     (mul(binomial(x + 2, 2), x in l) + 3*mul(floor(x/2) + 1, x in l) + 2*`if`(andmap(x -> x mod 3 = 0, l), 1, 0))/6 - ceil(mul(x + 1, x in l)/2);
%p A122179 end proc:
%p A122179 seq(A122179(n), n = 1 .. 88); # _Felix Huber_, May 27 2026
%o A122179 (PARI) for(n=1,105, t=0; for(x=2,n-1, for(y=x,n-1, for(z=y,n-1, if(x*y*z==n, t++)))); print1(t,", "))
%o A122179 (PARI) A122179(n) = { my(s=0); fordiv(n, x, if((x>1)&&(x<n),for(y=x, n-1, for(z=y, n-1, if(x*y*z==n, s++))))); (s); }; \\ _Antti Karttunen_, Aug 24 2017
%o A122179 (Python)
%o A122179 from math import prod, comb
%o A122179 from sympy import factorint
%o A122179 def A122179(n):
%o A122179     f = factorint(n).values()
%o A122179     return (prod(comb(e+2,2) for e in f)+3*prod((e>>1)+1 for e in f)+((not any(e%3 for e in f))<<1))//6-(prod(e+1 for e in f)+1>>1) # _Chai Wah Wu_, May 28 2026
