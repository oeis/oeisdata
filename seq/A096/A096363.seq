%I A096363 #25 Mar 29 2026 08:55:04
%S A096363 60,300,1500,15000,150000,1500000,15000000,150000000,1500000000,
%T A096363 15000000000,150000000000,1500000000000,15000000000000,
%U A096363 150000000000000,1500000000000000,15000000000000000,150000000000000000,1500000000000000000,15000000000000000000,150000000000000000000
%N A096363 Length of repeating cycle of the final n digits in the Fibonacci sequence.
%C A096363 Pisano periods pi(10^(n-1)).
%H A096363 Daniel Lance Herrick, <a href="https://www.fq.math.ca/Scanned/11-5/herrick.pdf">On the Periodicity of the Terminal Digits in the Fibonacci Sequences</a>, The Fibonacci Quarterly, Vol. 11, No. 5, page 535.
%H A096363 Dov Jarden, <a href="https://www.fq.math.ca/Scanned/1-4/jarden.pdf">On the Periodicity of the Last Digits of the Fibonacci Numbers</a>, The Fibonacci Quarterly, Vol. 1, No. 4, page 21.
%H A096363 Ron Knott, <a href="https://r-knott.surrey.ac.uk/Fibonacci/fibmaths.html#cycles">The final digits</a>.
%H A096363 Eric Weisstein's World of Mathematics, <a href="https://mathworld.wolfram.com/PisanoPeriod.html">Pisano Period</a>.
%H A096363 <a href="/index/Rec#order_01">Index entries for linear recurrences with constant coefficients</a>, signature (10).
%F A096363 a(n) = A001175(A011557(n)).
%F A096363 From _Elmo R. Oliveira_, Mar 28 2026: (Start)
%F A096363 G.f.: 60*x*(1 - 5*x - 25*x^2)/(1 - 10*x).
%F A096363 E.g.f.: (3/2)*(exp(10*x) - 1) + 15*x*(3 + 5*x).
%F A096363 a(n) = 15*10^(n-1) for n > 2.
%F A096363 a(n) = 10*a(n-1) for n > 3.
%F A096363 a(n) = 5*A114307(n) = 3*A216099(n+1). (End)
%t A096363 Join[{60, 300},LinearRecurrence[{10},{1500},14]] (* _Ray Chandler_, Aug 09 2015 *)
%o A096363 (Haskell)
%o A096363 a096363 = a001175 . (10 ^)  -- _Reinhard Zumkeller_, Jan 16 2014
