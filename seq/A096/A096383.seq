%I A096383 #25 Jun 20 2026 04:37:23
%S A096383 84,240,486,840,1320,1944,2730,3696,4860,6240,7854,9720,11856,14280,
%T A096383 17010,20064,23460,27216,31350,35880,40824,46200,52026,58320,65100,
%U A096383 72384,80190,88536,97440,106920,116994,127680,138996,150960,163590,176904,190920,205656,221130
%N A096383 Area of the Pythagorean triangle a = u^2 - v^2 (cf. A096382) when v = 3, u = 4, 5, 6, ...
%C A096383 The area of a Pythagorean triangle of sides a < b < c is A = (1/2)*ab. Substituting a = u^2 - v^2, b = 2uv into A and simplifying, we get A = uv(v^2 - u^2).
%C A096383 When v = 1 except for the leading zeros, we get A007531. Since the sides a,b of Pythagorean triple triangles are of opposite parity, the area will always be an integer.
%H A096383 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (4,-6,4,-1).
%F A096383 a(n) = (n-3)*(n*3)*(n+3), n >= 4. - _Zerinvary Lajos_, Mar 05 2007
%F A096383 From _Harvey P. Dale_, Aug 28 2011: (Start)
%F A096383 a(n) = 4*a(n-1)-6*a(n-2)+4*a(n-3)- a(n-4); a(4)=84, a(5)=240, a(6)=486, a(7)=840.
%F A096383 With offset 0, g.f.: (6*x*(5*x-16)+84)/(x-1)^4. (End)
%F A096383 From _Amiram Eldar_, Jun 20 2026: (Start)
%F A096383 Sum_{n>=4} 1/a(n) = 73/3240.
%F A096383 Sum_{n>=4} (-1)^n/a(n) = 2*log(2)/27 - 137/3240. (End)
%p A096383 seq((n-3)*(n*3)*(n+3), n=3..38); # _Zerinvary Lajos_, Mar 05 2007
%t A096383 Table[(n-3)(3n)(n+3),{n,4,40}] (* _Harvey P. Dale_, Aug 28 2011 *)
%t A096383 (* Alternative: *)
%t A096383 LinearRecurrence[{4,-6,4,-1},{84,240,486,840},40] (* _Harvey P. Dale_, Aug 28 2011 *)
%o A096383 (PARI) areagen(n,u) = for(v=u+1,n,print1(u*v*(v^2-u^2)","))
%Y A096383 Cf. A007531, A096382.
%K A096383 nonn,easy,changed
%O A096383 4,1
%A A096383 _Cino Hilliard_, Aug 05 2004
%E A096383 Name and offset corrected and more terms added by _Amiram Eldar_, Jun 20 2026
