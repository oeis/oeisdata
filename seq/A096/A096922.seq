%N A096922 Numbers m for which there is a unique k such that m = k + (product of nonzero digits of k).
%H A096922 Chris R. Rehmann, <a href="/A096922/b096922.txt">Table of n, a(n) for n = 1..10000</a>
%H A096922 P. A. Loomis, <a href="http://facstaff.bloomu.edu/ploomis/sequences.html">An Interesting Family of Iterated Sequences</a>
%H A096922 P. A. Loomis, <a href="http://facstaff.bloomu.edu/ploomis/itseq4.ps">An Introduction to Digit Product Sequences</a>, J. Rec. Math., 32 (2003-2004), 147-151.
%H A096922 P. A. Loomis, <a href="/A063108/a063108.pdf">An Introduction to Digit Product Sequences</a>, J. Rec. Math., 32 (2003-2004), 147-151. [Annotated archived copy]
%H A096922 <a href="/index/Coi#Colombian">Index entries for Colombian or self numbers and related sequences</a>
%e A096922 21 is the unique k such that k + (product of nonzero digits of k) = 23, hence 23 is a term.
%t A096922 f[n_] := Block[{s = Sort[ IntegerDigits[n]]}, While[ s[[1]] == 0, s = Drop[s, 1]]; n + Times @@ s]; t = Table[0, {200}]; Do[ a = f[n]; If[a < 200, t[[a]]++ ], {n, 200}]; Select[ Range[ 200], t[[ # ]] == 1 &] (* _Robert G. Wilson v_, Jul 16 2004 *)
%o A096922 (PARI) addpnd(n)=local(k,s,d);k=n;s=1;while(k>0,d=divrem(k,10);k=d[1];s=s*max(1,d[2]));n+s
%o A096922 {c=1;z=160;v=vector(z);for(n=1,z+1,k=addpnd(n);if(k<=z,v[k]=v[k]+1));for(j=1,length(v),if(v[j]==c,print1(j,",")))}
%o A096922 (MATLAB)
%o A096922 N = 63; a = NaN(1,N); j = 1; n = 1;
%o A096922 while any(isnan(a)) && n<=flintmax
%o A096922     k = (1:n-1)'; D = dec2base(k,10)-'0'; D(D==0) = 1;
%o A096922     if length(find(k + prod(D,2)==n))==1
%o A096922         a(j) = n; j = j+1;
%o A096922     end
%o A096922     n = n+1;
%o A096922 end
%o A096922 disp(regexprep(num2str(a), ' +', ', ')) % _Chris R. Rehmann_, Jul 17 2026
