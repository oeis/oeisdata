%U A096783 50272,51200,53600,53824,55072,57696,59648,62848,64800,66048,69824,76896,79200,82048,84672,85600,87648,89472,96448,98400
%N A096783 Numbers n such that n, n+1, n+2, n+3, n+4 are all of the form x^2+2*y^2 for nonnegative x, y.
%C A096783 All terms are divisible by 32. - _Robert Israel_, Jul 02 2026
%H A096783 Robert Israel, <a href="/A096783/b096783.txt">Table of n, a(n) for n = 1..6922</a>
%e A096783 96=8^2+2*4^2, 97=5^2+2*6^2, 98 = 0^2+2*7^2,99=9^2+2*3^2=7^2+2*5^2,100=10^2+2*0^2
%p A096783 N:= 10^6: # for terms <= N
%p A096783 Q:= {seq(seq(x^2 + 2*y^2,y=0..floor(sqrt((N-x^2)/2))),x=0..floor(sqrt(N)))}:
%p A096783 sort(convert(Q intersect (Q -~ 1) intersect (Q -~ 2) intersect (Q -~3) intersect(Q -~ 4),list)); # _Robert Israel_, Jul 02 2026
%t A096783 f[n_] := f[n_] = Block[{y = 0}, While[x = Sqrt[n - 2y^2]; !IntegerQ[x] && x >= 0, y++ ]; If[x \[Element] Reals, 1, 0]]; Select[ Range[0, 76895], f[ # ] == f[ # + 1] == f[ # + 2] == f[ # + 3] == f[ # + 4] == 1 &] (* _Robert G. Wilson v_, Aug 20 2004 *)
%K A096783 nonn
