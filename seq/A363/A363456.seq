%I A363456 #13 Mar 24 2026 00:16:45
%S A363456 1,2,6,27,150,900,5697,37226,246280,1648592,11204274,76594539,
%T A363456 527679639,3653869018,25325645617,175614323059,1219700206001
%N A363456 Positions of the terms of the Chernoff sequence (A006939) in A025487.
%C A363456 Indices of records in A363455.
%F A363456 A025487(a(n)) = A006939(n).
%F A363456 A363455(a(n)) = n.
%e A363456 A006939(0) = A025487(1) = 1, so a(0) = 1.
%e A363456 A006939(1) = A025487(2) = 2, so a(1) = 2.
%e A363456 A006939(2) = A025487(6) = 12, so a(2) = 6.
%t A363456 lps = Cases[Import["https://oeis.org/A025487/b025487.txt", "Table"], {_, _}][[;; , 2]];
%t A363456 cher = Table[Product[Prime[k]^(n - k + 1), {k, 1, n}], {n, 0, 8}]
%t A363456 Position[lps, #] & /@ cher // Flatten
%o A363456 (Python)
%o A363456 from math import prod
%o A363456 from functools import lru_cache
%o A363456 from itertools import count
%o A363456 from sympy import prime, integer_log, primorial
%o A363456 def A363456(n):
%o A363456     @lru_cache(maxsize=None)
%o A363456     def g(x, m, j): return sum(g(x//(prime(m)**i), m-1, i) for i in range(j,integer_log(x, prime(m))[0]+1)) if m-1 else max(0,x.bit_length()-j)
%o A363456     c, f = 1, prod(prime(k)**(n-k+1) for k in range(1,n+1))
%o A363456     for k in count(1):
%o A363456         if primorial(k)>f:
%o A363456             break
%o A363456         c += g(f,k,1)
%o A363456     return c # _Chai Wah Wu_, Mar 23 2026
