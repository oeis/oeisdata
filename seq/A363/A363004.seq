%I A363004 #14 Jul 24 2026 01:03:30
%S A363004 1,1,1,1,2,7,40,355,4819,99242,3049155,138762035,9290399173
%N A363004 Number of sequences of n distinct positive integers whose Gilbreath transform is (1, 1, ..., 1).
%H A363004 <a href="/index/Ge#Gilbreath">Index entries for sequences related to Gilbreath conjecture and transform</a>.
%e A363004 For n = 5, the a(5) = 7 sequences are:
%e A363004   (1, 2, 4, 6,  8),
%e A363004   (1, 2, 4, 6, 10),
%e A363004   (1, 2, 4, 8,  6),
%e A363004   (1, 2, 4, 8, 10),
%e A363004   (1, 2, 4, 8, 12),
%e A363004   (1, 2, 4, 8, 14),
%e A363004   (1, 2, 4, 8, 16).
%o A363004 (Python)
%o A363004 def A363004(n):
%o A363004     if n == 0: return 1
%o A363004     total = 0
%o A363004     def rec(diag, used):
%o A363004         nonlocal total
%o A363004         if len(diag) == n: total += 1; return
%o A363004         vs = {1}
%o A363004         for t in diag[:0:-1]:
%o A363004             vs = {w for v in vs for w in (t+v, t-v) if w >= 0}
%o A363004         for v in vs:
%o A363004             for x in {diag[0]+v, diag[0]-v}:
%o A363004                 if x < 1 or x in used: continue
%o A363004                 u, nd = x, [x]
%o A363004                 for t in diag: u = abs(u-t); nd.append(u)
%o A363004                 rec(nd, used | {x})
%o A363004     rec([1], {1})
%o A363004     return total
%Y A363004 Cf. A080839 (increasing sequences), A363002 (nondecreasing sequences), A363003, A363005 (distinct integers).
%K A363004 nonn,more,changed
%O A363004 0,5
%A A363004 _Pontus von Brömssen_, May 13 2023
%E A363004 a(12) from _Hari Gridharan_, Jul 23 2026
