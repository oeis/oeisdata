%I A349116 #21 Mar 23 2026 06:54:17
%S A349116 1,7,57,605,7990,126378,2331462,49183590,1168343775,30871159429,
%T A349116 898302280271,28547663567787,983905660878140,36556999252315556,
%U A349116 1456715662183096092,61973464872507939132,2803744852868605501965,134413716665674685292183,6807005707226954237422477
%N A349116 a(n) = Sum_{m=1..n} (Sum_{k=1..m} (Sum_{j=1..k} j^n)).
%H A349116 Vaclav Kotesovec, <a href="/A349116/b349116.txt">Table of n, a(n) for n = 1..200</a>
%H A349116 Hjalmar Rosengren, <a href="https://mathoverflow.net/a/509380">Identity with binomial coefficients and Stirling numbers of the second kind</a>, answer to question on MathOverflow, 2026.
%F A349116 a(n) ~ c * n^n, where c = 1/(1 - 3/exp(1) + 3/exp(2) - 1/exp(3)) = 3.959134481...
%F A349116 a(n) = Sum_{j=1..n} binomial(n-j+2,2)*j^n (due to Hjalmar Rosengren). - _Mikhail Kurkov_, Mar 22 2026
%t A349116 Table[Sum[Sum[Sum[j^n, {j, 1, k}], {k, 1, m}], {m, 1, n}], {n, 1, 20}]
%t A349116 Table[(Zeta[-2-n] - HurwitzZeta[-2-n,1+n] + (3+2*n)*(HurwitzZeta[-1-n,1+n] - Zeta[-1-n]) + (1+n)*(2+n)*(Zeta[-n] - HurwitzZeta[-n,1+n]))/2, {n,1,20}] (* _Vaclav Kotesovec_, Mar 23 2026 *)
%o A349116 (PARI) a(n) = sum(j=1, n, binomial(n-j+2,2)*j^n) \\ _Mikhail Kurkov_, Mar 22 2026
%Y A349116 Cf. A215084, A349117.
%K A349116 nonn
%O A349116 1,2
