%U A385110 2485361,2485475,4660337,4970723,4971025,9320675,9903217,9942051,19806435,19864689,19884107,39729379
%N A385110 Numbers congruent to {1, 3, 7} (mod 8) with 4 odd numbers in their orbit under the Collatz 3x+1 map, cf. A198587.
%C A385110 Original name: Terms of A198587 congruent {1, 3, 7} (mod 8).
%C A385110 Sorted set of all A385109(A198587(i)), i > 0.
%o A385110 (PARI) N=3; forstep(n=1, 1e6, 2, n%8==5 && next; my(s=n, c=0); while(s>1 && c<=N, s=3*s+1; s>>=valuation(s,2); c++); c==N && print1(n,", ")); \\ edited (speed increase factor 50) by _M. F. Hasler_, Apr 25 2026
%Y A385110 Cf. A198587, A385109.
