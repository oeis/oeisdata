%I A385519 #15 Jul 13 2026 21:32:16
%S A385519 5,7,463,5333,586471,12690943,18414001,123036583,804146449,
%T A385519 1117131202441,11170373961701,92009554676141,110451862680769,
%U A385519 600827908214213
%N A385519 Primes p that divide both 2^k + 3 and 3^k + 2 for some k.
%C A385519 Includes terms p of A196627 with even multiplicative orders ord_p(2) = ord_p(3), in particular, these larger terms: 1098445767808750903973251, 364947672292511454405089069, 203315521506434771079581843014801, 59813046375181769306016700165290169537, 1517811599380242183731391003255018381040066573726286733611752067380771. The smallest known term of A196627 that does not belong here is 18969653181299397175271. - _Max Alekseyev_, Jun 26 2026
%H A385519 Mathematics StackExchange, <a href="https://math.stackexchange.com/questions/5079698/if-gcdan-b-bn-a-is-bounded-then-a-tc-b-td">If gcd(a^n + b, b^n + a) is bounded, then a = t^c, b = t^d.</a>
%e A385519 a(3) = 463 is a term because 2^265 + 3 and 3^265 + 2 are divisible by 463.
%p A385519 filter:= proc(p) local a2, m2, a3, m3;
%p A385519   if not isprime(p) then return false fi;
%p A385519   try
%p A385519     a2, m2:= NumberTheory:-ModularLog(-3,2,p,output=[result,char]);
%p A385519   a3, m3:= NumberTheory:-ModularLog(-2,3,p,output=[result,char]);
%p A385519   a2 - a3 mod igcd(m2,m3) = 0;
%p A385519  catch: false
%p A385519  end try
%p A385519 end proc:
%p A385519 select(filter, [seq(i,i=5..2*10^7,2)]);
%Y A385519 Cf. A196627.
%K A385519 nonn,hard,more,changed
%O A385519 1,1
%A A385519 _Robert Israel_, Jul 01 2025
%E A385519 a(8)-a(14) from _Max Alekseyev_, Jul 13 2026
