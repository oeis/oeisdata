%S A385474 1,7,76,991,14281,219172,3512440,58096591,984340003,16996883887,
%T A385474 298017184048,5291703108292,94961611382860,1719543577996888,
%U A385474 31379622840361696,576519956457976495,10655055147825932119,197959348525977645781,3695112941037246866044
%N A385474 Expansion of (1/x) * Series_Reversion( x * (1-2*x)^2 / (1+x)^3 ).
%H A385474 Robert Israel, <a href="/A385474/b385474.txt">Table of n, a(n) for n = 0..765</a>
%H A385474 <a href="/index/Res#revert">Index entries for reversions of series</a>
%F A385474 a(n) = (1/(n+1)) * Sum_{k=0..n} 2^(n-k) * binomial(3*(n+1),k) * binomial(3*n-k+1,n-k).
%F A385474 a(n) = (1/(n+1)) * [x^n] ( (1+x)^3 / (1-2*x)^2 )^(n+1).
%F A385474 D-finite with recurrence: 189*(3*n + 5)*(3*n + 4)*a(n) - 6*(1202*n^2 + 3789*n + 3066)*a(n + 1) + 16*(103*n^2 + 588*n + 833)*a(n + 2) - 32*(n + 4)*(2*n + 7)*a(n + 3) = 0. - _Robert Israel_, Jun 07 2026
%p A385474 f:= gfun:-rectoproc({189*(3*n + 5)*(3*n + 4)*a(n) - 6*(1202*n^2 + 3789*n + 3066)*a(n + 1) + 16*(103*n^2 + 588*n + 833)*a(n + 2) - 32*(n + 4)*(2*n + 7)*a(n + 3),a(0) = 1, a(1) = 7, a(2) = 76},a(n),remember):
%p A385474 map(f, [$0..20]); # _Robert Israel_, Jun 07 2026
%o A385474 (PARI) my(N=20, x='x+O('x^N)); Vec(serreverse(x*(1-2*x)^2/(1+x)^3)/x)
%o A385474 (PARI) a(n) = sum(k=0, n, 2^(n-k)*binomial(3*(n+1), k)*binomial(3*n-k+1, n-k))/(n+1);
