%U A385925 47,43,53,47,41,53,47,47,59,59,61,61,61,53,59,59,67,61
%N A385925 a(n) = denominator q of the fraction p/q that minimizes |m/n - p/q | with m/n != p/q, where p is 1 or prime, q is prime, q < n, and m ranges from 1 to n - 1, with this rule to ensure uniqueness: if for given n there is more than one minimizing triple (m, p, q), then choose the least such m, then least q, then least p.
%C A385925 Referring to the definition, this is the "least version"; for the "greatest version", see A394354.
%e A385925 In the following table, columns 1-4 give values for the closest prime-fraction p/q to m/n as determined by the definition of a(n). In particular,, a(3), ..., a(30) occupy column 2.  Column 5 shows a comparison: < if p/q < m/n and > is p/q > m/n. Column 6 gives an approximation for the minimal distance |m/n - p/q|.
%e A385925    n	  m  	 p      q     comp.     min. dist.
%e A385925    3  	  1	 1      2	>	0.16666667
%e A385925    4        1	 1	3	>	0.08333333
%e A385925    5	  2	 1	3	<	0.06666667
%e A385925    6	  1	 1	5	>	0.03333333
%e A385925    7	  3	 2	5	<	0.02857143
%e A385925    8	  1	 1	7	>	0.01785714
%e A385925    9	  4	 3	7	<	0.01587302
%e A385925   10	  3	 2	7	<	0.01428571
%e A385925   11	  3	 2	7	>	0.01298701
%e A385925   12	  1	 1     11	>	0.00757576
%e A385925   13	  6	 5     11	<	0.00699301
%e A385925   14	  1	 1     13	>	0.00549451
%e A385925   15	  8	 7     13	>	0.00512821
%e A385925   16	  3	 2     11	<	0.00568182
%e A385925   17	  4	 3     13	<	0.00452489
%e A385925   18	  1	 1     17	>	0.00326797
%e A385925   19	  3	 2     13	<	0.00404858
%e A385925   20	  1	 1     19	>	0.00263158
%e A385925   21	 16     13     17	>	0.00280112
%e A385925   22	 15     13     19	>	0.00239234
%e A385925   23	  6	 5     19	>	0.00228833
%e A385925   24	  1	 1     23	>	0.00181159
%e A385925   25	 12     11     23	<	0.00173913
%e A385925   26	 15     11     19	>	0.00202429
%e A385925   27	 20     17     23	<	0.00161031
%e A385925   28	  3	 2     19	<	0.00187970
%e A385925   29	 24     19     23	<	0.00149925
%e A385925   30	  1	 1     29	>	0.00114943
%e A385925 |1/4  - 1/3| = .08333333... < |1/4 - p/q| for all other p/q as in the definition of a(n), so a(4) = 1. - _Clark Kimberling_, Mar 17 2026
%t A385925 u[p_] := p == 1 || PrimeQ[p];
%t A385925 t = Table[min = Infinity; b = {None, None, None};
%t A385925    Do[Do[If[PrimeQ[q],
%t A385925       Do[If[u[p], If[m/n != p/q, d = Abs[m/n - p/q];
%t A385925          If[d < min, min = d;
%t A385925           b = {m, p, q};]]], {p, 1, n}]], {q, 2, n - 1}], {m, 1, n - 1}];
%t A385925    {mVal, pVal, qVal} = b;
%t A385925    comp = If[pVal/qVal < mVal/n, "<", ">"];
%t A385925    {n, mVal, pVal, qVal, comp, NumberForm[N[min], {10, 8}]}, {n, 3, 30}];
%t A385925 TableForm[t, TableHeadings -> {None, {"n", "m", "p", "q", "comp.", "min. dist."}}]
