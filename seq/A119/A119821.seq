%I A119821 #21 May 19 2026 08:36:08
%S A119821 1,4,33,436,8015,189596,5494797,188692708,7494744807,338103170428,
%T A119821 17079035749061,955117390512858,58584586487137113,3910851585418994256,
%U A119821 282272352712037938081,21904366942822876046020,1818619255216622892043939,160860974289752252341289904,15101683998188487229892992721
%N A119821 Coefficients of x^n in the n-th iteration of x/(1-x)^2 for n>=1.
%C A119821 The coefficient of x^n in the n-th iteration of x/(1-x) = n^(n-1) = A000169(n); does this variant have a simple formula for a(n)?
%H A119821 Paul D. Hanna, <a href="/A119821/b119821.txt">Table of n, a(n) for n = 1..400</a>
%F A119821 a(n) = [x^n] F^n(x) where F^n(x) = F^{n-1}(F(x)) with F(x) = x/(1-x)^2.
%F A119821 a(n) = [x^n] x*( Product_{k=0..n-1} Q(k)^2 ) / Q(n)^2 where Q(n) = Q(n-1)^2 - x*Product_{k=0..n-2} Q(k)^2 for n > 1, starting with Q(0) = 1 and Q(1) = 1 - x. The coefficients in Q(n) equals row n+1 of array A147990. - _Paul D. Hanna_, May 19 2026
%e A119821 The successive iterations of F(x) = x/(1-x)^2 begin:
%e A119821 F(x) = x + 2*x^2 + 3*x^3 + 4*x^4 + 5*x^5 + 6*x^6 + 7*x^7 + 8*x^8 +...
%e A119821 F(F(x)) = x + 4*x^2 + 14*x^3 + 46*x^4 + 145*x^5 + 444*x^6 + 1331*x^7 + 3926*x^8 + ... + A030267(n)*x^n + ...
%e A119821 F(F(F(x))) = x + 6*x^2 + 33*x^3 + 174*x^4 + 892*x^5 + 4480*x^6 + 22149*x^7 + ... + A396093(n)*x^n + ...
%e A119821 F^4(x) = x + 8*x^2 + 60*x^3 + 436*x^4 + 3102*x^5 + 21728*x^6 + 150350*x^7 + ... + A396094(n)*x^n + ...
%e A119821 The table of coefficients of x^k in F^n(x), the n-th iteration of F(x) = x/(1-x)^2, begins
%e A119821   n = 1: [1,  2,   3,    4,     5,      6,       7, ...];
%e A119821   n = 2: [1,  4,  14,   46,   145,    444,    1331, ...];
%e A119821   n = 3: [1,  6,  33,  174,   892,   4480,   22149, ...];
%e A119821   n = 4: [1,  8,  60,  436,  3102,  21728,  150350, ...];
%e A119821   n = 5: [1, 10,  95,  880,  8015,  72090,  642031, ...];
%e A119821   n = 6: [1, 12, 138, 1554, 17255, 189596, 2066073, ...];
%e A119821   n = 7: [1, 14, 189, 2506, 32830, 426244, 5494797, ...]; ...
%e A119821 in which the main diagonal forms this sequence.
%e A119821 RELATED ARRAY.
%e A119821 The formula for the n-th iteration of F(x) = x/(1-x)^2 is
%e A119821 F^n(x) = x*( Product_{k=0..n-1} Q(k)^2 ) / Q(n)^2
%e A119821 where
%e A119821 Q(n) = Q(n-1)^2 - x*Product_{k=0..n-2} Q(k)^2 for n > 1, starting with Q(0) = 1 and Q(1) = 1 - x.
%e A119821 Thus,
%e A119821   Q(2) = Q(1)^2 - x = (1-x)^2 - x = 1 - 3*x + x^2 ;
%e A119821   Q(3) = Q(2)^2 - x*Q(1)^2 = (1 - 3*x + x^2)^2 - x*(1-x)^2 ;
%e A119821   Q(4) = Q(3)^2 - x*Q(1)^2*Q(2)^2 ;
%e A119821   Q(5) = Q(4)^2 - x*Q(1)^2*Q(2)^2*Q(3)^2 ; etc.
%e A119821 The first few polynomials Q(n) begin
%e A119821   Q(0) = 1 ;
%e A119821   Q(1) = 1 - x ;
%e A119821   Q(2) = 1 - 3*x + x^2 ;
%e A119821   Q(3) = 1 - 7*x + 13*x^2 - 7*x^3 + x^4 ;
%e A119821   Q(4) = 1 - 15*x + 83*x^2 - 220*x^3 + 303*x^4 - 220*x^5 + 83*x^6 - 15*x^7 + x^8 ; ...
%e A119821 The coefficients in Q(n) form row n+1 of array A147990.
%o A119821 (PARI) {upto(n) = my(F=x/(1-x +x*O(x^n))^2, G=x); for(k=1, n,
%o A119821 G=subst(F, x, G); print1(polcoef(G, k),", ") )}
