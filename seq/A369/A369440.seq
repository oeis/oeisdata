%N A369440 Expansion of (1/x) * Series_Reversion( x / ((1+x) * (1+x^2)^2) ).
%H A369440 Robert Israel, <a href="/A369440/b369440.txt">Table of n, a(n) for n = 0..1496</a>
%H A369440 <a href="/index/Res#revert">Index entries for reversions of series</a>
%F A369440 a(n) = (1/(n+1)) * Sum_{k=0..floor(n/2)} binomial(2*n+2,k) * binomial(n+1,n-2*k).
%F A369440 D-finite with recurrence: 31457280*(2*n + 5)*(2*n + 3)*(n + 2)*(n + 1)*a(n) - 131072*(2*n + 5)*(n + 2)*(1849*n^2 + 15600*n + 29781)*a(n + 1) - 4096*(131909*n^4 + 1768714*n^3 + 8682049*n^2 + 18513524*n + 14472960)*a(n + 2) - 5120*(33821*n^4 + 485111*n^3 + 2601199*n^2 + 6197905*n + 5560080)*a(n + 3) + 128*(574657*n^4 + 8834652*n^3 + 47280836*n^2 + 97395645*n + 50001150)*a(n + 4) - 32*(407917*n^4 + 9490232*n^3 + 82996052*n^2 + 323501902*n + 474371865)*a(n + 5) + 5*(468235*n^4 + 12355402*n^3 + 121976345*n^2 + 533884850*n + 874009656)*a(n + 6) + 936*(2*n + 15)*(4*n + 31)*(n + 8)*(4*n + 33)*a(n + 7) = 0. - _Robert Israel_, Mar 20 2026
%p A369440 f:= gfun:-rectoproc({31457280*(2*n + 5)*(2*n + 3)*(n + 2)*(n + 1)*a(n) - 131072*(2*n + 5)*(n + 2)*(1849*n^2 + 15600*n + 29781)*a(n + 1) - 4096*(131909*n^4 + 1768714*n^3 + 8682049*n^2 + 18513524*n + 14472960)*a(n + 2) - 5120*(33821*n^4 + 485111*n^3 + 2601199*n^2 + 6197905*n + 5560080)*a(n + 3) + 128*(574657*n^4 + 8834652*n^3 + 47280836*n^2 + 97395645*n + 50001150)*a(n + 4) - 32*(407917*n^4 + 9490232*n^3 + 82996052*n^2 + 323501902*n + 474371865)*a(n + 5) + 5*(468235*n^4 + 12355402*n^3 + 121976345*n^2 + 533884850*n + 874009656)*a(n + 6) + 936*(2*n + 15)*(4*n + 31)*(n + 8)*(4*n + 33)*a(n + 7), a(0) = 1, a(1) = 1, a(2) = 3, a(3) = 9, a(4) = 30, a(5) = 107, a(6) = 396}, a(n), remember):
%p A369440 map(f, [$0..30]); # _Robert Israel_, Mar 20 2026
%o A369440 (PARI) my(N=30, x='x+O('x^N)); Vec(serreverse(x/((1+x)*(1+x^2)^2))/x)
%o A369440 (PARI) a(n, s=2, t=2, u=1) = sum(k=0, n\s, binomial(t*(n+1), k)*binomial(u*(n+1), n-s*k))/(n+1);
