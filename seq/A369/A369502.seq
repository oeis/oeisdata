%N A369502 Expansion of (1/x) * Series_Reversion( x / ((1+x)^2+x)^2 ).
%H A369502 Robert Israel, <a href="/A369502/b369502.txt">Table of n, a(n) for n = 0..894</a>
%H A369502 <a href="/index/Res#revert">Index entries for reversions of series</a>
%F A369502 a(n) = (1/(n+1)) * Sum_{k=0..n} binomial(2*n+2,k) * binomial(4*n-2*k+4,n-k).
%F A369502 D-finite with recurrence: (52000*n^3 + 260000*n^2 + 403000*n + 195000)*a(n) + (40920*n^3 + 262980*n^2 + 556260*n + 386400)*a(n + 1) + (-4482*n^3 - 38286*n^2 - 107664*n - 99480)*a(n + 2) + (81*n^3 + 972*n^2 + 3879*n + 5148)*a(n + 3) = 0. - _Robert Israel_, Apr 19 2026
%p A369502 f:= gfun:-rectoproc({(52000*n^3 + 260000*n^2 + 403000*n + 195000)*a(n) + (40920*n^3 + 262980*n^2 + 556260*n + 386400)*a(n + 1) + (-4482*n^3 - 38286*n^2 - 107664*n - 99480)*a(n + 2) + (81*n^3 + 972*n^2 + 3879*n + 5148)*a(n + 3), a(0) = 1, a(1) = 6, a(2) = 47}, a(n), remember):
%p A369502 map(f, [$0..30]); # _Robert Israel_, Apr 19 2026
%o A369502 (PARI) my(N=30, x='x+O('x^N)); Vec(serreverse(x/((1+x)^2+x)^2)/x)
%o A369502 (PARI) a(n) = sum(k=0, n, binomial(2*n+2, k)*binomial(4*n-2*k+4, n-k))/(n+1);
