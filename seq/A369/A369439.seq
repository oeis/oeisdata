%I A369439 #12 Mar 20 2026 16:22:01
%S A369439 1,2,6,22,89,382,1708,7870,37108,178184,868318,4283402,21347902,
%T A369439 107330004,543707480,2772469998,14219396908,73303128344,379621891640,
%U A369439 1974078923416,10303600000553,53960438323438,283461807342876,1493252678987602,7886649917261724
%N A369439 Expansion of (1/x) * Series_Reversion( x / ((1+x)^2 * (1+x^2)) ).
%H A369439 Robert Israel, <a href="/A369439/b369439.txt">Table of n, a(n) for n = 0..1334</a>
%H A369439 <a href="/index/Res#revert">Index entries for reversions of series</a>
%F A369439 a(n) = (1/(n+1)) * Sum_{k=0..floor(n/2)} binomial(n+1,k) * binomial(2*n+2,n-2*k).
%F A369439 D-finite with recurrence: 2048*(2*n + 3)*(n + 2)*(n + 1)*a(n) + 512*(n + 2)*(2*n^2 + 38*n + 81)*a(n + 1) - 512*(7*n^3 + 105*n^2 + 443*n + 570)*a(n + 2) + 32*(301*n^3 + 3699*n^2 + 15032*n + 20172)*a(n + 3) - 16*(223*n^3 + 3279*n^2 + 16079*n + 26313)*a(n + 4) + 4*(125*n^3 + 2235*n^2 + 13339*n + 26586)*a(n + 5) - 3*(3*n + 20)*(3*n + 22)*(n + 7)*a(n + 6) = 0. - _Robert Israel_, Mar 20 2026
%p A369439 f:= gfun:-rectoproc({2048*(2*n + 3)*(n + 2)*(n + 1)*a(n) + 512*(n + 2)*(2*n^2 + 38*n + 81)*a(n + 1) - 512*(7*n^3 + 105*n^2 + 443*n + 570)*a(n + 2) + 32*(301*n^3 + 3699*n^2 + 15032*n + 20172)*a(n + 3) - 16*(223*n^3 + 3279*n^2 + 16079*n + 26313)*a(n + 4) + 4*(125*n^3 + 2235*n^2 + 13339*n + 26586)*a(n + 5) - 3*(3*n + 20)*(3*n + 22)*(n + 7)*a(n + 6), a(0) = 1, a(1) = 2, a(2) = 6, a(3) = 22, a(4) = 89, a(5) = 382}, a(n), remember):
%p A369439 map(f, [$0..30]); # _Robert Israel_, Mar 20 2026
%o A369439 (PARI) my(N=30, x='x+O('x^N)); Vec(serreverse(x/((1+x)^2*(1+x^2)))/x)
%o A369439 (PARI) a(n, s=2, t=1, u=2) = sum(k=0, n\s, binomial(t*(n+1), k)*binomial(u*(n+1), n-s*k))/(n+1);
%Y A369439 Cf. A036765.
%K A369439 nonn
%O A369439 0,2
