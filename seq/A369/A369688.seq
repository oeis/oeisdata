%N A369688 G.f. satisfies A(x) = 1 + x*A(x) + x^2*(1-x)^3*A(x)^5.
%H A369688 Robert Israel, <a href="/A369688/b369688.txt">Table of n, a(n) for n = 0..1532</a>
%F A369688 a(n) = Sum_{k=0..floor(n/2)} binomial(n,2*k) * binomial(5*k,k) / (4*k+1).
%F A369688 D-finite with recurrence: 2869*(n + 4)*(n + 3)*(n + 2)*(n + 1)*a(n) - 2*(5482*n + 19443)*(n + 4)*(n + 3)*(n + 2)*a(n + 1) + (n + 4)*(n + 3)*(14910*n^2 + 121840*n + 249203)*a(n + 2) - (n + 4)*(7380*n^3 + 104750*n^2 + 490432*n + 759411)*a(n + 3) - (n + 4)*(715*n^3 + 6320*n^2 + 11412*n - 11904)*a(n + 4) + 256*(2*n + 11)*(n + 5)*(3*n^2 + 31*n + 81)*a(n + 5) - 64*(n + 5)*(2*n + 13)*(2*n + 11)*(n + 6)*a(n + 6) = 0. - _Robert Israel_, May 01 2026
%p A369688 f:= gfun:-rectoproc({2869*(n + 4)*(n + 3)*(n + 2)*(n + 1)*a(n) - 2*(5482*n + 19443)*(n + 4)*(n + 3)*(n + 2)*a(n + 1) + (n + 4)*(n + 3)*(14910*n^2 + 121840*n + 249203)*a(n + 2) - (n + 4)*(7380*n^3 + 104750*n^2 + 490432*n + 759411)*a(n + 3) - (n + 4)*(715*n^3 + 6320*n^2 + 11412*n - 11904)*a(n + 4) + 256*(2*n + 11)*(n + 5)*(3*n^2 + 31*n + 81)*a(n + 5) - 64*(n + 5)*(2*n + 13)*(2*n + 11)*(n + 6)*a(n + 6), a(0) = 1, a(1) = 1, a(2) = 2, a(3) = 4, a(4) = 12, a(5) = 36}, a(n), remember):
%p A369688 map(f, [$0..30]); # _Robert Israel_, May 01 2026
%o A369688 (PARI) a(n) = sum(k=0, n\2, binomial(n, 2*k)*binomial(5*k, k)/(4*k+1));
