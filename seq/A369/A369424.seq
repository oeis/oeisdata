%t A369424 nmax = 60; Rest[CoefficientList[Series[Sum[x^(k^2) * (1+x)^k / (1-x)^k, {k, 1, Sqrt[nmax] + 1}], {x, 0, nmax}], x]] (* _Vaclav Kotesovec_, Jun 13 2026 *)
