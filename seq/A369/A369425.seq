%N A369425 Expansion of Sum_{n>=1} x^(n*(n+1)/2)*((1+x)/(1-x))^n.
%H A369425 Vaclav Kotesovec, <a href="/A369425/b369425.txt">Table of n, a(n) for n = 1..10000</a>
%F A369425 Conjecture: a(n) = b(n) - b(n-2) where b(n) = Sum_{k=1..n} A142978(n-k+1, A003056(k)). - _Mikhail Kurkov_, Jun 13 2026
%t A369425 nmax = 50; Rest[CoefficientList[Series[Sum[x^(k*(k+1)/2) * (1+x)^k / (1-x)^k, {k, 1, Sqrt[2*nmax] + 1}], {x, 0, nmax}], x]] (* _Vaclav Kotesovec_, Jun 13 2026 *)
%o A369425 (PARI) my(N=66,x='x+O('x^N)); Vec(sum(n=1,N,x^(n*(n+1)/2)*((1+x)/(1-x))^n))
%Y A369425 Cf. A003056, A142978, A369424, A219282.
