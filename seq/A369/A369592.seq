%N A369592 Expansion of (1/x) * Series_Reversion( x / (1+x+x^4/(1+x)^3) ).
%C A369592 Number of ordered trees with n+1 edges, having nonroot nodes of outdegree 0 or 4. - _Emanuele Munarini_, Jun 20 2024
%H A369592 Robert Israel, <a href="/A369592/b369592.txt">Table of n, a(n) for n = 0..4093</a>
%F A369592 a(n) = (1/(n+1)) * Sum_{k=0..floor(n/4)} (n-4*k+1) * binomial(n+1,k).
%F A369592 D-finite with recurrence: (-1048576*n^3 - 6291456*n^2 - 11534336*n - 6291456)*a(n) + (1703936*n^3 + 14942208*n^2 + 42336256*n + 38535168)*a(n + 1) + (-589824*n^3 - 5898240*n^2 - 18776064*n - 19169280)*a(n + 2) + (221184*n^3 + 3981312*n^2 + 22978560*n + 42442752)*a(n + 3) + (-18432*n^3 - 1069056*n^2 - 9424896*n - 22487040)*a(n + 4) + (-184320*n^3 - 2810880*n^2 - 14094336*n - 23126016)*a(n + 5) + (69120*n^3 + 1175040*n^2 + 6537600*n + 11827584)*a(n + 6) + (-23328*n^3 - 559872*n^2 - 4430592*n - 11560032)*a(n + 7) + (13608*n^3 + 334368*n^2 + 2731752*n + 7420896)*a(n + 8) + (486*n^3 + 19440*n^2 + 242298*n + 965304)*a(n + 9) + (-729*n^3 - 23328*n^2 - 248751*n - 883872)*a(n + 10) = 0. - _Robert Israel_, Apr 10 2026
