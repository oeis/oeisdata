%F A369504 a(n) = (1/(n+1)) * Sum_{k=0..floor(n/3)} binomial(2*n+2,k) * binomial(4*n-2*k+4,n-3*k).
%F A369504 D-finite with recurrence (-7511407439680*n^5 - 78869778116640*n^4 - 317356964326480*n^3 - 611240780403960*n^2 - 562416632046040*n - 197174445291600)*a(n) + (7653545818640*n^5 + 59239934831040*n^4 + 76405578127100*n^3 - 439307257244280*n^2 - 1414631965265980*n - 1163715767638200)*a(n + 1) + (6304651947224*n^5 + 151452600862500*n^4 + 1283726130587600*n^3 + 5073731789821500*n^2 + 9581824395015656*n + 7006894304161920)*a(n + 2) + (-7659918163311*n^5 - 154377309960225*n^4 - 1231810325105895*n^3 - 4866084690493815*n^2 - 9518612129526234*n - 7376057695117080)*a(n + 3) + (924021930232*n^5 + 20784996199560*n^4 + 188127174208600*n^3 + 858886615204680*n^2 + 1984214501284768*n + 1861779153732960)*a(n + 4) + (-46144995772*n^5 - 1380961461780*n^4 - 16634950295620*n^3 - 100804894219740*n^2 - 307214288635168*n - 376557127845360)*a(n + 5) + (2919716656*n^5 + 98922699600*n^4 + 1343817042880*n^3 + 9151033138560*n^2 + 31243960250944*n + 42794652967680)*a(n + 6) + (-48025000*n^5 - 1872975000*n^4 - 29208805000*n^3 - 227678841000*n^2 - 887071234960*n - 1382009815680)*a(n + 7) = 0. - _Robert Israel_, Apr 21 2026
%o A369504 (PARI) my(N=30, x='x+O('x^N)); Vec(serreverse(x/((1+x)^2+x^3)^2)/x)
%o A369504 (PARI) a(n) = sum(k=0, n\3, binomial(2*n+2, k)*binomial(4*n-2*k+4, n-3*k))/(n+1);
