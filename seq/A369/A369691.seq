%N A369691 G.f. satisfies A(x) = 1/(1-x)^3 + x^3*A(x)^3.
%H A369691 Robert Israel, <a href="/A369691/b369691.txt">Table of n, a(n) for n = 0..1791</a>
%F A369691 a(n) = Sum_{k=0..floor(n/3)} binomial(n+3*k+2,n-3*k) * binomial(3*k,k) / (2*k+1).
%F A369691 D-finite with recurrence: 2*(n + 3)*(2*n + 3)*a(n) - 2*(7*n + 23)*(2*n + 5)*a(n + 1) + 8*(2*n + 7)*(5*n + 17)*a(n + 2) - (139*n^2 + 1083*n + 2052)*a(n + 3) + (83*n^2 + 495*n + 232)*a(n + 4) + (83*n^2 + 1497*n + 6244)*a(n + 5) - (139*n^2 + 2253*n + 9072)*a(n + 6) + 8*(5*n + 43)*(2*n + 17)*a(n + 7) - 2*(2*n + 19)*(7*n + 61)*a(n + 8) + 2*(2*n + 21)*(n + 9)*a(n + 9) = 0. - _Robert Israel_, May 01 2026
%p A369691 f:= gfun:-rectoproc({2*(n + 3)*(2*n + 3)*a(n) - 2*(7*n + 23)*(2*n + 5)*a(n + 1) + 8*(2*n + 7)*(5*n + 17)*a(n + 2) - (139*n^2 + 1083*n + 2052)*a(n + 3) + (83*n^2 + 495*n + 232)*a(n + 4) + (83*n^2 + 1497*n + 6244)*a(n + 5) - (139*n^2 + 2253*n + 9072)*a(n + 6) + 8*(5*n + 43)*(2*n + 17)*a(n + 7) - 2*(2*n + 19)*(7*n + 61)*a(n + 8) + 2*(2*n + 21)*(n + 9)*a(n + 9), a(0) = 1, a(1) = 3, a(2) = 6, a(3) = 11, a(4) = 24, a(5) = 66, a(6) = 196, a(7) = 576, a(8) = 1692 }, a(n), remember):
%p A369691 map(f, [$0..30]); # _Robert Israel_, May 01 2026
%o A369691 (PARI) a(n) = sum(k=0, n\3, binomial(n+3*k+2, n-3*k)*binomial(3*k, k)/(2*k+1));
