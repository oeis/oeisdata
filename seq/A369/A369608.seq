%I A369608 #8 Apr 29 2026 18:21:02
%S A369608 0,2,2,6,14,39,125,399,1310,4356,14970,51715,178832,635778,2290019,
%T A369608 8106059,29234378,105635076,384409483,1408730050,5193316109,
%U A369608 19170300330,71421970661,263893092145,984568438169,3686368605467,13838552783467,52008816746450
%N A369608 Number of solutions to +- 2 +- 3 +- 5 +- 7 +- ... +- prime(2*n) = prime(2*n).
%H A369608 Robert Israel, <a href="/A369608/b369608.txt">Table of n, a(n) for n = 1..500</a>
%F A369608 a(n) = [x^prime(2*n)] Product_{k=1..2*n} (x^prime(k) + 1/x^prime(k)).
%p A369608 M:= 80: # for a(1) .. a(M/2)
%p A369608 N:= add(ithprime(i),i=1..M): m:= 0: p:= 1: R:= NULL: V:= Vector(2*N+1): V[1]:= 1:
%p A369608 for i from 1 to M do
%p A369608   p:= ithprime(i);
%p A369608   V[1+2*p..m+1+2*p]:= V[1+2*p .. m+1+2*p] + V[1..m+1];
%p A369608   if i::even then R:= R, V[1+m/2+2*p] fi;
%p A369608   m:= m + 2*p;
%p A369608 od:
%p A369608 R; # _Robert Israel_, Apr 29 2026
%t A369608 Table[Coefficient[Product[(x^Prime[k] + 1/x^Prime[k]), {k, 1, 2 n}], x, Prime[2 n]], {n, 1, 28}]
%Y A369608 Cf. A000040, A022894, A063890, A113040, A350695, A369390.
%K A369608 nonn,changed
%O A369608 1,2
