%F A074307 a(9*n)=4*n, a(9*n+1)=8*n+2, a(9*n+2)=16*n+3, a(9*n+3)=8*n+1, a(9*n+4)=16*n+11, a(9*n+5)=16*n+5, a(9*n+6)=8*n+7, a(9*n+7)=16*n+13, a(9*n+8)=8*n+6. - _Philippe Deléham_, Nov 14 2023
%F A074307 From _Elmo R. Oliveira_, May 15 2026: (Start)
%F A074307 a(n) = 2*a(n-9) - a(n-18).
%F A074307 G.f.: x*(2 + 3*x + x^2 + 11*x^3 + 5*x^4 + 7*x^5 + 13*x^6 + 6*x^7 + 4*x^8 + 6*x^9 + 13*x^10 + 7*x^11 + 5*x^12 + 11*x^13 + x^14 + 3*x^15 + 2*x^16) / ((x - 1)^2 * (1 + x + x^2)^2 * (1 + x^3 + x^6)^2). (End)
%o A074307 (PARI) A074305(m) = if(m%3==0,m/3*2,if(m%3==1,(m-1)/3*4+3,(m-2)/3*4+1))
