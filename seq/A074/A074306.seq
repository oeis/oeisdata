%S A074306 0,2,3,1,6,5,9,4,12,8,15,7,18,11,21,10,24,14,27,13,30,17,33,16,36,20,
%T A074306 39,19,42,23,45,22,48,26,51,25,54,29,57,28,60,32,63,31,66,35,69,34,72,
%U A074306 38,75,37,78,41,81,40,84,44,87,43,90,47,93,46,96,50,99,49,102,53,105,52
%N A074306 Inverse of permutation in A074305.
%C A074306 A permutation of the nonnegative integers.
%H A074306 G. Venturini, <a href="https://doi.org/10.1002/sapm1992863185">Iterates of number-theoretic functions with periodic rational coefficients (Generalization of the 3x+1 problem)</a>, Stud. Appl. Math., Vol. 86 (1992), pp. 185-218.
%H A074306 <a href="/index/Per#IntegerPermutation">Index entries for sequences that are permutations of the natural numbers</a>.
%H A074306 <a href="/index/Rec#order_06">Index entries for linear recurrences with constant coefficients</a>, signature (0,1,0,1,0,-1).
%F A074306 From _Elmo R. Oliveira_, May 15 2026: (Start)
%F A074306 a(n) = a(n-2) + a(n-4) - a(n-6).
%F A074306 G.f.: x*(1 + 2*x)*(2 + x)*(1 - x + x^2) / ((1 - x^2)*(1 - x^4)). (End)
%o A074306 (PARI) a(m)=if(m%2==0,m/2*3,if(m%4==3,(m-3)/4*3+1,(m-1)/4*3+2))
%o A074306 for(n=0,120,print1(a(n),", ")) \\ C. Ronaldo
%Y A074306 Cf. A074305, A074307, A074308.
%K A074306 nonn,easy
%O A074306 0,2
