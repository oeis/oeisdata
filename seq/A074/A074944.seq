%U A074944 2,2,1,5,1,2,2,3,1,5,1,4,2,2,1,7,1,2,2,5,1,4,1,3,2,2,1,9,1,2,2,3,1,5,1,6,2
%N A074944 Number of k with 1 <= k <= n such that gcd(n,k) = tau(k), where tau is A000005, number of divisors function.
%H A074944 Antti Karttunen, <a href="/A074944/b074944.txt">Table of n, a(n) for n = 1..16384</a>
%H A074944 Amiram Eldar, <a href="/A074944/a074944.jpg">Plot of Sum_{k=1..n} a(k)/(n*log(n)) for n = 2..10^5</a>.
%F A074944 Sum_{i=1..n} a(i) seems to be asymptotic to c*n*log(n) with 0.5 < c < 0.6.
%F A074944 The above conjecture seems to be wrong. See the graph in the Links section. - _Amiram Eldar_, Mar 10 2026
%t A074944 a[n_] := Sum[If[GCD[n, k] == DivisorSigma[0, k], 1, 0], {k, 1, n}]; Array[a, 105] (* _Amiram Eldar_, Mar 10 2026 *)
%o A074944 (PARI) a(n)=sum(k=1,n,if(gcd(n,k)-numdiv(k),0,1))
%Y A074944 Cf. A000005.
%K A074944 easy,nonn,changed
%O A074944 1,2
%A A074944 _Benoit Cloitre_, Oct 05 2002
