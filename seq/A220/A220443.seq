%S A220443 0,9,45,126,270,495,819,1260,1836,2565,3465,4554,5850,7371,9135,11160,
%T A220443 13464,16065,18981,22230,25830,29799,34155,38916,44100,49725,55809,
%U A220443 62370,69426,76995,85095,93744,102960,112761,123165,134190,145854,158175,171171,184860,199260
%N A220443 a(n) = Sum_{i=1..n} (3*i)^2.
%H A220443 T. Aaron Gulliver, <a href="https://www.m-hikari.com/ijcms/ijcms-2012/37-40-2012/gulliverIJCMS37-40-2012.pdf">Sums of Powers of Integers Divisible by Three</a>, Int. J. Contemp. Math. Sciences, Vol. 7, 2012, no. 38, pp. 1895-1901.
%H A220443 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (4,-6,4,-1).
%F A220443 From _Colin Barker_, Jul 22 2013: (Start)
%F A220443 a(n) = 3*n*(1 + 3*n + 2*n^2)/2.
%F A220443 G.f.: 9*x*(x+1) / (x-1)^4. (End)
%F A220443 a(n) = A045943(n) * A005408(n). - _Bruce J. Nicholson_, Jun 12 2020
%F A220443 From _Elmo R. Oliveira_, Jul 06 2026: (Start)
%F A220443 a(n) = 3*A059270(n).
%F A220443 a(n) = 4*a(n-1) - 6*a(n-2) + 4*a(n-3) - a(n-4).
%F A220443 E.g.f.: (3*x/2)*(6 + 9*x + 2*x^2)*exp(x). (End)
%o A220443 (PARI) a(n) = sum(k=1, n, (3*k)^2); \\ _Michel Marcus_, Aug 29 2015
%Y A220443 Equals 9*A000330.
%Y A220443 Cf. A005408, A045943, A059270.
%K A220443 nonn,easy,changed
%O A220443 0,2
%A A220443 _N. J. A. Sloane_, Dec 22 2012
