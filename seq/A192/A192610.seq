%S A192610 9,36,37,54,55,76,79,330,333,352,370,394,405,417,427,456,490,492,498,
%T A192610 504,517,550,583,624,634,652,667,762,795,828,855,874,876,891,898,903,
%U A192610 921,924,925,930,949,960,967,982,3181,3186,3201,3208,3232,3243,3274,3333,3336,3402,3403,3409,3411,3442
%N A192610 Numbers k such that the concatenation of k^3 k^2 k^1 k^0 is prime.
%C A192610 All terms == 0 or 1 (mod 3). - _Robert Israel_, May 20 2026
%H A192610 Robert Israel, <a href="/A192610/b192610.txt">Table of n, a(n) for n = 1..10000</a>
%e A192610 9 is in the list because the concatenation of 9^3 9^2 9^1 9^0 is 7298191 and this number is prime.
%p A192610 lcat:= proc(L) local x,i;
%p A192610   x:= L[1];
%p A192610   for i from 2 to nops(L) do
%p A192610     x:= x*10^(1+ilog10(L[i]))+L[i]
%p A192610   od;
%p A192610   x
%p A192610 end proc:
%p A192610 filter:= n -> isprime(lcat([n^3,n^2,n,1])):
%p A192610 select(filter, [$1..5000]); # _Robert Israel_, May 20 2026
%t A192610 Select[Range[1000],PrimeQ[FromDigits[Flatten[IntegerDigits/@ (#^Range[ 3,0,-1])]]]&] (* _Harvey P. Dale_, Jul 27 2011 *)
%Y A192610 Cf. A192608, A192609.
%K A192610 nonn,base
%O A192610 1,1
