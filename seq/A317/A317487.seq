%F A317487 a(n) = n!*(n-2)*(n-3)/8 for n > 1. - _Andrew Howroyd_, Jul 30 2018
%F A317487 From _Amiram Eldar_, Jun 21 2026: (Start)
%F A317487 Sum_{n>=4} 1/a(n) = 8*(e + gamma - Ei(1))/3 - 32/9, where e = A001113, gamma = A001620 and Ei(1) = A091725.
%F A317487 Sum_{n>=4} (-1)^n/a(n) = 16*(gamma - Ei(-1))/3 - 8/(3*e) - 28/9, where Ei(-1) = -A099285. (End)
%t A317487 a[n_] := n!*(n-2)*(n-3)/8; a[1] = 0; Array[a, 22] (* _Amiram Eldar_, Jun 21 2026 *)
%o A317487 (PARI) a(n) = if(n > 1, n!*(n-2)*(n-3)/8, 0); \\ _Andrew Howroyd_, Jul 30 2018
