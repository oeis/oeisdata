%T A217531 24030,24936,25612,28132,32040,35125,35296,43053,47835,51404,51703,
%U A217531 52324,55869,66003,69060,80125,82464,86833,101061,102240,103039,104647,110334,110616,111153
%N A217531 Numbers k such that sum of cubes of digits of k equals the sum of prime divisors of k.
%C A217531 Numbers k such that A055012(k) = A008472(k).
%H A217531 Amiram Eldar, <a href="/A217531/b217531.txt">Table of n, a(n) for n = 1..10000</a>
%e A217531 402 = 2*3*67 is in the sequence because 4^3 + 0^3 + 2^3 = 2 + 3 + 67 = 72.
%t A217531 Rest[Select[Range[20000], Total[Transpose[FactorInteger[#]][[1]]]==Total[IntegerDigits[#]^3]&]]
%o A217531 (PARI) isok(k) = vecsum(factor(k)[, 1]) == vecsum(apply(x -> x^3, digits(k))); \\ _Amiram Eldar_, Mar 03 2026
%Y A217531 Cf. A055012, A008472.
