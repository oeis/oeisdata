%U A217533 4053412,4150651,4213312,4293261,4351003,4499068,5053964,5794602,6277560,10030353,10211034,10422024,10423242
%N A217533 Numbers k such that sum of 5th power of digits of k equals the sum of prime divisors of k.
%C A217533 Numbers k such that A055014(k) = A008472(k).
%H A217533 Amiram Eldar, <a href="/A217533/b217533.txt">Table of n, a(n) for n = 1..10000</a>
%e A217533 22011 = 3*11*23*29 is in the sequence because 2^5 + 2^5 + 0^5 + 1^5 + 1^5 = 3 + 11 + 23 + 29 = 66.
%t A217533 Rest[Select[Range[8000000], Total[Transpose[FactorInteger[#]][[1]]]==Total[IntegerDigits[#]^5]&]]
%o A217533 (PARI) isok(k) = vecsum(factor(k)[, 1]) == vecsum(apply(x -> x^5, digits(k))); \\ _Amiram Eldar_, Mar 03 2026
%Y A217533 Cf. A055014, A008472.
