%T A198584 14563,29013,29125,54613,58197,58253,116053,116501,218453,232789,
%U A198584 233013,464213,466005,466033,873813,931157,932053,932067,1856853,1864021,1864133
%N A198584 Odd numbers producing exactly 3 odd numbers under the Collatz (3x+1) iterations.
%C A198584 One of the odd numbers is always 1. So besides a(n), there is exactly one other odd number, A198585(n), which is a term in A002450.
%C A198584 This is the disjoint union of sequences A228871 and A228872, corresponding to the terms for which the second odd number of the trajectory is larger, respectively smaller than the initial value. - _T. D. Noe_, Sep 12 2013, edited by _M. F. Hasler_, Apr 24 2026
%C A198584 Start with the numbers in A350053. If k is in sequence then so is 4*k+1. - _Ralf Stephan_, Jun 18 2025
%H A198584 T. D. Noe, <a href="/A198584/b198584.txt">Table of n, a(n) for n = 1..1009</a>
%F A198584 Numbers of the form (2^m*(2^n-1)/3-1)/3 where n == 2 (mod 6) if m is even and n == 4 (mod 6) if m is odd. - _Charles R Greathouse IV_, Sep 09 2022
%F A198584 a(n) = (16*2^floor(b(n)) - 2^(2*floor((b(n) - 1)/2) + 3*floor(b(n)) - 6*(floor(b(n)/2) - floor((floor(b(n))^2 + 20)/12) + n) - 2))/9 - 1/3 where b(n) = sqrt(3)*sqrt(4*n - 3). - _Alan Michael Gómez Calderón_, Feb 02 2025
%F A198584 a(n) = floor(16*2^b(n)*(1 - 2^d(n))/9) with b(n) = floor(sqrt(12*n-9)) and d(n) = 6*floor((b(n)^2-4)/12 - n) + (8 if b(n) odd else 4). - _M. F. Hasler_, Apr 24 2026
%e A198584 The Collatz iterations starting with 113 give 113, 340, 170, 85, 256, 128, 64, 32, 16, 8, 4, 2, 1. In this trajectory of 113 are three odd numbers: 113, 85 and 1. Therefore 113 is in the sequence.
%t A198584 Collatz[n_] := NestWhileList[If[EvenQ[#], #/2, 3 # + 1] &, n, # > 1 &]; t = {}; Do[If[Length[Select[Collatz[n], OddQ]] == 3, AppendTo[t, n]], {n, 1, 10000, 2}]; t
%o A198584 (Python)
%o A198584 from math import isqrt  ## code edited by _M. F. Hasler_, Apr 24 2026
%o A198584 def A198584(n): # compute the n-th term of the sequence
%o A198584     n -= 1; s = isqrt(3*n)//3 ; a = s*3 ; b = a**2//3
%o A198584     c = n-b ; d = 4*(n*3+a+(c<s)+(c>4*s+1)+(c>5*s+1))+5
%o A198584     e = isqrt(d) ; f = e-1-( (d-e*e) >> 1 )
%o A198584     return ((((8<<e)-(1<<f))//3)-1)//3
%o A198584 for n in range(1,200):
%o A198584     print(A198584(n), end =", ") # _André Hallqvist_, Jul 25 2019
%o A198584 (Python)
%o A198584 # just prints the sequence
%o A198584 for a in range (5,100,1):
%o A198584   for b in range(a-8+4*(a&1),0,-6):
%o A198584     print(( ((1<<a)-(1<<b))//3-1)//3 ,end=",") # _André Hallqvist_, Aug 14 2019
%o A198584 (PARI) A198584(n,b=sqrtint(12*n-9))=(2^b-2^(b+b%2*4+4+((b^2-4)\12-n)*6))*16\9 \\ _M. F. Hasler_, Apr 24 2026
