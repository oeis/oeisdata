%I A240134 #27 May 11 2026 23:37:09
%S A240134 0,1,4,3,12,5,24,7,40,9,60,11,84,13,112,15,144,17,180,19,220,21,264,
%T A240134 23,312,25,364,27,420,29,480,31,544,33,612,35,684,37,760,39,840,41,
%U A240134 924,43,1012,45,1104,47,1200,49,1300,51,1404,53,1512,55,1624,57,1740,59,1860,61,1984,63,2112,65
%N A240134 Numerator of (n-1) * ceiling(n/2) / n.
%C A240134 A046092 Union A005408.
%H A240134 Bruce Nye, <a href="/A240134/b240134.txt">Table of n, a(n) for n = 1..5000</a>
%H A240134 <a href="/index/Rec#order_06">Index entries for linear recurrences with constant coefficients</a>, signature (0,3,0,-3,0,1).
%F A240134 a(2*n) = 2*n-1.
%F A240134 a(2*n-1) = 2*n*(n-1).
%F A240134 From _Colin Barker_, Apr 02 2014: (Start)
%F A240134 a(n) = 3*a(n-2) - 3*a(n-4) + a(n-6).
%F A240134 G.f.: x^2*(x^4-4*x-1) / ((x-1)^3*(x+1)^3). (End)
%F A240134 a(n) = n - 1 + (2*floor((n+2)/2)^2 - 2*floor((n+2)/2) - n + 1) * (n mod 2). - _Wesley Ivan Hurt_, Apr 02 2014
%F A240134 a(n) = (n-1)*(n+3-(n-1)*(-1)^n)/4. - _Wesley Ivan Hurt_, Dec 05 2023
%e A240134 a(1) = 0 because the numerator of: {(1-1) * ceiling(1/2) / 1 = 0 * 1 / 1 = (0 / 1)} = 0.
%e A240134 a(2) = 1 because the numerator of: {(2-1) * ceiling(2/2) / 2 = 1 * 1 / 2 = (1 / 2)} = 1.
%e A240134 a(3) = 4 because the numerator of: {(3-1) * ceiling(3/2) / 3 = 2 * 2 / 3 = (4 / 3)} = 4.
%p A240134 A240134:=n->numer( (n-1)*ceil(n/2) / n ); seq(A240134(n), n=1..66);
%t A240134 Table[Numerator[(n - 1) Ceiling[n/2] / n], {n, 100}]
%o A240134 (PARI) concat(0, Vec(x^2*(x^4-4*x-1)/((x-1)^3*(x+1)^3) + O(x^67))) \\ _Colin Barker_, Apr 02 2014
%o A240134 (Magma) [(n-1)*(n+3-(n-1)*(-1)^n)/4 : n in [1..66]]; // _Wesley Ivan Hurt_, Dec 05 2023
%o A240134 (Python)
%o A240134 def A240134(n): return (m:=n>>1)*(m+1)<<1 if n&1 else (n&-2)-1  # _Chai Wah Wu_, May 07 2026
%Y A240134 Bisections: A046092 and A005408.
%Y A240134 Cf. A142150 (floor(a(n) / n)).
%K A240134 nonn,easy,changed
%O A240134 1,3
%A A240134 _Wesley Ivan Hurt_, Apr 02 2014
