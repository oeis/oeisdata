%I A240007 #30 May 12 2026 05:33:13
%S A240007 4,75,8,375,140,56,675,1029,294,1380,11774,180,420,112,120,656,6328,
%T A240007 312,243,3660,24003,3612
%N A240007 Smallest k such that the number of groups of order k is equal to prime(n), or 0 if no such k exists.
%C A240007 According to the Conway article, every n <= 10000000 is the number of groups of order k for some k. - _Eric M. Schmidt_, Sep 14 2014
%H A240007 John H. Conway, Heiko Dietrich and E. A. O'Brien, <a href="http://www.math.auckland.ac.nz/~obrien/research/gnu.pdf">Counting groups: gnus, moas and other exotica</a>, The Mathematical Intelligencer, Spring 2008, Volume 30, Issue 2, pp 6-15, doi:10.1007/BF02985731. See Table 2 but beware errors; see A046057.
%F A240007 a(n) = A046057(prime(n)). - _Andrei Zabolotskii_, May 11 2026
%e A240007 a(6)= 56 because prime(6) = 13 => there exists 13 groups of order 56.
%o A240007 (SageMath)
%o A240007 def A240007(n_range, search_limit=2000):
%o A240007     """ Returns -1 if no such k is found within the search_limit.
%o A240007     GAP's Small Groups library is complete only up to 2000. """
%o A240007     targets = {int(nth_prime(n)): n for n in n_range}
%o A240007     results = {n: -1 for n in n_range}
%o A240007     found = 0
%o A240007     bound = len(n_range)
%o A240007     for k in range(1, search_limit + 1):
%o A240007         try:
%o A240007             count = int(gap.NumberSmallGroups(k))
%o A240007             if count in targets:
%o A240007                 val = targets[count]
%o A240007                 if results[val] == -1:
%o A240007                     results[val] = k
%o A240007                     found += 1
%o A240007             if found == bound: break
%o A240007         # GAP might not have the order in its library
%o A240007         except Exception:
%o A240007             continue
%o A240007     return [results[n] for n in n_range]
%o A240007 lst = A240007(range(1, 20), 2000); print(lst)  # _Peter Luschny_, May 11 2026
%Y A240007 Cf. A000001, A046057, A053403.
%K A240007 nonn,more,changed
%O A240007 1,1
%A A240007 _Michel Lagneau_, Mar 30 2014
%E A240007 Values for 59, 71, 79, 89, and 97 filled in from Conway link by _Eric M. Schmidt_, Sep 14 2014
