%p A260850 A260850List := proc(N)
%p A260850     local a, b, i, n, p;
%p A260850     a := Vector(1 .. N);
%p A260850     b := 1;
%p A260850     for n from 1 to N do
%p A260850         for i in ifactors(n)[2] do
%p A260850             p := i[1]^i[2];
%p A260850             b := `if`(b mod p = 0, b/p, b*p);
%p A260850         end do;
%p A260850         a[n] := b;
%p A260850     end do;
%p A260850     convert(a, list);
%p A260850 end proc:
%p A260850 A260850List(100); # _Felix Huber_, May 27 2026
%t A260850 nn = 35; p[_] := 0; r = 0;
%t A260850 Do[(Map[If[p[#1] < #2,
%t A260850       p[#1] += #2,
%t A260850       p[#1] -= #2] & @@ # &, #];
%t A260850       If[r < #, r = #] &[#[[-1, 1]] ] ) &@
%t A260850     Map[{PrimePi[#1], #2} & @@ # &, FactorInteger[n]];
%t A260850   a[n] = Times @@ Array[Prime[#]^p[#] &, r], {n, nn}];
%t A260850 Array[a, nn] (* _Michael De Vlieger_, Apr 12 2024 *)
