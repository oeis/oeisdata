%S A372881 1,7,19,44,61,133,127,256,297,427,331,836,469,889,1159,1408,817,2079,
%T A372881 1027,2684,2413,2317,1519,4864,2825,3283,4131,5588,2437,8113,2791,
%U A372881 7424,6289,5719,7747,13068,3997,7189,8911,15616,4921,16891,5419,14564,18117,10633,6487,26752
%N A372881 a(n) = Sum_{j=1..n} Sum_{k=1..n} gcd(j*k,n).
%H A372881 Amiram Eldar, <a href="/A372881/b372881.txt">Table of n, a(n) for n = 1..10000</a> (terms 1..1000 from Seiichi Manyama)
%F A372881 Multiplicative with a(p^e) = Sum_{j,k=0..e} f(j,e,p)*f(k,e,p)*p^(2*e+min(j+k,e)-j-k-2), where f(m,e,p) = p-1 if m < e, and p if m = e. - _Amiram Eldar_, Apr 21 2026
%t A372881 g[p_, i_, e_] := If[i == e, p, p-1]; f[p_, e_] := Sum[Sum[p^(2*e + Min[j+k, e] - j - k - 2) * If[j == e, p, p - 1], {j, 0, e}]*If[k == e, p, p - 1], {k, 0, e}]; a[1] = 1; a[n_] := Times @@ f @@@ FactorInteger[n]; Array[a, 100] (* _Amiram Eldar_, Apr 21 2026 *)
%o A372881 (PARI) a(n) = sum(j=1, n, sum(k=1, n, gcd(j*k, n)));
%o A372881 (PARI) g(p, e) = sum(k = 0, e, if(k == e, p, p-1) * sum(j = 0, e, if(j == e, p, p-1) * p^(2*e + min(j+k, e) - j - k - 2)));
%o A372881 a(n) = {my(f = factor(n)); prod(i = 1, #f~, g(f[i, 1], f[i, 2]));} \\ _Amiram Eldar_, Apr 21 2026
