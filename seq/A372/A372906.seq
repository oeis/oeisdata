%S A372906 1,5,11,21,29,55,55,82,97,145,131,231,181,275,319,312,305,485,379,609,
%T A372906 605,655,551,902,681,905,819,1155,869,1595,991,1184,1441,1525,1595,
%U A372906 2037,1405,1895,1991,2378,1721,3025,1891,2751,2813,2755,2255,3432,2521,3405,3355
%N A372906 a(n) = Sum_{j=1..n} Sum_{k=1..n} gcd(j,n) * gcd(k,n) / gcd(j*k,n).
%H A372906 Amiram Eldar, <a href="/A372906/b372906.txt">Table of n, a(n) for n = 1..10000</a> (terms 1..1000 from Seiichi Manyama)
%F A372906 Multiplicative with a(p^e) = Sum_{j,k=0..e} f(j,e,p)*f(k,e,p)*p^(2*e-2-min(j+k,e)), where f(m,e,p) = p-1 if m < e, and p if m = e. - _Amiram Eldar_, Apr 21 2026
%t A372906 g[p_, i_, e_] := If[i == e, p, p-1]; f[p_, e_] := Sum[Sum[p^(2*e - 2 - Min[j+k , e]) * If[j == e, p, p - 1], {j, 0, e}]*If[k == e, p, p - 1], {k, 0, e}]; a[1] = 1; a[n_] := Times @@ f @@@ FactorInteger[n]; Array[a, 100] (* _Amiram Eldar_, Apr 21 2026 *)
%o A372906 (PARI) a(n) = sum(j=1, n, sum(k=1, n, gcd(j, n)*gcd(k, n)/gcd(j*k, n)));
%o A372906 (PARI) g(p, e) = sum(k = 0, e, if(k == e, p, p-1) * sum(j = 0, e, if(j == e, p, p-1) * p^(2*e - 2 - min(j+k, e))));
%o A372906 a(n) = {my(f = factor(n)); prod(i = 1, #f~, g(f[i, 1], f[i, 2]));} \\ _Amiram Eldar_, Apr 21 2026
