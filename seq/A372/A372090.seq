%N A372090 G.f. A(x) satisfies A(x) = 1/( 1 - 4*x*A(x)*(1 + x*A(x)) )^(1/2).
%H A372090 Robert Israel, <a href="/A372090/b372090.txt">Table of n, a(n) for n = 0..931</a>
%F A372090 a(n) = (1/(n+1)) * Sum_{k=0..n} 4^k * binomial(n/2+k-1/2,k) * binomial(k,n-k).
%F A372090 a(n) = 4^n*binomial((3*n-1)/2, n)*hypergeom([(1-n)/2, -n/2], [(1-3*n)/2], -1)/(n+1). - _Stefano Spezia_, Apr 18 2024
%F A372090 D-finite with recurrence: -3840*(2*n + 3)*(2*n + 1)*(n + 2)*a(n) + 16*(977*n^3 + 6399*n^2 + 12934*n + 7680)*a(n + 2) + 2*(n + 5)*(721*n^2 + 7510*n + 18900)*a(n + 4) - 11*(n + 5)*(n + 7)*(n + 6)*a(n + 6) = 0. - _Robert Israel_, May 20 2026
%p A372090 f:= gfun:-rectoproc({-3840*(2*n + 3)*(2*n + 1)*(n + 2)*a(n) + 16*(977*n^3 + 6399*n^2 + 12934*n + 7680)*a(n + 2) + 2*(n + 5)*(721*n^2 + 7510*n + 18900)*a(n + 4) - 11*(n + 5)*(n + 7)*(n + 6)*a(n + 6), a(0) = 1, a(1) = 2, a(2) = 12, a(3) = 88, a(4) = 728, a(5) = 6464}, a(n), remember):
%p A372090 map(f, [$0..40]); # _Robert Israel_, May 20 2026
%o A372090 (PARI) a(n) = sum(k=0, n, 4^k*binomial(n/2+k-1/2, k)*binomial(k, n-k))/(n+1);
%Y A372090 Cf. A372091.
