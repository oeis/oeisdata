%I A273161 #12 May 15 2026 05:29:34
%S A273161 0,1,2,3,5,7,13,19,34,61,108,174,384,641,1166,2337,4458,7828,16421,
%T A273161 29346,57231,114126,215915,396491,839324,1549146,2983185,5978656,
%U A273161 11628952,21812113,45099914,84842925,166417181,332267593,647614074,1234586894,2538571022
%N A273161 a(n) = Sum_{k=1..n} C(n-k, floor((n-k)/k)).
%F A273161 a(n) ~ 2^(n - 3/2) / sqrt(Pi*n). - _Vaclav Kotesovec_, May 28 2021
%p A273161 A273161:=n->add(binomial(n-i,floor((n-i)/i)), i=1..n): seq(A273161(n), n=0..50);
%t A273161 Table[Sum[Binomial[n - i, Floor[(n - i)/i]], {i, n}], {n, 0, 40}]
%o A273161 (Python)
%o A273161 from math import comb
%o A273161 def A273161(n):
%o A273161     c, j = 0, 1
%o A273161     while j <= n:
%o A273161         k = n//j
%o A273161         m = n//k
%o A273161         c += comb(n-j+1,k)-comb(n-m,k)
%o A273161         j = m+1
%o A273161     return c # _Chai Wah Wu_, May 14 2026
%Y A273161 Cf. A051054, A273160.
%K A273161 nonn,easy,changed
%O A273161 0,3
%A A273161 _Wesley Ivan Hurt_, May 16 2016
