%N A037118 Trajectory of 3 under map n->41n+1 if n odd, n->n/2 if n even.
%H A037118 Vincenzo Librandi, <a href="/A037118/b037118.txt">Table of n, a(n) for n = 0..1000</a>
%t A037118 NestList[If[OddQ[#],41#+1,#/2]&,3,34] (* _Harvey P. Dale_, Jul 27 2012 *)
%o A037118 (Magma) f := func< x | IsOdd(x) select 41*x+1 else x div 2 >; x := 3; L := [x]; for i in [0..33] do
%o A037118 x := f(x); L := L cat [x]; end for; L; // _Vincenzo Librandi_, Feb 23 2026
