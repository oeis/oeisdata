%U A037493 75953565144145,607628521153162,4861028169225297,38888225353802378,311105802830419025,2488846422643352202,19910771381146817617,159286171049174540938
%N A037493 Base 8 digits are, in order, the first n terms of the periodic sequence with initial period 2,1.
%H A037493 <a href="/index/Rec">Index entries for linear recurrences with constant coefficients</a>, signature (8,1,-8).
%F A037493 a(n) = 8a(n-1) + a(n-2) - 8a(n-3).
%F A037493 G.f.: x*(2+x) / ( (x-1)*(8*x-1)*(1+x) ). - _R. J. Mathar_, Apr 26 2015
%F A037493 a(n) = floor(17*8^n/63). - _Christian Krause_, Jun 04 2026
%t A037493 With[{c=PadRight[{},20,{2,1}]},Table[FromDigits[Take[c,n],8],{n,20}]] (* or *) LinearRecurrence[{8,1,-8},{2,17,138},20] (* _Harvey P. Dale_, Jan 24 2012 *)
