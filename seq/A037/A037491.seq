%I A037491 #31 May 30 2026 17:01:53
%S A037491 2,13,80,481,2888,17329,103976,623857,3743144,22458865,134753192,
%T A037491 808519153,4851114920,29106689521,174640137128,1047840822769,
%U A037491 6287044936616,37722269619697,226333617718184,1358001706309105,8148010237854632,48888061427127793,293328368562766760
%N A037491 Base 6 digits are, in order, the first n terms of the periodic sequence with initial period 2,1.
%H A037491 <a href="/index/Rec#order_03">Index entries for linear recurrences with constant coefficients</a>, signature (6,1,-6).
%F A037491 a(n) = 6a(n-1) + a(n-2) - 6a(n-3).
%F A037491 G.f.: x*(2+x) / ( (x-1)*(6*x-1)*(1+x) ). - _R. J. Mathar_, Nov 21 2011
%F A037491 a(n) = floor(13*6^n/35). - _Christian Krause_, May 30 2026
%F A037491 E.g.f.: (13*(cosh(6*x) - cosh(x) + sinh(6*x)) - 8*sinh(x))/35. - _Stefano Spezia_, May 30 2026
%t A037491 Module[{nn=20,d},d=PadRight[{},nn,{2,1}];Table[FromDigits[Take[d,n],6],{n,nn}]] (* _Harvey P. Dale_, Feb 26 2015 *)
%t A037491 (* Alternative: *)
%t A037491 LinearRecurrence[{6,1,-6},{2,13,80},20] (* _Harvey P. Dale_, Feb 26 2015 *)
%K A037491 nonn,base,easy
%O A037491 1,1
%A A037491 _Clark Kimberling_
%E A037491 An incorrect recurrence was deleted by _N. J. A. Sloane_, Sep 13 2009
%E A037491 a(21)-a(23) from _Christian Krause_, May 30 2026
