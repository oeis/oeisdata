%S A037175 2,3,15,22,98,460,5408,21170,243568,3587402,25881424,25888784,
%T A037175 33305870,61202192,115333190,135135182,167241932,788355824,788360176,
%U A037175 1653570248
%N A037175 Numbers k such that |s(k) - k| = number of primes <= k, where s(k) is sigma(k) - k.
%C A037175 a(21) > 10^11. - _Donovan Johnson_ Aug 15 2011
%F A037175 { k : abs(A033880(k)) = A000720(k) }.
%p A037175 with(numtheory):np:=0: for n from 1 to 300000 do if isprime(n) then np:=np+1 fi: if(abs(sigma(n)-2*n)=np) then printf("%d, ",n) fi od: # C. Ronaldo, Feb 20 2005
%p A037175 # Alternative:
%p A037175 q:= proc(k) uses numtheory; is(abs(sigma(k)-2*k)=pi(k)) end:
%p A037175 select(q, [$1..50000])[];  # _Alois P. Heinz_, Jun 17 2026
%o A037175 (PARI) np=0;for(n=1,10000000,if(isprime(n),np=np+1);if(abs(sigma(n)-2*n)==np,print1(n,","))) \\ C. Ronaldo, Feb 20 2005
%Y A037175 Cf. A000203, A000720, A033880.
%K A037175 nonn,more
%O A037175 1,1
%A A037175 _Naohiro Nomoto_
