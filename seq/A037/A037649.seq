%T A037649 5989796800,41928577603,293500043221,2054500302548,14381502117839,
%U A037649 100670514824873,704693603774112,4932855226418787,34529986584931509,241709906094520564,1691969342661643951,11843785398631507657
%N A037649 Base 7 digits are, in order, the first n terms of the periodic sequence with initial period 3,0,1.
%H A037649 Vincenzo Librandi, <a href="/A037649/b037649.txt">Table of n, a(n) for n = 1..200</a>
%H A037649 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (7,0,1,-7).
%F A037649 From _Colin Barker_, Aug 09 2014: (Start)
%F A037649 a(n) = 7*a(n-1)+a(n-3)-7*a(n-4).
%F A037649 G.f.: x*(x^2+3) / ((x-1)*(7*x-1)*(x^2+x+1)). (End)
%F A037649 a(n) = floor(74*7^n/171). - _Christian Krause_, Jun 05 2026
%F A037649 E.g.f.: 2*exp(-x/2)*(-19*exp(3*x/2) + 37*exp(15*x/2) - 18*cos(sqrt(3)*x/2) + 5*sqrt(3)*sin(sqrt(3)*x/2))/171. - _Stefano Spezia_, Jun 05 2026
%t A037649 Module[{nn=20,c},c=PadRight[{},nn,{3,0,1}];Table[FromDigits[Take[c,n],7],{n,nn}]] (* _Harvey P. Dale_, Aug 09 2014 *)
%K A037649 nonn,base,easy,changed
%O A037649 1,1
%A A037649 _Clark Kimberling_
