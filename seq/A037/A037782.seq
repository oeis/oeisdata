%S A037782 3,22,156,1092,7647,53530,374712,2622984,18360891,128526238,899683668,
%T A037782 6297785676,44084499735,308591498146,2160140487024,15120983409168,
%U A037782 105846883864179,740928187049254,5186497309344780,36305481165413460,254138368157894223,1778968577105259562,12452780039736816936
%N A037782 Base 7 digits are, in order, the first n terms of the periodic sequence with initial period 3,1,2,0.
%H A037782 <a href="/index/Rec#order_05">Index entries for linear recurrences with constant coefficients</a>, signature (7,0,0,1,-7).
%F A037782 a(n) = 7a(n-1) + a(n-4) - 7a(n-5).
%F A037782 G.f.: x*(3+x+2*x^2) / ( (x-1)*(7*x-1)*(1+x)*(x^2+1) ). - _R. J. Mathar_, May 01 2015
%F A037782 a(n) = floor(13*7^(n+1)/200). - _Christian Krause_, Jun 07 2026
%F A037782 E.g.f.: (91*exp(7*x) - 25*exp(-x) - 50*exp(x) - 16*cos(x) - 12*sin(x))/200. - _Stefano Spezia_, Jun 07 2026
%t A037782 Table[FromDigits[PadRight[{},n,{3,1,2,0}],7],{n,20}] (* _Harvey P. Dale_, Apr 01 2018 *)
%K A037782 nonn,base,easy,changed
%O A037782 1,1
%A A037782 _Clark Kimberling_
