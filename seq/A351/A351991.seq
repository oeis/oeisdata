%T A351991 886873780,4775054571,106484438048,651701988633,16430255716392,
%U A351991 111498817293652,3124376125290804,23598473924038152,721819990948712614,5975067276022072669,199594173117826648968
%N A351991 Expansion of e.g.f. Product_{k>=1} 1/(1 - x^prime(k)/prime(k)!).
%H A351991 Alois P. Heinz, <a href="/A351991/b351991.txt">Table of n, a(n) for n = 0..476</a>
%p A351991 b:= proc(n, i) option remember; `if`(n=0, 1, `if`(i<1, 0, b(n, i-1)+
%p A351991      (p-> `if`(p>n, 0, binomial(n, p)*b(n-p, i)))(ithprime(i))))
%p A351991     end:
%p A351991 a:= n-> b(n, numtheory[pi](n)):
%p A351991 seq(a(n), n=0..24);  # _Alois P. Heinz_, Mar 11 2026
%o A351991 (PARI) my(N=40, x='x+O('x^N)); Vec(serlaplace(1/prod(k=1, N, 1-isprime(k)*x^k/k!)))
%Y A351991 Cf. A005651, A319112, A334370.
%K A351991 nonn,changed
%O A351991 0,5
%A A351991 _Seiichi Manyama_, Feb 27 2022
