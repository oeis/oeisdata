%S A045874 1,10,102,1020,1020,1020,10206,102064,1020645,10206450,102064501,
%T A045874 1020645012,10206450124,1020645012408,10206450124080,10206450124080,
%U A045874 1020645012408001,10206450124080012,102064501240800126,1020645012408001260,1020645012408001260,102064501240800126006
%N A045874 a(1)=1, a(n) is the smallest multiple of n that begins with a(n-1).
%H A045874 Robert Israel, <a href="/A045874/b045874.txt">Table of n, a(n) for n = 1..431</a>
%p A045874 R:= 1: r:= 1:
%p A045874 for n from 2 to 20 do
%p A045874    for d from 0 do
%p A045874      y:= -10^d*r mod n;
%p A045874      if y < 10^d then
%p A045874        r:= y + 10^d*r; R:= R,r; break
%p A045874 fi od od:
%p A045874 R; # _Robert Israel_, Apr 07 2026
