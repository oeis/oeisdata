%I A045646 #29 Jul 09 2026 00:57:20
%S A045646 1,10,19,199,19999999999999999999999
%N A045646 Least integer k > 0 with additive persistence A031286(k) = n.
%C A045646 Original name: Alternative version of A006050.
%C A045646 This is also the smallest k such that digit sum of k = previous term. - _Dominick Cancilla_, Aug 09 2010
%D A045646 H. J. Hindin, The additive persistence of a number, J. Rec. Math., 7 (No. 2, 1974), 134-135.
%H A045646 N. J. A. Sloane, <a href="http://neilsloane.com/doc/persistence.html">The persistence of a number</a>, J. Recreational Math., 6 (1973), 97-98.
%F A045646 For n > 1, a(n) = 2*10^((a(n-1)-1)/9) - 1.
%F A045646 a(n) = A006050(n) for n>=1.
%p A045646 a:= proc(n) a(n):= `if`(n<2, 10^n, 2*10^((a(n-1)-1)/9)-1) end:
%p A045646 seq(a(n), n=0..4);  # _Alois P. Heinz_, Jul 07 2026
%t A045646 Join[{1},NestList[2*10^((#-1)/9)-1&,10,3]] (* _Harvey P. Dale_, Sep 20 2011 *)
%o A045646 (PARI) A045646(n)=if(n>1, 10^(A045646(n-1)\9)*2-1, 10^n) \\ _M. F. Hasler_, Jul 05 2026
%o A045646 (Python) A045646=lambda n: 10**(A045646(n-1)//9)*2-1 if n>1 else 10**n # _M. F. Hasler_, Jul 05 2026
%Y A045646 Cf. A003001 (similar for multiplication), A006050 (variant with a(0)=0), A031286 (additive persistence).
%K A045646 nonn,base,nice,changed
%O A045646 0,2
%A A045646 _N. J. A. Sloane_
%E A045646 Next term is 1 followed by 2222222222222222222222 9s.
%E A045646 New name from _M. F. Hasler_, Jul 07 2026
