%I A045070 #14 Jul 23 2026 03:34:49
%S A045070 831,975,1011,1020,1279,1855,1999,2035,2044,2303,2879,3023,3059,3068,
%T A045070 3199,3263,3295,3311,3319,3323,3325,3326,3391,3535,3571,3580,3647,
%U A045070 3791,3827,3836,3871,3887,3895,3899,3901,3902,3919
%N A045070 Numbers whose base-4 representation contains exactly one 0 and four 3's.
%H A045070 Robert Israel, <a href="/A045070/b045070.txt">Table of n, a(n) for n = 1..10000</a>
%p A045070 f:= proc(d) local n1,R,Q;
%p A045070   R:= NULL:
%p A045070   for n1 from 0 to d-5 do
%p A045070     Q:= select(t -> t[-1] <> 0, combinat:-permute([0,1$n1,2$(d-n1-5),3$4]));
%p A045070     R:= R, op(map(proc(t) local i; add(t[i]*4^(i-1),i=1..d) end proc, Q));
%p A045070   od;
%p A045070   sort([R])
%p A045070 end proc:
%p A045070 seq(op(f(d)),d=5..7); # _Robert Israel_, Jul 23 2026
%Y A045070 Cf. A007090.
%K A045070 nonn,base,changed
%O A045070 1,1
%A A045070 _Clark Kimberling_
