%I A154660 #9 May 18 2026 18:43:40
%S A154660 3,4,5,6,7,8
%N A154660 Numbers k such that k! + 37 and abs(k! - 37) are primes.
%e A154660 5 is a term since 5! - 37 = 83 and 5! + 37 = 157, both prime.
%t A154660 lst={};a=37;Do[If[PrimeQ[n!-a]&&PrimeQ[n!+a],AppendTo[lst,n]],{n,2*5!}];lst
%Y A154660 Cf. A144046.
%K A154660 nonn,full,fini
%O A154660 1,1
%A A154660 _Vladimir Joseph Stephan Orlovsky_, Jan 13 2009
%E A154660 Name corrected by _Chai Wah Wu_, Oct 18 2020
