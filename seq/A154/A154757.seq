%I A154757 #19 Jun 11 2026 01:05:56
%S A154757 1,1,3,14,83,574,4433,37274,335751,3204616,32159272,337383121,
%T A154757 3684215369,41735965645,489173496890,5919292080009,73818803164143,
%U A154757 947369393139133,12496581035619137,169248547161053704,2351389448608182950,33484451978153816768,488397582642492894240,7291892040418905617996
%N A154757 G.f. satisfies A(x) = Sum_{n>=0} A^n(x)^(n+1).
%C A154757 Notation: A^n(x) denotes the n-th iteration of A(x) with A^0(x) = x.
%H A154757 Paul D. Hanna, <a href="/A154757/b154757.txt">Table of n, a(n) for n = 1..150</a>
%F A154757 G.f. A(x) satisfies: A^k(x) = Sum_{n>=0} ( A^(n+k-1)(x) )^(n+1) for all k.
%e A154757 G.f.: A(x) = x + x^2 + 3*x^3 + 14*x^4 + 83*x^5 + 574*x^6 + ...
%e A154757 where A(x) = x + A(x)^2 + A^2(x)^3 + A^3(x)^4 + A^4(x)^5 + ...
%e A154757 Likewise,
%e A154757 A^2(x) = A(x) + A^2(x)^2 + A^3(x)^3 + A^4(x)^4 + A^5(x)^5 + ...
%e A154757 A^3(x) = A^2(x) + A^3(x)^2 + A^4(x)^3 + A^5(x)^3 + A^6(x)^5 + ...
%e A154757 A^(-1)(x) = x - x^2 - A(x)^3 - A^2(x)^4 - A^3(x)^5 - ...
%e A154757 etc.
%e A154757 Explicitly,
%e A154757 A^2(x) = x + 2*x^2 + 8*x^3 + 44*x^4 + 292*x^5 + 2201*x^6 + ...;
%e A154757 A^3(x) = x + 3*x^2 + 15*x^3 + 96*x^4 + 715*x^5 + 5921*x^6 + ...;
%e A154757 A^4(x) = x + 4*x^2 + 24*x^3 + 176*x^4 + 1464*x^5 + 13322*x^6 + ...;
%e A154757 A^(-1)(x) = x - x^2 - x^3 - 4*x^4 - 21*x^5 - 133*x^6 - 959*x^7 - ...;
%e A154757 also,
%e A154757 A(x)^2 = x^2 + 2*x^3 + 7*x^4 + 34*x^5 + 203*x^6 + 1398*x^7 + ...;
%e A154757 A^2(x)^3 = x^3 + 6*x^4 + 36*x^5 + 236*x^6 + 1692*x^7 + ...;
%e A154757 A^3(x)^4 = x^4 + 12*x^5 + 114*x^6 + 1032*x^7 + 9367*x^8 + ...;
%e A154757 A^4(x)^5 = x^5 + 20*x^6 + 280*x^7 + 3440*x^8 + ...;
%e A154757 A^5(x)^6 = x^6 + 30*x^7 + 585*x^8 + 9490*x^9 + ...; ...
%o A154757 (PARI) \\ By definition A(x) = Sum_{n>=0} A^n(x)^(n+1)
%o A154757 {a(n) = my(A=x,G); for(k=1,n, A = truncate(A) + x*O(x^k); G = x + x*O(x^k);
%o A154757 A = x + sum(m=1,k, (G=subst(A,x,G))^(m+1)) + x*O(x^n);); polcoeff(GF=A,n)}
%o A154757 \\ Print the terms
%o A154757 {upto(n) = a(n); Vec(GF)}
%o A154757 upto(25) \\ Program revised by _Paul D. Hanna_, Jun 10 2026
