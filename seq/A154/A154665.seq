%I A154665 #20 May 20 2026 04:42:14
%S A154665 3,4,5,6,40
%N A154665 Numbers k such that k!^2 + 8663 and abs(k!^2 - 8663) are primes.
%C A154665 Next term is larger than 72.
%C A154665 a(6) > 1000 (if it exists) - _Robert Price_, Mar 26 2019
%C A154665 There are no more terms: none were found in a search past 8663 and (k!)^2 + 8663 is divisible by 8663 for all k >= 8663. - _Michael S. Branicky_, May 19 2026
%t A154665 lst={};a=8663;Do[If[PrimeQ[n!^2-a]&&PrimeQ[n!^2+a],AppendTo[lst,n]],{n,3*4!}];lst
%Y A154665 Cf. A144046, A154660, A154661, A154662, A154663, A154664.
%K A154665 nonn,fini,full
