%I A065018 #30 Apr 22 2026 04:47:27
%S A065018 1,10,17,59,37,170,65,284,186,370,145,1003,197,650,629,1245,325,1860,
%T A065018 401,2183,1105,1450,577,4828,998,1970,1786,3835,901,6290,1025,5214,
%U A065018 2465,3250,2405,10974,1445,4010,3349,10508,1765,11050,1937,8555,6882,5770,2305,21165
%N A065018 a(n) = Sum_{d|n} sigma(d)^2.
%H A065018 Harry J. Smith, <a href="/A065018/b065018.txt">Table of n, a(n) for n = 1..1000</a>
%F A065018 From _R. J. Mathar_, Feb 03 2011: (Start)
%F A065018 Dirichlet convolution of A072861 and A000012.
%F A065018 Dirichlet g.f.: zeta^2(s)*zeta^2(s-1)*zeta(s-2)/zeta(2s-2). (End)
%F A065018 Sum_{k=1..n} a(k) ~ 5 * zeta(3)^2 * n^3 / 6. - _Vaclav Kotesovec_, Feb 01 2019
%F A065018 From _Seiichi Manyama_, May 08 2021: (Start)
%F A065018 G.f.: Sum_{k >= 1} sigma(k)^2 * x^k/(1 - x^k).
%F A065018 If p is prime, a(p) = 1 + (p+1)^2. (End)
%F A065018 Multiplicative with a(p^e) = Sum_{k=0..e} ((p^(k+1)-1)/(p-1))^2. - _Amiram Eldar_, Apr 22 2026
%t A065018 f[p_, e_] := ((p^(2*e+4)-1)/(p+1) - 2*p^(e+2) + e*(p-1) + 2*p)/(p-1)^3; a[1] = 1; a[n_] := Times @@ f @@@ FactorInteger[n]; Array[a, 100] (* _Amiram Eldar_, Apr 22 2026 *)
%o A065018 (PARI) a(n) = sumdiv(n, d, sigma(d)^2); \\ _Harry J. Smith_, Oct 03 2009
%o A065018 (PARI) my(N=66, x='x+O('x^N)); Vec(sum(k=1, N, sigma(k)^2*x^k/(1-x^k))) \\ _Seiichi Manyama_, May 08 2021
%Y A065018 Cf. A000012, A029939, A062367, A072861.
%K A065018 mult,nonn,easy,changed
%O A065018 1,2
%A A065018 _Vladeta Jovovic_, Nov 19 2001
