%N A065543 a(n) is smallest prime > 11*a(n-1), a(1) = 11.
%H A065543 Bruce Nye, <a href="/A065543/b065543.txt">Table of n, a(n) for n = 1..500</a>
%t A065543 NextPrim[n_Integer] := Block[ {k = n + 1}, While[ !PrimeQ[k], k++ ]; Return[k]]; a[1] = 11; a[n_] := NextPrim[ 11*a[n - 1]]; Table[ a[n], {n, 1, 20} ]
%o A065543 (PARI) lista(nn) = {my(va=vector(nn));va[1]=11;for(n=2, nn, va[n]=nextprime(11*va[n-1]));va;} \\ _Bruce Nye_, Apr 15 2026
