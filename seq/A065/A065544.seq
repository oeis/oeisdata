%N A065544 a(n) is smallest prime > 13*a(n-1), a(1) = 13.
%H A065544 Bruce Nye, <a href="/A065544/b065544.txt">Table of n, a(n) for n = 1..500</a>
%t A065544 NextPrim[n_Integer] := Block[ {k = n + 1}, While[ !PrimeQ[k], k++ ]; Return[k]]; a[1] = 13; a[n_] := NextPrim[ 13*a[n - 1]]; Table[ a[n], {n, 1, 20} ]
%o A065544 (PARI) lista(nn) = {my(va=vector(nn));va[1]=13;for(n=2, nn, va[n]=nextprime(13*va[n-1]));va;} \\ _Bruce Nye_, Apr 15 2026
