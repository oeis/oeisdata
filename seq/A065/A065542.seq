%N A065542 a(n) is smallest prime > 7*a(n-1), a(1) = 7.
%t A065542 NextPrim[n_Integer] := Block[ {k = n + 1}, While[ !PrimeQ[k], k++ ]; Return[k]]; a[1] = 7; a[n_] := NextPrim[ 7*a[n - 1]]; Table[ a[n], {n, 1, 20} ]
%t A065542 NestList[NextPrime[7#]&,7,20] (* _Harvey P. Dale_, Apr 23 2019 *)
%o A065542 (PARI) lista(nn) = {my(va=vector(nn));va[1]=7;for(n=2, nn, va[n]=nextprime(7*va[n-1]));va;} \\ _Bruce Nye_, Apr 01 2026
