%U A065538 115202710221517,1152027102215173,11520271022151733,115202710221517367,1152027102215173871,11520271022151738733,115202710221517387361,1152027102215173873693,11520271022151738737021
%N A065538 a(n) is smallest prime > 10*a(n-1), a(1) = 11.
%H A065538 Bruce Nye, <a href="/A065538/b065538.txt">Table of n, a(n) for n = 1..1000</a>
%t A065538 NextPrim[n_Integer] := Block[ {k = n + 1}, While[ !PrimeQ[k], k++ ]; Return[k]]; a[1] = 11; a[n_] := NextPrim[ 10*a[n - 1]]; Table[ a[n], {n, 1, 20} ]
%o A065538 (PARI) lista(nn) = {my(va=vector(nn)); va[1]=11; for(n=2, nn, va[n]=nextprime(10*va[n-1])); va; } \\ _Bruce Nye_, Apr 08 2026
