%U A065539 132175317727727,1321753177277287,13217531772772933,132175317727729369,1321753177277293697,13217531772772937039,132175317727729370443,1321753177277293704439
%N A065539 a(n) is smallest prime > 10*a(n-1), a(1) = 13.
%H A065539 Bruce Nye, <a href="/A065539/b065539.txt">Table of n, a(n) for n = 1..1000</a>
%t A065539 NextPrim[n_Integer] := Block[ {k = n + 1}, While[ !PrimeQ[k], k++ ]; Return[k]]; a[1] = 13; a[n_] := NextPrim[ 10*a[n - 1]]; Table[ a[n], {n, 1, 20} ]
%o A065539 (PARI) lista(nn) = {my(va=vector(nn)); va[1]=13; for(n=2, nn, va[n]=nextprime(10*va[n-1])); va; } \\ _Bruce Nye_, Apr 08 2026
