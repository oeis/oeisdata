%T A065541 294379823,1471899119,7359495683,36797478433,183987392167,
%U A065541 919936960849,4599684804259,22998424021409,114992120107093,574960600535527,2874803002677691,14374015013388469
%N A065541 a(n) is the smallest prime > 5*a(n-1), a(1) = 5.
%H A065541 Bruce Nye, <a href="/A065541/b065541.txt">Table of n, a(n) for n = 1..1000</a>
%t A065541 NextPrim[n_Integer] := Block[ {k = n + 1}, While[ !PrimeQ[k], k++ ]; Return[k]]; a[1] = 5; a[n_] := NextPrim[ 5*a[n - 1]]; Table[ a[n], {n, 1, 25} ]
%o A065541 (PARI) lista(nn) = {my(va=vector(nn));va[1]=5;for(n=2, nn, va[n]=nextprime(5*va[n-1]));va;} \\ _Bruce Nye_, Apr 10 2026
