%e A342531 Row n = 15 counts the following strict partitions (empty columns indicated by dots, A..F = 10..15):
%e A342531   F  87     753   96    762   A5   A41   B4   B31  C3  C21  D2  .  E1  .  .
%e A342531      654    6432  852   843   861  9321  A32
%e A342531      54321  6531  7431  951   942
%e A342531                   7521  8421
%t A342531 Table[Length[Select[IntegerPartitions[n],UnsameQ@@#&&If[Length[#]<=1,k==0,Max[Differences[Reverse[#]]]==k]&]],{n,0,15},{k,0,n}]
%o A342531 (PARI)
%o A342531 r(n) = {if(n<3,n-1,2)}
%o A342531 c(i,k) = {prod(j=1,i-1, sum(u=0,k, x^(u*j)))}
%o A342531 B_x(k,N) = {my(x='x+O('x^(N+1)), B = sum(i=2,(sqrtint(8*N+1)-1)\2, x^(i*(i+1)/2)/(1-x^i) * (c(i,k-1) - c(i,k-2)))); B}
%o A342531 A_xy(N) = { my(x='x+O('x^(N+1)), A = 1/(1-x) + sum(k=1,N, y^k * B_x(k,N))); vector(N, n, concat(Vecrev(polcoeff(A, n-1)),vector(r(n),i,0)))} \\ _John Tyler Rascoe_, Jun 24 2026
