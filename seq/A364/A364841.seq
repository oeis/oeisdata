%N A364841 Number of subsets S of {1..n} containing no element equal to the sum of a k-multiset of elements of S, for any 2 <= k <= |S|.
%H A364841 Bert Dobbelaere, <a href="/A364841/b364841.txt">Table of n, a(n) for n = 0..64</a>
%e A364841 The a(0) = 1 through a(5) = 15 subsets:
%e A364841   {}  {}   {}   {}     {}     {}
%e A364841       {1}  {1}  {1}    {1}    {1}
%e A364841            {2}  {2}    {2}    {2}
%e A364841                 {3}    {3}    {3}
%e A364841                 {1,3}  {4}    {4}
%e A364841                 {2,3}  {1,3}  {5}
%e A364841                        {1,4}  {1,3}
%e A364841                        {2,3}  {1,4}
%e A364841                        {3,4}  {1,5}
%e A364841                               {2,3}
%e A364841                               {2,5}
%e A364841                               {3,4}
%e A364841                               {3,5}
%e A364841                               {4,5}
%e A364841                               {3,4,5}
%t A364841 Table[Length[Select[Subsets[Range[n]], Intersection[#,Join@@Table[Total/@Tuples[#,k], {k,2,Length[#]}]]=={}&]],{n,0,10}]
