%S A326328 1,-3,33,-723,25953,-1376643,101031873,-9795436563,1212135593793,
%T A326328 -186388033956483,34859622790687713,-7791941518975112403,
%U A326328 2051293521728340489633,-628173356956461494680323,221398076445213367209575553,-88980467736394156270609236243,40450409313733718675802456121473
%N A326328 a(n) = (2*n)! [x^(2*n)] cosh(x)^(-3).
%C A326328 Apparently all terms except the initial 1 have 3-valuation 1. - _F. Chapoton_, Nov 25 2021
%D A326328 H. S. Wall, Analytic Theory of Continued Fractions, Chelsea 1973, p. 206.
%F A326328 O.g.f. as a Stieltjes-type continued fraction: 1/(1 + 3*x/(1 + 8*x/(1 + 15*x/(1 +... + n*(n + 2)*x/(1 + ... ))))). See Wall, Chapter XI, eqn. 53.11 with k = 3. - _Peter Bala_, Dec 13 2025
%F A326328 From _Seiichi Manyama_, Apr 21 2026: (Start)
%F A326328 a(0) = 1; a(n) = -(1/4) * Sum_{k=0..n-1} (3 + 9^(n-k)) * binomial(2*n,2*k) * a(k).
%F A326328 a(n) = ((-1)^n/2) * (A000364(n) + A000364(n+1)) = (1/2) * (A028296(n) - A028296(n+1)). (End)
%p A326328 egf := cosh(z)^(-3): ser := series(egf, z, 36):
%p A326328 seq((2*n)!*coeff(ser, z, 2*n), n=0..16);
%o A326328 (PARI) a(n) = my(x='x+O('x^(2*n+1))); (2*n)!*polcoef(1/cosh(x)^3, 2*n); \\ _Seiichi Manyama_, Apr 21 2026
