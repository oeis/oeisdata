%S A242933 2,16,28,36,40,50,52,64,66,70,76,78,88,92,96,100,112,116,120,124,126,
%T A242933 130,136,144,148,154,156,160,162,170,172,176,184,186,188,190,196,204,
%U A242933 208,210,216,220,222,232,236,238,244,246,248,250,256,260,266,268,276,280,286
%N A242933 Even numbers m such that m*k/(k+m) is never prime for all k.
%C A242933 If m were an odd number, k*m/(k+m) would never be prime for all k; these are trivial and are not included. See A242932.
%C A242933 It is believed that numbers in A016742 (except 4) are members of this sequence.
%C A242933 This is true (see Fried link). - _Sela Fried_, Mar 23 2026
%H A242933 Sela Fried, <a href="/A242933/a242933.pdf">Proof of a conjecture stated in A242933</a>, 2026.
%e A242933 16*k/(16+k) is an integer for k = 16, 48, 112, and 240. These k-values give the integers 8, 12, 14, and 15, respectively. Since none are prime, 16 is a member of this sequence.
%o A242933 (PARI) f(n)=for(k=1,n*(n-1),s=(k*n)/(k+n); if(floor(s)==s,if(ispseudoprime(s),return(k)))) \\ A242834
%o A242933 n=1; while(n<300,if(f(2*n)==0,print1(2*n,", ")); n+=1)
%Y A242933 Cf. A242932, A242834.
%K A242933 nonn,changed
%O A242933 1,1
