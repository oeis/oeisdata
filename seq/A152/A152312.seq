%N A152312 Primes without odd prime digits.
%H A152312 Ashaz Jameel, <a href="/A152312/b152312.txt">Table of n, a(n) for n = 1..10000</a>
%t A152312 Select[Prime[Range[250]], FreeQ[IntegerDigits[#], 3 | 5 | 7] &] (* _Paolo Xausa_, Mar 03 2026 *)
%o A152312 (Python)
%o A152312 from sympy import isprime
%o A152312 from itertools import count, islice, product
%o A152312 def agen(): # generator of terms
%o A152312     yield 2
%o A152312     for d in count(2):
%o A152312         for first in "124689":
%o A152312             for mid in product("0124689", repeat=d-2):
%o A152312                 for last in "19":
%o A152312                     if isprime(t:=int(first + "".join(mid) + last)):
%o A152312                         yield t
%o A152312 print(list(islice(agen(), 52))) # _Michael S. Branicky_, Feb 26 2026
