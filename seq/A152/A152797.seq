%H A152797 Paul D. Hanna, <a href="/A152797/b152797.txt">Table of n, a(n) for n = 0..85</a>
%o A152797 (PARI) \\ Generate A152795 Using Matrix Products
%o A152797 {A152795(n, k) = my(M=matrix(2, 2, r, c, if(r>=c, 1)), D, L, S); for(i=2, n,
%o A152797 D = matrix(#M, #M, r, c, if(r==c, 2^(r-1))); \\ D = Diagonal of powers of 2
%o A152797 L = M - M^0; \\ L = M without diagonal of 1's
%o A152797 S = M + L*D*L; \\ S = New matrix, shifted up 1 row and 1 column
%o A152797 M = matrix(#M+1, #M+1, r, c, if(c==1, 1, if(r==1, 0, S[r-1, c-1])) ));
%o A152797 TM = M; M[n+1, k+1]}
%o A152797 \\ Print up to n terms from column 2 of triangle A152795
%o A152797 {upto(n) = A152795(n+2, 2); for(r=0, n, print1(TM[r+3, 3], ", "))}
%o A152797 upto(20) \\ - Paul D. Hanna, Jul 14 2026
