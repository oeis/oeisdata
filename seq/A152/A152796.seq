%U A152796 10407899725137769634427,28707447266050669790599803,147248797277103732587507718779,1410808673457013948221704611011195,25349526018761122174269487916246604411
%N A152796 Column 1 of triangle A152795.
%H A152796 Paul D. Hanna, <a href="/A152796/b152796.txt">Table of n, a(n) for n = 0..90</a>
%F A152796 a(n) = A152795(n+1,1) for n >= 0. - _Paul D. Hanna_, Jul 14 2026
%o A152796 (PARI) \\ Generate A152795 Using Matrix Products
%o A152796 {A152795(n, k) = my(M=matrix(2, 2, r, c, if(r>=c, 1)), D, L, S); for(i=2, n,
%o A152796 D = matrix(#M, #M, r, c, if(r==c, 2^(r-1))); \\ D = Diagonal of powers of 2
%o A152796 L = M - M^0; \\ L = M without diagonal of 1's
%o A152796 S = M + L*D*L; \\ S = New matrix, shifted up 1 row and 1 column
%o A152796 M = matrix(#M+1, #M+1, r, c, if(c==1, 1, if(r==1, 0, S[r-1, c-1])) ));
%o A152796 TM = M; M[n+1, k+1]}
%o A152796 \\ Print up to n terms from column 1 of triangle A152795
%o A152796 {upto(n) = A152795(n+1, 1); for(r=0, n, print1(TM[r+2, 2], ", "))}
%o A152796 upto(20) \\ - _Paul D. Hanna_, Jul 14 2026
