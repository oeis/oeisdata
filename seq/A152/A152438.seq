%N A152438 a(n) = (19^n - 1)/(9*2^(3 - 2*(n mod 2))).
%H A152438 Ray Chandler, <a href="/A152438/b152438.txt">Table of n, a(n) for n = 0..782</a>
%H A152438 <a href="/index/Rec#order_04">Index entries for linear recurrences with constant coefficients</a>, signature (0,362,0,-361).
%e A152438 From _Elmo R. Oliveira_, Mar 31 2026: (Start)
%e A152438 G.f.: x*(1 + 5*x + 19*x^2)/((1 - x^2)*(1 - 361*x^2)).
%e A152438 a(n) = (19^n - 1)*(5 - 3*(-1)^n)/144.
%e A152438 a(n) = 362*a(n-2) - 361*a(n-4). (End)
%t A152438 a[n_] :=(19^n - 1)/(9*2^(3 - 2*Mod[n, 2]));
%t A152438 Table[a[n], {n, 0, 30}]
