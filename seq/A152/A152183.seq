%I A152183 #12 Apr 12 2026 16:42:48
%S A152183 1,23,769,5817,93907,1154762,13192642
%N A152183 Number of overlapping n-digit blocks of the golden ratio phi = (sqrt(5)+1)/2 needed to see all 10^n possibilities.
%t A152183 Clear[ f ]; f[ 0 ] := 1; f[ n_Integer /; n > 0 ] := Module[ {i, cnt, m, p}, i = 0; cnt = 0; m = Table[ 0, {10^n} ]; p = Map[ FromDigits, Partition[ First[ RealDigits[ GoldenRatio, 10, 20*10^n ] ], n, 1 ] ] + 1; Catch[ Map[ ( i++; If[ m[ [ # ] ] == 0, m[ [ # ] ] = 1; If[ ++cnt == 10^n, Throw[ i ] ] ]) &, p ] ] ]; Table[ f[ n ], {n, 0, 4} ]
%Y A152183 Cf. A001622, A152182.
%K A152183 nonn,more,base
%O A152183 0,2
