%U A323948 33554431,67208864,168435456,234127718,536870921,1247483648,2073742814,4194967196,8589934591,27279869284,34359738368,68729476736,174877906944
%N A323948 The numbers 2^n with 1's and 2's swapped, then sorted.
%H A323948 Robert Israel, <a href="/A323948/b323948.txt">Table of n, a(n) for n = 0..3311</a>
%p A323948 f:= proc(x) local L,i;
%p A323948   L:= subs([1=2,2=1],convert(x,base,10));
%p A323948   add(L[i]*10^(i-1),i=1..nops(L))
%p A323948 end proc:
%p A323948 N:= 20: # for terms < 10^N
%p A323948 sort(map(f, [seq(2^i,i=0..ilog2(10^N))])); # _Robert Israel_, May 21 2026
%Y A323948 Cf. A000079, A306392.
%K A323948 nonn,base,changed
%O A323948 0,2
