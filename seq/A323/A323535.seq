%U A323535 148305406398618918682372310424354816000000,4049882681498254991937037064898924144230400000000,137651993399006086593846978063252515678682995490816000000
%N A323535 a(n) = Product_{k=1..n} (binomial(k-1,7) + binomial(n-k,7)).
%H A323535 Robert Israel, <a href="/A323535/b323535.txt">Table of n, a(n) for n = 0..105</a>
%F A323535 a(n) ~ exp(-7*n + (n-7)*(1 + c*Pi)) * n^(7*n) / (7!)^n, where c = 8*cos((Pi + arctan(2769*sqrt(3)/239))/6) / sqrt(21) = 1.2446281707164555154936427017... is the root of the equation 823543*c^6 - 3764768*c^4 + 4302592*c^2 - 692224 = 0.
%p A323535 f:= proc(n) local k;
%p A323535 mul(binomial(k-1,7) + binomial(n-k,7), k=1..n)
%p A323535 end proc:
%p A323535 map(f, [$0..25]); # _Robert Israel_, Jun 03 2026
%t A323535 Table[Product[Binomial[k-1,7] + Binomial[n-k,7], {k, 1, n}], {n, 0, 20}]
%o A323535 (PARI) a(n) = prod(k=1, n, binomial(k-1, 7) + binomial(n-k, 7)); \\ _Daniel Suteu_, Jan 17 2019
